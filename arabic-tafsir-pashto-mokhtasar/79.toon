tafsir[46]{c,v,t}:
  79,1,"الله پر هغو پرېښتو لوړه وکړه چې د کافرانو ساوې په سختۍ او تاوتريخوالي کشکوي."
  79,2,"او پر هغو پرېښتو يې لوړه وکړه چې د مؤمنانو ساوې په نرمۍ او آسانۍ وباسي."
  79,3,"او پر هغو پرېښتو يې لوړه وکړه چې د الله پر امر له آسمانه ځمکې ته غوټې وهي (راکوزيږي)."
  79,4,"او پر هغو پرېښتو يې لوړه وکړه چې د الله د امر په پرځای کولو کې له يو بل وړاندې کېږي."
  79,5,"او پر هغو پرېښتو يې لوړه وکړه چې الله هغوی ته له خپلې پرېکړې کوم امر کړی هغه پر ځای کوي لکه د بندګانو پر کړنو ګومارل شوې پرېښتې؛ پر دغو ټولو يې لوړه وکړه چې هرومرو به هغوی د حساب او بدلې لپاره راپورته کوي."
  79,6,"په کومه ورځ چې ځمکه له لومړي پوکي سره ولړزيږي."
  79,7,"په دغه پوکي پسې به بل دويم پوکی وي."
  79,8,"په دغه ورځ به د کافرانو او بې لارو خلکو زړونه په وېره کې وي."
  79,9,"پر سترګو به يې د رسوايۍ اغېز ښکاري."
  79,10,"او هغوی به وايي: آيا وروسته تر دې چې مړه شوو بېرته ژوند ته نه ورګرځو؟!."
  79,11,"او کله چې موږ وراسته خالي هډوکي يو له دې وروسته بېرته ګرځو؟!."
  79,12,"هغوی ويل: کله چې وګرځو؛ نو دا خو ډېره تاواني ګرځېدنه ده، چې څښتن يې دوکه کړل شوی دی."
  79,13,"د بېرته راګرځېدو چاره آسانه ده، هغه خو يوازې پر پوکي د ګومارل شوې پرېښتې له لوري يوه چېغه ده."
  79,14,"نو بيا به ټول د ځمکې پر مخ ژوندي وي وروسته تر دې چې هغوی يې په ګېډه کې مړه وو."
  79,15,"اې رسوله! تاته د موسی خبر له خپل پالونکي او له خپل دښمن فرعون سره راغلی؟!."
  79,16,"کله چې يې پالونکي د طوی په سپېڅلې شېله کې اواز ورته وکړ."
  79,17,"له هغه ویناوو چې هغه ته يې وکړې دا وه چې: فرعون ته ورشه، پرته له شکه هغه په تيري او لويۍکې له بريده اوښتی دی."
  79,18,"هغه ته ووايه: اې فرعونه! آيا ته غواړې چې له کفر او ګناهونو پاک شې؟."
  79,19,"او خپل هغه پالونکي ته دې لارښوونه وکړم چې پيدا کړی يې یې او خيال  دې ساتلی؛ نو ترې ووېرېږې، داسې کار وکړې چې راضي يې کړې، او له هغه څه ځان وساتې چې په غوسه کوي يې؟."
  79,20,"نو بيا موسی عليه السلام هغه ته لويه نښانه وښوده چې پر دې خبره يې دلالت کولو چې هغه د خپل پالونکي له لوري يې رسول دی، او هغه لاس او لکڼه وو."
  79,21,"نو د فرعون له لوري بل څه نه و مګر دا چې دغه نښانه يې درواغ وګڼله او په هغه څه کې يې له موسی عليه السلام سرغړونه وکړه چې امر يې ورته کړی و."
  79,22,"بيا يې پر هغه څه له له ايمان راوړلو مخ واوړي چې موسی عليه السلام ورسره راغلی و د الله په سرغړونه او د حق سره په معارضه کې په هڅه کولو سره."
  79,23,"نو هغه خپل قوم او پيروان را ټول کړل پر موسی عليه السلام د برلاسه کېدو لپاره او په لوړ اواز يې وويل:"
  79,24,"زه مو تر ټولو لوړ پالونکی يم، نو له ما پرته پر تاسو د بل چا پيروي نشته."
  79,25,"نو الله هغه ونيوی، په دنيا کې يې په درياب کې په ډوبلو عذاب ورکړ، او په آخرت کې تر ټولو سخت عذاب ته په ننه اېستلو سره یې عذاب ورکړ."
  79,26,"پرته له شکه پر کوم څه مو چې فرعون ته په دنيا او آخرت کې عذاب ورکړ په هغو کې د هغه چا لپاره پند دی چې له الله وېريږي؛ نو همغه له نصيحتونو ګټه پورته کوي."
  79,27,"اې د بېرته را ژوندي کولو درواغ ګڼونکو! آيا ستاسې پيداکول سخت دي، او که د هغه آسمان چې جوړ کړی يې دی؟!."
  79,28,"د هغه چت يې په پورته خوا کې لوړ ګرځولی، او برابر کړی يې دی، چې نه کمی پکې شته، نه څېرې والی او نه کوم عيب."
  79,29,"او د هغه شپه يې تياره کړې ده، کله چې لمر ولويږي، او رڼا يې ښکاره کړې ده کله چې لمر را پورته شي."
  79,30,"او ځمکه يې وروسته له هغه وغوړوله چې آسمان يې پيداکړ، او په هغې کې يې ګټې کښېښودلې."
  79,31,"او له هغې يې د اوبو داسې چينې را واېستلې چې بهيږي، او داسې شينګياوې يې پکې را شنې کړې چې خزندې پکې څري."
  79,32,"او غرونه يې پر ځمکه ثابت وګرځول."
  79,33,"اې خلکو! دا ټول ستاسو لپاره ګټې دي او ستاسو د څارويو لپاره، چاچې دا ټول پيداکړي دي هغه يې له بېرته راګرځولو څخه نه بې وسې کيږي."
  79,34,"نو کله چې هغه دويم پوکی راشي چې هر څه به په وېره سره پټ کړي او قيامت را منځته شي."
  79,35,"په کومه ورځ چې هغه راشي انسان ته به هر هغه عمل ور په ياد شي چې مخکې يې کړی وي هغه که ښه وي او که بد."
  79,36,"او دوزخ به راوړل شي او مخامخ به ښکاره کړل شي هغه چاته چې ويني يې."
  79,37,"نو څوک چې په لار ورکۍ کې له بريده اوښتی وي."
  79,38,"او د دنيا پاتې کېدونکي ژوند ته يې د آخرت پر تلپاتې ژوند لومړيتوب ورکړی وي."
  79,39,"پرته له شکه اور به يې هغه استوګنځی وي چې ورځي به."
  79,40,"نو څوک چې د خپل پالونکي په مخکې له درېدلو ډار شوی وي او ځان يې د هوسونو له پيروۍ را ګرځولی وي کوم چې الله حرام کړي دي، د هغه لپاره استوګنځی جنت دی چې ورځي به."
  79,41,"79:40"
  79,42,"اې رسوله! دغه د بېرته راژوندي کېدو درواغ ګڼونکي پوښتنه درڅخه کوي چې قيامت به کله را منځته کيږي؟."
  79,43,"تا لره پر هغه پوهه نشته چې هغوی لره يې ياد کړې، او نه دا ستا کار دی، ستا کار يوازې د هغه لپاره چمتووالی دی."
  79,44,"يوازې ستا د پالونکي لوري ته د هغه د پوهې پای دی."
  79,45,"ته يوازې د هغه چا وېروونکی يې چې له قيامته وېريږي، ځکه همغه ستا پر وېرونه ګټه اخلي."
  79,46,"کله چې هغوی قيامت مخامخ وويني، داسې به وي لکه د دنيا په ژوند کې يې چې يوازې يو ماښام او يا يو سهار تېر کړی وي."
