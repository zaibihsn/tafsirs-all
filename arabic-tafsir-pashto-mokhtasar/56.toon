tafsir[96]{c,v,t}:
  56,1,"او کله چې هرومرو قيامت را منځته شي."
  56,2,"هيڅوک به ونه موندل شي چې هغه درواغ وګڼي لکه څنګه يې چې په دنيا کې درواغ ګڼل کېدی."
  56,3,"بې لارې کافرانو لره اور ته په ننه اېستلو سره ښکته کوونکی دی، هغه مؤمنانو لره چې ځان ساتونکي دي د هغوی جنت ته په ننه اېستلو سره پورته کوونکی دی."
  56,4,"کله چې ځمکه په لويه لړزه ولړزول شي."
  56,5,"او غرونه ميده ميده ورژول شي."
  56,6,"نو هغه غرونه له رژولو څخه خور ګرد شي چې هيڅ قرار ورلره نه وي."
  56,7,"او په دغه ورځ کې به تاسې درې ډوله وئ."
  56,8,"نو هغه د ښي لاس خلک چې خپلې عملنامې يې په ښي اخلي، څومره د لوړې او لويې مرتبې والا دي!"
  56,9,"او د کيڼ لاس خلک چې خپلې عملنامې په کيڼ لاس اخلي، څومره سپک او بدې مرتبې والا دي!"
  56,10,"او هغه کسان چې په دنيا کې د ښېګڼو په کولو مخکې کېدونکي دي همغوی په آخرت کې جنت ته په ننوتلو مخکې کېدونکي دي."
  56,11,"همدوی د الله په وړاندې نېږدې کړل شوي دي."
  56,12,"د نعمتونو والا په جنتو کې به وي، چې په ډول ډول نعمتونو به خوندونه اخلي."
  56,13,"يوه ډله به له دغه امته او له پخوانيو امتونو وي."
  56,14,"او په آخره زمانه کې به لږ خلک وي چې هغوی به له مخکېنيو نېږدې کړل شوو څخه وي."
  56,15,"پر داسې تختونو به وي چې له سرو زرو اوبدل شوي وي."
  56,16,"پر دغو تکيو به يوبل ته مخامخ ډډه وهونکي ناست وي، يو به د بل څټ نه ويني."
  56,17,"پر هغوی به د خدمت لپاره يې داسې هلکان تاويږي چې زوړوالی او پای ته رسېدل به نه ورته رسيږي."
  56,18,"پر هغوی به له داسې ګيلاسونو سره تاويږي چې لاستي نه لري او له داسې کوزو سره چې لاستي به لري، او د داسې روانو شرابو له پیالو سره چې هيڅ به نه ختميږي."
  56,19,"د دنيا د شرابو غوندې به نه وي، چې څښونکي ته به يې سرخوږی نه رسيږي، او نه به يې عقل له منځه ځي."
  56,20,"او پر هغوی به دغه هلکان له داسې مېوو سره تاويږي چې هغوی يې خوښوي."
  56,21,"او د مارعانو له غوښو سره تاويږي چې زړونه يې غواړي."
  56,22,"او هغوی لره به په جنت کې په ښايست کې پراخه سترګو والا مېرمنې وي."
  56,23,"د ملغرو غوندې په پوښ کې ساتل شوې"
  56,24,"دا د هغوی لپاره د هغه څه بدله ده چې په دنيا کې يې کوم نېک عملونه کول."
  56,25,"په جنت کې به ناوړه خبره نه اوري، او نه داسې څه چې څښتن لره يې کومه ګناه وي."
  56,26,"هغوی به نه اوري مګر يوازې پرهغوی د پرېښتو سلام، او د ځينو سلام پر ځينو باندې."
  56,27,"او د ښي اړخ خلک به هغه کسان وي چې عملنامې يې په ښي لاسونو ورکړل شي، د هغوی به د الله په وړاندې ډېره لويه مرتبه او شان وي."
  56,28,"په داسې بېرو کې به وي چې اغزي يې ترې پرې کړل شوي وي او هيڅ ستنوزه پکې نه وي"
  56,29,"او په داسې يو پر بل پاسه له پاسه زياتو کيلو کې به وي."
  56,30,"او په داسې اوږده غځېدلي سيوري کې به وي چې نه ختميږي."
  56,31,"او په داسې روانو اوبو کې به وي چې نه دريږي."
  56,32,"او په داسې ډېرو مېوو کې چې نه منحصريږي."
  56,33,"له هغوی به هيڅکله نه ختميږي، هغو لره به موسم نه وي، او نه به په هيڅ وخت کې د هغوی په مخکې خنډ راځي چې هغوی دغ مېوې غواړي."
  56,34,"او په اوچتو لوړو داسې فرشو کې به وي چې پر تکيو اېښودل شوي وي."
  56,35,"پرته له شکه موږ دغه يادې حورې په يو غير عادي پيداکولو سره پيداکړې دي."
  56,36,"هغوی مو داسې پېغلې ګرځولې دي چې له دې مخکې هيڅ لمس شوې هم نه دي."
  56,37,"خپلو مېړونو ته به يې ګرانې وي، په عمر کې به ورسره برابرې وي."
  56,38,"هغوی مو د هغو ښي لاس خلکو لپاره پيداکړې دي چې د ښي لاس خلک به يې اخلي د هغوی د نېکمرغۍ د نښې په توګه."
  56,39,"هغوی د پخوانيو نبيانو له ډلې څخه دي."
  56,40,"او بله ډله د محمد صلی الله عليه وسلم له امت څخه چې هغه تر ټولو وروستی امت دی."
  56,41,"او د ګيڼ اړخ خلک به هغه کسان وي چې عملنامې يې په چپو لاسونو ورکړل شي، د هغوی به ډېر بد حال او د ورګرځېدو ځای وي."
  56,42,"په سختو ګرمو بادونو، او په سختو ګرمو اوبو کې به وي."
  56,43,"او د تک تور دود په سيوري کې به وي."
  56,44,"نه به خوندور چلېدونکی وي او نه ښه منظر والا."
  56,45,"پرته له شکه دې عذاب ته له ور ګرځېدو مخکې هغوی په دنيا کې په نعمتونو کې وو، يوازې د خپلو نفسي غوښتنو په غم کې يې وو."
  56,46,"او هغوی پر الله د کفر کولو او له هغه پرته د بوتانو لمانځلو ټينګ هوډ لرلو."
  56,47,"او هغوی له بېرته را ژوندي کېدو څخه نټه کوله، د ملنډو او لېرې ګڼلو په توګه به يې ورته ويل: کله چې موږ مړه شو، خاورې وراسته هډوکي وګرځو؛ نو له دغه وروسته به بيا را پاڅېږو؟!"
  56,48,"او آيا زموږ لومړني پلرونه چې له موږ مخکې مړه شوي دي هغوی به هم بيا را څول کيږي؟!"
  56,49,"ای رسوله! دغو له بېرته را پاڅېدو څخه نټه کوونکو ته ووايه: پرته له شکه لومړني خلک او له هغوی وروستني (ټول به)."
  56,50,"هرومرو به هغوی د قيامت په ورځ د حساب او بدلې لپاره را غونډ کړل شي."
  56,51,"بيا اې د بېرته را پورته کېدو نټه کوونکو چې له نېغې لارې لار ورکي ياست د قيامت په ورځ به د زقوم له ونې د مېوې خوړونکي ياست په داسې حال کې چې هغه تر ټولو بده او خبيثه مېوه ده."
  56,52,"بيا ای د بېرته را پورته کېدو نټه کوونکو چې له نېغې لارې لار ورکي ياست د قيامت په ورځ به د زقوم له ونې د مېوې خوړونکي ياست په داسې حال چې هغه تر ټولو بده او خبيثه مېوه ده."
  56,53,"او له دغې ترخې ونې به خپلې وږې ګېډې ډکوونکي ياست."
  56,54,"بيا به له سختو ګرمو اوبو څښونکي وي."
  56,55,"او له هغه به زيات څښونکي وي لکه اوښان چې د سختې تندې له امله زيات څښاک کوي."
  56,56,"دغه ياد شوي ترخه خواړه او ګرم څښاک د هغوی هغه مېلمستيا ده چې د بدلې په ورځ به يې هرکلی پرې کيږي."
  56,57,"ای درواغ ګنونکو! موږ تاسې پيداکړئ وروسته تردې چې تاسو نشته وئ، نو ولې باور نه کوئ چې موږ تاسو له مرګ وروسته مو بېرته ژوندي را پورته کوو؟!"
  56,58,"ای خلکو! هغه مني مو ليدلي چې د خپلو مېرمنو په رحمونو کې يې څڅوئ؟!"
  56,59,"آيا تاسې دغه مني پيداکوئ، او که موږ يې پيداکوونکي يو؟"
  56,60,"موږ ستاسو ترمنځ مرګ ټاکلی، ستاسو هر يوه لپاره ټاکلې نېټه ده چې له هغې نه مخکې کيږي او نه وروسته کيږي، او موږ عاجزه کېدونکي نه يو."
  56,61,"چې ستاسې هغه حالت به بدل کړو پر کوم پيدايښت او تصوير چې ياست چې پرې پوه ياست او له نوي سره به مو داسې پيداکړو چې پر هغه پيدايښت او صورت تاسې نه پوهېږئ."
  56,62,"او پرته له شکه تاسې پوه ياست چې ستاسې لومړنی پيدايښت مو څنګه کړی دی، نو آيا پند نه اخلئ او نه پوهېږئ چې چا لومړی ځل پيداکړي ياست هغه ستاسو له مرګ وروسته په بېرته را پاڅولو ځواکم دی؟!"
  56,63,"نو آيا د هغه تخم خبر به راکړئ چې په ځمکه کې يې اچوئ؟!"
  56,64,"آيا تاسې هغه څوک ياست چې دغه تخم را شين کوئ، او که موږ يې شين کوو؟!"
  56,65,"که موږ د دغه کښت ټوټه ټوټه کول وغواړو هرومرو به يې وروسته تردې ټوټه ټوټه کړو چې پخېدو او رسېدو ته نېږدې شوی وي، نو وروسته تردې له هغه څه تعجب کوئ چې ورته ورسېدل."
  56,66,"وايئ به: پرته له شکه موږ په عذابېدونکي يو د هغه څه په له لاسه ورکولو سره چې لګولي مو دي."
  56,67,"بلکې موږ بيخي له روزي بې برخې يو."
  56,68,"آيا هغه اوبه مو ليدلې دي چې څښئ يې کله چې تږي شئ؟!"
  56,69,"آيا تاسې په آسمان کې ورېځې نازلې کړې دي، او که موږ هغه څوک يو چې نازلې کړې مو دي؟!"
  56,70,"که موږ د دغو اوبو سخت ترېووالی غوښتی چې د څښلو او بل ته د ورکولو ګټه نه ترې پورته کېدلای هرومرو به مو سخته تروې ګرځولې وای، نو ولې د هغو پر خوږو اورولو د الله شکر نه باسئ چې پر تاسو يوه لورېينه ده."
  56,71,"آيا هغه اور مو ليدلئ چې تاسو يې د خپلو ګټو لپاره بلوئ؟!"
  56,72,"آيا تاسو د هغې ونه پيداکړې چې بلول کيږي، او که موږ يې پيداکوونکي يو پر تاسو د مهربانۍ له مخې؟!"
  56,73,"موږ دغه اور ستاسو لپاره پند ګرځولی چې تاسو ته د آخرت اور در په يادوي، او له تاسو څخه مو مسافرو ته ګتور ګرځولی دی."
  56,74,"نو ای رسوله! د خپل لوی پالونکي پاکي بيانوه له هغه څه څخه چې وړ يې نه دی."
  56,75,"الله د ستورو په ځايونو او موقعيتونو لوړه کوي."
  56,76,"او پرته له شکه پر دغو ځايونو لوړه کول که چېرې تاسو د هغه پر لوی والي پوهېږئ ډېر لوی قسم دی، ځکه په هغو کې داسې نښانې او پندونه دي چې نه منحصره کيږي."
  56,77,"پرته له شکه ای خلکو! پر تاسو لوستل شوی قران يو عزتمن قرآن دی، ځکه په هغو کې لويې ګټې دي."
  56,78,"د خلکو له سترګو په ساتل شوي کتاب کې دی، چې هغه لوح محفوظ دی."
  56,79,"هغه ته له ګناهونو او عيبونو پاکو پرېښتو پرته بل څوک لاس نه ور وړي."
  56,80,"د مخلوقاتو د پالونکي له لوري پر نبي محمد صلی الله عليه وسلم نازل شوی دی."
  56,81,"نو آيا اې مشرکانو! تاسو د دغې خبرې درواغ ګڼونکي ياست رېښتيني ګڼونکي يې نه ياست؟!"
  56,82,"او له الله سره په هغه څه کې شرک کول چې هغه تاسو ته کوم نعمتونه دررکړي پرته له شکه تاسې هغه درواغجن ګڼئ، چې باران د نوء په نوم ستوري ته يې منسوبو، نو وايي: پر موږ د فلاني ستوري له امله واورېدل او يا فلاني ستوري له امله."
  56,83,"نو ولې هغه وخت چې روح مرۍ ته ورسيږي."
  56,84,"او په دغه وخت کې تاسو په خپلو مخونو کې حاضر کړل شوی وينئ."
  56,85,"او موږ د خپلې پوهې، خپل ځواک او خپلو پرېښتو له اړخه ستاسو مړي ته له تاسو زيات ور نېږدې يو، خو تاسو دغه پرېښتې نه وينئ."
  56,86,"نو که تاسو ګومان کوئ چې د خپلو کړنو د بدلې لپاره به نه را پاڅول کېږئ."
  56,87,"دغه روح چې ستاسو له مړي څخه وزي ولې نه راستنوئ که تاسې رېښتيني ياست؟! او تاسې دا نه شئ کولای."
  56,88,"نو که هغه مړی ښېګڼو ته له مخکې کېدونکو څخه وي."
  56,89,"نو هغه لره به داسې هوسايي چې له هغه وروسته به ستړيا نه وي، ښه روزي، لورېينه، او هغه لره داسې جنت وي چې په هغه څه به خوندونه اخلي چې زړه يې غواړي."
  56,90,"او که هغه مړی د ښي لاس خلکو څخه وي؛ نو پر حالت يې مه خپه کېږه، هغوی لره سلامتي او امن دی."
  56,91,"56:90"
  56,92,"او که هغه مړی د هغه څه له درواغ ګڼونکو څخه وي چې رسول صلی الله عليه وسلم ورسره راغلی له نېغې لارې څخه لار ورکی وي."
  56,93,"نو د هغه مېلمستيا چې هرکلی به يې پرې کيږي سختې ګرمې اوبه به وي."
  56,94,"او هغه لره به د دوزخ په اور سوزول وي."
  56,95,"ای رسوله! دغه څه چې موږ يې کيسه درته بيان کړه، هرومرو داسې باوري حق دی چې هيڅ شک پکې نشته."
  56,96,"نو د خپل لوی پالونکي په نوم دې پاکي بيانوه، او له عيبونو يې پاکي بيانوه."
