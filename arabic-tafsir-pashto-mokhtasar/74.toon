tafsir[56]{c,v,t}:
  74,1,"اې په خپلو جامو کې ځان پټوونکیه! ( او هغه نبي صلی الله عليه وسلم دی)."
  74,2,"پاڅېږه او د الله له عذابه وېرول وکړه."
  74,3,"او د پالونکي لويي دې بيان کړه."
  74,4,"او ځان دې له ګناهونو پاک کړه او جامې دې له پليتيو پاکې کړه."
  74,5,"او د بوتانو له لمانځنې لرې اوسه."
  74,6,"او پر خپل پالونکي دې احسان مه باروه چې دې نېک عمل زیات ګڼې"
  74,7,"او له کومې ستونزې سره چې مخ کېږې خپل پالونکي ته صبر پرې کوه."
  74,8,"نو کله چې په ښکر (شپېلۍ) کې دويم ځل پوکړل شي."
  74,9,"بیا دغه ورځ سخته ورځ وي."
  74,10,"پر هغو کسانو چې پر الله او د هغه پر رسولانو يې کفر کړی وي آسانه به نه وي."
  74,11,"اې رسوله! ما او هغه څوک سره پرېږده چې د مور په ګېده کې مې يې يوازې پرته له مال او اولاده پيدا کړی (چې هغه د مغيره زوی وليد دی)."
  74,12,"او هغه لره مې ډېر مال ورکړ."
  74,13,"او هغه لره مې له هغه سره حاضر زامن پيداکړل چې په محفلونو کې ورسره حاضريږي د هغه د زيات مال له امله د سفر لپاره نه ورڅخه بېليږي."
  74,14,"او هغه لره مې په ژوند، روزۍ او اولاد کې پراخه پراخي ورکړه."
  74,15,"بيا هم هغه پر ما د خپل کفر له امله هيله لري چې زه به هغه ته ور زيات کړم وروسته تردې چې دغه ټول مې ورکړي دي."
  74,16,"چاره به داسې نه وي لکه څنګه چې هغه فکر کړی، پرته له شکه هغه زموږ پر رسول زموږ لخوا د نازل کړل شويو آيتونو لپاره ضد کوونکی د هغو درواغ ګڼونکی و."
  74,17,"ژر به هغه پر داسې سخت عذاب مکلف کړم چې زغملی به يې نه شي."
  74,18,"دغه کافر چې پورته نعمتونه مو پرې لورولې و، فکر یې وکړ چې د قران د غلط ثابتولو لپاره څه ووایې، په سوچ کې یې پدې اړه اټکل وکړ."
  74,19,"د الله له رحمتې دې لیرې وي او په عذاب دې کړای شي، څرنګه اندازه یې ولګوله."
  74,20,"بيا دې پرې لعنت وي او په عذاب دې شي څنګه خبره يې جوړه کړه."
  74,21,"بيا يې په هغه څه کې بيا کتنه او فکر وکړ چې ويل يې."
  74,22,"بيا يې مخ تريو او بړوس کړ کله يې چې هغه څه ونه موندل چې په قرآن کې پرې عيب ووايي."
  74,23,"بيا يې ايمان ته شا کړه او د نبي صلی الله عليه وسلم له پيروۍ يې لویې وکړه."
  74,24,"نو ويې ويل: دا چې محمد ورسره راغلی د الله کلام نه دی، بلکې کوډې دي چې له بل څخه يې روايت کوي."
  74,25,"دا د الله کلام نه دی، بلکې د انسانانو خبرې دي."
  74,26,"ژر به دغه کافر د دوزخ له طبقو څخه يوې طبقې ته ننباسم، چې هغه سقر ده چې ګرمي به يې ګالي."
  74,27,"او اې محمده ته څه پوهېږې چې سقر حه دی؟!."
  74,28,"هغه له عذاب ورکړل شوي څخه هيڅ هم نه پریږدي مګر پرې راوړي، او نه يې پرېږدي، بيا راګرځي لکه څنګه چې و، بيا پرې راوړي، او همداسې يې تکراروي."
  74,29,"سخت سوځوونکی او د پوستکو بدلوونکی دی."
  74,30,"پر هغه نولس پرېښتې ګومارل شوې چې هغوی يې ساتونکې دي."
  74,31,"او موږ د دوزخ ساتونکي نه دي ګرځولي مګر پرېښتې، چې بشر د هغوی توان نه لري، او د هغوی دغه شمېر مو يوازې د هغو کسانو لپاره ازموينه ګرځولې ده چې پر الله يې کفر کړی، ترڅو هغه څه ووايي چې وايي يې، نو پر هغوی عذاب څو برابره کړي او ترڅو هغه يهود باور وکړي چې تورات ورکړل شوی او هغه نصارا چې انجيل ورکړل شوی دی، کله چې قرآن نازلېده د هغوی د کتابونو تصدیق کوونکی و، ترڅو د مؤمنانو ايمان زيات شي، کله چې هغوی له اهل کتابو سره موافق شي، يهود، نصار او مؤمنان شک نه کوي، او ترڅو په ايمان کې تردد کوونکي او کافران ووايي: الله پر دغه عجيب شمېر د څه اراده کړې ده، لکه له دغه شمېر څخه د منکر لار ورکي، او پر هغه د رېښتيني بلونکي لارښوونه، الله چې د چا لار ورکي وغواړي پرې لار ورکی کوي يې او د چا چې لارښوونه وغواړي لارښوونه يې پرې کوي، او ستا د پالونکي لښکرې د هغوی د زياتوالي له امله يوازې الله ته معلومې دي، او اور يوازې د بشر لپاره يوه يادونه ده چې د الله پاک عظمت پرې پېژني."
  74,32,"وينا داسې نه ده لکه څنګه چې ځينې مشرکان ګومان کوي چې د هغه ملګري د دوزخ د څوکيدارانو لپاره بسنه کوي ترڅو يې ترې وباسي، الله پر سپوږمۍ لوړه وکړه."
  74,33,"او په شپه يې لوړه وکړه کله چې وګرځي."
  74,34,"او پر سهار يې لوړه وکړه کله چې رڼا شي."
  74,35,"بېشکه د دوزخ اور يو له لويو بلاوو څخه دی."
  74,36,"د انسانانو لپاره ډاروونکی او وېروونکی دی."
  74,37,"اې خلکو! له تاسې څخه د هغه لپاره چې پر الله ايمان راوړلو او نېک عمل ته وړاندې کېدل غواړي او يا د کفر او ګناهونو له امله وروسته پاتې کېدل."
  74,38,"هر څوک په خپلو کړو اعمالو کې نيولی شوی دی، يا به يې اعمال تباه کوي او يا به يې خلاصوي او له تباهۍ به يې ژغوري."
  74,39,"پرته له مؤمنانو ځکه هغوی پر خپلو ګناهونو نه نيول کيږي، بلکې تر هغو ور تېريږي ځکه هغوی لره نېک عمل شته."
  74,40,"او هغوی به د قيامت په ورځ په جنتونو کې ځينې يې له ځينو پوښتنې کوي."
  74,41,"له هغو کافرانو څخه چې خپل ځانونه يې د ګناهونو په ترسره کولو تباه کړي دي."
  74,42,"هغوی به ورته وايي: څه شي دوزخ ننه اېستئ؟"
  74,43,"نو کافران به په دې ويلو سره ځواب ورکوي: موږ له هغو کسانو څخه نه وو چې د دنيا په ژوند کې يې فرضي لمنځونه کول."
  74,44,"او نه مو بې وزله ته خواړه ورکول کوم چې الله موږ ته راکړي و."
  74,45,"او له اهل باطل سره به تاوېدلو چېرې به چې هغوی تاوېدل، او د لارورکو او بې لارو سره مو خبرې کولې."
  74,46,"او د بدلې ورځ مو درواغ ګڼله."
  74,47,"او په درواغ ګڼلو کې مو زياته سرکښي وکړه تردې چې مرګ راته راغی، نو زموږ او د توبې ترمنځ خڼد وګرځېدی."
  74,48,"د قيامت په ورځ به له پرېښتو، نبيانو او نېکانو څخه د سپارښت کوونکو منځګړيتوب هغوی ته ګټه ونه رسوي، ځکه د سپارښتنې له شرطونو څخه دا دي چې د چا سپارښتنه کيږي له هغه به الله راضي وي."
  74,49,"څه شي دغه مشرکان له قرآنه مخ اړوونکي ګرځولي دي؟!."
  74,50,"هغوی په مخ اړولو او له هغه څخه په تېښته کې لکه وحشي خره داسې دي چې ډېر سخت ترېدلي وي."
  74,51,"له زمري څخه له وېرې تښتېدلي وي."
  74,52,"بلکې هر یو له دغو مشرکانو غواړي چې د هغه له سر سره دې داسې غوړېدلی کتاب وي چې پردې خبره يې خبروي چې محمد د الله له لورې رسول دی، د دې خبرې لامل د دلايلو کموالی او د حجتونو کمزوري نه ده، بلکې هغه عناد او لويي ده."
  74,53,"امر داسې نه دی، بلکې د هغوی په لارورکۍ کې د زيادت لامل دا دی چې هغوی د آخرت پر عذاب ايمان نه لري؛ نو پر خپل کفر پاتې دي."
  74,54,"خبر اوسئ بېشکه دغه قرآن يو نصيحت او ور يادوونکی دی."
  74,55,"نو څوک چې غواړي قرآن ولولي او نصيحت ترې واخلي ودې لولي او نصيحت دې ترې واخلي."
  74,56,"او يوازې هغه خلک ترې نصيحت اخېتسلای شي چې الله د هغوی نصيحت اخېستل وغواړي، الله پاک د دې وړ دی چې د هغه د امرونو په پرځای کولو او له نواهيوو يې په ډډه کول ترې وېره وشي، او د دې واک لري چې د بندګانو ګناهونه يې وبښي کله چې هغوی توبه ورته وباسي."
