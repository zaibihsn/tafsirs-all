tafsir[40]{c,v,t}:
  78,1,"دغه مشرکان وروسته له دې چې الله يې خپل رسول صلی الله عليه وسلم ورته ولېږلو د څه په اړه پوښنې سره کوي."
  78,2,"ځينې يې له ځینو د لوی خبر په اړه پوښتنې کوي او هغه دغه قرآن دی چې د هغوی پر رسول نازل کړل شوی د بېرته راپورته کېدو پر خبر مشتمل دی."
  78,3,"دغه قرآن چې هغوی يې په هکله په هغه څه اختلاف کړی چې د هغه لپاره يې بيانوي، چې هغه کوډې، يا شعر، يا کهانت (د غيب خبرې) او يا هم د پخوانيو کيسې دي."
  78,4,"داسې نه ده لکه څرنګه چې هغوی چې ګومان کړی، ژر به دغه د قرآن درواغ ګڼونکي د خپلو درواغ ګڼلو په بده پایله پوه شي."
  78,5,"بيا د هغوی لپاره د دې خبرې ټينګار کيږي."
  78,6,"آيا ځمکه مو د هغوی لپاره داسې فرش نه ده ګرځولې چې پر هغې د برکراره پاتې کېدو لپاره يې وړ وي؟!."
  78,7,"او غرونه مو پر هغې د مېخونو غوندې ګرځولي چې له خوځېدو يې را ګرځوي."
  78,8,"او اې خلکو! تاسو مو جوړې جوړې پيداکړي ياست: ځينې له تاسې نارينه او ځينې ښځينه دي."
  78,9,"او ستاسو خوب مو له له نشاط څخه پرېکون ګرځولی ترڅو آرام وکړئ."
  78,10,"او شپه مو ستاسو لپاره د هغې په تياره د هغه جامو غوندې پټوونکې ګرځولې چې خپل شرمځايونه پرې پټوئ."
  78,11,"او ورځ مو ډګر ګرځولې ده د کار او روزۍ پلټڼې لپاره."
  78,12,"او جوړ کړې مو دې ستاسې له پاسه اووه آسمانونه چې ودانۍ یې کلکه او جوړښت یې غښتلی دی."
  78,13,"او لمر مو یو سخت روښانه او رڼا والا ډېوه ګرځولې ده."
  78,14,"او هغه ته له نېږدې ورېځو مو د زياتو تویوونکو اوبو والا باران ورولی دی."
  78,15,"ترڅو پرې ډول ډول دانې او ډول ډول شينګياوې را وباسو."
  78,16,"او داسې باغونه پرې را وباسو چې د ونو څانګې يې په يو بل کې د زيات ننوتلو له امله سره نېښتې وي."
  78,17,"پرته له شکه د خلکو تر منځ د پرېکړې ورځ يو ژمنه شوی ټاکل شوی وخت دی چې شاتګ نه ترې کيږي."
  78,18,"په کومه ورځ چې پرېښته په ښکر کې د دويم ځل لپاره پوکی وکړي؛ نو اې خلکو! تاسې به ډلې ډلې راځئ."
  78,19,"او آسمان به پرانستل شي؛ نو هغه لره به د پرانېستو دروازو غوندې سوروي او سوړې وي."
  78,20,"او غرونه به داسې وچلول شي چې پر تيت ګرد به بدل شي، او رېګ غوندې به شي."
  78,21,"پرته له شکه دوزخ منتظر څارنځی دی."
  78,22,"د ظالمانو لپاره د ورګرځېدو ځای دی چې ور ګرځي به."
  78,23,"په هغو کې به دومره زياتې زمانې او وختونه اوسېدونکي وي چې هيڅ پای نه لري."
  78,24,"په هغو کې به نه يخه هوا څکي چې د دوزخ ګرمي ورڅخه يخه کړي، او نه به داسې څښاک چې خوند پرې واخلي."
  78,25,"يوازې سختې ګرمې اوبه به څکي، او هغه څه چې د دوزخيانو له زوو بهيږي."
  78,26,"هغه چې پر کوم کفر او لار ورکۍ و له هغې سره برابره بدله ده."
  78,27,"پرته له شکه هغوی په دنيا کې له هغوی سره په آخرت کې د الله له حسابه نه ډارېدل؛ ځکه هغوی پر بېرته را پورته کېدو باور نه لرلو، که چېرې هغوی له بېرته را پورته کېدو وېرېدلای هرومرو به يې پر الله ايمان راوړی و، او نېک عمل به يې کړی وای."
  78,28,"او زمو پر رسول نازل کړل شوي زموږ ايتونه يې په درواغ ګنلو سره درواغ ګڼلي وو."
  78,29,"او د هغوی له کړنو مو هرڅه ضبظ کړي او شمېرلي وو، او هغه يې د کړنو په پاڼو کې ليکل شوي وو."
  78,30,"اې سرکښانو! دغه تلپاتې عذاب وڅکئ، هيڅکله به در زيات نه کړو مګر پر عذاب مو بل عذاب."
  78,31,"پرته له شکه د هغو کسانو لپاره چې د خپل پالونکي د امرونو په پرځای کولو او له نواهيوو يې په ډډه کولو وېريږي، د هغوی لپاره د بريا ځای دی چې په خپله موخه کې به پکې بريالي کيږي او هغه جنت دی."
  78,32,"باغونه او انګور دي."
  78,33,"داسې پېغلې چې په عمر کې به ورسره برابرې وي."
  78,34,"او د شرابو ډکې پيالې"
  78,35,"په جنت کې به باطلې خبرې نه اوري، او نه درواغ اوري، او نه ځينې يې ځينونورو ته درواغ وايي."
  78,36,"دا هر څه به له هغه څه څخه وي چې الله پر هغوی احسان او بسنه کوونکې لورېينه کړې ده."
  78,37,"د آسمانونو او ځمکې پالونکی دی او د هغه څه رب دی چې د هغو دواړو ترمنځ دي، د دنيا او آخرت ډېر مهربان دی، او ټول چې په ځمکه کې او که په آسمان کې دي له هغه څخه پوښتنه نه شي کولای مګر داچې هغوی ته اجازه ورکړل شي."
  78,38,"په کومه ورځ چې جبرئيل او پرېښتې کتار کتار ودريږي، او هغوی به د هيچا د سپارښت لپاره خبرې نه شي کولای مګر چاته چې رحمان د سپارښت اجازه ورکړي، او هغه سمه خبره وکړي لکه د توحيد (يووالي) کلمه."
  78,39,"دغه ستاسو لپاره بيان شوې هغه ورځ ده چې په رامنځته کېدو کې يې هيڅ شک نشته، اوس چې څوک په هغې کې د الله له عذابه ځان ژغورل غواړي؛ نو د داسې نېکو اعمالو لوري ته دې لار غوره کړي چې خپل پالونکی راضي کوي."
  78,40,"اې خلکو! پرته له شکه موږ تاسو له هغه نېږدې عذابه وېرولي واست چې راځي به، په کومه ورځ چې به هر څوک په دنيا کې د خپل کړي عمل انتظار کوي، او کافر به له عذابه د خلاصون په هيله وايي: های کاشکي زه د څارويو غوندې خاورې ګرځېدلی وای کله چې هغو څارويو ته د قيامت په ورځ وويل شي: خاورې شئ."
