tafsir[22]{c,v,t}:
  85,1,""
  85,2,"শপথ প্রতিশ্রুত দিবসের। [১][১] সকলের মতেই এর উদ্দেশ্য হল কিয়ামত দিবস।"
  85,3,""
  85,4,""
  85,5,""
  85,6,""
  85,7,""
  85,8,""
  85,9,"আকাশমন্ডলী ও পৃথিবীর সার্বভৌমত্ব যাঁর। আর আল্লাহ সর্ববিষয়ের সম্যক দ্রষ্টা।"
  85,10,""
  85,11,""
  85,12,""
  85,13,""
  85,14,""
  85,15,""
  85,16,""
  85,17,""
  85,18,"ফিরআউন ও সামূদের?"
  85,19,"তবুও কাফেররা মিথ্যাজ্ঞান করায় রত।"
  85,20,"আর আল্লাহ তাদেরকে পরিবেষ্টন করে রয়েছেন।[১][১] এই আয়াত إِنَّ بَطشَ رَبِّكَ لَشَدِيد আয়াতেরই প্রতিপাদক এবং তাকীদস্বরূপ।"
  85,21,"বরং এটা গৌরবান্বিত কুরআন।"
  85,22,""
