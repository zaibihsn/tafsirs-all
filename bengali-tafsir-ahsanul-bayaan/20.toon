tafsir[135]{c,v,t}:
  20,1,"ত্ব-হা-।"
  20,2,""
  20,3,"বরং এমন ব্যক্তিকে উপদেশ দেওয়ার জন্য যে (আল্লাহকে) ভয় করে।"
  20,4,"এটা তাঁর নিকট হতে অবতীর্ণ; যিনি সমুচ্চ আকাশমন্ডলী ও পৃথিবী সৃষ্টি করেছেন।"
  20,5,""
  20,6,""
  20,7,""
  20,8,""
  20,9,"মূসার বৃত্তান্ত তোমার কাছে পৌঁছেছে কি?"
  20,10,""
  20,11,""
  20,12,""
  20,13,""
  20,14,""
  20,15,""
  20,16,""
  20,17,"হে মূসা! তোমার ডান হাতে ওটা কি?’"
  20,18,""
  20,19,""
  20,20,""
  20,21,""
  20,22,""
  20,23,""
  20,24,""
  20,25,""
  20,26,"এবং আমার কর্ম সহজ করে দাও।"
  20,27,"আমার জিহ্বার জড়তা দূর করে দাও।"
  20,28,"যাতে তারা আমার কথা বুঝতে পারে।"
  20,29,"আমার স্বজনবর্গের মধ্য হতে আমার জন্য একজন সহায়ক নিযুক্ত কর।"
  20,30,"আমার ভাই হারূনকে।"
  20,31,"তার দ্বারা আমার শক্তি সুদৃঢ় কর।"
  20,32,""
  20,33,"যাতে আমরা তোমার পবিত্রতা ও মহিমা ঘোষণা করতে পারি প্রচুর।"
  20,34,"এবং তোমাকে স্মরণ করতে পারি অধিক।[১][১] এখানে উক্ত দু'আ করার কারণ বলা হয়েছে। যাতে এইভাবে তোমার পয়গাম পৌঁছে দেওয়ার সাথে সাথে বেশী বেশী তোমার তসবীহ-যিকরও করতে পারি।"
  20,35,""
  20,36,""
  20,37,""
  20,38,"যখন আমি তোমার মায়ের অন্তরে ইঙ্গিত দ্বারা নির্দেশ দিয়েছিলাম যা ছিল নির্দেশ দেওয়ার।"
  20,39,""
  20,40,""
  20,41,"আমি তোমাকে আমার নিজের জন্য প্রস্তুত করে (মনোনীত করে) নিয়েছি।"
  20,42,""
  20,43,""
  20,44,""
  20,45,""
  20,46,""
  20,47,""
  20,48,""
  20,49,""
  20,50,""
  20,51,""
  20,52,""
  20,53,"যিনি তোমাদের জন্য পৃথিবীকে করেছেন বিছানা এবং তাতে করে দিয়েছেন তোমাদের চলবার পথ। তিনি আকাশ হতে বৃষ্টি বর্ষণ করেন এবং আমি তা দ্বারা বিভিন্ন প্রকারের উদ্ভিদ উৎপন্ন করি।"
  20,54,""
  20,55,""
  20,56,"আমি তো তাকে আমার সমস্ত নিদর্শন দেখিয়েছিলাম; কিন্তু সে মিথ্যাজ্ঞান করেছে ও অমান্য করেছে।"
  20,57,""
  20,58,""
  20,59,""
  20,60,""
  20,61,""
  20,62,""
  20,63,""
  20,64,"অতএব তোমরা তোমাদের কলা-কৌশল সুসংহত কর। তারপর সারিবদ্ধ হয়ে উপস্থিত হও। আজকে যে জয়ী হবে সেই হবে সফল।’"
  20,65,""
  20,66,""
  20,67,"মূসা তার অন্তরে কিছু ভয় অনুভব করল।"
  20,68,""
  20,69,""
  20,70,""
  20,71,""
  20,72,""
  20,73,""
  20,74,""
  20,75,""
  20,76,""
  20,77,""
  20,78,""
  20,79,""
  20,80,""
  20,81,""
  20,82,""
  20,83,"হে মূসা! তোমার সম্প্রদায়কে পশ্চাতে ফেলে তোমাকে ত্বরা করতে বাধ্য করল কিসে?"
  20,84,""
  20,85,""
  20,86,""
  20,87,""
  20,88,""
  20,89,""
  20,90,""
  20,91,""
  20,92,""
  20,93,""
  20,94,""
  20,95,""
  20,96,""
  20,97,""
  20,98,""
  20,99,""
  20,100,""
  20,101,"ঐ (পাপের শাস্তি)তে ওরা স্থায়ী হবে[১] এবং কিয়ামতের দিন এই বোঝা ওদের জন্য কত মন্দ হবে।[১] না ওরা তা হতে বাঁচতে পারবে আর না পালাতে।"
  20,102,""
  20,103,""
  20,104,""
  20,105,""
  20,106,"অতঃপর তিনি ভূমিকে মসৃণ সমতল ভূমিতে পরিণত করবেন।"
  20,107,"যাতে তুমি উঁচু-নীচু দেখবে না।’"
  20,108,""
  20,109,""
  20,110,""
  20,111,""
  20,112,""
  20,113,""
  20,114,""
  20,115,""
  20,116,""
  20,117,""
  20,118,""
  20,119,"সেখানে পিপাসার্ত হবে না এবং রোদ্র-ক্লিষ্ট ও হবে না।’"
  20,120,""
  20,121,""
  20,122,""
  20,123,""
  20,124,""
  20,125,""
  20,126,""
  20,127,""
  20,128,""
  20,129,""
  20,130,""
  20,131,""
  20,132,""
