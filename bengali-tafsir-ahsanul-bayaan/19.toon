tafsir[98]{c,v,t}:
  19,1,"কা-ফ হা ইয়া আ’ইন স্বা-দ।"
  19,2,"এটা তোমার প্রতিপালকের অনুগ্রহের বিবরণ তাঁর দাস যাকারিয়ার[১] প্রতি।[১] যাকারিয়া (আঃ) বানী ইস্রাঈলের একজন নবী ছিলেন। তিনি ছিলেন ছুতোর এবং এই পেশাই ছিল তাঁর জীবিকার একমাত্র উপায়।"
  19,3,""
  19,4,""
  19,5,""
  19,6,"যে উত্তরাধিকারী হবে আমার এবং উত্তরাধিকারী হবে ইয়াকূবের বংশের। আর হে আমার প্রতিপালক! তাকে তুমি সন্তোষভাজন কর।’"
  19,7,""
  19,8,""
  19,9,""
  19,10,""
  19,11,""
  19,12,""
  19,13,""
  19,14,""
  19,15,""
  19,16,"(হে রসূল!) তুমি এই কিতাবে (উল্লিখিত) মারয়্যামের কথা বর্ণনা কর; যখন সে তার পরিবারবর্গ হতে পৃথক হয়ে নিরালায় পূর্ব দিকে এক স্থানে আশ্রয় নিল।"
  19,17,""
  19,18,""
  19,19,""
  19,20,""
  19,21,""
  19,22,"অতঃপর সে গর্ভে সন্তান ধারণ করল ও তাকে নিয়ে এক দূরবর্তী স্থানে চলে গেল।"
  19,23,""
  19,24,""
  19,25,""
  19,26,""
  19,27,""
  19,28,""
  19,29,""
  19,30,""
  19,31,""
  19,32,""
  19,33,""
  19,34,""
  19,35,""
  19,36,""
  19,37,""
  19,38,"তারা যেদিন আমার নিকট আসবে সেদিন তারা কত স্পষ্ট শুনবে ও দেখবে![১] কিন্তু সীমালংঘনকারিগণ আজ স্পষ্ট বিভ্রান্তিতে রয়েছে।[১] এগুলি বিস্ময়সূচক শব্দ। অর্থাৎ পৃথিবীতে তারা সত্য দেখা হতে ও সত্য শোনা হতে অন্ধ ও বধির ছিল। কিন্তু কিয়ামতের দিন তারা খুব বেশী দেখতে ও শুনতে পাবে; যদিও এই বেশী দেখা ও শোনা তাদের কোনই কাজে লাগবে না।"
  19,39,""
  19,40,"নিশ্চয় পৃথিবী ও তাতে যা কিছু আছে তার চূড়ান্ত মালিকানার অধিকারী আমিই এবং তারা আমারই নিকট প্রত্যাবর্তিত হবে।"
  19,41,""
  19,42,""
  19,43,""
  19,44,""
  19,45,""
  19,46,""
  19,47,""
  19,48,""
  19,49,""
  19,50,""
  19,51,""
  19,52,"আমি তাকে আহবান করেছিলাম তূর পর্বতের ডান দিক হতে এবং আমি নিভৃত আলাপ করা অবস্থায় তাকে নিকটবর্তী করেছিলাম।"
  19,53,"আমি নিজ অনুগ্রহে তাকে দিলাম তার ভ্রাতা হারূনকে নবীরূপে।"
  19,54,""
  19,55,"সে তার পরিজনবর্গকে নামায ও যাকাত আদায়ের নির্দেশ দিত এবং সে ছিল তার প্রতিপালকের নিকট সন্তোষভাজন।"
  19,56,"এই কিতাবে (উল্লিখিত) ইদরীসের কথা বর্ণনা কর; সে ছিল একজন সত্যবাদী নবী।"
  19,57,""
  19,58,""
  19,59,""
  19,60,""
  19,61,""
  19,62,""
  19,63,"এ হল সেই জান্নাত যার অধিকারী করব আমি আমার দাসদের মধ্যে সংযমশীলকে।"
  19,64,""
  19,65,""
  19,66,""
  19,67,""
  19,68,""
  19,69,""
  19,70,""
  19,71,"তোমাদের প্রত্যেকেই তাতে প্রবেশ করবে; এটা তোমার প্রতিপালকের অনিবার্য সিদ্ধান্ত।"
  19,72,""
  19,73,""
  19,74,""
  19,75,""
  19,76,""
  19,77,""
  19,78,"সে কি অদৃশ্য সম্বন্ধে অবহিত হয়েছে অথবা পরম দয়াময়ের নিকট হতে প্রতিশ্রুতি লাভ করেছে?"
  19,79,""
  19,80,""
  19,81,""
  19,82,""
  19,83,""
  19,84,""
  19,85,""
  19,86,""
  19,87,""
  19,88,""
  19,89,""
  19,90,""
  19,91,"যেহেতু তারা পরম দয়াময়ের প্রতি সন্তান আরোপ করে।"
  19,92,"অথচ সন্তান গ্রহণ করা পরম দয়াময়ের জন্য শোভনীয় নয়।"
  19,93,""
  19,94,""
  19,95,""
  19,96,""
  19,97,""
  19,98,""
