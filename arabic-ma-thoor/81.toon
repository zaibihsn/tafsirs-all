quran[29]{c,v,t}:
  81,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨١٥٩٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، وذَكر أنها نزلت بعد <span class="qpc-hafs">﴿تَبَّتْ يَدا أبِي لَهَبٍ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٩٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: مكّيّة{2}. (١٥/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٩٥<span class="dash">-</span></span> عن عبد الله بن الزُّبير= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٩٦<span class="dash">-</span></span> وعن عائشة، مثله{3}. (١٥/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٩٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٩٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسمّياها <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٩٩<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٠<span class="dash">-</span></span> عن محمد بن مسلم الزّهري: مكّيّة، وسمّاها: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، وذكر أنها نزلت بعد <span class="qpc-hafs">﴿تَبَّتْ يَدا أبِي لَهَبٍ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠١<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٢<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة التكوير مكّيّة، عددها تسع وعشرون آية كوفي{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٣<span class="dash">-</span></span> عن محمد بن إسحاق في قصة إسلام عمر: أنّه طلب الصحيفة من أخته، فدَفعتْها إليه، وكان عمر يقرأ الكتاب، فقرأ طه حتى إذا بلغ: <span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها لتجزى كل نفس بما تسعى﴾</span> إلى قوله: <span class="qpc-hafs">﴿فتردى﴾</span> [طه:١٥-١٦]، وقرأ: <span class="qpc-hafs">﴿إذا الشمس كورت﴾</span> حتى بلغ: <span class="qpc-hafs">﴿علمت نفس ما أحضرت﴾</span> فأسلم عند ذلك عمر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٤<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>مَن سَرَّه أنْ ينظر إلى يوم القيامة كأنه رأيُ عين فليقرأ: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، و<span class="qpc-hafs">﴿إذا السَّماءُ انْفَطَرَتْ﴾</span>، و<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span></b>»{10}. (١٥/٢٥٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا ٱلشَّمۡسُ كُوِّرَتۡ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٠٥<span class="dash">-</span></span> عن أبي مريم، أنّ النبي ﷺ في قول الله: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span> قال: «<b>كُوِّرت في جهنم</b>». <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span> قال: «<b>انكدرت في جهنم، وكلّ مَن عُبِد مِن دون الله فهو في جهنم، إلا ما كان من عيسى ابن مريم وأُمّه، ولو رضيا أن يُعبدا لدخلاها</b>»{11}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٦<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>الشمس والقمر يُكوّران يوم القيامة</b>». زاد البزار في مسنده: «<b>في النار</b>»{12}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٧<span class="dash">-</span></span> عن أبى ذرّ الغفاري، قال: كنتُ آخذًا بيد رسول الله ﷺ، ونحن نتماشى جميعًا نحو المغرب، وقد طفلت الشمسُ، فما زلنا ننظر إليها حتى غابتْ، قال: قلت: يا رسول الله، أين تغرب؟ قال: «<b>تغرب في السماء، ثم تُرفع مِن سماء إلى سماء، حتى تُرفع إلى السماء السابعة العليا، حتى تكون تحت العرش، فتخرّ ساجدة، فتسجد معها الملائكة المُوكَّلون بها، ثم تقول: يا رب، مِن أين تأمرني أن أطلع؟ أمن مغربي أم من مطلعي؟».</b> قال: <b>«فذلك قوله ﷿: <span class="qpc-hafs">﴿والشمس تجرى لمستقر لها﴾</span> حيث تُحبس تحت العرش، <span class="qpc-hafs">﴿ذلك تقدير العزيز العليم﴾</span></b> [يس:٣٨]». قال: <b>«يعني: ذلك صنع الرّبّ العزيز في مُلكه العليم بخَلْقه».</b> قال: <b>«فيأتيها جبرائيل ﵇ بحُلّة ضوء مِن نور العرش، على مقادير ساعات النهار في طوله في الصيف، أو قِصره في الشتاء، أو ما بين ذلك في الخريف والربيع».</b> قال: <b>«فتلبس تلك الحُلّة كما يلبس أحدُكم ثيابه، ثم ينطلق بها في جوِّ السماء حتى تطلع من مطالعها</b>». قال النبيُّ ﷺ: «<b>فكأنها قد حُبستْ مقدار ثلاث ليالٍ، ثم لا تُكسى ضوءًا، وتؤمر أن تطلع مِن مغربها، فذلك قوله ﷿: <span class="qpc-hafs">﴿إذا الشمس كورت﴾</span></b>»{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٨<span class="dash">-</span></span> عن <span class="name-1">أُبيّ بن كعب</span> -من طريق أبي العالية- قال: ستُّ آيات قبل يوم القيامة؛ بينما الناس في أسواقهم إذ ذهب ضوء الشمس، فبينما هم كذلك إذ وقعت الجبال على وجه الأرض، فتحرّكتْ واضطربتْ واختلطتْ، ففَزعت الجنُّ إلى الإنس والإنس إلى الجن، واختلطت الدوابّ والطير والوحش، فماجوا بعضهم في بعض: <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span> قال: اختلطت، <span class="qpc-hafs">﴿وإذا العِشارُ عُطِّلَتْ﴾</span> أهملها أهلُها، <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span> قال الجنُّ للإنس: نحن نأتيكم بالخبر. فانطلقوا إلى البحر، فإذا هي نار تَأَجَّج، فبينما هم كذلك إذ تصدّعت الأرض صدعةً واحدة إلى الأرض السابعة وإلى السماء السابعة، فبينما هم كذلك إذ جاءتهم ريح فأماتتهم{14}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: أظْلَمَتْ{15}. (١٥/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: أُغْوِرَت{16}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>: يعني: ذهبت{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق بيان- في قوله: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: يُكَوِّرُ الله الشمسَ والقمرَ والنجومَ يومَ القيامة في البحر، ويبعث الله ريحًا دبورًا فتنفخه حتى يرجع نارًا{18}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق سفيان، عن أبيه، عن منذر الثوري- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: رُمِيَ بها{19}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span>، قال: سِتُّ آياتٍ مِن هذه السورة في الدنيا والناس ينظرون إليه، وستّ في الآخرة: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span> إلى: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span> هذه الدنيا والناس ينظرون إليه. <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span> إلى: <span class="qpc-hafs">﴿وإذا الجَنَّةُ أُزْلِفَتْ﴾</span> هذه الآخرة{20}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: هي بالفارسية: كُور{21}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق يعقوب القمي، عن جعفر- <span class="qpc-hafs">﴿كُوِّرَتْ﴾</span>، قال: غُوِّرتْ، وهي بالفارسية: كُور تكور{22}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: دُهْوِرَت{20}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: اضْمَحلَّتْ{24}. (١٥/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦١٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: ذهب ضوؤها{25}. (١٥/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فَضالة- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، يقول: تُكوّر حتى يذهب ضوؤها، فلا يبقى لها ضوءٌ{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: نُكِّسَتْ. وفي رواية: أُلْقِيَتْ{27}. (١٥/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>: ذهب ضوؤها، فلا ضوء لها{28}. (١٥/٢٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق مسلم الزنجي- <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>: ذهب ضوؤها{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span> فذهب ضوؤها{30}<span class=comment-ref>٧٠٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٠</span> في قوله: <span class="qpc-hafs">﴿كورت﴾</span> قولان: <b>الأول</b>: ذهب ضوؤها. <b>الثاني</b>: رُمي بها.</p><p>وقد <span class="comment-type-4">جمع</span> بينهما <u>ابنُ جرير</u> (٢٤/١٣١) <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «والصواب من القول في ذلك عندنا: أن يُقال: <span class="qpc-hafs">﴿كورت﴾</span> كما قال الله -جلّ ثناؤه-، والتكوير في كلام العرب: جَمْع بعض الشيء إلى بعض، وذلك كتكوير العمامة، وهو لفّها على الرأس، وكتكوير الكارة، وهي جمع الثياب بعضها إلى بعض، ولفّها. وكذلك قوله: <span class="qpc-hafs">﴿إذا الشمس كورت﴾</span> إنما معناه: جمْع بعضها إلى بعض، ثم لُفّتْ فرُمي بها، وإذا فُعل ذلك بها ذهب ضوؤها. فعلى التأويل الذي تأولناه وبيّناه لكلا القولين اللذين ذكرتُ عن أهل التأويل وجه صحيح، وذلك أنها إذا كُوّرتْ ورُمي بها: ذهب ضوؤها».</p><p>وبنحوه <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٥٤٤)،: «وتكوير الشمس: هو أن تدار ويُذهب بها إلى حيث شاء الله كما يدار كور العمامة، وعبّر المفسِّرون عن ذلك بعبارات؛ فمنهم مَن قال: ذهب نورها. ومنهم مَن قال: رُمي بها. قاله الربيع بن خثيم. وغير ذلك مما هو أشياء تابعة لتكويرها».</div></p></div>",footnotes:1:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٩٩.الأثر في سيرة ابن إسحاق ص١٦٠-١٦٣ مطولًا.أخرجه أحمد ٨/٤٢٣-٤٢٤ (٤٨٠٦)، ٨/٥٢٨ (٤٩٣٤)، ٩/١٠-١١ (٤٩٤١)، ١٠/٤٢ (٥٧٥٥)، والترمذي ٥/٥٢٥-٥٢٦ (٣٦٢٣)، والحاكم ٢/٥٦٠ (٣٩٠٠)، ٤/٦٢٠ (٨٧١٩)، والثعلبي ١٠/١٣٦ مختصرًا.</p><p>قال الترمذي: «هذا حديث غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن القيسراني في تذكرة الحفاظ ص٣٢٩ (٨٢٩): «رواه عبد الله بن بجير الصنعاني، عن عبد الرحمن بن يزيد الصنعاني، عن ابن عمر. وعبد الله متروك الحديث، وليس هذا بابن ريسان، ذاك ثقة». وقال عبد الغني المقدسي في ذكر النار ص٨٧-٨٨ (٨٠): «هذا حديث حسن غريب». وقال الهيثمي في المجمع ٧/١٣٤ (١١٤٦٨): «رواه أحمد بإسنادين، ورجالهما ثقات». وقال ابن حجر في الفتح ٨/٦٩٥: «حديث جيد».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٢-. وعزاه السيوطي إلى الديلمي.أخرجه البخاري ٤/١٠٨ (٣٢٠٠) بلفظ: «<b>مُكوّران</b>»، والبزار -كما في تفسير ابن كثير ٨/٣٢٩-.أخرجه ابن جرير في تاريخه ١/٦٣-٦٥، من طريق خلف بن واصل، عن عمر بن صبح أبي نعيم البلخي، عن مقاتل بن حيّان، عن عبد الرحمن بن أبْزى، عن أبي ذرّ الغفاري به.</p><p>وسنده شديد الضعف؛ فيه خلف بن واصل، اتهمه ابن حجر بالوضع. لسان الميزان ٣/٣٧٣. وفيه عمر بن صبح، وهو متروك. كما في الميزان ٣/٢٠٦.أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٢٨، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه ابن جرير ٢٤/١٢٩، وابن أبي حاتم -كما في الإتقان ٢/٥٣- دون آخره. وعزاه السيوطي إلى ابن المنذر، والبيهقي في الشعب.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٢٩.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٢-، وأبو الشيخ (٦٤٥). وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٤٣، كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان عن أبيه عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.كذا في النسخ. وقال الجواليقي: «وهو بالفارسية: كُورْبُور». وفي اللسان: «وهو بالفارسية: كُورْبِكرِه». المعرب ص٣٣٥، واللسان (كور)، وينظر: تعليق الشيخ أحمد شاكر على المعرب. والأثر أخرجه ابن جرير ٢٤/١٣٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٣٠. وعزاه السيوطي إلى ابن أبي حاتم بلفظ: كور سود، وأنه من قول يعقوب. كما عزا السيوطي نحوه إلى عبد بن حميد بلفظ: هي كور بالفارسية، دون بيانها. وذكر محققو الدر أنها كذا في نسخه. وقال الجواليقي في المعرب ص٣٣٥: «وهو بالفارسية: كُورْبُور». وفي اللسان (كور): «وهو بالفارسية: كُورْبِكرِه».عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٢٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٣٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧-. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٨-.أخرجه ابن جرير ٢٤/١٣٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٥٠ من طريق معمر، وابن جرير ٢٤/١٢٩ من طريق شعبة ومعمر أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص٦٦ (تفسير مسلم الزنجي). وينظر: تفسير البغوي ٨/٣٤٢.تفسير مقاتل بن سليمان ٤/٦٠١.
  81,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٢٥<span class="dash">-</span></span> عن أبي مريم، أنّ النبي ﷺ قال في قول الله: <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: «<b>انكدرت في جهنم، وكُلُّ مَن عُبد من دون الله فهو في جهنم، إلا ما كان من عيسى ابن مريم وأُمّه، ولو رضيا أن يُعبدا لَدخلاها</b>»{1}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: تغيّرتْ{2}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق سفيان، عن أبيه، عن منذر الثوري- <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: تناثرتْ{3}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: تناثَرَتْ{4}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٢٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: تساقطتْ{5}. (١٥/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: انتثَرَتْ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: تساقطتْ، وتهافتتْ{7}. (١٥/٢٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٢<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٣<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span> تُمطِر السماء يومئذ نجومًا، فلا يبقى نجمٌ إلا وقع{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، يعني: اكدارّت الكواكب، وتناثرتْ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</span>، قال: رُمِي بها مِن السماء إلى الأرض{10}<span class=comment-ref>٧٠٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥١</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٤/١٣٢) أنّ قوله: <span class="qpc-hafs">﴿انكدرت﴾</span> يعني: تناثرت وتساقطت، فقال: "وقوله: <span class="qpc-hafs">﴿وإذا النجوم انكدرت﴾</span> يقول: وإذا النجوم تناثرتْ مِن السماء فتساقطتْ، وأصل الانكدار: الانصباب، <span class="mustanad">كما قال العجاج</span>:</p><p>أبصر خربان فضاء فانكدر</p><p>يعني بقوله: انكدر: انصب". وذكر أقوال السلف على ذلك، ثم ذكر قول ابن عباس أنّ <span class="qpc-hafs">﴿انكدرت﴾</span> معناه: تغيَّرتْ، ولم يعلّق عليه.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٥٤٥) على قول ابن عباس، فقال: «وقال ابن عباس: <span class="qpc-hafs">﴿انكَدَرَتْ﴾</span>: تغيَّرتْ، من قولهم: ماء كدر، أي: متغير اللون».</div></p></div>",footnotes:1:تقدم تخريجه في تفسير الآية السابقة.أخرجه ابن جرير ٢٤/١٣٣، وابن أبي حاتم -كما في الإتقان ٢/٥٣- دون آخره. وعزاه السيوطي إلى ابن المنذر، والبيهقي في الشعب.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٣٢. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣٨ (٢١)- بلفظ: تساقطت.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٣٢.أخرجه ابن جرير ٢٤/١٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. كما أخرجه عبد الرزاق ٢/٣٥٠–٣٥١ من طريق معمر بلفظ: تناثرت.تفسير البغوي ٨/٣٤٦.تفسير مقاتل بن سليمان ٤/٦٠١.أخرجه ابن جرير ٢٤/١٣٣.
  81,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡجِبَالُ سُیِّرَتۡ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٣٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span>، <span class="qpc-hafs">﴿وإذا الجِبالُ سُيِّرَتْ﴾</span>، قال: سارَتْ{1}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿وإذا الجِبالُ سُيِّرَتْ﴾</span>، قال: ذهبتْ{2}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا الجِبالُ سُيِّرَتْ﴾</span> مِن أماكنها، واستوتْ بالأرض كما كانت أول مرة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣٨ (٢١)-، وابن جرير ٢٤/١٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠١.
  81,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٣٩<span class="dash">-</span></span> عن <span class="name-1">أُبيّ بن كعب</span> -من طريق أبي العالية- <span class="qpc-hafs">﴿وإذا العِشارُ عُطِّلَتْ﴾</span>، قال: إذا أهملها أهلُها{1}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق سفيان، عن أبيه، عن منذر الثوري- <span class="qpc-hafs">﴿عُطِّلَتْ﴾</span>، قال: لم تُحلَب، ولم تُصرّ، وتخلّى منها أهلُها{2}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿وإذا العِشارُ﴾</span> عشار الإبل <span class="qpc-hafs">﴿عُطِّلَتْ﴾</span> لا راعي لها{3}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿عُطِّلَتْ﴾</span>، قال: سُيِّبتْ، وتُرِكَتْ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿عُطِّلَتْ﴾</span>، يقول: لا راعي لها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وإذا العِشارُ﴾</span>، قال: هي الإبل{6}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿وإذا العِشارُ عُطِّلَتْ﴾</span>، قال: سيّبها أهلها فلم تُصرّ، ولم تُحلب، ولم يكن في الدنيا مال أعجب إليهم منها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿عُطِّلَتْ﴾</span>، قال: سيَّبها أهلوها؛ أتاهم ما شغلهم عنها، فلم تُصرّ، ولم تُحلب، ولم يكن في الدنيا مال أعجب إليهم منها{8}<span class=comment-ref>٧٠٥٢</span>. (١٥/٢٦١)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٢</span> لم يذكر <u>ابنُ جرير</u> (٢٤/١٣٤-١٣٥) غير قول قتادة، وما في معناه.</div></p><p><div></p><p><p><span class="item-no">٨١٦٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا العِشارُ عُطِّلَتْ﴾</span> يعني: وإذا النُّوق الحوامل أُهملتْ، يعني: الناقة الحاملة نسيها أربابها، وذلك أنّه ليس شيء أحبَّ إلى الأعراب من الناقة الحاملة، يقول: أهملها أربابها للأمر الذي عاينوه{9}<span class=comment-ref>٧٠٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٣</span> ذكر <u>ابنُ كثير</u> (١٤/٢٦٠) عبارات السلف في قوله: <span class="qpc-hafs">﴿عطلت﴾</span>، ثم <span class="comment-type-4">علّق</span> قائلًا: «والمعنى في هذا كله متقارب».</p><p>و<span class="comment-type-4">بيّن</span> أنّ العِشار هي النُّوق الحوامل، كما جاء في أقوال السلف، ثم ذكر فيها عدة <b>أقوال أخر</b>، فقال: «وقد قيل في العِشار: إنها السحاب يُعطّل عن المسير بين السماء والأرض لخراب الدنيا. وقد قيل: إنها الأرض التي تعشر. وقيل: إنها الديار التي كانت تُسكن، تُعطَّل لذهاب أهلها. حكى هذه الأقوال كلها الإمام أبو عبد الله القرطبي في كتابه التذكرة، ورجّح أنها الإبل. وعزاه إلى أكثر الناس». ثم <span class="comment-type-4">علّق</span> قائلًا: «قلتُ: بل <span class="mustanad">لا يُعرف عن السلف والأئمة سواه</span>».</div></p><p><div></p><p><p><span class="item-no">٨١٦٤٨<span class="dash">-</span></span> عن الليث [بن سعد] -من طريق ابن وهب- قال: كان بعض مَن مضى يقول في قول الله: <span class="qpc-hafs">﴿وإذا العِشارُ عُطِّلَتْ﴾</span>: العِشار: اللقاح عُطِّلتْ{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ ۝٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨١٦٤٩<span class="dash">-</span></span> عن سفيان بن عُيينة، قال: قال <span class="name-3">عمر بن ذرّ</span>: ... مَن جاء يلتمس الخبرَ فقد وجد الخبر، هذا تقويض الدنيا. ثم قرأ: <span class="qpc-hafs">﴿إذا الشمس كورت﴾</span>، فكان ابن ذرّ يقول: هيهات العِشار وأهل العِشار، عطّلها أهلُها بعد الضَّنِّ بها{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٣٤، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٣٤. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٧٠٧ بلفظ: العشار: هي الإبل عطلها أربابها، وأخرجه ابن جرير ٢٤/١٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣٥.أخرجه ابن جرير ٢٤/١٣٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١٣٥.أخرجه عبد الرزاق ٢/٣٥٠، وابن جرير ٢٤/١٣٥ بلفظ: عشار الإبل سُيِّبت. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠١.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٧ (٣٢٤).أخرجه أبو نعيم في حلية الأولياء ٥/١١٠.
  81,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡوُحُوشُ حُشِرَتۡ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٥٠<span class="dash">-</span></span> عن <span class="name-1">أُبيّ بن كعب</span> -من طريق أبي العالية- <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: اختلطتْ{1}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: حشْر البهائم: موتها، وحشْر كلّ شيء: الموت، غير الجن والإنس؛ فإنهما يوافيان يوم القيامة{2}. (١٥/٢٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك بن قيس- <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: يُحشَر كلُّ شيء يوم القيامة، حتى إنّ الذباب ليُحشر{3}. (١٥/٢٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق منذر الثوري- <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: أتى عليها أمْرُ الله{4}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: حشْرها: موتها{5}. (١٥/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: حشْر البهائم: موتها{6}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، قال: إنّ هذه الخلائق موافية يوم القيامة، فيقضي الله فيها ما يشاء{7}. (١٥/٢٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا الوُحُوشُ حُشِرَتْ﴾</span>، يعني: جُمِعَتْ{8}<span class=comment-ref>٧٠٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٤</span> اختُلف في قوله: <span class="qpc-hafs">﴿حشرت﴾</span> على أقوال: <b>الأول</b>: ماتت: <b>الثاني</b>: جُمعت. <b>الثالث</b>: اختلطت.</p><p>وقد <span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (٢٤/١٣٧) بين القول الأول والثاني <span class="mustanad">مستندًا إلى اللغة، والنظائر</span>، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: معنى <span class="qpc-hafs">﴿حشرت﴾</span>: جُمعت، فأُميتت. لأنّ المعروف في كلام العرب من معنى الحشْر: الجمع، ومنه قول الله: <span class="qpc-hafs">﴿والطير محشورة﴾</span> [ص:١٩] يعني: مجموعة، وقوله: <span class="qpc-hafs">﴿فحشر فنادى﴾</span> [النازعات:٢٣]، وإنما يُحمل تأويل القرآن على الأغلب الظاهر مِن تأويله، لا على الأنكر المجهول».</div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٣٦-١٣٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه ابن جرير ٢٤/١٣٦، والحاكم ٢/٥١٥. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٤-، والخطيب في المتفق والمفترق (٧٦٨). وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠١.
  81,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡبِحَارُ سُجِّرَتۡ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٥٨<span class="dash">-</span></span> عن <span class="name-1">أُبيّ بن كعب</span> -من طريق أبي العالية- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: قالت الجن للإنس: نحن نأتيكم بالخبر. فانطلقوا إلى البحار، فإذا هي تأجّج نارًا {1}. (١٥/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٥٩<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق سعيد بن المسيّب- أنه سأل رجلًا مِن اليهود: أين جهنم؟ فقال: البحر. فقال: ما أراه إلا صادقًا، <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span> [الطور:٦]، ‹وإذا البِحارُ سُجِرَتْ› مُخفّفة{2}<span class=comment-ref>٧٠٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٥</span> ذكر <u>ابنُ جرير</u> (٢٤/١٤٠) قراءة التخفيف والتثقيل في قوله: <span class="qpc-hafs">﴿سجرت﴾</span>، ثم <span class="comment-type-4">علّق</span> عليهما قائلًا: «والصواب من القول في ذلك: أنهما قراءتان <span class="mustanad">معروفتان متقاربتا المعنى</span>، فبأيتهما قرأ القارئ فمصيب».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٨/٥٤٦) -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- قراءة التثقيل بقوله: «وهي مترجحة بكون البحار جمعًا، كما قال: <span class="qpc-hafs">﴿كِتابًا يَلْقاهُ مَنشُورًا﴾</span> [الإسراء:١٣]، وكما قال: <span class="qpc-hafs">﴿صُحُفًا مُنَشَّرَةً﴾</span> [المدثر:٥٢]، ومثله: <span class="qpc-hafs">﴿قَصْرٍ مَشِيدٍ﴾</span> [الحج:٤٥]، و<span class="qpc-hafs">﴿بُرُوجٍ مُشَيَّدَةٍ﴾</span> [النساء:٧٨] لأنها جماعة».</div></p><p><div></p><p><p><span class="item-no">٨١٦٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجالد، عن شيخ من بَجِيلة- في قوله: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، قال: كوَّر الله الشمسَ والقمرَ والنجومَ في البحر، فيبعث عليها ريحًا دبورًا، فتنفخه حتى يصير نارًا، فذلك قوله: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>. قال: اختلط ماؤها بماء الأرض. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتْ زُهير بن أبي سُلمى وهو يقول:</p><p>لقد نازعتُمُ حسبًا قديمًا وقد سجَرَت بحارُهُمُ بحاري؟{4}. (١٥/٢٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: تسجَّر حتى تصير نارًا{5}. (١٥/٢٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق سفيان، عن أبيه، عن أبي يعلى- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: فاضتْ{6}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: أُوقِدَتْ{7}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: ذهب ماؤها؛ غار ماؤها. قال: سُجّرتْ وفُجِّرتْ سواء{8}. (١٥/٢٦٠، ٢٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿وإذا البحار سُجِّرَتْ﴾</span>، قال: أُوقِدَتْ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: غار ماؤها، فذهب{10}. (١٥/٢٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سليمان التيمي، وأبي رجاء- في هذا الحرف: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: يَبستْ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٦٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، يعني: فاضتْ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنبِّه</span> -من طريق أبي الهذيل- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: سُجّرت البحار نارًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: ذهب ماؤها، ولم يبقَ منها قطرة{14}. (١٥/٢٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: فُتِحتْ وسُيِّرتْ{15}. (١٥/٢٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٣<span class="dash">-</span></span> عن <span class="name-3">شِمْر بن عطية</span> -من طريق حفص بن حميد- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: تُسجّر كما يُسجّر التّنُّور{16}. (١٥/٢٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: مُلئتْ، ألا تراه يقول: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span> [الطور:٦]؟{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، يعني: فُجِّرتْ بعضها في جوف بعض، العَذْب والمالح، فصارت البحور كلّها بحرًا واحدًا، مثل طشتٍ فيه ماء{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: أُوقِدَتْ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span>، قال: إنها تُوقَد يوم القيامة، زعموا ذلك التسجير في كلام العرب{2}<span class=comment-ref>٧٠٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٦</span> اختُلف في قوله: <span class="qpc-hafs">﴿سجرت﴾</span> على أقوال: <b>الأول</b>: أي: اشتعلتْ نارًا وحميتْ. <b>الثاني</b>: أي: فاضتْ. <b>الثالث</b>: أي: ذهب ماؤها.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/١٤٠) -<span class="mustanad">مستندًا إلى النظائر، وإلى اللغة-</span> أنّ المعنى: "مُلئتْ حتى فاضتْ، فانفجرتْ وسالتْ كما وصفها اللهُ به في الموضع الآخر، فقال: <span class="qpc-hafs">﴿وإذا البحار فجرت﴾</span> [الانفطار:٣]، والعرب تقول للنهر أو للركي المملوء: ماء مسجور، ومنه قول لبيد:</p><p>فَتَوَسَّطا عُرْضَ السَّرِيِّ وصَدَّعا مَسْجُورةً مُتَجاوِرًا قُلّامُها</p><p>ويعني بالمسجورة: المملوءة ماء".</p><p>وذكر <u>ابنُ عطية</u> (٨/٥٤٦) هذه الأقوال، ثم <span class="comment-type-4">علّق</span> قائلًا: «ويحتمل أن يكون المعنى: مُلكتْ، وقُيِّد اضطرابها حتى لا تخرج على الأرض بسبب الهول، فتكون اللفظة مأخوذة من ساجور الكلب».</div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٣٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه ابن جرير ٢٤/١٣٨.أخرجه ابن جرير ٢٤/١٣٨.أخرجه الطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧- من طريق كثير أبي محمد. وعزاه السيوطي إلى البيهقي في البعث.أخرجه ابن جرير ٢٤/١٣٩، كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٧٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد، كما عزا نحوه إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧-.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر. وعند ابن جرير ٢٤/١٤٠ بلفظ: يبست، وعلق البخاري في صحيحه ٤/١٨٨٣ نحوه.أخرجه ابن جرير ٢٤/١٤٠.ذكره يحيى بن سلام –كما في تفسير ابن أبي زمنين ٥/٩٩-.أخرجه عبد الرزاق ٢/٣٥٠.أخرجه ابن جرير ٢٤/١٣٩-١٤٠، وأخرجه عبد الرزاق ٢/٣٥٠ من طريق معمر بنحوه، وكذلك ابن جرير. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٩٣-.أخرجه ابن جرير ٢٤/١٣٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٥٠، وابن جرير ٢٤/١٣٩.تفسير مقاتل بن سليمان ٤/٦٠١.أخرجه ابن جرير ٢٤/١٣٨.أخرجه ابن جرير ٢٤/١٣٨.
  81,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلنُّفُوسُ زُوِّجَتۡ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٦٧٨<span class="dash">-</span></span> عن النُّعمان بن بشير: سمعتُ رسول الله ﷺ يقول: <b><span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span></b>، قال: «<b>هما الرجلان يعملان العمل، يدخلان الجنة والنار</b>». وقال: <b><span class="qpc-hafs">﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</span></b> [الصافات:٢٢]{1}. (١٥/٢٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٧٩<span class="dash">-</span></span> عن النعمان بن بشير أنه قال: قال رسول الله ﷺ: <b><span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span></b>، قال: «<b>الضُّرَباء؛ كل رجل مع كل قوم كانوا يعملون عمله، وذلك بأن الله ﷿ يقول: <span class="qpc-hafs">﴿وكنتم أزواجا ثلاثة فأصحاب الميمنة ما أصحاب الميمنة وأصحاب المشأمة ما أصحاب المشأمة والسابقون السابقون﴾</span></b> [الواقعة:٧-١٠]، <b>قال: هم الضُّرَباء</b>»{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٠<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق سماك بن حرب، عن النُّعمان بن بشير- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: هو الرجل يُزوّج نظيره من أهل الجنة، والرجل يُزوّج نظيره من أهل النار يوم القيامة. ثم قرأ: <span class="qpc-hafs">﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</span> [الصافات:٢٢]{3}. (١٥/٢٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨١<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: تزويجها: أن يؤلّف كلّ قوم إلى شبههم{4}. (١٥/٢٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٢<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق سماك بن حرب، عن النُّعمان بن بشير- <span class="qpc-hafs">﴿وإذا النفوس زوجت﴾</span>، قال: هما الرجلان يعملان العمل، فيدخلان به الجنة. وقال: <span class="qpc-hafs">﴿احشروا الذين ظلموا وأزواجهم﴾</span> [الصافات:٢٢]، قال: ضرباءهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٣<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق النُّعمان بن بشير- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>. قال: يُقرَن بين الرجل الصالح مع الصالح في الجنة، ويُقرَن بين الرجل السوء مع السوء في النار، فذلك تزويج الأنفس{6}. (١٥/٢٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: يسيل وادٍ مِن أصل العرش مِن ماءٍ فيما بين الصيحتين، ومقدار ما بينهما أربعون عامًا، فيَنبتُ منه كلُّ خَلْقٍ بَلِي مِن الإنسان أو طير أو دابة، ولو مرّ عليهم مارٌّ قد عرفهم قبل ذلك لَعرفهم على وجه الأرض قد نبتوا، ثم تُرسل الأرواح فتُزَوّج الأجساد، فذلك قول الله: <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>{7}. (١٥/٢٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: ذلك حين يكون الناس أزواجًا ثلاثة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق سفيان، عن أبيه، عن منذر الثوري- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: كلّ رجل مع صاحب عمله{9}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span>، <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: زوّج الروح للجسد{10}. (١٥/٢٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جُبَير]</span> -من طريق جعفر- في قوله ﷿: <span class="qpc-hafs">﴿وإذا النفوس زوجت﴾</span>، قال: زُوِّجت الأرواحُ الأبدان{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٨٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: الأمثال للناس جُمِع بينهم{12}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: زُوِّجت الأرواح الأجساد{13}. (١٥/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي عمرو- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: ترجع الأرواح إلى أجسادها{14}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: يُقرن الرجل في الجنة بقرينه الصالح في الدنيا، ويُقرن الرجل الذي كان يعمل السوء في الدنيا بقرينه الذي كان يعينه في النار{15}. (١٥/٢٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: زُوّج الروح بالجسد، وأُعيدت الأرواح في الأجساد{16}. (١٥/٢٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: أُلحِق كلُّ امرئٍ بشِيعته{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: أُلْحِقَ كلُّ إنسان بشيعته؛ اليهود باليهود، والنصراني بالنصراني{18}. (١٥/٢٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: أشكالهم{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٧<span class="dash">-</span></span> قال <span class="name-2">عطاء [بن أبي رباح]</span>: <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span> زُوِّجتْ نفوس المؤمنين بالحُور العين، وقُرنتْ نفوس الكافرين بالشياطين{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>، <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span>، قال: زُوِّج المؤمنون الحُورَ العين، والكفارُ الشياطينَ{21}. (١٥/٢٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٦٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span> أُزوجتْ أنفس المؤمنين مع الحُور العين، وأُزوجتْ أنفس الكافرين مع الشياطين، يعني: ابن آدم وشيطانه مقرونًا في السلسلة الواحدة زوجان. نظيرها في سورة الصافات [٢٢] قوله ﷿: <span class="qpc-hafs">﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</span> يعني: قرناءهم{22}<span class=comment-ref>٧٠٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٧</span> اختُلف في قوله: <span class="qpc-hafs">﴿وإذا النفوس زوجت﴾</span> على أقوال: <b>الأول</b>: أُلحِق كلّ إنسان بشكله، وقُرِن بين الضرباء والأمثال. <b>الثاني</b>: عني بذلك: أنّ الأرواح رُدَّتْ إلى الأجساد، فزُوِّجتْ بها، أي: جُعلتْ لها زوجًا. <b>الثالث</b>: زُوِّجتْ أنفس المؤمنين الحُور العين، وأنفس المشركين الشياطين.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٥٤٧) على القول الأول بقوله: «وفي الآية على هذا حضٌّ على دليل الخير، <span class="mustanad">فقد قال ﵇</span>: «<b>المرء مع من أحب</b>». وقال: «<b>فلينظر أحدكم مَن يُخالِل</b>». <span class="mustanad">وقال الله تعالى</span>: <span class="qpc-hafs">﴿الأَخِلّاءُ يَوْمَئِذٍ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إلّا المُتَّقِينَ﴾</span> [الزخرف:٦٧]».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/١٤٤) -<span class="mustanad">مستندًا إلى النظائر-</span> القول الأول، وهو قول عمر وغيره، فقال: «وأولى التأويلين في ذلك بالصحة: الذي تأوله عمر بن الخطاب ﵁؛ للعلّة التي اعتل بها، وذلك قول الله -تعالى ذِكره-: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span> [الواقعة:٧]، وقوله: <span class="qpc-hafs">﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</span> [الصافات:٢٢]، وذلك لا شك الأمثال والأشكال في الخير والشر، وكذلك قوله: <span class="qpc-hafs">﴿وإذا النفوس زوجت﴾</span> بالقرناء والأمثال في الخير والشر».</p><p>ولم يذكر <u>ابنُ القيم</u> (٣/٢٥٦-٢٥٧) غير القول الأول والثالث، و<span class="comment-type-3">رجّح</span> الأول <span class="mustanad">مستندًا إلى قول النبي</span> ﷺ: «<b>لا يحب المرء قومًا إلا حُشِر معهم</b>». ثم <span class="comment-type-4">علّق</span> على القول الثالث بقوله: «وهو راجع إلى القول الأول».</div></p></div>",footnotes:1:أخرجه ابن مردويه -كما في الفتح ٨/٦٩٤-.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/ ٣٣٢-، من طريق أبيه، عن محمد بن الصباح البزار، عن الوليد بن أبي ثور، عن سماك به.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧-، وابن مردويه -كما في تغليق التعليق ٤/٣٦١-٣٦٢-.أخرجه ابن منيع -كما في المطالب العالية (٤١٧٦)-.أخرجه ابن جرير ٢٤/١٤١.أخرجه عبد الرزاق ٢/٣٥٠ بنحوه، وابن أبي شيبة ١٣/٢٧٩، وعبد بن حميد -كما في تغليق التعليق ٤/٣٦٢-، وابن جرير ٢٤/١٤٢ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٥-، والحاكم ٢/٥١٥-٥١٦ بنحوه، وابن مردويه -كما في تغليق التعليق ٤/٣٦١-، وأبو نعيم في الحلية -كما في فتح الباري ٦/٦٩٤-. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن المنذر، والبيهقي في البعث.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٥-.أخرجه ابن جرير ٢٤/١٤٣.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٤٣. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه ص٣٦ (تفسير يحيى بن يمان).تفسير مجاهد ص٧٠٧، وأخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣٨ (٢١)-، وابن جرير ٢٤/١٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وزاد ابن أبي الدنيا: الزُّناة مع الزُّناة، وأَكَلة الربا مع أكَلة الربا، وقَتَلة النفس مع قَتَلة النفس.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٤٤، ومن طريق محمد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الفراء في معاني القرآن ٣/٢٣٩-٢٤٠.أخرجه ابن جرير ٢٤/١٤٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٤٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٩- بنحوه.أخرجه ابن جرير ٢٤/١٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٥٠.تفسير البغوي ٨/٣٤٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠١.
  81,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡمَوۡءُۥدَةُ سُىِٕلَتۡ ۝٨ بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨١٧٠٠<span class="dash">-</span></span> عن <span class="name-2">أبي الضُّحى مُسلم بن صُبيح</span> -من طريق الأعمش- أنه قرأ: (وإذا المَوْءُودَةُ سَأَلَتْ)، قال: طلبتْ قاتلَها بدمائها{1}. (١٥/٢٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠١<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق سعيد- <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span>، قال: هي في بعض القراءة: (سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ){2}<span class=comment-ref>٧٠٥٨</span>. (١٥/٢٦١)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٥٨</span> ذكر <u>ابنُ جرير</u> (٢٤/١٤٥، ١٤٧-١٤٨) قراءة: (سَأَلَتْ)، و<span class="comment-type-1">وجّهها</span>، فقال: «قرأه أبو الضُّحى مُسلم بن صُبيح: (وإذا المَوْءُودَةُ سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ) بمعنى: سألت الموءودة الوائدين: بأي ذنب قتلوها». ثم <span class="comment-type-4">علّق</span> عليها قائلًا: «ولو قرأ قارئ ممن قرأ: (سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ) كان له وجه، وكان يكون معنى ذلك مَن قرأ: <span class="qpc-hafs">﴿بأي ذنب قتلت﴾</span> غير أنه إذا كان حكاية جاز فيه الوجهان». و<span class="comment-type-1">وجّه</span> قراءة <span class="qpc-hafs">﴿سُئلت﴾</span> بقوله: «وقرأ ذلك بعض عامة قراء الأمصار: <span class="qpc-hafs">﴿وإذا الموءودة سئلت بأي ذنب قتلت﴾</span> بمعنى: سُئلت الموءودة بأي ذنبٍ قُتلتْ، ومعنى <span class="qpc-hafs">﴿قتلت﴾</span> قُتلتْ غير أنّ ذلك ردٌّ إلى الخبر على وجه الحكاية على نحو القول الماضي قبل، وقد يتوجه معنى ذلك إلى أن يكون: وإذا الموءودة سألتْ قَتَلتَها ووائديها، بأي ذنبٍ قتلوها؟ ثم ردّ ذلك إلى ما لم يُسمّ فاعله، فقيل: بأي ذنبٍ قُتلتْ».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u> (٨/٥٤٨) بقوله: «وهذا على وجه التوبيخ للعرب الفاعلين ذلك؛ لأنها تسأل ليصير الأمر إلى سؤال الفاعلين، ويحتمل أن تكون مسؤولًا عنها مطلوبًا الجواب منهم. كما قال تعالى: <span class="qpc-hafs">﴿إن العهد كان مسؤلا﴾</span> [الإسراء:٣٤]، وكما سُئل التراث والحقوق».</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> قراءة: <span class="qpc-hafs">﴿سئلت﴾</span> <span class="mustanad">مستندًا إلى إجماع الحجة من القراء</span>، فقال: «وأولى القراءتين في ذلك عندنا بالصواب قراءة مَن قرأ ذلك <span class="qpc-hafs">﴿سُئلت﴾</span> بضم السين <span class="qpc-hafs">﴿بأي ذنب قتلت﴾</span> على وجه الخبر؛ لإجماع الحجّة من القراء عليه».</div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡمَوۡءُۥدَةُ سُىِٕلَتۡ ۝٨ بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨١٧٠٢<span class="dash">-</span></span> عن جُدامة بنت وهب، قالت: سُئِل رسول الله ﷺ عن العَزْل. فقال: «<b>ذاك الوَأْدُ الخفي، وهي: <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span></b>»{3}. (١٥/٢٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span>، يقول: سألت{4}. (١٥/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span>، قال: أطفال المشركين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٥<span class="dash">-</span></span> قال <span class="name-1">ابن عباس</span>: الموءودة هي المدفونة، كانت المرأة في الجاهلية إذا هي حَملتْ فكان أوان ولادها حَفرتْ حفرة، فتمخّضتْ على رأس تلك الحفرة، فإن ولدت جارية رَمتْ بها في تلك الحفرة، وإن ولدتْ غلامًا حبستْه. قال <span class="name-1">ابن عباس</span>: فمَن زعم أنهم في النار فقد كذب، بل هم في الجنة{5}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span> -من طريق منذر الثوري- <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span>، قال: كانت العرب مِن أفعل الناس لذلك{6}. (١٥/٢٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿بِأَيِّ ذَنْبٍ قُتِلَتْ﴾</span> أراد الله أن يُوَبِّخ قاتلها؛ لأنها قُتلتْ بغير ذنب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span>، قال: هي في بعض القراءة: (سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ). قال: لا بذنب. قال: وكان أهل الجاهلية يقتل أحدهم ابنته، ويغذو كلبه؛ فعاب اللهُ ذلك عليهم{2}. (١٥/٢٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا المَوْؤُدَةُ سُئِلَتْ﴾</span> يعني: دفْن البنات، وذلك أنّ أهل الجاهلية كان أحدهم إذا وُلدت له الابنة دفنها في التراب وهي حيّة، <span class="qpc-hafs">﴿بِأَيِّ ذَنْبٍ قُتِلَتْ﴾</span> سُئل قاتلها بأي ذنبٍ قَتلها وهي حيّة لم تُذنب قط{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧١٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span> قال: البنات التي كانت طوائف يقتلونهن. وقرأ: <span class="qpc-hafs">﴿بِأَيِّ ذَنْبٍ قُتِلَتْ﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡمَوۡءُۥدَةُ سُىِٕلَتۡ ۝٨ بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨١٧١١<span class="dash">-</span></span> عن عمر بن الخطاب، في قوله: <span class="qpc-hafs">﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</span>، قال: جاء قيس بن عاصم التميمي إلى رسول الله ﷺ، فقال: إنِّي وأدتُ ثمان بنات لي في الجاهلية. فقال له النبي ﷺ: «<b>أعتِقْ عن كلّ واحدة رقبة</b>». قال: إني صاحب إبل. قال: «<b>فأهدِ عن كلّ واحدة بَدَنة</b>»{11}. (١٥/٢٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧١٢<span class="dash">-</span></span> عن سلمة بن يزيد الجُعْفيّ، عن رسول الله ﷺ، قال: «<b>الوائدة والموءودة في النار، إلا أن تُدرك الوائدة الإسلام؛ فيعفو الله عنها</b>»{12}. (١٥/٢٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧١٣<span class="dash">-</span></span> عن صَعْصَعة بن ناجية المجاشعِيّ -وهو جدّ الفرزدق- قال: قلتُ: يا رسول الله، إنِّي عملتُ أعمالًا في الجاهلية، فهل لي فيها مِن أجر؟ قال: «<b>وما عملتَ؟</b>». قال: أحييتُ ثلاثمائة وستين من الموءودة؛ أشتري كلّ واحد منهن بناقتين عشراوين وجمل، فهل لي في ذلك مِن أجر؟ فقال النبي ﷺ: «<b>لك أجره إذ منَّ الله عليك بالإسلام</b>»{13}. (١٥/٢٦٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/١٤٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.</p><p>وهي قراءة شاذة، تروى أيضًا عن علي بن أبي طالب، وابن مسعود، وابن عباس، وغيرهم. انظر: مختصر ابن خالويه ص١٦٩.أخرجه ابن جرير ٢٤/١٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه مسلم ٢/١٠٦٧ (١٤٤٢).أخرجه ابن أبي حاتم -كما في الإتقان ٢/٥٣- دون آخره. وعزاه السيوطي إلى ابن جرير، وابن المنذر، والبيهقي في الشعب.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور ٨/٢٦٢ (٢٣٩٩). وعزاه السيوطي ابن أبي شيبة، وعبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٩-.أخرجه ابن جرير ٢٤/١٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠١-٦٠٢.أخرجه ابن جرير ٢٤/١٤٨.أخرجه البزار ١/٣٥٥ (٢٣٨)، والطبراني في الكبير ١٨/٣٣٧ (٨٦٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣٥-، والثعلبي ١٠/١٣٩، من طريق عبد الرزاق، عن إسرائيل، عن سماك بن حرب، عن النعمان بن بشير، عن عمر بن الخطاب به.</p><p>قال الهيثمي في المجمع ٧/١٣٤ (١١٤٦٩): «رجال البزار رجال الصحيح، غير حسين بن مهدي الأيلي، وهو ثقة». وقال الألباني في الصحيحة ٧/٨٧٧ (٣٢٩٨): «ورجاله ثقات؛ رجال مسلم، غير الحسين شيخ البزار، وهو ابن مهدي الأبُلِّي، وهو ثقة عند ابن حبان، صدوق عند أبي حاتم».أخرجه أحمد ٢٥/٢٦٨ (١٥٩٢٣)، والنسائي في الكبرى ١٠/٣٢٥ (١١٥٨٥)، والواحدي في التفسير الوسيط ٤/٤٣٠، من طريق داود بن أبي هند، عن الشعبي، عن علقمة، عن سلمة بن يزيد الجُعْفيّ به. وعند الواحدي: داود عن علقمة، بدون ذكر الشعبي.</p><p>قال ابن عبد البر في التمهيد ١٨/١٢٠: «ليس لهذا الحديث إسناد أقوى وأحسن من هذا الإسناد». وقال الهيثمي في المجمع ١/١١٩ (٤٦٦): «رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢١٧ (٧٨١٩): «سند رواته ثقات».أخرجه الطبراني في الكبير ٨/٧٦ (٧٤١٢)، والحاكم ٣/٧٠٧ (٦٥٦٢) مطولًا، من طريق عباد بن كسيب العنبري، عن طفيل بن عمرو الربعي، عن صَعْصَعَة بن ناجية به.</p><p>قال الهيثمي في المجمع ١/٩٤-٩٥ (٣٣٨): «فيه الطفيل بن عمرو التميمي، قال البخاري: لا يصحّ حديثه». وقال العقيلي في الضعفاء الكبير ٢/٢٢٨ (٧٧٥): «لا يُتابع عليه».
  81,9,""
