  81,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّیۡلِ إِذَا عَسۡعَسَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٧٦٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق أبي عبد الرحمن- أنه خرج حين طلع الفجر، فقال: نِعمَ ساعة الوتر هذه. ثم تلا: <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ والصُّبْحِ إذا تَنَفَّسَ﴾</span>{1}. (١٥/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٦٤<span class="dash">-</span></span> عن أبي ظَبْيان، قال: كنتُ أتبع <span class="name-1">علي بن أبي طالب</span> ﵁ وهو خارج نحو المشرق، فاستقبل الفجر؛ فقرأ هذه الآية: <span class="qpc-hafs">﴿والليل إذا عسعس﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: إذا أدبر{3}. (١٥/٢٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: إذا أقبل{4}. (١٥/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>. قال: إقبال سواده. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول امرئ القيس:</p><p>عَسعَسَ حتى لو شاء ادَّنا كان له من ضوئِه مَقبَسُ؟{5}. (١٥/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: أظلم{6}. (١٥/٢٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: إقباله، ويُقال: إدباره{7}. (١٥/٢٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>: إذا أدبر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span> إذا أظلم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: إذا غشِيَ الناسَ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٣<span class="dash">-</span></span> عن <span class="name-2">عطية العَوفيّ</span> -من طريق الفضيل- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: أشار بيده إلى المغرب{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: إذا أدبر{12}. (١٥/٢٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابنه عبد الرحمن- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: إذا ذهب. وفي قول الله: <span class="qpc-hafs">﴿واللَّيْلِ إذا سَجى﴾</span> [الضحى:٢]، قال: سجْوه: سكونه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، يعني: إذا أظلم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ﴾</span>، قال: <span class="qpc-hafs">﴿عَسعس﴾</span>: تولّى. وقال: تنفّس الصبح من هاهنا. وأشار إلى المشرق اطلاع الفجر{11}<span class=comment-ref>٧٠٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٦١</span> اختُلف في قوله: <span class="qpc-hafs">﴿والليل إذا عسعس﴾</span> على قولين: <b>الأول</b>: أدبر. <b>الثاني</b>: أقبل بظلامه.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/١٦١-١٦٢) -<span class="mustanad">مستندًا إلى دلالة العقل واللغة</span>- القول الأول، فقال: «وأولى التأويلين في ذلك بالصواب عندي قول مَن قال: معنى ذلك: إذا أدبر، وذلك لقوله: <span class="qpc-hafs">﴿والصبح إذا تنفس﴾</span> فدلّ بذلك على أنّ القسم بالليل مدبرًا، وبالنهار مقبلًا، والعرب تقول: عَسعس الليل. وسعسع الليل: إذا أدبر، ولم يبق منه إلا اليسير».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٥٥٠).</p><p>و<span class="comment-type-4">كذا</span> <u>ابنُ القيم</u> (٣/٢٥٩-٢٦٠) <span class="mustanad">مستندًا إلى السياق، وإلى ظاهر القرآن</span>، فقال: «والأحسن أنْ يكون القَسم بانصرام الليل وإقبال النهار؛ فإنه عقيبه مِن غير فصل، فهذا أعظم في الدلالة والعبرة، بخلاف إقبال الليل وإقبال النهار، فإنه لم يُعرف القَسم في القرآن بهما، ولأنّ بينهما زمنًا طويلًا، فالآية في انصرام هذا ومجيء الآخر عقيبه بغير فصل أبلغ، فذكر سبحانه حالة ضعف هذا وإدباره، وحالة قوة هذا وتنفّسه، وإقباله يطرد ظلمة الليل بتنفّسه، فكلما تنفّس هرب الليل وأدبر بين يديه، وهذا هو القول».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٤/٢٦٩-٢٧٠) <span class="mustanad">-مستندًا إلى الدلالة العقلية، والنظائر-</span> القول الثاني، فقال: «وعندي أنّ المراد بقوله: <span class="qpc-hafs">﴿عسعس﴾</span> إذا أقبل، وإن كان يصحّ استعماله في الإدبار، لكن الإقبال هاهنا أنسب؛ كأنه أقسم تعالى بالليل وظلامه إذا أقبل، وبالفجر وضيائه إذا أشرق، كما قال: <span class="qpc-hafs">﴿والليل إذا يغشى والنهار إذا تجلى﴾</span> [الليل:١-٢]، وقال: <span class="qpc-hafs">﴿والضحى والليل إذا سجى﴾</span> [الضحى:١-٢]، وقال <span class="qpc-hafs">﴿فالق الإصباح وجعل الليل سكنًا﴾</span> [الأنعام:٩٦]، وغير ذلك من الآيات». ثم قال: «وقال كثير من علماء الأصول: إنّ لفظة <span class="qpc-hafs">﴿عسعس﴾</span> تُستعمل في الإقبال والإدبار على وجه الاشتراك، فعلى هذا يصح أن يراد كل منهما».</p><p>وبنحوه <span class="comment-type-1">وجّهه</span> <u>ابنُ القيم</u>.</div></p></div>",footnotes:1:أخرجه عبد الرزاق في مصنفه ٣/١٨ (٤٦٣٠، ٤٦٣١)، والطحاوي ١/٣٤٠، وابن جرير ٢٤/١٦٠، والطبراني في الأوسط (١٤٥١)، والحاكم ٢/٥١٦، والبيهقي في سننه ٢/٤٩٧. كما أخرجه الشافعي في كتاب الأم ٨/٤١١ بلفظ: أنّ عليًا ﵇ خرج حين ثوَّب المؤذن، فقال: أين السائل عن الوِتر؟ نِعْمَ ساعة الوتر هذه. ثم قرأ: <span class="qpc-hafs">﴿والليل إذا عسعس الصبح إذا تنفس﴾</span>.أخرجه ابن جرير ٢٤/١٥٩.أخرجه ابن جرير ٢٤/١٥٩، وكذلك من طريق العَوفيّ، وابن أبي حاتم -كما في الإتقان ٢/٥٣-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٢.أخرجه الطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٠٨ بلفظ: إذا أدبر، وأخرجه ابن جرير ٢٤/١٦٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٠٠-.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦١.أخرجه ابن جرير ٢٤/١٦١.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦٠، وكذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٦ (٣٠).تفسير مقاتل بن سليمان ٤/٦٠٢.أخرجه ابن جرير ٢٤/١٦١.
  81,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلصُّبۡحِ إِذَا تَنَفَّسَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٧٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والصُّبْحِ إذا تَنَفَّسَ﴾</span>، قال: إذا بدا النهارُ حين طلوع الفجر{1}. (١٥/٢٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جُبَير]</span> -من طريق جعفر- <span class="qpc-hafs">﴿والصُّبْحِ إذا تَنَفَّسَ﴾</span>، قال: إذا نشأ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والصُّبْحِ إذا تَنَفَّسَ﴾</span>، قال: إذا أضاء، وأقبل{3}. (١٥/٢٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والصُّبْحِ إذا تَنَفَّسَ﴾</span> يعني: إذا أضاء لونُه، فأقسم الله تعالى بهؤلاء الآيات أنّ هذا القرآن <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٥٣-. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه ابن جرير ٢٤/١٦٢.أخرجه ابن جرير ٢٤/١٦٣. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٠٢.
  81,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٧٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span>، قال: جبريل{1}. (١٥/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٣<span class="dash">-</span></span> عن <span class="name-2">عامرالشعبي</span> -من طريق عطاء- <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span>، قال: جبريل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> – من طريق إسماعيل- <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span>، قال: جبريل{3}. (١٥/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span>، قال: هو جبريل{4}. (١٥/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span> على الله، يعني: جبريل ﵇، هو علَّم محمدًا ﷺ{5}<span class=comment-ref>٧٠٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٦٢</span> أفادت آثار السلف أنّ المراد بالرسول الكريم جبريل ﵇. وقد ذكره <u>ابنُ عطية</u> (٨/٥٥٠-٥٥١)، وذكر <b>قولًا آخر</b> أنه محمد ﷺ، ثم <span class="comment-type-3">رجّح</span> الأول بقوله: «والقول الأول أصح». ولم يذكر مستندًا.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٧.أخرجه أبو الشيخ في العظمة (٥٠٠). وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦٣، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠٢.
  81,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذِی قُوَّةٍ عِندَ ذِی ٱلۡعَرۡشِ مَكِینࣲ ۝٢٠ مُّطَاعࣲ ثَمَّ أَمِینࣲ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٧٨٧<span class="dash">-</span></span> عن معاوية بن قُرّة، قال: قال رسول الله ﷺ لجبريل: «<b>ما أحسن ما أثنى عليك ربّك؛ <span class="qpc-hafs">﴿ذِي قُوَّةٍ عِنْدَ ذِي العَرْشِ مَكِينٍ مُطاعٍ ثَمَّ أمِينٍ﴾</span>! فما كانت قوتك؟ وما كانت أمانتك؟</b>». قال: أمّا قوتي فإني بُعثتُ إلى مدائن لوط، وهي أربع مدائن، وفي كلّ مدينة أربعمائة ألف مقاتل سوى الذّراري، فحملتُهم مِن الأرض السُّفلى حتى سمع أهلُ السماء أصوات الدجاج ونباح الكلاب، ثم هويتُ بهم، فقلبتهنّ، وأمّا أمانتي فلم أومر بشيء فعدوتُه إلى غيره{1}. (١٥/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قال النبي ﷺ لجبريل ليلة أسري به: «<b>اكشف عن النار</b>». فكشف عنها، فنظر إليها، فذلك قوله: <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ أمِينٍ﴾</span>{2}. (١٥/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿أمِينٍ﴾</span> على الوحي{2}. (١٥/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ذِي قُوَّةٍ عِنْدَ ذِي العَرْشِ مَكِينٍ مُطاعٍ ثَمَّ أمِينٍ﴾</span>، قال: يعني: جبريل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ أمِينٍ﴾</span>: يعني: جبريل ﵇{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ﴾</span> أمر الله أهل السماء بطاعة جبريل، كما أمر أهل الأرض أن يُطيعوا محمدًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ أمِينٍ﴾</span>، قال: أمين على سبعين حجابًا يدخلها بغير إذن{7}. (١٥/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩٤<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق معقل- <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ أمِينٍ﴾</span>، قال: ذاكم جبريل ﵇{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ﴾</span>: مطاع عند الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذِي قُوَّةٍ﴾</span> يعني: ذا بطش، وذلك أنّ النبي ﷺ حين بُعِث قال إبليس: مَن لهذا النبي الذي خرج مِن أرض تِهامة؟ فقال شيطان -واسمه: الأبيض- هو صاحب الأنبياء: أنا له. فأتى النبيَّ ﷺ، فوجده في بيت الصفا، فلما انصرف قام الأبيض في صورة جبريل ﷺ ليوحي إليه، فنزل جبريلُ ﵇، فقام بينه وبين النبي ﷺ، فدفعه جبريل ﷺ بيده دفعة هَيّنة، فوقع مِن مكة بأقصى الهند مِن فَرَقه، <span class="qpc-hafs">﴿عِنْدَ ذِي العَرْشِ مَكِينٍ﴾</span> يقول: جبريل ﵇ وجيهٌ عند الله، <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ﴾</span> يعني: هنالك في السموات، وذلك أنّ النبي ﷺ ليلة عُرج به إلى السموات رأى إبراهيم ﷺ وموسى ﵉، فصافحوه، وأداره جبريل على الملائكة في السموات، فاستبشروا به، وصافحوه، ورأى مالكًا خازن النار، فلم يُكلّمه، ولم يُسلّم عليه، فقال النبي ﷺ لجبريل ﵇: «<b>مَن هذا؟</b>». قال: هذا مالك، خازن جهنم، لم يَتكلّم قط، وهؤلاء النفر معه، فخزنة جهنم نُزعتْ منهم الرأفة والرحمة، وأُلقي عليهم العبوس والغضب على أهل جهنم، أما إنهم لو كلّموا أحدًا منذ خُلقوا لكلّموك؛ لكرامتك على الله ﷿. فقال النبي ﷺ: «<b>قل له فليكشف عن بابٍ منها</b>». فكشف عن مثل منخَر الثور منها، فتَخَلْخَلَتْ فجاءتْ بأمر عظيم، حسبت أنها الساعة حتى أهيل منها النبي ﷺ، فقال لجبريل: مُره فليردّها. فأمره جبريل ﵇، فأطاعه مالك ﵇، فردّها، فذلك قوله: <span class="qpc-hafs">﴿مُطاعٍ ثَمَّ﴾</span>، <span class="qpc-hafs">﴿أمِينٍ﴾</span> يُسمّى أمينًا لما استودعه ﷿ من أمْره في خَلْقه{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٥٠/٣٢٥-٣٢٦، والواحدي في التفسير الوسيط ٤/٤٣١ (١٢٨٥)، من طريق المسيّب بن شريك، عن يزيد بن أبي زياد، عن معاوية بن قرة به.</p><p>وسنده شديد الضعف؛ فيه المسيّب بن شريك، وهو متروك. كما في الميزان ٤/١١٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٥.أخرجه ابن جرير ٢٤/١٦٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٠١-.أخرجه ابن جرير ٢٤/١٦٤، وأبو الشيخ في العظمة (٥٠٠). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٤.أخرجه ابن جرير ٢٤/١٦٥.تفسير مقاتل بن سليمان ٤/٦٠٢-٦٠٤.
