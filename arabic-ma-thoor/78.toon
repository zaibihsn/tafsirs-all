quran[40]{c,v,t}:
  78,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٠٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (١٥/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسَمّاها: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span>، وذكر أنها نزلت بعد: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٤<span class="dash">-</span></span> عن عبد الله بن الزُّبير، قال: نزلت <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span> بمكة{3}. (١٥/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٦<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسَمَّياها: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٨<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، وسَمّاها: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span>، ونزلت بعد: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٩<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٠<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة النبأ مكّيّة، عددها أربعون آية كوفي{8}<span class=comment-ref>٦٩٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٧</span> قال <u>ابنُ عطية</u> (٨/٥١٢): «وهي مكّيّة <span class="mustanad">بإجماع</span>».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٥٥.
  78,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَمَّ یَتَسَاۤءَلُونَ ۝١ عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨١١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق محمد بن جُحادة- قال: لَمّا بُعِث النبيُّ ﷺ جَعلوا يتساءلون بينهم؛ فنزلت: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>{1}<span class=comment-ref>٦٩٧٨</span>. (١٥/١٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٨</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٥) غير قول الحسن.</div></p><p><div></p><p><p><span class="item-no">٨٠٨١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span> نزلت في أبي لبابة وأصحابه، وذلك أنّ كفار مكة كانوا يجتمعون عند رسول الله ﷺ، ويَسمعون حديثه، فإذا حَدَّثهم خالفوا قوله، واستهزؤوا منه، وسخروا؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿أنْ إذا سَمِعْتُمْ﴾</span> يا محمد <span class="qpc-hafs">﴿آياتِ اللَّهِ يُكْفَرُ بِها ويُسْتَهْزَأُ بِها فَلا تَقْعُدُوا مَعَهُمْ حَتّى يَخُوضُوا فِي حَدِيثٍ غَيْرِهِ﴾</span> [النساء:١٤٠]. فكان رسول الله ﷺ يُحَدِّث المؤمنين، فإذا رأى رجلًا مِن المشركين كفَّ عن الحديث حتى يَذهب، ثم أقبلوا بجماعتهم، فقالوا: يا محمد، أبخلتَ بما كنتَ تُحدِّثنا؟ لو أنك حَدّثتنا عن القرون الأولى فإنّ حديثك عجبٌ. قال: «<b>لا، واللهِ، لا أُحدِّثكم بعد يومي هذا، وربي قد نهاني عنه</b>». فأنزل الله تعالى: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَمَّ یَتَسَاۤءَلُونَ ۝١ عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>، قال: القرآن{3}. (١٥/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عَنِ النَّبَإ العَظِيمِ﴾</span>، قال: القرآن{4}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>، قال: القرآن{5}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عَنِ النَّبَإ العَظِيمِ﴾</span>: وهو البعْث بعد الموت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span> استفهام للنبي ﷺ: عن أيِّ شيء يتساءلون؟ ... <span class="qpc-hafs">﴿عَنِ النَّبَإ العَظِيمِ﴾</span> يعني: القرآن، كقوله: <span class="qpc-hafs">﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ﴾</span> [ص:٦٧] لأنه كلام الله تعالى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ الَّذِي هُمْ فِيهِ مُخْتَلِفُون﴾</span>، قال: يوم القيامة. قال: قالوا: هذا اليوم الذي تزعمون أنّا نحيا فيه وآباؤنا. قال: فهم فيه مُختلِفون، لا يؤمنون به، فقال الله: <span class="qpc-hafs">﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ أنْتُمْ عَنْهُ مُعْرِضُونَ﴾</span> [ص:٦٧-٦٨] يوم القيامة لا يؤمنون به{6}<span class=comment-ref>٦٩٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٩</span> ذكر <u>ابنُ عطية</u> (٨/٥١٢) في عَوْد الضمير في قوله: <span class="qpc-hafs">﴿يتساءلون﴾</span> احتمالين: <b>الأول</b>: «أن يريد: جميع العالم». و<span class="comment-type-1">وجّهه</span> بقوله: «فيكون الاختلاف حينئذ يُراد به تصديق المؤمنين، وتكذيب الكافرين، ونزغات الملحدين». <b>الثاني</b>: «أن يراد بالضمير: الكفار من قريش». <span class="comment-type-1">ووجّهه</span> بقوله: «فيكون الاختلاف شكّ بعض وتكذيب بعض، وقولهم سحرٌ وكهانة وشِعر وجنون وغير ذلك».</p><p>وذكر <u>ابنُ عطية</u> (٨/٥١٢) إضافة إلى ما ورد في أقوال السلف في المراد بالنبأ العظيم <b>قولًا</b> آخر، فقال: «و<span class="qpc-hafs">﴿النبأ العظيم﴾</span> قال قوم: هو الشرع الذي جاء به محمد ﷺ».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.تفسير مقاتل بن سليمان ٤/٥٥٧.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر. والوارد عن ابن جرير الرواية التالية.أخرجه ابن جرير ٢٤/٦.تفسير مقاتل بن سليمان ٤/٥٥٧.أخرجه ابن جرير ٢٤/٦.
  78,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی هُمۡ فِیهِ مُخۡتَلِفُونَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span>، قال: مُصدِّق، ومُكذِّب{1}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span>، قال: هو البعْث بعد الموت، صار الناس فيه رجلين؛ مُصدِّق، ومُكذِّب، فأمّا الموت فأَقرُّوا به كلّهم لمعاينتهم إياه، واختلفوا في البعْث بعد الموت{2}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span> يقول: لِمَ يسألون عن القرآن وهم يخالفونه، ولا يؤمنون به؟! فصَدَّق بعضُهم به، وكفر بعضُهم به، فاختلفوا فيه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٧-٥٥٨.
  78,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّا سَیَعۡلَمُونَ ۝٤ ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في حَيّين من أحياء العرب، يعني: [بني] عبد مناف بن قُصي، وبني سهم بن عمرو بن هُصَيص بن كعب{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَلَّا سَیَعۡلَمُونَ ۝٤ ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٢٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق ثابت-: <span class="qpc-hafs">﴿كَلّا سَيَعْلَمُونَ﴾</span> الكفار، <span class="qpc-hafs">﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span> المؤمنون. وكذلك كان يقرؤها{2}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿كَلّا سَيَعْلَمُونَ ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span>، قال: وعيد بعد وعيد{3}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم الوعيد، فقال: <span class="qpc-hafs">﴿كَلّا سَيَعْلَمُونَ﴾</span> إذا قُتِلوا ببدر، وتَوفّتهم الملائكة ظالمي أنفسهم، يَضربون وجوههم وأدبارهم، ثم قال: <span class="qpc-hafs">﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span> وعيد على أثر وعيد ...، نظيرها في <span class="qpc-hafs">﴿ألْهاكُمُ التَّكاثُرُ﴾</span>{4}<span class=comment-ref>٦٩٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٠</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٤/٧-٨) أنّ قوله: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> في الموضعين وعيد، كما أفاده قول مقاتل، وقول الحسن، ثم ذكر قول الضَّحّاك، ولم يعلّق عليه.</p><p>وذكر <u>ابنُ عطية</u> (٨/٥١٣) في الآية قراءات، و<span class="comment-type-1">وجّه</span> المعنى عليها، فقال: «وقرأ السبعة، والحسن، وأبو جعفر، وشيبة، والأعمش: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> بالياء في الموضعين على ذِكر الغائب، فظاهر الكلام أنه ردٌّ على الكفار في تكذيبهم وعيد لهم في المستقبل، وكرّر الزجر تأكيدًا، وقال الضَّحّاك: المعنى: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> يعني: الكفار على جهة الوعيد، <span class="qpc-hafs">﴿ثم كلا سيعلمون﴾</span> يعني: المؤمنين على جهة الوعد. وقرأ ابن عامر فيما روى عنه مالك بن دينار والحسن بخلاف: (كَلّا سَتَعْلَمُونَ) بالتاء في الموضعين على مخاطبة الحاضر، كأنه تعالى يقول: قُل لهم، يا محمد، وكرِّر عليهم الزجر والوعيد تأكيدًا. وكلّ تأويل في هذه القراءة غير هذا فمتعسف. وقرأ قوم: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> بالياء على جهة الردّ والوعيد للكفار، (ثم كلا ستعلمون) بالتاء من فوق على جهة الردّ على الكفار والوعد للمؤمنين».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨.أخرجه ابن جرير ٢٤/٨.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٨. وأشار بالنظير إلى قوله تعالى: <span class="qpc-hafs">﴿كلا سوف تعلمون ثم كلا سوف تعلمون﴾</span> [التكاثر:٣-٤].
