quran[45]{c,v,t}:
  50,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧١٨٨٩<span class="dash">-</span></span> عن أبي أُمامة، قال: قال رسول الله ﷺ: «<b>أعطاني ربّي السَّبع الطُّوَل مكان التوراة، والمِئين مكان الإنجيل، وفُضِّلتُ بالمُفصّل</b>»{1}. (١٣/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٠<span class="dash">-</span></span> عن أبي قِلابة، عن النبيِّ ﷺ، قال: «<b>أُعطِيتُ السَّبع مكان التوراة، وأُعطِيتُ المثاني مكان الإنجيل، وأُعطِيتُ كذا مكان الزَّبُور، وفُضِّلتُ بالمُفصّل</b>»{2}. (١٣/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩١<span class="dash">-</span></span> عن واثِلة، قال: قال رسول الله ﷺ: «<b>أُعطيتُ مكان التوراة السَّبع الطُّوال، وأُعطِيتُ مكان الزَّبُور المِئين، وأُعطِيتُ مكان الإنجيل المثاني، وفُضِّلتُ بالمُفصّل</b>»{3}. (١٣/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٢<span class="dash">-</span></span> عن أوْس بن حُذَيفة، قال: قدِمنا في وفْد ثَقِيف، فسألتُ أصحاب رسول الله ﷺ: كيف تُحزِّبون القرآن؟ قالوا: ثلاث، وخمس، وسبع، وتسع، وإحدى عشرة، وثلاث عشرة، وحزب المُفصّل وحده{4}. (١٣/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٣<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق عبد الله بن حبيب- قال: نزل المُفصّل بمكة، فمكثنا حِجَجًا نقرؤه لا ينزل غيره{5}. (١٣/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق المسيّب- قال: الطُّوَل كالتوراة، والمئُون كالإنجيل، والمثاني كالزَّبُور، وسائر القرآن بعدُ فضلٌ على الكتب{6}. (١٣/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: إنّ لكلّ شيء لُبابًا، وإنّ لُباب القرآن المُفصّل{7}. (١٣/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكِّيَّة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكِّيَّة، وذكرها بمسمى: <span class="qpc-hafs">﴿ق والقرآن المجيد﴾</span>، وأنها نزلت بعد سورة المرسلات{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٨<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت سورة ق بمكّة{10}. (١٣/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٨٩٩<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{10}. (١٣/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٠<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠١<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكِّيَّة، وذكراها بمسمى: <span class="qpc-hafs">﴿ق والقرآن المجيد﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٢<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكِّيَّة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٣<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكِّيَّة، وذكرها <span class="qpc-hafs">﴿ق والقرآن المجيد﴾</span>، وأنها نزلت بعد سورة المرسلات{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٤<span class="dash">-</span></span> عن علي بن أبي طلحة: مكِّيَّة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٥<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة ق مكِّيَّة، عددها خمس وأربعون آية كوفيّة{16}<span class=comment-ref>٦١١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١١٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٢٩) أن هذه السورة مكية <span class="mustanad">بإجماع من المتأولين</span>.</div></p><p><h3><span class="qpc-hafs">﴿قۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ق﴾</span> و<span class="qpc-hafs">﴿ن﴾</span> [القلم: ١] وأشباه هذا: فإنه قسَمٌ أقسَمه الله، وهو اسم من أسماء الله{17}. (١٣/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنه قال: <span class="qpc-hafs">﴿ق﴾</span> هو جبل أخضر من زُمُرّد، خُضرة السماء منه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: خلَق الله جبلًا يُقال له: ق، محيط بالعالم، وعروقه إلى الصخرة التي عليها الأرض، فإذا أراد الله أن يُزلزل قريةً أمر ذلك الجبل، فحرَّك ذلك العِرْق الذي يلي تلك القرية، فيُزلزِلها ويحرِّكها، فمِن ثَمَّ تَحَرَّك القريةُ دون القرية{19}. (١٣/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ليث بن أبي سليم، عن مجاهد- قال: خلَق الله تعالى مِن وراء هذه الأرض بحرًا محيطًا بها، ثم خلق مِن وراء ذلك جبلًا يُقال له: ق، السماء الدنيا مُترفرِفة عليه، ثم خلَق من وراء ذلك الجبل أرضًا مثل تلك الأرض سبع مرات، ثم خلق مِن وراء ذلك بحرًا محيطًا بها، ثم خلق من وراء ذلك جبلًا يُقال له: ق، السماء الثانية مُترفرِفة عليه، حتى عدَّ سبع أرَضين، وسبعة أبحر، وسبعة أجبُل، وسبع سموات، قال: وذلك قوله: <span class="qpc-hafs">﴿والبَحْرُ يَمُدُّهُ مِن بَعْدِهِ سَبْعَةُ أبْحُرٍ﴾</span> [لقمان:٢٧]{20}<span class=comment-ref>٦١١٩</span>. (١٣/٦١٢)</p></p><p></div></p><p><div><span class=comment-ref>٦١١٩</span> <span class="comment-type-4">ذكر</span> <u>ابن كثير</u> (١٣/١٨٠-١٨١) أنه أثر غريب لا يصحّ سنده عن ابن عباس، وقال: «والذي رواه ابن أبي طلحة، عن ابن عباس في قوله: <span class="qpc-hafs">﴿ق﴾</span> قال: هو اسم من أسماء الله ﷿. والذي ثبت عن مجاهد: أنه حرف من حروف الهجاء، كقوله: (ص، ن، حم، طس، الم) ونحو ذلك. فهذه تبعد ما تقدم عن ابن عباس».</div></p><p><div></p><p><p><span class="item-no">٧١٩١٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن بُرَيدة</span>، في قوله: <span class="qpc-hafs">﴿ق﴾</span>، قال: جبل من زُمُرّد، محيط بالدنيا، عليه كَنَفا السماء{21}. (١٣/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الملك ابن جُرَيْج- قال: <span class="qpc-hafs">﴿ق﴾</span> جبل محيط بالأرض{22}. (١٣/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١٢<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١٣<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ق﴾</span> هو جبل محيط بالأرض، مِن زُمُرّدة خضراء، خُضرة السماء منه، وعليه كتفا السماء، والسماء عليه مُقَبَّبة، وما أصاب الناس مِن زُمُرّد فهو مِمّا تساقط مِن ذلك الجبل{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿ق﴾</span> اسم مِن أسماء القرآن{24}. (١٣/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١٥<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿ق﴾</span> افتتاح أسماء الله: قدير، وقادر، وقاهر، وقاض، وقابض{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿ق﴾</span> جبل مِن زُمُرُّدة خضراء، محيط بالعالم، فخُضرة السماء منه، ليس من الخلْق شيء على خَلْقه، وتنبت الجبال منه، وهو وراء الجبال، وعروق الجبال كلّها مِن قاف، فإذا أراد الله تعالى زلزلة أرضٍ أوحى إلى المَلَك الذي عنده أن يُحَرِّك عِرقًا مِن الجبل، فتتحرك الأرض التي يريد، وهو أول جبل خُلِقَ، ثم أبو قبيس بعده، وهو الجبل الذي الصفا تحته ودون قاف بمسيرة سنة، جبلٌ تغرب فيه الشمس، يُقال له: الحجاب، فذلك قوله: <span class="qpc-hafs">﴿حَتّى تَوارَتْ بِالحِجابِ﴾</span> [ص:٣٢] يعني: بالجبل، وهو من وراء الحجاب، وله وجهٌ كوجه الإنسان، وقلبٌ كقلوب الملائكة في الخشية لله{26}<span class=comment-ref>٦١٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٠</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٣/١٨٠) القول بأن «ق»: جبل محيط بالأرض <span class="mustanad">مستندًا للدلالة العقلية</span>، فقال: «وكأنّ هذا -والله أعلم- من خرافات بني إسرائيل التي أخذها عنهم بعض الناس، لما رأى من جواز الرواية عنهم فيما لا يُصدّق ولا يُكذّب. وعندي أن هذا وأمثاله وأشباهه من اختلاق بعض زنادقتهم، يُلبّسون به على الناس أمر دينهم، كما افُتري في هذه الأمة -مع جلالة قدْر علمائها وحفّاظها وأئمتها- أحاديث عن النبي ﷺ وما بالعهد مِن قِدَم، فكيف بأمة بني إسرائيل مع طول المدى، وقلّة الحفّاظ النُّقّاد فيهم، وشُرْبهم الخمور، وتحريف علمائهم الكَلِم عن مواضعه، وتبديل كتب الله وآياته! وإنما أباح الشارعُ الرواية عنهم في قوله: «<b>وحدِّثوا عن بني إسرائيل، ولا حرج</b>» فيما قد يجوّزه العقل، فأما فيما تحيله العقول، ويُحكم عليه بالبطلان، ويغلب على الظّنون كذبه، فليس من هذا القبيل».</p><p>و<span class="comment-type-4">نقل</span> (١٣/١٨١) <b>قولًا آخر</b> بأن المراد بـ<span class="qpc-hafs">﴿ق﴾</span>: «قُضي الأمر، والله». وأن قوله: <span class="qpc-hafs">﴿ق﴾</span> دلّتْ على المحذوف من بقيّة الكَلِم <span class="mustanad">كقول الشاعر</span>:</p><p>قلت لها: قفي فقالت: قاف</p><p>و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للغة</span>، فقال: «وفي هذا التفسير نظر؛ لأنّ الحذف في الكلام إنما يكون إذا دلّ دليل عليه، ومِن أين يُفهم هذا من ذِكر هذا الحرف؟».</p><p>وساق <u>ابنُ عطية</u> (٨/٣٠-٣١) الأقوال الواردة عدا قول القُرظيّ، ثم <span class="comment-type-4">علَّق</span> بقوله: «و<span class="qpc-hafs">﴿ق﴾</span> على هذه الأقوال: مُقسَم به وبالقرآن المجيد، وجواب القسم منتظَر».</p><p>و<span class="comment-type-4">ذكر</span> القول الذي قاله ابن كثير، و<span class="comment-type-4">ذكر</span> أقوالًا غيرها، فقال: «<b>قال القُرظيّ</b>: هو دال على أسماء الله تعالى هي: قادر، وقاهر، وقريب، وقاض، وقابض. <b>وقيل:</b> المعنى: قُضي الأمر من رسالتك ونحوه، <span class="qpc-hafs">﴿والقرآن المجيد﴾</span> فجواب القسم في الكلام الذي يدل عليه قاف. <b>وقال قوم</b>: المعنى: قِف عند أمرنا. <b>وقيل المعنى</b>: قُهر هؤلاء الكفرة، وهذا أيضًا وقع عليه القسَم». ثم أورد <b>احتمالًا آخر</b>، فقال: «ويحتمل أن يكون المعنى: قيامهم من القبور حق، والقرآن المجيد». و<span class="comment-type-4">علق</span> عليه بقوله: «فيكون أول السورة مِن المعنى الذي اطَّرد بعد»، ثم قال: «وعلى هذه الأقوال فثَمّ كلام مضمر عنه وقع الإضراب، كأنه قال: ما كذّبوك ببرهان، ونحو هذا مما يليق مظهرًا».</div></p><p><h3><span class="qpc-hafs">﴿قۤۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧١٩١٧<span class="dash">-</span></span> قال <span class="name-2">وهْب بن مُنَبِّه</span>: إنّ ذا القرنين أتى وأَشْرَفَ على جبل قاف، فرأى تحته وحوله جبالًا صغارًا، فقال له: ما أنت؟ قال: أنا قاف. قال: فما هذه الجبال حولك؟ قال: هي عروقي، وما من مدينة من المدائن إلا وفيها عِرْقٌ من عروقي، فإذا أراد الله ﷿ أن يُزلزل تلك الأرض أمرني، فحرّكتُ عِرقي ذلك، فتزلزلت تلك الأرض. فقال له: يا قاف، فأخبِرْني بشيءٍ مِن عظمة الله. قال: إنّ شأن ربّنا لعظيم، تَقْصُرُ عنه الصفات، وتنقضي دونه الأوهام. قال: فأخبِرني بأدنى ما يوصف منها. قال: إنّ ورائي لَأرضًا مسيرة خمسمائة عام، في عَرض خمسمائة عام، مِن جبال ثلجٍ يَحْطِمُ بعضه بعضًا، لولا ذاك الثلج لاحترقتُ من حرّ جهنم. قال: زدني. قال: إنّ جبريل ﵇ واقف بين يدي الله سبحانه تَرْعُدُ فرائصه، يخْلق الله من كل رِعْدَةٍ مائة ألف مَلك، فأولئك الملائكة وقوف وصفوف بين يدي الله سبحانه، مُنكِّسو رؤوسهم، فإذا أذن الله لهم في الكلام قالوا: لا إله إلا الله، وهو قوله: <span class="qpc-hafs">﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا لا يَتَكَلَّمُونَ إلّا مَن أذِنَ لَهُ الرَّحْمَنُ وقالَ صَوابًا﴾</span> [النبأ:٣٨]، يعني: قول: لا إله إلا الله{27}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡقُرۡءَانِ ٱلۡمَجِیدِ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿والقُرْآنِ المَجِيدِ﴾</span>، قال: الكريم{28}. (١٣/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿والقُرْآنِ المَجِيدِ﴾</span> ليس شيء أحسن منه ولا أفضل{29}. (١٣/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر بن أبي المُغيرة- <span class="qpc-hafs">﴿ق والقُرْآنِ المَجِيدِ﴾</span>، قال: الكريم{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والقُرْآنِ المَجِيدِ﴾</span>، يعني: والقرآن الكريم{26}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ٨/٢٥٨ (٨٠٠٣، ٨٠٠٤).</p><p>قال الهيثمي في المجمع ٧/١٥٨ (١١٦٢٦): «فيه ليث بن أبي سليم، وقد ضعّفه جماعة، ويُعتبر بحديثه، وبقية رجاله رجال الصحيح».أخرجه ابن الضريس في فضائل القرآن ص٨٢ (١٥٧)، ص١٢٧ (٢٩٩)، وابن جرير ١/٩٦-٩٧ بنحوه.</p><p>وقال الألباني في الصحيحة ٣/٤٦٩: «إسناده صحيح مرسل».أخرجه أحمد ٢٨/١٨٨ (١٦٩٨٢)، وابن جرير ١/٩٦، والثعلبي ٩/٦٨.</p><p>قال المنذري في الترغيب والترهيب ٢/٢٤٠ (٢٢٤٢): «رواه أحمد، وفي إسناده عمران القطان». وقال ابن كثير في تفسيره ١/١٥٤ عن رواية نسبها لأبي عبيد: «هذا حديث غريب، وسعيد بن بشير فيه لين». وقال الهيثمي في المجمع ٧/٤٦ (١١١٠٩): «رواه أحمد، وفيه عمران القطان، وثّقه ابن حبان وغيره، وضعّفه النسائي وغيره، وبقية رجاله ثقات». وقال المناوي في التيسير ١/١٧٢: «وفيه عمران القطان». وقال الألباني في الصحيحة ٣/٤٦٩ (١٤٨٠): «وهذا إسناد حسن، رجاله ثقات رجال الشيخين، غير عمران القطان فهو حسن الحديث، للخلاف المعروف فيه ... فالحديث بمجموع طرقه صحيح».أخرجه ابن أبي شيبة ٢/٥٠١-٥٠٢، وأحمد ٢٦/٨٨-٨٩ (١٦١٦٦)، وأبو داود (١٣٩٣)، وابن ماجه (١٣٤٥).أخرجه الطبراني في الأوسط (٦٣٤٤).</p><p>وقال الهيثمي في مجمع الزوائد ٧/١٥٧: «فيه خديج بن معاوية، وثّقه أحمد وغيره، وضعّفه جماعة».أخرجه ابن جرير ١/٩٧.أخرجه الدارمي ٢/٤٤٧، والطبراني (٨٦٤٤)، والبيهقي في الشعب (٢٤٨٧). وعزاه السيوطي إلى محمد بن نصر.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (ت: اللاحم) ٣/٢٠ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصَيف عن مجاهد.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/١٠٧.أخرجه ابن جرير ٢١/٤٠٠. وعزاه السيوطي إلى ابن المنذر مختصرًا.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٦٩-. وتفسير الثعلبي ٩/٩٢-٩٣ وذكر أنه رواية أبي الحوراء، عن عبد الله بن عباس.أخرجه ابن أبي الدنيا في العقوبات (٢٢)، وأبو الشيخ في العظمة (٩٩١).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٧٢-.أخرجه أبو الشيخ (٩٩٢)، والحاكم ٢/٤٦٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه عبد الرزاق ٢/٢٣٦.تفسير الثعلبي ٩/٩٢-٩٣.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ٩/٩٢.تفسير مقاتل بن سليمان ٤/١٠٩.تفسير الثعلبي ٩/٩٣.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢١/٤٠١.تفسير مقاتل بن سليمان ٤/١٠٩.
  50,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ عَجِبُوۤا۟ أَن جَاۤءَهُم مُّنذِرࣱ مِّنۡهُمۡ فَقَالَ ٱلۡكَـٰفِرُونَ هَـٰذَا شَیۡءٌ عَجِیبٌ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٢٢<span class="dash">-</span></span> قال <b>⟨الحسن البصري</b>:⟩{ت} وقع القَسَم على تعجُّب المشركين مما جاء به محمد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ عَجِبُوا أنْ جاءَهُمْ مُنْذِرٌ مِنهُمْ﴾</span> يعني: محمدًا، <span class="qpc-hafs">﴿فَقالَ الكافِرُونَ﴾</span> من أهل مكة: <span class="qpc-hafs">﴿هذا شَيْءٌ عَجِيبٌ﴾</span> يعني: هكذا الأمر! عجيب أن يكون محمدٌ رسولًا، وذلك أنّ كفار مكّة كذّبوا بمحمد ﷺ{2}<span class=comment-ref>٦١٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢١</span> على هذا القول فالضمير في قوله: <span class="qpc-hafs">﴿عجبوا﴾</span> للكافرين، وكرّر الكلام تأكيدًا ومبالغة، وهو ما <span class="comment-type-4">ذكره</span> <u>ابنُ عطية</u> (٨/٣٢)، ثم <span class="comment-type-4">بيّن</span> أن الإشارة بـ<span class="qpc-hafs">﴿هذا﴾</span> عليه تحتمل احتمالين: <b>الأول</b>: أن تكون إلى نفس مجيء البشر. <b>الثاني</b>: أن تكون إلى القول الذي يتضمنه الإنذار، وهو الخبر بالبعث. و<span class="comment-type-4">علَّق</span> عليه بقوله: «ويؤيد هذا القول ما يأتي بعد». وساق <b>قولًا آخر</b> وهو: أن يكون الضمير لجميع الناس مؤمنهم وكافرهم. و<span class="comment-type-4">علَّق</span> عليه بقوله: «لأن كل مفطور عجِب من بعثة بشر رسولًا لله، لكن المؤمنون نظروا واهتدوا، والكافرون بقوا في عمايتهم، وصمّوا وحاجّوا بذلك العجب، <span class="mustanad">ولذلك قوله تعالى</span>: <span class="qpc-hafs">﴿فقال الكافرون هذا شيء عجيب﴾</span>».</div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٦٩-.تفسير مقاتل بن سليمان ٤/١٠٩-١١٠.
  50,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰاۖ ذَ ٰ⁠لِكَ رَجۡعُۢ بَعِیدࣱ ۝٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧١٩٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا ذلِكَ رَجْعٌ﴾</span> نزلَتْ في أُبيّ بن خلف الجُمَحي، وأبي الأشدّين، واسمه: أسيد بن كلدة، وهما من بني جُمح، ونبيه ومُنَبِّه أخوين، ابني الحجاج السَّهميّين، وكلّهم من قريش، وقالوا: إنّ الله لا يُحيينا، وكيف يَقْدِرُ علينا إذا كُنّا ترابًا وضَلَلنا في الأرض؟!{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰاۖ ذَ ٰ⁠لِكَ رَجۡعُۢ بَعِیدࣱ ۝٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧١٩٢٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا ذلِكَ رَجْعٌ﴾</span>، قالوا: كيف يُحيينا الله، وقد صِرنا عظامًا ورُفاتًا، وضَلَلنا في الأرض؟!{2}<span class=comment-ref>٦١٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٢</span> <span class="comment-type-4">قال</span> <u>ابن جرير</u> (٢١/٤٠٣-٤٠٤): «في هذا الكلام متروكٌ استُغْنِي بدلالة ما ذُكر عليه مِن ذكره، وذلك أنّ الله دلّ بخبره عن تكذيب هؤلاء المشركين الذين ابتدأ هذه السورة بالخبر عن تكذيبهم رسوله محمدًا ﷺ بقوله: <span class="qpc-hafs">﴿بل عجبوا أن جاءهم منذر منهم فقال الكافرون هذا شيء عجيب﴾</span> على وعيده إيّاهم على تكذيبهم محمدًا ﷺ، فكأنه قال لهم -إذ قالوا منكرين رسالة الله رسوله محمدًا ﷺ: <span class="qpc-hafs">﴿هذا شيء عجيب﴾</span>-: ستعلمون -أيها القوم- إذا أنتم بُعثتم يوم القيامة ما يكون حالكم في تكذيبكم محمدًا ﷺ، وإنكاركم نبوته. فقالوا مجيبين رسول الله ﷺ: <span class="qpc-hafs">﴿أئذا متنا وكنا ترابا﴾</span> نعلم ذلك، ونرى ما تعِدنا على تكذيبك <span class="qpc-hafs">﴿ذلك رجع بعيد﴾</span> أي: أن ذلك غير كائن، ولسنا راجعين أحياء بعد مماتنا. فاستغني بدلالة قوله: <span class="qpc-hafs">﴿بل عجبوا أن جاءهم منذر منهم فقال الكافرون هذا شيء عجيب﴾</span> مِن ذِكر ما ذكرت مِن الخبر عن وعيدهم». ثم <span class="comment-type-4">ذكر</span> أن قول الضَّحّاك فيه دلالة على صحة ما قاله مِن أنهم أنكروا البعث إذا تُوعّدوا به.</div></p><p><div></p><p><p><span class="item-no">٧١٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا ذلِكَ رَجْعٌ﴾</span> إلى الحياة <span class="qpc-hafs">﴿بَعِيدٌ﴾</span> بأنّ البعث غير كائن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ذَلِكَ رَجْعٌ بَعِيدٌ﴾</span>، قال: أنكروا البعث، فقالوا: مَن يستطيع أن يُرْجعنا ويُحيينا؟!{4}. (١٣/٦١٤)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٣.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن المنذر -كما في الفتح ٨/٥٩٣-.
  50,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَدۡ عَلِمۡنَا مَا تَنقُصُ ٱلۡأَرۡضُ مِنۡهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span>، قال: مِن أجسادهم، وما يذهب منها{1}. (١٣/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span>، قال: ما تأكل الأرض من لحومهم، وأبشارهم، وعِظامهم، وأشعارهم{2}. (١٣/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span>، قال: من عظامهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿قد علمنا ماتنقص الأرض منهم﴾</span>، قال: ما تأكل الأرض من دمائهم، ولحومهم، وأشعارهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span>، يقول: ما أكَلت الأرض منهم ونحن عالِمون به، وهم عندي مع عِلْمي فيهم في كتاب حفيظ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span> ما تأكل الأرض من أبدانهم{6}<span class=comment-ref>٦١٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٣</span> نسب <u>ابنُ عطية</u> (٨/٣٣) هذا القولَ للسُّدّي، ثم <span class="comment-type-4">علَّق</span>، بقوله: «وهذا قول حسن، مضمّنه الوعيد».</div></p><p><div></p><p><p><span class="item-no">٧١٩٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span>، يعني: الموت، تأكلهم الأرض إذا ماتوا{7}. (١٣/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span> هو الموت، يقول: قد علِمنا مَن يموت منهم، ومَن يبقى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span> يقول: ما أكَلت مِن الموتى من لحوم، وعروق، وعظام بني آدم، ما خلا العُصْعُصَ{9}، وتأكل لحوم الأنبياء والعروق، ما خلا عظامهم، مع عِلْمي فيهم{10}<span class=comment-ref>٦١٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٤</span> <span class="comment-type-4">نقل</span> <u>ابن عطية</u> (٨/٣٣) عن الثعلبي أنّ ابن عباس قال: معناه: قد علمنا ما تنقص أرض بالإيمان من الكفرة الذين يدخلون في الإيمان. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للسياق</span>، فقال: «وهذا قول أجنبي من المعنى الذي قبلُ وبعدُ». و<span class="comment-type-4">ذكر</span> أنّ حفظ ما تنقص الأرض إنما هو ليعود بعينه يوم القيامة، وأن هذا هو الحق. و<span class="comment-type-4">نقل</span> عن بعض الأصوليين أنهم ذهبوا إلى أن الأجساد المُبعثرة المبعوثة يجوز أن تكون غير هذه. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للقرآن</span>، فقال: «وهذا عندي خلافٌ لظاهر كتاب الله، ولو كانت غيرها فكيف كانت تشهد الأيدي والأرجل على الكفرة إلى غير ذلك مما يقتضي أنّ أجساد الدنيا هي التي تعود».</div></p><p><h3><span class="qpc-hafs">﴿وَعِندَنَا كِتَـٰبٌ حَفِیظُۢ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٣٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وعِنْدَنا كِتابٌ حَفِيظٌ﴾</span>، قال: لِعِدّتهم، وأسمائهم{11}. (١٣/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</span> ما تأكل الأرض مِن أبدانهم، <span class="qpc-hafs">﴿وعندنا﴾</span> بذلك <span class="qpc-hafs">﴿كتاب حفيظ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعِنْدَنا كِتابٌ حَفِيظٌ﴾</span> يعني: محفوظ من الشياطين، يعني: اللوح المحفوظ{10}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢١/٤٠٤.تفسير مجاهد ص٦١٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٦-، وابن جرير ٢١/٤٠٤. وعلّقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التفسير، عقب باب تفسير سورة ق ٤/١٨٣٤.أخرجه إسحاق البستي ص٤٠٠.أخرجه ابن جرير ٢١/٤٠٥.أخرجه عبد الرزاق ٣/٢٢٧.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٤-٤٠٥، ومن طريق سعيد بنحوه.تفسير الثعلبي ٩/٩٤، وتفسير البغوي ٧/٣٥٦.هو عَظْم عَجْب الذَّنَب. النهاية (عصعص).تفسير مقاتل بن سليمان ٤/١١٠.أخرجه إسحاق البستي ص٤٠٠ من طريق جويبر بلفظ: بعدتهم وأسمائهم. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٣/٢٢٧.تفسير مقاتل بن سليمان ٤/١١٠.
  50,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ كَذَّبُوا۟ بِٱلۡحَقِّ لَمَّا جَاۤءَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿بَلْ كَذَّبُوا بِالحَقِّ لَمّا جاءَهُمْ﴾</span>: أي: كذّبوا بالقرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ كَذَّبُوا بِالحَقِّ﴾</span> يعني: بالقرآن <span class="qpc-hafs">﴿لَمّا جاءَهُمْ﴾</span> يعني: حين جاءهم به محمد{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُمۡ فِیۤ أَمۡرࣲ مَّرِیجٍ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>، يقول: مُختَلِف{3}. (١٣/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>، يقول: في أمر ضلالة{4}. (١٣/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي جَمرة- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>. يقول: المريج: الشيء المُنكر المُتغيّر، أما سمعت قول الشاعر:</p><p>فجالتْ والتمستُ به حشاها فخرّ كأنه خَوْطٌ{5} مريجُ؟{6}. (١٣/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>. قال: مُختلط. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>فَراغَتْ فانتَفَذَتْ به حشاها فخرّ كأنه خوطٌ مريجُ؟{7}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>-من طريق جعفر بن أبي المغيرة- في قوله: <span class="qpc-hafs">﴿فَهُمْ فِي أمْرٍ مَرِيجٍ﴾</span>، قال: مُلْتَبِس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>، قال: مُلتبس{9}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span> ما ترك قومٌ الحقَّ إلا مَرَج أمرهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٤٩<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span> أمر ضلالة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>، قال: مُلْتَبِسٌ عليهم أمره{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>، قال: مَن ترك الحق مَرَج عليه رأيه، والتبس عليه دينه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿أمر مريج﴾</span>، قال: أمرٌ مُلتبسٌ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿فَهُمْ فِي أمْرٍ مَرِيجٍ﴾</span>، يعني: مُختلفٌ مُلتبسٌ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿فِي أمْرٍ مَرِيجٍ﴾</span>، قال: المريج: المُختلط{16}<span class=comment-ref>٦١٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٥</span> اختُلف في قوله: <span class="qpc-hafs">﴿مريج﴾</span> على أقوال: <b>الأول</b>: أنّ المريج: المختلط. <b>الثاني</b>: المختلف. <b>الثالث</b>: في أمر ضلالة. <b>الرابع</b>: الملتبس. <b>الخامس</b>: المُنكر.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢١/٤٠٨) أن هذه الأقوال متقاربة المعاني <span class="mustanad">بدلالة اللغة</span>، فقال معللًا: «لأن الشيء المُختلف مُلتبسٌ معناه مشكل، وإذا كان كذلك كان منكرًا؛ لأنّ المعروف واضح بيّن، وإذا كان غير معروف كان لاشك ضلالة؛ لأن الهدى بيّن لا لبس فيه».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٤) على القول الأول الذي قاله ابن عباس، وابن زيد، فقال: «أي: بعضهم يقول: ساحر. وبعضهم يقول: كاهن. وبعضهم يقول: شاعر. إلى غير ذلك من تخليطهم، وكذلك عادت فكرةُ كلِّ واحد منهم مختلطة في نفسها». و<span class="comment-type-4">ذكر</span> قولًا آخر بأن المريج: المضطرب، و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهو قريب من الأول».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٠٥، ٤٠٧.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٦، وابن أبي حاتم -كما في الإتقان ٢/٤٣-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤٠٧.الخوط: الغصن الناعم. مختار الصحاح (خوط).أخرجه ابن جرير ٢١/٤٠٦. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر.أخرجه الطستي في مسائله -كما في الإتقان ٢/٩٦-. وعزاه السيوطي إلى ابن الأنباري في الوقف، والخطيب في تلخيص المتشابه.أخرجه ابن جرير ٢١/٤٠٧.تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤٠٧، ومن طريق جعفر أيضًا. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر.تفسير البغوي ٧/٣٥٧.تفسير الثعلبي ٩/٩٤.أخرجه ابن جرير ٢١/٤٠٥، ٤٠٧.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٧.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٨.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٨.
  50,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَمۡ یَنظُرُوۤا۟ إِلَى ٱلسَّمَاۤءِ فَوۡقَهُمۡ كَیۡفَ بَنَیۡنَـٰهَا وَزَیَّنَّـٰهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَلَمْ يَنْظُرُوا إلى السَّماءِ فَوْقَهُمْ كَيْفَ بَنَيْناها﴾</span> بغير عَمد، <span class="qpc-hafs">﴿وزَيَّنّاها﴾</span> بالكواكب{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا لَهَا مِن فُرُوجࣲ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وما لَها مِن فُرُوجٍ﴾</span>، قال: شُقوق{2}<span class=comment-ref>٦١٢٦</span>. (١٣/٦١٦)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٦</span> ساق <u>ابنُ كثير</u> (١٣/١٨٣) هذا القول، وساق قولين آخرين: <b>الأول</b>: أن معنى <span class="qpc-hafs">﴿فروج﴾</span>: صدوع. <b>الثاني</b>: أن معناها: فتوق. ثم <span class="comment-type-4">علَّق</span> بقوله: «والمعنى متقارب، <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿الذي خلق سبع سموات طباقا ما ترى في خلق الرحمن من تفاوت فارجع البصر هل ترى من فطور. ثم ارجع البصر كرتين ينقلب إليك البصر خاسئا وهو حسير﴾</span> [الملك:٣-٤]».</div></p><p><div></p><p><p><span class="item-no">٧١٩٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: <span class="qpc-hafs">﴿ما لها من فروج﴾</span> مِن شُقوق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما لَها مِن فُرُوجٍ﴾</span> يعني: مِن خَلَل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٥٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وما لَها مِن فُرُوجٍ﴾</span> وقد سأله: الفُروج: الشيء المُتَبرِّئ بعضُه مِن بعض؟ قال: نعم{5}<span class=comment-ref>٦١٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٥) أنّ النقّاش حكى أن هذه الآية تُعطي أن السماء مستديرة، و<span class="comment-type-2">انتقده</span>، فقال: «وليس الأمر كما حُكي، إذا تُدُبّر اللفظ وما يقتضي».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١١٠.تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤٠٨ بلفظ: شق. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر.أخرجه إسحاق البستي ص٤٠٠.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٩.
  50,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ مَدَدۡنَـٰهَا وَأَلۡقَیۡنَا فِیهَا رَوَ ٰ⁠سِیَ وَأَنۢبَتۡنَا فِیهَا مِن كُلِّ زَوۡجِۭ بَهِیجࣲ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿مِن كُلِّ زَوْجٍ بَهِيجٍ﴾</span>. قال: الزّوج: الواحد، والبهيج: الحَسن. قال: وهل تعرف العرب ذلك؟ قال: نعم؛ أما سمعت الأعشى وهو يقول:</p><p>وكلّ زوجٍ من الدِّيباج يَلبَسه أبو قدامة محْبُوًّا بذاك معا؟{1}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿بَهِيجٍ﴾</span>، يقول: حَسن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿مِن كُلِّ زَوْجٍ بَهِيجٍ﴾</span>، قال: حَسن{3}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والأَرْضَ مَدَدْناها﴾</span> يعني: بسطناها مسيرةَ خمسمائة سنة مِن تحت الكعبة، <span class="qpc-hafs">﴿وأَلْقَيْنا فِيها رَواسِيَ﴾</span> يعني: الجبال، وهي ستة أجبُل، والجبال كلّها مِن هذه الستة الأجبُل، <span class="qpc-hafs">﴿وأَنْبَتْنا فِيها﴾</span> في الأرض <span class="qpc-hafs">﴿مِن كُلِّ زَوْجٍ﴾</span> يعني: مِن كلّ صنفٍ مِن النّبْت <span class="qpc-hafs">﴿بَهِيجٍ﴾</span> يعني: حَسن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- وقد سأله: البهيج: هو الحَسن المنظر؟ قال: نعم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:مسائل نافع (٢٣٠). وعزاه السيوطي إلى الطستي.أخرجه ابن جرير ٢١/٤٠٩.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٩ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/١١٠-١١١.أخرجه ابن جرير ٢١/٤٠٩-٤١٠.
  50,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَبۡصِرَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تَبْصِرَةً﴾</span>، قال: بصيرة{1}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿تَبْصِرَةً وذِكْرى﴾</span>، قال: تبصرة من الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿تَبْصِرَةً﴾</span>، قال: نِعَمٌ تبصرةً للعباد{3}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَبْصِرَةً وذِكْرى﴾</span>، يعني: هذا الذي ذَكر مِن خلْقه جعله تبصرةً وتفكِرة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَذِكۡرَىٰ لِكُلِّ عَبۡدࣲ مُّنِیبࣲ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٠<span class="dash">-</span></span> و<span class="name-2">عطاء</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿مُنِيبٍ﴾</span>، قالا: مُخْبِت{5}. (١٣/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وذِكْرى لِكُلِّ عَبْدٍ مُنِيبٍ﴾</span>، قال: المُنيب: المُقبِل بقلبه إلى الله{6}. (١٣/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِكُلِّ عَبْدٍ مُنِيبٍ﴾</span>، يعني: مُخلِص القلب بالتوحيد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿تبصرة وذكرى لكل عبد منيب﴾</span>، قال: راجع. قال <span class="name-3">سفيان</span>: والإنابة: الاقبال{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤١٠، والفريابي -كما في تغليق التعليق ٤/٣١٦، والفتح ٨/٥٩٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤١٠.أخرجه ابن جرير ٢١/٤١٠ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد. وعزاه ابن حجر في الفتح ٨/٥٩٣ إلى عبد الرزاق عن معمر عن قتادة بلفظ: نعمة من الله ﷿.تفسير مقاتل بن سليمان ٤/١١١.أخرجه ابن جرير ٢١/٤١٠. وعزاه السيوطي إلى عَبد بن حميد.أخرجه ابن جرير ٢١/٤١٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/١١١.أخرجه إسحاق البستي ص٤٠٢.
  50,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَزَّلۡنَا مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ مُّبَـٰرَكࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مُلَيْكَة- أنه كان إذا أمطرت السماء يقول: يا جارية، أخرِجي سَرْجي، أخرِجي ثيابي. ويقول: <span class="qpc-hafs">﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</span>{1}. (١٣/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</span>، قال: المطر{2}. (١٣/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٦<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق أبي المليح- قال: البرَكة في القرآن المطر، <span class="qpc-hafs">﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</span>{3}. (١٣/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</span> يعني: المطر، فيه البركة، حياة كلّ شيء{4}<span class=comment-ref>٦١٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٨</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٣٥ بتصرف): «قوله تعالى: <span class="qpc-hafs">﴿ماء مباركا﴾</span> <b>قيل</b>: يعني: جميع المطر، كله يتصف بالبركة، وإن ضرّ بعضه أحيانًا ففيه مع ذلك الضر الخاص البركة العامة. <b>وقال بعض المفسرين</b>: <span class="qpc-hafs">﴿ماء مباركًا﴾</span> يريد به: ماء مخصوصًا خالصًا للبركة، ينزله الله كل سنة، وليس كل المطر يتصف بذلك».</div></p><p><h3><span class="qpc-hafs">﴿فَأَنۢبَتۡنَا بِهِۦ جَنَّـٰتࣲ وَحَبَّ ٱلۡحَصِیدِ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وحَبَّ الحَصِيدِ﴾</span>، قال: الحِنطة{5}. (١٣/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٧٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وحب الحصيد﴾</span>، قال: الحِنطة، والشعير{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وحَبَّ الحَصِيدِ﴾</span>، قال: هو البُرّ والشّعير{7}. (١٣/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَنْبَتْنا بِهِ جَنّاتٍ﴾</span> يعني: بساتين، <span class="qpc-hafs">﴿وحَبَّ الحَصِيدِ﴾</span> يعني: حين يخرج من سُنبله{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَنۢبَتۡنَا بِهِۦ جَنَّـٰتࣲ وَحَبَّ ٱلۡحَصِیدِ ۝٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧١٩٨٢<span class="dash">-</span></span> عن القاسم بن أبي بزَّة، قال: سأل رجلٌ <span class="name-1">عبد الله بن الزبير</span> عن طين المطر. فقال: تسألني عن طهورين جميعًا، قال الله: <span class="qpc-hafs">﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</span>، وقال رسول الله ﷺ: «<b>جُعلتْ لي الأرض مسجدًا وطهورًا</b>»{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري في الأدب المفرد (١٢٢٨).أخرجه أبو الشيخ في العظمة (٧٤٠).أخرجه أبو الشيخ (٧٣٩).تفسير مقاتل بن سليمان ٤/١١١.تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤١١، والفريابي -كما في الفتح ٨/٥٩٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه إسحاق البستي ص٤٠١.أخرجه عبد الرزاق ٢/٢٣٦-٢٣٧، وابن جرير ٢١/٤١١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/١١١.أخرجه عبد الرزاق ١/٣٢ (٩٨).
  50,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلنَّخۡلَ بَاسِقَـٰتࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٨٣<span class="dash">-</span></span> عن قُطْبة، قال: سمعتُ النَّبِيّ ﷺ يقرأ في الصبح: <span class="qpc-hafs">﴿ق﴾</span>، فلما أتى على هذه الآية: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ لَها طَلْعٌ نَضِيدٌ﴾</span> قال قُطْبة: فجعلتُ أقول: ما بُسُوقها؟ فقال: «<b>طُولها</b>»{1}. (١٣/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>، قال: الطُّول{2}. (١٣/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٥<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شدّاد</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>، قال: بُسُوقها: طُولها في إقامة{3}. (١٣/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٦<span class="dash">-</span></span> عن إسماعيل بن أبي خالد، قال: سألت <span class="name-2">عبد الله بن شَدّاد بن الهاد</span> عن قول الله: <span class="qpc-hafs">﴿والنخل باسقات لها طلع نضيد﴾</span>. قال: طُولهنّ، واستواؤهنّ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span> مستويات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٨<span class="dash">-</span></span> عن عبد الله بن عثمان بن خُثَيم، قال: سألتُ <span class="name-2">عكرمة</span> عن قوله: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>، فقلت: ما بُسُوقها؟ قال: بُسُوقها: طَلْعها؛ ألم ترَ أنّه يقال للشاة إذا حانَ وِلادها: أبْسَقَت؟= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٨٩<span class="dash">-</span></span> قال: فرجعتُ إلى <span class="name-2">سعيد بن جُبَير</span>، فقلت له: فقال: كذب، بُسُوقها: طُولها في كلام العرب؛ ألم تر أن الله قال: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span> ثم قال: <span class="qpc-hafs">﴿طَلْعٌ نَضِيدٌ﴾</span>{6}. (١٣/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>، قال: الطّوال{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: بُسُوقها: التفافها{8}. (١٣/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>: الباسقات: الطّوال{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span> مَواقير حَوامل{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>: يعني: طولها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿والنخل باسقات﴾</span>، قال: طوال{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>، يعني: وأنبَتنا بالماء النَّخلَ الطّوال{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿والنَّخْلَ باسِقاتٍ﴾</span>، قال: البُسُوق: الطُّول{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّهَا طَلۡعࣱ نَّضِیدࣱ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿طَلْعٌ نَضِيدٌ﴾</span>، قال: مُتراكِمٌ بعضه على بعض{15}. (١٣/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٩٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿طَلْعٌ نَضِيدٌ﴾</span>، قال: المُنَضَّد{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿طَلْعٌ نَضِيدٌ﴾</span>، قال: نُضِّد بعضه على بعض{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠١<span class="dash">-</span></span> قال <span class="name-2">ابن شهاب</span>: والنّضيد: الذي بعضه فوق بعض{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَها طَلْعٌ﴾</span> يعني: الثمر <span class="qpc-hafs">﴿نَضِيدٌ﴾</span> يعني: منضود بعضه على بعض، مثل قوله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span> [الواقعة:٩]{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّهَا طَلۡعࣱ نَّضِیدࣱ ۝١٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٠٠٣<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأجدع الهَمداني</span> -من طريق أبي عبيدة بن عبد الله بن مسعود- قال: الجنّة نَخلْها نضيدٌ من أصلها إلى فرعها، وتمرتها كالقِلال، كلما نُزعت تمرة عادت مكانها أخرى، وأنهار تجري في غير أخدود، والعنقود منها اثنا عشر ذراعًا{20}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه مسلم ١/٣٣٦، ٣٣٧ (٤٥٧) مختصرًا، والحاكم ٢/٥٠٤ (٣٧٢٨) واللفظ له.</p><p>قال الحاكم: «قد أخرج مسلم هذا الحديث بغير هذه السياقة، ولم يذكر تفسير البسوق فيه، وهو صحيح على شرطه». ووافقه الذهبي.أخرجه ابن جرير ٢١/٤١٢ بلفظ: الطوال، ومن طريق العوفي أيضًا، وابن أبي حاتم -كما في الإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤١٢. وعزاه السيوطي إلى ابن المنذر بلفظ: استقامتها.أخرجه إسحاق البستي ص٤٠٢.تفسير الثعلبي ٩/٩٥، وتفسير البغوي ٧/٣٥٧.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مجاهد ص٦١٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٦-، وابن جرير ٢١/٤١٢. وعلقه البخاري في صحيحه ٤/١٨٣٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤١٢-٤١٣.تفسير الثعلبي ٩/٩٥.أخرجه عبد الرزاق ٢/٢٣٧، وابن جرير ٢١/٤١٣، وكذلك من طريق سعيد، كما أخرجه سعيد بن منصور في سننه -التفسير ٧/٣٩٩ (٢٠٣٤) من طريق أبي عوانة عن قتادة قال: الطوال.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٨.تفسير مقاتل بن سليمان ٤/١١١.أخرجه ابن جرير ٢١/٤١٣.أخرجه ابن جرير ٢١/٤١٣-٤١٤ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢١/٤١٤.أخرجه ابن جرير ٢١/٤١٤، كما أخرجه عبد الرزاق ٢/٢٣٧، وابن جرير ٢١/٤١٤ بنحوه من طريق معمر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٠١ (١٩٨)، ولم يتبين الطريق في النسخة.تفسير مقاتل بن سليمان ٤/١١١.أخرجه سفيان الثوري ص٢٨٠، وإسحاق البستي ص٤٠٢.
  50,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿رِّزۡقࣰا لِّلۡعِبَادِۖ وَأَحۡیَیۡنَا بِهِۦ بَلۡدَةࣰ مَّیۡتࣰاۚ كَذَ ٰ⁠لِكَ ٱلۡخُرُوجُ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٠٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وجعلنا هذا كلّه <span class="qpc-hafs">﴿رِزْقًا لِلْعِبادِ﴾</span>، ثم قال: <span class="qpc-hafs">﴿وأَحْيَيْنا بِهِ﴾</span> يعني: بالماء <span class="qpc-hafs">﴿بَلْدَةً مَيْتًا﴾</span> لم يكن عليها نَبْت؛ فنَبَتت الأرض، <span class="qpc-hafs">﴿كَذلِكَ الخُرُوجُ﴾</span> يقول: وهكذا تَخرجون مِن القبور بالماء، كما أخرجت النَّبْت من الأرض بالماء، فهذا كله مِن صنيعه ليعرفوا توحيد الرب وقدرته على البعث{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١١١.
  50,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ وَأَصۡحَـٰبُ ٱلرَّسِّ وَثَمُودُ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٠٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وأَصْحابُ الرَّسِّ﴾</span>، قال: بئر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿وأَصْحابُ الرَّسِّ﴾</span>: الرّس: بئر قُتل فيها صاحب يس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي بكير- <span class="qpc-hafs">﴿وأَصْحابُ الرَّسِّ﴾</span>: أنهم قوم رسُّوا نبيّهم في بئر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَصْحابُ الرَّسِّ﴾</span>، قال: كانوا بحِجْر، بناحية اليمامة، على آبار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذَّبَتْ قَبْلَهُمْ﴾</span> قبل أهل مكة <span class="qpc-hafs">﴿أصْحابُ الرَّسِّ﴾</span> يعني: أصحاب البئر، واسمها: قلج، وهي البئر التي قُتل فيها حَبيب النَّجار صاحب ياسين{5}<span class=comment-ref>٦١٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٧) أن كعب الأحبار قال: أصحاب الرس هم أصحاب الأخدود. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للتاريخ</span>، فقال: «وهذا ضعيف؛ لأن أصحاب الأخدود لم يُكَذِّبوا نبيًّا، إنما هو مَلك أحرق قومًا».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤١٥.أخرجه ابن جرير ٢١/٤١٥.أخرجه ابن جرير ٢١/٤١٥.أخرجه عبد الرزاق ٢/٢٣٧.تفسير مقاتل بن سليمان ٤/١١١.
  50,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَادࣱ وَفِرۡعَوۡنُ وَإِخۡوَ ٰ⁠نُ لُوطࣲ ۝١٣ وَأَصۡحَـٰبُ ٱلۡأَیۡكَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٠١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عمرو بن عبد الله- أنه قال: <span class="qpc-hafs">﴿الأَيْكة﴾</span> الشّجر المُلتَفّ، وأصحاب الرَّسّ كانتا أُمّتَين، فبعث الله إليهم نبيًّا واحدًا؛ شُعيبًا، وعذّبهما الله بعذابين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَصْحابُ الأَيْكَةِ﴾</span>، قال: كانوا أصحاب غَيْضَة{2}، وكانت عامّة شَجَرهم الدَّوم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَصْحابُ الأَيْكَةِ﴾</span> يعني: غَيْضَةُ الشجر، أكثرها الدَّوم الـمـُــــقْل، وهم قوم شُعيب ﵇{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَوۡمُ تُبَّعࣲۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٠١٣<span class="dash">-</span></span> قال <b>⟨قتادة بن دعامة</b>:⟩{ت} ذمّ الله تعالى قوم تُبّع، ولم يذُمّه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقَوْمُ تُبَّعٍ﴾</span> بن أبي شراح، ويقال: شراحيل الحميري{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠١٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: وكان قوم تُبّع أهل أوثان يعبدونها{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُلࣱّ كَذَّبَ ٱلرُّسُلَ فَحَقَّ وَعِیدِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٠١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَحَقَّ وعِيدِ﴾</span>، قال: ما أُهلكوا به، تخويفًا لهؤلاء{8}. (١٣/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كُلٌّ﴾</span> كلّ هؤلاء <span class="qpc-hafs">﴿كَذَّبَ الرُّسُلَ فَحَقَّ وعِيدِ﴾</span> يعني: فوجب عليهم عذابي، فعذّبتُهم، فاحذروا -يا أهل مكة- مثل عذاب الأمم الخالية، فلا تُكذّبوا محمدًا ﷺ{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤١٥-٤١٦.وهي الشجر الملتف. النهاية (غيض).أخرجه عبد الرزاق ٢/٢٣٧.تفسير مقاتل بن سليمان ٤/١١١.تفسير البغوي ٧/٣٥٨.تفسير مقاتل بن سليمان ٤/١١١.أخرجه ابن جرير ٢١/٤١٦.</p><p><b>وقد تقدم الآثار مفصلةً عن تُبَّع وخبره عند تفسير قوله تعالى: <span class="qpc-hafs">﴿أهُمْ خَيْرٌ أمْ قَوْمُ تُبَّعٍ﴾</span></b> [الدخان:٣٧].أخرجه ابن جرير ٢١/٤١٩. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/١١١.
