  44,49,""
  44,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩ إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، يقول: لستَ بعزيز، ولا كريم{1}. (١٣/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم يقول له المَلك: <span class="qpc-hafs">﴿ذُقْ﴾</span> العذاب، أيها المتعزّز المتكرّم، يوبّخه ويصغّره بذلك، يقول: <span class="qpc-hafs">﴿إنَّكَ﴾</span> زعمت في الدنيا <span class="qpc-hafs">﴿أنْتَ العَزِيزُ﴾</span> يعني: المنيع، <span class="qpc-hafs">﴿الكَرِيمُ﴾</span> يعني: المتكرّم. قال: فكان أبو جهل يقول في الدنيا: أنا أعزّ قريش وأكرمها. فلمّا ذاق شِدّة العذاب في الآخرة قال له المَلك: <span class="qpc-hafs">﴿إنَّ هَذا ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</span> يعني: تشكُّون في الدنيا أنه غير كائن، فهذا مستقرّ الكفار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريج</span>، في قوله: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، قال: هو يومئذ ذليل، ولكن يَستهزئ به، كما كنتَ تُعزّز في الدنيا، وتُكرّم بغير كرم الله وعزّه{3}. (١٣/٢٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩ إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ۝٥٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥٥<span class="dash">-</span></span> عن أبي هريرة، رفعه: «<b>إنّ الله له ثلاثة أثواب؛ اتَّزر بالعِزَّة، وتَسَرْبَل بالرحمة، وارتدى بالكبرياء، فمَن تعزَّز بغير ما أعزّه الله فذلك الذي يُقال له: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، ومَن رحم الناس ﵀، فذلك الذي تسرْبل بِسرْباله الذي ينبغي له، ومَن تكبّر فقد نازع الله رداءه الذي ينبغي له؛ فإنه -تبارك وتعالى- يقول: لا ينبغي لِمَن نازعني أن أُدخِله الجنة</b>»{4}. (١٣/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٦<span class="dash">-</span></span> عن أبي هريرة، عن <span class="name-2">كعب</span> نحوه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٨٢٥.عزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في شعب الإيمان ١٠/٤٦٧ (٧٨١٠)، من طريق بكار بن قتيبة القاضي، عن صفوان بن عيسى، عن ابن عجلان، عن سعيد المقبري، عن أبي هريرة به.</p><p>وسنده ليّن؛ فيه محمد بن عجلان، قال عنه ابن حجر في تقريب التهذيب (٦١٣٦): «صدوق، إلا أنه اختلطت عليه أحاديث أبي هريرة».أخرجه ابن جرير ٢١/٦٢.
  44,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی مَقَامٍ أَمِینࣲ ۝٥١ فِی جَنَّـٰتࣲ وَعُیُونࣲ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿مَقامٍ أمِينٍ﴾</span>، قال: أمِنوا الموت أن يموتوا، وأمِنوا الهَرَم أن يَهْرموا، ولا يجوعوا، ولا يعْروا{1}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span>، قال: أمين مِن الشيطان، والأوصاب، والأحزان{2}<span class=comment-ref>٥٩٢٨</span>. (١٣/٢٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٨</span> لم يذكر <u>ابنُ جرير</u> (٢١/٦٤) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٧٠١٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر مُستقر المؤمنين، فقال: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span> في مساكن، آمنين مِن الخوف والموت، <span class="qpc-hafs">﴿فِي جَنّاتٍ وعُيُونٍ﴾</span> يعني: بساتين، وأنهار جارية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span>، قال: أمِنوا الموت والعذاب{4}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦١<span class="dash">-</span></span> عن الوليد، قال: قال <span class="name-3">زهير بن محمد</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span>، قال: أمِنوا فيه مِن الموت{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٤٥ (٣٦٦٤٦).أخرجه ابن جرير ٢١/٦٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٨٢٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا في ذكر الموت ٥/٤٩٩ (٣١٧).
