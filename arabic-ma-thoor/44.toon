quran[59]{c,v,t}:
  44,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٦٩٨٥٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكيّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٥٨<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت بمكة سورة <span class="qpc-hafs">﴿حم﴾</span> الدُّخان{2}. (١٣/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٥٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراساني-: مكيّة، ونزلت بعد الزُّخرف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٠<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: نزلت بمكة سورة الدخان{2}. (١٣/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦١<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٢<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكيّة. وسمّياها: <span class="qpc-hafs">﴿حم﴾</span> الدُّخان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٣<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٤<span class="dash">-</span></span> عن محمد ابن شهاب الزّهري: مكيّة، وسمّاها: <span class="qpc-hafs">﴿حم﴾</span> الدُّخان، ونزلت بعد <span class="qpc-hafs">﴿حم﴾</span> الزُّخرف{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٥<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٦<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الدُّخان مكيّة، عددها تسع وخمسون آية كوفي{9}<span class=comment-ref>٥٨٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٩٩</span> قال <u>ابنُ عطية</u> (٧/٥٦٩): «هذه السورة مكية، <span class="mustanad">لا أحفظ خلافًا في شيء منها</span>».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصَيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٨١٥.
  44,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حمۤ ۝١ وَٱلۡكِتَـٰبِ ٱلۡمُبِینِ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٨٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والكِتابِ المُبِينِ﴾</span>، يعني: البيّن ما فيه{1}<span class=comment-ref>٥٩٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٠٠</span> ذكر <u>ابنُ عطية</u> (٧/٥٦٩) احتمالين في معنى: <span class="qpc-hafs">﴿المبين﴾</span>، فقال: «<span class="qpc-hafs">﴿المبين﴾</span> يحتمل أن يكون مِن الفعل المتعدي؛ أي: يبيّن الهدى والشرع ونحوه، ويحتمل أن يكون من غير المتعدي؛ أي: هو مبين في نفسه».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨١٧.
  44,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّاۤ أَنزَلۡنَـٰهُ فِی لَیۡلَةࣲ مُّبَـٰرَكَةٍۚ إِنَّا كُنَّا مُنذِرِینَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٨٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ﴾</span>، قال: أُنزل القرآن في ليلة القدر، ثم نزل به جبريلُ على رسول الله ﷺ نجومًا بجواب كلام الناس{1}. (١٣/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ﴾</span>: نزل القرآنُ ليلةَ القدر إلى السماء الدنيا جُملة واحدة، ثم جعل بعد ذلك ينزل نجومًا؛ ثلاث آيات، وأربع آيات، وخمس آيات، وأقلّ مِن ذلك وأكثر. ثم تلا هذه الآية: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span> [الواقعة:٧٥]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>، في قوله: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ﴾</span>، قال: نزل القرآن جملةً على جبريل، وكان جبريل يجيء به بعدُ إلى النبي ﷺ{3}. (١٣/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ﴾</span>، قال: هي ليلة القدر{4}. (١٣/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ﴾</span>: ليلة القدر، ونزلت صُحف إبراهيم في أول ليلةٍ مِن رمضان، ونزلت التوراة لستِّ ليالٍ مضَتْ مِن رمضان، ونزل الزّبور لست عشرة مضَتْ مِن رمضان، ونزل الإنجيل لثمان عشرة مضَتْ مِن رمضان، ونزل الفرقان لأربع وعشرين مضَتْ مِن رمضان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ﴾</span> يعني: القرآن مِن اللوح المحفوظ إلى سماء الدنيا إلى السّفَرة من الملائكة، وهم الكَتبة، وكان ينزل مِن اللوح المحفوظ كل ليلة قَدْر، فيُنزل الله ﷿ من القرآن إلى السماء الدنيا، على قَدر ما ينزل به جبريلُ ﵇ في السّنة إلى مثلها من العام المُقبل، حتى نزل القرآن كلّه في ليلة القدر، <span class="qpc-hafs">﴿فِي لَيْلَةٍ مُبارَكَة﴾</span> نزل القرآن كلّه من اللوح المحفوظ إلى السَّفَرة في ليلة واحدة؛ ليلة القدر، فقبضه جبريل مِن السَّفَرة في عشرين شهرًا، وأدّاه إلى النبي في عشرين سنة، وسُمّيت ليلة القدر ليلة مباركة لما فيها من البركة والخير، <span class="qpc-hafs">﴿إنّا كُنّا مُنْذِرِينَ﴾</span> يعني: بالقرآن{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: ابتُدئ رسول الله ﷺ بالتنزيل في شهر رمضان. قال الله تبارك وتعالى: <span class="qpc-hafs">﴿شهر رمضان الذي أنزل فيه القرآن﴾</span> إلى آخر الآية [البقرة:١٨٥]، وقال الله تعالى: <span class="qpc-hafs">﴿إنا أنزلناه في ليلة القدر﴾</span> إلى آخر السورة، وقال: <span class="qpc-hafs">﴿حم والكتاب المبين إنا أنزلناه في ليلة مباركة إنا كنا منذرين﴾</span>، وقال: <span class="qpc-hafs">﴿إن كنتم آمنتم بالله وما أنزلنا على عبدنا يوم الفرقان يوم التقى الجمعان﴾</span> [الأنفال:٤١] وذلك التقاء رسول الله ﷺ والمشركين ببدر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله ﷿: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ﴾</span>، قال: تلك الليلة ليلة القدر، أنزل الله هذا القرآنَ مِن أُمّ الكتاب في ليلة القدر، ثم أنزله على الأنبياء في الليالي والأيام، وفي غير ليلة القدر{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّاۤ أَنزَلۡنَـٰهُ فِی لَیۡلَةࣲ مُّبَـٰرَكَةٍۚ إِنَّا كُنَّا مُنذِرِینَ ۝٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٨٧٦<span class="dash">-</span></span> عن <span class="name-2">أبي الجَلْد</span>، قال: نزلت صُحف إبراهيم في أول ليلة مِن رمضان، وأُنزلت التوراة لستٍّ خلَوْن مِن رمضان، وأُنزِل الزّبور لثنتي عشرة ليلةً خلَتْ مِن رمضان، وأُنزل الإنجيل لثمانِ عشرة ليلةً خلَتْ من رمضان، وأُنزل القرآن لأربع وعشرين{9}. (١٣/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span>، قال: نزل القرآن مِن السماء العليا إلى السماء الدنيا جميعًا في ليلة القدر، ثم فُصِّل بعد ذلك في تلك السنين{3}. (١٣/٢٤٩)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٩٨-.عزاه السيوطي إلى سعيد بن منصور.أخرجه عبد الرازق ٢/٢٠٥، وابن جرير ٢١/٥-٦ من طريق سعيد. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢١/٥.تفسير مقاتل بن سليمان ٣/٨١٧.سيرة ابن إسحاق ص١٠٩-١١٠.أخرجه ابن جرير ٢١/٦.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى سعيد بن منصور.
  44,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهَا یُفۡرَقُ كُلُّ أَمۡرٍ حَكِیمٍ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٨٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، قال: يُكتب مِن أُمّ الكتاب في ليلة القدر ما يكون في السنة من رزْق، أو موت، أو حياة، أو مطر، حتى يُكتبَ الحُجّاجُ: يحجّ فلان ويحجّ فلان{1}. (١٣/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> أنّ الله يقضي الأُقضية في ليلة النّصف من شعبان، ويسلّمها إلى أربابها في ليلة القدر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبير- قال: إنّك لَترى الرجلَ يمشي في الأسواق، وقد وقع اسمُه في الموتى. ثم قرأ: <span class="qpc-hafs">﴿حم والكِتابِ المُبِينِ إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، يعني: ليلة القدر. قال: ففي تلك الليلة يُفْرَق أمر الدنيا إلى مثلها من قابل؛ موت، أو حياة، أو رزْق، كلّ أمر الدنيا يُفْرق تلك الليلة إلى مثلها من قابل{3}. (١٣/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، في قوله: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، قال: أمر السّنة إلى السّنة، إلا الشقاء والسعادة؛ فإنه في كتاب الله لا يُبدّل ولا يُغيّر{4}. (١٣/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٢<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السُّلَمِيّ</span> -من طريق سعيد بن عبيدة- قال: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، يُدبّر أمر السّنة إلى السّنة في ليلة القدر{5}. (١٣/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٣<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span>، قال: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> هي ليلة القدر، يُجاء بالديوان الأعظم، السّنة إلى السّنة، فيغفر الله ﷿ لمن يشاء، ألا ترى أنه قال: <span class="qpc-hafs">﴿رَحْمَةً مِن رَبِّكَ﴾</span>؟{6}. (١٣/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>. قال: يُفْرَق في ليلة القدر ما يكون في السّنة مِن رزْق أو مصيبة، ثم يُقدّم ما شاء، ويؤخّر ما شاء، فأما كتاب الشقاء والسعادة فإنه ثابت لا يتغيّر{7}. (١٣/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>. قال: في ليلة القدر، كلُّ أمر يكون في السّنة إلى السّنة، إلا الحياة والموت، ويُفْرَق فيها المعايش والمصائب كلّها{8}. (١٣/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، قال: يُقْضى في ليلة القدر كلّ أمر مُحكم{4}. (١٣/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الثوري، عن محمد بن سُوقَة- قال: يُؤذن للحاجّ ببيت الله في ليلة القدر، فيُكتَبون بأسمائهم وأسماء آبائهم، فلا يغادر تلك الليلةَ أحدٌ مِمَّن كُتِبَ. ثم قرأ: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> فلا يُزاد فيهم، ولا يُنقص منهم{10}. (١٣/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق إسماعيل البجلي، عن محمد بن سُوقَة- قال: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> في ليلة النّصف من شعبان يُبرم أمر السّنة، ويُنسخ الأحياء من الأموات، ويُكتب الحاجّ، فلا يُزاد فيهم، ولا يُنقص منهم أحد{11}<span class=comment-ref>٥٩٠١</span>. (١٣/٢٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٠١</span> اختلف المفسرون في تعيين الليلة المباركة التي يُفْرق فيها كلّ أمر حكيم على قولين: <b>الأول</b>: أنها ليلة القدر. وهو قول جمهور المفسرين. <b>الثاني</b>: أنها ليلة النّصف من شعبان. وهو قول عكرمة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢١/٦-١٠)، و<u>ابنُ القيم</u> (٢/٤٤٠)، و<u>ابنُ كثير</u> (١٢/٣٣٤) القول الأول. و<span class="comment-type-2">انتقدوا</span> القول الثاني، <span class="mustanad">استنادًا إلى القرآن</span>، وذلك قوله تعالى: <span class="qpc-hafs">﴿إنا أنزلناه في ليلة القدر﴾</span> [القدر:١]. قال <u>ابنُ كثير</u>: «ومَن قال: إنها ليلة النصف من شعبان -كما رُوي عن عكرمة- فقد أبعد النَّجْعَة، فإنّ نصَّ القرآن أنها في رمضان». ثم أورد حديث عثمان بن محمد بن المغيرة بن الأخنس أن رسول الله ﷺ قال: «تُقطع الآجال من شعبان إلى شعبان، حتى إنّ الرجل لينكح ويولد له، وقد أُخرج اسمه في الموتى». وبيّن عدم صحة الاستدلال به على أنها ليلة النصف من شعبان، فقال: «فهو حديث مرسل، ومثله لا يُعارَضُ به النصوص».</div></p><p><div></p><p><p><span class="item-no">٦٩٨٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيّ</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، قال: عَمَلُ السّنة إلى السّنة{12}. (١٣/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيّ</span> -من طريق سفيان الثوري- في قوله: <span class="qpc-hafs">﴿فيها يفرق كل أمر حكيم﴾</span>، قال: أمر السّنة إلى السّنة. قال: ما كان مِن خلْق، أو أجَل، أو رزْق، أو مصيبة، أو نحو هذا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩١<span class="dash">-</span></span> عن <span class="name-2">أبي نَضْرَة [المُنذر بن مالك العَبْديّ]</span>، قال: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> يُفرق أمر السّنة في كلّ ليلة قدْر؛ خيرها، وشرّها، ورزْقها، وأجَلها، وبلاؤها، ورخاؤها، ومعاشها إلى مثلها من السّنة{14}. (١٣/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> ما يريد الله أن يُنزِل مِن الوحي، ويُنفِذ من الأمور في سمائه وأرضه وخلْقه تلك السّنة، يُنزِلُه في ليلة القدر إلى سمائه، ثم يُنزِله في الأيام والليالي على قَدر، حتى يَحُول الحَوْل من تلك الليلة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ربيعة بن كلثوم- أنّ رجلًا قال له: يا أبا سعيد، ليلة القدر في كل رمضان هي؟ قال: إي، واللهِ، إنها لَفي كلّ رمضان، وإنه لليلة فيها يُفْرَق كلّ أمر حكيم، فيها يقضي الله كلّ أجَل وعَمَلٍ ورزْق إلى مثلها{16}. (١٣/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span> فيها يُفْرق أمر السّنة إلى السّنة. وفي لفظ قال: فيها يُقضى ما يكون مِن السّنة إلى السّنة{17}. (١٣/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩٥<span class="dash">-</span></span> عن <span class="name-2">عمر مولى غُفْرة</span> -من طريق عبد الحميد بن سالم- قال: يُقال: يُنسَخ لملَك الموت مَن يموت مِن ليلة القدر إلى مثلها، وذلك لأنّ الله يقول: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، فتجد الرجل ينكح النساء، ويغرس الغرْس، واسمُه في الأموات{18}. (١٣/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٨٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيها يُفْرَقُ كُلُّ أمْرٍ حَكِيمٍ﴾</span>، يقول: يقضي الله في ليلة القدر كلَّ أمر مُحكَم ما يكون في السّنة كلّها إلى مثلها مِن العام المقبل من الخير والشرّ، والشدة والرخاء، والمصائب{19}. (ز)</p></p><p></div></p></div>",footnotes:1:علّقه محمد بن نصر في قيام رمضان ص١٠٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير البغوي ٧/٢٢٨.أخرجه ابن جرير ٢١/١٠ مختصرًا، والحاكم ٢/٤٤٨، والبيهقي في شعب الإيمان (٣٦٦١). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٩٧-، وابن جرير ٢١/٨، والبيهقي (٣٦٦٣). وعزاه السيوطي إلى محمد بن نصر، وعَبد بن حُمَيد.أخرجه البيهقي (٣٦٦٤).أخرجه ابن جرير ٢١/٩. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير مجاهد ص٥٩٧، وأخرجه ابن جرير ٢١/٨. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٠٥. وعزاه السيوطي إلى محمد بن نصر، وابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ٢١/٩-١٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.</p><p><b>وقد أورد السيوطي ١٣/٢٥٣-٢٦١ عقب تفسير الآية أحاديث كثيرة في فضل ليلة النصف من شعبان.</b>أخرجه محمد بن نصر في قيام رمضان ص١٠٥، وابن جرير ٢١/٨ بنحوه، والبيهقي (٣٦٦٢). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه إسحاق البستي ص٣٢٤.أخرجه البيهقي (٣٦٦٥). وعزاه السيوطي إلى عَبد بن حُمَيد، ومحمد بن نصر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٩٩-.أخرجه ابن جرير ٢١/٧، ومحمد بن نصر ص١٠٥. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/٢٠٥ من طريق معمر، وابن جرير ٢١/٨-٩ من طريقي سعيد ومعمر، والبيهقي (٣٦٦٥). وعزاه السيوطي إلى عَبد بن حُمَيد، ومحمد بن نصر.أخرجه ابن جرير ٢١/٧.تفسير مقاتل بن سليمان ٣/٨١٧.
  44,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡرࣰا مِّنۡ عِندِنَاۤۚ إِنَّا كُنَّا مُرۡسِلِینَ ۝٥ رَحۡمَةࣰ مِّن رَّبِّكَۚ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٨٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْرًا مِن عِنْدِنا﴾</span> يقول: كان أمرًا مِنّا، <span class="qpc-hafs">﴿إنّا كُنّا مُرْسِلِينَ﴾</span> يعني: مُنزلين هذا القرآن، <span class="qpc-hafs">﴿رَحْمَةً مِن رَبِّكَ﴾</span> لِمَن آمن به{1}<span class=comment-ref>٥٩٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٠٢</span> ذكر <u>ابنُ عطية</u> (٧/٥٧٠) احتمالين في قوله تعالى: <span class="qpc-hafs">﴿إنا كنا مرسلين﴾</span>: <b>الأول</b>: أن المراد: «إرسال الرسل والأنبياء». <b>والثاني</b>: أنّ المراد: «الرحمة» التي ذُكِرَت بعد ذلك. ثم <span class="comment-type-4">علَّق</span> على الاحتمال الأول بقوله: «وعلى التأويل الأول نُصب قوله: <span class="qpc-hafs">﴿رحمة﴾</span> على المصدر، و<b>يُحتمَل</b> أن يكون نصبها على الحال».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨١٨.
