  36,17,""
  36,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّا تَطَیَّرۡنَا بِكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالُوا إنّا تَطَيَّرْنا بِكُمْ﴾</span>، قال: يقولون: إنْ أصابنا شرٌّ فإنّما هو مِن أجلكم{1}. (١٢/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال القوم للرسل: <span class="qpc-hafs">﴿قالُوا إنّا تَطَيَّرْنا بِكُمْ﴾</span>، يقول: تشاءمنا بكم، وذلك أنّ المطر حُبِس عنهم، فقالوا: أصابنا هذا الشرُّ -يعنون: قحط المطر- مِن قِبَلِكم{2}<span class=comment-ref>٥٤١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤١١</span> ذكر <u>ابنُ عطية</u> (٧/٢٤٠) في السبب الذي من أجله قالوا: <span class="qpc-hafs">﴿إنا تطيرنا بكم﴾</span> ما جاء في قول مقاتل، وذكر <b>قولًا آخر</b> أنهم قالوا ذلك لأن الجذام انتشر فيهم، ثم <span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى النظائر</span>أن تطيرهم: «إنما كان بسبب ما دخل قريتهم من اختلاف الكلمة وافتتان الناس، وهذا على نحو تطير قريش بمحمد ﷺ، وعلى نحو ما خُوطِب به موسى».</div></p><p><div></p><p><p><span class="item-no">٦٤٤٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالُوا إنّا تَطَيَّرْنا بِكُمْ﴾</span> تشاءمنا بكم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَىِٕن لَّمۡ تَنتَهُوا۟ لَنَرۡجُمَنَّكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لَنَرْجُمَنَّكُمْ﴾</span>، قال: لنشتمنكم. قال: والرجم في القرآن كله: الشتم{4}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَئِنْ لَمْ تَنْتَهُوا لَنَرْجُمَنَّكُمْ﴾</span> لنرجمنكم بالحجارة حتى نقتلكم بها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لَئِنْ لَمْ تَنْتَهُوا لَنَرْجُمَنَّكُمْ﴾</span> بالحجارة{1}<span class=comment-ref>٥٤١٢</span>. (١٢/٣٣٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٤١٢</span> لم يذكر <u>ابنُ جرير</u> (١٩/٤١٦) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿لَنَرْجُمَنَّكُمْ﴾</span>، يعني: لَنقتلنكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال القوم للرسل: <span class="qpc-hafs">﴿لَئِنْ لَمْ تَنْتَهُوا لَنَرْجُمَنَّكُمْ﴾</span> لئن لم تسكتوا عنّا لنقتلنكم{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَیَمَسَّنَّكُم مِّنَّا عَذَابٌ أَلِیمࣱ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿ولَيَمَسَّنَّكُمْ مِنّا عَذابٌ ألِيمٌ﴾</span> ولينالنكم مِنّا عذابٌ مُوجِع{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَيَمَسَّنَّكُمْ﴾</span> يعنى: وليصيبنكم <span class="qpc-hafs">﴿مِنّا عَذابٌ ألِيم﴾</span> يعني: وجيعًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَيَمَسَّنَّكُمْ مِنّا عَذابٌ ألِيمٌ﴾</span> مُوجِع قبل أن نقتلكم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ٢/٨٠٤ بنحوه، وعبد الرزاق ٢/١٤١ من طريق معمر، وابن جرير ١٩/٤١٦. وعزاه السيوطي إلى عبد حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٧٦. وأوله في تفسير الثعلبي ٨/١٢٥ منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ٢/٨٠٤.عزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلام ٢/٨٠٤.أخرجه يحيى بن سلام ٢/٨٠٤ بنحوه، وعبد الرزاق ٢/١٤١ من طريق معمر، وابن جرير ١٩/٤١٦. وعزاه السيوطي إلى عبد حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٠٤.تفسير مقاتل بن سليمان ٣/٥٧٦.أخرجه ابن جرير ١٩/٤١٧.تفسير مقاتل بن سليمان ٣/٥٧٦.تفسير يحيى بن سلام ٢/٨٠٤.
  36,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ طَـٰۤىِٕرُكُم مَّعَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿طائِرُكُمْ مَعَكُمْ﴾</span>، قال: شُؤمكم معكم{1}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿طائركم﴾</span>: مصائبكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٧<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٨<span class="dash">-</span></span> و<span class="name-2">كعب الأحبار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٧٩<span class="dash">-</span></span> و<span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق-: قالت لهم الرسل: <span class="qpc-hafs">﴿طائِرُكُمْ مَعَكُمْ﴾</span>، أي: أعمالكم معكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨١<span class="dash">-</span></span> و<span class="name-2">الضحاك</span>: <span class="qpc-hafs">﴿قالُوا طائِرُكُمْ مَعَكُمْ﴾</span> حظّكم مِن الخير والشرِّ{4}<span class=comment-ref>٥٤١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤١٣</span> ذكر <u>ابنُ عطية</u> (٧/٢٤٠) ما جاء في هذا القول، وقال: «وبهذا فسر الناس». ثم <span class="comment-type-1">وجّهه</span> بقوله: «وسمي الحظ والنصيب طائرًا استعارة، أي: هو مما يحصل عن النظر في الطائر، وكثر استعمال هذا المعنى حتى قالت المرأة الأنصارية: فطار لنا. حين اقتسم المهاجرون عثمان بن مظعون، ويقول الفقهاء: طار لفلان في المحاصَّة كذا».</div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿طائِرُكُمْ مَعَكُمْ﴾</span>، قال: ما كُتِب عليكم واقِعٌ بكم{5}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- <span class="qpc-hafs">﴿قالُوا طائِرُكُمْ مَعَكُمْ﴾</span>: أي: عملكم معكم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالُوا طائِرُكُمْ مَعَكُمْ﴾</span>: أي: أعمالكم معكم{7}. (١٢/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> فقالت الرسل: <span class="qpc-hafs">﴿طائِرُكُمْ مَعَكُمْ﴾</span> الذي أصابكم كان مكتوبًا في أعناقكم{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَىِٕن ذُكِّرۡتُمۚ بَلۡ أَنتُمۡ قَوۡمࣱ مُّسۡرِفُونَ ۝١٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٨٦<span class="dash">-</span></span> قرأ <span class="name-2">زِرُّ بن حُبَيْش</span>: ‹ أأَن ذُكِّرْتُمْ› بالنصب{9}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين</span>، أنه قرأ ذلك: <span class="qpc-hafs">﴿أئِن ذُكِّرْتُمْ﴾</span>{10}<span class=comment-ref>٥٤١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤١٤</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٩/٤١٧-٤١٨) على هذه القراءة، فقال: «قرأته عامة قراء الأمصار: <span class="qpc-hafs">﴿أئن ذكرتم﴾</span> بكسر الألف من»إن«وفتح ألف الاستفهام، بمعنى: إن ذكرناكم فمعكم طائركم. ثم أدخل على»إن«-التي هي حرف جزاء- ألف استفهام في قول بعض نحويي البصرة، وفي قول بعض الكوفيين منوي به التكرير، كأنه قيل: قالوا: طائركم معكم إن ذكرتم فمعكم طائركم، فحذف الجواب اكتفاء بدلالة الكلام عليه».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u> قائلًا (٧/٢٤١ بتصرف): «وقُرِئ <span class="qpc-hafs">﴿أئن﴾</span> بهمزتين الثانية مكسورة، على معنى: أئن ذكرتم تتطيرون».</p><p>ثم <span class="comment-type-3">رجّحها</span> <u>ابنُ جرير</u> <span class="mustanad">مستندًا إلى إجماع الحجة من القراء، وأقوال السلف</span>، فقال: «والقراءة التي لا نجيز القراءة بغيرها القراءة التي عليها قراء الأمصار، وهي دخول ألف الاستفهام على حرف الجزاء، وتشديد الكاف على المعنى الذي ذكرناه عن قارئيه كذلك، لإجماع الجحة من القراء عليه وبنحو الذي قلنا في ذلك قال أهل التأويل».</div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٨<span class="dash">-</span></span> عن <span class="name-2">يحيي بن وثّاب</span>، أنه قرأها: <span class="qpc-hafs">﴿أئِن ذُكِّرْتُمْ﴾</span> بالخفض{5}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٨٩<span class="dash">-</span></span> عن <span class="name-2">الأعمش</span> -من طريق إسماعيل-: (أئِن ذُكِرْتُمْ) مخففة{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَىِٕن ذُكِّرۡتُمۚ بَلۡ أَنتُمۡ قَوۡمࣱ مُّسۡرِفُونَ ۝١٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أئِنْ ذُكِّرْتُمْ﴾</span>، يقول: أئن ذكرناكم بالله تطيرتم بنا!{13}<span class=comment-ref>٥٤١٥</span>. (١٢/٣٣٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٤١٥</span> لم يذكر <u>ابنُ جرير</u> (١٩/٤١٨) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٦٤٤٩١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿أئِنْ ذُكِّرْتُمْ﴾</span>، يعني: وُعِظْتُم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٢<span class="dash">-</span></span> عن هارون، عن إسماعيل، عن <span class="name-2">سليمان بن مهران الأعمش</span>: (أئِن ذُكِرْتُمْ) مخففة، يقول: شؤمكم معكم أئن ذُكِرتم!= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٣<span class="dash">-</span></span> قال: وتفسير <span class="name-2">الحسن البصري</span>: تطيّرون بنا مِن أجل أننا ذكَّرناكم؟!{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أإنْ ذُكِّرْتُمْ﴾</span> أئن وُعظتم بالله ﷿ تطيرتم بنا؟! <span class="qpc-hafs">﴿بَلْ أنْتُمْ قَوْمٌ مُسْرِفُونَ﴾</span> قوم مشركون، والشرك أسرف الذنوب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بَلْ أنْتُمْ قَوْمٌ مُسْرِفُونَ﴾</span> مشركون{17}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم -كما في الفتح ٦/٤٦٧، والتغليق ٤/٣٣-. وعلقه البخاري في صحيحه ٤/١٨٠٦.أخرجه ابن جرير ١٩/٤١٧.تفسير الثعلبي ٨/١٢٥، وتفسير البغوي ٧/١٣.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٨٠٤.أخرجه يحيى بن سلام ٢/٨٠٤ بنحوه، وعبد الرزاق ٢/١٤١ من طريق معمر، وابن جرير ١٩/٤١٧. وعزاه السيوطي إلى عبد حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٧٦.عزاه السيوطي إلى عبد بن حميد.</p><p>و‹أأَن ذُكِّرْتُمْ› بفتح الهمزة الثانية، وتشديد الكاف قراءة متواترة، قرأ بها أبو جعفر، وقرأ بقية العشرة كذلك إلا أنهم كسروا الهمزة الثانية. انظر: النشر ٢/٣٥٣، والإتحاف ص٤٦٦.أخرجه ابن جرير ١٩/٤١٨.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص١٨٣.</p><p>وهي قراءة شاذة، تروى أيضًا عن أبي جعفر. انظر: المحتسب ٢/٢٠٥، ومختصر ابن خالويه ص١٢٥.أخرجه يحيى بن سلام ٢/٨٠٤ بنحوه، وعبد الرزاق ٢/١٤١ من طريق معمر، وابن جرير ١٩/٤١٨. وعزاه السيوطي إلى عبد حميد، وابن المنذر، وابن أبي حاتم. وعقب عليه يحيى بن سلام بقوله: على الاستفهام.علقه يحيى بن سلام ٢/٨٠٤.أخرجه إسحاق البستي ص١٨٣.تفسير مقاتل بن سليمان ٣/٥٧٦.تفسير يحيى بن سلام ٢/٨٠٤.
  36,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَاۤءَ مِنۡ أَقۡصَا ٱلۡمَدِینَةِ رَجُلࣱ یَسۡعَىٰ قَالَ یَـٰقَوۡمِ ٱتَّبِعُوا۟ ٱلۡمُرۡسَلِینَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٤٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ يَسْعى﴾</span>، قال: هو حبيب النجار{1}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ يَسْعى﴾</span>، قال: اسم صاحب يس: حبيب، وكان الجُذام قد أسرع فيه{2}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٨<span class="dash">-</span></span> <span class="name-1">عن عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٤٩٩<span class="dash">-</span></span> و<span class="name-2">كعب الأحبار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٠<span class="dash">-</span></span> و<span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق-: أنّه كان رجلًا مِن أهل أنطاكية، وكان اسمه: حبيبًا، وكان يعمل الجرير{3}، وكان رجلًا سقيمًا، قد أسرع فيه الجذام، وكان منزله عند باب من أبواب المدينة قاصيًا، وكان مؤمنًا ذا صدقة، يجمع كسبه إذا أمسى -فيما يذكرون- فيقسمه نصفين؛ فيطعم نصفًا عياله، ويتصدق بنصف، فلم يهمُّه سقمُه ولا عملُه ولا ضعفه عن عمل ربه، قال: فلما أجمع قومُه على قتل الرسل بلغ ذلك حبيبًا، وهو على باب المدينة الأقصى، فجاء يسعى إليهم يذكِّرهم بالله، ويدعوهم إلى اتباع المرسلين، فقال: <span class="qpc-hafs">﴿يا قَوْمِ اتَّبِعُوا المُرْسَلِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن عبد الرحمن- أنه ذُكِر له حبيبُ بن زيد بن عاصم، أخو بني مازن بن النجار، الذي كان مسيلمة الكذاب قطعه باليمامة حين جعل يسأله عن رسول الله ﷺ، فجعل يقول: أتشهد أنّ محمدًا رسول الله؟ فيقول: نعم. ثم يقول: أتشهد أني رسول الله؟ فيقول له: لا أسمع. فيقول مسيلمة: أتسمع هذا، ولا تسمع هذا؟ فيقول: نعم. فجعل يقطِّعه عضوًا عضوًا، كلما سأله لم يَزِده على ذلك حتى مات في يديه. قال <span class="name-2">كعب</span> -حين قيل له: اسمه: حبيب-: وكان -واللهِ- صاحب يس اسمه: حبيب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: وجاء حبيبٌ وهو يكتم إيمانه، فقال: <span class="qpc-hafs">﴿يا قَوْمِ اتَّبِعُوا المُرْسَلِينَ﴾</span>. فلما رأوه أعلن بإيمانه، فقال: <span class="qpc-hafs">﴿إنِّي آمَنتُ بِرَبِّكُمْ فاسْمَعُونِ﴾</span>. وكان نجارًا؛ ألقوه في بئر، وهي الرس، وهم أصحاب الرس{6}. (١٢/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: كان رجلًا مِن قوم يونس، وكان به جذام، وكان يطيف بآلهتهم يدعوها، إذ مرَّ على قوم مجتمعين، فأتاهم، فإذا هم قد قتلوا نبيين، فبعث الله إليهم الثالث، فلمّا سمع قوله قال: يا عبد الله، إنّ معي ذهبًا، فهل أنت آخذه مِنِّي، وأتَّبعك، وتدعو الله لي؟ قال: لا أريد ذهبك، ولكن اتبعني. فلما رأى الذي به دعا الله له فبرأ، فلما رأى ما صنع به <span class="qpc-hafs">﴿قالَ يا قَوْمِ اتَّبِعُوا المُرْسَلِينَ * اتَّبِعُوا مَن لا يَسْأَلُكُمْ أجْرًا﴾</span> لِما كان عرض عليه مِن الذهب فلم يقبله منه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٤<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلَز لاحق بن حميد</span> -من طريق عاصم الأحول- قال: كان اسم صاحب يس: حبيب بن مُرَي{8}. (١٢/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ يَسْعى﴾</span>، قال: بلغني: أنّه رجل كان يعبد اللهَ في غار، واسمه: حبيب، فسمع بهؤلاء النفر الذين أرسلهم عيسى إلى أهل أنطاكية، فجاءهم{9}. (١٢/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٦<span class="dash">-</span></span> عن <span class="name-2">عمر بن الحكم</span>، في قوله: <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ يَسْعى﴾</span>، قال: بلغنا أنه كان إسكافًا{10}. (١٢/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span>، في قوله: <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ يَسْعى﴾</span>، قال: بلغنا أنه كان إسكافًا{11}. (١٢/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span>، في قوله: <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ يَسْعى﴾</span>، قال: بلغنا أنه كان قصّارًا{12}. (١٢/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ رَجُلٌ﴾</span>: كان حَرّاثًا{6}. (١٢/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاءَ مِن أقْصا المَدِينَةِ رَجُلٌ يَسْعى﴾</span> على رجليه، اسمه: حبيب بن أبريا، أعور، نجار من بني إسرائيل، كان في غارٍ يعبد الله ﷿، فلما سمع بالرسل أتاهم وترك عمله، <span class="qpc-hafs">﴿قالَ يا قَوْمِ اتَّبِعُوا المُرْسَلِينَ﴾</span> الثلاثة: تومان، ويونس، وشمعون، <span class="qpc-hafs">﴿اتَّبِعُوا مَن لا يَسْئَلُكُمْ أجْرًا وهُمْ مُهْتَدُونَ﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وجاءَ مِن أقْصى المَدِينَةِ﴾</span> أنطاكية <span class="qpc-hafs">﴿رَجُلٌ يَسْعى﴾</span> يعني: يسرع، وهو حبيب النجار{15}<span class=comment-ref>٥٤١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤١٦</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١١/٢٥٧-٢٥٨ بتصرف) <span class="mustanad">مستندًا إلى ظاهر القرآن، ودلالة التاريخ، والدلالة العقلية</span> كون المدينة أنطاكية، فقال: «وقد تقدم عن كثير من السلف أن هذه القرية هي أنطاكية... وفي ذلك نظر من وجوه: <b>أحدها</b>: أن أهل أنطاكية آمنوا برسل المسيح إليهم، وكانوا أول مدينة آمنت بالمسيح؛ ولهذا كانت عند النصارى إحدى المدائن الأربعة اللاتي فيهن بَتاركة، وهن: القدس؛ لأنها بلد المسيح، وأنطاكية؛ لأنها أول بلدة آمنت بالمسيح عن آخر أهلها، والإسكندرية؛ لأن فيها اصطلحوا على اتخاذ البتاركة والمطارنة والأساقفة والقساوسة والشمامسة والرهابين، ثم رومية؛ لأنها مدينة الملك قسطنطين الذي نصر دينهم وأطده. ولما ابتنى القسطنطينية نقلوا البترك من رومية إليها، كما ذكره غير واحد ممن ذكر تواريخهم، كسعيد بن بطريق وغيره من أهل الكتاب والمسلمين، فإذا تقرر أن أنطاكية أول مدينة آمنت فأهل هذه القرية قد ذكر الله تعالى أنهم كذبوا رسله، وأنه أهلكهم بصيحة واحدة أخمدتهم، فالله أعلم. <b>الثاني</b>: أن قصة أنطاكية مع الحواريين أصحاب المسيح بعد نزول التوراة، وقد ذكر أبو سعيد الخدري وغير واحد من السلف: أن الله تعالى بعد إنزاله التوراة لم يهلك أمةً مِن الأمم عن آخرهم بعذاب يبعثه عليهم، بل أمر المؤمنين بعد ذلك بقتال المشركين. ذكروه عند قوله تعالى: <span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب من بعد ما أهلكنا القرون الأولى﴾</span> [القصص:٤٣]. فعلى هذا يتعيَّن أن هذه القرية المذكورة في القرآن العظيم قرية أخرى غير أنطاكية، كما أطلق ذلك غير واحد من السلف أيضًا. أو تكون أنطاكية إن كان لفظها محفوظًا في هذه القصة مدينة أخرى غير هذه المشهورة المعروفة، فإن هذه لم يعرف أنها أهلكت لا في الملة النصرانية ولا قبل ذلك».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ تيمية</u> (٥/٣١٨-٣٢٣) في كلام طويل.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٢٠. وعزاه السيوطي إلى ابن أبي حاتم.الجرير: الحبال. التاج (جرر).أخرجه ابن جرير ١٩/٤١٩-٤٢٠.أخرجه ابن جرير ١٩/٤٢٠.عزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ٢/٨٠٥.أخرجه ابن جرير ١٩/٤١٩.أخرجه عبد الرزاق ٢/١٤١، وابن جرير ١٩/٤٢١ بنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم. والإسكاف: كلُّ صانِعٍ سِوى الخَفَّاف، وقيل: النجار، وقيل: كل صانع بيده حديدة. التاج (سكف).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم. والقصار: مبيّض الثياب. التاج (قصر).عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٧٦-٥٧٧.تفسير يحيى بن سلام ٢/٨٠٤.
  36,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱتَّبِعُوا۟ مَن لَّا یَسۡـَٔلُكُمۡ أَجۡرࣰا وَهُم مُّهۡتَدُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٣<span class="dash">-</span></span> و<span class="name-2">كعب الأحبار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٤<span class="dash">-</span></span> و<span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق فيما بلغه- <span class="qpc-hafs">﴿اتَّبِعُوا مَن لا يَسْأَلُكُمْ أجْرًا وهُمْ مُهْتَدُونَ﴾</span>: أي: لا يسألونكم أموالكم على ما جاءوكم به مِن الهدى، وهم لكم ناصحون، فاتبعوهم تهتدوا بهداهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: <span class="qpc-hafs">﴿اتَّبِعُوا مَن لا يَسْأَلُكُمْ أجْرًا﴾</span> لما كان عرض عليه من الذهب فلم يقبله منه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: لما انتهى إليهم -يعني: الرسل- قال: هل تسألون على هذا مِن أجر؟ فقالوا: لا. فقال لقومه: <span class="qpc-hafs">﴿يا قَوْمِ اتَّبِعُوا المُرْسَلِينَ * اتَّبِعُوا مَن لا يَسْأَلُكُمْ أجْرًا وهُمْ مُهْتَدُونَ﴾</span>{3}. (١٢/٣٣٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٢١.أخرجه يحيى بن سلام ٢/٨٠٥.أخرجه عبد الرزاق ٢/١٤١ من طريق معمر، وابن جرير ١٩/٤٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.
  36,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا لِیَ لَاۤ أَعۡبُدُ ٱلَّذِی فَطَرَنِی وَإِلَیۡهِ تُرۡجَعُونَ ۝٢٢ ءَأَتَّخِذُ مِن دُونِهِۦۤ ءَالِهَةً إِن یُرِدۡنِ ٱلرَّحۡمَـٰنُ بِضُرࣲّ لَّا تُغۡنِ عَنِّی شَفَـٰعَتُهُمۡ شَیۡـࣰٔا وَلَا یُنقِذُونِ ۝٢٣ إِنِّیۤ إِذࣰا لَّفِی ضَلَـٰلࣲ مُّبِینٍ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٨<span class="dash">-</span></span> و<span class="name-2">كعب الأحبار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥١٩<span class="dash">-</span></span> و<span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق- قال: ناداهم -يعني: نادى قومه- بخلاف ما هم عليه مِن عبادة الأصنام، وأظهر لهم دينَه وعبادةَ ربِّه، وأخبرهم أنه لا يملك نفعه ولا ضره غيرُه، فقال: <span class="qpc-hafs">﴿وما لِيَ لا أعْبُدُ الَّذِي فَطَرَنِي وإلَيْهِ تُرْجَعُونَ * أأَتَّخِذُ مِن دُونِهِ آلِهَةً﴾</span> ثم عابها، فقال: <span class="qpc-hafs">﴿إنْ يُرِدْنِ الرَّحْمَنُ بِضُرٍّ﴾</span> وشِدَّة <span class="qpc-hafs">﴿لا تُغْنِ عَنِّي شَفاعَتُهُمْ شَيْئًا ولا يُنْقِذُونِ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله تعالى: <span class="qpc-hafs">﴿ومالِي لا أعْبُدُ الَّذِي فَطَرَنِي وإلَيْهِ تُرْجَعُونَ﴾</span>: هذا رجل دعا قومَه إلى الله، وأبدى لهم النصيحة، فقتلوه على ذلك. وذُكر لنا: أنهم كانوا يرجمونه بالحجارة، وهو يقول: اللهم، اهدِ قومي، اللهم، اهدِ قومي، اللهم، اهدِ قومي. حتى أقْعَصُوه{2} وهو كذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٢١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: كانوا يرمونه بالحجارة، وهو يقول: اللهم، اهد قومي. فعلَّقوه بسُور المدينة حتى قطَّعوه وقتلوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأخذوه، فرفعوه إلى الملك، فقال له: برئِتَ مِنّا، واتبعتَ عدونا! فقال:<span class="qpc-hafs">﴿وما لِيَ لا أعْبُدُ الَّذِي فَطَرَنِي﴾</span> خلقني <span class="qpc-hafs">﴿وإلَيْهِ تُرْجَعُونَ * أأَتَّخِذُ مِن دُونِهِ آلِهَةً إنْ يُرِدْنِ الرَّحْمنُ بِضُرٍّ لا تُغْنِ عَنِّي شَفاعَتُهُمْ شَيْئًا﴾</span> لا تقدر الآلهة أن تشفع لي فتكشف الضر عنِّي شفاعتها، <span class="qpc-hafs">﴿ولا يُنْقِذُونِ﴾</span> مِن الضر، <span class="qpc-hafs">﴿إنِّي إذًا لَفِي ضَلالٍ مُبِينٍ﴾</span> لفي خسران بيِّن إن اتخذت مِن دون الله -جلَّ وعزَّ- آلهةً...{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما لِيَ لا أعْبُدُ الَّذِي فَطَرَنِي﴾</span> خلقني <span class="qpc-hafs">﴿وإلَيْهِ تُرْجَعُونَ﴾</span> يوم القيامة، <span class="qpc-hafs">﴿أأَتَّخِذُ مِن دُونِهِ آلِهَةً﴾</span> على الاستفهام، <span class="qpc-hafs">﴿إنْ يُرِدْنِ الرَّحْمَنُ بِضُرٍّ لا تُغْنِ عَنِّي شَفاعَتُهُمْ﴾</span> يعني: الآلهة؛ لِما كان يدعو آلهتهم لِما به مِن الجذام فلم يغن عنه <span class="qpc-hafs">﴿شَيْئًا ولا يُنْقِذُونِ﴾</span> مِن ضُرِّي، يعني: الجذام الذي كان به{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٢٢.أقعصوه: ضربوه فقتلوه مكانه. اللسان (قعص).أخرجه ابن جرير ١٩/٤٢٣-٤٢٤.تفسير الثعلبي ٨/١٢٦.تفسير مقاتل بن سليمان ٣/٥٧٦-٥٧٧.تفسير يحيى بن سلام ٢/٨٠٤-٨٠٥.
