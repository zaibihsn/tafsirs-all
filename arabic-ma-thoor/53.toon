  53,26,""
  53,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ لَیُسَمُّونَ ٱلۡمَلَـٰۤىِٕكَةَ تَسۡمِیَةَ ٱلۡأُنثَىٰ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تَسْمِيَةَ الأُنْثى﴾</span>، قال: الإناث{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ﴾</span> يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال <span class="qpc-hafs">﴿لَيُسَمُّونَ المَلائِكَةَ تَسْمِيَةَ الأُنْثى﴾</span> حين زعموا: أنّ الملائكة إناث، وأنها تشفع لهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٥٧.تفسير مقاتل بن سليمان ٤/١٦٣.
  53,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا لَهُم بِهِۦ مِنۡ عِلۡمٍۖ إِن یَتَّبِعُونَ إِلَّا ٱلظَّنَّۖ وَإِنَّ ٱلظَّنَّ لَا یُغۡنِی مِنَ ٱلۡحَقِّ شَیۡـࣰٔا ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما لَهُمْ به﴾</span> بذلك <span class="qpc-hafs">﴿مِن عِلمٍ﴾</span> أنّها إناث <span class="qpc-hafs">﴿إنْ يَتَّبِعُونَ إلّا الظَّنَّ﴾</span> يقول: ما يتبعون إلا الظن، وما يستيقنون أنها إناث، <span class="qpc-hafs">﴿وإنَّ الظَّنَّ لا يُغْنِي مِنَ الحَقِّ شَيْئًا﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا لَهُم بِهِۦ مِنۡ عِلۡمٍۖ إِن یَتَّبِعُونَ إِلَّا ٱلظَّنَّۖ وَإِنَّ ٱلظَّنَّ لَا یُغۡنِی مِنَ ٱلۡحَقِّ شَیۡـࣰٔا ۝٢٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤١٥<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، قال: احذروا هذا الرأيَ على الدين، فإنّما كان الرأي مِن رسول الله ﷺ مصيبًا؛ لأنّ الله كان يريه، وإنما هو مِنّا تكلُّفٌ وظنٌّ، <span class="qpc-hafs">﴿وإنَّ الظَّنَّ لا يُغْنِي مِنَ الحَقِّ شَيْئًا﴾</span>{2}. (١٤/٣٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٣.عزاه السيوطي إلى ابن أبي حاتم.
  53,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَعۡرِضۡ عَن مَّن تَوَلَّىٰ عَن ذِكۡرِنَا وَلَمۡ یُرِدۡ إِلَّا ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْ مَن تَوَلّى عَنْ ذِكْرِنا﴾</span> يعني: عن مَن أعرض عن الإيمان بالقرآن، <span class="qpc-hafs">﴿ولَمْ يُرِدْ إلّا الحَياةَ الدُّنْيا﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٣.
  53,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مَبۡلَغُهُم مِّنَ ٱلۡعِلۡمِۚ إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِیلِهِۦ وَهُوَ أَعۡلَمُ بِمَنِ ٱهۡتَدَىٰ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ذَلِكَ مَبْلَغُهُمْ مِنَ العِلْمِ﴾</span>، قال: رأيهم{1}. (١٤/٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذَلِكَ مَبْلَغُهُمْ مِنَ العِلْمِ﴾</span> يعني: من مبلغ رأيهم مِن العلم أنّ الملائكة إناث، وأنها تشفع لهم، <span class="qpc-hafs">﴿إنَّ رَبَّكَ هُوَ أعْلَمُ بِمَن ضَلَّ عَنْ سَبِيلِهِ﴾</span> يعني: عن الهدى من غيره، <span class="qpc-hafs">﴿وهُوَ أعْلَمُ﴾</span> من غيره <span class="qpc-hafs">﴿بِمَنِ اهْتَدى﴾</span> منكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤١٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْ مَن تَوَلّى عَنْ ذِكْرِنا﴾</span> إلى قوله: <span class="qpc-hafs">﴿ذَلِكَ مَبْلَغُهُمْ مِنَ العِلْمِ﴾</span>، قال: يقول: ليس لهم علمٌ إلا الذي هم فيه مِن الكفر بالله وبرسوله، ومكابرتهم لما جاء مِن عند الله. قال: وهؤلاء أهل الشّرك{3}<span class=comment-ref>٦٢٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٤</span> لم يذكر <u>ابنُ جرير</u> (٢٢/٥٨) في معنى: <span class="qpc-hafs">﴿ذَلِكَ مَبْلَغُهُمْ مِنَ العِلْمِ﴾</span> سوى قول ابن زيد.</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مَبۡلَغُهُم مِّنَ ٱلۡعِلۡمِۚ إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِیلِهِۦ وَهُوَ أَعۡلَمُ بِمَنِ ٱهۡتَدَىٰ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: قلّما كان رسولُ الله ﷺ يقوم مِن مجلس حتى يدعو بهؤلاء الدعوات لأصحابه: «<b>اللهم، اقْسِم لنا مِن خشيتك ما يحول بيننا وبين معاصيك، ومِن طاعتك ما تبلّغنا به جنتك، ومِن اليقين ما تُهَوِّن علينا مصيبات الدنيا، ومتِّعنا بأسماعنا وأبصارنا وقوتنا ما أحييتنا، واجعله الوارثَ مِنّا، واجعل ثأرنا على مَن ظلمنا، وانصرنا على مَن عادانا، ولا تجْعل مصيبتنا في ديننا، ولا تجعل الدنيا أكبر همِّنا، ولا مبلغ علمنا، ولا تُسلّط علينا مَن لا يرحمنا</b>»{4}. (١٤/٣٥)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦٢٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٦٣.أخرجه ابن جرير ٢٢/٥٨.أخرجه الترمذي ٦/١٠٩-١١٠ (٣٨٠٩) واللفظ له، من طريق ابن المبارك، عن يحيى بن أيوب، عن عبيد الله بن زحر، عن خالد بن أبي عمران، أنّ ابن عمر به.</p><p>وأخرجه الحاكم ١/٧٠٩ (١٩٣٤)، من طريق الليث بن سعد، عن خالد بن أبي عمران، عن نافع، عن ابن عمر به.</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». وقال الذهبي في معجم الشيوخ الكبير ١/٢٩٩: «هذا حديث غريب فرد».
  53,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِ لِیَجۡزِیَ ٱلَّذِینَ أَسَـٰۤـُٔوا۟ بِمَا عَمِلُوا۟ وَیَجۡزِیَ ٱلَّذِینَ أَحۡسَنُوا۟ بِٱلۡحُسۡنَى ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٢١<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الله بن عيّاش- في قول الله: <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ أساءُوا بِما عَمِلُوا ويَجْزِيَ الَّذِينَ أحْسَنُوا بِالحُسْنى﴾</span>: الذين أساؤوا: المشركون، والذين أحسنوا: المؤمنون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِلَّهِ ما فِي السَّماواتِ وما فِي الأَرْضِ﴾</span> عظّم نفسه بأنّه غنيٌّ عن عبادتهم والملائكة، وغيرهم عبيد وفي مُلكه؛ <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ أساءُوا بِما عَمِلُوا﴾</span> في الآخرة، الذين أساؤوا بما عملوا من الشّرك في الدنيا، وذلك أنه قال في الأنعام [١٢]، والنساء [٨٧]: <span class="qpc-hafs">﴿لَيَجْمَعَنَّكُمْ إلى يَوْمِ القِيامَةِ لا رَيْبَ فِيهِ﴾</span> يعني: لا شكّ في البعث أنّه كائِن. <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ أساءُوا بِما عَمِلُوا﴾</span> مِن الشّرك في الدنيا، <span class="qpc-hafs">﴿ويَجْزِيَ الَّذِينَ أحْسَنُوا﴾</span> التوحيد في الدنيا <span class="qpc-hafs">﴿بِالحُسْنى﴾</span> وهي الجنة{2}<span class=comment-ref>٦٢٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٢٠) أن قوله تعالى: <span class="qpc-hafs">﴿ولِلَّهِ ما فِي السَّماواتِ وما فِي الأَرْضِ﴾</span> «اعتراضٌ بين الكلامَيْن»، ونقل عن بعض النحويين: أن «اللام متعلقة بما في المعنى من التقدير؛ لأن تقديره: ولله ما فِي السَّماواتِ وما في الأَرض يضلّ من يشاء ويهدي من يشاء لِيَجْزِيَ». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «والنظر الأول أقلّ تكلُّفًا من هذا الإضمار». ونقل عن قوم: أن «اللام متعلقة في أول السورة: <span class="qpc-hafs">﴿إنْ هُوَ إلّا وحْيٌ يُوحى﴾</span> [النجم:٤]». ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهذا بعيد».</div></p><p><div></p><p><p><span class="item-no">٧٣٤٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ أساءُوا بِما عَمِلُوا﴾</span> قال: أهل الشِّرك، <span class="qpc-hafs">﴿ويَجْزِيَ الَّذِينَ أحْسَنُوا﴾</span> قال: المؤمن{3}. (١٤/٣٦)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٥٩ (١٣٠)، وابن جرير ٢٢/٥٩.تفسير مقاتل بن سليمان ٤/١٦٣.عزاه السيوطي إلى ابن المنذر.
  53,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یَجۡتَنِبُونَ كَبَـٰۤىِٕرَ ٱلۡإِثۡمِ وَٱلۡفَوَ ٰ⁠حِشَ إِلَّا ٱللَّمَمَۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نَزَلَتْ في نَبْهان التَّمّار، وذلك أنّه كان له حانوتٌ يبيع فيه التمر، فأتتْه امرأةٌ تريد تمرًا، فقال لها: ادخلي الحانوت؛ فإنّ فيه تمرًا جيدًا. فلما دخلتْ راودها عن نفسها، فأبتْ عليه، فلما رأت الشرّ خرجتْ، فوثب إليها، فضرب عَجُزَها بيده، فقالت: واللهِ، ما نلتَ مِنِّي حاجتك، ولا حفظتَ غيبة أخيك المسلم. فذهبت المرأةُ، وندم الرجل، فأتى النبيَّ ﷺ، فأخبره بصنيعه، فقال له النبي ﷺ: «<b>ويحك، يا نبهان، فلعلّ زوجها غازٍ في سبيل الله</b>». فقال: الله ورسوله أعلم. فقال: «<b>أما علمتَ أنّ الله يغار للغازي ما لا يغار للمقيم</b>». فلقي أبا بكر ﵁، فأعلمه، فقال: ويحك، فلعلّ زوجها غازٍ في سبيل الله. فقال: الله أعلم. ثم رجع، فلقي عمر بن الخطاب ﵁، فأخبره، فقال: ويحك، لعلّ زوجها غازٍ في سبيل الله. قال: الله أعلم. فصرعه عمر، فوطئه، ثم انطلَق به إلى النبي ﷺ، فقال: يا رسول الله، إخواننا غُزاة في سبيل الله تُكسر الرماح في صدورهم، يخلُف هذا ونحوه أهليهم بسوء، فاضرب عنقه. فضحك النبيُّ ﷺ، فقال: أرْسِله، يا عمر. فنَزَلَتْ فيه: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ والفَواحِشَ إلّا اللَّمَمَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٢٥<span class="dash">-</span></span> عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ والفَواحِشَ إلّا اللَّمَمَ﴾</span>، قال: قال المشركون: إنما كانوا بالأمس يعملون معنا. فأنزل الله ﷿: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span> ما كان منهم في الجاهلية. قال: واللمم: الذي ألمّوا به من تلك الكبائر والفواحش في الجاهلية قبل الإسلام، وغفرها لهم حين أسلموا{2}<span class=comment-ref>٦٢٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٦</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٢١) قول ابن زيد في نزول الآية بقوله: «فهي <span class="mustanad">مثل قوله تعالى</span>: <span class="qpc-hafs">﴿وأَنْ تَجْمَعُوا بَيْنَ الأُخْتَيْنِ إلّا ما قَدْ سَلَفَ﴾</span> [النساء:٢٣]».</div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یَجۡتَنِبُونَ كَبَـٰۤىِٕرَ ٱلۡإِثۡمِ وَٱلۡفَوَ ٰ⁠حِشَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ والفَواحِشَ﴾</span>، قال: الكبائر: ما سمّى الله فيه النار، والفواحش: ما كان فيه حدٌّ في الدنيا{3}. (١٤/٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نَعتَ المتّقين، فقال: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ﴾</span> يعني: كلّ ذنب يُختم بالنار، <span class="qpc-hafs">﴿والفَواحِشَ﴾</span> يعني: كلّ ذنب فيه حدٌّ{4}<span class=comment-ref>٦٢٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/١٢٠-١٢١) عند تفسير قوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ﴾</span>: «واختلف الناس في الكبائر، ما هي؟ فذهب الجمهور إلى أنها السَّبع الموبقات التي وردت في الأحاديث، وقد مضى القول في ذكرها واختلاف الأحاديث فيها في سورة النساء. وتحرير القول في الكبائر: أنها كل معصية يوجد فيها حدٌّ في الدنيا، أو تَوَعُّدٌ بنار في الآخرة، أو لعنة أو نحو هذا خاصٌّ بها. فهي كثيرة العدد، ولهذا قال ابن عباس ﵄ حين قيل له: أسَبْعٌ هي؟ فقال: هي إلى السبعين أقربُ منها إلى السبع».</div></p><p><h3><span class="qpc-hafs">﴿إِلَّا ٱللَّمَمَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٢٨<span class="dash">-</span></span> عن أبي هريرة -من طريق الحسن- أُراه رفعه، في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: «<b>اللمّة من الزّنى، ثم يتوب ولا يعود، واللمّة من شُرب الخمر، ثم يتوب ولا يعود</b>». قال: فتلك الإلمام{5}. (١٤/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٢٩<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>أتدرون ما اللَّمَم؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>هو الرجل يُلِمّ بالنّظرة مِن الزِّنا ثم لا يعود، ويُلِمّ بالشّربة مِن الخمر ثم لا يعود، ويُلِمّ بالسرقة ثم لا يعود</b>»{6}. (١٤/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الضُّحى- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: زِنا العينين: النّظر، وزِنا الشفتين: التقبيل، وزِنا اليدين: البطْش، وزِنا الرِّجلين: المشي، ويصدّق ذلك الفَرْج أو يكذّبه، فإن تقدّم بفَرْجه كان زانيًا، وإلا فهو اللمم{7}. (١٤/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣١<span class="dash">-</span></span> عن <span class="name-1">حُذيفة بن اليمان</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٢<span class="dash">-</span></span> و<span class="name-1">أبي سعيد الخُدري</span>: <span class="qpc-hafs">﴿اللَّمَمَ﴾</span>: هو صغار الذنوب؛ مثل النّظرة، والغَمزة، والقُبلة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٣<span class="dash">-</span></span> عن محمد بن سيرين، قال: سأل رجلٌ <span class="name-1">زيدَ بن ثابت</span> عن هذه الآية: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ والفَواحِشَ إلّا اللَّمَمَ﴾</span>. فقال: حرّم الله عليك الفواحشَ ما ظهر منها وما بطن{9}. (١٤/٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق عبد الرحمن- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>. قال: هي النّظرة، والغَمزة، والقُبلة، والمباشرة، فإذا مسّ الختان الختان فقد وجب الغُسل، وهو الزّنا{10}. (١٤/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٥<span class="dash">-</span></span> عن سعيد بن أبي سعيد، قال: كان <span class="name-1">أبو هريرة</span> يقول: <span class="qpc-hafs">﴿اللمم﴾</span>: النكاح؛ يعني: التزويج{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق عمرو بن شعيب- قال: اللمَم: ما دون الشِّرك{12}<span class=comment-ref>٦٢٨٨</span>. (١٤/٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٨</span> <span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٨/١٢٢) على هذا القول قائلًا: «وهذا عندي لا يصح عن عبد الله بن عمرو ﵄».</div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- قال: ما رأيتُ شيئًا أشبه باللّمَم مِمّا قال أبو هريرة عن النبيِّ ﷺ، قال: «<b>إنّ الله كتب على ابن آدم حظّه مِن الزنا أدرك ذلك لا محالة، فزِنا العين النّظر، وزِنا اللسان النُّطق، والنفس تتمنّى وتشتهي، والفَرْج يصدّق ذلك أو يكذّبه</b>»{13}. (١٤/٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: هو الرجل يُلِمّ بالفاحشة، ثم يتوب منها. قال: وقال رسول الله ﷺ:</p><p>إن تغفر اللهمّ تغفر جمّا وأيّ عبد لك لا ألَمّا!{14}. (١٤/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، يقول: إلا ما قد سلف{15}. (١٤/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: يُلِمّ بها في الحين ثم يتوب{16}. (١٤/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: اللّمَم: كلّ شيء بين الحدَّين؛ حدّ الدنيا وحدّ الآخرة، يكفّره الصلاة، وهو دون كل مُوجب، فأمّا حدّ الدنيا فكلُّ حدٍّ فرض الله عقوبته في الدنيا، وأما حدّ الآخرة فكلّ شيء ختمه الله بالنار، وأخَّر عقوبته إلى الآخرة{17}. (١٤/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- قال: <span class="qpc-hafs">﴿اللَّمَمَ﴾</span>: الذي يُلِمّ المرّة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- قال: اللّمَم: ما بين الحدّين: حدّ الدنيا، وحدّ الآخرة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزبير</span> -من طريق عطاء- قال: اللّمَم: ما بين الحدّين: حد الدنيا، وحد الآخرة{20}. (١٤/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٥<span class="dash">-</span></span> عن الحسن البصري، في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: كان <span class="name-1">أصحاب رسول الله ﷺ</span> يقولون: هو الرجل يصيب اللّمّة مِن الزِّنا، واللّمّة من شُرب الخمر، فيجتنبها ويتوب منها{21}. (١٤/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٦<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأجْدع الهَمداني</span> -من طريق مسلم- في قوله: <span class="qpc-hafs">﴿إلا اللَّمَمَ﴾</span>، قال: إن تقدّم كان زِنًا، وإن تأخّر كان لَمَمًا{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٧<span class="dash">-</span></span> قال <span class="name-2">محمد بن علي بن الحنفيّة</span>: <span class="qpc-hafs">﴿اللَّمَمَ﴾</span> كلّ ما هممتَ به مِن خير أو شرٍّ فهو لَمَم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٨<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>: <span class="qpc-hafs">﴿اللَّمَمَ﴾</span> هو ما لمّ على القلب، أي: خطر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: الرجل يُلِمّ بالذنب ثم ينزع عنه. قال: وكان أهل الجاهلية يطوفون بالبيت وهم يقولون:</p><p>إن تغفر اللهمّ تغفر جمّا وأيّ عبد لك لا ألَمّا!{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سفيان الثوري- <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: كلّ شيء بين حدّ الدنيا والآخرة فهو اللّمَم يغفره الله{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، أنّه ذُكِر له قول الحسن في اللّمَم: هي الخَطْرة من الزّنا. فقال: لا، ولكنها الضمّة، والقُبلة، والشمّة{27}. (١٤/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، يقول: ما بين الحدّين، كلّ ذنبٍ ليس فيه حدٌّ في الدنيا ولا عذاب في الآخرة، فهو اللّمَم{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٣<span class="dash">-</span></span> عن <span class="name-2">طاووس</span> -من طريق خُصيف- قال: اللّمَم: ما ألممتَ بالنّظر، ولمستَ بيدك وتناولتَ، ما لم يكن الجماع{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق منصور بن عبد الرحمن- أنه سأله عن قول الله: <span class="qpc-hafs">﴿يَجْتَنِبُونَ كَبائِرَ الإثْمِ والفَواحِشَ إلّا اللَّمَمَ﴾</span>. قال: هو ما دون الزّنا. ثم روى لنا عن ابن مسعود قال: زِنا العينين ما نظرَتْ إليه، وزِنا اليد ما لمسَتْ، وزِنا الرجل ما مشَتْ، والتحقيق بالفَرْج{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: أن يقع الوقعة ثم ينتهي{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: الزَّنية في الحين{32}. (١٤/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span> إلا اللّمّة يُلِمّ بها من الذنوب{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قول الله: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ والفَواحِشَ إلّا اللَّمَمَ﴾</span>، قال: اللّمّة من الزّنا، أو السّرقة، أو شُرب الخمر، ثم لا يعود{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٥٩<span class="dash">-</span></span> قال <span class="name-2">عطاء بن أبي رباح</span>: <span class="qpc-hafs">﴿اللَّمَمَ﴾</span> عادة النفس الحين بعد الحين{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٠<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: هو ما دون الجماع{27}. (١٤/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، قال: سُئِلتُ عن اللّمَم. فقلتُ: هو الرجل يصيب الذنبَ ثم يتوب. وأخبرتُ بذلك <span class="name-1">ابن عباس</span>، فقال: لقد أعانك عليها مَلكٌ كريم{37}. (١٤/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: الوقعة من الزنا لا يعود لها{38}. (١٤/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن القاسم</span> -من طريق قرة- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: اللَّمّة يُلِمّ بها مِن الذنوب{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span>، قال: اللّمَم: ما بين الحدّين، ما لم يبلغ حدّ الدنيا، ولا حدّ الآخرة؛ مُوجبة قد أوجب الله لأهلها النار، أو فاحشة يُقام عليها الحدّ في الدنيا{40}. (١٤/٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابن عيّاش- في قوله: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ﴾</span> قال: الشّرك، <span class="qpc-hafs">﴿والفَواحِشَ﴾</span> قال: الزّنا، تركوا ذلك حين دخلوا في الإسلام، وغفر الله لهم ما كانوا ألَمُّوا به وأصابوا من ذلك قبل الإسلام{41}. (١٤/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابنه عبد الرحمن- في قول الله: <span class="qpc-hafs">﴿إلا اللَّمَمَ﴾</span>، قال: هو ما ألَمُّوا به في الشِّرك{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٧<span class="dash">-</span></span> عن <span class="name-3">زياد بن أبي مريم</span> -من طريق خُصيف- في قوله ﷿: <span class="qpc-hafs">﴿الذين يجتنبون كبائر الإثم والفواحش إلا اللمم﴾</span>، قال: اللّمَم: كلّ شيء ألممتَ به، ثم تركتَه ونزعتَ عنه{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: اللّمَم على وجهين: كلّ ذنب لم يذكر الله عليه حدًّا في الدنيا ولا عذابًا في الآخرة، فذلك الذي تكفّره الصلوات ما لم يبلغ الكبائر والفواحش. والوجه الآخر هو: الذّنب العظيم يُلِمّ به المسلم المرّة بعد المرّة، فيتوب منه{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نَعتَ المتّقين، فقال: <span class="qpc-hafs">﴿الَّذِينَ يَجْتَنِبُونَ كَبائِرَ الإثْمِ﴾</span> يعني: كلّ ذنب يُختم بالنار، <span class="qpc-hafs">﴿والفَواحِشَ﴾</span> يعني: كلّ ذنب فيه حدٌّ، <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span> يعني: ما بين الحدّين{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن هب- في قوله: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span> ما كان منهم في الجاهلية. قال: واللّمَم: الذي ألَمُّوا به مِن تلك الكبائر والفواحش في الجاهلية قبل الإسلام، وغفرها لهم حين أسلموا{2}<span class=comment-ref>٦٢٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٩</span> اختُلف في معنى: <span class="qpc-hafs">﴿إلّا اللَّمَمَ﴾</span> في هذه الآية على أقوال: <b>الأول:</b> إلا اللَّمم الذي ألَمُّوا به مِن الإثم والفواحش في الجاهلية قبل الإسلام. <b>الثاني:</b> اللَّمَم: صغائر الذنوب من النّظرة والقُبلة والغَمزة، وما كان دون الزنا. <b>الثالث:</b> اللَّمم: ما لم يجب عليه حدٌّ في الدنيا، ولم يستحقّ عليه في الآخرة عذاب. <b>الرابع:</b> أن يُلِمَّ بالذنب مرَّة، ثم يتوب. <b>الخامس:</b> ما يَهُمُّ به الإنسان. <b>السادس:</b> ما خطر على القلب.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٢١) القول الثاني بقوله: «وهي ما لا حدَّ فيه ولا وعيد مختصًّا بها مذكورًا لها، وإنما يقال صغار بالإضافة إلى غيرها، وإلا فهي بالإضافة إلى الناهي عنها كبائر كلها، <span class="mustanad">ويعضد هذا قول النبي</span> ﷺ: «<b>إنّ الله كتب على ابن آدم حظّه من الزنا لا محالة، فزِنا العين النّظر، وزِنا اللسان المنطق، والفَرْج يكذِّب ذلك أو يصدّقه، فإن تقدّم فَرْجه فهو زانٍ، وإلا فهو اللَّمَم</b>». ثم <span class="comment-type-4">علَّق</span> عليه بقوله:»وتظاهر العلماء في هذا القول، وكثُر المائل إليه«. و<span class="comment-type-1">وجَّه</span> القول الرابع بقوله:»فكأن هذا التأويل يقتضي الرفق بالناس في إدخالهم في الوعد بالحسنى؛ إذ الغالب في المؤمنين مواقعة المعاصي، وعلى هذا أنشدوا -<span class="mustanad">وقد تمثل به النبي</span> ﷺ-:</p><p>إن تَغْفِر اللهمَّ تَغْفِرْ جَمّا وأيُّ عبدٍ لك لا ألَمّا".</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٦٨) <span class="mustanad">-مستندًا إلى اللغة</span>- أن الاستثناء منقطع، وأن المعنى: «الذين يجتنبون كبائر الإثم والفواحش إلا اللّمَم بما دون كبائر الإثم، ودون الفواحش الموجِبة الحدودَ في الدنيا والعذاب في الآخرة، فإنّ ذلك معفوٌّ لهم عنه». ثم قال: «وذلك عندي <span class="mustanad">نظير قوله -جلَّ ثناؤه</span>-: <span class="qpc-hafs">﴿إنْ تَجْتَنِبُوا كَبائِرَ ما تُنْهَوْنَ عَنْهُ نُكَفِّرْ عَنْكُمْ سَيِّئاتِكُمْ ونُدْخِلْكُمْ مُدْخَلًا كَرِيمًا﴾</span> [النساء:٣١]».</p><p>وزاد <u>ابنُ عطية</u> (٨/١٢٢-١٢٣) قولين آخرين: <b>أحدهما</b> عن نفطويه: «اللّمَم: ما ليس بمعتاد». <b>والآخر</b> عن الحسن بن الفضل: «اللّمَم: نظرة الفجأة».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٣/٧٨) القول الثاني، فقال: «والصحيح قول الجمهور: أن اللّمَم صغائر الذنوب، كالنّظرة، والغَمزة، والقُبلة، ونحو ذلك، هذا قول جمهور الصحابة ومن بعدهم، وهو قول أبي هريرة، وعبد الله بن مسعود، وابن عباس، ومسروق، والشعبي». ولم يذكر مستندًا، ثم <span class="comment-type-4">علَّق</span> بقوله: «ولا يُنافي هذا قول أبي هريرة، وابن عباس في الرواية الأخرى: إنه يُلِمّ بالكبيرة ثم لا يعود إليها [وهو القول الرابع]، فإنّ»اللمم«إما أنه يتناول هذا وهذا ويكون على وجهين، كما قال الكلبي، أو أنّ أبا هريرة وابن عباس ألحقا من ارتكب الكبيرة مرة واحدة ولم يُصرّ عليها، بل حصلت منه فلتة في عمره باللّمم، ورأيا أنها إنّما تتغلظ وتكبر وتعظم في حقّ مَن تكرّرت منه مرارًا عديدة. وهذا من فقه الصحابة ﵃ وغوْر علومهم، ولا ريب أنّ الله يسامح عبده المرة والمرتين والثلاث، وإنما يُخاف العَنت على مَن اتخذ الذنب عادته، وتكرّر منه مرارًا كثيرة، وفي ذلك آثار سلفية، والاعتبار بالواقع يدل على هذا ... فأول ذنب إن لم يكن هو اللّمم، فهو من جنسه ونظيره، فالقولان عن أبي هريرة وابن عباس متفقان غير مختلفين». ثم قال: «وهذه اللفظة فيها معنى المقاربة والإعتاب بالفعل حينًا بعد حين، فإنه يقال: ألمَّ بكذا: إذا قاربه ولم يَغْشه، ومن هذا سُمِّيت القُبلة والغَمزة لممًا؛ لأنها تُلِمّ بما بعدها، ويقال: فلان لا يزورنا إلا لمامًا، أي: حينًا بعد حين. فمعنى اللفظة ثابت في الوجهين اللذيْن فسّر الصحابة بهما الآية، وليس معنى الآية: الذين يجتنبون كبائر الإثم والفواحش إلا اللمم فإنهم لا يجتنبونه. فإن هذا يكون ثناء عليهم بترك اجتناب اللمم، وهذا محال، وإنما هذا استثناء من مضمون الكلام ومعناه، فإن سياق الكلام في تقسيم الناس إلى محسن ومسيء، وأنّ الله يجزي هذا بإساءته وهذا بإحسانه، ثم ذكر المحسنين ووصفهم بأنهم يجتنبون كبائر الإثم والفواحش، ومضمون هذا: أنه لا يكون محسنًا مجزيًّا بإحسانه، ناجيًا من عذاب الله، إلا مَن اجتَنب كبائر الإثم والفواحش، فحسن حينئذ استثناء اللّمَم، وإن لم يدخل في الكبائر، فإنه داخل في جنس الإثم والفواحش».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ وَ ٰ⁠سِعُ ٱلۡمَغۡفِرَةِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٧١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكَ واسِعُ المَغْفِرَةِ﴾</span> لِمَن فعل ذلك وتاب{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّ رَبَّكَ واسِعُ المَغْفِرَةِ﴾</span>: قد غفر ذلك لهم{48}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ وَ ٰ⁠سِعُ ٱلۡمَغۡفِرَةِۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٧٣<span class="dash">-</span></span> عن أبي وائل، قال: رأى أبو مَيسَرة عمرو بن شَرحبيل -وكان مِن أفاضل أصحاب عبد الله- في المنام، قال: رأيتُ كأني دخلتُ الجنة، فإذا قباب مضروبة، فقلتُ: لِمَن هذه؟ فقالوا: لِذي الكَلاع وحَوشَب. وكانا مِمَّن قُتلا مع معاوية. فقلت: فأين عمّار وأصحابه؟ فقالوا: أمامك. قلتُ: وقد قَتل بعضُهم بعضًا! وكيف ذلك؟ قالوا: إنهم لقوا الله سبحانه، فوجدوه واسع المغفرة{49}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُوَ أَعۡلَمُ بِكُمۡ إِذۡ أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ وَإِذۡ أَنتُمۡ أَجِنَّةࣱ فِی بُطُونِ أُمَّهَـٰتِكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿هُوَ أعْلَمُ بِكُمْ﴾</span>، قال: هو كنحو قوله: <span class="qpc-hafs">﴿وهُوَ أعْلَمُ بِالمُهْتَدِينَ﴾</span> [الأنعام:١١٧، النحل:١٢٥، القصص:٥٦، القلم:٧]{50}. (١٤/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿إذْ أنْشَأَكُمْ مِنَ الأَرْضِ وإذْ أنْتُمْ أجِنَّةٌ فِي بُطُونِ أُمَّهاتِكُمْ﴾</span>، قال: علم الله مِن كلِّ نفسٍ ما هي عاملة، وما هي صانعة، وإلى ما هي صائرة{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُوَ أعْلَمُ بِكُمْ﴾</span> مِن غيره <span class="qpc-hafs">﴿إذْ أنْشَأَكُمْ مِنَ الأَرْضِ﴾</span> يعني: خَلَقكم مِن تراب وهو أعلم بكم، <span class="qpc-hafs">﴿وإذْ أنْتُمْ أجِنَّةٌ فِي بُطُونِ أُمَّهاتِكُمْ﴾</span> يعني: جنين{52} الذي يكون في بطن أمه{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>-من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إذْ أنْشَأَكُمْ مِنَ الأَرْضِ وإذْ أنْتُمْ أجِنَّةٌ﴾</span>، قال: حين خَلَق آدم من الأرض، ثم خَلَقكم من آدم{54}<span class=comment-ref>٦٢٩٠</span>. (١٤/٤٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٢٣) في قوله تعالى: <span class="qpc-hafs">﴿هُوَ أعْلَمُ بِكُمْ إذْ أنْشَأَكُمْ مِنَ الأَرْضِ﴾</span> قولين: <b>الأول:</b> «العامل في <span class="qpc-hafs">﴿إذ﴾</span> هو <span class="qpc-hafs">﴿أعلم﴾</span>». <b>والثاني</b> عن بعض النحاة: «العامل فيها فعل مضمر تقديره: اذكروا إذ». ثم <span class="comment-type-3">رجَّح</span> القول الأول؛ <span class="mustanad">لأنه أظهر</span> قائلًا: «والمعنى الأول أبْيَن». وعلَّل ذلك بقوله: «لأن تقديره: فإذا كان عِلْمه قد أحاط بكم وأنتم في هذه الأحوال ووقع بكم التخفي فأحرى أن يقع بكم وأنتم تغفلون وتجترحون». وذكر أنّ الإنشاء من الأرض «<b>يحتمل</b> أن يُراد به إنشاء الغذاء».</div></p><p><h3><span class="qpc-hafs">﴿فَلَا تُزَكُّوۤا۟ أَنفُسَكُمۡۖ هُوَ أَعۡلَمُ بِمَنِ ٱتَّقَىٰۤ ۝٣٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٧٨<span class="dash">-</span></span> عن ثابت بن الحارث الأنصاري، قال: كانت اليهود إذا هلك لهم صبيٌّ صغير قالوا: هو صِدِّيق. فبلغ ذلك النبيّ ﷺ، فقال: «<b>كذبت يهود، ما مِن نَسمة يخلقها اللهُ في بطن أُمّها إلا أنه شقي أو سعيد</b>». فأنزل الله عند ذلك: <span class="qpc-hafs">﴿هُوَ أعْلَمُ بِكُمْ إذْ أنْشَأَكُمْ مِنَ الأَرْضِ﴾</span> الآية كلّها{55}. (١٤/٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٧٩<span class="dash">-</span></span> عن عائشة –من طريق مسروق-، نحوه{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨٠<span class="dash">-</span></span> قال محمد بن السّائِب الكلبي: كان ناسٌ يعملون أعمالًا حسنة، ثم يقولون: صلاتنا، وصيامنا، وحَجّنا. فأنزل الله تعالى هذه الآية: <span class="qpc-hafs">﴿هو أعلم بمن اتقى﴾</span>، أي: بَرّ وأطاع وأخلص العمل لله تعالى{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨١<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span> وقال ناس من المسلمين: صَلّينا، وصُمنا، وفعلنا. فزكُّوا أنفسهم؛ فقال الله تعالى: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ هُوَ أعْلَمُ بِمَنِ اتَّقى﴾</span>{53}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَا تُزَكُّوۤا۟ أَنفُسَكُمۡۖ هُوَ أَعۡلَمُ بِمَنِ ٱتَّقَىٰۤ ۝٣٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٨٢<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span>، يعني: يعمل حسنة، ويرعوي عن سيئة{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span> لا تمدحوها{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span>، قال: لا تعملوا بالمعاصي، وتقولون: نعمل بالطاعة{27}. (١٤/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span> أخلِص العمل لله{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق سفيان- يقول: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span>، يقول: فلا تُبَرِّئوها{63}<span class=comment-ref>٦٢٩١</span>. (١٤/٤٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩١</span> ذكر ابن عطية  (٨/١٢٣) في قوله تعالى: <span class="qpc-hafs">﴿فَلَا تُزَكُّوا أَنْفُسَكُمْ﴾</span> أن "ظاهره النهي عن أن يُزَكِّي أحدٌ نفسه". ثم ذكر احتمالًا آخر: "أن يكون نهيًا أن يُزَكِّي بعض الناس بعضًا". ثم علَّق عليه بقوله: "وإذا كان هذا فإنما يُنهى عن تزكية السُّمعة والمدح للدنيا، أو القطع بالتزكية، ومن ذلك الحديث في عثمان بن مظعون عند موته، وأما تزكية الإمام والقدوة أحدًا ليُؤتمَّ به أو لِيَتَهَمَّمَ الناس بالخير فجائز، وقد زكّى رسول الله ﷺ بعض أصحابه، أبا بكر وغيره ﵃، وكذلك تزكية الشهود في الحقوق جائز للضرورة إليها".</div></p><p><h3><span class="qpc-hafs">﴿فَلَا تُزَكُّوۤا۟ أَنفُسَكُمۡۖ هُوَ أَعۡلَمُ بِمَنِ ٱتَّقَىٰۤ ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٨٧<span class="dash">-</span></span> عن زينب بنت أبي سلمة، أنها سُميت: بَرّة، فقال رسول الله ﷺ: «<b>لا تزكُّوا أنفسكم، الله أعلم بأهل البِرِّ منكم، سمُّوها</b>: <b>زينب</b>»{64}. (١٤/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٨٨<span class="dash">-</span></span> قال أبو بكر الصِّدِّيق ل<span class="name-1">قيس بن عاصم</span>: صِف لنا نفسَك. فقال: إن الله يقول: <span class="qpc-hafs">﴿فَلا تُزَكُّوا أنْفُسَكُمْ﴾</span>؛ فلستُ بمُزكٍّ نفسي، وقد نهاني الله عنه. فأعجب أبا بكر ذلك منه{65}. (١٤/٤٣)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٤-١٦٥.أخرجه ابن جرير ٢٢/٦٠.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/١٦٤. وقد تقدمت الآثار في معنى الكبائر عند تفسير قوله تعالى: <span class="qpc-hafs">﴿إنْ تَجْتَنِبُوا كَبائِرَ ما تُنْهَوْنَ عَنْهُ﴾</span> [النساء:٣١].أخرجه البيهقي في الشعب ٩/٢٧٧ (٦٦٥٧، ٦٦٥٨)، وأبو الطاهر -كما في جزء أبي الطاهر للدراقطني ص٣٤-٣٥ (٨٩)-، وابن جرير ٢٢/٦٤ بزيادة: «<b>واللمة من السرقة، ثم يتوب ولا يعود</b>» من طريق الحسن، عن أبي هريرة به. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.</p><p>وسنده ضعيف لانقطاعه؛ فالحسن لم يسمع من أبي هريرة. ينظر: جامع التحصيل ص١٦٤.عزاه السيوطي إلى ابن مردويه مرسلًا.أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٦٢، والحاكم ٢/٤٧٠، والبيهقي (٧٠٦٠).تفسير الثعلبي ٩/١٤٨.أخرجه ابن جرير ٢٢/٦١.أخرجه مسدد -كما في المطالب العالية (٤١٢٣)-، وابن جرير ٢٢/٦٣.أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٦٧ (٢٠٩٥).أخرجه ابن جرير ٢٢/٦٦.أخرجه البخاري ٨/٥٤ (٦٢٤٣)، ٨/١٢٥ (٦٦١٢)، ومسلم ٤/٢٠٤٦ (٢٦٥٧)، وعبد الرزاق ٣/٢٥٢ (٣٠٣٧)، وابن جرير ٢٢/٦٢.أخرجه الترمذي ٥/٤٨١ (٣٥٦٨)، والحاكم ١/١٢١ (١٨٠)، ٢/٥١٠ (٣٧٥٠)، وابن جرير ٢٢/٦٣-٦٤، والبغوي ٤/٩٧، من طريق زكريا بن إسحاق، عن عمرو بن دينار، عن عطاء، عن ابن عباس به.</p><p>قال الترمذي: «هذا حديث حسن صحيح غريب، لا نعرفه إلا من حديث زكريا بن إسحاق». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي. وقال ابن كثير في تفسيره ٧/٤٦١: «وفي صحته مرفوعًا نظر». وقال الهيثمي في المجمع ٧/١١٥ (١١٣٧٨): «رجاله رجال الصحيح».أخرجه ابن جرير ٢٢/٦٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٦٣، ٦٥.أخرجه ابن جرير ٢٢/٦٧.أخرجه ابن جرير ٢٢/٦٦.أخرجه ابن جرير ٢٢/٦٧-٦٨، وبنحوه من طريق الحكم.أخرجه ابن جرير ٢٢/٦٧. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.أخرجه ابن جرير ٢٢/٦٥.أخرجه ابن جرير ٢٢/٦٢.تفسير الثعلبي ٩/١٤٩.تفسير الثعلبي ٩/١٤٩، وتفسير البغوي ٧/٤١٣.أخرجه ابن جرير ٢٢/٦٤، ٦٦.أخرجه ابن جرير ٢٢/٦٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٦٧.أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٦٩ (٢٠٩٨).أخرجه ابن جرير ٢٢/٦٢.أخرجه ابن جرير ٢٢/٦٦.عزاه السيوطي إلى البخاري في تاريخه.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١١-.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٧-، وعبد الرزاق ٢/٢٥٦ من طريق معمر بنحوه، وابن جرير ٢٢/٦٦.تفسير الثعلبي ٩/١٤٩.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر. وأخرجه ابن جرير ٢٢/٦٥ بلفظ: الزنا ثم يتوب.أخرجه ابن جرير ٢٢/٦٦.أخرجه ابن جرير ٢٢/٦٨، وبنحوه من طريق أبي جعفر.أخرجه ابن جرير ٢٢/٦١، وعبد الله بن وهب في الجامع -تفسير القرآن ١/٥٩ (١٣١).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٥٤ (١١٧).أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٦٨-٤٦٩ (٢٠٩٧).تفسير الثعلبي ٩/١٤٩، وتفسير البغوي ٧/٤١٣.تفسير مقاتل بن سليمان ٤/١٦٤.أخرجه ابن جرير ٢٢/٦٠.تفسير البغوي ٧/٤١٣.أخرجه ابن جرير ٢٢/٦٩.أخرجه الثعلبي ٩/١٤٩.تفسير مجاهد ص٦٢٨، وأخرجه ابن جرير ٢٢/٧٠.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٧٨ (٣٦٧٦٨).هكذا هي في المصدر.تفسير مقاتل بن سليمان ٤/١٦٥.أخرجه ابن جرير ٢٢/٧٠.أخرجه الطبراني في الكبير ٢/٨١ (١٣٦٨)، وأبو نعيم في معرفة الصحابة ١/٤٧٨ (١٣٦٢)، ويحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١١-٣١٢-، من طريق ابن لهيعة، عن الحارث بن يزيد، عن ثابت بن الحارث الأنصاري به.</p><p>وقال العراقي في تخريج أحاديث الإحياء ص١٣٦٧: «فيه عبد الله بن لهيعة». وقال الألباني في الضعيفة ١٣/٢٦٢ (٦١١٦): «ضعيف».أورده الثعلبي ٩/١٥٠.تفسير الثعلبي ٩/١٥٠، وتفسير البغوي ٧/٤١٣.تفسير مقاتل بن سليمان ٤/١٦٥.تفسير الثعلبي ٩/١٥٠.تفسير الثعلبي ٩/١٥٠، وتفسير البغوي ٧/٤١٣.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٩/١٥٠.أخرجه ابن جرير ٢٢/٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه مسلم ٣/١٦٨٧ (٢١٤٢).عزاه السيوطي إلى الزبير بن بكار في الموفقيات.
  53,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ ٱلَّذِی تَوَلَّىٰ ۝٣٣ وَأَعۡطَىٰ قَلِیلࣰا وَأَكۡدَىٰۤ ۝٣٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>، قال: نَزَلَتْ في العاص بن وائل{1}. (١٤/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنها نزلت في الوليد بن المغيرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩١<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>، و<span class="name-3">المسيّب بن شريك</span>، و<span class="name-2">السُّدِّيّ</span>، و<span class="name-3">الكلبي</span>: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span> نَزَلَتْ في عثمان بن عفان ﵁، كان يتصدّقُ ويُنفِق في الخير، فقال له أخوه مِن الرضاعة عبد الله بن سعد بن أبي سَرح: ما هذا الذي تصنع؟! يُوشِك أن لا يبقى لك مالٌ. فقال عثمان: إنّ لي ذنوبًا وخطايا، وأنا أطلب بما أصنع رضا الله، وأرجو عفوه. فقال له عبد الله: أعْطني ناقتك برحْلها وأنا أتحمّل عنك ذنوبك كلّها. فأعطاه، وأشهد الله على ذلك، وأمسَك عن بعض ما كان يصنع مِن الصّدقة والنفقة؛ فأنزل الله سبحانه: <span class="qpc-hafs">﴿أفرأيت الذي تولى﴾</span> يعني: يوم أُحد حين ترك المركز، <span class="qpc-hafs">﴿وأعطى﴾</span> يعني: صاحبه <span class="qpc-hafs">﴿قليلًا وأكدى﴾</span> أي: قطع نفقته. فعاد عثمان ﵁ إلى أحسن ذلك وأجمله{3}<span class=comment-ref>٦٢٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٨/١٢٤) قصة عثمان بن عفان ﵁ مع عبد الله بن أبي سرح قائلًا: «وذلك كلّه عندي باطل، وعثمان عن مثله مُنَزَّهٌ».</div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span>، قال: الوليد بن المُغيرة، كان يأتي النبيَّ ﷺ وأبا بكر، فيستمع ما يقولان{4}. (١٤/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: أنها نَزَلَتْ في الوليد بن المُغيرة، وكان قد اتّبع رسول الله ﷺ على دينه، فعيّره بعضُ المشركين، وقال له: أتركْتَ دين الأشياخ وضلّلتهم وزعمتَ أنهم في النار؟! كان ينبغي لك أن تنصرهم. قال: إني خشيتُ عذاب الله. فضمن له الذي عاتبه إن هو أعطاه شيئًا مِن ماله ورجع إلى شِركه أن يحمل عنه عذاب الله، ففعل، وأعطى الذي عاتبه بعض ما كان ضَمِن له، ثم بخل، ومنحه تمام ما ضمن له؛ فأنزل الله سبحانه: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى وأَعْطى قَلِيلًا وأَكْدى﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: أنّ النبيَّ ﷺ خرج في مغزاة، فجاء رجلٌ، فلم يجد ما يخرج عليه، فلقي صديقًا له، فقال: أعطِني شيئًا. قال: أُعطيك بَكْرِي{6} هذا على أن تتحمّل بذنوبي. فقال له: نعم. فأنزل الله: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى وأَعْطى قَلِيلًا وأَكْدى﴾</span>{7}. (١٤/٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٥<span class="dash">-</span></span> عن <span class="name-2">عطاء بن يسار</span> -من طريق موسى بن عبيدة الربذي- قال: نَزَلَتْ في رجلٍ قال لأهله: جهِّزوني أنطلِق إلى هذا الرجل -يعني: النبي ﷺ-. فتجهّز، وخرج، فلقيه رجلٌ مِن الكفار، فقال له: أين تريد؟ قال: محمدًا، لعلّي أصيب من خيره. فقال له الرجل: أعطِني جهازك وأحمل عنك إثمك. فنَزَلَتْ فيه هذه الآية: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٦<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span> نَزَلَتْ في أبي جهل، وذلك أنه قال: واللهِ، ما يأمرنا محمد إلا بمكارم الأخلاق. فذلك قوله: <span class="qpc-hafs">﴿أعْطى قَلِيلًا وأَكْدى﴾</span> أي: لم يؤمن به{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٧<span class="dash">-</span></span> عن <span class="name-2">درّاج أبي السَّمح</span> -من طريق خلاد بن سليمان- قال: خرجتْ سريةٌ غازيةٌ، فسأل رجلٌ رسول الله ﷺ أن يحمله، فقال: «<b>لا أجِد ما أحملك عليه</b>». فانصرف حزينًا، فمرَّ برجل رِحاله مُنِيخة بين يديه، فشكا إليه، فقال له الرجل: هل لك أن أحملك فتَلْحَق الجيش بحسناتك؟ فقال: نعم. فركب؛ فنَزَلَتْ: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span>{10}. (١٤/٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span> نَزَلَتْ في العاص بن وائل السهمي، وذلك أنه كان ربما يوافق رسول الله ﷺ في بعض الأمور{9}<span class=comment-ref>٦٢٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩٣</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٢٤) القول بنزولها في الوليد أو في العاص بن وائل -مِمَّن ظنَّ أنه يدفع عن نفسه العذاب بمالٍ يبذله- بقوله: «فقوله تعالى: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span> -على هذا القول- هو في المال». ونقل عن مقاتل -في كتاب الثعلبي- أن المعنى: «وأعطى من نفسه قليلًا في قُربه من الإيمان، ثم أكْدى، أي: انقطع ما أعطى». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا <span class="mustanad">بيِّنٌ مِن اللفظ</span>، والآخر يحتاج إلى رواية».</div></p><p><div></p><p><p><span class="item-no">٧٣٤٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span> عن الحقّ، يعني: الوليد بن المُغيرة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، قال: إنّ رجلًا أسلم، فلقِيه بعضُ مَن يعيُّره، فقال: أتركْتَ دين الأشياخ وضلّلتهم، وزعمتَ أنهم في النار؟! قال: إنِّي خشيتُ عذابَ الله. قال: أعطِني شيئًا، وأنا أحمل كلَّ عذاب كان عليك. فأعطاه شيئًا، فقال: زِدني. فتعاسرا، حتى أعطاه شيئًا، وكتب له كتابًا، وأشهد له، ففيه نَزَلَتْ هذه الآية: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span>{13}. (١٤/٤٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ ٱلَّذِی تَوَلَّىٰ ۝٣٣ وَأَعۡطَىٰ قَلِیلࣰا وَأَكۡدَىٰۤ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٥٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>، قال: قطع، نَزَلَتْ في العاص بن وائل{1}. (١٤/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>، قال: أطاع قليلًا، ثم انقطع{15}. (١٤/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى وأَعْطى قَلِيلًا وأَكْدى﴾</span>، يقول: أعطى قليلًا ثم انقطع{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>. قال: أعطى قليلًا من ماله، ومنع الكثير، ثم كدَّره بمنِّه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>أعطى قليلًا ثم أكدى بمنِّه ومَن يَنشر المعروف في الناس يُحمد؟{17}. (١٤/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أفَرَأَيْتَ الَّذِي تَوَلّى﴾</span>، قال: الوليد بن المُغيرة؛ كان يأتي النبيَّ ﷺ وأبا بكر، فيستمع ما يقولان، وذلك ما أعطى مِن نفسه؛ أعطى الاستماع، <span class="qpc-hafs">﴿وأَكْدى﴾</span> قال: انقطع عطاؤه، ترك ذلك{4}. (١٤/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>، قال: انقطع فلا يُعطي شيئًا، ألم تر إلى البئر يقال لها: أكْدَت{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿وأَكْدى﴾</span>، يقول: انقطع عطاؤه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٨<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>: أعطى قليلًا، ثم قطعه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span>، قال: أعطى قليلًا، ثم قطع ذلك{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥١٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿أعطى قليلًا﴾</span>، قال: يُقال: أعطى قليلًا وانقطع{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥١١<span class="dash">-</span></span> قال <span class="name-3">عبد الله بن طاووس</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأَكْدى﴾</span>، قال: أعطى قليلًا، ثم قطع ذلك{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَعْطى قليلًا﴾</span> مِن الخير بلسانه، <span class="qpc-hafs">﴿وأَكْدى﴾</span> يعني: قطع{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَكْدى﴾</span>: عاسره{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأَعْطى قَلِيلًا وأَكْدى﴾</span> إنما قلَّ؛ لأنه كان لغير الله{27}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن مردويه -كما في الفتح ٨/٦٠٤-.تفسير الثعلبي ٩/١٥٠.تفسير مجاهد ص٦٢٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢-، وابن جرير ٢٢/٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٩/١٥١.البَكْر –بالفتح-: الفَتِيُّ من الإبل. النهاية (بكر).عزاه السيوطي إلى ابن أبي حاتم.أخرجه الثعلبي ٩/١٥١.تفسير الثعلبي ٩/١٥١، وتفسير البغوي ٧/٤١٤.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٠٣-١٠٤ (٢٣٦). وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٩/١٥١، وتفسير البغوي ٧/٤١٤.تفسير مقاتل بن سليمان ٤/١٦٥.أخرجه ابن جرير ٢٢/٧٢.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٧٢ بلفظ: أعطى قليلًا ثم انقطع. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٧٢.أخرجه الطستي -كما في الإتقان ٢/٨٢-.تفسير مجاهد ص٦٢٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢-، وابن جرير ٢٢/٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٧٣.أخرجه ابن جرير ٢٢/٧٣.أخرجه ابن جرير ٢٢/٧٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٢-.أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٧٣ من طريق سعيد بنحوه.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٧.أخرجه ابن جرير ٢٢/٧٣.تفسير مقاتل بن سليمان ٤/١٦٥. وبنحوه في تفسير البغوي ٧/٤١٤ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢٢/٧٣.تفسير ابن أبي زمنين ٤/٣١٢.
