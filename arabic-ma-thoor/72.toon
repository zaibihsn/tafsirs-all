  72,13,""
  72,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّا مِنَّا ٱلۡمُسۡلِمُونَ وَمِنَّا ٱلۡقَـٰسِطُونَۖ فَمَنۡ أَسۡلَمَ فَأُو۟لَـٰۤىِٕكَ تَحَرَّوۡا۟ رَشَدࣰا ۝١٤ وَأَمَّا ٱلۡقَـٰسِطُونَ فَكَانُوا۟ لِجَهَنَّمَ حَطَبࣰا ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٢٠٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿القاسِطُونَ﴾</span> هم الذين جعلوا لله نِدًّا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وأَنّا مِنّا المُسْلِمُونَ ومِنّا القاسِطُونَ﴾</span>، قال: العادِلون عن الحق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ومنا القاسِطُونَ﴾</span>، قال: هم الظالمون{3}. (١٥/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٠٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿ومنا القاسِطُونَ﴾</span>، قال: هم الظالمون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومنا القاسِطُونَ﴾</span>، قال: هم الجائرون{5}. (١٥/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأما القاسِطُونَ﴾</span>، قال: هم الجبّارون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنّا مِنّا المُسْلِمُونَ﴾</span> يعني: المُخلصين، هذا قول التسعة، <span class="qpc-hafs">﴿ومنا القاسِطُونَ﴾</span> يعني: العادلين بالله، وهم المَرَدة، <span class="qpc-hafs">﴿فَمَن أسْلَمَ﴾</span> يقول: فمَن أخلص لله ﷿ من كفار الجنّ <span class="qpc-hafs">﴿فَأُولَئِكَ تَحَرَّوْا رَشَدًا﴾</span> يعني: أخلصوا بالرشد، <span class="qpc-hafs">﴿وأما القاسِطُونَ﴾</span> يعني: العادلين بالله <span class="qpc-hafs">﴿فَكانُوا لِجَهَنَّمَ حَطَبًا﴾</span> يعني: وقودًا. فهذا كله قول مؤمني الجنّ التسعة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: المُقسط: العادل، والقاسط: الجائر. وذكر بيت شعر:</p><p>قَسَطنا على الأملاك في عهد تُبَّعٍ ومن قبلِ ما أدرى النفوسَ عقابها{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٢٤١.أخرجه ابن جرير ٢٣/٣٣٣.تفسير مجاهد ص٦٧٧، وأخرجه ابن جرير ٢٣/٣٣٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٧-.أخرجه ابن جرير ٢٣/٣٣٣، كذلك من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٢٢.تفسير مقاتل بن سليمان ٤/٤٦٤.أخرجه ابن جرير ٢٣/٣٣٦.
  72,15,""
  72,15,""
  72,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱسۡتَقَـٰمُوا۟ عَلَى ٱلطَّرِیقَةِ لَأَسۡقَیۡنَـٰهُم مَّاۤءً غَدَقࣰا ۝١٦ لِّنَفۡتِنَهُمۡ فِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٢١٣<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق السُّدِّيّ- <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span>، قال: حيثُما كان الماءُ كان المالُ، وحيثما كان المالُ كانت الفتنةُ{1}. (١٥/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> قال: أقاموا ما أُمروا به؛ <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> قال: مَعينًا{2}. (١٥/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> يعني بالاستقامة: الطاعة. فأمّا الغَدَق: فالماء الطاهر الكثير؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> يقول: لنَبْتليهم به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿ماءً غَدَقًا﴾</span>. قال: كثيرًا جاريًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر:</p><p>تُدني كراديسَ مُلتفًّا حدائقها كالنّبْت جادتْ بها أنهارها غدقا؟{4}. (١٥/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق المنهال- في قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> قال: الدين؛ <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> قال: مالًا كثيرًا؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> قال: لنَبْتليهم فيه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبيد الله بن أبي زياد-: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> طريقة الإسلام؛ <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> قال: نافعًا كثيرًا، لأَعطيناهم مالًا كثيرًا؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> حتى يَرجعوا لِما كَتبه عليهم من الشقاء{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عَلقمة بن مَرْثَد- <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> قال: الإسلام؛ <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> قال: الكثير؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> قال: لنَبْتليهم به{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> قال: هذا مَثَلٌ ضربه الله، كقوله: <span class="qpc-hafs">﴿ولَوْ أنَّهُمْ أقامُوا التَّوْراةَ والإنْجِيلَ وما أُنْزِلَ إلَيْهِمْ مِن رَبِّهِمْ لَأَكَلُوا مِن فَوْقِهِمْ ومِن تَحْتِ أرْجُلِهِمْ﴾</span> [المائدة:٦٦]، وقوله تعالى: <span class="qpc-hafs">﴿ولَوْ أنَّ أهْلَ القُرى آمَنُوا واتَّقَوْا لَفَتَحْنا عَلَيْهِمْ بَرَكاتٍ مِنَ السَّماءِ والأَرْضِ﴾</span> [الأعراف:٩٦]. والماء الغَدَق يعني: الماء الكثير؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> لنَبْتليهم فيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span>، قال: لأَعطيناهم مالًا كثيرًا{9}. (١٥/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٢<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلَز لاحق بن حميد</span> -من طريق عمران بن حُدَيْر- في قوله تعالى: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span>، قال: على طريقة الضّلالة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، في قوله: <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span>، قال: كثيرًا، والماء: المال{9}. (١٥/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ﴾</span> الآية، يقول: لو استقاموا على طاعة الله وما أُمِروا به لأَكثر الله لهم مِن الأموال حتى يُفتنوا بها{9}. (١٥/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span>، أي: لأَوسعنا لهم من الرِّزق{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> قال: لو آمنوا كلّهم؛ <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ﴾</span> لأَوسعنا لهم من الدنيا{14}. (١٥/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٧<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٨<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span> = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٢٩<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي:</span> أنّ معناه: وأن لو استقاموا على الضّلالة لأَعطيناهم سَعَةً من الرزق لِنَستدْرِجهم بها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿ماءً غَدَقًا﴾</span>، قال: عَيشًا رَغدًا{16}. (١٥/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> يعني: طريقة الهُدى؛ <span class="qpc-hafs">﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span> يعني: كثيرًا من السماء، وهو المطر، بعد ما كان رُفِع عنهم المطر سبع سنين فيَكثر خيرهم؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> يقول: لكي نَبْتليهم فيه بالخصب والخير، كقوله في سورة الأعراف [٩٦]: <span class="qpc-hafs">﴿ولَوْ أنَّ أهْلَ القُرى آمَنُوا﴾</span> يقول: صَدَّقوا <span class="qpc-hafs">﴿واتقوا لَفَتَحْنا عَلَيْهِمْ بَرَكاتٍ مِنَ السَّماءِ﴾</span> يعني: المطر <span class="qpc-hafs">﴿والأَرْضِ﴾</span> يعني به: النبات{17}<span class=comment-ref>٦٨٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٣٦</span> اختُلف في معنى: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</span> في هذه الآية على قولين: <b>الأول:</b> طريقة الكفر. <b>الثاني:</b> طريقة الهدى.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٤٣٣) القول الأول بقوله: «أي: لو كفر مَن أسلم مِن الناس لأَسقيناهم ماءً إملاءً لهم واستدراجًا». و<span class="comment-type-1">وجَّه</span> القول الثاني بقوله: «والمعنى: على طريقة الإسلام والحق، وهذا المعنى <span class="mustanad">نحو قوله تعالى</span>: <span class="qpc-hafs">﴿ولَوْ أنَّ أهْلَ الكِتابِ آمَنُوا واتَّقَوْا لَكَفَّرْنا عَنْهُمْ سَيِّئاتِهِمْ﴾</span> [المائدة:٦٥]، <span class="mustanad">وقوله تعالى</span>: <span class="qpc-hafs">﴿ولَوْ أنَّهُمْ أقامُوا التَّوْراةَ والإنْجِيلَ وما أُنْزِلَ إلَيْهِمْ مِن رَبِّهِمْ لَأَكَلُوا مِن فَوْقِهِمْ ومِن تَحْتِ أرْجُلِهِمْ﴾</span> [المائدة:٦٦]». ثم <span class="comment-type-3">رجَّح</span> الثاني <span class="mustanad">-مستندًا إلى اللغة، والعقل</span>- بقوله: «وهذا القول أبْيَن؛ لأنّ استعارة الاستقامة للكفر قلقة».</div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</span>، قال: الغَدَق: الكثير؛ ماءً كثيرًا؛ <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> لنَختَبِرهم فيه{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّنَفۡتِنَهُمۡ فِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٢٣٣<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٤<span class="dash">-</span></span> و<span class="name-2">عُبيد بن عُمير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٥<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٦<span class="dash">-</span></span> و<span class="name-2">عطية بن سعد العَوفيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٧<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٨<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿لنَفْتِنَهُمْ فِيهِ﴾</span> لنَختَبِرهم كيف شُكرهم فيما خُوّلوا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span>، قال: لنَبْتليهم حتى يَرجعوا إلى ما كُتب عليهم{20}. (١٥/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span>: لنَبْتليهم فيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span>، يقول: لكي نَبْتليهم فيه بالخصب والخير{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُعۡرِضۡ عَن ذِكۡرِ رَبِّهِۦ یَسۡلُكۡهُ عَذَابࣰا صَعَدࣰا ۝١٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٢٤٢<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿يَسْلُكْهُ﴾</span> بالياء{23}. (١٥/٢٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُعۡرِضۡ عَن ذِكۡرِ رَبِّهِۦ یَسۡلُكۡهُ عَذَابࣰا صَعَدࣰا ۝١٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٢٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: ‹ومَن يُعْرِضْ عَن ذِكْرِ رَبِّهِ نَسْلُكْهُ عَذابًا صَعَدًا›، قال: شُقّة من العذاب يَصعد فيها{24}. (١٥/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: ‹نَسْلُكْهُ عَذابًا صَعَدًا›، قال: جبلًا في جهنم{25}. (١٥/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿عَذابًا صَعَدًا﴾</span>، قال: لا راحة فيه{26}. (١٥/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عَذابًا صَعَدًا﴾</span>، قال: مَشقّة من العذاب{27}. (١٥/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿عَذابًا صَعَدًا﴾</span>، قال: مَشقّة من العذاب{28}. (١٥/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿صَعَدًا﴾</span> لا يزداد إلا شِدّة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿عَذابًا صَعَدًا﴾</span>، قال: عذابًا لا راحة فيه{9}. (١٥/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿عَذابًا صَعَدًا﴾</span>، قال: صَعودًا مِن عذاب الله، لا راحة فيه{31}. (١٥/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿صَعَدًا﴾</span> مَشقّة{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٥٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: يُكلّف الوليد بن المُغيرة أن يَصعد في النار جبلًا مِن صخرة مَلساء، حتى يَبلغ أعلاها، يجذب مِن أمامه بالسلاسل، ويُضرب بمَقامع من حديد حتى يَبلغ أعلاها، ولا يَبلغها في أربعين سنة، فإذا بَلغ أعلاها انحدر إلى أسفلها، ثم يُكلّف أيضًا صُعُودَها، فذلك دأْبه أبدًا، وهو قوله: <span class="qpc-hafs">﴿سَأُرْهِقُهُ صَعُودًا﴾</span> [المدثر:١٧]{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَن يُعْرِضْ عَنْ ذِكْرِ رَبِّهِ﴾</span> القرآن؛ <span class="qpc-hafs">﴿يَسْلُكْهُ عَذابًا صَعَدًا﴾</span> يعني: شدّة العذاب الذي لا راحة له فيه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٢٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَسْلُكْهُ عَذابًا صَعَدًا﴾</span>، قال: الصَّعَد: العذاب المُتعِب{35}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٣٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٣/٣٣٥.أخرجه الطستي -كما في الإتقان ٢/٧٧-.أخرجه عبد الرزاق ٢/٣٢٢، وابن جرير ٢٣/٣٣٧.أخرجه ابن جرير ٢٣/٣٣٥-٣٣٦، وبنحوه من طريق أبي سنان، عن غير واحد.أخرجه ابن جرير ٢٣/٣٣٦.أخرجه ابن جرير ٢٣/٣٣٨.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٣٣٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٤٦-.أخرجه عبد الرزاق ٢/٣٢٢، وابن جرير ٢٣/٣٣٧. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٥٣-٥٤، وتفسير البغوي ٨/٢٤١.أخرجه ابن جرير ٢٣/٣٣٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٦٤.أخرجه ابن جرير ٢٣/٣٣٧.تفسير الثعلبي ١٠/٥٣.أخرجه ابن جرير ٢٣/٣٣٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٣٣٨.تفسير مقاتل بن سليمان ٤/٤٦٤.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف، وعاصم، ويعقوب، وقرأ بقية العشرة: ‹نَسْلُكْهُ› بالنون. انظر: النشر ٢/٣٩٢، والإتحاف ص٥٦٦.أخرجه ابن جرير ٢٣/٣٣٥، ٣٣٩.أخرجه ابن جرير ٢٣/٣٣٩، وهناد (٢٧٩)، والحاكم ٢/٥٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن جرير.أخرجه هناد (٢٨٠)، وابن جرير ٢٣/٣٣٩، كذلك من طريق جابر أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه هناد (٢٨٠).تفسير الثعلبي ١٠/٥٤، وتفسير البغوي ٨/٢٤١.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٢٢، وابن جرير ٢٣/٣٣٩، ٣٤٠-كذلك من طريق سعيد أيضًا. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٤٦-. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٥٤.تفسير الثعلبي ١٠/٥٤.تفسير مقاتل بن سليمان ٤/٤٦٤.أخرجه ابن جرير ٢٣/٣٤٠.
