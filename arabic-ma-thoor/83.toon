  83,35,""
  83,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ ثُوِّبَ ٱلۡكُفَّارُ مَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢١٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿هَلْ ثُوِّبَ﴾</span>، قال: جُوزِيَ{1}. (١٥/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ ثُوِّبَ الكُفّارُ ما كانُوا يَفْعَلُونَ﴾</span>، يعني: ينظرون مِن الكُوى، فإذا رأوهم يُعذَّبون قالوا: واللهِ، قد ثُوِّب الكفار ما كانوا يفعلون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿هَلْ ثُوِّبَ الكُفّارُ ما كانُوا يَفْعَلُونَ﴾</span>: حين كانوا يسخرون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٧١٣، وأخرجه ابن جرير ٢٤/٢٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٢٦.أخرجه ابن جرير ٢٤/٢٢٩.
  84,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٢١٧٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الانشقاق بمكة{1}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٧٩<span class="dash">-</span></span> عن عبد الله بن الزُّبير، مثله{2}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٠<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، وذكر أنها نزلت بعد <span class="qpc-hafs">﴿إذا السَّماءُ انْفَطَرَتْ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨١<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٢<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسمّياها: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٣<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٤<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة الانفطار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٥<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٦<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الانشقاق مكّيّة، عددها خمس وعشرون آية كوفي{8}<span class=comment-ref>٧٠٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩١</span> قال <u>ابنُ عطية</u> (٨/٥٦٧): «وهي مكّيّة <span class="mustanad">بلا خلاف بين المتأولين</span>».</div></p><p><div></p><p><p><span class="item-no">٨٢١٨٧<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>مَن سَرَّه أن ينظر إلى يوم القيامة كأنه رأي عين فليقرأ: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، و<span class="qpc-hafs">﴿إذا السَّماءُ انْفَطَرَتْ﴾</span>، و<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span></b>»{9}. (١٥/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٨<span class="dash">-</span></span> عن صفوان بن عَسّال: أنّ رسول الله ﷺ سجد في: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>{10}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٩<span class="dash">-</span></span> عن أبي هريرة، قال: سجدنا مع رسول الله ﷺ في: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، و<span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</span>{11}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٠<span class="dash">-</span></span> عن أبي هريرة -من طريق ابن سيرين- قال: إنّ رجلين اقترآ بـ<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، و<span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</span> .... قال: فسجد أحدهما، ولم يسجد الآخر. قال: الذي سجد أفضلهما أو خيرهما. قال ابن سيرين: إن لم يكن النبي ﵇ وعمر فلا أدري مَن هُما{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩١<span class="dash">-</span></span> عن أبي رافع، قال: صلّيتُ مع أبي هريرة العَتمة، فقرأ: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span> فسجد، فقلت له، فقال: سجدتُ خلف أبي القاسم ﷺ، فلا أزال أسجد فيها حتى ألقاه{13}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٢<span class="dash">-</span></span> عن زرّ، قال: قرأ <span class="name-1">عمّار</span> على المنبر: <span class="qpc-hafs">﴿إذا السماء انشقت﴾</span>، فنزل فسجد{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٣<span class="dash">-</span></span> عن أبي بشر أنه رأى <span class="name-2">عمر بن عبد العزيز</span> صلّى العشاء، فقرأ فيها بـ<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، فسجد فيها، وقرأها مرة أخرى، فلم يسجد.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٤<span class="dash">-</span></span> قال: وحدَّثني معاوية بن صالح، عن أبي الزّاهرية، عن جبير بن نفير، عن <span class="name-1">أبي الدّرداء</span> أنه كان مرة يسجد في: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، ومرة لا يسجد فيها{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا ٱلسَّمَاۤءُ ٱنشَقَّتۡ ۝١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢١٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وذلك أنّ أخوين مِن بني أُميّة -أحدهما اسمه: عبد الله بن عبد الأسد، والآخر اسمه: الأسود بن عبد الأسد-؛ أحدهما مؤمن بالله واسمه عبد الله، وأما الآخر فاسمه الأسود وهو الكافر، فقال لأخيه عبد الله: آمنتُ بمحمد؟ قال: نعم. قال: ويحك! إنّ محمدًا يزعم إذا مِتنا وكُنّا ترابًا فإنّا لمبعوثون في الآخرة، ويزعم أنّ الدنيا تنقطع، فأخبرني ما حال الأرض يومئذ؟ فأنزل الله ﷿: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا ٱلسَّمَاۤءُ ٱنشَقَّتۡ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢١٩٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، في قوله: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، قال: تنشق السماء مِن المجَرَّة{17}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span> انشقّتْ لنزول ربّ العزة والملائكة، فإنها تنشق حتى يُرى طرفاها، ثم تُرى خَلْقًا باليًا{16}<span class=comment-ref>٧٠٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٢</span> قال <u>ابنُ عطية</u> (٨/٥٦٧): «وانشقاق السماء: هو تفطّرها لهول يوم القيامة، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿وانْشَقَّتِ السَّماءُ فَهِيَ يَوْمَئِذٍ واهِيَةٌ﴾</span> [الحاقة:١٦]، <b>وقال</b> الفراء والزَّجّاج وغيرهما: هو تشقّقها بالغمام. <b>وقال قوم</b>: تشقّقها: تفتُّحها أبوابًا لِنُزول الملائكة وصعودهم في هول يوم القيامة».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٦٣١.تقدم تخريجه في مقدمة سورة التكوير.أخرجه الطبراني في الكبير ٨/٦٨ (٧٣٩٣)، وابن نصر في فوائده ص١٠٦، ١٠٧ (١١٣، ١١٤)، من طريق يحيى بن عقبة بن أبي العيزار، عن إدريس الأودي، وابن أبي ليلى، عن عاصم بن أبي النجود، عن زِرّ بن حُبيش، عن صفوان بن عَسّال به.</p><p>قال ابن أبي حاتم في علل الحديث ٢/٥٢٢ (٥٦١): «قال أبو زرعة: هذا حديث منكر خطأ». وقال البغوي في معجم الصحابة ٣/٣٤٢ (١٢٨٣): «وهذا حديث غريب، لا أعلم رواه غير يحيى بن عقبة، وهو ضعيف الحديث». وقال الهيثمي في المجمع ٢/٢٨٦ (٣٧٠٥): «فيه يحيى بن عقبة بن أبي العيزار، وهو ضعيف جدًّا».أخرجه مسلم ١/٤٠٦ (٥٧٨).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٩٩ (٢٢٤).أخرجه البخاري (٧٦٦، ٧٦٨، ١٠٧٨)، ومسلم (٥٧٨/١١٠). وعزاه السيوطي إلى ابن مردويه.أخرجه سعيد بن منصور في سننه -التفسير ٨/٣٠٧ (٢٤٣٥).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن٣/٩٧-٩٨ (٢١٩).تفسير مقاتل بن سليمان ٤/٦٣٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٣٣.
  84,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَذِنَتۡ لِرَبِّهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ﴾</span>، قال: أطاعتْ{1}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سمعتْ حين كلَّمها{2}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: سَمِعَتْ، وأطاعتْ{3}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سَمِعَتْ، وأطاعتْ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سَمِعَتْ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سَمِعَتْ، وأطاعتْ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: سَمِعَتْ، وأطاعتْ{7}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٥<span class="dash">-</span></span> عن <span class="name-2">حبيب بن أبي ثابت</span> -من طريق معروف بن واصل- في قوله: <span class="qpc-hafs">﴿وأذنت لربها وحقت﴾</span>: سَمِعَتْ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: أطاعتْ، وحُقَّ لها أن تطيع{9}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span> انشقّتْ، وسَمِعَتْ لربّها، وأطاعتْ{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحُقَّتۡ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وحُقَّتْ﴾</span>، قال: حُقّتْ بالطاعة{11}<span class=comment-ref>٧٠٩٣</span>. (١٥/٣١٤)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٣</span> ذكر <u>ابنُ عطية</u> (٨/٥٦٨) قول ابن عباس، ثم <span class="comment-type-4">ذكر</span> احتمالًا آخر، فقال: «و<b>يحتمل</b> أن يريد: وحُق لها أن تنشق لشدة الهول وخوف الله تعالى».</div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- <span class="qpc-hafs">﴿وحُقَّتْ﴾</span>: وحُقَّ لها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وحُقَّتْ﴾</span>، يقول: حُقَّ لها أن تفعل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: أطاعتْ، وحُقَّ لها أن تطيع{9}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحُقَّتْ﴾</span> وكان يحقّ لها ذلك{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٢٩٤-.عزاه السيوطي إلى ابن المنذر. وأخرجه ابن جرير ٢٤/٢٣١ من طريق عطية العَوفيّ بلفظ: سمعت لربها.أخرجه الحاكم ٢/٥١٨.أخرجه ابن جرير ٢٤/٢٣١.تفسير مجاهد ص٧١٤، وأخرجه ابن جرير ٢٤/٢٣١.أخرجه ابن جرير ٢٤/٢٣١.أخرجه عبد الرزاق ٣/٣٥٨، وابن جرير ٢٤/٢٣١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٩١ (٢٤٢٦).عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٦٣٣.أخرجه ابن جرير ٢٤/٢٣٢ بنحوه، وابن أبي حاتم -كما في فتح الباري ٦/٢٩٤-.أخرجه ابن جرير ٢٤/٢٣٢.تفسير مجاهد ص٧١٤.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٦٣٣.
  84,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ۝٣ وَأَلۡقَتۡ مَا فِیهَا وَتَخَلَّتۡ ۝٤ وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢١٣<span class="dash">-</span></span> عن عبد الله بن عمر، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span> الآية، قال: «<b>أنا أول مَن تنشق عنه الأرض يوم القيامة، فأجلس جالسًا في قبري، وإنّ الأرض تحركتْ بي، فقلت لها: ما لكِ؟ فقالت: إنّ ربي أمرني أنْ أُلقي ما في جوفي، وأنْ أتخلّى فأكون كما كنتُ إذ لا شيء فِيّ. وذلك قوله: <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</span></b>»{1}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق مجاهد- قال: كان البيت قبل الأرض بألفي سنة، وذلك قول الله: <span class="qpc-hafs">﴿وإذا الأَرْضُ مُدَّتْ﴾</span>، قال: مُدَّت مِن تحتِه مَدًّا{2}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وإذا الأَرْضُ مُدَّتْ﴾</span> قال: يوم القيامة، <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها﴾</span> أخرجت ما فيها مِن الموتى، <span class="qpc-hafs">﴿وتَخَلَّتْ﴾</span> عنهم{3}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-، مثله{4}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</span>، قال: سواري الذهب{5}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</span>، قال: أخرجتْ أثقالها، وما فيها من الكنوز، والناس{6}<span class=comment-ref>٧٠٩٤</span>. (١٥/٣١٦)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥٦٨) نحو ما جاء في قول قتادة عن الزَّجّاج، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وقال الزَّجّاج: من الكنوز، وهذا ضعيف؛ لأن ذلك يكون وقت خروج الدَّجّال، وإنما تلقي يوم القيامة الموتى».</div></p><p><div></p><p><p><span class="item-no">٨٢٢١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا الأَرْضُ مُدَّتْ﴾</span> مثل الأديم الممدود، <span class="qpc-hafs">﴿وأَلْقَتْ﴾</span> ما فِيها من الحيوان، <span class="qpc-hafs">﴿وتَخَلَّتْ﴾</span> يقول: سَمِعَتْ لربّها وأطاعتْ، وكان [يحقّ] لها ذلك{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ۝٣ وَأَلۡقَتۡ مَا فِیهَا وَتَخَلَّتۡ ۝٤ وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ۝٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٢٠<span class="dash">-</span></span> عن جابر بن عبد الله، عن النبي ﷺ، قال: «<b>تمُد الأرضُ يوم القيامة مدَّ الأديمِ، ثم لا يكون لابن آدم منها إلا موضعُ قدميه</b>»{8}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢١<span class="dash">-</span></span> عن علي بن حسين، أنّ النبي ﷺ قال: «<b>إذا كان يومُ القيامة مَدَّ الله الأرض، حتى لا يكون لبشر مِن الناس إلا موضع قدميه، فأكون أولَ مَن يُدعى، وجبريل عن يمين الرحمن، واللهِِ، ما رآه قبلها، فأقول: يا ربّ، إنّ هذا أخبرني أنكَ أرسلتَه إلَيّ. فيقول: صدق. ثم أشفع فأقول: يا ربّ، عبادك عبدوك في أطراف الأرض</b>». قال: «<b>وهو المقام المحمود</b>»{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق أبي المُغيرة- قال: إذا كان يوم القيامة مُدّت الأرض مدَّ الأديم، وحَشر الله الخلائق؛ الإنس والجن والدواب والوحوش، فإذا كان ذلك اليوم جعل الله القِصاص بين الدوابِّ، حتى تقتصَّ الشاة الجَمّاءُ من القرناءِ بنَطْحتِها، فإذا فرغ الله من القصاص بين الدواب قال لها: كوني ترابًا. فيراها الكافر، فيقول: يا ليتني كنتُ ترابًا{10}. (١٥/٣١٥)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو القاسم الخُتَّلي في الديباج ص١٠٢ (٣٤)، من طريق سلام بن سلم الطويل، عن عبد الحميد، عن نافع، عن ابن عمر به.</p><p>وسنده شديد الضعف؛ فيه سلام بن سلم، وهو متروك. الميزان ٢/١٧٥.أخرجه الحاكم ٢/٥١٨، والبيهقي في الدلائل ٢/٤٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه الحاكم ٢/٥١٨.تفسير مجاهد ص٧١٤ مقتصرًا على الآية الثانية، وأخرجه ابن جرير ٢٤/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٩ بنحوه، وابن جرير ٢٤/٢٣٣ بلفظ: أخرجتْ أثقالها وما فيها. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٣٣-٦٣٤.أخرجه الحاكم ٤/٦١٤ (٨٧٠١) مطولًا بنحوه.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن حجر في الفتح ١١/٣٧٦: «ورجاله ثقات، إلا أنه اختُلف على الزُّهريّ في صحابيه». وقال السيوطي: «بسند جيد».أخرجه عبد الرزاق ٣/٤٠٧ بنحوه، وابن جرير ٢٤/٢٣٢ مرسلًا.أخرجه الحاكم ٤/٥٧٥.
  84,4,""
