  100,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَحُصِّلَ مَا فِی ٱلصُّدُورِ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٥٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وحُصِّلَ ما فِي الصُّدُورِ﴾</span>، قال: أُبرِز{1}. (١٥/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٥٩٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>: <span class="qpc-hafs">﴿وحُصِّلَ ما فِي الصُّدُورِ﴾</span>، قال: أُخرِج ما في الصدور{2}. (١٥/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٥٩٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، <span class="qpc-hafs">﴿وحُصِّلَ ما فِي الصُّدُورِ﴾</span>، قال: الأعمال، حُصِّل ما فيها{3}. (١٥/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٥٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحُصِّلَ ما فِي الصُّدُورِ﴾</span> مِن الخير والشّرّ، يعني: تَمَيّز ما في القلوب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وحُصِّلَ ما فِي الصُّدُورِ﴾</span>، يقول: مُيِّز{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٥٩٠. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٠٣.أخرجه ابن جرير ٢٤/٥٩١.
  100,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّهُم بِهِمۡ یَوۡمَىِٕذࣲ لَّخَبِیرُۢ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٦٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبَّهُمْ بِهِمْ يَوْمَئِذٍ﴾</span> يعني: يوم القيامة <span class="qpc-hafs">﴿لَخَبِيرٌ﴾</span> بالصالح منهم والطالح{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٨٠٣.
  101,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٤٦٠٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٣<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت سورة القارعة بمكة{2}. (١٥/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلت بعد <span class="qpc-hafs">﴿لإيلاف قريش﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٦<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق- مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٨<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد <span class="qpc-hafs">﴿لإيلاف﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦٠٩<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦١٠<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة القارعة مكّيّة، عددها إحدى عشرة آية كوفي{8}<span class=comment-ref>٧٢٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٧٤</span> قال <u>ابنُ عطية</u> (٨/٦٧٧): «وهي مكّيّة <span class="mustanad">بلا خلاف</span>».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٨٠٩.
  101,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلۡقَارِعَةُ ۝١ مَا ٱلۡقَارِعَةُ ۝٢ وَمَاۤ أَدۡرَىٰكَ مَا ٱلۡقَارِعَةُ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: القارعة مِن أسماء يوم القيامة{1}. (١٥/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿القارِعَةُ ما القارِعَةُ﴾</span>، قال: هي الساعة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿القارِعَةُ ما القارِعَةُ﴾</span>، قال: هي الساعة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿القارِعَةُ ما القارِعَةُ﴾</span> يَقرع الله ﷿ أعداءه بالعذاب، <span class="qpc-hafs">﴿وما أدْراكَ ما القارِعَةُ﴾</span> تعظيمًا لها لشدّتها، وكلّ شيء في القرآن <span class="qpc-hafs">﴿وما أدْراكَ﴾</span> فقد أخبر به النبي ﷺ، وكلّ شيء في القرآن <span class="qpc-hafs">﴿وما يُدْرِيكَ﴾</span> فما لم يخبر به؛ وفي الأحزاب [٦٣]: <span class="qpc-hafs">﴿وما يُدْرِيكَ لَعَلَّ السّاعَةَ تَكُونُ قَرِيبًا﴾</span>، وقال فى هذه السورة: <span class="qpc-hafs">﴿وما أدْراكَ ما القارِعَةُ﴾</span>، ثم أخبر عنها فقال: <span class="qpc-hafs">﴿يَوْمَ يَكُونُ النّاسُ كالفَراشِ المَبْثُوثِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٦١٥<span class="dash">-</span></span> عن <span class="name-3">وكيع [بن الجرّاح]</span> -من طريق أبي كريب- قال: سمعتُ أنّ القارعة والواقعة والحاقة: القيامة{5}<span class=comment-ref>٧٢٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٧٥</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٥٩٢-٥٩٣) غير قول وكيع، وقتادة، وابن عباس أنّ القارعة: هي القيامة.</p><p>وقد <span class="comment-type-4">ذكر</span> ذلك <u>ابنُ عطية</u> (٨/٦٧٧)، وزاد <b>قولًا آخر</b>، فقال: «وقال قوم من المتأوّلين: القارعة: صيحة النفخة في الصور؛ لأنها تَقرع الأسماع، وفي ضمن ذلك القلوب».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٥٩٢ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٤/٥٩٢.أخرجه ابن جرير ٢٤/٥٩٢.تفسير مقاتل بن سليمان ٤/٨١١.أخرجه ابن جرير ٢٤/٥٩٣.
  101,3,""
  100,11,""
