  54,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خُشَّعًا أَبۡصَـٰرُهُمۡ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ كَأَنَّهُمۡ جَرَادࣱ مُّنتَشِرࣱ ۝٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٣٢<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (خاشِعَةً أبْصارُهُمْ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنه كان يقرأ: ‹خاشِعًا أبْصارُهُمْ› بالألف{2}. (١٤/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٣٤<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿خُشَّعًا أبْصارُهُمْ﴾</span> برفع الخاء{3}<span class=comment-ref>٦٣١٣</span>. (١٤/٧٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٣</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿خشعًا أبصارهم﴾</span> <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿خُشّعًا﴾</span>. <b>وقرأ غيرهم</b>: ‹خاشِعًا›. <b>وقرأ آخرون</b>: (خاشِعَةً).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٢/١١٧-١١٨) أنّ الأولى بمعنى: خاشع. وأنّ الثانية بالألف على التوحيد اعتبارًا بقراءة عبد الله الثالثة، و<span class="comment-type-4">بين</span> أنهم ألحقوه وهو بلفظ الاسم في التوحيد، إذ كان صفة بحكم «فعَل» و«يفعَل» في التوحيد إذا تقدم الأسماء، <span class="mustanad">كما قال الشاعر</span>:</p><p>وشبابٍ حَسنٍ أوجههم من إياد بن نِزار بن مَعد</p><p>فوحّد حسنًا وهو صفة للأوجه، وهي جمع.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابن عطية</u> (٨/١٤٠).</div></p><p><h3><span class="qpc-hafs">﴿خُشَّعًا أَبۡصَـٰرُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- (خاشِعًا أبْصارُهُمْ): أي: ذليلة أبصارهم{4}. (١٤/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خُشَّعًا﴾</span> يعني: ذليلة خافضة <span class="qpc-hafs">﴿أبْصارُهُمْ﴾</span> عند معاينة النار{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ كَأَنَّهُمۡ جَرَادࣱ مُّنتَشِرࣱ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٣٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿كَأَنَّهُمْ جَرادٌ مُنْتَشِرٌ﴾</span> شبّههم بالجراد؛ إذا أدركه الليل لزِم الأرض، فإذا أصبح وطلع عليه الشمس انتشر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٣٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿يخرجون من الأجداث كأنهم جراد منتشر﴾</span>، قال: الأجداث: القبور{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَخْرُجُونَ مِنَ الأَجْداثِ﴾</span> يعني: القبور <span class="qpc-hafs">﴿كَأَنَّهُمْ جَرادٌ مُنْتَشِرٌ﴾</span> حين انتشر من معدنه، فشبّه الناسَ بالجراد إذا خرجوا من قبورهم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٧.</p><p>وهي قراءة شاذة، تروى أيضًا عن أُبَيّ. انظر: مختصر ابن خالويه ص١٤٨.أخرجه الحاكم ٢/٤٧٢-٤٧٣. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها أبو عمرو، ويعقوب، وحمزة، والكسائي، وخلف، وقرأ بقية العشرة: <span class="qpc-hafs">﴿خُشَّعًا أبْصارُهُمْ﴾</span> بضم الخاء. انظر: النشر ٢/٣٨٠، والإتحاف ص٥٢٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١١٧.تفسير مقاتل بن سليمان ٤/١٧٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٧-.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٠.تفسير مقاتل بن سليمان ٤/١٧٨.
  54,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُّهۡطِعِینَ إِلَى ٱلدَّاعِۖ یَقُولُ ٱلۡكَـٰفِرُونَ هَـٰذَا یَوۡمٌ عَسِرࣱ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، قال: ناظرين{1}. (١٤/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿مُهْطِعِينَ﴾</span>. قال: مُذْعنين خاضعين. قال: وهل تعرف العرب ذلك؟ قال: نعم أما سمعتَ قول تُبّع:</p><p>تعبَّدني نِمْر بن سعد وقد دَرى ونِمْر بن سعد لي مَدِينٌ ومُهْطِع{2}. (١٤/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم الأفطس- ‹مُهْطِعِينَ إلى الدّاعِي›، قال: هو النَّسَلان{3}{4}. (١٤/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٣<span class="dash">-</span></span> عن <span class="name-2">أبي الضُّحى مسلم بن صبيح</span> -من طريق سفيان، عن أبيه- <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، قال: التَّحْمِيجُ{5}{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، ‹مُهْطِعِينَ إلى الدّاعِي›، قال: صائخي آذانهم إلى الصوت{7}. (١٤/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، قال: مُنطلقين{7}. (١٤/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، قال: عامدين إلى الداعي{9}. (١٤/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٧<span class="dash">-</span></span> عن <span class="name-2">تميم بن حَذْلَم</span> -من طريق عثمان بن يسار- في قوله <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، قال: الإهطاع: التّحميج{10}. (١٤/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، يعني: مُقبلين سِراعًا إذا خرجوا مِن القبور إلى صوت إسرافيل القائم على الصخرة التي ببيت المقدس، فيُهوَّن على المؤمنين الحشر كأدنى صلاتهم، والكفار يُكبّون على وجوههم، فلا يقومون مقامًا ولا يخرجون مخرجًا إلا عسر عليهم، في كلّ موطن شدّة ومشقّة، فذلك قوله: <span class="qpc-hafs">﴿يَقُولُ الكافِرُونَ هَذا يَوْمٌ عَسِرٌ﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٤٩<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿مُهْطِعِينَ إلى الدّاعِ﴾</span>، قال: هكذا، أبصارهم شاخصة إلى السماء{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٧٠٥، ٢٢/١١٩، وابن المنذر -كما في فتح الباري ٨/٦١٦-، وابن أبي حاتم -كما في الإتقان ٢/٢٢-.أخرجه الطستي -كما في الإتقان ٢/١٠١-.النَّسَلان: الإسراع في العدو. لسان العرب (نسل).أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٧-٣٢٨-. وعزاه السيوطي إلى عبد بن حميد.التَّحْمِيج: فتح العين وتحديد النظر، كأنه مبهُوت أو خائف. النهاية ولسان العرب (حمج).أخرجه ابن جرير ٢٢/١١٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٣/٧٠٥، ٢٢/١١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٣/٧٠٥، ٢٢/١١٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١١٩.
  54,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ فَكَذَّبُوا۟ عَبۡدَنَا وَقَالُوا۟ مَجۡنُونࣱ وَٱزۡدُجِرَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</span>، قال: استُطِير جنونًا{1}. (١٤/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحكم- <span class="qpc-hafs">﴿وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</span>، قال: استُعِرَ جنونًا{2}<span class=comment-ref>٦٣١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٤١-١٤٢) أنه على قول مجاهد فقوله: <span class="qpc-hafs">﴿وازدجر﴾</span> من قول قوم نوح، و<span class="comment-type-2">انتقده</span> بقوله: «وهذا قول فيه تَعَسُّف وتَحَكُّم».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وازْدُجِرَ﴾</span>، قال: تهدّدوه بالقتل{3}. (١٤/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذَّبَتْ قَبْلَهُمْ﴾</span> قبل أهل مكة <span class="qpc-hafs">﴿قَوْمُ نُوحٍ فَكَذَّبُوا عَبْدَنا﴾</span> نوحًا، <span class="qpc-hafs">﴿وقالُوا﴾</span> لنوح: <span class="qpc-hafs">﴿مَجْنُونٌ وازْدُجِرَ﴾</span> يعني: استطار القلب منه، وأوعدوه بالقتل، وضربوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</span>، قال: اتّهموه وزجروه وأوعدوه لَئِن لم يفعل ليكوننّ من المرجومين. وقرأ: <span class="qpc-hafs">﴿قالُوا لَئِنْ لَمْ تَنْتَهِ يا نُوحُ لَتَكُونَنَّ مِنَ المَرْجُومِينَ﴾</span> [الشعراء:١١٦]{5}<span class=comment-ref>٦٣١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٥</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٩٦) على قول ابن زيد بقوله: «وهو متوجه حسن».</div></p></div>",footnotes:1:تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في التغليق ٤/٣٢٧-، وابن جرير ٢٢/١٢٠، ومن طريق منصور أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٢٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٧-. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١٢١.
  54,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَدَعَا رَبَّهُۥۤ أَنِّی مَغۡلُوبࣱ فَٱنتَصِرۡ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَدَعا رَبَّهُ أنِّي مَغْلُوبٌ فانْتَصِرْ﴾</span> بعد ما كان يُضرب في كلّ يوم مرتين حتى يُغشى عليه، فإذا أفاق قال: اللهم، اهدِ قومي؛ فإنهم لا يعلمون{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٨.
  54,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَفَتَحۡنَاۤ أَبۡوَ ٰ⁠بَ ٱلسَّمَاۤءِ بِمَاۤءࣲ مُّنۡهَمِرࣲ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٥٦<span class="dash">-</span></span> عن أبي الطُّفيل: أنّ ابن الكَوّاء سأل <span class="name-1">عليًّا</span> عن المَجرّة. فقال: هي شَرْج{1} السماء، ومنها فُتحت أبواب السماء بماء مُنهمر. ثم قرأ: <span class="qpc-hafs">﴿فَفَتَحْنا أبْوابَ السَّماءِ﴾</span> الآية{2}. (١٤/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَفَتَحْنا أبْوابَ السَّماءِ بِماءٍ مُنْهَمِرٍ﴾</span>، قال: كثير، لم تمطر السماء قبل ذلك اليوم ولا بعده إلا مِن السحاب، وفُتحت أبواب السماء بالماء مِن غير سحابٍ ذلك اليوم، فالتقى الماءان{3}<span class=comment-ref>٦٣١٦</span>. (١٤/٧٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٦</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/١٤٢) هذا القول منسوبًا لأبي حاتم، ثم قال: «<b>وقال قوم من أهل التأويل</b>: الأبواب حقيقة، فُتحت في السماء أبواب جرى منها الماء. <b>وقال جمهور المفسرين</b>: بل هو مجاز وتشبيه؛ لأن المطر كثر كأنه من أبواب».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَفَتَحْنا أبْوابَ السَّماءِ﴾</span> أربعين يومًا <span class="qpc-hafs">﴿بِماءٍ مُنْهَمِرٍ﴾</span> يعني: مُنصَبٌّ كثير{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٥٩<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿بِماءٍ مُنْهَمِرٍ﴾</span>، قال: ينصبُّ انصِبابًا{5}. (ز)</p></p><p></div></p></div>",footnotes:1:المجرة شَرَج السماء: يقال: هي بابُها. لسان العرب (جرر).أخرجه البخاري في الأدب (٧٦٦)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٥٢-.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١٢٢.
  54,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفَجَّرۡنَا ٱلۡأَرۡضَ عُیُونࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٦٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٦١<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿وفَجَّرْنا الأَرْضَ﴾</span> مُنفجرٌ من الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفَجَّرْنا الأَرْضَ﴾</span> أربعين يومًا <span class="qpc-hafs">﴿عُيُونًا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٦٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- في قوله: <span class="qpc-hafs">﴿وفَجَّرْنا الأَرْضَ عُيُونًا﴾</span>، قال: فجّرنا الأرض بالماء، وجاء من السماء ماءٌ؛ فالتقى الماء والماء{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱلۡتَقَى ٱلۡمَاۤءُ عَلَىٰۤ أَمۡرࣲ قَدۡ قُدِرَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٦٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق موسى بن عبيد- في قوله: <span class="qpc-hafs">﴿فالتَقى الماءُ﴾</span> قال: ماء السماء وماء الأرض، <span class="qpc-hafs">﴿عَلى أمْرٍ قَدْ قُدِرَ﴾</span> قال: كانت الأقواتُ قبل الأجساد، وكان القدرُ قبل البلاء{4}. (١٤/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فالتَقى الماءُ عَلى أمْرٍ قَدْ قُدِرَ﴾</span> وذلك أنّ ماء السماء وماء الأرض قدّر الله تعالى كليهما، فكانا سواء، لم يَزد ماءُ السماء على ماء الأرض، وكان ماءُ السماء باردًا مثل الثّلج، وماء الأرض حارًّا مثل الحميم، فذلك قوله: <span class="qpc-hafs">﴿عَلى أمْرٍ قَدْ قُدِرَ﴾</span> لأنّ الماء ارتفع فوق كلّ جبل ثلاثين يومًا، ويقال: أربعين ذراعًا، فكان الماء الذي على الأرض والذي على رؤوس الجبال سواء، فابتَلعت الأرضُ ماءَها، وبقي ماء السماء أربعين يومًا لم تشربه الأرض، فهذه البحور التي على الأرض منها{5}<span class=comment-ref>٦٣١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٧</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٨/١٤٣) على الاختلاف في ارتفاع الماء بقوله: «ولا خبر يقطع العذر في شيء من هذا التحديد».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٦٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿قَدْ قُدِرَ﴾</span>، قال: صاعٌ بصاع{6}. (١٤/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٦٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- في قوله: <span class="qpc-hafs">﴿فالتَقى الماءُ عَلى أمْرٍ قَدْ قُدِرَ﴾</span>، قال: ماء السماء وماء الأرض{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٦٤.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١٢٢.أخرجه ابن جرير ٢٢/١٢٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٧٨-١٧٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٢٢.
  54,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَحَمَلۡنَـٰهُ عَلَىٰ ذَاتِ أَلۡوَ ٰ⁠حࣲ وَدُسُرࣲ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق حصين، عن مجاهد- في قوله: <span class="qpc-hafs">﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ ودُسُرٍ﴾</span>، قال: الألواح: ألواح السفينة، والدُّسُر: معاريضها التي تُشَدّ بها السفينة{1}. (١٤/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله تعالى: <span class="qpc-hafs">﴿ودُسُرٍ﴾</span>، قال: المسامير{2}. (١٤/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أن نافع بن الأزرق قال له: أخبِرني عن قول الله: <span class="qpc-hafs">﴿ودُسُرٍ﴾</span>. قال: الدُّسُر: التي تُحرز به السفينة. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>سفينة نُوتِيٍّ{3} قدُ احْكِم صُنعُها مُثخَّنة{4} الألواح مَنسوجة الدُّسُر؟{5}. (١٤/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قال: الدُّسُر: كَلْكَل{6} السفينة{7}. (١٤/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿ودُسُرٍ﴾</span>، قال: أضلاع السفينة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: الألواح: الصفائح، والدُّسُر: العوارض{9}. (١٤/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحُصين- <span class="qpc-hafs">﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ﴾</span> قال: ألواح السفينة، <span class="qpc-hafs">﴿ودُسُرٍ﴾</span>: عوارضها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ذاتِ ألْواحٍ ودُسُرٍ﴾</span>: أمّا الألواح: فجانبا السفينة، وأمّا الدُّسُر: فطرفاها وأصلها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الدُّسُر: صدرها الذي تَضرب به الموج{12}. (١٤/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، نحوه{12}. (١٤/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ ودُسُرٍ﴾</span>، قال: تدْسُر الماء بصدرها. أو قال: بِجُؤْجُؤها{14}<span class=comment-ref>٦٣١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٨</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٨/١٤٣) على هذا القول الذي قاله ابن عباس من طريق العَوفيّ، والحسن، بقوله: «لأنها تدْسُر الماء، أي: تدفعه، والدّسر: الدفع».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٧٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- وسئل عن هذه الآية: <span class="qpc-hafs">﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ ودُسُرٍ﴾</span>. قال: الدُّسُر: المسامير{15}<span class=comment-ref>٦٣١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٩</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٨/١٤٣) على هذا القول الذي قاله ابن عباس من طريق علي، والقُرَظيّ، وقتادة، وابن زيد، فقال: «وهذا هو قول الجمهور، وهو عندي من الدفع المتتابع؛ لأن المسمار يُدفع أبدًا حتى يستوي».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ﴾</span> قال: معاريض السفينة، <span class="qpc-hafs">﴿ودُسُرٍ﴾</span> قال: دُسرت بمسامير{16}. (١٤/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: حُدِّثنا: أنّ دُسُرها: مساميرها التي شُدّت بها{17}. (١٤/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحَمَلْناهُ﴾</span> نوحًا <span class="qpc-hafs">﴿عَلى ذاتِ ألْواحٍ﴾</span> يعني: ألواح السفينة، وهي مِن ساج، ثم قال: <span class="qpc-hafs">﴿ودُسُرٍ﴾</span> يعني: مسامير مِن حديد، تُشدّ به السفينة، كان بابها في عرضها{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ودُسُرٍ﴾</span>، قال: الدُسُر: المسامير التي دُسِرت بها السفينة؛ ضُربت فيها، شُدّت بها{19}<span class=comment-ref>٦٣٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٠</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/١٤٣-١٤٤) أن <b>جمهور الناس</b> على أنّ السفينة كانت على هيئة السفن اليوم كجُؤْجُؤ الطائر. ثم <span class="comment-type-4">بيّن</span> أنه <b>ورد</b> في بعض الكتب أنها كانت مربّعة، طويلة في السماء، واسعة السّفل، ضيّقة العلو، وكان أعلاها مفتوحًا للهواء والتنفس؛ لأن الغرض منها إنما كانت السلامة حتى ينزل الماء، ولم يكن طلب الجري وقصد المواضع المعيّنة، ومع هذه الهيئة فلها مجرى ومرسى، ثم <span class="comment-type-4">علَّق</span> بقوله: «والله أعلم كيف كانت، والكلّ محتمل».</div></p></div>",footnotes:1:أخرجه إبراهيم الحربي في غريب الحديث -كما في تغليق التعليق ٤/٣٢٧-، وابن المنذر -كما في فتح الباري ٨/٦١٦-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٢/١٢٤، وابن المنذر -كما في فتح الباري ٨/٦١٦-.النوتى: الملاّح. اللسان (نتا).ثَخُنَ الشيء: كَثُف وغَلُظ وصَلُب. لسان العرب (ثخن).أخرجه الطستي -كما في الإتقان ٢/٩٨-.الكلكل: الصدر من كل شيء. اللسان (كلكل).أخرجه ابن جرير ٢٢/١٢٥. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١٢٦. وعلقه البخاري في صحيحه ٤/١٨٤٣.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٢/١٢٥.أخرجه ابن جرير ٢٢/١٢٥-١٢٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٢٤-١٢٥، كما أخرجه من طريق قتادة ومعمر بنحوه، كذلك أخرجه عبد الرزاق ٢/٢٥٨ من طريق معمر بنحوه.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥١ (٣٠٨)، وابن جرير ٢٢/١٢٣.أخرجه عبد الرزاق ٢/٢٥٨، وابن جرير ٢٢/١٢٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٢٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٨- بنحوه.تفسير مقاتل بن سليمان ٤/١٧٩.أخرجه ابن جرير ٢٢/١٢٤.
  54,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَجۡرِی بِأَعۡیُنِنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَجْرِي بِأَعْيُنِنا﴾</span>، يقول: تجري السفينة في الماء بعين الله تعالى، فأغرق الله قوم نوح، فذلك الغرق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿تَجْرِي بِأَعْيُنِنا﴾</span> بحِفظنا{2}<span class=comment-ref>٦٣٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٤٣) أنّ <b>الجمهور على هذا القول،</b> وأنّ قوله: <span class="qpc-hafs">﴿بأعيننا﴾</span> معناه: بحفظنا وكفايتنا وتحت نظرنا منّا لأهلها. و<span class="comment-type-4">ساق</span> قولين آخرين: <b>الأول</b>: أن المراد مَن حفظها مِن الملائكة، سمّاهم: عيونًا. <b>الثاني</b>: أن قوله: <span class="qpc-hafs">﴿بأعيننا﴾</span> يريد به: العيون المفجَّرة من الأرض. ونسبه للرمّاني. و<span class="comment-type-2">انتقده</span> بقوله: «وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- في قوله: <span class="qpc-hafs">﴿تَجْرِي بِأَعْيُنِنا﴾</span>، يقول: بأمرنا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَزَاۤءࣰ لِّمَن كَانَ كُفِرَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: (جَزَآءً لِمَن كانَ كَفَرَ){4}، قال: جزاءً، الله هو الذي كُفِر{5}. (١٤/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى، عن ابن أبي نجيح- (لِمَن كانَ كَفَرَ)، قال: كفر بالله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- (جَزَآءً لِمَن كانَ كَفَرَ)، قال: لمن كان كفَر فيه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَزاءً لِمَن كانَ كُفِرَ﴾</span>، يعني: نوحًا المكفور به{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٩١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿جَزاءً لِمَن كانَ كُفِرَ﴾</span>، قال: لمن كان كَفر نِعم الله، وكَفر بآلاء ربّه وكتبه ورسله، فإنّ ذلك جزاء له{9}<span class=comment-ref>٦٣٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٢</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿جزاء لمن كان كفر﴾</span> على قولين: <b>الأول</b>: أن المعنى: فعلنا ذلك جزاء لمن كان كفر فيه، بمعنى: كفر بالله فيه. <b>الثاني</b>: جزاء لما كان كُفر من أيادي الله ونِعمه. وعلى هذا القول وُجّه معنى «مَن» إلى «ما».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/١٢٧-١٢٨) -<span class="mustanad">مستندًا إلى دلالة اللغة، والقرآن</span>- القول الأول الذي قاله مجاهد، <span class="comment-type-4">فقال</span>: «لأن معنى الكفر: الجحود، وهو الذي جحد ألوهيته ووحدانيته قوم نوح، فقال بعضهم لبعض: <span class="qpc-hafs">﴿لا تذرن آلهتكم ولا تذرن ودا ولا سواعا ولا يغوث ويعوق ونسرا﴾</span> [نوح:٢٣]. ومَن ذهب به إلى هذا التأويل كانت»مَن«: الله، كأنه قيل: غُرّقت لله بكفرهم به. ثم ساق <b>احتمالًا آخر</b>، هو قريب من قول مقاتل، فقال:»ولو وجّه موجّهٌ إلى أنها مرادٌ بها نوح والمؤمنون به كان مذهبًا، فيكون معنى الكلام حينئذ: فعلنا ذلك جزاء لنوح ولمن كان معه في الفُلك، كأنه قيل: غرّقناهم لنوح ولصنيعهم بنوح ما صنعوا من كُفرهم به".</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/١٤٤) على القول الأول، بقوله: «كأنه قال: غضبًا وانتصارًا لله تعالى، أي: انتصَر لنفسه، فأنجى المؤمنين، وأغرق الكافرين».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٩.تفسير الثعلبي ٩/١٦٥، وتفسير البغوي ٧/٤٢٩.أخرجه ابن جرير ٢٢/١٢٦.وهي قراءة شاذة، قرأ بها قتادة ويزيد بن رومان وحميد. ينظر: تفسير القرطبي ١٧/١٣٣.عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٢/١٢٦.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١٢٧. وفي تفسير مجاهد ص٦٣٤ بلفظ: قال: يقول: كفر، يقول: جزاء من الله.تفسير مقاتل بن سليمان ٤/١٧٩.أخرجه ابن جرير ٢٢/١٢٧.
  54,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَد تَّرَكۡنَـٰهَاۤ ءَایَةࣰ فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق معمر، عن يونس-: أنّ الله حين غَرَّق الأرض جعلت الجبال تشمخ، فتواضع الجُوديّ، فرفعه الله على الجبال، وجعل قرار السفينة عليه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولَقَدْ تَرَكْناها آيَةً﴾</span>، قال: أبقى الله سفينة نوح على الجُوديّ حتى أدركها أوائل هذه الأمة{2}<span class=comment-ref>٦٣٢٣</span>. (١٤/٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٣</span> ساق <u>ابن كثير</u> (١٣/٢٩٧) هذا القول، ثم <span class="comment-type-3">رجَّح</span> أن المراد: جنس السُّفن، <span class="mustanad">مستندًا إلى الظاهر</span>، فقال: «والظاهر أن المراد من ذلك: جنس السُّفن».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٤٤) أنّ مكيًّا قال بعود الضمير في قوله: <span class="qpc-hafs">﴿تركناها﴾</span> على الفِعلة والقصة.</div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: أبقى اللهُ السفينةَ في أرض الجزيرة عبرةً وآيةً، حتى نظر إليها أوائلُ هذه الأمة نظرًا، وكم مِن سفينة بعدها فصارت رمادًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ تَرَكْناها آيَةً﴾</span> يعني: السفينة كانت عِبرة وآية لمن بعدهم من الناس، نظيرها في الحاقة، وفي الصافات، وفى العنكبوت{4}، <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span> يقول: هل مَن يتذكر؟ فيعلم أنّ ذلك حقٌّ فيعتبر ويخاف عقوبة الله تعالى{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٥٨، وابن جرير ٢٢/١٢٩ من طريق معمر.أخرجه عبد الرزاق ٢/٢٥٨، وعبد بن حميد -كما في التغليق ٤/٣٢٨-، وابن جرير ٢٢/١٢٨ من طريق سعيد بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٢٨، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٨- واللفظ له.لعله يشير إلى آيات قصة نوح في هذه السور: <span class="qpc-hafs">﴿إنّا لَمّا طَغى الماءُ حَمَلْناكُمْ فِي الجارِيَةِ لِنَجْعَلَها لَكُمْ تَذْكِرَةً وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span> [الحاقة:١١-١٢]، <span class="qpc-hafs">﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</span> [الصافات:٧٦-٧٨]، <span class="qpc-hafs">﴿فَأَنْجَيْناهُ وأَصْحابَ السَّفِينَةِ وجَعَلْناها آيَةً لِلْعالَمِينَ﴾</span> [العنكبوت:١٥].تفسير مقاتل بن سليمان ٤/١٧٩-١٨٠.
  54,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَیۡفَ كَانَ عَذَابِی وَنُذُرِ ۝١٦ وَلَقَدۡ یَسَّرۡنَا ٱلۡقُرۡءَانَ لِلذِّكۡرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</span>، قال: لولا أنّ الله يسّره على لسان الآدميين ما استطاع أحدٌ مِن الخلق أن يتكلّم بكلام الله{1}. (١٤/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٧<span class="dash">-</span></span> عن أنس بن مالك مرفوعًا، مثله{2}. (١٤/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٨<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: يسَّرنا للحفظ ظاهرًا، وليس مِن كُتُبِ اللهِ كتابًا يُقرأ كلُّه ظاهرًا إلا القرآن{3}<span class=comment-ref>٦٣٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٤</span> ساق <u>ابن عطية</u> قول ابن جبير (٨/١٤٥)، ثم <span class="comment-type-4">علَّق</span> بقوله: «يسّر بما فيه من حُسن النّظم وشرف المعاني، فله لَوْطة بالقلوب، وامتزاج بالعقول السليمة».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</span>، قال: هوَّنّا قراءته{4}. (١٤/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَكَيْفَ كانَ عَذابِي ونُذُرِ ولَقَدْ يَسَّرْنا﴾</span> يقول: هوَّنّا <span class="qpc-hafs">﴿القُرْآنَ لِلذِّكْرِ﴾</span> يعني: ليتذكّروا فيه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</span>، قال: يسّرنا: بيّنّا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٣٨٠٢<span class="dash">-</span></span> عن ابن مسعود، قال: قرأتُ على النبيِّ ﷺ: (فَهَلْ مِن مُّذَّكِرٍ) بالذال، فقال: <span class="qpc-hafs">﴿فَهَلْ مِن مُّدَّكِرٍ﴾</span> بالدال{7}<span class=comment-ref>٦٣٢٥</span>. (١٤/٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٥</span> <span class="comment-type-4">علَّق</span> <u>ابن كثير</u> (١٣/٢٩٨) على هذا الحديث بقوله: «أخرج مسلم هذا الحديث وأهل السنن إلا ابن ماجه، من حديث أبي إسحاق».</div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٨٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span>، قال: هل من متذكّر{8}. (١٤/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- في قوله: <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span>، قال: هل من مُنزَجِر عن المعاصي{9}. (١٤/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span>، قال: هل مِن طالب خير يُعان عليه؟{10}. (١٤/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٦<span class="dash">-</span></span> عن <span class="name-2">مَطر الورّاق</span> -من طريق ابن شَوذب- في قوله: <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span>، قال: هل مِن طالب علم فيُعان عليه؟{11}<span class=comment-ref>٦٣٢٦</span><span class=comment-ref>٦٣٢٧</span>. (١٤/٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٦</span> ساق <u>ابن عطية</u> (٨/١٤٥) هذا القول الذي قاله قتادة، ومطر الوراق، وضمرة، ثم <span class="comment-type-4">علَّق</span> بقوله: «الآية تعديد نعمة في أنّ الله يسّر الهدى ولا بخل من قبله، فلله درّ مَن قبل واهتدى».</div></p><p><div><span class=comment-ref>٦٣٢٧</span> <span class="comment-type-4">علَّق</span> <u>ابن كثير</u> (١٣/٢٩٨) على هذا الأثر بقوله: «وكذا علقه البخاري بصيغة الجزم عن مطر الوراق».</div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span> يعنى: فيتذكّر فيه، ولولا أنّ الله تعالى يسّر القرآن للذِّكر ما استطاع أحدٌ أن يتكلّم بكلام الله تعالى، ولكنّ الله تعالى يسّره على خلْقه، فيقرؤونه على كلّ حال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span>، قال: المدّكر: الذي يتذكّر، وفي كلام العرب: المدّكر: المتذكّر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨٠٩<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span>، قال: فهل من مذّكّر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٨١٠<span class="dash">-</span></span> عن ضمرة -من طريق مروان- قال: <span class="qpc-hafs">﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ فَهَلْ مِن مُدَّكِرٍ﴾</span> طالب علم{15}<span class=comment-ref>٦٣٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢٨</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿فهل من مدكر﴾</span> على قولين: <b>الأول</b>: أنه يعني: فهل من معتبرٍ ومتّعظ. <b>الثاني</b>: فهل من طالب خير فيُعان عليه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/١٣١) القول الأول <span class="mustanad">مستندًا إلى الأغلب في اللغة</span>، فقال: «لأن ذلك هو الأغلب من معانيه على ظاهره». و<span class="comment-type-4">بيّن</span> أن القول الثاني قريب مما قاله.</div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٨١١<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق عاصم- أنه مرَّ برجل يقول: سورة خفيفة. قال لا تقُلْ: سورة خفيفة. ولكن قُلْ: سورة يسيرة. لأن الله يقول: <span class="qpc-hafs">﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</span>{16}. (١٤/٧٨)</p></p><p></div></p></div>",footnotes:1:أخرجه البيهقي (٥٧٢). وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أورده الديلمي في الفردوس ٥/٢٥٩-٢٦٠ (٨١٢٢) بنحوه.</p><p>قال ابن عراق الكناني في تنزيه الشريعة ١/٣٠٩ (٨٤): «وفيه عباد بن عبد الصمد». وقال ابن عدي في الكامل في ضعفاء الرجال ٥/٥٥٢ في ترجمة عباد بن عبد الصمد أبي معمر (١١٧١): «وعباد بن عبد الصمد له عن أنس غير حديث منكر، وعامة ما يرويه في فضائل علي، وهو ضعيف منكر الحديث، ومع ذلك غالٍ في التشيع».تفسير الثعلبي ٩/١٦٥.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٦٣٤-، وابن جرير ٢٢/١٣٠ بلفظ: هوَّنّا، والبيهقي في الأسماء والصفات (٥٧٣). وعلقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التوحيد، باب <span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر فهل من مدكر﴾</span> ٦/٢٧٤٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٨٠.أخرجه ابن جرير ٢٢/١٣١.أخرجه البخاري (٤٨٧٤)، والحاكم ٢/٢٧٣ (٢٩٨٥).</p><p>و(فَهَلْ مِن مُّذَّكِرٍ) بالذال قراءة شاذة، تروى أيضًا عن عيسى، وقتادة. انظر: مختصر ابن خالويه ص١٤٨-١٤٩.عزاه السيوطي إلى ابن المنذر، وعبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٤٧ (٢٩٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٣١، ومن طريق الحارث بن عبيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٣١-١٣٢، وأبو نعيم في الحلية ٣/٧٦. وعزاه السيوطي إلى ابن أبي الدنيا، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٨٠.أخرجه ابن جرير ٢٢/١٣٠.أخرجه ابن جرير ٢٢/١٣٠.أخرجه الدارمي في سننه ١/٣٦٤ (٣٥٩).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٤ (١٨)، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٤٩٧-٤٩٨ (٣٠٧٢٠). وعزاه السيوطي إلى ابن المنذر، وزاد ابن وهب في روايته: فإن الله يقول: <span class="qpc-hafs">﴿إنّا سَنُلْقِي عَلَيْكَ قَوْلًا ثَقِيلًا﴾</span> [المزمل:٥].
  54,17,""
