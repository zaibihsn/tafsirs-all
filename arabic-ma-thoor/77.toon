  77,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ نَخۡلُقكُّم مِّن مَّاۤءࣲ مَّهِینࣲ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ألَمْ نَخْلُقْكُمْ مِن ماءٍ مَهِينٍ﴾</span>: يعني بالمهين: الضعيف{1}<span class=comment-ref>٦٩٦٧</span>. (١٥/١٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٧</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٣/٥٩٤) مبيّنًا معنى الآية <span class="mustanad">استنادًا إلى أثر ابن عباس</span>: «يقول -تعالى ذِكْره-: <span class="qpc-hafs">﴿ألم نخلقكم﴾</span> أيها الناس <span class="qpc-hafs">﴿من ماء مهين﴾</span> يعني: من نُطفة ضعيفة».</div></p><p><div></p><p><p><span class="item-no">٨٠٧١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿مِن ماءٍ مَهِينٍ﴾</span>، قال: ضعيف{2}. (١٥/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم بيّن لهم بَدء خَلْق أنفسهم؛ لئلا يُكذّبوا بالبعث، وليَعتبِروا، فقال: يا مَعشر المُكذِّبين، <span class="qpc-hafs">﴿ألَمْ نَخْلُقْكُمْ مِن ماءٍ مَهِينٍ﴾</span>. يقول: ماء ضعيف، وهو النّطفة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٤.عزاه السيوطي إلى ابن جرير، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهُ فِی قَرَارࣲ مَّكِینٍ ۝٢١ إِلَىٰ قَدَرࣲ مَّعۡلُومࣲ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَجَعَلْناهُ فِي قَرارٍ مَكِينٍ﴾</span>، قال: الرَّحِم{1}. (١٥/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَجَعَلْناهُ فِي قَرارٍ مَكِينٍ﴾</span> يعني: الماء يَتمَكّن في الرَّحِم، <span class="qpc-hafs">﴿إلى قَدَرٍ مَعْلُومٍ﴾</span> يعني: تسعة أشهُر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦٩١، وأخرجه ابن جرير ٢٣/٥٩٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,22,""
  77,21,""
  77,22,""
  77,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَدَرۡنَا فَنِعۡمَ ٱلۡقَـٰدِرُونَ ۝٢٣ وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧١٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُويبر- <span class="qpc-hafs">﴿فَقَدَرْنا فَنِعْمَ القادِرُونَ﴾</span> قال: فخَلَقنا فنِعْم المالكون{1}. (١٥/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقَدَرْنا﴾</span> الصّبيَّ في رَحِم أُمّه تسعة أشهُر، ودون ذلك أو فوق ذلك، فقال الله ﷿: <span class="qpc-hafs">﴿فَنِعْمَ القادِرُونَ﴾</span>، ثم قال: <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿فَقَدَرْنا فَنِعْمَ القادِرُونَ﴾</span>، قال: فمَلكنا فنِعْم المالكون{3}. (١٥/١٧٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٦.تفسير مقاتل بن سليمان ٤/٥٤٤.عزاه السيوطي إلى ابن المنذر.
  77,24,""
  77,24,""
  77,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ كِفَاتًا ۝٢٥ أَحۡیَاۤءࣰ وَأَمۡوَ ٰ⁠تࣰا ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الرّبيع بن خُثَيْم-: أنه أخذ قَمْلَة، فدفنها في المسجد، ثم قرأ: <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</span>{1}. (١٥/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا﴾</span>، قال:كِنًّا{2}. (١٥/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عثمان بن الأسود- <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا﴾</span>، قال: تَكْفِتُهم أمواتًا، وتَكُفّ أذاهم أحياء{3}. (١٥/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿كِفاتًا﴾</span> قال: تَكْفِتُ الميت، ولا يُرى منه شيء. وقوله: <span class="qpc-hafs">﴿أحْياءً﴾</span> الرجل في بيته لا يُرى من عمله شيء{4}. (١٥/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: إذا وجدتَ قَمْلَة في المسجد فادفنها، ويقول: <span class="qpc-hafs">﴿ألم نجعل الأرض كفاتا أحياء وأمواتا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</span>، قال: أحياء يكونون فيها، ويُغيِّبون فيها ما أرادوا. وفي لفظ: يُغيِّبون فيها ما أرادوا. وقوله: <span class="qpc-hafs">﴿أحْياءً وأَمْواتًا﴾</span>، قال: يُدفنون فيها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٥<span class="dash">-</span></span> عن <span class="name-2">عامرالشعبي</span> -من طريق بيان- <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</span>، قال: بَطنها لأمواتكم، وظَهرها لأحيائكم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٦<span class="dash">-</span></span> عن بَيان بن بِشر، قال: خَرجْنا في جنازة فيها <span class="name-2">عامر الشعبي</span>، فلما انتَهينا إلى الجبّان تلا هذه الآية: <span class="qpc-hafs">﴿ألم نجعل الأرض كفاتا أحياء وأمواتا﴾</span>، قال: كِفات الأموات -وأشار إلى القبور-، وهذه كِفات الأحياء -وأشار بيده إلى البيوت-{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿أحْياءً وأَمْواتًا﴾</span>، قال: أحياء فوقها على ظهرها، وأمواتًا يُقبرون فيها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</span> أليس قد جَعل لكم الأرض كِفاتًا لكم، تَدفِنون فيها أمواتكم، وتَبثُّون عليها أحياءكم، وتَسكنون عليها؟! فقد كَفت الموتى والأحياء{10}<span class=comment-ref>٦٩٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٨</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٣/٥٩٦) مبيّنًا معنى الآية <span class="mustanad">استنادًا إلى أقوال السلف</span>: «يقول -تعالى ذِكْره- مُنبِّهًا عباده على نِعَمه عليهم: <span class="qpc-hafs">﴿ألم نجعل﴾</span> أيها الناس <span class="qpc-hafs">﴿الأرض﴾</span> لكم <span class="qpc-hafs">﴿كفاتا﴾</span> يقول: وعاء، يُقال: هذا كِفْتُ هذا وكَفِيتُه: إذا كان وعاءه. وإنما معنى الكلام: ألم نجعل الأرض كِفات أحيائكم وأمواتكم، تَكْفِتُ أحياءكم في المساكن والمنازل، فتضمّهم فيها وتجمعهم، وأمواتكم في بطنِها في القبور، فيُدفنون فيها». وذكر <b>احتمالًا</b> آخر، فقال: «وجائز أن يكون عُنِي بقوله: <span class="qpc-hafs">﴿كفاتا أحياء وأمواتا﴾</span> تَكْفِتُ أذاهم في حال حياتهم، وجيَفَهم بعد مماتهم».</p><p>وذكر <u>ابنُ عطية</u> (٨/٥٠٦) نحو قول <u>ابن جرير</u> في معنى <span class="qpc-hafs">﴿كِفاتًا﴾</span>، ثم قال: «و<span class="qpc-hafs">﴿أحياء﴾</span> -على هذا التأويل- معمول لقوله سبحانه: <span class="qpc-hafs">﴿كِفاتًا﴾</span> لأنه مصدر». ونقل عن بعض المتأولين: أنّ «<span class="qpc-hafs">﴿أحْياءً وأَمْواتًا﴾</span> إنما هو بمعنى أنّ الأرض فيها أقطارٌ أحياءٌ وأقطارٌ أموات». و<span class="comment-type-1">وجَّهه</span> بقوله: «يراد: ما يُنبت وما لا يُنبت، فنصب <span class="qpc-hafs">﴿أحْياءً﴾</span> -على هذا- إنما هو على الحال من الأرض». ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والتأويل الأول أقوى». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ٢/٣٦٨، وابن جرير ٢٣/٥٩٧، والبيهقي في سننه ٢/٢٩٤. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٥٩٦، وابن أبي حاتم -كما في الإتقان ٢/٥١-.أخرجه ابن جرير ٢٣/٥٩٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٣٨ (٢٣٧٤)، وابن جرير ٢٣/٥٩٧ بنحوه.تفسير مجاهد ص٦٩١، وأخرجه ابن جرير ٢٣/٥٩٨.أخرجه ابن جرير ٢٣/٥٩٧.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٣٧ (٢٣٧٢).أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٩٨، وبنحوه من طريق سعيد.تفسير مقاتل بن سليمان ٤/٥٤٤-٥٤٥.
  77,26,""
  77,26,""
  77,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا فِیهَا رَوَ ٰ⁠سِیَ شَـٰمِخَـٰتࣲ وَأَسۡقَیۡنَـٰكُم مَّاۤءࣰ فُرَاتࣰا ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿رَواسِيَ﴾</span>، قال: جبالًا مُشرِفات{1}. (١٥/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجَعَلْنا فِيها رَواسِيَ شامِخاتٍ﴾</span>: يعني: الجبال{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال: <span class="qpc-hafs">﴿وجَعَلْنا فِيها رَواسِيَ شامِخاتٍ﴾</span> وهي جبال راسخة في الأرض أوتادًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٩، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٥٩٨.تفسير مقاتل بن سليمان ٤/٥٤٥.
  77,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَسۡقَیۡنَـٰكُم مَّاۤءࣰ فُرَاتࣰا ۝٢٧ وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فُراتًا﴾</span>: عَذْبًا{1}. (١٥/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿وأَسْقَيْناكُمْ ماءً فُراتًا﴾</span>، قال: مِن أربعة أنهار: سَيْحان، وجَيْحان، والنّيل، والفُرات، وكلّ ماء يَشربه ابن آدم فهو من هذه الأنهار<span class=comment-ref>٦٩٦٩</span>، وهي تَخرج من تحت صخرة من عند بيت المقدس؛ وأما سَيْحان فهو ببلخ، وأما جَيْحان فدِجْلة، وأما الفُرات ففُرات الكوفة، وأما النّيل فهو نيل مصر{2}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٩</span> نقل <u>ابنُ عطية</u> (٨/٥٠٧) عن عكرمة نحو قول ابن عباس، فقال: «حُكي عن عكرمة أنّ كل ماء في الأرض فهو من هذه». أي: من هذه الأنهار الأربعة، و<span class="comment-type-2">انتقده</span> قائلًا: «وفي هذا بُعْد».</div></p><p><div></p><p><p><span class="item-no">٨٠٧٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿ماءً فُراتًا﴾</span>، قال: عَذْبًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأَسْقَيْناكُمْ ماءً فُراتًا﴾</span>: أي: ماء عَذْبًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> ثم قال: <span class="qpc-hafs">﴿وأَسْقَيْناكُمْ ماءً فُراتًا﴾</span> يقول: ماء حُلوًا، <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالبعث، وقد عَلِموا أنّ الله تعالى قد خَلَق هذه الأشياء كلّها{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٩، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٥٩٩-٦٠٠.تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٥٩٩.أخرجه ابن جرير ٢٣/٥٩٩.تفسير مقاتل بن سليمان ٤/٥٤٥.
  77,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱنطَلِقُوۤا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span> في الدنيا أنّه غير كائن، وهي النار، وذلك أنه إذا انطلَق أهلُ النار وهي تُهمْهِم زَفرتْ جهنمُ زَفرةً واحدة، فيَخرج عُنُق، فيُحيط بأهلها، ثم تَزْفُر زفرةً أخرى، فيَخرج عُنُق لها من نار، وتُحيط بهم، ثم تَزْفِرُ الثالثة، فيَخرج عُنُق، فيُحيط بالآخرين، فتصير حولهم سُرادق من نار، فيَخرج دُخان من جهنم، فيقوم فوقهم، فيظنّ أهلها أنه ظِلٌّ، وأنه سينفعهم من هذه النار، فيَنطلِقون كلّهم بأجمعهم، فيَستظِلّون تحتها، فيَجدونها أشدّ حرًّا من السُّرادق، فذلك قوله: <span class="qpc-hafs">﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span>، وهو شِعْب بجهنم، أنهم كَذّبوا الرُّسُل في الدنيا بأنّ العذاب في الآخرة ليس بكائن، فتقول لهم الملائكة الخُزّان: <span class="qpc-hafs">﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٥.
  77,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱنطَلِقُوۤا۟ إِلَىٰ ظِلࣲّ ذِی ثَلَـٰثِ شُعَبࣲ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span>: دُخان جهنم{1}<span class=comment-ref>٦٩٧٠</span>. (١٥/١٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٠</span> <span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/٥٠٧) <b>رواية</b> -ولم ينسبها-: أن دخان جهنم «يعلو من ثلاثة مواضع، فيراه الكفار، فيظنون أنه مُغْنٍ، فيُهرعون إليه، فيجدونه على أسوأ وصف». ونقل <b>عن ابن عباس</b> في معنى الآية قوله: «هذه المخاطبة إنما تقال يومئذ لِعَبَدَة الصليب إذا اتَّبع كلّ أحد ما كان يعبد، فيكون المؤمنون في ظِلّ الله تعالى، ولا ظلَّ إلا ظلُّه، ويقال لعَبَدة الصليب: انطَلِقُوا إلى ظِلِّ معبودكم، وهو الصليب، له ثَلاثُ شُعَبٍ، والشُّعب تفرق الجسم الواحد فرقًا، ثم نفى تعالى عنه محاسن الظِّل».</div></p><p><div></p><p><p><span class="item-no">٨٠٧٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span>، قال: هو كقوله: <span class="qpc-hafs">﴿نارًا أحاطَ بِهِمْ سُرادِقُها﴾</span> [الكهف:٢٩] قال: والسُّرادق: دُخان النار. فأحاط بهم سُرادقها، ثم تَفَرّق، فكان ثلاث شُعَب، فقال: <span class="qpc-hafs">﴿انْطَلِقُوا إلى ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span>؛ شُعبة هاهنا، وشُعبة هاهنا، وشُعبة هاهنا، <span class="qpc-hafs">﴿لا ظَلِيلٍ ولا يُغْنِي مِنَ اللَّهَبِ﴾</span>{2}. (١٥/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span>، قال: هو كقوله: <span class="qpc-hafs">﴿نارًا أحاطَ بِهِمْ سُرادِقُها﴾</span> [الكهف:٢٩]، والسُّرادق: الدُّخان؛ دُخان النار، فأحاط بهم سُرادقها، ثم تَفَرّق فكان ثلاث شُعَب؛ شُعبة ههنا، وشُعبة ههنا، وشُعبة ههنا{3}. (١٥/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span> هو السُّرادق، والظِّلّ من يَحموم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿انْطَلِقُوا إلى ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span> لأنها تَنقطع ثلاث قِطع{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٦٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٦٠٠-٦٠١.أخرجه عبد الرزاق ١/٤٠٢، ٢/٣٤٠.تفسير الثعلبي ١٠/١١٠.تفسير مقاتل بن سليمان ٤/٥٤٥.
  77,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا ظَلِیلࣲ وَلَا یُغۡنِی مِنَ ٱللَّهَبِ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٤٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿لا ظَلِيلٍ ولا يُغْنِي مِنَ اللَّهَبِ﴾</span> لا يُردّ لهب جهنم عنكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿لا ظَلِيلٍ﴾</span> يقول: لا بارد، <span class="qpc-hafs">﴿ولا يُغْنِي مِنَ اللَّهَبِ﴾</span> يقول: مِن ذلك السُّرادق الذي قد أحاط حولهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/٣٠٦.تفسير مقاتل بن سليمان ٤/٥٤٥.
  77,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهَا تَرۡمِی بِشَرَرࣲ كَٱلۡقَصۡرِ ۝٣٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- أنه قرأها: (كالقَصَرِ) بفتح القاف والصاد، قال: قَصَر النّخل. يعني: الأعناق{1}. (١٥/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> أنه كان يقرأ: <span class="qpc-hafs">﴿كالقَصْرِ﴾</span>، قال: كقطعة النّخلة الحادرة{2}. (١٥/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هارون- أنه قرأ: <span class="qpc-hafs">﴿كالقَصْرِ﴾</span> بجزم الصاد، وقال: هو الجَزْل من الخَشَب{3}. (١٥/١٨٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهَا تَرۡمِی بِشَرَرࣲ كَٱلۡقَصۡرِ ۝٣٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عَلقمة- في قوله: <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: إنها ليستْ كالشجر والجبال، ولكنها مِثل المدائن والحُصون{4}. (١٥/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿بِشَرَرٍ كالقَصْرِ﴾</span>، قال: مثل قَصْر النّخلة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بِشَرَرٍ كالقَصْرِ﴾</span>، قال: كالقَصْر العظيم{6}. (١٥/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الرحمن بن عابس- في قوله: <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: كُنّا نرفع الخَشَب بقِصَر ثلاثة أذرع أو أقل، فنرفعه للشتاء، فنُسمِّيه: القَصْر{7}. (١٥/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، (كالقَصَرِ)، قال: كجذور الشجر{8}. (١٥/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الرحمن بن عابس- قال: كانت العرب تقول في الجاهلية: اقصُرُوا لنا الحَطَب، فيُقطع على قَدْر الذّراع والذّراعين{9}. (١٥/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كالقَصْرِ﴾</span>، قال: هو القصر{10}. (١٥/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>: فالقَصْر: الشجر المُقطّع. ويقال: القَصْر: النّخل المقطوع{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٦<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: ليس كالخَشَب، ولكن كالقصور والمدائن{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، في قوله: <span class="qpc-hafs">﴿كالقَصْرِ﴾</span>، قال: مثل قَصْر النّخلة{13}. (١٥/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كالقَصْرِ﴾</span>، قال: حِزَم الشجر، وقِطَع النّخل{14}. (١٥/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: ذكَر القصرَ{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في الآية: <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: القَصْر: أصول الشجر العِظام، كأنها أجْواز الإبل الصُّفر{16}. (١٥/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كالقَصْرِ﴾</span>، قال: أصول الشجر، وأصول النّخل{17}. (١٥/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- في قول الله: <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: إنّ على جهنم سُورًا، فما خرج مِن وراء السُّور مِمّا يَرجع فيها في عِظَم القَصْر، ولون القار{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٣<span class="dash">-</span></span> عن الأسود -من طريق عطاء بن السّائِب- <span class="qpc-hafs">﴿تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>، قال: مثل القَصْر{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذَكر الظِّل، فقال: <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span> وهو أصول الشجر يكون في البَريّة، فإذا جاء الشتاء قُطعتْ أغصانها، فتبقى أصولها، فيَحرقها البرد، فَتَسْوَدُّ، فتراها في البَريّة كأمثال الجمال إذا أُنيخَتْ في البَريّة، فذلك قوله: <span class="qpc-hafs">﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</span>{20}<span class=comment-ref>٦٩٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧١</span> اختَلف القراء في قراءة قوله تعالى: <span class="qpc-hafs">﴿كالقصر﴾</span> على وجهين: <b>الأول</b>: بسكون الصاد -وهي قراءة الجمهور-، هكذا <span class="qpc-hafs">﴿كالقَصْر﴾</span>، واخْتُلِف في المعنى -على هذه القراءة- على قولين: أولهما: أنّ القَصْر هنا واحد القصور. وثانيهما: أنّ المراد به هنا الغليظ من الخَشَب، كأصول النّخل، وما أشبه ذلك. و<b>الثاني</b>: بفتح الصاد -وهي قراءة لابن عباس-، هكذا (كالقَصَر)، بمعنى: أعناق الدواب.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٢٣/٦٠٤-٦٠٥) قراءة الجمهور، والتأويل الأول لها <span class="mustanad">استنادًا إلى السياق، ولغة العرب</span>، فقال: «وأولى القراءتين بالصواب في ذلك عندنا ما عليه قُراء الأمصار، وهو سكون الصاد، وأولى التأويلات به أنه القَصْر من القصور، وذلك لدلالة قوله: <span class="qpc-hafs">﴿كأنه جمالات صفر﴾</span> على صحته، والعرب تشبّه الإبل بالقصور المبنيّة ...، وقيل: <span class="qpc-hafs">﴿بشرر كالقصر﴾</span> ولم يقل: كالقصور. والشّرر جماع، كما قيل: <span class="qpc-hafs">﴿سيهزم الجمع ويولون الدبر﴾</span> [القمر:٤٥]، ولم يقل: الأدبار. لأنّ الدُّبر بمعنى الأدبار، وفعل ذلك توفيقًا بين رؤوس الآيات ومقاطع الكلام؛ لأن العرب تَفعل ذلك كذلك، وبلسانها نزل القرآن. وقيل: <span class="qpc-hafs">﴿كالقصر﴾</span>، ومعنى الكلام: كعِظَم القَصْر، كما قيل: <span class="qpc-hafs">﴿تدور أعينهم كالذي يغشى عليه من الموت﴾</span> [الأحزاب:١٩]، ولم يقل: كعيون الذي يُغشى عليه. لأنّ المراد في التشبيه الفعل لا العين». <span class="mustanad">واستشهد بأثر الأسود</span>.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/٥٠٨) قول ابن عباس من طريق عبد الرحمن بن عابس وما في معناه؛ أنّ القصر: «خشبٌ كان في الجاهلية يُقطَع من جَزْل الحطب من النّخل وغيره، على قدْر الذراع وفوقه ودونه، يُستَعَدُّ به للشتاء» قائلًا: «وهو المراد في الآية، وإنما سُمّي بالقَصْر لأنه يحيط بالقصرة». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٦٠٤. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن سعيد بن جبير. انظر: المحتسب ٢/٣٤٦، ومختصر ابن خالويه ص١٦٧.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.أخرجه ابن جرير ٢٣/٦٠٤.أخرجه الطبراني في الأوسط (٩١٢). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٦٠٣.أخرجه ابن جرير ٢٣/٦٠١، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤١، وهناد (٢٧٣)، والبخاري (٤٩٣٢-٤٩٣٣)، وابن جرير ٢٣/٦٠٢ بنحوه، وابن مردويه -كما في فتح الباري ٨/٦٨٨- بنحوه، والحاكم ٢/٥١١. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن مردويه -كما في فتح الباري ٧/٦٨٨-، وابن جرير ٢٣/٦٠٢ بنحوه.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٦٠٣.أخرجه ابن أبي الدنيا في كتاب صفة النار -ضمن موسوعة الإمام ابن أبي الدنيا ٦/٤٣٨ (١٧٣)-.عزاه السيوطي إلى ابن جرير وهو في بعض نسخ ابن جرير، وفي نسخة التركي ٢٣/٦٠٣ عن سعيد بن جُبَير، عن ابن عباس، كما تقدم.تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٦٠٣ بلفظ: حِزَم الشجر، يعني الحزمة. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٦٠١.أخرجه ابن جرير ٢٣/٦٠٣-٦٠٤. وقال عقبه: وسط كل شيء: جَوْزه.أخرجه عبد الرزاق ٢/٣٤٠ من طريق معمر، وابن جرير ٢٣/٦٠٣ بنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٥٢ (١١٢)، وابن جرير ٢٣/٦٠١-٦٠٢.أخرجه ابن جرير ٢٣/٦٠٥.تفسير مقاتل بن سليمان ٤/٥٤٥-٥٤٦.
  77,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَنَّهُۥ جِمَـٰلَتࣱ صُفۡرࣱ ۝٣٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- أنه كان يقرأ: ‹جُمالاتٌ› بضم الجيم {1}<span class=comment-ref>٦٩٧٢</span>. (١٥/١٨١)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٢</span> اختَلف القُراء في قراءة قوله تعالى: <span class="qpc-hafs">﴿جمالات﴾</span> على ثلاثة أوجه: <b>الأول</b>: بكسر الجيم، وتاء مفتوحة في آخرها -وهي قراءة عامة أهل المدينة والبصرة، وبعض الكوفيّين-، هكذا ‹جِمالاتٌ›، على أنها جمع جِمال. و<b>الثاني</b>: بكسر الجيم، وهاء التأنيث في آخرها -وهي قراءة عامة الكوفيّين-، هكذا <span class="qpc-hafs">﴿جِمالَتٌ﴾</span>، على أنها جمع جَمَل،كما يقال: حِجارة جمع حَجَر. و<b>الثالث</b>: بضم الجيم، وتاء مفتوحة في آخرها -وهي قراءة لابن عباس-، هكذا ‹جُمالات›، على أنها جمع «جُمالة» أي: الشيء المجمل.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٨/٥٠٩ بتصرف) على هذه الأوجه بقوله: «ضم الجيم فيها من»الجُمْلة«لا من»الجَمَل«، وكسرها من»الجَمَل«لا من»الجُمْلة«». و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢٣/٦٠٩) إلى صحة الوجهين <b>الأول والثاني</b>، فقال: «الصواب من القول في ذلك أنّ لقارئ ذلك اختيار أي القراءتين شاء من كسر الجيم وقراءتها بالتاء وكسر الجيم، وقراءتها بالهاء التي تصير في الوصل تاء؛ <span class="mustanad">لأنهما القراءتان المعروفتان في قراء الأمصار</span>». و<span class="comment-type-2">انتَقَدَ</span> (٢٣/٦٠٩) الوجه <b>الثالث</b>، فقال: «أما ضم الجيم فلا أستجيزه؛ <span class="mustanad">لإجماع الحُجّة من القرأة على خلافه</span>».</div></p><p><h3><span class="qpc-hafs">﴿كَأَنَّهُۥ جِمَـٰلَتࣱ صُفۡرࣱ ۝٣٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي-: ‹جِمالاتٌ صُفْرٌ›، قال: قِطَع النّحاس{2}. (١٥/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الرحمن بن عابس- أنه سئل عن قوله: <span class="qpc-hafs">﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</span>. قال: حِبال السُّفن يُجمع بعضها إلى بعض حتى تكون كأوساط الرجال{3}. (١٥/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: ‹كَأَنَّهُ جِمالاتٌ صُفْرٌ›، قال: الإبل{4}. (١٥/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٦٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</span>: الحِبال{5}. (١٥/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق هلال بن خَبّاب- في قوله: <span class="qpc-hafs">﴿جِمالَتٌ صُفْرٌ﴾</span>، قال: قُلُوس الجسر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</span>، قال: حِبال الجُسور{7}. (١٥/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- <span class="qpc-hafs">﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</span>، قال: هي الإبل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> أنه كان يقرأ: ‹جِمالاتٌ صُفْرٌ›، قال: القَلُوص{9}. (١٥/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> في قوله: ‹كأنه جِمالاتٌ صُفْر› قال: الصُّفر السُّود{10}. (١٥/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق داود بن أبي هند- <span class="qpc-hafs">﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</span>، قال: الأيْنُق السُّود{11}. (١٥/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- (كَأَنَّهُ جِمالاتٌ صُفْرٌ)، قال: كأنه نُوق سُود{12}. (١٥/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</span>، يقول: كأنها جِمال سوداء إذا رأيتَها من مكان بعيد{13}<span class=comment-ref>٦٩٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٣</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿جمالات صفر﴾</span> على ثلاثة أقوال: <b>الأول</b>: أنّها الجِمال الصُّفْر، وأراد بالصُّفْر: السُّود، سُمِّيت «صُفْرًا» لأنّ سَوادها يَضرِب إلى الصُّفرة. وهو قول الحسن، ومجاهد، وقتادة. و<b>الثاني</b>: أنها قُلُوس السُّفن، والقُلُوس: جمْع قَلْس، وهو حَبل ضخم من لِيف. وهو قول ابن عباس، وسعيد بن جُبَير. و<b>الثالث</b>: أنها قِطَع النّحاس. وهو قولٌ آخر لابن عباس.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٥٠٩) على القول الثالث بقوله: «وكان اشتقاق هذه اللفظة من اسم الجملة».</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٢٣/٦٠٨) القولَ الأولَ <span class="mustanad">استنادًا إلى لغة العرب</span>، فقال: «أولى الأقوال عندي بالصواب قول مَن قال: عُني بالجمالات الصُّفر: الإبل السُّود؛ لأن ذلك هو المعروف من كلام العرب، وأنّ الجِمالات جمع جِمال، نظير: رجال، ورجالات، وبيوت، وبيوتات».</p><p>ونقل <u>ابنُ عطية</u> عن جمهور الناس أنّ «الصُّفْر: الفاقعة؛ لأنها أشبه بلون الشَّرَر».</div></p><p><h3><span class="qpc-hafs">﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالبعْث{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٦٠٩. وعزاه السيوطي إلى ابن المنذر.</p><p>و‹جُمالاتٌ› بضم الجيم قراءة متواترة، قرأ بها رويس، وكسرها على التوحيد: <span class="qpc-hafs">﴿جِمالَتٌ﴾</span> حمزة، والكسائي، وخلف، وحفص، وكسرها على الجمع بقية العشرة: ‹جِمالاتٌ›. انظر: النشر ٢/٣٩٧، والإتحاف ص٥٦٨.أخرجه ابن جرير ٢٣/٦٠٨، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤١، وهناد (٢٧٣)، والبخاري (٤٩٣٢-٤٩٣٣)، وابن جرير ٢٣/٦٠٦، ٦٠٧، ٦٠٨ وبنحوه من طريق عطية وسليمان، وابن مردويه -كما في فتح الباري ٨/٦٨٨- بنحوه، والحاكم ٢/٥١١. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٦٠٧. وعزاه السيوطي إليه بلفظ: هو الجسر. وفي لفظ: كالجبال.أخرجه ابن جرير ٢٣/٦٠٧ من طرق.تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٦٠٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٦٠٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن الأنباري في كتاب الأضداد ص١٦٠، ١٦١.أخرجه ابن جرير ٢٣/٦٠٥-٦٠٦ بلفظ: الأينق السود.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٦٠٦، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٦.تفسير مقاتل بن سليمان ٤/٥٤٦.
  77,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا یَوۡمُ لَا یَنطِقُونَ ۝٣٥ وَلَا یُؤۡذَنُ لَهُمۡ فَیَعۡتَذِرُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٧٩<span class="dash">-</span></span> عن عبد الله بن الصّامت، قال: قلت <span class="name-1">لعبد الله بن عمرو بن العاص</span>: أرأيتَ قول الله: <span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ ولا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</span>. قال: إنّ يوم القيامة يوم له حالات وتارات؛ في حال لا يَنطِقون، وفي حال يَنطِقون، وفي حال يَعْتذِرون، لا أُحدِّثكم إلا ما حدَّثنا رسول الله ﷺ، قال: «<b>إذا كان يوم القيامة يَنزل الجبّار في ظُلَل من الغمام -وكلّ أُمّة جاثية- في ثلاث حُجُب، مسيرة كلّ حجاب خمسون ألف سنة؛ حِجاب من نور، وحِجاب من ظُلمة، وحِجاب من ماء، لا يُرى لذلك، فيَأمر بذلك الماء فيعود في تلك الظُّلمة، ولا تَسمع نفس ذلك القول إلا ذَهبت، فعند ذلك لا يَنطِقون</b>»{1}. (١٥/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنّ نافع بن الأزرق سأله عن قوله تعالى: <span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</span>، و<span class="qpc-hafs">﴿فَلا تَسْمَعُ إلّا هَمْسًا﴾</span> [طه:١٠٨]، و<span class="qpc-hafs">﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span> [الصافات:٢٧، والطور:٢٥]، و<span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</span> [الحاقة:١٩]، فما هذا؟ قال: ويحك! هل سألتَ عن هذا أحدًا قبلي؟ قال: لا. قال: أما إنك لو كنتَ سألتَ هَلكتَ؛ أليس قال الله تعالى: <span class="qpc-hafs">﴿وإنَّ يَوْمًا عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾</span> [الحج:٤٧]؟ قال: بلى. قال: وإنّ لكلّ مقدار يوم من هذه الأيام لونًا من الألوان{2}. (١٥/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٨١<span class="dash">-</span></span> عن أبي الضُّحى، أنّ نافع بن الأزرق وعطية أتيا <span class="name-1">ابن عباس</span>، فقالا: يا ابن عباس، أخبِرنا عن قول الله: <span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</span>، وقوله: <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ يَوْمَ القِيامَةِ عِنْدَ رَبِّكُمْ تَخْتَصِمُونَ﴾</span> [الزمر:٣١]، وقوله: <span class="qpc-hafs">﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</span> [الأنعام:٢٣]، وقوله: <span class="qpc-hafs">﴿ولا يَكْتُمُونَ اللَّهَ حَدِيثًا﴾</span> [النساء:٤٢]. قال: ويحك، يا ابن الأزرق، إنه يوم طويل، وفيه مواقف؛ تأتي عليهم ساعة لا يَنطِقون، ثم يُؤذن لهم فيَختَصِمون، ثم يَمكُثون ما شاء الله يَحلِفون ويَجْحدون، فإذا فَعلوا ذلك خَتم الله على أفواههم، ويَأمر جوارحهم، فتَشهد على أعمالهم بما صَنعوا، ثم تَنطِق ألسنتهم فيَشهدون على أنفسهم بما صَنعوا. قال: وذلك قوله: <span class="qpc-hafs">﴿ولا يَكْتُمُونَ اللَّهَ حَدِيثًا﴾</span>{3}. (١٥/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٨٢<span class="dash">-</span></span> عن عكرمة أنه سُئل عن قوله: <span class="qpc-hafs">﴿يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span> [المعارج:٤]. قال: ألا أُخبرِكم بأشدّ مما تسألون عنه؟ قال <span class="name-1">ابن عباس</span>، وذَكر: <span class="qpc-hafs">﴿لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span> [الرحمن:٣٩]، <span class="qpc-hafs">﴿فَوَرَبِّكَ لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾</span> [الحجر:٩٢]، و<span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</span>، قال <span class="name-1">ابن عباس</span>: إنها أيام كثيرة في يوم واحد، فيَصنع الله فيها ما يشاء، فمنها: <span class="qpc-hafs">﴿يَوْمُ لا يَنْطِقُونَ﴾</span>، ومنها: <span class="qpc-hafs">﴿يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span> [الإنسان:١٠]{4}. (١٥/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٨٣<span class="dash">-</span></span> عن قتادة، قال جاء رجل إلى <span class="name-2">عكرمة</span>، فقال: أرأيتَ قول الله تعالى: <span class="qpc-hafs">﴿هذا يوم لا ينطقون﴾</span>، وقوله: <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ يَوْمَ القِيامَةِ عِنْدَ رَبِّكُمْ تَخْتَصِمُونَ﴾</span> [الزمر:٣١]؟ قال: إنها مواقف، فأما موقف منها فتكلموا واختصموا، ثم ختم الله على أفواههم، فتكلمت أيديهم وأرجلهم، فحينئذ لا ينطقون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذَكر الويل متى يكون، فقال: <span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ ولا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</span>، فقال: أن تَعتذروا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالبعث{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه ابن حجر في الفتح ٨/٦٨٦ إلى ابن مردويه مقتصرًا على أوله، وعزاه إليه بتمامه السيوطي ١٥/١٨٤.أخرجه الحاكم ٤/٥٧٣.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٢-، وعبد بن حميد -كما في فتح الباري ٨/٦٨٦-.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/١٦٢.تفسير مقاتل بن سليمان ٤/٥٤٦.تفسير مقاتل بن سليمان ٤/٥٤٦.
