  88,19,""
  88,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِلَى ٱلۡأَرۡضِ كَیۡفَ سُطِحَتۡ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وإلى الأرْضِ كَيْفَ سُطِحَتْ﴾</span>: هل يقدر أحد أن يَخلُق مثل الإبل، أو يرفع مثل السماء، أو ينصب مثل الجبال، أو يسطح مثل الأرض غيري؟!{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿وإلى الأَرْضِ كَيْفَ سُطِحَتْ﴾</span> أي: بُسطتْ. يقول: الذي خَلَق هذا قادر على أن يَخلُق في الجنة ما أراد{2}. (١٥/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإلى الأَرْضِ كَيْفَ سُطِحَتْ﴾</span>، يعني: كيف بُسطتْ مِن تحت الكعبة مسيرة خمسمائة عام{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البغوي ٨/٤١٠.أخرجه ابن جرير ٢٤/٣٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.
  88,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٧٥<span class="dash">-</span></span> عن جابر، قال: قرأ رسول الله ﷺ: <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِم بِمُصَيْطِرٍ﴾</span> بالصاد{1}. (١٥/٣٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٧٦<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «<b>أُمرتُ أنْ أقاتل الناس حتى يقولوا: لا إله إلا الله. فإذا قالوها عصموا مِنِّي دماءهم وأموالهم إلا بحقِّها، وحسابهم على الله</b>». ثم قرأ: <span class="qpc-hafs">﴿فَذَكِّرْ إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>{2}. (١٥/٣٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، يقول: بجبّار، فاعفُ عنهم واصفح{3}. (١٥/٣٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، قال: جبّار{4}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٧٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿بِمُصَيْطِرٍ﴾</span>، قال: بمُسلَّط{5}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، قال: بقاهر{6}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، قال: كِلْ عبادي إلَيَّ{7}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَذَكِّرْ﴾</span> أهل مكة، يا محمد <span class="qpc-hafs">﴿إنَّما أنْتَ مُذَكِّرٌ﴾</span> كالذين من قبلك، <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span> يقول: لستَ عليهم بملِك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، قال: لستَ عليهم بمُسلَّط أن تُكرههم على الإيمان{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، قال: نسَخ ذلك، فقال: <span class="qpc-hafs">﴿اقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾</span> [التوبة:٥]{10}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، يقول: لستَ عليهم بملِك، ثم نَسَخَتْها آيةُ السيف في براءة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، قال: لستَ عليهم بمُسلَّط أن تُكرههم على الإيمان. قال: ثم جاء بعد هذا: <span class="qpc-hafs">﴿جاهِدِ الكُفّارَ والمُنافِقِينَ واغْلُظْ عَلَيْهِمْ﴾</span> [التوبة:٧٣، والتحريم:٩]، وقال: <span class="qpc-hafs">﴿واقْعُدُوا لَهُمْ كُلَّ مَرْصَدٍ﴾</span> وارصدوهم لا يخرجوا في البلاد، <span class="qpc-hafs">﴿فَإنْ تابُوا وأَقامُوا الصَّلاةَ وآتَوُا الزَّكاةَ فَخَلُّوا سَبِيلَهُمْ إنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾</span> [التوبة:٥]. قال: فنَسَخَتْ <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>. قال: جاء اقتله أو يُسلِم. قال: والتذكرة كما هي لم تُنسخ. وقرأ: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> [الذاريات:٥٥]{9}<span class=comment-ref>٧١٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٩</span> ذكر <u>ابنُ عطية</u> (٨/٦٠٢) اختلاف المفسرين في قوله تعالى: <span class="qpc-hafs">﴿إلا مَن تَوَلّى وكَفَرَ﴾</span> على قولين: <b>الأول:</b> «أنّ الاستثناء متصل، والمعنى: إلا مَن تولى وكفر فأنت مُسيطِرٌ عليه». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فالآية -على هذا- لا نسخ فيها». <b>الثاني:</b> «أن الاستثناء منفصل، والمعنى: <span class="qpc-hafs">﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</span>، وتمَّ الكلام، وهي آية موادعة منسوخة بالسيف، ثم قال تعالى: <span class="qpc-hafs">﴿إلّا مَن تَوَلّى وكَفَرَ * فَيُعَذِّبُهُ﴾</span>». ثم <span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى أحوال النزول</span>، فقال: «وهذا هو القول الصحيح؛ لأن السورة مكّيّة، والقتال إنما نزل بالمدينة».</div></p></div>",footnotes:1:أخرجه الحاكم ٢/٢٧٩ (٣٠٠٧).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم».</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا هشامًا فإنه قرأ: ‹بِمُسَيْطِرٍ› بالسين، وما عدا قنبلًا وابن ذكوان وحفصًا وخلادًا الأربعة كلهم في رواية. انظر: النشر ٢/٣٧٨، والإتحاف ص٥٨٢.أخرجه مسلم ١/٥٢ (٢١)، وابن جرير ٢٤/٣٤٢.أخرجه ابن جرير ٢٤/٣٤١، وابن أبي حاتم -كما في الإتقان ٢/٥٥-. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.تفسير مجاهد ص٥٠١، وأخرجه ابن جرير ٢٤/٣٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٤١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٧٩-٦٨٠.أخرجه ابن جرير ٢٤/٣٤١.عزاه السيوطي إلى أبي داود في ناسخه. وينظر: نواسخ القرآن لابن الجوزي ص٥٠٧.تفسير مقاتل بن سليمان ٤/٦٧٩-٦٨٠.أخرجه ابن جرير ٢٤/٣٤١.
  88,22,""
  88,21,""
  88,22,""
  88,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ۝٢٣ فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٨٧<span class="dash">-</span></span> في قراءة <span class="name-1">عبد الله بن مسعود</span>: (فَإنَّهُ يُعَذِّبُهُ اللهُ العَذابَ الأَكْبَرَ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ۝٢٣ فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إلّا مَن تَوَلّى وكَفَرَ﴾</span>، قال: حسابه على الله{2}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا مَن تَوَلّى﴾</span> يعني: أعرَض، <span class="qpc-hafs">﴿وكَفَرَ﴾</span> بالإيمان، <span class="qpc-hafs">﴿فَيُعَذِّبُهُ اللَّهُ﴾</span> في الآخرة <span class="qpc-hafs">﴿العَذابَ الأَكْبَرَ﴾</span> وإنما سمّاه الله الأكبر لأنّ الله كان أوعدهم القتل والجوع في الدنيا، فقال الأكبر؛ لأنه أكبر من الجوع والقتل، وهو عذاب جهنم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٨.</p><p>وهي قراءة شاذة. انظر: المحرر الوجيز ٥/٤٧٥، والجامع لأحكام القرآن ٢٢/٢٥٤.تفسير مجاهد ص٥٠١، وأخرجه ابن جرير ٢٤/٣٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٨٠.
  88,24,""
  88,24,""
  88,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ إِلَیۡنَاۤ إِیَابَهُمۡ ۝٢٥ ثُمَّ إِنَّ عَلَیۡنَا حِسَابَهُم ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج، عن عطاء الخُراسانيّ- في قوله: <span class="qpc-hafs">﴿إنَّ إلَيْنا إيابَهُمْ﴾</span>، قال: مرجعهم{1}. (١٥/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، مثله{2}. (١٥/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿إنَّ إلَيْنا إيابَهُمْ﴾</span>. قال: الإياب: المرجع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت عَبيد بن الأَبْرص يقول:</p><p>وكلّ ذي غَيْبة يؤوب وغائب الموت لا يؤوب</p><p>وقال الآخر:</p><p>فأَلقتْ عصاها واستقرّ بها النَّوى كما قرّ عَينًا بالإياب المسافر{3}. (١٥/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّ إلَيْنا إيابَهُمْ ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾</span>، قال: إلى الله الإياب، وعلى الله الحساب{4}. (١٥/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿إنَّ إلَيْنا إيابَهُمْ﴾</span>، قال: مُنقَلَبهم{5}. (١٥/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾</span>، يعني: جزاءهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ إلَيْنا إيابَهُمْ﴾</span> يعني: مصيرهم، <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾</span> يعني: جزاءهم على الله هَيِّن{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن المنذر -كما في فتح الباري ٨/٧٠١-.عزاه السيوطي إلى ابن أبي حاتم. وينظر: فتح الباري ٨/٧٠١.أخرجه الطستي -كما في الإتقان ٢/٩٠-.أخرجه ابن جرير ٢٤/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٥-.تفسير مقاتل بن سليمان ٤/٦٨٠.
  88,26,""
