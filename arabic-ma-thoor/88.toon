quran[26]{c,v,t}:
  88,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٢٧٦١<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الغاشية بمكة{1}. (١٥/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٢<span class="dash">-</span></span> عن عبد الله بن الزُّبير، مثله{2}. (١٥/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمُسمّى: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span>، وأنها نزلت بعد سورة الذاريات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٤<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٥<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٦<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٧<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد <span class="qpc-hafs">﴿والذّارِيات﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٨<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٦٩<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الغاشية مكّيّة، عددها ست وعشرون آية{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هَلۡ أَتَىٰكَ حَدِیثُ ٱلۡغَـٰشِیَةِ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٧٧٠<span class="dash">-</span></span> عن عمرو بن ميمون، قال: مَرَّ النبيُّ ﷺ على امرأة تقرأ: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span>، فقام يستمع، ويقول: «<b>نعم، قد جاءني</b>»{9}. (١٥/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الغاشية مِن أسماء يوم القيامة، عظّمه الله، وحذّره عباده{10}. (١٥/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span>، قال: الساعة{11}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أشعث- قال: الغاشية: غاشية النار{12}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، قال: الغاشية: القيامة{13}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿الغاشِيَةِ﴾</span> يعني: القيامة، تغشى الناسَ بعذابها وعقابها{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span>، قال: حديث الساعة{15}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span> يعني: قد أتاك حديث أهل النار، وكلّ شيء في القرآن <span class="qpc-hafs">﴿هَلْ أتاكَ﴾</span>: قد أتاك{16}<span class=comment-ref>٧١٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٣٩</span> اختُلف في معنى: <span class="qpc-hafs">﴿الغاشية﴾</span> في هذه الآية على قولين: <b>الأول:</b> أنها القيامة تغشى الناس بالأهوال. <b>الثاني:</b> أنها النار تغشى وجوه الكفرة.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٥٩٦) على القول الأول بقوله: «يؤيده قوله تعالى: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</span>، والوجوه الخاشعة هي وجوه الكفار، وخشوعها: ذُلُّها وتغيُّرُها بالعذاب». و<span class="comment-type-4">علَّق</span> على القول الثاني بقوله: «وقد قال تعالى: <span class="qpc-hafs">﴿وتَغْشى وُجُوهَهُمُ النّارُ﴾</span> [إبراهيم:٥٠]، وقال: <span class="qpc-hafs">﴿ومِن فَوْقِهِمْ غَواشٍ﴾</span> [الأعراف:٤١]، فهي تغشى سكانها».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٣٢٧) <span class="mustanad">العموم</span>، فقال: «إن الله قال لنبيّه: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span>، ولم يُخْبِرنا أنه عَنى غاشية القيامة، ولا أنه عَنى غاشية النار، وكلتاهما غاشيةٌ، هذه تغشى الناس بالبلابل والأهوال والكروب، وهذه تغشى الكفار باللفْح في الوجوه والشُّواظ والنُّحاس، فلا قول أصحُّ في ذلك مِن أن يقال كما قال -جلَّ ثناؤه-، ويُعَمَّ الخبرُ بذلك كما عمَّه».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٦٧٥.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٠٦- مرسلًا.أخرجه ابن جرير ٢٤/٣٢٦، وابن أبي حاتم مختصرًا -كما في الإتقان ٢/٥٥، وفتح الباري ٨/٧٠٠-.أخرجه ابن جرير ٢٤/٣٢٦.أخرجه ابن جرير ٢٤/٣٢٧. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٣-.أخرجه ابن جرير ٢٤/٣٢٦. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٧.
  88,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وُجُوهࣱ یَوۡمَىِٕذٍ خَـٰشِعَةٌ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٧٧٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ﴾</span>، قال: يعني: في الآخرة{1}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</span>، قال: خاشعة في النار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</span>، قال: ذليلة في النار{3}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</span>، يعني: ذليلة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨، وابن جرير ٢٤/٣٢٨.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم. وعند ابن جرير ٢٤/٣٢٨ من طريق سعيد بلفظ: ذليلة.تفسير مقاتل بن سليمان ٤/٦٧٧.
  88,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَامِلَةࣱ نَّاصِبَةࣱ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٧٨٢<span class="dash">-</span></span> عن أبي عمران الجَونيّ، قال: مَرَّ <span class="name-1">عمر بن الخطاب</span> براهبٍ، فوقف، ونودي الراهب، فقيل له: هذا أمير المؤمنين. فاطّلع، فإذا إنسان به مِن الضر والاجتهاد وتَرْك الدنيا، فلمّا رآه عمر بكى، فقيل له: إنه نصراني! فقال عمر: قد علمتُ، ولكني رحِمتُه؛ ذكرتُ قول الله: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ تَصْلى نارًا حامِيَةً﴾</span>، فرحمتُ نَصَبه واجتهاده، وهو في النار{1}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</span>، قال: يعني: اليهود والنصارى، تخشع ولا ينفعها عملُها{2}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: النصارى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الضحى- <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: الرُّهبان{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</span>، قال: تعمل وتَنصَب في النار{5}<span class=comment-ref>٧١٤٠</span>. (١٥/٣٨١)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٠</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٣٢٨) في معنى: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span> سوى قول ابن عباس من طريق العَوفيّ، وقول الحسن، وقتادة، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٨<span class="dash">-</span></span> و<span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</span> هم الرُّهبان، وأصحاب الصوامع{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٨٩<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</span> يُكلّفون ارتقاء جبل مِن حديد في النار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: عاملة في الدنيا بالمعاصي، تَنصَب في النار يوم القيامة{8}<span class=comment-ref>٧١٤١</span>. (١٥/٣٨٢)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤١</span> اختُلف في معنى: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span> على أقوال: <b>الأول:</b> عاملة في النار ناصبة فيها. <b>الثاني:</b> عاملة في الدنيا ناصبة فيها، والآية في القِسِّيسين، وعباد الأوثان، وكلّ مَن اجتهد في كُفر. <b>الثالث:</b> عاملة في الدنيا ناصبة يوم القيامة.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٥٩٦) القول الثالث بقوله: «فالعمل -على هذا- هو مساعي الدنيا».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٧/٥) -<span class="mustanad">مستندًا إلى اللغة، والدلالة العقلية، والنظائر</span>- القول الأول، فقال: «هذا هو الحق لوجوه: <b>أحدها</b>: أنه على هذا التقدير يتعلق الظرف بما يليه، أي: وجوه يوم الغاشية خاشعة عاملة ناصبة صالية، وعلى الأولى لا يتعلق إلا بقوله: <span class="qpc-hafs">﴿تصلى﴾</span>، ويكون قوله: <span class="qpc-hafs">﴿خاشعة﴾</span> صفة للوجوه، قد فصل بين الصفة والموصوف بأجنبي متعلّق بصفة أخرى متأخرة، والتقدير: وجوه خاشعة عاملة ناصبة يومئذٍ تصلى نارًا حامية، والتقديم والتأخير على خلاف الأصل؛ فالأصل إقرار الكلام على نظْمه وترتيبه لا تغيير ترتيبه، ثم إنما يجوز فيه التقديم والتأخير مع القرينة، أما مع اللبس فلا يجوز؛ لأنه يلتبس على المخاطب، ومعلوم أنه ليس هنا قرينة تدل على التقديم والتأخير، بل القرينة تدل على خلاف ذلك، فإرادة التقديم والتأخير بمثل هذا الخطاب خلاف البيان، وأمْر المخاطب بفهمه تكليف لما لا يطاق. <b>الوجه الثاني</b>: أنّ الله قد ذكر وجوه الأشقياء ووجوه السعداء في السورة، فقال بعد ذلك: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ ناعِمَةٌ لِسَعْيِها راضِيَةٌ فِي جَنَّةٍ عالِيَةٍ﴾</span>، ومعلوم أنه إنما وصفها بالنعمة يوم القيامة لا في الدنيا؛ إذ هذا ليس بمدح، فالواجب تشابه الكلام وتناظر القسمين، لا اختلافهما، وحينئذ فيكون الأشقياء وُصفتْ وجوههم بحالها في الآخرة. <b>الثالث</b>: أنّ نظير هذا التقسيم قوله: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ ناضِرَةٌ إلى رَبِّها ناظِرَةٌ ووُجُوهٌ يَوْمَئِذٍ باسِرَةٌ تَظُنُّ أنْ يُفْعَلَ بِها فاقِرَةٌ﴾</span> [القيامة:٢٢-٢٥]، وقوله: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ ضاحِكَةٌ مُسْتَبْشِرَةٌ ووُجُوهٌ يَوْمَئِذٍ عَلَيْها غَبَرَةٌ تَرْهَقُها قَتَرَةٌ أُولَئِكَ هُمُ الكَفَرَةُ الفَجَرَةُ﴾</span> [عبس:٣٨-٤٢]، وهذا كله وصفٌ للوجوه لحالها في الآخرة لا في الدنيا. <b>الرابع</b>: أنّ وصف الوجوه بالأعمال ليس في القرآن، وإنما في القرآن ذِكْر العلامة، كقوله: <span class="qpc-hafs">﴿سِيمِاهُمْ فِي وُجُوهِهِمْ﴾</span> [الفتح:٢٩]، وقوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لأَرَيْناكَهُمْ فَلَعَرَفْتَهُمْ بِسِيماهُمْ﴾</span> [محمد:٣٠]، وقوله: <span class="qpc-hafs">﴿وإذا تُتْلى عَلَيْهِمْ آياتُنا بَيِّناتٍ تَعْرِفُ فِي وُجُوهِ الَّذِينَ كَفَرُوا المُنْكَرَ يَكادُونَ يَسْطُونَ بِالَّذِينَ يَتْلُونَ عَلَيْهِمْ آياتِنا﴾</span> [الحج:٧٢]، وذلك لأنّ العمل والنَّصَب ليس قائمًا بالوجوه فقط؛ بخلاف السيما والعلامة. <b>الخامس</b>: أنّ قوله: <span class="qpc-hafs">﴿خاشِعَةً عامِلَةٌ ناصِبَةٌ﴾</span> لو جُعل صفة لهم في الدنيا لم يكن في هذا اللفظ ذم، فإنّ هذا إلى المدح أقرب، وغايته أنه وصفٌ مشترك بين عُبّاد المؤمنين وعُبّاد الكفار، والذم لا يكون بالوصف المشترك، ولو أُريد المختص لقيل: خاشعة للأوثان -مثلًا-، عاملة لغير الله، ناصبة في طاعة الشيطان. وليس في الكلام ما يقتضي كون هذا الوصف مختصًّا بالكفار، ولا كونه مذمومًا، وليس في القرآن ذمٌّ لهذا الوصف مطلقًا، ولا وعيد عليه، فحمْله على هذا المعنى خروج عن الخطاب المعروف في القرآن. <b>السادس</b>: أنّ هذا الوصف مختص ببعض الكفار، ولا موجب للتخصيص، فإنّ الذين لا يتعبّدون من الكفار أكثر، وعقوبة فُسّاقهم في دينهم أشد في الدنيا والآخرة، فإنّ مَن كفَّ منهم عن المحرمات المتفق عليها، وأدّى الواجبات المتفق عليها لم تكن عقوبته كعقوبة الذين يدعون مع الله إلهًا آخر، ويقتلون النفس التي حرّم الله إلا بالحق ويَزْنُون. فإذا كان الكفر والعذاب على هذا التقدير في القسم المتروك أكثر وأكبر؛ كان هذا التخصيص عكس الواجب. <b>السابع</b>: أنّ هذا الخطاب فيه تنفير عن العبادة والنُّسك ابتداء، ثم إذا قُيِّد ذلك بعبادة الكفار والمبتدعة -وليس في الخطاب تقييد- كان هذا سعيًا في إصلاح الخطاب بما لم يُذكر فيه».</div></p><p><div></p><p><p><span class="item-no">٨٢٧٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- أنه قرأ: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: لم تعمل لله في الدنيا، فأعْملها في النار{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله تعالى: <span class="qpc-hafs">﴿وجوه يومئذ خاشعة عاملة ناصبة﴾</span>، قال: لم تخشع لله في الدنيا فأخْشعها وأنصبها في النار، فذلك عمَلها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: تكبّرتْ في الدنيا عن طاعة الله، فأعْملها وأنصبها في النار{11}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: عاملة ناصبة في النار{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</span> يُجَرُّون على وجوههم في النار{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span> يعني: عاملة في النار، النار تأكله ويأكل مِن النار، يعني: ناصبة للعذاب صاغِرة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span>، قال: لا أحد أنصب ولا أشدّ مِن أهل النار{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٦٨، والحاكم ٢/٥٢١-٥٢٢. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم. وعزاه الحافظ في الفتح ٨/٧٠٠ إليه من طريق عكرمة دون ذكر آخره.علقه البخاري في صحيحه ٦/١٦٨. وذكر الحافظ ابن حجر في الفتح ٨/٧٠٠ أنّ ابن أبي حاتم وصله من طريق علي بن أبي طلحة.أخرجه الثعلبي -كما في الفتح ٨/٧٠٠-.أخرجه ابن جرير ٢٤/٣٢٨.تفسير الثعلبي ١٠/١٨٨.تفسير الثعلبي ١٠/١٨٧، وتفسير البغوي ٨/٤٠٨.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٢٨، وابن أبي الدنيا في صفة النار ٦/٤٢٧-٤٢٨ (١٢٩) من طريق يونس.أخرجه أبو الشيخ في طبقات المحدثين بأصبهان ٢/٢٠٤.أخرجه ابن جرير ٢٤/٣٢٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٩، وابن جرير ٢٤/٣٢٨.تفسير الثعلبي ١٠/١٨٧، وتفسير البغوي ٨/٤٠٤.تفسير مقاتل بن سليمان ٤/٦٧٧.أخرجه ابن جرير ٢٤/٣٢٩.
  88,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَصۡلَىٰ نَارًا حَامِیَةࣰ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٧٩٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: <span class="qpc-hafs">﴿تَصْلى نارًا حامِيَةً﴾</span> تخوض في النار كما تخوض الإبل في الوَحْل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٧٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿تَصْلى نارًا حامِيَةً﴾</span>، قال: حارّة{2}. (١٥/٣٨٢)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/١٨٨، وتفسير البغوي ٨/٤٠٤.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.
  88,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تُسۡقَىٰ مِنۡ عَیۡنٍ ءَانِیَةࣲ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: هي التي قد طال أنْيُها{1}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: قد أنى غليانها{2}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: انتهى حرُّها{3}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: قد بلغتْ إناها، وحان شُربها{4}. (١٥/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: قد أنى حرّها{5}. (١٥/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: قد آن طبخُها منذ خلق الله السماوات والأرض{6}. (١٥/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: أنى طبخها منذ خلق الله السماوات والأرض{7}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿مِن عَيْنٍ آنِيَةٍ﴾</span>، قال: انتهى حرُّها، فليس فوقه حرّ{2}. (١٥/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</span> مِن عينٍ قد انتهى حرُّها، وذلك أنّ جهنم تُسَعَّر عليهم منذ يوم خُلقتْ إلى يوم يدخلونها، وهي عينٌ تخرج مِن أصل جبل طولها مسيرة سبعين عامًا، ماؤها أسود كدرديّ الزيت، كدرٌ غليظ، كثير الدعاميص{9}، تسقيه الملائكة بإناء مِن حديد مِن نار، فيشربه، فإذا قرّب الإناء مِن فِيه أحرق شدقيه، وتناثرتْ أنيابُه وأضراسُه، فإذا بلغ صدره نضج قلبه، فإذا بلغ بطنه غلى كما يغلي الحميم مِن شدة الحرّ حتى يذوب كما يذوب الرصاص إذا أصابه النار، فيدعو الشقيُّ بالويل{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿آنِيَةٍ﴾</span>، قال: حاضرة{11}<span class=comment-ref>٧١٤٢</span>. (١٥/٣٨٣)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٥٩٧) على قول ابن زيد بقوله: «من قولهم: أنى الشيءُ: إذا حضر».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٢٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٥٠٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٥، وفتح الباري ٨/٧٠٠-، وهناد (٢٦٥)، وابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨، وابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٢٤- من طريق المبارك، وابن جرير ٢٤/٣٢٩-٣٣٠، وابن أبي الدنيا في صفة النار ٦/٤٢٧-٤٢٨ (١٢٩) من طريق يونس. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.الدعاميص: جمع دعموص، وهي دويبة تكون في مستنقع الماء. النهاية (دعمص).تفسير مقاتل بن سليمان ٤/٦٧٧-٦٧٨.أخرجه ابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى ابن أبي حاتم.
  88,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّیۡسَ لَهُمۡ طَعَامٌ إِلَّا مِن ضَرِیعࣲ ۝٦ لَّا یُسۡمِنُ وَلَا یُغۡنِی مِن جُوعࣲ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨١٠<span class="dash">-</span></span> عن أبي الدّرداء، قال: قال رسول الله ﷺ: «<b>يُلقى على أهل النار الجوعُ، حتى يعدل ما هم فيه مِن العذاب، فيستغيثون بالطعام، فيُغاثون بطعام مِن ضريع، لا يُسمن ولا يُغني مِن جوع</b>»{1}. (١٥/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١١<span class="dash">-</span></span> عن عبد الله بن عباس، <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: قال رسول الله ﷺ: «<b>شيء يكون في النار شبه الشوك، أمرّ مِن الصبر، وأنتن مِن الجِيفة، وأشدّ حرًّا مِن النار، سمّاه الله: الضريع، إذا طعمه صاحبه لا يدخل البطن، ولا يرتفع إلى الفم، فيبقى بين ذلك، ولا يُغني من جوع</b>»{2}. (١٥/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٢<span class="dash">-</span></span> قال <span class="name-1">أبو الدّرداء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٣<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>: إنّ الله تعالى يُرسل على أهل النار الجوع، حتى يعدل عندهم ما هم فيه من العذاب، فيستغيثون، فيُغاثون مِن الضّريع، ثم يستغيثون، فيُغاثون بطعام ذا غُصّة، فيذكرون أنهم كانوا يجيزون الغصص في الدنيا بالماء، فيستسقون، فيُعطشهم ألف سنة، ثم يُسقون من عين آنية، شَربةً لا هنيئة ولا مريئة، فإذا أدنوه من وجوههم سلخ جلود وجوههم وشواها، فإذا وصل إلى بطونهم قطعها، فذلك قوله عز جل: <span class="qpc-hafs">﴿وسُقُوا ماءً حَمِيمًا فَقَطَّعَ أمْعاءَهُمْ﴾</span> [محمد:١٥]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: الشِّبرِق{4}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، يقول: مِن شجر مِن نار{5}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: الشِّبرِق اليابس{6}. (١٥/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>: هو شيء يطرحه البحر المالح، يُسمِّيه أهل اليمن: الضريع{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٨<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق عمرو بن مالك- قال: الضريع: السُّلّاء، وهو الشوك، وكيف يَسمَن مَن كان طعامه الشوك؟!{8}. (١٥/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨١٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- <span class="qpc-hafs">﴿إلّا مِن ضَرِيعٍ﴾</span>، قال: مِن حجارة{9}. (١٥/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿إلّا مِن ضَرِيعٍ﴾</span>، قال: الزّقوم{10}<span class=comment-ref>٧١٤٣</span>. (١٥/٣٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٣</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٥٩٧) قول سعيد بن جُبَير بقوله: «لأنّ الله تعالى قد أخبر في هذه الآية أنّ الكفار لا طعام لهم إلا مِن ضَرِيعٍ، وقد أخبر أنّ الزّقوم طعام الأثيم، فذلك يقتضي أنّ الضّريع: الزّقوم».</div></p><p><div></p><p><p><span class="item-no">٨٢٨٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إلّا مِن ضَرِيعٍ﴾</span>، قال: الشِّبرِق اليابس{11}. (١٥/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عبد الرحمن الأصبهاني- في قوله: <span class="qpc-hafs">﴿إلّا مِن ضَرِيعٍ﴾</span>، قال: الشِّبرِق{12}. (١٥/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق رجل من عبد القيس- قال: الضّريع: الشِّبرِق؛ شجرة ذات شوك لاطئة بالأرض، فإذا كان الربيع سمّتها قريش: الشِّبرِق، فإذا هاج العود سمّتها: الضّريع{13}. (١٥/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: الضّريع بلغة قريش في الربيع: الشِّبرِق، وفي الصيف: الضّريع{14}. (١٥/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: هو الشِّبرِق، إذا يبس يُسمّى: الضّريع{15}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: مِن شرّ الطعام، وأبشعه، وأخبثه{16}. (١٥/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿طعام إلا من ضريع﴾</span>، قال: شجرة يقال لها: الشِّبرِق{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span> نبْتٌ يَنبت في الربيع، فإذا كان في الصيف يبس؛ فاسمه إذا كان عليه ورقه: شِبرِق، وإذا تساقط ورقه فهو: الضّريع، فالإبل تأكله أخضر، فإذا يبس لم تذقه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span> وهي شجرة تكون بمكة كثيرة الشوك، لا تَقربها دابة في الأرض مِن شوكها، ولا يستطيع أحد أن يمسّها مِن كثرة شوكها، وتُسمّيها قريش وهي رطبة في الربيع: الشِّبرِق، وتصيب الإبل من ورقها في الربيع ما دامت رطبة، فإذا يبستْ لم تَقربها الإبل، وما من دابة في الأرض من الهوام والسباع وما يؤذي بني آدم إلا مثلها في النار، سلّطها الله ﷿ على أهلها، لكنها مِن نار، وما خلق الله شيئًا في النار إلا من النار، <span class="qpc-hafs">﴿لا يُسْمِنُ ولا يُغْنِي مِن جُوعٍ﴾</span> فإنهم لا يطعمون مِن أجل الجوع، وإنما من أجل العذاب{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٣٠<span class="dash">-</span></span> عن <span class="name-3">شريك بن عبد الله</span> -من طريق محمد بن عبيد- في قوله: <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: الشِّبرِق{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٣١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</span>، قال: الضّريع: الشوك من النار. قال: وأما في الدنيا فإنّ الضّريع: الشوك اليابس الذي ليس له ورق، تدعوه العرب: الضّريع، وهو في الآخرة شوك من نار{21}<span class=comment-ref>٧١٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٤</span> زاد <u>ابنُ عطية</u> (٨/٥٩٨-٥٩٩) في معنى الآية <b>أقوالًا أخرى</b>، و<span class="comment-type-4">علَّق</span> على بعضها، فقال: «وقيل: الضريع: العِشْرِقُ. <span class="mustanad">وقال النبي</span> ﷺ: «<b>الضريع شوك في النار</b>». وقال بعض اللغويين: الضريع يَبِسُ العَرْفَج إذا تحطّم. وقال آخرون: هو رَطْبُ العَرْفج. وقال الزَّجّاج: هو نَبْتٌ كالعَوْسج. وقال بعض المفسرين: الضّريع نبتٌ في البحر أخضر منتن مُجَوَّف مستطيل له نَوْر فيه كبير ... وكلّ مَن ذَكر شيئًا مما قدمناه فإنما يعني أنّ ذلك من نار ولا بُدّ، وكلّ ما في النار فهو نار. وقال قوم: ضَرِيع وادٍ في جهنم. وقال جماعة من المتأولين: الضّريعُ طعام أهل النار. ولم يُرِد أن يخصص شيئًا مما ذُكِر، قال بعض اللغويين: وهذا مما لا تعرفه العرب. وقيل: الضّريع: الجلدة التي على العظم تحت اللحم». ثم <span class="comment-type-4">علَّق</span> بقوله: «ولا أعرف مَن تأوَّل الآية بهذا، وأهل هذه الأقاويل يقولون: الزّقوم لطائفة، والضّريع لطائفة، والغِسْلين لطائفة».</div></p></div>",footnotes:1:أخرجه الترمذي ٤/٥٤١-٥٤٣ (٢٧٦٨) مطولًا، وابن جرير ١٧/١٢٣-١٢٤، والثعلبي ٨/٣٤٥.</p><p>قال الترمذي: «قال عبد الله بن عبد الرحمن -يعني الدارمي-: والناس لا يرفعون هذا الحديث، إنما روي هذا الحديث عن الأعمش، عن شِمْر بن عطية، عن شَهْر بن حَوْشَب، عن أُمّ الدّرداء، عن أبي الدّرداء قولَه، وليس بمرفوع، وقطبة بن عبد العزيز هو ثقة عند أهل الحديث». وذكر الدارقطني في العلل ٦/٢٢٠ (١٠٨٦) الاختلاف في أسانيده، بين إرساله وإسناده، وبين رفعه ووقفه، وأنّ وقفه مسندًا موقوفًا أصح من غيره.أخرجه الواحدي في التفسير الوسيط ٤/٤٧٤ (١٣٣٧) مختصرًا. وأورده الديلمي في الفردوس ٢/٤٣٤ (٣٩٠٥) واللفظ له، والثعلبي ١٠/١٨٨. وعزاه السيوطي إلى ابن مردويه.</p><p>قال ابن كثير في البداية والنهاية ٢٠/١٥٧: «وهذا حديث غريب جدًّا». وقال السيوطي: «بسند واهٍ».تفسير الثعلبي ١٠/١٨٨، وتفسير البغوي ٨/٤٠٨.أخرجه ابن جرير ٢٤/٣٣١. والشِّبرِق: نبت حجازي يؤكل وله شوك، وإذا يبس سُمّي الضريع. النهاية (شبرق).أخرجه ابن جرير ٢٤/٣٣٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٨٨.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي مصنف ابن أبي شيبة في (ت: محمد عوامة) ١٩/٤٨٨-٤٨٩ (٣٦٨٠٧) بلفظ: «السلم»، وهو كذلك في بعض نسخ الدر المنثور. والسَّلَم نوع من العضاه وهو كلّ شجر له شوك. أما السُّلّاء: فشوك النخل، واحدتها سلاءة. اللسان (سلأ، سلم، عضه).أخرجه ابن جرير ٢٤/٣٣٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مجاهد ص٥٠٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٥، وفتح الباري ٨/٧٠٠-، وهناد (٢٦٥)، وابن جرير ٢٤/٣٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨ مختصرًا، وابن جرير ٢٤/٣٣٢.أخرجه ابن جرير ٢٤/٣٣٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم بلفظ: الشّبرِق، شر الطعام وأبشعه وأخبثه.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٣-.تفسير مقاتل بن سليمان ٤/٦٧٨.أخرجه ابن جرير ٢٤/٣٣٢.أخرجه ابن جرير ٢٤/٣٣٣.
