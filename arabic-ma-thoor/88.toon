  88,6,""
  88,7,""
  88,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٣٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> أنه قرأ في سورة الغاشية: (مُتَّكِئِينَ فِيها ناعِمِينَ فِيها){1}. (١٥/٣٨٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ ناعِمَةٌ﴾</span> يعني: فَرِحة، شبّه الله ﷿ وجوههم بوجوه قوم فَرِحين؛ إذا أصابوا الشراب طابتْ أنفسهم، فاجتمع الدم في وجوههم، فاجتمع فرح القلوب وفرح الشراب، فهو ضاحك الوجه، مبتسم طيّب النفس{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة.تفسير مقاتل بن سليمان ٤/٦٧٨.
  88,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّسَعۡیِهَا رَاضِیَةࣱ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِسَعْيِها راضِيَةٌ﴾</span>، يعني: قد رضي الله عمله، فأثابه الله ﷿ ذلك بعمله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٣٥<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، في قوله: <span class="qpc-hafs">﴿لِسَعْيِها راضِيَةٌ﴾</span>، قال: رَضِيَتْ عملها{2}. (١٥/٣٨٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٧٨.عزاه السيوطي إلى ابن أبي حاتم.
  88,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِی جَنَّةٍ عَالِیَةࣲ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي جَنَّةٍ عالِيَةٍ﴾</span> وإنما سمّاها عالية لأن جهنم أسفل منها، وهي دركات، والجنة درجات{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٧٨.
  88,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا تَسۡمَعُ فِیهَا لَـٰغِیَةࣰ ۝١١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٣٧<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها﴾</span> بالتاء ونصب التاء، <span class="qpc-hafs">﴿لاغِيَةً﴾</span> منصوبة منونة{1}<span class=comment-ref>٧١٤٥</span>. (١٥/٣٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٥</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span> على ثلاث قراءات: <b>الأولى:</b> <span class="qpc-hafs">﴿لا تَسْمَعُ﴾</span> بفتح التاء، بمعنى: لا تسمع الوجوه. <b>الثانية:</b> ‹لا تُسْمَعُ› بضم التاء، بمعنى: ما لم يُسمّ فاعله. <b>الثالثة:</b> ‹لا يُسْمَعُ› بالضم أيضًا غير أنها بالياء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٣٣٦) «أن كل ذلك قراءاتٌ <span class="mustanad">معروفاتٌ صحيحات المعاني</span>، فبأيِّ ذلك قرأ القارئ فمصيبٌ».</div></p><p><h3><span class="qpc-hafs">﴿لَّا تَسۡمَعُ فِیهَا لَـٰغِیَةࣰ ۝١١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span>، يقول: لا تَسمع أذًى ولا باطلًا{2}. (١٥/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span>، قال: شتمًا{3}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span>، قال: لا تَسمع فيها باطلًا، ولا مَأْثَمًا{4}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤١<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span>، <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span>، قال: مُؤْذِيَة{5}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span>، يقول: لا يسمع بعضهم من بعض غيبة، ولا كذب، ولا شتم{6}<span class=comment-ref>٧١٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٦</span> ذكر <u>ابنُ جرير</u> (٢٤/٣٣٤) عن بعض نحويي الكوفة أنّ معنى الآية: «لا تسمع فيها حالفةٌ على الكذب، ولذلك قيل: لاغية». ثم <span class="comment-type-2">انتقده</span> -<span class="mustanad">مستندًا إلى أقوال السلف</span>- قائلًا: «ولهذا الذي قاله مذهبٌ ووجْهٌ، لولا أنّ أهل التأويل من الصحابة والتابعين على خلافه، وغير جائزٍ لأحدٍ خلافهم فيما كانوا عليه مُجْمِعين».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا ابن كثير، وأبا عمرو، ورويسًا؛ فإنهم قرؤوا: ‹لا يُسْمَعُ فِيها لاغِيَةٌ› بالياء، ورفع <span class="qpc-hafs">﴿لاغِيَةٌ﴾</span>، وما عدا نافعًا فإنه قرأ: ‹لا تُسْمَعُ فِيها لاغِيَةٌ› بالتاء ورفع <span class="qpc-hafs">﴿لاغِيَةٌ﴾</span>. انظر: النشر ٢/٤٠٠، والإتحاف ص٥٨١.أخرجه ابن جرير ٢٤/٣٣٤.تفسير مجاهد ص٥٠١، وأخرجه ابن جرير ٢٤/٣٣٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٦٨، وابن جرير ٢٤/٣٣٥، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٧٨-٦٧٩.
  88,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهَا عَیۡنࣱ جَارِیَةࣱ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيها عَيْنٌ جارِيَةٌ﴾</span> يعني: في الجنة؛ لأنها فيها تجري الأنهار{1}<span class=comment-ref>٧١٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٧</span> ذكر <u>ابنُ عطية</u> (٨/٦٠٠) في معنى: <span class="qpc-hafs">﴿عَيْنٌ﴾</span> قوله: «<span class="qpc-hafs">﴿عَيْنٌ﴾</span> في هذه الآية اسم جنس، <b>ويحتمل</b> أن تكون عينًا مخصوصة ذُكرت على جهة التشريف لها».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٧٩.
  88,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهَا سُرُرࣱ مَّرۡفُوعَةࣱ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</span>، قال: بعضها فوق بعض{1}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</span> ألواحها مِن ذهب، مُكلّلة بالزَّبَرْجد والدُّرّ والياقوت، مرتفعة ما لم يجئ أهلها، فإذا أراد أن يجلس عليها تواضعتْ له حتى يجلس عليها، ثم ترتفع إلى مواضعها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</span> منسوجة بقضبان الدُّرّ والذَّهب، عليها سبعون فراشًا، كلّ فراش قدر غرفة مِن غرف الدنيا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</span>، قال: مرتفعة{4}. (١٥/٣٨٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٣٦.تفسير البغوي ٨/٤٠٩.تفسير مقاتل بن سليمان ٤/٦٧٩.عزاه السيوطي إلى ابن المنذر.
  88,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَكۡوَابࣱ مَّوۡضُوعَةࣱ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٤٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿وأكواب﴾</span>، قال: الأكواب: الأقساط{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَكْوابٌ مَوْضُوعَةٌ﴾</span>، يعني: مصفوفة، وهي أكواب من فِضّة، وهي في الصفاء مثل القوارير، مُدَوَّرة الرؤوس، ليس لها عُرًى ولا خراطيم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤.تفسير مقاتل بن سليمان ٤/٦٧٩.
  88,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَمَارِقُ مَصۡفُوفَةࣱ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ونَمارِقُ﴾</span>، قال: مجالس{1}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ونَمارِقُ﴾</span>، قال: الوسائد{2}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ونَمارِقُ﴾</span>، قال: المرافق{3}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ونَمارِقُ﴾</span>، قال: الوسائد{4}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونَمارِقُ مَصْفُوفَةٌ﴾</span>، يعني: الوسائد الكبار العظام، مصفوفة على الطنافس، وهي بلغة قريش خاصة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٣٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣٧، وابن أبي حاتم -كما في الإتقان ٢/٥٥-.أخرجه ابن جرير ٢٤/٣٣٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.
  88,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٥٥<span class="dash">-</span></span> عن عمار بن محمد، قال: صَلّيتُ خلف <span class="name-2">منصور بن المعتمر</span>، فقرأ: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</span>، فقرأ فيها: (وزَرابِيُّ مَبْثُوثَةٌ مُّتَّكِئِينَ فِيها ناعِمِينَ){1}. (١٥/٣٨٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وزَرابِيُّ﴾</span>، قال: البُسط{2}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وزَرابِيُّ﴾</span> هي الطنافس التي لها خمل رقيق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وزَرابِيُّ مَبْثُوثَةٌ﴾</span>، قال: بعضها على بعض{4}. (١٥/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وزَرابِيُّ﴾</span>، قال: البُسُط{5}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿مَبْثُوثَةٌ﴾</span>، قال: مبسوطة{6}. (١٥/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزَرابِيُّ مَبْثُوثَةٌ﴾</span>، يعني: طنافس مبسوطة بعضها على بعض، يذكّرهم الله ﷿ صُنعه؛ ليعتبر عباده، فيحرصوا عليها، ويرغبوا فيها، ويحذروا النار، فإنّ عقوبته على قدر سلطانه، وكرامته قدر سلطانه{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٦٢<span class="dash">-</span></span> عن عبد الله بن أبي الهذيل: أنّ موسى أو غيره من الأنبياء قال: يا ربّ، كيف يكون هذا منك؟! أولياؤك في الأرض خائفون يُقتلون، ويطلبون فلا يُعطون، وأعداؤك يأكلون ما شاؤوا، ويشربون ما شاؤوا! ونحو هذا، فقال: انطلِقوا بعبدي إلى الجنة. فينظر ما لم يَر مثله قطّ؛ إلى أكواب موضوعة، ونمارق مصفوفة، وزرابيّ مبثوثة، وإلى الحُور العين، وإلى الثمار، وإلى الخدم كأنهم لؤلؤ مكنون، فقال: ما ضرّ أوليائي ما أصابهم في الدنيا إذا كان مصيرهم إلى هذا؟! ثم قال: انطلِقوا بعبدي. فانطُلق به إلى النار، فخرج منها عُنق، فصَعِق العبد، ثم أفاق، فقال: ما نفع أعدائي ما أعطيتُهم في الدنيا إذا كان مصيرهم إلى هذا؟ قال: لا شيء{8}. (١٥/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٦٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عمار</span> -من طريق عكرمة بن خالد- قال: رأيتُ عمر بن الخطاب يُصلِّي على عبقريّ، وهو الزرابيّ{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف.</p><p>وهي قراءة شاذة.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤٠٩.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٣٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.أخرجه ابن أبي شيبة ١٣/١١٥.أخرجه ابن جرير ٢٤/٣٣٧.
  88,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: لما نعت الله ما في الجنة عجِب من ذلك أهلُ الضلالة؛ فأنزل الله: <span class="qpc-hafs">﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾</span>، وكانت الإبل عيشًا من عيش العرب، وخَوَلًا مِن خَوَلهم{1}. (١٥/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: ذكر الله تعالى ارتفاع سُرُرِ الجنة، وفُرُشِها، فقالوا: كيف نصعدها؟ فأنزل الله تعالى هذه الآية{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٦٦<span class="dash">-</span></span> سُئِل <span class="name-2">الحسن البصري</span> عن هذه الآية: <span class="qpc-hafs">﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾</span>، وقيل له: الفيل أعظم في الأعجوبة؟ فقال: أمّا الفيل فالعرب بعيدة العهد بها، ثم هو لا خير فيه، لا يُركب ظهرها، ولا يؤكل لحمها، ولا يُحلب درّها، والإبل أعزّ مالٍ للعرب وأنفَسها، تأكل النوى والقتّ وتُخرج اللبن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٦٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾</span> لأنّها تنهض بحمْلها وهي باركة، ولأنه ليس شيء مِن الحيوانات سابقها غيرها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَلا يَنْظُرُونَ إلى الإبِلِ﴾</span> لأنّ العرب لم يكونوا رأوا الفيل، وإنما ذكر لهم ما أبصروا، ولو أنه قال: أفلا ينظرون إلى الفِيَلة <span class="qpc-hafs">﴿كَيْفَ خُلِقَتْ﴾</span> لم يتعجّبوا لها؛ لأنهم لم يَروها{5}<span class=comment-ref>٧١٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٤٨</span> نقل <u>ابنُ عطية</u> (٨/٦٠١) <b>عن المبرد</b> قوله: «الإبل هنا: السحاب؛ <span class="mustanad">لأنّ العرب قد تسميها بذلك</span> إذ تأتي أرسالًا كالإبل، وتُزْجى كما تُزْجى الإبل، وهي في هيئتها أحيانًا تشبه الإبل والنعام». واستشهد ببيت من الشعر:</p><p>كأن السحاب دوين السما ء نعام تعلق بالأرجل.</div></p><p><h3><span class="qpc-hafs">﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٦٩<span class="dash">-</span></span> عن <span class="name-2">شريح [القاضي]</span> -من طريق أبي إسحاق، عمَّن سمعه- أنه كان يقول لأصحابه: اخرجوا بنا إلى السوق فننظر إلى الإبل كيف خُلقتْ؟{6}. (١٥/٣٨٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤١٠.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤١٠.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤١٠.تفسير مقاتل بن سليمان ٤/٦٧٩.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٠١-، وابن جرير ٢٤/٣٣٩. وعزاه السيوطي إلى عبد بن حميد.
  88,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِلَى ٱلسَّمَاۤءِ كَیۡفَ رُفِعَتۡ ۝١٨ وَإِلَى ٱلۡجِبَالِ كَیۡفَ نُصِبَتۡ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿وإلى السَّماءِ كَيْفَ رُفِعَتْ وإلى الجِبالِ كَيْفَ نُصِبَتْ﴾</span>، قال: تصعد إلى الجبل الصَّيْخُود{1} عامة يومك، فإذا أفضيتَ إلى أعلاه أفضيتَ إلى عيون مُتفجِّرة، وأثمار متهدّلة، لم تغرسه الأيدي، ولم تعمله الناس، نعمة من الله، وبُلْغَة إلى أجل{2}. (١٥/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإلى السَّماءِ كَيْفَ رُفِعَتْ﴾</span> من فوقهم خمسمائة عام، <span class="qpc-hafs">﴿وإلى الجِبالِ كَيْفَ نُصِبَتْ﴾</span> على الأرض أوتادًا لِئلّا تزول بأهلها{3}. (ز)</p></p><p></div></p></div>",footnotes:1:يقال صخرة صيخود: شديدة لا تعمل فيها المعاول. التاج (صخد).أخرجه ابن جرير ٢٤/٣٣٩-٣٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.
