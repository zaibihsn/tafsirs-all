  76,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُدۡخِلُ مَن یَشَاۤءُ فِی رَحۡمَتِهِۦۚ وَٱلظَّـٰلِمِینَ أَعَدَّ لَهُمۡ عَذَابًا أَلِیمَۢا ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُدْخِلُ مَن يَشاءُ فِي رَحْمَتِهِ﴾</span> يعني: في جنّته، <span class="qpc-hafs">﴿والظّالِمِينَ﴾</span> يعني: المشركين <span class="qpc-hafs">﴿أعَدَّ لَهُمْ عَذابًا ألِيمًا﴾</span> يعني: وجيعًا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٣٦.
  77,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٠٦١٤<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: بينما نحن مع النبيِّ ﷺ في غارٍ بمنى إذ نزلت عليه سورة: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، فإنه ليتلوها، وإني لأتلقاها من فِيه، وإنّ فاه لَرَطْبٌ بها؛ إذ وثبتْ علينا حيّة، فقال النبيُّ ﷺ: «<b>اقتلوها</b>». فابْتَدرناها، فذَهبتْ، فقال النبيُّ ﷺ: «<b>وُقِيتْ شَرّكم كما وُقيتم شَرّها</b>»{1}. (١٥/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦١٥<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: نزلت <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span> بحِراء ليلة الحيّة. قالوا: وما ليلة الحيّة؟ قال: خَرجتْ حيّةٌ، فقال النبي ﷺ: «<b>اقتلوها</b>». فتَغيّبتْ في جُحر، فقال: «<b>دَعوها؛ فإنّ الله وقاها شَرّكم، كما وقاكم شَرّها</b>»{2}. (١٥/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦١٦<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: كُنّا مع النبيِّ ﷺ في غارٍ، فنَزلت عليه: <span class="qpc-hafs">﴿والمرسلات﴾</span>، فأَخذْتُها مِن فِيه، وإنّ فاه لَرَطْبٌ بها، فلا أدري بأيّها خَتم: <span class="qpc-hafs">﴿فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ﴾</span> [المرسلات:٥٠]، أو: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمُ ارْكَعُوا لا يَرْكَعُونَ﴾</span> [المرسلات:٤٨]{3}. (١٥/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦١٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة المرسلات بمكة{4}. (١٥/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦١٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمى: <span class="qpc-hafs">﴿والمرسلات﴾</span>، وأنها نزلت بعد: <span class="qpc-hafs">﴿ويْلٌ لكُلّ هُمَزَةٍ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦١٩<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٠<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢١<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٢<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، وذكرها بمسمى: <span class="qpc-hafs">﴿والمرسلات﴾</span>، وأنها نزلت بعد: <span class="qpc-hafs">﴿لا أقسم بيوم القيامة﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٤<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة المرسلات مكّيّة، عددها خمسون آية{10}<span class=comment-ref>٦٩٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٥٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٥٠١): «هي مكية في قول جمهور المفسرين، وحكى النّقاش أنه قيل: إنّ فيها مِن المدني قوله: <span class="qpc-hafs">﴿وإذا قيل لهم اركعوا لا يركعون﴾</span> [المرسلات:٤٨] على قول مَن قال: إنها حكاية عن حال المنافقين في القيامة، وإنها بمعنى قوله تعالى: <span class="qpc-hafs">﴿يدعون إلى السجود فلا يستطيعون﴾</span> [القلم:٤٢]».</p><p>وقد نُصَّ على مكيّة سورة المرسلات في تفسير <u>ابن كثير</u> (١٤/٢١٩).</div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٥<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>مَن قَرَأَ: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span> فقال: <span class="qpc-hafs">﴿فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ﴾</span></b> [المرسلات:٥٠] <b>فَلْيَقُلْ: آمَنّا بالله، ومن قرَأَ: <span class="qpc-hafs">﴿والتِّينِ والزَّيْتُونِ﴾</span> فَلْيَقُلْ: بلى، وأنا على ذلك من الشّاهدين، ومَن قَرَأَ: <span class="qpc-hafs">﴿ألَيْسَ ذَلِكَ بِقادِرٍ عَلى أنْ يُحْيِيَ المَوْتى﴾</span></b> [القيامة:٤٠] <b>فَلْيَقُلْ: بلى</b>». قال إسماعيل: فذهبت أنظر هل حفظ؟ وكان أعرابيًّا، فقال: يا ابن أخي، أظننتَ أني لم أحفظه، لقد حَججتُ ستين حجّة، ما منها سنة إلا أعرف البعير الذي حَججتُ عليه{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمُرۡسَلَـٰتِ عُرۡفࣰا ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٢٦<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جدّه، قال: قال رسول الله ﷺ: «<b>الرياح ثمان؛ أربع منها عذاب، وأربع منها رحمة، فالعذاب منها: العاصف، والصّرْصَر والعقيم والقاصف. والرحمة منها: النّاشرات، والمُبَشِّرات، والمرسلات، والذّاريات، فيُرسِل الله المرسلات فتُثير السحاب، ثم يُرسِل المُبَشِّرات فتُلْقِح السحاب، ثم يُرسِل الذّاريات فتَحمل السحاب، فتَدُرُّ كما تَدُرّ اللّقْحة، ثم تُمطر وهنّ اللواقح، ثم يُرسِل النّاشِرات فتَنشُر ما أراد</b>»{12}. (١٥/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: الملائكة{13}. (١٥/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي العُبَيْدَيْن- أنه سأله عن قوله: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، فقال: الريح{14}. (١٥/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٢٩<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي صالح- <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: هي الملائكة أُرسلتْ بالمعروف{15}. (١٥/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عطاء- قال: الرياح ثمان: أربع منها عذاب، وأربع منها رحمة؛ فأما العذاب منها: فالقاصف، والعاصف، والعقيم، والصّرْصَر، قال الله تعالى: <span class="qpc-hafs">﴿ريحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</span> [فصلت:١٦]. قال: مشؤومات، وأما رياح الرحمة: فالنّاشِرات، والمُبَشِّرات، <span class="qpc-hafs">﴿والمرسلات﴾</span>، <span class="qpc-hafs">﴿والذّارِياتِ﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: الريح{17}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: الملائكة{18}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٣<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأَجْدع الهَمداني</span> -من طريق مسلم- <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: الملائكة{13}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٤<span class="dash">-</span></span> عن <span class="name-2">ابن بُرَيْدة</span> -من طريق صالح- في قوله: <span class="qpc-hafs">﴿عُرْفًا﴾</span>، قال: يَتبع بعضها بعضًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: الريح{21}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿والمرسلات عُرْفًا فالعاصِفاتِ عَصْفًا والنّاشِراتِ نَشْرًا فالفارِقاتِ فَرْقًا فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{22}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span> أنها الرياح. وقال: عُرفها: جَريها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: هي الرُّسل تُرسَل بالمعروف{24}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٣٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: الملائكة يجيئون بالأعارف{25}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- في قوله: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: هي الرياح{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، قال: هي الريح{27}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span>، يقول: الملائكة، وأُرسِلوا بالمعروف{28}<span class=comment-ref>٦٩٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٥٦</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿والمرسلات عُرْفًا﴾</span> على أربعة أقوال: <b>الأول</b>: أنها الملائكة تُرسَل مُتتابعة بالمعروف. وهو قول أبي هريرة، وابن مسعود، ومسروق، وأبي صالح في رواية عنه. وتأويل الكلام على ذلك: والملائكة التي أُرسلتْ بأمر الله ونهيه، وذلك هو العُرْف. و<b>الثاني</b>: أنهم الرُّسُل يُرسَلون بما يُعرفون به من المعجزات، إفضالًا من الله على عباده ببعثتهم. وهو قول أبي صالح. و<b>الثالث</b>: أنها الرياح تُرسَل بما عرفها الله تعالى. وهو قول لابن مسعود، وابن عباس، ومجاهد، وقتادة. و<b>الرابع</b>: أنها السحب لما فيها من نعمة ونقمة عارفة بما أُرسلتْ فيه، ومَن أُرسلتْ إليه.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢٣/٥٧٣) إلى <span class="mustanad">العموم</span>، فقال: «الصواب من القول في ذلك عندنا أن يُقال: إنّ الله -تعالى ذِكْره- أقسم بالمرسلات عُرْفًا، وقد تُرسل عُرفًا الملائكة، وتُرسَل كذلك الرياح، ولا دلالة تدل على أنّ المعنيّ بذلك أحد الجنسين دون الآخر، وقد عمّ -جلّ ثناؤه- بإقسامه بكلّ ما كانت صفته ما وصف، فكلّ مَن كان صفته كذلك، فداخلٌ في قسَمه ذلك، مَلكًا أو ريحًا أو رسولًا من بني آدم مرسلًا».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (١٤/٢٢٠) إلى القول الثالث <span class="mustanad">استنادًا إلى النظائر</span>، فقال: «الأظهر أنّ المرسلات هي الرياح كما قال تعالى: <span class="qpc-hafs">﴿وأرسلنا الرياح لواقح﴾</span> [الحجر:٢٢]، وقال تعالى: <span class="qpc-hafs">﴿وهو الذي يرسل الرياح بشرا بين يدي رحمته﴾</span> [الأعراف:٥٧]».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ القيم</u> (٣/٢٤٣) القول الثاني <span class="mustanad">لمخالفته النظائر، والسياق، والأفصح لغة</span>، فقال: «الإرسال المُقسم به هاهنا مُقيّد بالعُرف؛ فإما أن يكون ضد المنكر فهو إرسال رُسله من الملائكة، ولا يَدخل في ذلك إرسال الرياح ولا الصواعق ولا الشياطين، وأما إرسال الأنبياء فلو أُريد لقال:»والمرسلين«، وليس بالفصيح تسمية الأنبياء»مرسلات«، وتكلّف الجماعات المرسلات خلاف المعهود من استعمال اللفظ، فلم يُطلق في القرآن جمع ذلك إلا جمع تذكير لا جمع تأنيث، وأيضًا فاقتران اللفظة بما بعدها من الأقسام لا يناسب تفسيرها بالأنبياء، وأيضًا فإنّ الرُّسُل مُقسمٌ عليهم في القرآن لا مُقسمٌ بهم، كقوله: <span class="qpc-hafs">﴿تاللَّهِ لَقَدْ أرْسَلْنا إلى أُمَمٍ مِن قَبْلِكَ﴾</span> [النحل:٦٣]، وقوله: <span class="qpc-hafs">﴿وإنَّكَ لَمِنَ المُرْسَلِينَ﴾</span> [البقرة:٢٥٢]، وقوله: <span class="qpc-hafs">﴿يس والقُرْآنِ الحَكِيمِ إنَّكَ لَمِنَ المُرْسَلِينَ﴾</span> [يس:١-٣]».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥٠٢) احتمالين آخرين في معنى: <span class="qpc-hafs">﴿عُرْفًا﴾</span> على القول بأنّ <span class="qpc-hafs">﴿والمرسلات﴾</span>: الرياح: <b>الأول:</b> «أن يكون <span class="qpc-hafs">﴿عُرْفًا﴾</span> بمعنى: <span class="qpc-hafs">﴿والمرسلات﴾</span> الرياح التي يعرفها الناس ويعهدونها، ثم عقَّب بذكر الصنف المستنكر الضارِّ وهي العاصفات». <b>والثاني:</b> «أن يريد بالعُرف مع الرياح: التتابع كعُرف الفرس ونحوه، <span class="mustanad">وتقول العرب</span>: هبَّ عُرف من ريح». و<span class="comment-type-4">علَّق</span> بقوله: «والقول في العُرف مع أنّ المُرْسَلات هي الرياح يطَّرد على أنّ المُرْسَلاتِ هي السحاب».</div></p></div>",footnotes:1:أخرجه البخاري ٣/١٤ (١٨٣٠)، ٤/١٢٩-١٣٠ (٣٣١٧)، ٦/١٦٤-١٦٥ (٤٩٣٠، ٤٩٣١، ٤٩٣٤)، ومسلم ٤/١٧٥٥ (٢٢٣٤).أخرجه أحمد ٧/٣٨٥-٣٨٦ (٤٣٧٧)، والطبراني في الكبير ١٠/١١٨ (١٠١٥٥)، وابن مردويه -كما في فتح الباري ٨/٦٨٧-، من طريق محمد بن إسحاق، عن عبد الرحمن بن الأسود، عن أبيه، عن ابن مسعود به.</p><p>وسنده حسن.أخرجه الحاكم ٢/٢٥١، وابن عساكر في تاريخ دمشق ٣٣/٧٣-٧٤ مطولًا. وعزاه السيوطي إلى ابن مردويه.</p><p>وصححه الحاكم.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٤١.أخرجه أحمد ١٢/٣٥٣-٣٥٤ (٧٣٩١)، وأبو داود ٢/١٦٣ (٨٨٧)، والترمذي ٥/٥٣٧-٥٣٨ (٣٦٤١) مختصرًا، والحاكم ٢/٥٥٤ (٣٨٨٢) مختصرًا.</p><p>قال الترمذي: «هذا حديث إنما يُروى بهذا الإسناد عن هذا الأعرابي عن أبي هريرة، ولا يُسمّى». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وأورده ابن أبي حاتم في العلل ٤/٧١٦ (١٧٦٣). والدارقطني في العلل ١١/٢٤٦ (٢٢٦٧). وأورد رواية أبي داود والترمذي النوويُّ في خلاصة الأحكام ١/٥٠٢ (١٦٧٥) في فصل في ضعيف من نحوه. وقال الهيثمي في المجمع ٧/١٣٢ (١١٤٥٧): «رواه أحمد، وفيه رجلان لم أعرفهما». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٦ (٥٨٨٥): «هذا إسناد ضعيف؛ لجهالة التابعي». وقال الألباني في ضعيف أبي داود ١/٣٤٣ (١٥٦): «إسناده ضعيف».عزاه السيوطي إلى ابن مردويه.</p><p>وسنده حسن إن صحّ الإسناد إلى عمرو بن شعيب.أخرجه ابن جرير ٢٣/٥٨٢.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩١-، وابن جرير ٢٣/٥٨٠-٥٨١ من طرق. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٢٠-، والحاكم ٢/٥١١.أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -ضمن موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.أخرجه ابن جرير ٢٣/٥٨٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٥٨٢.أخرجه ابن جرير ٢٣/٥٨٢.أخرجه ابن جرير ٢٣/٥٨١.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧٧-.أخرجه ابن جرير ٢٣/٥٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٥٨١.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٨١، كذلك من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱلۡعَـٰصِفَـٰتِ عَصۡفࣰا ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي العُبَيْدَيْن- <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span>، قال: الريح{1}. (١٥/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٤<span class="dash">-</span></span> عن خالد بن عرعرة، قال: قام رجل إلى <span class="name-1">علي</span>، فقال: ما العاصفات عصفًا؟ قال: الرياح{2}. (١٥/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span>، قال: الريح{3}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span>، قال: الريح{3}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿والمرسلات عُرْفًا فالعاصِفاتِ عَصْفًا والنّاشِراتِ نَشْرًا فالفارِقاتِ فَرْقًا فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{5}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span>، قال: الريح{6}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٤٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span>، قال: الريح العواصف{7}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span>، قال: هي الريح{8}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span> وهي الرياح{9}<span class=comment-ref>٦٩٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٥٧</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span> على قولين: <b>الأول</b>: أنها الرياح الشديدات الهبوب. وهو قول الجمهور. و<b>الثاني</b>: أنها الملائكة. وهو قول آخر لمجاهد.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢٣/٥٨٣) إلى القول الأول <span class="mustanad">استنادًا إلى أقوال السلف</span>، فقال: «قوله: <span class="qpc-hafs">﴿فالعاصفات عصفا﴾</span> يقول -جلّ ذِكْره-: فالرياح العاصفات عصفًا، يعني: الشديدات الهبوب السريعات المرّ. وبنحو الذي قلنا في ذلك قال أهل التأويل».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (١٤/٢٢٠ بتصرف) إلى القول الأول، فقال: «الأظهر: أنّ العاصفات هي الرياح، يقال: عصفت الرياح: إذا هبَّتْ بتصويت». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٣/٢٤٣-٢٤٤): «إن كان العُرف مِن التتابُع كعُرف الفرس وعُرف الديك والناس إلى فلان عرف واحد، أي: سابقون في قصده والتوجه إليه؛ جاز أن تكون المرسلات الرياح، ويؤيّده عطف العاصفات عليه والنّاشرات، وجاز أن تكون الملائكة، وجاز أن يعمّ النوعين لوقوع الإرسال عُرفًا عليهما، ويؤيّده أنّ الرياح مُوكل بها ملائكة تسوقها وتُصرّفها، ويؤيّد كونها الرياح <span class="mustanad">عطف العاصفات عليها بفاء التعقيب والتسبب</span> فكأنها أُرسِلت فعَصفت، ومَن جعل المرسلات الملائكة قال: هي تعصف في مُضيّها مُسرعة كما تعصف الرياح، والأكثرون على أنها الرياح».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩١-، وابن راهويه -كما في المطالب العالية (٤١٧٢)-، وابن جرير ٢٣/٥٨٣، ٥٨٥، والحاكم ٢/٥١١، والبيهقي في شعب الإيمان (٣٩٩١). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٥٨٤.أخرجه ابن جرير ٢٣/٥٨٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٥٨٤-٥٨٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٨٥، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلنَّـٰشِرَ ٰ⁠تِ نَشۡرࣰا ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي العُبَيْدَيْن- أنه سأله عن <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span>. قال: الريح{1}. (١٥/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span>، قال: الريح{2}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿والمرسلات عُرْفًا فالعاصِفاتِ عَصْفًا والنّاشِراتِ نَشْرًا فالفارِقاتِ فَرْقًا فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{3}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span> هي الرياح التي يُرسِلها الله بُشرًا بين يدي رحمته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span>، قال: هي الرِّياح{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل [بن أبي خالد]- <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span>، قال: المطر{6}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span>، قال: الملائكة يَنشُرون الكتب{7}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span>، قال: الرياح{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span> هم الملائكة يَنشُرون الكتب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأما قوله: <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span> وهي أعمال بني آدم تُنشَر يوم القيامة{10}<span class=comment-ref>٦٩٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٥٨</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿والنّاشِراتِ نَشْرًا﴾</span> على ثلاثة أقوال: <b>الأول</b>: أنها الرياح. و<b>الثاني</b>: أنها المطر. و<b>الثالث</b>: أنها الملائكة التي تَنشُر الكتب.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢٣/٥٨٧) إلى <span class="mustanad">العموم</span>، فقال: «أولى الأقوال في ذلك عندنا بالصواب أن يُقال: إنّ الله -تعالى ذِكْره- أقسم بالنّاشِرات نشرًا، ولم يخْصُص شيئًا من ذلك دون شيء، فالرياح تَنشُر السحاب، والمطر يَنشُر الأرض، والملائكة تَنشُر الكتب، ولا دلالة مِن وجهٍ يجب التسليم له على أنّ المراد مِن ذلك بعضٌ دون بعضٍ، فذلك على كلِّ ما كان ناشرًا».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (١٤/٢٢٠ بتصرف) إلى القول الأول «وهو قول ابن مسعود، والحسن، وقتادة»، فقال: «الأظهر أنّ ... النّاشِرات: هي الرياح التي تَنشُر السحاب في آفاق السماء كما يشاء الرب ﷿». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٣/٢٤٤)، فقال: «<span class="mustanad">ويدل على صحة قولهم قوله تعالى</span>: ‹وهُوَ الَّذِي يَرْسُلُ الرِّياحَ نُشُرًا بَيْنَ يَدَيْ رَحْمَتِهِ› [الأعراف:٥٧]، يعني: أنها تَنشُر السحاب نشرًا، وهو: ضد الطي». ثم <span class="comment-type-4">قال</span>: «قلت: ويجوز أن تكون النّاشِرات لازمًا لا مفعول له، ولا يكون المراد أنهنّ نشَرن كذا؛ فإنه يقال: نشَر الميت حي، وأنشَره الله إذا أحياه، فيكون المراد بها: الأنفس التي حَييتْ بالعُرف الذي أُرسِلتْ به المرسلات، أو الأشباح والأرواح والبقاع التي حَييتْ بالرياح المرسلات؛ فإنّ الرياح سبب لنشور الأبدان والنبات، والوحي سبب لنشور الأرواح وحياتها».</p><p>ونقل <u>ابنُ عطية</u> (٨/٥٠٢، ٥٠٣) في معنى الآية <b>أقوالًا</b> أخرى، و<span class="comment-type-1">وجَّه</span> بعضها، فقال: "وقال بعض المتأولين: النّاشِرات: طوائف الملائكة التي تُباشر إخراج الموتى من قبورهم للبعْث، فكأنهم يحيونهم. وقال قوم: النّاشِرات: الرمم في بعث يوم القيامة، يقال: نشَر الميت، <span class="mustanad">ومنه قول الأعشى</span>:</p><p>يا عجبًا للمَيِّتِ النّاشر</p><p>وقيل: النّاشِرات: البقاع التي تحيا بالأمطار، شُبِّهتْ بالميت يُنشر".</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٨٥، ٥٨٦ بطرق متعددة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٥٨٦ بطرق.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٠٩، وتفسير البغوي ٧/٣٠١.أخرجه ابن جرير ٢٣/٥٨٦.أخرجه ابن جرير ٢٣/٥٨٦-٥٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٥٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٨٦.تفسير الثعلبي ١٠/١٠٩، وتفسير البغوي ٧/٣٠١.تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱلۡفَـٰرِقَـٰتِ فَرۡقࣰا ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span>، قال: الملائكة{1}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span>، قال: الملائكة فرّقتْ بين الحق والباطل{2}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span>، يعني: الملائكة تأتي بما يُفرّق بين الحق والباطل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿والمرسلات عُرْفًا فالعاصِفاتِ عَصْفًا والنّاشِراتِ نَشْرًا فالفارِقاتِ فَرْقًا فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{4}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span> هي الرياح تُفرّق السحاب وتبدّده{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span> هي آي القرآن؛ تُفرّق بين الحلال والحرام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span>، قال: الرُّسُل{7}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٦٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span>، قال: الملائكة يُفرّقون بين الحق والباطل{8}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span>، يعني: القرآن، ما فرّق الله به بين الحق والباطل{9}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أما قوله: <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span> فهو القرآن؛ فَرّق بين الحق والباطل{10}<span class=comment-ref>٦٩٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٥٩</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span> على أربعة أقوال: <b>الأول</b>: أنها الملائكة التي تُفرّق بين الحق والباطل. و<b>الثاني</b>: أنها الرُّسُل الذين يُفرّقون بين الحلال والحرام. و<b>الثالث</b>: أنها الرياح. و<b>الرابع</b>: أنّ المقصود: القرآن.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢٣/٥٨٨) إلى <span class="mustanad">العموم</span>، فقال: «الصواب من القول في ذلك أن يقال: أقسم ربُّنا -جلّ ثناؤه- بالفارقات، وهي الفاصِلات بين الحق والباطل، ولم يخْصُص بذلك منهنَّ بعضًا دون بعض، فذلك قَسَمٌ بكل فارقةٍ بين الحق والباطل؛ مَلكًا كان أو قرآنًا أو غير ذلك».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (١٤/٢٢١) إلى القول الأول، فقال: «قوله تعالى: <span class="qpc-hafs">﴿فالفارقات فرقا فالملقيات ذكرا عذرا أو نذرا﴾</span>، يعني: الملائكة. قاله ابن مسعود، وابن عباس، ومسروق، ومجاهد، وقتادة، والربيع بن أنس، والسُّدِّيّ، والثوري، ولا خلاف هاهنا؛ فإنها تَنزل بأمر الله على الرُّسُل تُفرّق بين الحق والباطل، والهُدى والغي، والحلال والحرام، وتُلقي إلى الرسل وحيًا فيه إعذار إلى الخَلْق، وإنذار لهم عقاب الله إنْ خالفوا أمره». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٢٤٥) أنّ أكثر المفسرين على أنها الملائكة؛ <span class="mustanad">ويدل عليه عطف المُلْقيات ذكرًا عليها بالفاء</span>، وهي الملائكة بالاتفاق، وعلى هذا فيكون القَسم بالملائكة التي تَنشُر أجنحتها عند النزول، ففَرّقتْ بين الحق والباطل، فأَلقَت الذِّكر على الرسل إعذارًا وإنذارًا. ثم <span class="comment-type-2">انتقد</span> القول الثالث <span class="mustanad">لدلالة السياق</span>، فقال: «ومَن جعل النّاشِرات الرياح جعل الفارقات صفة لها، وقال: هي تُفرّق السحاب ههنا وههنا، ولكن يأبى ذلك عطف المُلْقِيات بالفاء عليها». و<span class="comment-type-4">علق</span> على القول الثاني بقوله: «ومَن قال: هي جماعات الرُّسُل، فإنْ أراد الرُّسُل من الملائكة <span class="comment-type-3">فظاهر</span>، وإنْ أراد الرُّسُل من البشر فقد تقدم بيان <span class="comment-type-2">ضعف</span> هذا القول». و<span class="comment-type-4">علق</span> على القول الرابع بقوله: «مَن قال: الفارقات: أي: القرآن يُفرّق بين الحق والباطل، فقوله يلتئم مع كون النّاشِرات الملائكة أكثر من التئامه إذا قيل: إنها الرياح».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٣/٢٤٥): «ويظهر -والله أعلم بما أراد من كلامه- أنّ القَسم في هذه الآية وقع على النوعين؛ الرياح والملائكة، ووجه المناسبة: أنّ حياة الأرض والنبات وأبدان الحيوان بالرياح فإنها من روح الله، وقد جعلها الله تعالى نشورًا، وحياة القلوب والأرواح بالملائكة، فبهَذيْن النوعين يحصل نوعا الحياة، ولهذا -والله أعلم- فَصل أحد النوعين من الآخر بالواو، وجعل ما هو تابع لكل نوع بعده بالفاء».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٨٨.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/١٠٩، وتفسير البغوي ٧/٣٠١.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٧/٣٠١.تفسير الثعلبي ١٠/١٠٩، وتفسير البغوي ٧/٣٠١.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٣/٥٨٧-٥٨٨ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱلۡمُلۡقِیَـٰتِ ذِكۡرًا ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{1}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة بالتنزيل{2}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿والمرسلات عُرْفًا فالعاصِفاتِ عَصْفًا والنّاشِراتِ نَشْرًا فالفارِقاتِ فَرْقًا فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{3}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة يجيئون بالقرآن والكتاب{4}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span> هي الملائكة تُلقي الذِّكر على الرُّسُل، وتُلقيه الرُّسُل على بني آدم{5}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأما قوله: <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span> فهو جبريل ﷺ وحده، يُلقي الذِّكر على ألسنة الأنبياء والرُّسُل، وهو: <span class="qpc-hafs">﴿فالتّالِياتِ ذِكْرًا﴾</span> [الصافات:٣]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٧٨<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span>، قال: الملائكة{1}<span class=comment-ref>٦٩٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٠</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span> على ثلاثة أقوال: <b>الأول</b>: أنها الملائكة. و<b>الثاني</b>: أنه جبريل خاصّة. و<b>الثالث</b>: أنها الرُّسُل.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢٣/٥٨٨) إلى الأول -وهو قول الجمهور- <span class="mustanad">استنادًا إلى أقوال السلف</span>، فقال: «قوله: <span class="qpc-hafs">﴿فالملقيات ذكرا﴾</span> يقول: فالمُبلِّغات وحي الله رسله، وهي الملائكة. وبنحو الذي قلنا في ذلك قال أهل التأويل».</p><p>و<span class="comment-type-4">ذَهَبَ</span> إلى ذلك أيضًا <u>ابنُ كثير</u> (١٤/٢٢١).</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٨٩.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه عبد الرزاق ٢/٣٤٠ من طريق معمر مختصرًا بنحوه، وكذلك ابن جرير ٢٣/٥٨٩ من طريق سعيد.تفسير مقاتل بن سليمان ٤/٥٤٣.أخرجه ابن جرير ٢٣/٥٨٩.
  77,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عُذۡرًا أَوۡ نُذۡرًا ۝٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٧٩<span class="dash">-</span></span> عن زيد بن ثابت، عن النبي ﷺ، قال: «<b>أُنزِل القرآن بالتّفخيم</b>{1}». قال عمّار بن عبد الملك{2}: كهيئة: ‹عُذُرًا أوْ نُذُرًا›، و<span class="qpc-hafs">﴿الصَّدَفَيْنِ﴾</span> [الكهف:٩٦]، و<span class="qpc-hafs">﴿ألا لَهُ الخَلْقُ والأَمْرُ﴾</span> [الأعراف:٥٤]، وأشباه هذا في القرآن{3}<span class=comment-ref>٦٩٦١</span>. (١٥/١٧٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦١</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٣/٥٩٠): «اختَلفت القَرَأَة في قراءة ذلك؛ فقرأته عامة قراء المدينة والشام وبعض المكّيّين وبعض الكوفيّين: <span class="qpc-hafs">﴿عُذْرا﴾</span> بالتخفيف، ‹أوْ نُذُرًا› بالتثقيل، وقرأ ذلك عامة قراء الكوفة وبعض البصريّين بتخفيفهما، وقرأه آخرون من أهل البصرة بتثقيلهما. والتخفيف فيهما <span class="comment-type-3">أعجب إليّ</span>، وإن لم أدفع صحة التثقيل؛ لأنهما مصدران بمعنى الإعذار والإنذار».</div></p><p><h3><span class="qpc-hafs">﴿عُذۡرًا أَوۡ نُذۡرًا ۝٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿عُذْرًا أوْ نُذْرًا﴾</span>: يعني: الملائكة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿عُذْرًا أوْ نُذْرًا﴾</span>، قال: عُذرًا من الله، ونُذرًا منه إلى خَلْقه{5}. (١٥/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٨٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>: <span class="qpc-hafs">﴿عُذْرًا﴾</span> من الله، أو<span class="qpc-hafs">﴿نُذْرًا﴾</span> منه إلى الناس، وهم الرُّسُل يُعذِرون ويُنذِرون{6}. (١٥/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٨٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿عُذْرًا أوْ نُذْرًا﴾</span> المعنى: عُذْرًا ونُذْرًا، والألف صلة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿عُذْرًا أوْ نُذْرًا﴾</span>، يقول: عُذْرًا من الله، ونُذْرًا إلى خَلْقه{8}. (ز)</p></p><p></div></p></div>",footnotes:1:قال المناوي في فيض القدير ٣/٥٦: «أي: التعظيم، ومن تفخيمه: إعطاؤه حقّه وقفًا وابتداء، فإنّ رعاية الفواصل تزيد في البيان، وزيادته تُورث التوقير، أي: التعظيم». وقال السيوطي في الإتقان ١/٣٢١: «خامسها: أنّ المراد بالتفخيم تحريك أوساط الكَلم بالضم والكسر في المواضع المختلف فيها دون إسكانها؛ لأنه أشبع لها وأفخم. قال الداني: وكذا جاء مُفسّرًا عن ابن عباس ...».أحد رواة الحديث.أخرجه الحاكم ٢/٢٥٢ (٢٩٠٨)، ٢/٢٦٤ (٢٩٥٣) دون قوله: «قال عمار بن عبد الملك»، وفي إسناده بكّار بن محمد بن عبد الله، ومحمد بن عبد العزيز بن عمر بن عبد الرحمن بن عوف.</p><p>قال الحاكم: «صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «لا والله؛ العَوفيّ مُجمعٌ على ضعفه، وبكار ليس بعمدة، والحديث واهٍ مُنكر». وقال السيوطي في الإتقان ١/١٦٣: «أخرجه ابن الأنباري في كتاب الوقف والابتداء، فبيّن أن المرفوع منه: «<b>أُنزِل القرآن بالتفخيم فقط</b>»، وأنّ الباقي مُدرجٌ من كلام عمار بن عبد الملك أحد رواة الحديث». وقال الألباني في الضعيفة ٣/٥٢٠ (١٣٤٣): «منكر».</p><p>و‹عُذُرًا› بضم الذال قراءة متواترة، قرأ بها رَوح، وقرأ بقية العشرة: <span class="qpc-hafs">﴿عُذْرًا﴾</span> بإسكان الذال، واختلفوا في <span class="qpc-hafs">﴿نُذُرًا﴾</span> فقرأها بإسكان الذال أبو عمرو، وحفص، وحمزة، والكسائي، وخلف، وقرأ البقية ‹نُذُرًا› بضم الذال. و<span class="qpc-hafs">﴿الصَّدَفَيْنِ﴾</span> بفتح الصاد والدال قراءة متواترة، قرأ بها العشرة ما عدا ابن كثير، وأبا عمرو، ويعقوب، وابن عامر؛ فإنهم قرؤوا: ‹الصُّدُفَيْنِ› بضمهما، وما عدا شعبة؛ فإنه قرأ ‹الصُّدْفَيْنِ› بضم الصاد، وإسكان الدال. أما <span class="qpc-hafs">﴿ألا لَهُ الخَلْقُ والأَمْرُ﴾</span> فهي قراءة العشرة. انظر: النشر ٢/٣١٦، والإتحاف ص٥٦٧.أخرجه ابن جرير ٢٣/٥٩٠.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٨٩-٥٩٠، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧٧-.تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّمَا تُوعَدُونَ لَوَ ٰ⁠قِعࣱ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿إنَّما تُوعَدُونَ﴾</span> مِن أمر الساعة <span class="qpc-hafs">﴿لَواقِعٌ﴾</span> يعني: لكائن، ثم ما يكون في ذلك اليوم أنه لكائن، <span class="qpc-hafs">﴿وإنَّ الدِّينَ لَواقِعٌ﴾</span> [الذاريات:٦] يقول: وأنّ الحساب لكائن{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا ٱلنُّجُومُ طُمِسَتۡ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٨٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿فَإذا النُّجُومُ طُمِسَتْ﴾</span>، قال: تُطمس فيَذهب نورها{1}. (١٥/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَإذا النُّجُومُ طُمِسَتْ﴾</span> بعد الضوء والبياض إلى السّواد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلسَّمَاۤءُ فُرِجَتۡ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأما قوله: <span class="qpc-hafs">﴿وإذا السَّماءُ فُرِجَتْ﴾</span>،يقول: انفَرجتْ عن نزول مَن فيها من الملائكة وربّ العزّة لحساب الخلائق{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡجِبَالُ نُسِفَتۡ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا الجِبالُ نُسِفَتْ﴾</span>، يقول: مِن أصلها حتى استوت بالأرض، كما كانت أول مرة{1}<span class=comment-ref>٦٩٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٥٠٤): «نَسْف الجبال: هو بعد التسيير. وقيل: كونها هباء، وهو تفريقها بالريح».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٣.
  77,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلرُّسُلُ أُقِّتَتۡ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- <span class="qpc-hafs">﴿أُقِّتَتْ﴾</span>، قال: جُمِعَتْ{1}. (١٥/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٩١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿وإذا الرُّسُلُ أُقِّتَتْ﴾</span>، قال: أُوعدتْ{2}<span class=comment-ref>٦٩٦٣</span>. (١٥/١٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٣</span> <span class="comment-type-4">عَلَّقَ</span> <u>ابنُ كثير</u> (١٤/٢٢١) على هذا الأثر بقوله: «وكأنه يجعلها <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿وأشرقت الأرض بنور ربها ووضع الكتاب وجيء بالنبيين والشهداء وقضي بينهم بالحق وهم لا يظلمون﴾</span> [الزمر:٦٩]».</div></p><p><div></p><p><p><span class="item-no">٨٠٦٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أُقِّتَتْ﴾</span>، قال: أُجِّلتْ{3}. (١٥/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٩٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وإذا الرُّسُلُ أُقِّتَتْ﴾</span> أُجِّلتْ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأما قوله: <span class="qpc-hafs">﴿وإذا الرُّسُلُ أُقِّتَتْ﴾</span>، يقول: جُمعتْ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٩٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإذا الرُّسُلُ أُقِّتَتْ﴾</span>، قال: أُقِّتَتْ ليوم القيامة. وقرأ: <span class="qpc-hafs">﴿يَوْمَ يَجْمَعُ اللَّهُ الرُّسُلَ﴾</span> [المائدة:١٠٩]، قال: والأجَل الميقات. وقرأ: <span class="qpc-hafs">﴿يَسْأَلُونَكَ عَنِ الأَهِلَّةِ قُلْ هِيَ مَواقِيتُ لِلنّاسِ والحَجِّ﴾</span> [البقرة:١٨٩]، وقرأ: <span class="qpc-hafs">﴿إلى مِيقاتِ يَوْمٍ مَعْلُومٍ﴾</span> [الواقعة:٥٠]، قال: إلى يوم القيامة. قال: لهم أجلٌ إلى ذلك اليوم حتى يَبْلغوه{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٩١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٣/٥٩٢. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٥٩١، ومن طريق سفيان أيضًا. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧٨-.تفسير مقاتل بن سليمان ٤/٥٤٣.أخرجه ابن جرير ٢٣/٥٩١.
  77,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِأَیِّ یَوۡمٍ أُجِّلَتۡ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى الساعة في التقديم، فقال: <span class="qpc-hafs">﴿لِأَيِّ يَوْمٍ أُجِّلَتْ﴾</span> يقول: لأي يوم أجَّلَها، يعني: الساعة يوم القيامة، وجمع الملائكة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٣-٥٤٤.
  77,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِیَوۡمِ ٱلۡفَصۡلِ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٦٩٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لِيَوْمِ الفَصْلِ﴾</span> يوم يَفصل الرحمن ﷿ بين الخلائق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لِيَوْمِ الفَصْلِ﴾</span>: يوم يَفصل الله فيه بين الناس بأعمالهم؛ إلى الجنة، وإلى النار{2}. (١٥/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٦٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال تعالى: <span class="qpc-hafs">﴿لِيَوْمِ الفَصْلِ﴾</span>، يعني: يوم القضاء{3}<span class=comment-ref>٦٩٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٥٠٤): «ومن هذه الآية انتزَع القُضاةُ الآجالَ في الحكومات؛ ليقع فَصْل القضاء عند تمامها».</div></p></div>",footnotes:1:تفسير البغوي ٧/٣٠٥.أخرجه ابن جرير ٢٣/٥٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَدۡرَىٰكَ مَا یَوۡمُ ٱلۡفَصۡلِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٠٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وما أدْراكَ ما يَوْمُ الفَصْلِ﴾</span>، أي: أنك لم تكن تَدري ما يوم الفصل حتى أعلمتُك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما أدْراكَ ما يَوْمُ الفَصْلِ﴾</span>، قال: تعظيمًا لذلك اليوم{2}<span class=comment-ref>٦٩٦٥</span>. (١٥/١٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٥</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٣/٥٩٣) مبيّنًا معنى الآية <span class="mustanad">استنادًا إلى أثر قتادة</span>: «يقول -تعالى ذِكْره- لنبيّه محمد ﷺ: وأي شيء أدراك -يا محمد- ما يوم الفصل؟! معظِّمًا بذلك أمْره، وشدّة هَوْله».</div></p><p><div></p><p><p><span class="item-no">٨٠٧٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أدْراكَ ما يَوْمُ الفَصْلِ﴾</span> ما هو؟! تعظيمًا لشدّتها، فكَذّبوا بذلك اليوم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧٨-.أخرجه ابن جرير ٢٣/٥٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: ويلٌ: وادٍ في جهنم، يَسيل فيه صديد أهل النار، فجُعل للمُكذّبين{1}<span class=comment-ref>٦٩٦٦</span>. (١٥/١٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٦٦</span> <span class="comment-type-4">عَلَّقَ</span> <u>ابنُ كثير</u> (١٤/٢٢٢) على هذا الأثر بقوله: «لا يصحّ».</div></p><p><div></p><p><p><span class="item-no">٨٠٧٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، قال: ويلٌ لهم، والله، ويلٌ طويل{2}. (١٥/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: فأوعدهم <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالبعث{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٣/٥٩٣-٥٩٤ بلفظ: ويل -واللهِ- طويل. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ نُهۡلِكِ ٱلۡأَوَّلِینَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال: يا محمد، <span class="qpc-hafs">﴿ألَمْ نُهْلِكِ الأَوَّلِينَ﴾</span> الذين كَذّبوا بيوم القيامة، أهلكْتُهم بالصّيحة والخَسْف والمسْخ والفرق والعدو{1}{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٠٧<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿ألم نهلك الأولين﴾</span>، [قال]: يعني: الأمم السالفة حين كَذّبوا رسلهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:كذا في المطبوع.تفسير مقاتل بن سليمان ٤/٥٤٤.أخرجه أبو عمرو الداني في المكتفى ص٢٢٨ (٤٤).
  77,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ نُتۡبِعُهُمُ ٱلۡـَٔاخِرِینَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ نُتْبِعُهُمُ الآخِرِينَ﴾</span> بالأوّلين بالهلاك، يعني: العذاب، يعني: كفار مكة لَمّا كَذّبوا بمحمد ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٧٠٩<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلاّم</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿ثم نتبعهم الآخرين﴾</span>: يعني: [آخر] كفار هذه الأُمّة الذين تقوم عليهم الساعة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٤.أخرجه أبو عمرو الداني في المكتفى ص٢٢٨ (٤٤).
  77,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِینَ ۝١٨ وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٧١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span>، يقول: هكذا نَفعل بالمجرمين، يعني: الكفار الظَّلمة، يخوّف كفار مكة لئلا يُكذّبوا بمحمد ﷺ، أي: فاحذروا -يا أهل مكة- أن نَفعل بكم كما فَعلنا بالقُرون الأولى، ثم قال: <span class="qpc-hafs">﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالبعث{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,19,""
