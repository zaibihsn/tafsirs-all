  70,21,""
  70,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلۡمُصَلِّینَ ۝٢٢ ٱلَّذِینَ هُمۡ عَلَىٰ صَلَاتِهِمۡ دَاۤىِٕمُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٨١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عبد الرحمن- <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: على مواقيتها{1}. (١٤/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١١<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأَجْدع الهَمداني</span>، مثله{2}. (١٤/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٢<span class="dash">-</span></span> عن <span class="name-1">عِمران بن حُصَيْن</span> -من طريق أبي الأسود- <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: الذي لا يَلتفتُ في صلاته{3}. (١٤/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٣<span class="dash">-</span></span> عن <span class="name-1">عُقبة بن عامر</span> -من طريق أبي الخير- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: هم الذين إذا صَلَّوْا لم يَلتفِتوا{4}. (١٤/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٤<span class="dash">-</span></span> عن أبي الخير، أنّ <span class="name-1">عُقبة بن عامر</span> قال لهم: مَن <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>؟ قلنا: الذين لا يَزالون يُصلُّون. فقال: لا، ولكن الذين إذا صَلَّوا لم يَلتفِتوا عن يمين وشمال{5}<span class=comment-ref>٦٨٠١</span>. (١٤/٦٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٠١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/١٣٣ بتصرف) على هذا القول بقوله: «<span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿قد أفلح المؤمنون الذين هم في صلاتهم خاشعون﴾</span> [المؤمنون:١-٢]، ومنه: الماء الدائم، أي: الساكن الراكد».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٤٠٧).</p><p>وساق <u>ابنُ القيم</u> (٣/١٩٧) قول عُقبة، ثم <span class="comment-type-4">علَّق</span> بقوله: «قلتُ: هما أمران: الدوام عليها، والمداومة عليها، فهذا الدوام والمداومة في قوله تعالى: <span class="qpc-hafs">﴿والذين هم على صلاتهم يحافظون﴾</span>». ثم <span class="comment-type-4">قال</span>: «وفُسِّر الدوام: بسكون الأطراف والطمأنينة».</div></p><p><div></p><p><p><span class="item-no">٧٨٨١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span>، سُئل عن قول الله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>. قال: يُداوم عليها، ولا يَدَعها، ويُداوم على مواقيتها وحدودها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٦<span class="dash">-</span></span> عن <span class="name-2">أبي سَلمة بن عبد الرحمن</span>، عن عائشة، قالت: قال رسول الله ﷺ: «<b>خذوا من العمل ما تُطيقون؛ فإنّ الله لا يَملّ حتى تَملّوا</b>». قالت: وكان أحب الأعمال إلى رسول الله ﷺ ما دام عليه وإن قلّ، وكان إذا صلّى صلاة دام عليها. قال أبو سَلمة: قال الله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>{7}. (١٤/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم التيميّ</span>، في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: المكتوبة{2}. (١٤/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم [النخعي]</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: الصلوات الخمس{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد بن عبد الرحمن بن جَسّاسٍ- <span class="qpc-hafs">﴿على صلاتهم دائمون﴾</span>، قال: على مواقيتها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span> يَدُومون عليها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلّا المُصَلِّينَ الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: ذُكر لنا: أنّ دانيال نَعتَ أُمّة محمد ﷺ، فقال: يُصَلُّون صلاة لو صَلّاها قوم نوح ما أُغرقوا، أو عاد ما أُرسلتْ عليهم الريح العقيم، أو ثمود ما أخذتْهم الصّيحة. قال قتادة: فعليكم بالصلاة؛ فإنها خُلُقٌ من أخلاق المؤمنين حسن{12}. (١٤/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استأنف فقال: <span class="qpc-hafs">﴿إلّا المُصَلِّينَ﴾</span> فليسوا كذلك، ثم نَعتَهم الله تعالى فقال: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ﴾</span> يعني: الصلوات الخمس <span class="qpc-hafs">﴿دائِمُونَ﴾</span> بالليل والنهار، لا يَدَعونها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</span>، قال: هؤلاء المؤمنون الذين مع النبي ﷺ على صلاتهم دائمون{14}<span class=comment-ref>٦٨٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٠٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٧) أنّ الجمهور على أنّ المعنى: مواظبون قائمون لا يَملُّون في وقت من الأوقات فيتركونها. ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا في المكتوب، وأما النافلة فالدوام عليها الإكثار منها بحسب الطاقة، <span class="mustanad">وقد قال</span> ﷺ: «<b>أحبّ العمل إلى الله ما داوم عليه صاحبه</b>»».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/٣٩٥) أنّ السلف فسَّروا الدائم على الصلاة بالمُحافِظ على أوقاتها، وبالدائم على أفعالها بالإقبال عليها. ثم <span class="comment-type-4">علَّق</span> بقوله: «والآية <span class="mustanad">تعمّ</span> هذا وهذا، فإنه قال: <span class="qpc-hafs">﴿على صلاتهم دائمون﴾</span>، والدائم على الفعل هو المُديم له الذي يفعله دائمًا، فإذا كان هذا فيما يفعل في الأوقات المتفرقة، هو أن يَفعله كلّ يوم بحيث لا يَفعله تارة ويتركه أخرى، وسُمّي ذلك دوامًا عليه، فالدوام على الفعل الواحد المتصل أولى أن يكون دوامًا وأن تتناول الآية ذلك، وذلك يدل على وجوب إدامة أفعالها؛ لأن الله ﷿ ذمّ عموم الإنسان، واستثنى المُداوِم على هذه الصفة، فتاركُ إدامة أفعالها يكون مذمومًا من الشارع، والشارع لا يذمّ إلا على ترْك واجب أو فِعْل محرم».</div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١/٣١٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٢/٤٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٥ (٣١٨).أخرجه ابن خزيمة ٢/٤٣٧-٤٣٨ (١٢٨٣)، وابن حبان ٢/٦٧-٦٨ (٣٥٣)، ٤/٤٤٦-٤٤٧ (١٥٧٨) واللفظ له، وابن جرير ٢٣/٢٦٩. وأصل الحديث في البخاري ٧/١٥٥ (٥٨٦١)، ٨/٩٨ (٦٤٦٥)، ومسلم ١/٥٤٠ (٧٨٢).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٦٨، وعنه في رواية بلفظ: المكتوبة.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/١٣٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٦-.أخرجه ابن جرير ٢٣/٢٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٨.
  70,23,""
  70,23,""
  70,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤ لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝٢٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٨٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن بن محمد</span>: أنّ النبي ﷺ بَعثَ سَرِيّة، فغنموا، وفُتح عليهم، فجاء قوم لم يشهدوا، فنَزلت: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٨٢٥<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>يا أنس، ويل للأغنياء مِن الفقراء يوم القيامة، يقولون: ربّنا، ظلمونا حقوقنا التي فَرضتَ لنا عليهم. فيقول: وعزّتي وجلالي، لأقرِّبنكم ولأُبعّدنهم</b>». قال: وتلا رسول الله ﷺ: <b><span class="qpc-hafs">﴿والذين فِي أمْوالِهِمْ حَقٌّ معلوم لِلسّائِلِ والمَحْرُومِ﴾</span></b>{2}. (١٣/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عليّ- في قوله: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span>، يقول: هو سوى الصّدقة يَصل بها رَحِمه، أو يَقري بها ضيفًا، أو يَحمل بها كَلًّا، أو يُعين بها محرومًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٧<span class="dash">-</span></span> عن قزعة: أن <span class="name-1">ابن عمر</span> سُئِل عن قوله: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span> أهي الزَّكاة؟ فقال: إنّ عليك حقوقًا سوى ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span>، في قوله: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾</span>، قال: كانوا إذا خَرجَت الأُعطية أُعطوا منها{5}. (١٤/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- في قوله: <span class="qpc-hafs">﴿فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾</span>، قال: سوى الزَّكاة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span>، قال: الزَّكاة المفروضة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣١<span class="dash">-</span></span> عن <span class="name-3">زياد بن أبي مريم</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿حق معلوم﴾</span>، قال: الزَّكاة{8}<span class=comment-ref>٦٨٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٠٣</span> اختُلف في المراد بالحق المعلوم على قولين: <b>الأول</b>: أنه الزَّكاة المفروضة. <b>الثاني</b>: أنه حقٌّ سوى الزَّكاة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/٤٠٨) -<span class="mustanad">مستندًا إلى أحوال النزول</span>- القول الثاني الذي قاله ابن عمر، ومجاهد، والنَّخَعي، فقال: «هو الأصحُّ في هذه الآية؛ لأنّ السورة مكّيّة، وفرْض الزَّكاة وبيانها إنما كان بالمدينة».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٨٣٢<span class="dash">-</span></span> عن خالد بن أبي عمران، قال: سألتُ <span class="name-2">القاسم [بن محمد]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣٣<span class="dash">-</span></span> و<span class="name-2">سالم [بن عبد الله بن عمر]</span> عن قول الله: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span>. فقالا: المعلوم منسوخة، وكلّ صَدقة في القرآن منسوخة، نَسَخَتْها هذه الآية: <span class="qpc-hafs">﴿إنَّما الصَّدَقاُت لِلْفُقَراءِ والـمَساكِينِ﴾</span> إلى آخر الآية [التوبة:٦٠]. قالا: والمحروم مُحارَف في الرزق والتجارة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٨٣٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span> -من طريق الأعمش- قال: في المال حقٌّ سوى الزَّكاة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣٥<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق بيان- قال: إنّ في المال حقًّا سوى الزَّكاة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ﴾</span>{12} - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٨٣٦<span class="dash">-</span></span> عن إبراهيم النَّخَعي: أنّ ناسًا قدموا على <span class="name-1">علي [بن أبي طالب]</span> ﵁ الكوفة بعد وقْعة الجمل، فقال: اقسِموا لهم. وقال: هذا المحروم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣٧<span class="dash">-</span></span> عن أبي قِلابة عبد الله بن زيد الجرمي، قال: جاء سَيلٌ باليمامة، فذَهب بمال رجل، فقال <span class="name-1">رجل من أصحاب النبي ﷺ</span>: هذا المحروم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قيس بن كُركُم- في قوله: <span class="qpc-hafs">﴿لِلسّائِلِ والمَحْرُومِ﴾</span>، قال: السائل: الذي يسأل. والمحروم: المُحارَف الذي ليس له في الإسلام سهم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٣٩<span class="dash">-</span></span> عن أبي بشر، قال: سألتُ <span class="name-2">سعيد بن جُبَير</span> عن المحروم، فلم يَقُلْ فيه شيئًا. قال: وقال <span class="name-2">عطاء</span>: هو المحدود{16} المُحارَف{17}. (١٣/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span> -من طريق منصور- قال: المحروم: الذي لا فَيء له في الإسلام، وهو مُحارَف في الناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span> -من طريق قتادة بن دعامة-: المحروم: المُحارَف{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن بن محمد</span>: أنّ النبي ﷺ بَعثَ سَرِيّة، فغنموا، وفُتح عليهم، فجاء قومٌ لم يشهدوا، فنَزلت: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span> يعني: هؤلاء{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبى نجيح- قال: المحروم: الذي لا يُهدى له شيء، وهو مُحارَف{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حُصَيْن- قال: قال: السائل: الذي يسألك. والمَحْرُوم: الذي لا يَنمِي له مال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حُسين بن قيس- قال: المحروم: الرجل كانت له مَعيشة، فأُصيب بها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق ابن عَوْن- قال: أعياني أنْ أعلم ما المحروم{14}<span class=comment-ref>٦٨٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٠٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٤٠٨) على قول الشعبي بقوله: «يرحم الله الشعبي فإنه في هذه المسألة محروم، ولو أخذه اسم جنس فيمن عسُرت مطالبه بان له، وإنما كان يطلبه نوعًا مخصوصًا كالسائل».</div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٧<span class="dash">-</span></span> عن خالد بن أبي عمران، عن <span class="name-2">القاسم [بن محمد]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٨<span class="dash">-</span></span> و<span class="name-2">سالم [بن عبد الله بن عمر]</span> في قول الله: قالا: المحروم مُحارَف في الرزق والتجارة{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٤٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لِلسّائِلِ والمَحْرُومِ﴾</span>، السائل: المسكين الذي يسأل عند الحاجة. والمَحْرُوم: الفقير الذي لا يَسأل على حال، فحُرم أن يُعطى عن المسألة كما يُعطى السائل، وإنْ أُعطي شيئًا قَبل{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لِلسّائِلِ والمَحْرُومِ﴾</span>، قال: السائل: الذي يسأل بكَفّه. والمَحْرُوم: المُتعفِّف، ولكليهما عليك حقٌّ، يا ابن آدم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٥١<span class="dash">-</span></span> عن <span class="name-2">نافع</span> -من طريق أيوب- قال: المحروم: هو المُحارَف{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٥٢<span class="dash">-</span></span> عن <span class="name-3">زياد بن أبي مريم</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿والمحروم﴾</span>: الذي لم يُبسَط له في المَعيشة، ولم يُعط باب المسألة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾</span> يعني: مفروض <span class="qpc-hafs">﴿لِلسّائِلِ﴾</span> يعني: المسكين <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span> يعني: الفقير الذي لا سهم له في الخُمس ولا الفَيء{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span>، قال: المحروم: المُصاب ثمره وزَرْعه. وقرأ: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ﴾</span> حتى بَلغ: <span class="qpc-hafs">﴿مَحْرُومُونَ﴾</span> [الواقعة:٦٣-٦٧]. وقال أصحاب الجنة: <span class="qpc-hafs">﴿إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [القلم:٢٦-٢٧]{14}<span class=comment-ref>٦٨٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٠٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٨) في المحروم أقوالًا: <b>الأول</b>: مَن احترق زَرْعه. <b>الثاني</b>: مَن ماتتْ ماشيته. و<span class="comment-type-4">علَّق</span> عليهما بقوله: «وهذه أنواع الحرمان، لا أنّ الاسم يلزم هذا خاصّة». <b>الثالث</b>: أنه الكلب. ونسبه لعمر بن عبد العزيز. و<span class="comment-type-1">وجّهه</span> بقوله: «أراد -والله أعلم- أن يُعطي مثالًا من الحيوان ذي الكبد الرّطبة لما فيه من الأجر حسب الحديث المأثور».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٧٤.أخرجه الطبراني في الأوسط ٥/١٠٧-١٠٨ (٤٨١٣)، والثعلبي ٩/١١٣. وعزاه السيوطي إلى ابن مردويه. والآية وردت في المصدر دون واو في أولها.</p><p>قال الطبراني: «لم يرو هذا الحديث عن أنس إلا الحارث بن النعمان». وقال المنذري في الترغيب والترهيب ١/٣٠٦-٣٠٧ (١١٣٣): «من رواية الحارث بن النعمان؛ قال أبو حاتم: ليس بقوي. وقال البخاري: منكر الحديث». وقال الهيثمي في المجمع ٣/٦٢ (٤٣٢٥): «رواه الطبراني في الصغير والأوسط، فيه الحارث بن النعمان، وهو ضعيف». وقال المناوي في التيسير ٢/٤٨٤: «إسناد ضعيف».أخرجه ابن جرير ٢٣/٢٧٠.أخرجه ابن جرير ٢٣/٢٧٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٧١.أخرجه ابن جرير ٢٣/٢٧٠.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٨ (٢٢٩٨).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٨٦ (١٨٦).أخرجه ابن جرير ٢٣/٢٧٠.أخرجه ابن جرير ٢٣/٢٧٠.تقدمت الآثار في تفسير الآية عند نظيرها قوله تعالى: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُومِ﴾</span> [الذاريات:١٩]، قال ابن جرير ٢٣/٢٧١: «واختلفوا أيضًا في معنى المحروم في هذا الموضع نحو اختلافهم فيه في الذاريات، وقد ذكرنا ما قالوا فيه هنالك، ودلّلنا على الصحيح منه عندنا، غير أنّا نذكر بعض ما لم نذكر من الأخبار هنالك». ثم ذكر بعض ما ذكر أعلاه.أخرجه ابن جرير ٢٣/٢٧٣.أخرجه ابن جرير ٢٣/٢٧٥.أخرجه ابن جرير ٢٣/٢٧١، ٢٧٢، ٢٧٣، ومن طريق مجاهد، وعلي، وسعيد بنحوه.يقال: فلان مَجْدُود، وفلان مَحْدُود، والمجدود الذي يوافقه الجد، والمحدود المحروم. تفسير العلامة السمعاني ٦/٤٨.أخرجه ابن جرير ٢٣/٢٧٢.أخرجه ابن جرير ٢٣/٢٧٣.أخرجه ابن جرير ٢٣/٢٧٢.أخرجه ابن جرير ٢٣/٢٧٤.أخرجه ابن جرير ٢٣/٢٧٢.أخرجه ابن جرير ٢٣/٢٧٤.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٩ (٢٣٠٠).أخرجه ابن جرير ٢٣/٢٧٥.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٨٦ (١٨٦). وتقدم بتمامه في النسخ في الآية السابقة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٦.أخرجه ابن جرير ٢٣/٢٧٥.أخرجه ابن جرير ٢٣/٢٧٣.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٨ (٢٢٩٨).تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٧٥.
