  70,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُبَصَّرُونَهُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span>، قال: يَعْرِف بعضهم بعضًا ويَتعارفون، ثم يَفرّ بعضهم من بعض. يقول: <span class="qpc-hafs">﴿لكل امرئ منهم يومئذ شأن يغنيه﴾</span> [عبس:٣٧]{1}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span>، قال: المؤمنون يُبصرون الكافرين{2}. (١٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span> قال: يُعَرَّفونهم؛ يُعلَّمون، واللهِ، ليَعرفنّ يوم القيامة قومٌ قومًا، وأناسٌ أناسًا، <span class="qpc-hafs">﴿يَوَدُّ المُجْرِمُ لَوْ يَفْتَدِي﴾</span> الآيةَ قال: يتمنّى يوم القيامة لو يَفتدي بالأَحبّ فالأَحبّ، والأقرب فالأقرب، من أهله وعشيرته؛ لشدّة ذلك اليوم{2}. (١٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span> يعرفونهم؛ أما المؤمن فببياض وجهه، وأما الكافر فبسواد وجهه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span> يقول: يعرفونهم، ولا يُكلّمونهم، وذلك قوله: <span class="qpc-hafs">﴿فهم لا يتساءلون﴾</span> [القصص:٦٦]، <span class="qpc-hafs">﴿خاشِعَةً أبْصارُهُمْ﴾</span> [القلم:٤٣] خافضة أبصارهم ذليلة عند مُعاينة النار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span>، قال: يُبصرون الذين أضلُّوهم في الدنيا في النار{6}<span class=comment-ref>٦٧٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٦</span> اختُلف في الذين عُنوا بالهاء والميم في قوله: <span class="qpc-hafs">﴿يبصرونهم﴾</span> على أقوال: <b>الأول</b>: أنه عُني بذلك: الأقرباء؛ أنهم يَعرفون أقرباءهم، ويَعرف كلّ إنسان قريبه، فذلك تبصير الله إياهم. <b>الثاني</b>: أنّ المؤمنين يُبصرون الكافرين. <b>الثالث</b>: أنّ الكفار الذين كانوا أتباعًا لآخرين في الدنيا على الكفر يُعرّفون المتبوعين في النار.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٢٥٩) -<span class="mustanad">مستندًا إلى السياق</span>- القول الأول الذي قاله ابن عباس، وقتادة، فقال: «لأنّ ذلك أشبهها بما دلّ عليه ظاهر التنزيل، وذلك أنّ قوله: <span class="qpc-hafs">﴿يبصرونهم﴾</span> تلا قوله: <span class="qpc-hafs">﴿ولا يسأل حميم حميما﴾</span>؛ فلأن تكون الهاء والميم من ذكرهم أشبه منها بأن تكون مِن ذِكْر غيرهم».</div></p><p><h3><span class="qpc-hafs">﴿یَوَدُّ ٱلۡمُجۡرِمُ لَوۡ یَفۡتَدِی مِنۡ عَذَابِ یَوۡمِىِٕذِۭ بِبَنِیهِ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَوَدُّ المُجْرِمُ﴾</span> يعني: الكافر <span class="qpc-hafs">﴿لَوْ يَفْتَدِي مِن عَذابِ يَوْمِئِذٍ﴾</span> يوم القيامة <span class="qpc-hafs">﴿بِبَنِيهِ﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٥٧-٢٥٨.أخرجه ابن جرير ٢٣/٢٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٣٧، وتفسير البغوي ٨/٢٢٢.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٥٨.تفسير مقاتل بن سليمان ٤/٤٣٧.
  70,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَصَـٰحِبَتِهِۦ وَأَخِیهِ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وصاحِبَتِهِ﴾</span> يعني: امرأته{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وصاحِبَتِهِ﴾</span>، قال: الصاحبة الزوجة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٠.
  70,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفَصِیلَتِهِ ٱلَّتِی تُـٔۡوِیهِ ۝١٣ وَمَن فِی ٱلۡأَرۡضِ جَمِیعࣰا ثُمَّ یُنجِیهِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وفَصِيلَتِهِ﴾</span>، قال: قبيلته{1}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وفَصِيلَتِهِ﴾</span>، قال: عشيرته{2}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن</span> <span class="name-2">كعب القُرَظيّ</span>، <span class="qpc-hafs">﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾</span>، قال: قبيلته التي يَنتسب إليها{2}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾</span> يعني: رهطه وفَخذه الأدنى الذي يساوى إليهم، <span class="qpc-hafs">﴿ومَن فِي الأَرْضِ جَمِيعًا﴾</span> مِن شيء، <span class="qpc-hafs">﴿ثُمَّ يُنْجِيهِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٥٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾</span>، قال: فصيلته: عشيرته{5}<span class=comment-ref>٦٧٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٥) أنّ الفصيلة -في هذه الآية-: قرابة الرجل الأدنون. مثال ذلك: بنو هاشم مع النبي ﷺ. وأنها أيضًا في كلام العرب: الزوجة. ثم قال: «ولكن ذكْر الصاحبة في هذه الآية لم يُبْق في معنى الفصيلة إلا الوجه الذي ذكرناه».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٦٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٠.
  70,14,""
  70,12,""
  70,13,""
  70,14,""
  70,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّاۤۖ إِنَّهَا لَظَىٰ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿كَلّا﴾</span> لا يُنجيه ذلك لو افتَدى بهذا كلّه، ثم استأنف فقال: <span class="qpc-hafs">﴿إنَّها لَظى﴾</span> يعني بلَظى: استطالتها وقُدرتها عليهم، يعني: النار{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٧.
  70,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَزَّاعَةࣰ لِّلشَّوَىٰ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- في قوله: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: تَنزع أُمّ الراس{1}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span> يعني: الجلود والهام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>: للعَصب والعَقب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٤<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>: <span class="qpc-hafs">﴿نَزّاعَةً لِّلشَّوى﴾</span> لمحاسن وجهه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٥<span class="dash">-</span></span> قال <span class="name-2">مُرّة</span>: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span> للأعضاء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: فَروة الرأس{6}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٧<span class="dash">-</span></span> عن إبراهيم بن المُهاجر، قال: سألتُ <span class="name-2">سعيد بن جُبَير</span> عن قوله: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>. فلم يُخبر، فسألتُ عنها <span class="name-2">مجاهد بن جبر</span>، فقلتُ: اللحم دون العظم؟ فقال: نعم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: الشّوى: الأطراف{8}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: لجلود الرأس{9}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>: تَبري اللحم والجلد عن العظم، حتى لا تَترك منه شيئًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرّة بن خالد- <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: للهام، تَحرق كلّ شيء منه، ويَبقى فؤاده يصيح{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: للحم السّاقين{12}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: الأطراف{6}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: لِهامته، ومَكارم وجهه{14}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٥<span class="dash">-</span></span> عن <span class="name-2">ثابت البُناني</span> -من طريق جعفر- <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: لِمَكارِم وجه ابن آدم{15}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿نَزّاعَةً لِّلشَّوى﴾</span> لأُمّ الرأس، تأكل الدِّماغ كلّه، ثم يعود كما كان، ثم تعود لأَكْله، فذلك دَأْبها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، يقول: تَنزع النارُ الهامةَ، والأطرافَ؛ فلا تَبْقى{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٨<span class="dash">-</span></span> عن <span class="name-3">قُرّة بن خالد</span>، <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: نزّاعة للهام، تحرق كلّ شيء منه، ويبقى فؤاده نضيجًا{18}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٧٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿نَزّاعَةً لِلشَّوى﴾</span>، قال: الشوى: الآراب العظام، ذاك الشوى{19}<span class=comment-ref>٦٧٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٢٦١) أنّ «الشوى»: جمع شواة، وهي من جوارح الإنسان ما لم يكن مَقتلًا، يقال: رمى فأشوى: إذا لم يُصب مقتلًا، ثم <span class="comment-type-4">علَّق</span> بقوله: "فربما وصف الواصف بذلك جِلدة الرأس، <span class="mustanad">كما قال الأعشى</span>:</p><p>قالَتْ قُتَيْلَةُ ما لَهُ قَدْ جُلِّلَتْ شَيْبًا شَواتُهْ؟</p><p>وربما وصف بذلك الساق كقولهم في صفة الفرس:</p><p>عبْل الشوى نهد الجزاره</p><p>يعني بذلك: قوائمه، وأصل ذلك كله ما وصفت".</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٤٠٥-٤٠٦)، و<span class="comment-type-4">كذا</span> قال <u>ابنُ القيم</u> (٣/١٩٦).</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٦٢.أخرجه ابن جرير ٢٣/٢٦٢.تفسير الثعلبي ١٠/٣٨.تفسير الثعلبي ١٠/٣٨، وتفسير البغوي ٨/٢٢٣.تفسير الثعلبي ١٠/٣٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٢.أخرجه ابن أبي شيبة ١٣/١٦٨.أخرجه ابن جرير ٢٣/٢٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٦٣، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٥)-.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٦٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٥-.أخرجه ابن أبي شيبة ١٣/١٦٨، وابن جرير ٢٣/٢٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٣. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٩ (١٣٦)-. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٣٨، وتفسير البغوي ٨/٢٢٣.تفسير مقاتل بن سليمان ٤/٤٣٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٦٤.
  70,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَدۡعُوا۟ مَنۡ أَدۡبَرَ وَتَوَلَّىٰ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٨٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾</span> تدعو الكافرين والمنافقين بأسمائهم بلسان فصيح، ثم تَلتَقطهم كما يَلتَقط الطيرُ الحَبَّ{1}<span class=comment-ref>٦٧٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٦) أنه على هذا القول فدعاء النار حقيقة، ثم <span class="comment-type-4">نَقل</span> عن الخليل بن أحمد القول بأنّ نداءها عبارة عن حِرْصها عليهم، واستدنائها لهم، وما تُوقعه من عذابها. ونَقل عن ثعلب القول بأنّ: <span class="qpc-hafs">﴿تَدْعُو﴾</span> معناه: تُهلك، ثم <span class="comment-type-4">علَّق</span> بقوله: «<span class="mustanad">تقول العرب</span>: دعاك الله، أي: أهلكك، وحكاه الخليل عن العرب».</div></p><p><div></p><p><p><span class="item-no">٧٨٧٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾</span>، قال: عن الحق{2}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿تَدْعُو مَن أدْبَرَ﴾</span> قال: عن طاعة الله، <span class="qpc-hafs">﴿وتَوَلّى﴾</span> قال: عن كتاب الله، وعن حقّه{3}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَدْعُوا مَن أدْبَرَ﴾</span> يعني: تدعو النار يوم القيامة، تقول: إلَيَّ أهلي. فهذا دعاؤها لـــ<span class="qpc-hafs">﴿مَن أدْبَرَ﴾</span> عن الإيمان، <span class="qpc-hafs">﴿وتَوَلّى﴾</span> يقول: وأَعرَض عنه إلى الكفر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٨٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾</span>، قال: ليس لها سلطان إلا على هوان مَن كَفر وتَولّى وأَدبَر عن الله، فأمّا مَن آمن بالله ورسوله فليس لها عليه سلطان{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٣٨، وتفسير البغوي ٨/٢٢٣.أخرجه ابن جرير ٢٣/٢٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٦٤. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٤.
  70,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَمَعَ فَأَوۡعَىٰۤ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وجَمَعَ فَأَوْعى﴾</span>، قال: جمع المال{1}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجَمَعَ فَأَوْعى﴾</span>، قال: كان جَموعًا للخبيث{2}. (١٤/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وجَمَعَ فَأَوْعى﴾</span>، يعني: فأَكثر مِن المال، وأَمسَك، فلم يُؤدّ حقّ الله فيه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَمَعَ فَأَوۡعَىٰۤ ۝١٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٨٨<span class="dash">-</span></span> عن الحكم، قال: كان <span class="name-2">عبد الله بن عُكَيم</span> لا يَربط كِيسه، قال: سمعتُ الله يقول: <span class="qpc-hafs">﴿وجَمَعَ فَأَوْعى﴾</span>{4}. (١٤/٦٩٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٦٥. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن سعد ٦/١١٤، وابن جرير ٢٣/٢٦٥.
  70,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: نَزَلَتْ في أبي جهل بن هشام{1}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</span>، يعني: ضَجرًا، فهو أُمَيّة بن خلف الجُمَحي{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: الشَّرِه{3}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٢<span class="dash">-</span></span> عن عكرمة، قال: سُئل <span class="name-1">ابن عباس</span> عن الهَلُوع، فقال: هو كما قال الله؛ إذا مسه الشر كان جَزُوعًا، وإذا مَسَّهُ الخَيْر كان مَنُوعًا، فهو الهَلُوع{4}. (١٤/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</span>، قال: هو الذي قال الله: <span class="qpc-hafs">﴿إذا مَسَّهُ الشَّرُّ جَزُوعًا وإذا مَسَّهُ الخَيْر مَنُوعًا﴾</span>. ويقال: الهَلُوع: هو الجَزُوع الحريص، وهذا في أهل الشّرك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي صالح- في قوله: <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: الحريص على ما لا يحل له{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</span>. قال: ضَجورًا جَزوعًا، نَزَلَتْ في أبي جهل بن هشام. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ بِشر بن أبي خازم وهو يقول:</p><p>لا مانعًا لليتيم نِحْلته ولا مُكِبًا بخلْقه هلِعًا؟{7}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر بن أبي المُغيرة- في قوله: <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: شَحيحًا جَزُوعًا{8}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿منوعا﴾</span> شرِهًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: الذي لا يَشبع مِن جَمْع المال{3}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٩٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿إنَّ الإنْسانَ﴾</span> يعني: الكافر <span class="qpc-hafs">﴿خُلِقَ هَلُوعًا﴾</span> يقول: هو بخيلٌ، مَنوعٌ للخير، جَزوعٌ إذا نَزل به البلاء، فهذا الهَلُوع{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: الضَّجِر{8}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق حُميد- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</span>. قال: اقرأ ما بعدها. فقرأ: <span class="qpc-hafs">﴿إذا مَسَّهُ الشَّرُّ جَزُوعًا وإذا مَسَّهُ الخَيْر مَنُوعًا﴾</span>. قال: هو هكذا، خُلِق هكذا{13}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق معمر-: <span class="qpc-hafs">﴿هَلُوعًا﴾</span> هو الشَّرِه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٣<span class="dash">-</span></span> عن منصور بن زاذان، عن <span class="name-2">الحسن</span> [<span class="name-2">البصري</span>]، في قوله: <span class="qpc-hafs">﴿إن الإنسان خلق هلوعا﴾</span>، قال: بخيلًا بالخير{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٤<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿منوعا﴾</span> عَجُولًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: جَزُوعًا{17}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٦<span class="dash">-</span></span> عن <span class="name-2">حُصَيْن بن عبد الرحمن</span> -من طريق شعبة- <span class="qpc-hafs">﴿هَلُوعًا﴾</span>، قال: الحريص{18}. (١٤/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</span> يعني: ضَجِرًا، فهو أُمَيّة بن خلف الجُمحي، ثم نَعتَه، فقال: <span class="qpc-hafs">﴿إذا مَسَّهُ الشَّرُّ﴾</span> يقول: إذا أصابه <span class="qpc-hafs">﴿جَزُوعًا﴾</span>، <span class="qpc-hafs">﴿وإذا مَسَّهُ الخَيْر﴾</span> يعني: المال <span class="qpc-hafs">﴿مَنُوعًا﴾</span> فمَنع وبَخِل بحقّ الله تعالى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٨٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</span>، قال: الهَلُوع: الجَزُوع{20}<span class=comment-ref>٦٨٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٠٠</span> <span class="comment-type-4">نَقل</span> <u>ابنُ تيمية</u> (٦/٣٩٤) عن الجوهري القول بأنّ الهَلَع: أفحَش الجَزع. وعن غيره أنه في اللغة: أشدّ الحِرص وأسوأ الجَزع. وساق قول النبي ﷺ: «<b>شرُّ ما في المرء شُحٌّ هالِع، وجُبْنٌ خالع</b>». ثم <span class="comment-type-4">علَّق</span> بقوله: «ولهذا كان كلام السلف في تفسيره يتضمن هذه المعاني». وساق الآثار.</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٨٠٩<span class="dash">-</span></span> عن عليٍّ مرفوعًا: «<b>يُكتب أنين المريض؛ فإن كان صابرًا كان أنينه حسنات، وإن كان جَزوعًا كُتب هَلُوعًا لا أجْر له</b>»{21}. (١٤/٦٩٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن الطستي في مسائل نافع بن الأزرق ص٢٠٥ (١٧٤)، من طريق عيسى بن دأب، عن حميد الأعرج، وعبد الله بن أبي بكر بن محمد، عن أبيه، عن ابن عباس به.</p><p>وسنده شديد الضعف؛ فيه عيسى بن دأب، متروك. كما في الميزان ٣/٣٢٧. وفيه أيضًا حميد الأعرج القاص، قال عنه ابن حجر في التقريب (١٥٦٦): «ضعيف»تفسير مقاتل بن سليمان ٤/٤٣٧.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن جرير، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٢٦٦.تفسير الثعلبي ١٠/٣٩.أخرجه الطستي -كما في الإتقان ٢/٩٧-٩٨-.أخرجه ابن جرير ٢٣/٢٦٦. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٣٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٦.أخرجه ابن جرير ٢٣/٢٦٦. وعزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣١٧.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٥ (٢٢٩٤).تفسير الثعلبي ١٠/٣٩.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٦٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٧.أخرجه أبو نعيم في أخبار أصبهان ١/٣٣٠، من طريق القاسم بن+ بهرام، عن أبي إسحاق، عن الحارث، عن علي به. وأورده الديلمي في الفردوس ٥/٥٣٧ (٩٠١٤).</p><p>وسنده ضعيف؛ فيه القاسم بن بهرام، قال عنه الذهبي في الميزان ٣/٣٦٩: «له عجائب، وهّاه ابن حبان وغيره».
