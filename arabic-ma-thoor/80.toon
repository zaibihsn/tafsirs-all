  80,18,""
  80,19,""
  80,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱلسَّبِیلَ یَسَّرَهُۥ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٤٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- في قوله: <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>: يعني بذلك: خروجه مِن بطن أمه يسّره له{1}. (١٥/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٨٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، مثله{2}. (١٥/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>-من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: هو كقوله: <span class="qpc-hafs">﴿إنّا هَدَيْناهُ السَّبِيلَ إمّا شاكِرًا وإمّا كَفُورًا﴾</span> [الإنسان:٣] الشقاء والسعادة{3}. (١٥/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٨٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: خروجه من الرَّحِم{2}. (١٥/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: سبيل الخير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: خروجه مِن الرَّحِم{6}. (١٥/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: خروجه من بطن أمه{7}. (١٥/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سفيان- <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: خروجه من بطن أمه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٩٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، يعني: طريق الحق والباطل{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، يعني: هوّن طريقه في الخروج مِن بطن أمه، يقول: يسّره للخروج، أفلا يعتبر فيُوَحِّد الله في حُسن خَلْقه فيشكر الله في نِعمه!{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٤٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</span>، قال: هداه للإسلام والدين، يسّره له، وأعلمه به، والسبيل سبيل الإسلام{11}<span class=comment-ref>٧٠٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٣٩</span> اختُلف في السبيل الذي يسّره الله لها على قولين: <b>الأول</b>: أنها خروجه من بطن أمه. <b>الثاني</b>: أنها طريق الحق والباطل.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/١١٣) -<span class="mustanad">مستندًا إلى السياق</span>- القول الأول، وعلل ذلك بقوله: «وإنما قلنا ذلك أولى التأويلين بالصواب لأنه أشبههما بظاهر الآية، وذلك أنّ الخبر من الله قبلها وبعدها عن صفته؛ خَلْقه، وتدبيره جسمه، وتصريفه إياه في الأحوال، فالأولى أن يكون أوسط ذلك نظير ما قبله وما بعده».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٤/٢٥٠) القول الثاني بقوله: «وهذا هو الأرجح». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/١١١.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١١٢، وكذلك من طريق منصور أيضًا، وأخرجه عبد الرزاق ٢/٣٤٨ من طريق ابن جُرَيْج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١١٢، كما أخرجه عبد الرزاق ٢/٣٤٨، من طريق معمر، ومثله ابن جرير.أخرجه ابن جرير ٢٤/١١١. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤٨، وابن جرير ٢٤/١١٢، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١١١.تفسير البغوي ٨/٣٣٧.تفسير مقاتل بن سليمان ٤/٥٩٢.أخرجه ابن جرير ٢٤/١١٣.
  80,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٤٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ أماتَهُ﴾</span> عند أجَله، <span class="qpc-hafs">﴿فَأَقْبَرَهُ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ إِذَا شَاۤءَ أَنشَرَهُۥ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٤٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ إذا شاءَ أنْشَرَهُ﴾</span> في الآخرة، يعني: إذا شاء بعثه من بعد موته{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّا لَمَّا یَقۡضِ مَاۤ أَمَرَهُۥ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٤٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لَمّا يَقْضِ ما أمَرَهُ﴾</span>، قال: لا يقضي أحدٌ أبدًا كلَّ ما افتُرِضَ عليه{1}<span class=comment-ref>٧٠٤٠</span>. (١٥/٢٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٤٠</span> لم يذكر <u>ابنُ جرير</u> (٢٤/١١٤) غير قول مجاهد.</p><p>وذكر <u>ابنُ كثير</u> (١٤/٢٥١) قول مجاهد، ونحوه عن الحسن البصري، ثم قال <span class="comment-type-4">معلقًا</span>: «ولم أجد للمتقدمين فيه كلامًا سوى هذا، والذي يقع لي في معنى ذلك -والله أعلم- أن المعنى: <span class="qpc-hafs">﴿ثم إذا شاء أنشره﴾</span> أي: بعثه، <span class="qpc-hafs">﴿كلا لما يقض ما أمره﴾</span> أي: لا يفعله الآن حتى تنقضي المدة، ويفرغ القدر مِن بني آدم ممن كتب تعالى له أن سيوجد منهم، ويخرج إلى الدنيا، وقد أمر به تعالى كونًا وقدرًا، فإذا تناهى ذلك عند الله أنشر الله الخلائق، وأعادهم كما بدأهم. وقد روى ابن أبي حاتم، عن وهْب بن مُنَبِّه، قال: قال عُزير ﵇: قال المَلك الذي جاءني: فإنّ القبور هي بطن الأرض، وإنّ الأرض هي أُمّ الخلق، فإذا خلق الله ما أراد أن يخلق، وتمت هذه القبور التي مدّ الله لها انقطعت الدنيا، ومات مَن عليها، ولفظت الأرض ما في جوفها، وأخرجت القبور ما فيها، وهذا شبيه بما قلنا من معنى الآية، والله ﷾ أعلم بالصواب».</div></p><p><div></p><p><p><span class="item-no">٨١٤٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا﴾</span> لا يؤمن الإنسان بالنشور، ثم استأنف، فقال: <span class="qpc-hafs">﴿لَمّا يَقْضِ ما أمَرَهُ﴾</span> يعني: ما عهد الله إليه أمر الميثاق الأول، يعني: التوحيد، يعني به: آدم ﵇{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١١٤، والفريابي -كما في تغليق التعليق ٤/٣٦٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلۡیَنظُرِ ٱلۡإِنسَـٰنُ إِلَىٰ طَعَامِهِۦۤ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٥٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- في قوله: <span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</span>، قال: إلى خُرْئِهِ{1}. (١٥/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزُّبير</span>، في قوله: <span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</span>، قال: إلى مَدخله، ومَخرجه{2}. (١٥/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، مثله{3}<span class=comment-ref>٧٠٤١</span>. (١٥/٢٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٤١</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٥٤٠) على ما جاء عن مجاهد، وابن الزُّبير، وابن عباس، والحسن، فقال: «وذهب أُبيّ بن كعب، وابن عباس، والحسن، ومجاهد، وغيرهم إلى أن المراد: <span class="qpc-hafs">﴿إلى طَعامِهِ﴾</span> إذا صار رجيعًا؛ ليتأمل حيث تصير عاقبة الدنيا، وعلى أي شيء يتفانى أهلها، وتستدير رحاها، وهذا نظير ما روي عن ابن عمر: أنّ الإنسان إذا أحدث فإنّ ملكًا يأخذ بناصيته عند فراغه، فيردّ بصره إلى نحوه موقفًا له ومعجبًا، فينفع ذلك مَن له عقل».</div></p><p><div></p><p><p><span class="item-no">٨١٥٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</span>، قال: إلى مأكله، ومشربه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>-من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</span>: آية لهم{4}<span class=comment-ref>٧٠٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٤٢</span> لم يذكر <u>ابنُ جرير</u> (٢٤/١١٥) غير قول مجاهد هذا، وقوله من طريق منصور.</div></p><p><div></p><p><p><span class="item-no">٨١٥٠٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</span>، قال: مَلَك يثني رقبة -ابن آدم- إذا جلس على الخلاء؛ لينظر ما يَخرج منه{6}. (١٥/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استأنف ذِكر ما خُلق عليه، فذكر رِزقه ليعتبر، فقال: <span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ﴾</span> يعني: عُتبة بن أبي لهب <span class="qpc-hafs">﴿إلى طَعامِهِ﴾</span> يعني: رِزقه{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب التواضع (٢١٣).عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١١٥.أخرجه ابن جرير ٢٤/١١٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَنَّا صَبَبۡنَا ٱلۡمَاۤءَ صَبࣰّا ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٥٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿أنّا صَبَبْنا الماءَ صَبًّا﴾</span>، قال: المطر{1}. (١٥/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنّا صَبَبْنا الماءَ صَبًّا﴾</span> على الأرض، يعني: المطر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ شَقَقۡنَا ٱلۡأَرۡضَ شَقࣰّا ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٥٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ثُمَّ شَقَقْنا الأَرْضَ شَقًّا﴾</span>، قال: عن النبات{1}. (١٥/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ شَقَقْنا الأَرْضَ شَقًّا﴾</span>، يعني: عن النَّبت والشجر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَنۢبَتۡنَا فِیهَا حَبࣰّا ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٥١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَنْبَتْنا فِيها حَبًّا﴾</span> يعني: الحبوب كلّها{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعِنَبࣰا وَقَضۡبࣰا ۝٢٨ وَزَیۡتُونࣰا وَنَخۡلࣰا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٥١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وقَضْبًا﴾</span>، قال: الفِصفِصة، يعني: القَتّ{1}. (١٥/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥١٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿وقَضْبًا﴾</span>، قال: يعني: الرَّطْبة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥١٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- قال: <span class="qpc-hafs">﴿وقَضْبًا﴾</span> القَضْب: العلف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقَضْبًا﴾</span>، قال: والقَضْب: الفَصافِص{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعِنَبًا وقَضْبًا﴾</span> يعني به: الرّطاب، <span class="qpc-hafs">﴿وزَيْتُونًا﴾</span> يعني: الرَّطْبة التي يُعصر منها الزيت، <span class="qpc-hafs">﴿ونَخْلًا﴾</span>{5}<span class=comment-ref>٧٠٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٤٣</span> <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٨/٥٤١) -<span class="mustanad">مستندًا إلى دلالة العقل</span>- أنّ القَضْب: هو كلّ ما يُقضب ليأكله ابن آدم، فقال: «والذي أقوله إنّ القَضْب هنا: هو كلّ ما يُقضب ليأكله ابن آدم غضًّا من النبات؛ كالبقول والهليون ونحوه، فإنه من المطعوم جزء عظيم، ولا ذِكر له في الآية إلا في هذه اللفظة». و<span class="comment-type-2">انتقد</span> -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- القول بأنه الفَصافِص بقوله: «وهذا عندي ضعيف؛ لأن الفَصافِص هي للبهائم، فهي داخلة في الأبّ». ونقل تعليق ثعلب على قول مَن قال: هو الرَّطْبة. فقال: «وقال أبو عبيدة: القَضْب: الرَّطْبة. قال ثعلب: لأنه يُقضب كلّ يوم».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/١١٦، وابن أبي حاتم -كما في فتح الباري ١٣/٢٧١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١١٦.أخرجه ابن جرير ٢٤/١١٦.أخرجه ابن جرير ٢٤/١١٦.تفسير مقاتل بن سليمان ٤/٥٩٢.
