  3,108,""
  3,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِلَى ٱللَّهِ تُرۡجَعُ ٱلۡأُمُورُ ۝١٠٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٤١٥١<span class="dash">-</span></span> عن <span class="name-2">يحيى بن وثّاب</span> أنّه قرأ كل شيء في القرآن: ‹وإلى اللهِ تَرْجِعُ الأُمُورُ› بنصب التاء، وكسر الجيم{1}. (٣/٧٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِلَى ٱللَّهِ تُرۡجَعُ ٱلۡأُمُورُ ۝١٠٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: ثم قال: يا محمد، لله الخلق كله، السموات كلهن، ومَن فيهن، والأرضون كلهن، ومن فيهن، وما بينهن، مما يعلم ومما لا يعلم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولله ما في السماوات وما في الأرض وإلى الله ترجع الأمور﴾</span>، يعني: تصير أمور العباد إليه في الآخرة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>قرأ ابن عامر وحمزة والكسائي ويعقوب وخلف العاشر بفتح التاء وكسر الجيم حيث وقع في القرآن، وقرأ الباقون بضم التاء وفتح الجيم. انظر: التيسير ص٨٠، والنشر ٢/٢٠٩.أخرجه ابن أبي حاتم ٣/٧٣١.تفسير مقاتل بن سليمان ١/٢٩٤.
  3,110,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُنتُمۡ خَیۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَـٰبِ لَكَانَ خَیۡرࣰا لَّهُمۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> مولى ابن عباس -من طريق ابن جُرَيْج- في الآية، قال: نزلت في ابن مسعود، وعمار بن ياسر، وسالم مولى أبي حذيفة، وأبي بن كعب، ومعاذ بن جبل{1}<span class=comment-ref>١٣٤٥</span>. (٣/٧٢٥)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٥</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٢/٣١٦) على هذا الأثر بقوله: «يريد: ومَن شاكلهم».</div></p><p><div></p><p><p><span class="item-no">١٤١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله سبحانه: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، يعني: خير الناس للناس، وذلك أنّ مالك بن الضَّيف، ووهب بن يهوذا قالا لعبد الله بن مسعود، ومعاذ بن جبل، وسالم مولى أبى حذيفة: إنّ ديننا خير مما تدعونا إليه. فأنزل الله ﷿ فيهم: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُنتُمۡ خَیۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٥٦<span class="dash">-</span></span> عن معاوية بن حَيْدَة، أنه سمع النبي ﷺ، في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> قال: «<b>إنكم تُتِمُّون سبعين أمة، أنتم خيرها وأكرمها على الله</b>»{3}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٧<span class="dash">-</span></span> عن قتادة بن دِعامة، قال: ذُكِر لنا: أن <span class="name-1">عمر بن الخطاب</span> قرأ هذه الآية: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> الآية، ثم قال: يا أيها الناس، مَن سَرَّه أن يكون مِن تلكم الأمة فلْيُؤَدِّ شرط الله منها{4}. (٣/٧٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٨<span class="dash">-</span></span> عن إسماعيل السدي، في الآية، قال: قال <span class="name-1">عمر بن الخطاب</span>: لو شاء الله لقال: أنتم؛ فكنا كلنا، ولكن قال: <span class="qpc-hafs">﴿كنتم﴾</span> في خاصة أصحاب محمد، ومن صنع مثل صنيعهم كانوا <span class="qpc-hafs">﴿خير أمة أخرجت للناس﴾</span>{5}. (٣/٧٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٩<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق السدي، عمَّن حَدَّثه- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة﴾</span>، قال: تكون لأولنا، ولا تكون لآخرنا{6}<span class=comment-ref>١٣٤٦</span>. (٣/٧٢٥)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٦</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٢/٣١٦) قول عكرمة، وعمر بن الخطاب من طريق السدي، وابن عباس من طريق سعيد بن جبير، بقوله: «فهذا كلّه قولٌ واحد، مقتضاه أنّ الآية نزلت في الصحابة، قيل لهم: كنتم خير أمة، فالإشارة بقوله: <span class="qpc-hafs">﴿أُمَّةً﴾</span> إلى أمة محمد معينة، فإن هؤلاء هم خيرها».</div></p><p><div></p><p><p><span class="item-no">١٤١٦٠<span class="dash">-</span></span> عن <span class="name-1">أبي بن كعب</span> -من طريق أبي العالية- قال: لم تكن أمةٌ أكثرَ استجابة في الإسلام مِن هذه الأمة، فمِن ثَمَّ قال: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{7}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦١<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي حازم- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير الناس للناس، تأتون بهم في السلاسل في أعناقهم حتى يدخلوا في الإسلام{8}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>-من طريق عكرمة- <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير الناس للناس{9}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: هم الذين هاجروا مع رسول الله ﷺ إلى المدينة{10}. (٣/٧٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٤<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>، نحو ذلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق ثابت- في قوله ﷿: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خيرُ الناس للناس{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- قال: خير الناس للناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: هم أصحاب رسول الله ﷺ خاصة، يعني: وكانوا هم الرواة الدُّعاة الذين أمر الله المسلمين بطاعتهم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيْف- في الآية، قال: لم تكن أمةٌ دخل فيها مِن أصناف الناس غير هذه الأمة{7}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير الناس للناس،كان قبلكم لا يأمن هذا في بلاد هذا، ولا هذا في بلاد هذا، فكلما كنتم أمِنَ فيكم الأحمر والأسود، وأنتم خير الناس للناس{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قول الله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: كنتم خير الناس للناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف وتنهون عن المنكر﴾</span>، قال: قد كان ما تسمع مِن الخير في هذه الأمة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- أنّه كان يقول: نحن آخرها، وأكرمها على الله{18}<span class=comment-ref>١٣٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٧</span> <span class="comment-type-3">رجَّح</span> <u>ابن جرير</u> (٥/٦٧٥) <span class="mustanad">مستندًا إلى السنة،</span> و<u>ابن عطية</u> (٢/٣١٧) <span class="mustanad">مستندًا إلى القرآن، والسنة،</span> قول الحسن من طريق عباد، ومن طريق قتادة، بأن <span class="qpc-hafs">﴿كُنْتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنّاسِ﴾</span>: خطاب للأمة بأنهم خير أمة أخرجت للناس، فذكر <u>ابن جرير</u> بسنده: عن بَهْز بن حكيم، عن أبيه، عن جده، قال: سمعت رسول الله ﷺ يقول: «ألا إنكم وفَّيتم سبعين أمة، أنتم خيرها وأكرمها على الله». وزاد عليه ابن عطية استدلاله بقوله تعالى: <span class="qpc-hafs">﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا لِتَكُونُوا شُهَداءَ عَلى النّاسِ﴾</span> [البقرة:١٤٣]، وبقوله ﷺ: «نحن الآخرون السابقون» الحديث.</p><p>وكذا <span class="comment-type-3">رجَّح</span> <u>ابن كثير</u> (٣/١٤٢) <span class="mustanad">مستندًا إلى دلالة العموم، والنظائر،</span> بأن الآية عامة في جميع الأمة، فقال: "والصحيح أن هذه الآية عامة في جميع الأمة، كل قرن بحسبه، وخير قرونهم الذين بعث فيهم رسول الله ﷺ، ثم الذين يلونهم، ثم الذين يلونهم، كما قال في الآية الأخرى: <span class="qpc-hafs">﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا﴾</span>، أي: خيارًا، <span class="qpc-hafs">﴿لِتَكُونُوا شُهَداءَ عَلى النّاسِ ويَكُونَ الرَّسُولُ عَلَيْكُمْ شَهِيدًا﴾</span> [البقرة:١٤٣]».</p><p><span class="comment-type-1">ووجَّه</span> <u>ابن عطية</u> (٢/٣١٦) قول الحسن من طريق عباد، فقال: «فلفظ <span class="qpc-hafs">﴿أمة﴾</span> على هذا التأويل اسم جنس، كأنه قيل لهم: كنتم خير الأمم».</div></p><p><div></p><p><p><span class="item-no">١٤١٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن حسين- أنّه قرأ: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، فقال: هم الذين مَضَوْا من صدر هذه الأمة، يعني: أصحاب النبي ﷺ، قد كان الرجل منهم يلقى أخاه، فيقول: أبشر، أليس أنت كُنتِيًّا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٤<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر [محمد بن علي بن الحسين]</span> -من طريق جابر- <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير أهل بيت النبي ﷺ{7}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٥<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق عيسى بن موسى- في الآية، قال: خير الناس للناس، شهدتم للنبيين الذين كَفَر بهم قومُهم بالبلاغ{22}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٦<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: خير الناس للناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: هم أُمة محمد ﷺ، لم يؤمر نبي قبله بالقتال، فهم يقاتلون الكفار فيدخلونهم في دينهم، فهم خير أُمة للناس{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف وتنهون عن المنكر﴾</span>، قال: لم تكن أمة أكثر استجابة في الإسلام من هذه الأمة، فمِن ثَمَّ قال: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٩<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: خير الناس للناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة﴾</span>، قال: أنتم خير الناس للناس{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعنى: خير الناس للناس، ... <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> في زمانكم، كما فَضَّل بني إسرائيل في زمانهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>: ليس خلق مِن أهل الأديان إلا قالوا: ليس علينا جناح فيما نصيب من غيرنا من أهل الأديان، ولا يأمرون مَن سواهم بالخير، وهذه الأمة يأمرون كل أهل دين وأنفسهم، لا يظلم بعضهم بعضًا، بل يأمرونهم بالمعروف، وينهونهم عن المنكر؛ فأُمة محمد ﷺ خير الأُمم للناس{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف﴾</span>، يقول: تأمرونهم أن يشهدوا أن لا إله إلا الله، والإقرار بما أنزل الله، وتقاتلونهم عليه، ولا إله إلا الله هو أعظم المعروف، وتنهونهم عن المنكر، والمنكر هو التكذيب، وهو أنكر المنكر{30}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيّ</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿تأمرون بالمعروف﴾</span> قال: بالتوحيد، <span class="qpc-hafs">﴿وتنهون عن المنكر﴾</span> قال: عن الشرك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- قوله: <span class="qpc-hafs">﴿وتؤمنون بالله﴾</span>، يعني: تصدقون توحيد الله{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، يقول: على هذا الشرط، أن تأمروا بالمعروف، وتنهوا عن المنكر، وتؤمنوا بالله، يقول: لمن أنتم بين ظهرانيه، كقوله: <span class="qpc-hafs">﴿ولقد اخترناهم على علم على العالمين﴾</span> [الدخان:٣٢]{33}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿تأمرون﴾</span> الناس <span class="qpc-hafs">﴿بالمعروف﴾</span> يعني: بالإيمان، <span class="qpc-hafs">﴿وتنهون عن المنكر وتؤمنون﴾</span> بتوحيد الله، وتنهونهم عن الظلم، وأنتم خير الناس للناس، وغيركم من أهل الأديان لا يأمرون أنفسهم ولا غيرهم بالمعروف، ولا ينهونهم عن المنكر{2}<span class=comment-ref>١٣٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/٣١٨) أن قوله تعالى: <span class="qpc-hafs">﴿كُنْتُم﴾</span> «على صيغة الماضي، فإنها التي بمعنى الدوام، <span class="mustanad">كما قال</span>: <span class="qpc-hafs">﴿وكانَ اللهُ غَفُورًا رَحِيمًا﴾</span>، إلى غير هذا من الأمثلة». ثم نقل ثلاثة أقوال أخرى: <b>الأول:</b> «كنتم في علم الله». <b>الثاني:</b> «في اللوح المحفوظ». <b>الثالث:</b> «فيما أخبر به الأمم قديمًا عنكم».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَـٰبِ لَكَانَ خَیۡرࣰا لَّهُمۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- قوله: <span class="qpc-hafs">﴿آمن﴾</span>، قال: صدق{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولو آمن﴾</span> يعني: ولو صدق <span class="qpc-hafs">﴿أهل الكتاب﴾</span> يعني: اليهود بمحمد ﷺ، وما جاء به من الحق، <span class="qpc-hafs">﴿لكان خيرا لهم﴾</span> مِن الكفر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَـٰسِقُونَ ۝١١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- في قول الله تعالى: <span class="qpc-hafs">﴿الفاسقون﴾</span>، يعني: هم العاصون{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق شَيْبان- في قوله: <span class="qpc-hafs">﴿منهم المؤمنون﴾</span>، قال: استثنى الله منهم ثلاثة كانوا على الهدى والحق{32}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأكثرهم الفاسقون﴾</span>، قال: ذَمَّ الله أكثرَ الناس{39}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿منهم المؤمنون﴾</span> يعني: عبد الله بن سلام وأصحابه، <span class="qpc-hafs">﴿وأكثرهم الفاسقون﴾</span> يعني: العاصين، يعني: اليهود{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَـٰسِقُونَ ۝١١٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٤<span class="dash">-</span></span> عن علي بن أبي طالب، قال: قال رسول الله ﷺ: «<b>أُعْطِيت ما لم يُعْطَ أحد من الأنبياء: نُصِرت بالرعب، وأُعْطِيت مفاتيح الأرض، وسُمِّيت أحمد، وجُعِل التراب لي طهورًا، وجُعِلَت أمتي خير الأمم»</b>{41}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٥<span class="dash">-</span></span> عن قتادة بن دِعامة، قال: ذُكِرَ لنا: أن نبي الله ﷺ قال ذات يوم وهو مسند ظهره إلى الكعبة: «<b>نحن نكمل يوم القيامة سبعين أمة، نحن آخرها وخيرها</b>»{42}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٦<span class="dash">-</span></span> عن الحسن البصري -من طريق أبي الأشهب- قال رسول الله ﷺ: «<b>أنتم توفون سبعين أمة، أنتم خيرها وأكرمها على الله</b>»{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- قال: قال رجل: أعوذ بالله أن أكون كُنتِيًّا. قيل له: ما الكنتي؟ قال: تقول: لقد كنت مرة وكنت. وقرأ الحسن: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{44}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٦٧٢، وابن المنذر (٨٠٢).تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه عبد الرزاق ١/١٣٠، وعَبد بن حُمَيد (٤٠٩ - منتخب)، وأحمد ٣٣/٢٢٨، والترمذي (٣٠٠١)، وابن ماجه(٤٢٨٧)، وابن جَرِير ٥/٦٧٦،٦٧٥، وابن المنذر ٧٩٧، وابن أبي حاتم ٣/٧٣١، والطبراني ١٩/٤٢٢، والحاكم ٤/٨٤. وعزاه السيوطي إلى ابن مردويه.</p><p>حَسَّنه الترمذي، وصححه الحاكم، وقال الألباني في صحيح سنن ابن ماجه (٣٤٦٠): «حسن».أخرجه ابن جرير ٥/٦٧٢-٦٧٣.أخرجه ابن جرير ٥/٦٧١-٦٧٢، وابن أبي حاتم ٣/٧٣٢.أخرجه ابن جرير ٥/٦٧٢، وابن أبي حاتم ٣/٧٣٢.أخرجه ابن أبي حاتم ٣/٧٣٣.أخرجه البخاري (٤٥٥٧)، والنسائي في الكبرى (١١٠٧١)، وابن جرير ٥/٦٧٤، وابن المنذر (٨٠٣)، وابن أبي حاتم ٣/٧٣٢، والحاكم ٤/٨٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن المنذر (٧٩٩).أخرجه عبد الرزاق ١/١٣٠، وابن أبي شيبة ١٢/١٥٥، وأحمد ٤/٢٧٢، والنسائي في الكبرى (١١٠٧٢)، وابن جرير ٥/٦٧١، ٦٧٢، وابن المنذر (٨٠١)، وابن أبي حاتم ٣/٧٣٢، والحاكم ٢/٢٩٤. وعزاه السيوطي إلى عبد بن حميد، والفريابي.علَّقه ابن أبي حاتم ٣/٧٣٢.أخرجه ابن عدي في الكامل ٦/٢١٤. وعلَّقه ابن المنذر ١/٣٣١.علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.أخرجه ابن جرير ٥/٦٧٣.أخرجه ابن أبي حاتم ٣/٧٣٣.أخرجه ابن أبي حاتم ٣/٧٣٢-٧٣٣.علَّقه ابن وهْب في الجامع ٢/٤٩ (٨٧).أخرجه ابن جرير ٥/٦٧٥.أخرجه ابن جرير ٥/٦٧٥.أخرجه ابن المنذر ١/٣٣٣.أخرجه ابن أبي حاتم ٣/٧٣٣.أخرجه ابن أبي حاتم ٣/٧٣٣، وابن جرير ٥/٦٧٤ مختصرًا من طريق فضيل بن مرزوق. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.تفسير البغوي ٤/٩٠، وتفسير الثعلبي ٣/١٢٧.أخرجه ابن جرير ٥/٦٧٤.علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.أخرجه عبد الرزاق في تفسيره ١/١٣٠، وابن المنذر ١/٣٣٠.تفسير مقاتل بن سليمان ١/٢٩٥.تفسير الثعلبي ٣/١٢٧.أخرجه ابن جرير ٥/٦٧٦، وابن المنذر (٨٠٧)، وابن أبي حاتم ٣/٧٣٣-٧٣٤، والبيهقي في الأسماء والصفات (٢٠٦).أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٢٥٧-. وعلَّق ابن أبي حاتم ٣/٧٣٣ أولَه.أخرجه ابن أبي حاتم ٣/٧٣٤.أخرجه ابن جرير ٥/٦٧٣، وابن المنذر (٨٠٨) مختصرًا. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن أبي حاتم ٣/٧٣٤.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن أبي حاتم ٣/٧٣٤.أخرجه ابن أبي حاتم ٣/٧٣٤.أخرجه ابن أبي حاتم ٣/٧٣٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه أحمد ٢/١٥٦.</p><p>قال محققو المسند: «بسند حسن».أخرجه ابن جرير ٥/٦٧٦.تفسير ابن أبي زمنين ١/٣١٢.أخرجه ابن المنذر ١/٣٣٠.
  3,111,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَن یَضُرُّوكُمۡ إِلَّاۤ أَذࣰىۖ وَإِن یُقَـٰتِلُوكُمۡ یُوَلُّوكُمُ ٱلۡأَدۡبَارَ ثُمَّ لَا یُنصَرُونَ ۝١١١ ضُرِبَتۡ عَلَیۡهِمُ ٱلذِّلَّةُ أَیۡنَ مَا ثُقِفُوۤا۟ إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ وَحَبۡلࣲ مِّنَ ٱلنَّاسِ وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِ وَضُرِبَتۡ عَلَیۡهِمُ ٱلۡمَسۡكَنَةُۚ ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلۡأَنۢبِیَاۤءَ بِغَیۡرِ حَقࣲّۚ ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝١١٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، وذلك أن رؤساء اليهود: كعب بن مالك، وشعبة، وبَحْرِيّ، ونعمان، وأبا ياسر، وأبا نافع، وكنانة بن أبى الحُقَيْق، وابن صُورِيا، عمدوا إلى مؤمنيهم فآذوهم لإسلامهم، وهم عبدالله بن سلام وأصحابه، فأنزل الله ﷿: <span class="qpc-hafs">﴿لن يضروكم إلا أذى وإن يقاتلوكم يولوكم الأدبار ثم لا ينصرون﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَن یَضُرُّوكُمۡ إِلَّاۤ أَذࣰىۖ وَإِن یُقَـٰتِلُوكُمۡ یُوَلُّوكُمُ ٱلۡأَدۡبَارَ ثُمَّ لَا یُنصَرُونَ ۝١١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن منصور- <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: تسمعون منهم كَذِبًا على الله، يدعونكم إلى الضلالة{2}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: تسمعونه منهم{3}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: أذًى تسمعونه منهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لن يضروكم﴾</span> اليهود <span class="qpc-hafs">﴿إلا أذى﴾</span> باللسان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حَجّاج- <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: إشراكهم في عُزَيْر، وعيسى، والصليب{6}. (٣/٧٢٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ضُرِبَتۡ عَلَیۡهِمُ ٱلذِّلَّةُ أَیۡنَ مَا ثُقِفُوۤا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>، قال: هم أصحاب القَبالات{7}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>، قال: الجزية{8}. (٣/٧٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٦<span class="dash">-</span></span> عن عباد بن منصور، قال: سألت <span class="name-2">الحسن البصري</span> عن قوله: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>. قال: أذلهم الله فلا مَنَعَة لهم، وجعلهم الله تحت أقدام المسلمين{9}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: أدركتهم هذه الأمة وإنّ المجوس لتجبيهم الجزية{10}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٩<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>، قال: يُعْطُون الجِزْيَة عن يد وهم صاغرون{11}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن اليهود، فقال سبحانه: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span> يعني: المَذَلَّة، <span class="qpc-hafs">﴿أين ما ثقفوا﴾</span> يعني: وُجِدوا{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ وَحَبۡلࣲ مِّنَ ٱلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق هارون بن عنترة، عن أبيه- <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، قال: بعهد من الله، وعهد من الناس{13}. (٣/٧٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إلا بحبل من الله﴾</span> قال: بعهد، <span class="qpc-hafs">﴿وحبل من الناس﴾</span> قال: بعهدهم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: بعهد من الله، وعهد من الناس{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عثمان بن غياث- يقول: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، قال: بعهد من الله، وعهد من الناس{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: عهد مِن الله، وعهد مِن الناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج-: العهد: حبل الله{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: إلا بعهد من الله، وعهد من الناس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: إلا بعهد من الله، وعهد من الناس{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿بحبل من الله وحبل من الناس﴾</span>، قال: عهد من الله، وعهد من الناس{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: إلا بعهد من الله، وعهد من الناس{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: لا يأمنوا حيث ما تَوَجَّهُوا إلا بعهد من الله، وعهد من الناس، يعني: النبي ﷺ وحده{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أينما ثقفوا إلا بحبل من الله وحبل من الناس﴾</span>، قال: إلا بعهد، وهم يهود. قال: والحبل: العهد. قال: وذلك قول أبي الهيثم بن التَيِّهان لرسول الله ﷺ حين أتته الأنصار في العقبة: أيها الرجل، إنا قاطعون فيك حبالًا بيننا وبين الناس. يقول: عهودًا. قال: واليهود لا يأمنون في أرض من أرض الله إلا بهذا الحبل الذي لله قال ﷿، وقرأ: <span class="qpc-hafs">﴿وجاعل الذين اتبعوك فوق الذين كفروا إلى يوم القيامة﴾</span> [آل عمران: ٥٥]، قال: فليس بلد فيه أحد من النصارى إلا وهم فوق يهود في شرق ولا غرب، هم في البلدان كلها مستذلون، قال الله: <span class="qpc-hafs">﴿وقطعناهم في الأرض أمما﴾</span> [الأعراف: ١٦٨] قال: يهود{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٣<span class="dash">-</span></span> عن علي بن خلف قال: سمعت <span class="name-3">سفيان بن عيينة</span> يفسر حبل الله، قال: عهد الله. وقرأ: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، قال: إلا بعهد من الله، وعهد من الناس{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٢٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله تعالى: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، يقول: استوجبوا سخطه{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، قال: اسْتَحَقُّوا الغضب مِن الله{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وباؤوا بغضب من الله﴾</span>: فحَدَثَ عليهم من الله غضب{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، يعني: استوجبوا الغضب من الله{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَضُرِبَتۡ عَلَیۡهِمُ ٱلۡمَسۡكَنَةُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيّ</span> -من طريق الربيع- قوله: <span class="qpc-hafs">﴿وضربت عليهم المسكنة﴾</span>، قال: المسكنة: الفاقة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٩<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٠<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>، نحو ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿المسكنة﴾</span>، قال: الجزية{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٢<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق عبيد بن الطفيل- قوله: <span class="qpc-hafs">﴿وضربت عليهم المسكنة﴾</span>، قال: الخَراج{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضربت عليهم﴾</span> الذلة و<span class="qpc-hafs">﴿المسكنة﴾</span>، يعني: الذل والفقر{34}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلۡأَنۢبِیَاۤءَ بِغَیۡرِ حَقࣲّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> –من طريق أبي مَعْمَر الأزْدِي- قال: كانت بنو إسرائيل تقتل في اليوم ثلاثمائة نبي، ثم يقوم سوق بَقْلِهم من آخر النهار{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> الذي نزل بهم <span class="qpc-hafs">﴿بأنهم كانوا يكفرون بآيات الله ويقتلون الأنبياء بغير حق﴾</span>{36} <span class=comment-ref>١٣٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٩</span> ذكر <u>ابنُ عطية</u> (٢/٣٢١-٣٢٢) أن قوله تعالى: <span class="qpc-hafs">﴿بآيات الله﴾</span> يحتمل معنيين: <b>الأول:</b> «أن يراد بها: المتلوّة». <b>والثاني:</b> «أن يريد: العِبَر التي عرضت عليهم».</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝١١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ذلك بما عصوا وكانوا يعتدون﴾</span>، قال: اجتَنِبوا المعصية والعدوان، فإن بهما أُهْلِك من أُهْلِك من قبلكم من الناس{37}<span class=comment-ref>١٣٥٠</span>. (٣/٧٣٠)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٠</span> يرى <u>ابنُ جرير</u> (٥/٦٨٨-٦٨٩) بأن اسم الإشارة <span class="qpc-hafs">﴿ذلك﴾</span> في قوله تعالى: <span class="qpc-hafs">﴿ذَلِكَ بِما عَصَوْا وكانُوا يَعْتَدُونَ﴾</span> راجع إلى الشيء الذي أشير إليه بـ<span class="qpc-hafs">﴿ذلك﴾</span> في قوله تعالى: <span class="qpc-hafs">﴿ذَلِكَ بِأَنَّهُمْ كانُوا يَكْفُرُونَ بِآياتِ اللَّهِ ويَقْتُلُونَ الأَنْبِياءَ بِغَيْرِ حَقٍّ﴾</span>، أي: أنّ ما تحملوه من غضب الله وضرب الذلة والمسكنة عليهم، بسبب كفرهم، وقتلهم الأنبياء، ومعصيتهم ربهم، واعتدائهم في شرع ربهم، فاسم الإشارة الثاني عنده تأكيد للأول، وهو معنى قول قتادة.</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٢/٣٢٢) على <u>ابن جرير</u>، فقال بعدما ذكر قولَه: «والذي أقول: إن الإشارة بـ<span class="qpc-hafs">﴿ذلِكَ﴾</span> الأخير إنما هي إلى كفرهم وقتلهم، وذلك أنّ الله تعالى استدرجهم، فعاقبهم على العصيان والاعتداء بالمصير إلى الكفر وقتل الأنبياء، وهو الذي يقول أهل العلم: إن الله تعالى يعاقب على المعصية بالإيقاع في معصية، ويجازي على الطاعة بالتوفيق إلى طاعة».</div></p><p><div></p><p><p><span class="item-no">١٤٢٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> الذي أصابهم <span class="qpc-hafs">﴿بما عصوا وكانوا يعتدون﴾</span> في دينهم{34}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن جرير ٥/٦٧٩-٦٨٠، وابن أبي حاتم ٣/٧٣٤.أخرجه ابن جرير ٥/٦٧٩. وعلَّقه ابن أبي حاتم ٣/٧٣٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٦٧٩.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن جرير ٥/٦٧٩-٦٨٠، وابن أبي حاتم ٣/٧٣٥ من طريق ابن ثور.أخرجه ابن أبي حاتم ٣/٧٣٥، ولفظه: هم أصحاب القبالات، كفروا بالله العظيم.أخرجه ابن المنذر ١/٣٣٥. وفي لفظ آخر ١/٣٣٧: <span class="qpc-hafs">﴿الذلة والمسكنة﴾</span>: الجزية.أخرجه ابن جرير ٥/٦٨١، وابن أبي حاتم ٣/٧٣٥.أخرجه ابن جرير ٥/٦٨١، وابن المنذر (٨١١)، وابن أبي حاتم ٣/٧٣٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٣/٧٣٥.تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.أخرجه ابن المنذر (٨١٣)، وابن جرير ٥/٦٨٣، وابن أبي حاتم ٣/٧٣٥.أخرجه ابن جرير ٥/٦٨٢-٦٨٣ من طريق ابن جريج، وعبد الرزاق ١/١٣٠ من طريق معمر، وعبد بن حميد ص٥١ بلفظ: بعهد من الله. وعلَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٤. وعلَّقه ابن المنذر ١/٣٣٦، وابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٢. وعلَّقه ابن أبي حاتم ٣/٣٣٥.علَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٢، وعبد بن حميد ص٥١ بلفظ: بعهد من الله. وعلَّقه ابن المنذر ١/٣٣٦، وابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣١٢-.أخرجه أبو جعفر الرملي في جزئه ص١٠٢ (تفسير عطاء الخراساني). وعلَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥.تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.أخرجه ابن جرير ٥/٦٨٣.أخرجه أبو نعيم في أخبار أصبهان ٢/٧.أخرجه ابن أبي حاتم ٣/٣٣٦.أخرجه ابن المنذر ١/٣٣٦. وعلَّقه ابن أبي حاتم ٣/٣٣٦ بلفظ: استوجبوا.أخرجه ابن أبي حاتم ٣/٣٣٦.تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.أخرجه ابن أبي حاتم ٣/٣٣٦.علَّقه ابن أبي حاتم ٣/٣٣٦.أخرجه ابن أبي حاتم ٣/٣٣٦.أخرجه ابن أبي حاتم ٣/٣٣٦.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه ابن أبي حاتم ٣/٣٣٦.تفسير مقاتل بن سليمان ١/٢٩٦.</p><p>وقد تقدمت الآثار بتفصيل أكثر عند تفسير نظير هذه الآية في سورة البقرة: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ وباءُوا بِغَضَبٍ مِنَ اللَّهِ ذَلِكَ بِأَنَّهُمْ كانُوا يَكْفُرُونَ بِآياتِ اللَّهِ ويَقْتُلُونَ النَّبِيِّينَ بِغَيْرِ الحَقِّ ذَلِكَ بِما عَصَوْا وكانُوا يَعْتَدُونَ﴾</span> [البقرة:٦١]، وقد أحال إليها ابن جرير ٥/٦٨٨، بينما كررها ابن أبي حاتم كعادته.أخرجه ابن المنذر (٨٢١)، وابن جرير ٥/٦٨٩، وابن أبي حاتم ٣/٣٣٧.تفسير مقاتل بن سليمان ١/٢٩٦.
