  3,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ مِنۡهُمۡ لَفَرِیقࣰا یَلۡوُۥنَ أَلۡسِنَتَهُم بِٱلۡكِتَـٰبِ لِتَحۡسَبُوهُ مِنَ ٱلۡكِتَـٰبِ وَمَا هُوَ مِنَ ٱلۡكِتَـٰبِ وَیَقُولُونَ هُوَ مِنۡ عِندِ ٱللَّهِ وَمَا هُوَ مِنۡ عِندِ ٱللَّهِ وَیَقُولُونَ عَلَى ٱللَّهِ ٱلۡكَذِبَ وَهُمۡ یَعۡلَمُونَ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٣٤٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وإن منهم لفريقا يلوون ألسنتهم بالكتاب﴾</span>، قال: هم اليهود، كانوا يزيدون في كتاب الله ما لم يُنَزِّلِ الله{1}. (٣/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- <span class="qpc-hafs">﴿يلوون ألسنتهم بالكتاب﴾</span>، قال: يُحَرِّفونه{2}. (٣/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق مالك بن مِغْوَل- <span class="qpc-hafs">﴿يلوون ألسنتهم بالكتاب﴾</span>، قال: يُحَرِّفون عن مواضعه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن منصور- أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿ويقولون على الله الكذب وهم يعلمون﴾</span>. قال: هم أهل الكتاب، كلهم قد كَذَبوا على الله، وحَرَّفوا الكَلِم عن مواضعه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإن منهم لفريقا يلوون ألسنتهم بالكتاب﴾</span> حتى بلغ: <span class="qpc-hafs">﴿وهم يعلمون﴾</span>: هم أعداء الله اليهود، حرَّفوا كتاب الله، وابتدعوا فيه، وزعموا أنّه مِن عند الله{5}<span class=comment-ref>١٢٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٢٥٧</span> لم يذكر <u>ابنُ جرير</u> (٥/٥٢١-٥٢٣) غير هذا القول وما في معناه.</div></p><p><div></p><p><p><span class="item-no">١٣٤٧٣<span class="dash">-</span></span> عن عبد الصمد بن معقل، أنه سمع <span class="name-2">وهب بن منبه</span> يقول: إنّ التوراة والإنجيل كما أنزلهما الله لم يُغَيَّرْ منهما حرف، ولكنهم يَضِلُّون بالتحريف والتأويل، وكُتُبٍ كانوا يكتبونها من عند أنفسهم، <span class="qpc-hafs">﴿ويقولون هو من عند الله وما هو من عند الله﴾</span>، فأما كتب الله فهي محفوظة لا تَحُولُ{6}<span class=comment-ref>١٢٥٨</span>. (٣/٦٤١)</p></p><p></div></p><p><div><span class=comment-ref>١٢٥٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٣/٩٧) على قول وهب، فقال: «فإن عنى وهب ما بأيديهم من ذلك فلا شكَّ أنه قد دخلها التبديل والتحريف والزيادة والنقص، وأما تعريب ذلك المشاهد بالعربية ففيه خطأ كبير، وزيادات كثيرة ونقصان، ووهم فاحش، وهو من باب تفسير المعبر المعرب، وفهم كثير منهم بل أكثرهم بل جميعهم فاسد. وأمّا إن عنى كتب الله التي هي كتبه من عنده فتلك كما قال محفوظة لم يدخلها شيء».</div></p><p><div></p><p><p><span class="item-no">١٣٤٧٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿ويقولون هو من عند الله وما هو من عند الله﴾</span>، قال: هم أعداء الله اليهود، حَرَّفوا كتاب الله، وابتدعوا فيه، وزعموا أنّه مِن عند الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حَجّاج- <span class="qpc-hafs">﴿وإن منهم لفريقا يلوون ألسنتهم بالكتاب﴾</span>، قال: فريق من أهل الكتاب يلوون ألسنتهم، وذلك تحريفهم إيّاه عن موضعه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن منهم﴾</span> يعني: من اليهود <span class="qpc-hafs">﴿لفريقا﴾</span> يعني: طائفة، منهم: كعب بن الأشرف، ومالك بن الضَّيْف، وأبو ياسر، وجُدَيّ بن أخطب، وشعبة بن عمرو <span class="qpc-hafs">﴿يلوون ألسنتهم بالكتاب﴾</span> يعني باللَّيِّ: التحريف بالألسن فى أمر محمد ﷺ؛ <span class="qpc-hafs">﴿لتحسبوه من الكتاب﴾</span> يعني: التوراة. يقول الله ﷿: <span class="qpc-hafs">﴿وما هو من الكتاب﴾</span> كتبوا -يعني: من التوراة- غير نعت محمد ﷺ، ومحوا نعته، <span class="qpc-hafs">﴿ويقولون هو﴾</span> هذا النعت <span class="qpc-hafs">﴿من عند الله وما هو من عند الله﴾</span> ولكنهم كتبوه، <span class="qpc-hafs">﴿ويقولون على الله الكذب وهم يعلمون﴾</span> أنّهم كَذَبَة، وليس ذلك نعت محمد ﷺ{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٥٢٢، وابن أبي حاتم ٢/٦٨٩.أخرجه ابن جرير ٥/٥٢٢، وابن المنذر ١/٢٦٥، وابن أبي حاتم ٢/٦٨٩. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد.أخرجه ابن المنذر ١/٢٦٥. وعلَّقه ابن أبي حاتم ٢/٦٨٩.أخرجه ابن أبي حاتم ٢/٦٩٠.أخرجه ابن جرير ٥/٥٢٢، وعبد بن حميد كما في قطعة من تفسيره ص٣٥. وعلَّقه ابن أبي حاتم ٢/٦٨٨-٦٨٩ مختصرًا.أخرجه ابن المنذر ١/٢٦٦، وابن أبي حاتم ٢/٦٨٩.أخرجه ابن أبي حاتم ٢/٦٨٩.أخرجه ابن جرير ٥/٥٢٣.تفسير مقاتل بن سليمان ١/٢٨٦.
  3,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا كَانَ لِبَشَرٍ أَن یُؤۡتِیَهُ ٱللَّهُ ٱلۡكِتَـٰبَ وَٱلۡحُكۡمَ وَٱلنُّبُوَّةَ ثُمَّ یَقُولَ لِلنَّاسِ كُونُوا۟ عِبَادࣰا لِّی مِن دُونِ ٱللَّهِ وَلَـٰكِن كُونُوا۟ رَبَّـٰنِیِّـۧنَ بِمَا كُنتُمۡ تُعَلِّمُونَ ٱلۡكِتَـٰبَ وَبِمَا كُنتُمۡ تَدۡرُسُونَ ۝٧٩ وَلَا یَأۡمُرَكُمۡ أَن تَتَّخِذُوا۟ ٱلۡمَلَـٰۤىِٕكَةَ وَٱلنَّبِیِّـۧنَ أَرۡبَابًاۗ أَیَأۡمُرُكُم بِٱلۡكُفۡرِ بَعۡدَ إِذۡ أَنتُم مُّسۡلِمُونَ ۝٨٠﴾</span> - نزول الآيتين</h3></p><p><div></p><p><p><span class="item-no">١٣٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قال أبو رافع القُرَظِيّ حين اجتمعت الأحبار من اليهود، والنصارى من أهل نجران عند رسول الله ﷺ، ودعاهم إلى الإسلام: أتريد -يا محمد- أن نعبدك كما تعبدُ النصارى عيسى ابن مريم؟ فقال رجل مِن أهل نجران نصرانيٌّ يقال له الريسُ: أوَذاك تريد مِنّا، يا محمد؟ فقال رسول الله ﷺ: «<b>معاذ الله أن نعبد غير الله، أو نأمر بعبادة غيره، ما بذلك بعثني، ولا بذلك أمرني</b>». فأنزل الله في ذلك من قولهما: <span class="qpc-hafs">﴿ما كان لبشر أن يؤتيه الله الكتاب﴾</span> إلى قوله: <span class="qpc-hafs">﴿بعد إذ أنتم مسلمون﴾</span>{1}. (٣/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحّاك بن مزاحم</span>: نزلت في نصارى أهل نجران{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٧٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: بلغني: أنّ رجلًا قال: يا رسول الله، نُسَلِّم عليك كما يُسَلِّم بعضُنا على بعض، أفلا نسجد لك؟ قال: «<b>لا، ولكن أكرِموا نبيَّكم، واعرفوا الحقَّ لأهله، فإنّه لا ينبغي أن يُسجد لأحد من دون الله</b>». فأنزل الله: <span class="qpc-hafs">﴿ما كان لبشر أن يؤتيه الله الكتاب﴾</span> إلى قوله: <span class="qpc-hafs">﴿بعد إذ أنتم مسلمون﴾</span>{3}. (٣/٦٤٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا كَانَ لِبَشَرٍ أَن یُؤۡتِیَهُ ٱللَّهُ ٱلۡكِتَـٰبَ وَٱلۡحُكۡمَ وَٱلنُّبُوَّةَ ثُمَّ یَقُولَ لِلنَّاسِ كُونُوا۟ عِبَادࣰا لِّی مِن دُونِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٣٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨١<span class="dash">-</span></span> و<span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ما كانَ لِبَشَرٍ﴾</span> يعني: محمدًا <span class="qpc-hafs">﴿أنْ يُؤْتِيَه اللَّه الكِتابَ﴾</span> أي: القرآن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الحكم: العِلْم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مالك- قال: الحكم: اللُّبّ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٤<span class="dash">-</span></span> عن <span class="name-2">الضحّاك بن مزاحم</span>: <span class="qpc-hafs">﴿ما كان لبشر﴾</span> يعني: عيسى ﵇، وذلك أنّ نصارى نجران كانوا يقولون: إنّ عيسى أمرهم أن يتخذوه ربًّا، فقال تعالى: <span class="qpc-hafs">﴿ما كانَ لِبَشَرٍ﴾</span> يعني: عيسى <span class="qpc-hafs">﴿أنْ يُؤْتِيَه اللَّه الكِتابَ﴾</span> الإنجيل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٥<span class="dash">-</span></span> عن عباد بن منصور، قال: سألت <span class="name-2">الحسن [البصري]</span> عن قوله: <span class="qpc-hafs">﴿ما كان لبشر أن يؤتيه الله الكتاب والحكم والنبوة ثم يقول للناس كونوا عبادا لي من دون الله﴾</span>. فقال: ما كان لمؤمن أن يفعل ذلك، يأمر الناس أن يتخذوه أربابًا مِن دون الله. فقال: كان القوم يعبد بعضهم بعضًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: احتج عليهم بهذا؛ لقولهم: إن عيسى ينبغي له أن يعبد، وإنهم قبلوا ذلك عن الله، وهو في كتابهم الذي نزل من عند الله{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ما كان لبشر أن يؤتيه الله الكتاب والحكم والنبوة ثم يقول للناس كونوا عبادا لي من دون الله﴾</span>، يقول: ما كان ينبغي لبشر أن يؤتيه الله الكتاب والحكم والنبوة يأمر عباده أن يتخذوه ربًّا من دون الله{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-، مثله{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق ابن ثور- قال: <span class="qpc-hafs">﴿ما كان لبشر﴾</span> يقول: ما كان لنبي <span class="qpc-hafs">﴿أن يؤتيه الله الكتاب﴾</span>، كان ناس من يهود يتعبدون الناس من دون ربهم، بتحريفهم كتاب الله عن موضعه، فقال الله: <span class="qpc-hafs">﴿ما كان لبشر أن يؤتيه الله الكتاب والحكم والنبوة ثم يقول للناس كونوا عبادا لي من دون الله﴾</span>، ثم يأمرُ الناسَ بغير ما أنزل الله في كتابه{12}. (٣/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما كان لبشر﴾</span> يعني: عيسى ابن مريم ﷺ <span class="qpc-hafs">﴿أن يؤتيه الله﴾</span> يعني: أن يعطيه الله <span class="qpc-hafs">﴿الكتاب﴾</span> يعني: التوراة والإنجيل، <span class="qpc-hafs">﴿والحكم﴾</span> يعني: الفهم، <span class="qpc-hafs">﴿والنبوة ثم يقول للناس﴾</span> يعني: بني إسرائيل: <span class="qpc-hafs">﴿كونوا عبادا لي من دون الله﴾</span>{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِن كُونُوا۟ رَبَّـٰنِیِّـۧنَ بِمَا كُنتُمۡ تُعَلِّمُونَ ٱلۡكِتَـٰبَ وَبِمَا كُنتُمۡ تَدۡرُسُونَ ۝٧٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٣٤٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- أنّه كان يقرأ: <span class="qpc-hafs">﴿بما كنتم تُعَلِّمُونَ﴾</span>{14}. (٣/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه قرأ: <span class="qpc-hafs">﴿بما كنتم تُعَلِّمُونَ﴾</span> مثقلة، برفع التاء، وكسر اللام{15}. (٣/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- أنه قرأ: ‹بِما كُنتُمْ تَعْلَمُونَ الكِتابَ› خفيفة، بنصب التاء. قال ابن عيينة: ما عَلَّموه حتى عَلِموه{16}. (٣/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٤<span class="dash">-</span></span> عن أبي بكر: كان <span class="name-2">عاصم [بن أبي النجود]</span> يقرؤها: <span class="qpc-hafs">﴿بما كنتم تُعَلِّمُونَ الكتاب﴾</span> مثقلة، برفع التاء، وكسر اللام{17}. (٣/٦٤٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِن كُونُوا۟ رَبَّـٰنِیِّـۧنَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٣٤٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زِرٍّ- <span class="qpc-hafs">﴿ربانيين﴾</span>، قال: حُكَماء، علماء{18}. (٣/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>: هو الّذي يُرَبِّي علمَه بعمله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق عكرمة- <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، قال: حُلَماء، علماء، حُكَماء{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿ربانيين بما كنتم تعلمون الكتاب وبما كنتم تدرسون﴾</span>، قال: العلماء، الفقهاء{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٤٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿ربانيين﴾</span>، قال: فقهاء، مُعلِّمين{22}. (٣/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿ربانيين﴾</span>، قال: حُلَماء، علماء، حُكَماء{23}. (٣/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿ربانيين﴾</span>، قال: عُلَماء، فقهاء{24}. (٣/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٣<span class="dash">-</span></span> و<span class="name-2">عطية العوفي</span>، نحو ذلك{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ربانيين﴾</span>، قال: حكماء، فقهاء{26}. (٣/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق معمر، عن منصور بن المعتمر-: علماء، حلماء{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي رَزين [مسعود بن مالك الأسدي]</span> -من طريق سفيان، عن منصور بن المعتمر- <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، قال: حُكماء، علماء{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-، نحوه{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، قال: حلماء، فقهاء{30}. (٣/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٠٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- قال: <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، قال: علماء، فقهاء{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- <span class="qpc-hafs">﴿ربانيين﴾</span>، قال: حكماء، أتقياء{32}. (٣/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- <span class="qpc-hafs">﴿ولكن كونوا ربانيين﴾</span>، قال: كونوا فقهاء، علماء، حكماء{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- قال: الربّانِيُّون: الفقهاء العلماء، وهم فوق الأحبار{26}<span class=comment-ref>١٢٥٩</span>. (٣/٦٤٤)</p></p><p></div></p><p><div><span class=comment-ref>١٢٥٩</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٥/٥٣١ بتصرف) قول مجاهد بقوله: «لأنّ الأحبار هم العلماء، والرَّبّانيُّ: الجامع إلى العلمِ والفقهِ البصرَ بالسياسة، والتدبير، والقيام بأمور الرعية، وما يصلحهم في دنياهم ودينهم».</div></p><p><div></p><p><p><span class="item-no">١٣٥١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿كونوا ربانيين بما كنتم تعلمون الكتاب وبما كنتم تدرسون﴾</span>، يقول: كونوا فقهاء، كونوا علماء{35}. (٣/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٤<span class="dash">-</span></span> عن عباد بن منصور، قال: سألت <span class="name-2">الحسن [البصري]</span> عن قوله: <span class="qpc-hafs">﴿ولكن كونوا ربانيين﴾</span>. يقول: كونوا أهل عبادة، وأهل تقوى لله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف بن أبي جميلة- في قوله: <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، قال: كونوا فقهاء، علماء{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٦<span class="dash">-</span></span> وعن <span class="name-2">أبي رزين [مسعود بن مالك الأسدي]</span>، كذلك{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٧<span class="dash">-</span></span> عن <span class="name-2">يحيى بن عقيل</span> -من طريق أبي حمزة الثُّمالِيّ- في قوله: <span class="qpc-hafs">﴿الربانيون والأحبار﴾</span> [المائدة:٦٣]، قال: الفقهاء، العلماء{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولكن كونوا ربانيين﴾</span>، قال: كونوا فقهاء، علماء{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥١٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسباط بن نصر- في قوله: <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>: أما الربانيون: فالحكماء، الفقهاء{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، قال: كونوا فقهاء، علماء{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكن﴾</span> يقول لهم: <span class="qpc-hafs">﴿كونوا ربانيين﴾</span>، يعني: مُتَعَبِّدين لله ﷿{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- قال: الربانيون: الذين يَرُبُّون الناس، ولاة هذا الأمر، يَرُبُّونهم: يلونهم. وقرأ: <span class="qpc-hafs">﴿لولا ينهاهم الربانيون والأحبار﴾</span> [المائدة: ٦٣]، قال: الربانيون: الولاة، والأحبار: العلماء {44}<span class=comment-ref>١٢٦٠</span>. (٣/٦٤٤)</p></p><p></div></p><p><div><span class=comment-ref>١٢٦٠</span> اختلف في نسبة رباني، هل هي إلى الرب، من حيث هو العامل بطاعته، المعلم للناس ما أمر به؟، أم أن الرباني منسوب إلى الربان، وهو معلم الناس، وعالمهم السائس لأمرهم، مأخوذ من رب يرب إذا أصلح وربى، ثم نسب إليه رباني؟، وهو ما <span class="comment-type-3">رجَّحه</span> <u>ابنُ جرير</u> (٥/٥٢٩-٥٣٠) <span class="mustanad">مستندًا إلى اللغةِ</span>، فقال: "وأولى الأقوال عندي بالصواب في الربانيين: أنهم جمع رباني، وأن الرباني المنسوب إلى الربان ...، ومن ذلك قول علقمة بن عبدة:</p><p>فكُنْتَ امْرَأً أفْضَتْ إليك رِبابَتي ... وقَبْلَكَ رَبَّتْني فَضِعْتُ رُبُوبُ".</p><p>واختلف المفسرون في صفة من يستحق أن يقال له: رباني، و<span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (٥/٥٣٠-٥٣١) بين الأقوال الواردة باندراجها تحت عموم اللفظة؛ إذ العالم بالفقه والحكمة من المصلحين، وكذا التقي والحكيم، والوالي الذي يلي أمور الناس بما فيه الخير في دنياهم وأخراهم.</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ عطية</u> (٢/٢٦٩) بين الأقوال الواردة في صفة الرباني، فقال: «وجملة ما يُقال في الرباني: إنه العالم بالرب والشرع، المصيب في التقدير من الأقوال والأفعال التي يحاولها في الناس».</div></p><p><h3><span class="qpc-hafs">﴿بِمَا كُنتُمۡ تُعَلِّمُونَ ٱلۡكِتَـٰبَ وَبِمَا كُنتُمۡ تَدۡرُسُونَ ۝٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٣٥٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي رَزين [مسعود بن مالك الأسدي]</span> -من طريق منصور بن المعتمر- في قوله: <span class="qpc-hafs">﴿وبما كنتم تدرسون﴾</span>، قال: مذاكرة الفقه، كانوا يتذاكرون الفقه كما نتذاكرُه نحن{45}. (٣/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حميد الأعرج- <span class="qpc-hafs">﴿بما كنتم تعلمون﴾</span>: حقيقة ما عَلَّمُوه حتى عَلِمُوا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- قال: لا يعذر أحد حر، ولا عبد، ولا رجل، ولا امرأة لا يتعلم من القرآن جُهده ما بلغ منه؛ فإن الله يقول: <span class="qpc-hafs">﴿كونوا ربانيين بما كنتم تعلمون الكتاب وبما كنتم تدرسون﴾</span>{15}. (٣/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق ميمون الوَرّاق- في قوله: <span class="qpc-hafs">﴿كونوا ربانيين بما كنتم تعلمون الكتاب﴾</span>، قال: حَقٌّ على كل مَن تَعَلَّم القرآن أن يكون فقيهًا{48}. (٣/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٧<span class="dash">-</span></span> عن أبي بكر: كان <span class="name-2">عاصم [بن أبي النَّجود]</span> يقرؤها: <span class="qpc-hafs">﴿بما كنتم تُعَلِّمُونَ الكتاب﴾</span> مثقلة برفع التاء وكسر اللام، قال: القرآن، <span class="qpc-hafs">﴿وبما كنتم تدرسون﴾</span> قال: الفقه{49}. (٣/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بما كنتم تعلمون الكتاب﴾</span> يعني: التوراة والإنجيل، <span class="qpc-hafs">﴿وبما كنتم تدرسون﴾</span> يعني: تقرءون{13}<span class=comment-ref>١٢٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٢٦١</span> اختلف المفسرون في المدروس؛ <b>فذهب قوم</b>: إلى أنه الفقه. و<b>ذهب آخرون</b>: إلى أنه تلاوة القرآن.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/٥٣٢) القول الثاني <span class="mustanad">مستندًا إلى السياق</span>، فقال: «لأنه [يعني: الدراسة] عطف على قوله: <span class="qpc-hafs">﴿تعلمون الكتاب﴾</span>، والكتاب: هو القرآن، فلأن تكون الدراسة معنيًّا بها دراسة القرآن أولى مِن أن تكون معنيًّا بها دراسة الفقه الذي لم يَجْرِ له ذِكْرٌ».</div></p><p><div></p><p><p><span class="item-no">١٣٥٢٩<span class="dash">-</span></span> عن مقاتل بن محمد قال: سمعت <span class="name-3">وكيعًا</span> يقول في هذه الآية: سمعنا <span class="qpc-hafs">﴿بما كنتم تعلمون الكتاب﴾</span>، قال: القرآن{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٣٠<span class="dash">-</span></span> عن <span class="name-2">طلحة بن مُصَرِّف</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٣١<span class="dash">-</span></span> و<span class="name-3">سفيان الثوري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٣٢<span class="dash">-</span></span> و<span class="name-3">وكيع [بن الجرّاح]</span>، في قوله: <span class="qpc-hafs">﴿وبما كنتم تدرسون﴾</span>، قالوا: دِراية الفقه{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٣٣<span class="dash">-</span></span> عن عمر بن عبد الغفار القُهُندُزِيّ، قال: قال <span class="name-3">سفيان بن عيينة</span>: مَن قرأها <span class="qpc-hafs">﴿بما كنتم تعلمون الكتاب﴾</span>، قال: يقول: علِموا وعمِلوا، ثم عَلَّموا{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِمَا كُنتُمۡ تُعَلِّمُونَ ٱلۡكِتَـٰبَ وَبِمَا كُنتُمۡ تَدۡرُسُونَ ۝٧٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٣٥٣٤<span class="dash">-</span></span> قال <span class="name-2">محمد بن علي ابن الحنفية</span> يوم مات ابن عباس: مات رَبّانِيُّ هذه الأمّة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٣٥٣٥<span class="dash">-</span></span> قال <span class="name-2">مُرَّة بن شَراحِيل</span>: كان علقمة مِن الرَّبانييّن الذين يُعَلِّمون النّاس القرآن{55}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَأۡمُرَكُمۡ أَن تَتَّخِذُوا۟ ٱلۡمَلَـٰۤىِٕكَةَ وَٱلنَّبِیِّـۧنَ أَرۡبَابًاۗ أَیَأۡمُرُكُم بِٱلۡكُفۡرِ بَعۡدَ إِذۡ أَنتُم مُّسۡلِمُونَ ۝٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٣٥٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ولا يأمركم أن تتخذوا﴾</span>، قال: ولا يأمركم النبي ﷺ أن تتخذوا الملائكة والنبيين أربابًا{56}<span class=comment-ref>١٢٦٢</span>. (٣/٦٤٦)</p></p><p></div></p><p><div><span class=comment-ref>١٢٦٢</span> حكى <u>ابنُ جرير</u> (٥/٥٣٤) الخلاف في قراءة <span class="qpc-hafs">﴿يأمركم﴾</span> بين مَن قرأ برفع الراء على القطع؛ فيكون المعنى: ولا يأمركم الله، وبين من قرأ بالنصب؛ فيكون المعنى: ولا له أن يأمركم.</p><p>و<span class="comment-type-3">رجَّح</span> قراءة النصب بقوله: «وأولى القراءتين بالصواب في ذلك: <span class="qpc-hafs">﴿ولا يأمركم﴾</span> بالنصب على الاتصال بالذي قبله».</p><p>ولم يذكر (٥/٥٣٣) إلا قول ابن جريج.</div></p><p><div></p><p><p><span class="item-no">١٣٥٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يأمركم أن تتخذوا الملائكة والنبيين أربابا﴾</span> يعني: عيسى، وعزير، ولو أمركم بذلك لكان كفرًا، فذلك قوله: <span class="qpc-hafs">﴿أيأمركم بالكفر﴾</span> يعني: بعبادة الملائكة والنبيين، <span class="qpc-hafs">﴿بعد إذ أنتم مسلمون﴾</span> يعني: مخلصين له بالتوحيد{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البيهقي في الدلائل ٥/٣٨٤، وابن جرير ٥/٥٢٤، من طريق ابن إسحاق، عن محمد بن أبي محمد، عن عكرمة أو سعيد بن جبير، عن ابن عباس به.</p><p>وفي سنده محمد بن إسحاق، قال عنه ابن حجر في تقريب التهذيب (٥٧٢٥): «إمام المغازي، صدوق يدلس». وقد صرح بالتحديث عند البيهقي في الدلائل. وفيه أيضًا محمد بن أبي محمد مولى زيد بن ثابت، ذكره ابن حبان في الثقات ٧/٣٩٢، وقال عنه الذهبي في ميزان الاعتدال ٤/٢٦: «لا يعرف».تفسير الثعلبي ٣/١٠١.عزاه ابن حجر في العُجاب في بيان الأسباب ٢/٧٠٥ إلى عبد بن حميد.</p><p>قال الزَّيْلَعِي في تخريج أحاديث الكشاف ١/١٩٢: «غريب».تفسير البغوي ٣/٦٠.أخرجه ابن أبي حاتم ٢/٦٩٠.أخرجه ابن أبي حاتم ٢/٦٩٠.تفسير البغوي ٣/٦٠.أخرجه ابن أبي حاتم ٢/٦٩١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زَمَنين ١/٢٩٨-.أخرجه ابن جرير ٥/٥٢٥.أخرجه ابن جرير ٥/٥٢٥، وابن أبي حاتم ٢/٦٩١.أخرجه ابن أبي حاتم ٢/٦٩١. وأَخرج ابن جرير ٥/٥٢٥ نحوه من طريق حجاج.تفسير مقاتل بن سليمان ١/٢٨٦.أخرجه ابن المنذر (٦٤٨).عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/٥٣٢، وابن المنذر (٦٤٩)، وابن أبي حاتم ٢/٦٩٢. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/٥٣٣. وعزاه السيوطي إلى عَبد بن حُمَيد.</p><p>قرأ ابن عامر الشامي والكوفيون بضم التاء وفتح العين وكسر اللام مشددة، وقرأ الباقون بفتح التاء وإسكان العين وفتح اللام مخففة. انظر: التيسير ص٨٩، والنشر ٢/٢٤٠.أخرجه ابن المنذر ١/٢٦٧.تفسير الثعلبي ٣/١٠٢، وتفسير البغوي ١/٦١.أخرجه ابن أبي حاتم ٢/٦٩١.أخرجه ابن أبي حاتم ٢/٦٩٢.أخرجه ابن المنذر ١/٢٦٧، وابن أبي حاتم ٢/٦٩١.أخرجه ابن المنذر (٦٤٣)، وابن أبي حاتم ٢/٦٩١. وعزاه السيوطي إلى ابن جرير.أخرجه ابن جرير ٥/٥٢٨، وابن أبي حاتم ٢/٦٩٢.علَّقه ابن أبي حاتم ٢/٦٩٢.أخرجه ابن جرير ٥/٥٢٨.أخرجه عبد الرزاق ١/١٢٥، وابن أبي الدنيا في كتاب الحلم -موسوعة ابن أبي الدنيا ٢/٢٨ (٩)-. وعلَّقه ابن أبي حاتم ٢/٦٩١.أخرجه الثوري في تفسيره ص٧٨، وابن المنذر ١/٢٦٨، وابن جرير ٥/٥٢٦.أخرجه ابن جرير ٥/٥٢٧.عزاه السيوطي إلى البيهقي في الشعب، وفيه (١٨٥٦) بلفظ: علماء، وفقهاء.أخرجه الدارمي ١/٣٥٤ (٣٤٠). وعلَّقه ابن المنذر ١/٢٦٧، وابن أبي حاتم ٢/٦٩٢.أخرجه ابن جرير ٥/٥٢٩. وعلَّقه ابن أبي حاتم ٢/٦٩٢.تفسير مجاهد ص٢٥٤.أخرجه ابن جرير ٥/٥٢٨.أخرجه ابن جرير ٥/٥٢٨، وابن أبي حاتم ٢/٦٩٢. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٦٩١.أخرجه ابن جرير ٥/٥٢٦، وابن المنذر ١/٢٦٧. وعلَّقه ابن أبي حاتم ٢/٦٩٢.علَّقه ابن المنذر ١/٢٦٧.أخرجه ابن جرير ٥/٥٢٨.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٣٦، وابن جرير ٥/٥٢٧. وعلَّقه ابن المنذر ١/٢٦٧، وابن أبي حاتم ٢/٦٩٢.أخرجه ابن جرير ٥/٥٢٧.أخرجه أبو جعفر الرملي في جزئه ص١٠١ – (تفسير عطاء الخراساني). وعلَّقه ابن أبي حاتم ٢/٦٩٢.تفسير مقاتل بن سليمان ١/٢٨٦.أخرجه ابن جرير ٥/٥٢٩.أخرجه ابن أبي حاتم ٢/٦٩٢-٦٩٣.أخرجه ابن أبي حاتم ٢/٦٩٢.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه الدارمي ١/٣٥٣ (٣٣٨)، وابن المنذر ١/٢٨٦، وابن أبي حاتم ٢/٦٩٢.أخرجه ابن جرير ٥/٥٣٣. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ١/٢٨٦.أخرجه ابن أبي حاتم ٢/٦٩٢.علَّقه ابن أبي حاتم ٢/٦٩٣.أخرجه ابن أبي حاتم ٢/٦٩٢.تفسير الثعلبي ٣/١٠٢، وتفسير البغوي ١/٦١.تفسير الثعلبي ٣/١٠٢.أخرجه ابن جرير ٥/٥٣٥، وابن المنذر (٦٥١).تفسير مقاتل بن سليمان ١/٢٨٦.
