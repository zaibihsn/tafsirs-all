  52,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ تَمُورُ ٱلسَّمَاۤءُ مَوۡرࣰا ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: تحرَّك{1}. (١٣/٧٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: يوم تشقّق السماء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: تدور دورًا{3}. (١٣/٧٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>: يعني: استدارتها وتحريكها لأمر الله، ومَوْج بعضها في بعض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٣<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: <span class="qpc-hafs">﴿تَمُورُ﴾</span> تختلف{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: مَوْرها: تحرُّكها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٥<span class="dash">-</span></span> قال <span class="name-2">عطاء الخُراسانيّ</span>: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span> تختلف أجزاؤها بعضها في بعض{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أخبر متى يقع بهم العذاب، فقال: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span> يعني: استدارتها وتحريكها بعضها في بعضٍ من الخوف{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: هذا يوم القيامة، وأما المَوْرُ فلا عِلْمَ لنا به{2}<span class=comment-ref>٦٢٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤١</span> <span class="comment-type-1">فُسّر</span> «المور» بالحركة، <b>وفُسّر</b> بالدوران، <b>وفُسّر</b> بالتموج والاضطراب والتشقق.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٩) على تلك المعاني بقوله: «وهذه كلها تفاسير بالمعنى؛ لأن السماء العالية يعتريها هذا كله».</p><p>و<span class="comment-type-4">ساق</span> <u>ابنُ القيم</u> (٣/٥٥) ما جاء في تفسير المور، ثم قال: «والتحقيق أنه حركة في تموّج وتكفؤ وذهاب ومجيء؛ ولهذا فرق بين حركة السماء وحركة الجبال، فقال: <span class="qpc-hafs">﴿وتَسِيرُ الجِبالُ سَيْرًا﴾</span>، وقال: <span class="qpc-hafs">﴿وإذا الجِبالُ سُيِّرَتْ﴾</span> [التكوير:٣] من مكان إلى مكان، وأما السماء فإنها تتكفّأ، وتموج، وتذهب، وتجيء».</div></p><p><div></p><p><p><span class="item-no">٧٢٩١٨<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿يوم تمور السماء مورًا﴾</span> قال: فيها تقديم <span class="qpc-hafs">﴿إن عذاب ربك لواقع﴾</span> بهم <span class="qpc-hafs">﴿يوم تمور السماء مورًا﴾</span>{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٧٢، وابن أبي حاتم -كما في الإتقان ٢/٤٥-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٧٣.أخرجه ابن جرير ٢١/٥٧٢-٥٧٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٧٣.تفسير الثعلبي ٩/١٢٦.أخرجه عبد الرزاق ٢/٢٤٧، وابن جرير ٢١/٥٧٣ من طريق سعيد أيضًا.تفسير الثعلبي ٩/١٢٦، وتفسير البغوي ٧/٣٨٧ بنحوه.تفسير مقاتل بن سليمان ٤/١٤٤.أخرجه ابن جرير ٢١/٥٧٣.أخرجه أبو عمرو الداني في المكتفى ص٢٠٥ (٣٦).
  52,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَسِیرُ ٱلۡجِبَالُ سَیۡرࣰا ۝١٠ فَوَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١١ ٱلَّذِینَ هُمۡ فِی خَوۡضࣲ یَلۡعَبُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَسِيرُ الجِبالُ سَيْرًا﴾</span> مِن أمكنتها حتى تستوي بالأرض كالأديم الممدود، <span class="qpc-hafs">﴿فَوَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالعذاب <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي خَوْضٍ يَلْعَبُونَ﴾</span> يعني: في باطلٍ لاهون{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَسِیرُ ٱلۡجِبَالُ سَیۡرࣰا ۝١٠ فَوَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١١ ٱلَّذِینَ هُمۡ فِی خَوۡضࣲ یَلۡعَبُونَ ۝١٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق حُصين بن عقبة- قال: أكثرُ الناس خطايا أكثرُهم خوْضًا في الباطل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٤.أخرجه إسحاق البستي عند تفسير هذه الآية ص٤٤٨.
  52,11,""
  52,10,""
  52,11,""
  52,12,""
  52,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ یُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا ۝١٣ هَـٰذِهِ ٱلنَّارُ ٱلَّتِی كُنتُم بِهَا تُكَذِّبُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ﴾</span>، قال: يُدفَعون{1}. (١٣/٧٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ﴾</span>، قال: يُدفعون فيها دفعًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُدفع في أعناقهم حتى يَرِدوا النار{3}<span class=comment-ref>٦٢٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٩) على هذا القول بقوله: «<span class="mustanad">ومنه قوله تعالى</span>: <span class="qpc-hafs">﴿فذلك الذي يدع اليتيم﴾</span> [الماعون:٢]».</div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ﴾</span>، قال: يُدفعون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>: الدَّعّ: الدَّفع والإرهاق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، يقول: يُدفعون إلى نار جهنم دفعًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُدفعون إليها دفعًا{7}. (١٣/٧٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُزعَجون إليها إزعاجًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: والويل لهم <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span> وذلك أنّ خزنة جهنم بعد الحساب يغلّون بأيدي الكفار إلى أعناقهم، ثم يجمعون نواصيهم إلى أقدامهم وراء ظهورهم، ثم يدفعونهم في جهنم دفعًا على وجوههم، إذا دَنَوا منها قالت لهم خزنتُها: <span class="qpc-hafs">﴿هذِهِ النّارُ الَّتِي كُنْتُمْ بِها تُكَذِّبُونَ﴾</span> في الدنيا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٣٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُدفَعون دفعًا. وقرأ قول الله تبارك وتعالى: <span class="qpc-hafs">﴿فَذَلِكَ الَّذِي يَدُعُّ اليَتِيمَ﴾</span> [الماعون:٢]، قال: يدفعه ويُغْلِظ عليه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٧٥، وبنحوه من طريق عطية، وابن أبي حاتم -كما في الإتقان ٢/٤٥-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٧٥، كما أخرجه إسحاق البستي ص٤٤٨ من طريق عطاء الخُراسانيّ.أخرجه ابن جرير ٢١/٥٧٥.تفسير مجاهد ص٦٢٣، وأخرجه ابن جرير ٢١/٥٧٦.أخرجه ابن جرير ٢١/٥٧٦.أخرجه ابن جرير ٢١/٥٧٥.عزاه السيوطي إلى سعيد بن منصور.أخرجه عبد الرزاق ٢/٢٤٧، وابن جرير ٢١/٥٧٦، ومن طريق سعيد أيضًا.تفسير مقاتل بن سليمان ٤/١٤٤.أخرجه ابن جرير ٢١/٥٧٦.
  52,14,""
  52,14,""
  52,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَسِحۡرٌ هَـٰذَاۤ أَمۡ أَنتُمۡ لَا تُبۡصِرُونَ ۝١٥ ٱصۡلَوۡهَا فَٱصۡبِرُوۤا۟ أَوۡ لَا تَصۡبِرُوا۟ سَوَاۤءٌ عَلَیۡكُمۡۖ إِنَّمَا تُجۡزَوۡنَ مَا كُنتُمۡ تَعۡمَلُونَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَسِحْرٌ هَذا﴾</span> العذاب الذي ترون، فإنكم زعمتم في الدنيا أنّ الرسل سَحرة <span class="qpc-hafs">﴿أمْ أنْتُمْ لا تُبْصِرُونَ﴾</span>، فلما أُلقوا في النار قالت لهم الخزنة: <span class="qpc-hafs">﴿اصْلَوْها فاصْبِرُوا أوْ لا تَصْبِرُوا سَواءٌ عَلَيْكُمْ إنَّما تُجْزَوْنَ ما كُنْتُمْ تَعْمَلُونَ﴾</span> مِن الكفر والتكذيب في الدنيا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٤.
  52,16,""
  52,16,""
  52,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَعِیمࣲ ۝١٧ فَـٰكِهِینَ بِمَاۤ ءَاتَىٰهُمۡ رَبُّهُمۡ وَوَقَىٰهُمۡ رَبُّهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ﴾</span> يعني: الذين يَتَّقون الشرك <span class="qpc-hafs">﴿فِي جَنّاتٍ﴾</span> يعني: البساتين، <span class="qpc-hafs">﴿ونَعِيمٍ فاكِهِينَ﴾</span> يعني: مُعجبين، وناعمين محبُورين <span class="qpc-hafs">﴿بِما آتاهُمْ﴾</span> يعني: بما أعطاهم <span class="qpc-hafs">﴿رَبُّهُمْ﴾</span> في الجنة مِن الخير والكرامة، <span class="qpc-hafs">﴿ووَقاهُمْ رَبُّهُمْ عَذابَ الجَحِيمِ﴾</span>{1}<span class=comment-ref>٦٢٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٩٠) أن قوله تعالى: <span class="qpc-hafs">﴿إنّ المُتَّقِينَ فِي جَنّات:..﴾</span> <b>يحتمل</b> أن يكون خطاب أهل النار، فيكون إخبارهم بذلك زيادة في غمّهم وسُوء حالهم. ثم ساق <b>احتمالًا</b>، فقال: «ويحتمل أن يكون إخبارًا لمحمد ﷺ ومعاصريه، لما فرغ من ذكر عذاب الكفار، عقّب ذلك بنعيم المتقين ليبين الفرق ويقع التحريض على الإيمان». و<span class="comment-type-3">رجَّحه</span> بقوله: «وهو الأظهر». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٤-١٤٥.
