  52,35,""
  52,36,""
  52,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ عِندَهُمۡ خَزَاۤىِٕنُ رَبِّكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٣٢<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿أمْ عِنْدَهُمْ خَزائِنُ رَبِّكَ﴾</span> يعني: النبوة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٣٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿أمْ عِنْدَهُمْ خَزائِنُ رَبِّكَ﴾</span> خزائن المطر والرزق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ عِنْدَهُمْ خَزائِنُ﴾</span> يعني: أعندهم خزائن <span class="qpc-hafs">﴿رَبِّكَ﴾</span> يعني: أعندهم خزائن ربك، يقول: أبأيديهم مفاتيح ربّك بالرسالة، فيضعونها حيث شاؤوا، يقول: ولكنّ الله يختار لها مَن يشاء مِن عباده، لقولهم: <span class="qpc-hafs">﴿أأُنْزِلَ عَلَيْهِ الذِّكْرُ مِن بَيْنِنا﴾</span> [ص:٨]؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿أمْ هُمُ المُصَيْطِرُونَ﴾</span>{3}<span class=comment-ref>٦٢٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٥٣</span> <span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/٩٩) عن الزهراوي أنه قال: يريد بالخزائن: العلم. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا قول حسن إذا تؤمّل وبُسط».</div></p><p><h3><span class="qpc-hafs">﴿أَمۡ هُمُ ٱلۡمُصَۣیۡطِرُونَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أمْ هُمُ المُصَيْطِرُونَ﴾</span>، قال: المُسلَّطون{4}. (١٣/٧١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿أمْ هُمُ المُصَيْطِرُونَ﴾</span>، قال: أم هم المُنزِلون{5}. (١٣/٧١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٣٧<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿أمْ هُمُ المُصَيْطِرُونَ﴾</span> أم هم أربابٌ قاهرون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿أمْ هُمُ المُصَيْطِرُونَ﴾</span>، يعني: أم هم المُسيطرون على الناس، فيجبرونهم على ما شاءوا، ويمنعونهم عما شاءوا{3}<span class=comment-ref>٦٢٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٥٤</span> اختُلف في المراد بـ<span class="qpc-hafs">﴿المصيطرون﴾</span> على أقوال: <b>الأول</b>: أنهم المُسلّطون. <b>الثاني</b>: المُنزلون. <b>الثالث</b>: الأرباب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢١/٥٩٨) -<span class="mustanad">مستندًا إلى اللغة، والنظائر</span>- القول الأول الذي قاله ابن عباس من طريق علي، ومقاتل، فقال: «وذلك أن المسيطر في كلام العرب: الجبّار المتسلّط، ومنه قول الله: <span class="qpc-hafs">﴿لست عليهم بمصيطر﴾</span> [الغاشية:٢٢]، يقول: لست عليهم بجبّار متسلّط».</div></p></div>",footnotes:1:تفسير البغوي ٧/٣٩٢.تفسير البغوي ٧/٣٩٢.تفسير مقاتل بن سليمان ٤/١٤٧-١٤٨.أخرجه ابن جرير ٢١/٥٩٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢١/٥٩٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٩/١٣١، وتفسير البغوي ٧/٣٩٢، وأورد عقبه: فلا يكونوا تحت أمر ونهي، يفعلون ما شاؤوا.تفسير مقاتل بن سليمان ٤/١٤٧-١٤٨.
  52,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ لَهُمۡ سُلَّمࣱ یَسۡتَمِعُونَ فِیهِۖ فَلۡیَأۡتِ مُسۡتَمِعُهُم بِسُلۡطَـٰنࣲ مُّبِینٍ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ لَهُمْ سُلَّمٌ يَسْتَمِعُونَ فِيهِ﴾</span> يعني: ألَهُم سُلّمٌ إلى السماء يصعدون فيه، يعني: عليه، مثل قوله: <span class="qpc-hafs">﴿ولَأُصَلِّبَنَّكُمْ فِي جُذُوعِ النَّخْلِ ولَتَعْلَمُنَّ أيُّنا أشَدُّ عَذابًا وأَبْقى﴾</span> [طه:٧١]، يعني: على جذوع النخل، فيستمعون الوحي مِن الله تعالى إلى النبي ﷺ، <span class="qpc-hafs">﴿فَلْيَأْتِ مُسْتَمِعُهُمْ﴾</span> يعني: صاحبهم الذي يستمع الوحي <span class="qpc-hafs">﴿بِسُلْطانٍ مُبِينٍ﴾</span> يعني: بحُجّةٍ بيّنة بأنّه يقدر على أن يسمع الوحي من الله تعالى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿فَلْيَأْتِ مُسْتَمِعُهُمْ﴾</span>، قال: صاحبهم{2}. (١٣/٧٠٩)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٨.عزاه السيوطي إلى ابن المنذر.
  52,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ لَهُ ٱلۡبَنَـٰتُ وَلَكُمُ ٱلۡبَنُونَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ لَهُ البَناتُ ولَكُمُ البَنُونَ﴾</span> وذلك أنهم قالوا: الملائكة بنات الله. فقال الله تعالى لنبيّه ﷺ في الصافات [١٤٩]: <span class="qpc-hafs">﴿فاسْتَفْتِهِمْ﴾</span> يعني: سَلْهم؛ <span class="qpc-hafs">﴿ألِرَبِّكَ البَناتُ ولَهُمُ البَنُونَ﴾</span>. فسألهم النبيُّ ﷺ في هذه السورة: <span class="qpc-hafs">﴿أمْ لَهُ البَناتُ ولَكُمُ البَنُونَ﴾</span>. وفي النجم [٢١-٢٢] قال: <span class="qpc-hafs">﴿ألَكُمُ الذَّكَرُ ولَهُ الأُنْثى تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٨.
  52,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا فَهُم مِّن مَّغۡرَمࣲ مُّثۡقَلُونَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ أجْرًا فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</span>، يقول: هل سألتَ هؤلاء القوم أجرًا يجهدهم، فلا يستطيعون الإسلام؟!{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ تَسْئَلُهُمْ أجْرًا﴾</span> على الإيمان، يعني: جزاء، يعني: خَراجًا؛ <span class="qpc-hafs">﴿فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</span> يقول: أثْقلهم الغُرم، فلا يستطيعون الإيمان مِن أجل الغُرم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ أجْرًا فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</span>، يقول: أسألتَ هؤلاء القوم على الإسلام أجرًا، فمنعهم مِن أن يسلموا الجُعل؟!{3}. (١٣/٧٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ أجْرًا فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</span>، قال: يقول: أسألَهم على هذا أجرًا، فأَثقَلهم الذي يَبتغي أخذه منهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٩٩.تفسير مقاتل بن سليمان ٤/١٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٩٩.
  52,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ عِندَهُمُ ٱلۡغَیۡبُ فَهُمۡ یَكۡتُبُونَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٤٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿أمْ عِنْدَهُمُ الغَيْبُ﴾</span> أم عندهم اللوح المحفوظ؟{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: لَمّا قالوا: <span class="qpc-hafs">﴿نَتَرَبَّصُ بِهِ رَيْبَ المَنُونِ﴾</span> قال الله تعالى: <span class="qpc-hafs">﴿أمْ عِنْدَهُمُ الغَيْبُ﴾</span> حتى علموا بموت محمد، وإلى ما يؤول أمره؟{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ عِنْدَهُمُ﴾</span> يقول: أعندهم عِلم <span class="qpc-hafs">﴿الغَيْبُ﴾</span> بأنّ الله لا يبعثهم، وأنّ ما يقول محمد غير كائن، ومعهم بذلك كتاب، <span class="qpc-hafs">﴿فَهُمْ يَكْتُبُونَ﴾</span> ما شاءوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٠٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله:<span class="qpc-hafs">﴿أمْ عِنْدَهُمُ الغَيْبُ﴾</span>، قال: القرآن{4}. (١٣/٧٠٩)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٣٢، وتفسير البغوي ٧/٣٩٣، وأورد عقبه: فهم يكتبون ما فيه ويخبرون الناس به؟.تفسير الثعلبي ٩/١٣٢.تفسير مقاتل بن سليمان ٤/١٤٩.عزاه السيوطي إلى ابن المنذر.
  52,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ یُرِیدُونَ كَیۡدࣰاۖ فَٱلَّذِینَ كَفَرُوا۟ هُمُ ٱلۡمَكِیدُونَ ۝٤٢ أَمۡ لَهُمۡ إِلَـٰهٌ غَیۡرُ ٱللَّهِۚ سُبۡحَـٰنَ ٱللَّهِ عَمَّا یُشۡرِكُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٠٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ يُرِيدُونَ﴾</span> يقول: أيريدون في دار الندوة <span class="qpc-hafs">﴿كَيْدًا﴾</span> يعني: مكرًا بمحمد ﷺ، <span class="qpc-hafs">﴿فالَّذِينَ كَفَرُوا﴾</span> مِن أهل مكة <span class="qpc-hafs">﴿هُمُ المَكِيدُونَ﴾</span> يقول: هم الممكور بهم، فقتلهم الله ﷿ ببدر، <span class="qpc-hafs">﴿أمْ لَهُمْ﴾</span> يقول: ألهم <span class="qpc-hafs">﴿إلهٌ غَيْرُ اللَّهِ﴾</span> يمنعهم مِن دوننا، مِن مكْرنا بهم، يعني: القتل ببدر، فنَزَّه الربّ نفسه تعالى من أن يكون معه شريك، فذلك قوله: <span class="qpc-hafs">﴿سُبْحانَ اللَّهِ عَمّا يُشْرِكُونَ﴾</span> معه{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٩.
