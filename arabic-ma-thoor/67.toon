  67,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا رَأَوۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٢٦<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿فَلَمّا رَأَوْهُ﴾</span> يعني: العذاب ببدر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٢٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿فَلَمّا رَأَوْهُ﴾</span>، قال: لَمّا عايَنوه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَلَمّا رَأَوْهُ﴾</span>، قال: لَمّا رَأوا عذاب الله{3}. (١٤/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا رَأَوْهُ﴾</span> يعني: العذاب والنار في الآخرة{4}<span class=comment-ref>٦٧٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٩</span> <span class="comment-type-3">رجّح</span> <u>ابنُ تيمية</u> (٦/٣٦٧ بتصرف) في عوْد الضمير في قوله: <span class="qpc-hafs">﴿فلما رأوه﴾</span> ما جاء في قول مقاتل وغيره مِن أنه عائد على ما وُعدوا من العذاب يوم القيامة، وذكر قولًا لم يَنسبه لأحد مِن السلف أنّ الضمير عائد على الله تعالى، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى السياق</span>، فقال: «ومَن قال: إنّ الضمير عائد هنا إلى الله. فقوله ضعيف؛ فإنّ الله قال: <span class="qpc-hafs">﴿ويقولون متى هذا الوعد إن كنتم صادقين قل إنما العلم عند الله وإنما أنا نذير مبين فلما رأوه زلفة سيئت وجوه الذين كفروا وقيل هذا الذي كنتم به تدعون﴾</span>، فهذا يُبيّن أنّ الذي رَأوه هو الوعد، أي: الموعود به من العذاب، ألا تراه يقول: <span class="qpc-hafs">﴿وقيل هذا الذي كنتم به تدعون﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿زُلۡفَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿زُلْفَةً﴾</span>، قال: قد اقترب{5}. (١٤/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿زُلْفَةً﴾</span> قريبًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: <span class="qpc-hafs">﴿زُلْفَةً﴾</span> الزُّلفة: حاضرٌ، قد حضرهم عذاب الله ﷿{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سِیۤـَٔتۡ وُجُوهُ ٱلَّذِینَ كَفَرُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾</span>، قال: سِيئت بما رأتْ من عذاب الله وهَوانه{8}. (١٤/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾</span>، يعني: سِيئ لذلك وجوههم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقِیلَ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَدَّعُونَ ۝٢٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٣٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأ: ‹وقِيلَ هَذا الَّذِي كُنتُم بِهِ تَدْعُونَ› مُخفّفة{10}. (١٤/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبان العطار، وسعيد بن أبي عَروبة- أنه قرأها: ‹الَّذِي كُنتُم بِهِ تَدْعُونَ› خفيفة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٣٧<span class="dash">-</span></span> عن أبي بكر بن عيّاش، أنّ <span class="name-2">عاصمًا</span> قرأ: <span class="qpc-hafs">﴿تَدَّعُونَ﴾</span> مُثقّلة{12}<span class=comment-ref>٦٧١٠</span>. (١٤/٦١٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٠</span> ذكر <u>ابنُ جرير</u> (٢٣/١٣٧) القراءتين، و<span class="comment-type-1">وجّههما</span>، فقال: «واختلفت القرّاء في قراءة ذلك، فقرأته عامة قراء الأمصار: <span class="qpc-hafs">﴿هذا الذي كنتم به تدعون﴾</span> بتشديد الدال، بمعنى: تفتعلون من الدعاء. وذكر عن قتادة، والضَّحّاك أنهما قرآ ذلك: ‹تَدْعُونَ› بمعنى: تفعلون في الدنيا».</p><p>و<span class="comment-type-1">وجّههما</span> <u>ابنُ عطية</u> (٨/٣٦٢-٣٦٣)، فقال: «وقرأ جمهور الناس ونافع بخلاف عنه: <span class="qpc-hafs">﴿تدعون﴾</span> بفتح الدال وشدّها، على وزن: تفتعلون، أي: تتداعون أمره بينكم، وقال الحسن: يدّعون أنه لا جنة ولا نار. وقرأ أبو رجاء، والحسن، والضَّحّاك، وقتادة، وابن يَسار، وسلام: (يَدْعُونَ) بسكون الدال على معنى: يستعجلون، كقولهم: <span class="qpc-hafs">﴿عَجِّلْ لَنا قِطَّنا﴾</span> [ص:١٦]، و<span class="qpc-hafs">﴿فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ﴾</span> [الأنفال:٣٢]، وغير ذلك».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابن جرير</u> -<span class="mustanad">مستندًا لإجماع الحجة من القراء</span>- قراءة التشديد، فقال: «والصواب من القراءة في ذلك ما عليه قراء الأمصار؛ لإجماع الحُجّة من القراء عليه».</div></p><p><h3><span class="qpc-hafs">﴿وَقِیلَ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَدَّعُونَ ۝٢٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٣٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾</span> تدّعون أن لا جنة ولا نار{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبان العطار، وسعيد بن أبي عَروبة- أنه قرأها: (الَّذِي كُنتُم بِهِ تَدْعُونَ) خفيفة، ويقول: كانوا يَدْعُون بالعذاب. ثم قرأ: <span class="qpc-hafs">﴿وإذ قالوا اللهم إن كان هذا هو الحق من عندك فأمطر علينا حجارة من السماء أو ائتنا بعذاب أليم﴾</span> [الأنفال:٣٢]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقِيلَ﴾</span> لهم، يعني: قالتْ لهم الخَزنة: <span class="qpc-hafs">﴿هَذا﴾</span> العذاب <span class="qpc-hafs">﴿الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾</span> يعني: تَمتَرون في الدنيا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٤١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وقِيلَ هَذا الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾</span>، قال: استعجالهم بالعذاب{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٤٢<span class="dash">-</span></span> قال <span class="name-3">أبو بكر بن عياش</span>: تفسير <span class="qpc-hafs">﴿تَدَّعُونَ﴾</span>: تَستعجلون{12}. (١٤/٦١٥)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/٣٦١، وتفسير البغوي ٨/١٨٠.أخرجه ابن جرير ٢٣/١٣٦.أخرجه عبد الرزاق ٢/٣٠٦، وابن جرير ٢٣/١٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٤.تفسير مجاهد ص٦٦٧، وأخرجه ابن جرير ٢٣/١٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٤.أخرجه ابن جرير ٢٣/١٣٦.أخرجه عبد الرزاق ٢/٣٠٦، وابن جرير ٢٣/١٣٥-١٣٦، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٤.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿تَدَّعُونَ﴾</span> بفتحها مشددة. انظر: النشر ٢/٣٨٩، والإتحاف ص٥٥١.أخرجه ابن جرير ٢٣/١٣٧.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٣٦١.أخرجه ابن جرير ٢٣/١٣٧.تفسير مقاتل بن سليمان ٤/٣٩٤.أخرجه ابن جرير ٢٣/١٣٧.عزاه السيوطي إلى عبد بن حميد.
  67,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَهۡلَكَنِیَ ٱللَّهُ وَمَن مَّعِیَ أَوۡ رَحِمَنَا فَمَن یُجِیرُ ٱلۡكَـٰفِرِینَ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> لكفار مكة، يا محمد: <span class="qpc-hafs">﴿أرَأَيْتُمْ إنْ أهْلَكَنِيَ اللَّهُ﴾</span> إنْ عذَّبني الله، <span class="qpc-hafs">﴿ومَن مَعِيَ﴾</span> من المؤمنين <span class="qpc-hafs">﴿أوْ رَحِمَنا﴾</span> فلم يُعذّبنا، وأَنعَم علينا؛ <span class="qpc-hafs">﴿فَمَن يُجِيرُ الكافِرِينَ﴾</span> فمَن يُؤمّنكم أنتم <span class="qpc-hafs">﴿مِن عَذابٍ ألِيمٍ﴾</span> وجيع{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٤.
  67,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ هُوَ ٱلرَّحۡمَـٰنُ ءَامَنَّا بِهِۦ وَعَلَیۡهِ تَوَكَّلۡنَاۖ فَسَتَعۡلَمُونَ مَنۡ هُوَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ هُوَ الرَّحْمنُ﴾</span> الذي يفعل ذلك <span class="qpc-hafs">﴿آمَنّا بِهِ﴾</span> يقول: صدَّقنا بتوحيده؛ إن شاء أهلكنا أو عذَّبنا، <span class="qpc-hafs">﴿وعَلَيْهِ تَوَكَّلْنا﴾</span> يعني: بالله وثقنا، <span class="qpc-hafs">﴿فَسَتَعْلَمُونَ﴾</span> عند نزول العذاب <span class="qpc-hafs">﴿مَن هُوَ فِي ضَلالٍ مُبِينٍ﴾</span> يعني: باطل ليس بشيء، أنحن أم أنتم؟{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٤.
  67,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٤٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق سفيان - قال: نزلت هذه الآية: <span class="qpc-hafs">﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ غَوْرًا﴾</span> في بئر زمزم، وبئر ميمون بن الحَضرميّ{1}، وكانت جاهليةً{2}<span class=comment-ref>٦٧١١</span>. (١٤/٦١٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١١</span> ذكر <u>ابنُ عطية</u> (٨/٣٦٣) ما جاء في هذا الأثر، ثم قال <span class="comment-type-4">معلِّقًا</span>: «ويشبه أن تكون هاتان عُظْم ماءِ مكة، وإلا فكانت فيها آبار كثيرة كخُم والجَفر وغيرهما».</div></p><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿غَوْرًا﴾</span>، قال: داخِلًا في الأرض{3}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿غَوْرًا﴾</span>، قال: يَرجع في الأرض{3}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٤٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- <span class="qpc-hafs">﴿غَوْرًا﴾</span>: لا تَناله الدِّلاء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٤٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿غَوْرًا﴾</span>: ذاهِبًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿غَوْرًا﴾</span>، قال: ذاهبًا{7}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٢<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ غَوْرًا﴾</span>، يعني: ماء زمزم، وبئر ميمون الحضرمي، وهي بئر عادية قديمة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ﴾</span> يعني: ماء زمزم وغيره <span class="qpc-hafs">﴿غَوْرًا﴾</span> يعني: غارَ في الأرض، فذَهب؛ فلم تَقدِروا عليه{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَن یَأۡتِیكُم بِمَاۤءࣲ مَّعِینِۭ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>، قال: الجاري{3}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>، قال: عَذْب{11}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>، قال: ظاهِر{12}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٨<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر-، مثله{13}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>، قال: الظّاهر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>: جارٍ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>، المعين: الذي أصله من العيون{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ماءٍ مَعِينٍ﴾</span>، قال: الجاري{7}. (١٤/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَمَن يَأْتِيكُمْ بِماءٍ مَعِينٍ﴾</span> ظاهر تَناله الدِّلاء{9}. (ز)</p></p><p></div></p></div>",footnotes:1:قال الفاكهي عن بئر ميمون ٤/١٠٤: «وكانت آخر بئر حفرت [في مكة] من هذه البئار في الجاهلية، ولم يكن بمكة يومئذ ماء يشرب إلا زمزم، وبئر ميمون».أخرجه الفاكهي في أخبار مكة ٤/١٠٥. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٣٩.أخرجه ابن جرير ٢٣/١٣٩.أخرجه ابن جرير ٢٣/١٣٩. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٣٦٢، وتفسير البغوي ٨/١٨١.تفسير مقاتل بن سليمان ٤/٣٩٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٣٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد. وأخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٧- عن عكرمة. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٦- عن عكرمة.أخرجه ابن جرير ٢٣/١٣٩.أخرجه ابن جرير ٢٣/١٣٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٦-.أخرجه ابن جرير ٢٣/١٣٩. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٣٩٤.
  68,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٦٤<span class="dash">-</span></span> عن عائشة، قالت: نزلت سورة <span class="qpc-hafs">﴿ن والقلم﴾</span> بمكة{1}. (١٤/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ- قال: كانتْ إذا نزلت فاتحةُ سورةٍ بمكة كُتِبتْ بمكة، ثم يزيد الله فيها ما شاء، وكان أول ما نزل من القرآن: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</span>، ثم <span class="qpc-hafs">﴿ن والقلم﴾</span>، ثم المُزَّمِّل، ثم المُدَّثِّر{2}. (١٤/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة <span class="qpc-hafs">﴿ن والقلم﴾</span> بمكة{3}. (١٤/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وذكراها بمسمّى: <span class="qpc-hafs">﴿ن والقلم﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٦٩<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٠<span class="dash">-</span></span> عن محمد بن شهاب الزُّهريّ: مكّيّة، وذكرها بمسمّى: سورة <span class="qpc-hafs">﴿ن﴾</span>، وأنها نَزَلَتْ بعد: <span class="qpc-hafs">﴿اقرأ باسم ربك الذي خلق﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧١<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٢<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة <span class="qpc-hafs">﴿ن﴾</span> مكّيّة، عددها اثنتان وخمسون آية كوفي{8}<span class=comment-ref>٦٧١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٦٤) أنّ السورة مكّيّة <span class="mustanad">بلا خلاف بين أهل التأويل</span>.</div></p><p><h3><span class="qpc-hafs">﴿نۤۚ وَٱلۡقَلَمِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٧٣<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>إنّ أول ما خَلَق الله القلم والحوت، قال: اكتب. قال: ما أكتب؟ قال: كلّ شيء كائن إلى يوم القيامة</b>». ثم قرأ: <b><span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span></b>. فالنُّون: الحوت، والقلم: القلم{9}. (١٤/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٤<span class="dash">-</span></span> عن عبد الله بن عباس، في قوله: <span class="qpc-hafs">﴿ن والقَلَمِ﴾</span>، قال: قال رسول الله ﷺ: «<b>النُّون: السمكة التي عليها قَرار الأرضين، والقلم الذي خَطّ به ربّنا ﷿ القدَر؛ خيره وشَرّه، ضُرّه ونفْعه، <span class="qpc-hafs">﴿وما يَسْطُرُونَ﴾</span> قال: الكِرام الكاتبون</b>»{1}. (١٤/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٥<span class="dash">-</span></span> عن قُرّة، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span>، قال: «<b>لَوحٌ من نور، وقلم من نور يجري بما هو كائن إلى يوم القيامة</b>»{11}. (١٤/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٦<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>النُّون: اللوح المحفوظ، والقلم من نور ساطع</b>»{12}. (١٤/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٧<span class="dash">-</span></span> عن أبي هريرة، قال: سمعتُ رسولَ الله ﷺ يقول: «<b>إنّ أول شيء خَلَق الله القلم، ثم خَلَق النُّون، وهي الدَّواة، ثم قال له: اكتب. قال: وما أكتب؟ قال: ما كان وما هو كائن إلى يوم القيامة؛ من عملٍ، أو أثر، أو رِزق، أو أجَل. فكَتب ما يكون وما هو كائن إلى يوم القيامة، وذلك قوله: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span>، ثم خَتَم على فِي القلم، فلم يَنطق ولا يَنطق إلى يوم القيامة، ثم خَلَق الله العقل، فقال: وعزّتي، لأُكمِّلنّك فيمن أحببتُ، ولأُنقِصنّك فيمَن أبغضتُ</b>»{13}. (١٤/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span> حروف الرحمن مُقطّعة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قوله: <span class="qpc-hafs">﴿ن﴾</span>: أشباه هذا قَسمٌ أقسم الله به، وهي من أسماء الله{15}. (١٤/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظَبْيان- قال: إنّ أول شيء خَلَقه الله القلم، فقال له: اكتب. قال: يا ربّ، وما أكتب؟ قال: اكتب القَدَر. فجرى مِن ذلك اليوم بما هو كائن إلى أن تقوم الساعة، ثم طُوِي الكتاب، ورُفِع القلم، وكان عرشُه على الماء، فارتفع بخارُ الماء، ففُتِقتْ منه السماوات، ثم خَلَق النُّون، فبُسطتْ الأرض عليه، والأرض على ظهر النُّون، فاضطرب النُّون، فمادت الأرض، فأُثبتت بالجبال، فإنّ الجبال لَتَفْخَر على الأرض إلى يوم القيامة. ثم قرأ ابن عباس: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span>{16}. (١٤/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ثابت الثُّماليّ- قال: إنّ الله خَلَق النُّون، وهي الدَّواة، وخَلَق القلم، فقال: اكتب. قال: ما أكتب؟ قال: اكتب ما هو كائن إلى يوم القيامة{17}. (١٤/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ثابت الثُّمالي- قال: أول ما خَلَق الله القلم، فأخذه بيمينه، وكِلتا يديه يمين، وخَلَق النُّون، وهي الدَّواة، وخَلَق اللوح، فكَتب فيه، ثم خَلَق السماوات، فكتب ما يكون مِن حينئذ في الدنيا إلى أن تكون الساعة؛ مِن خَلْق مخلوق، أو عَملٍ معمول؛ برٍّ أو فجور، وكلّ رِزق؛ حلال أو حرام، رَطْبٍ أو يابس{18}. (١٤/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يحيى بن الجزار- <span class="qpc-hafs">﴿ن والقَلَمِ﴾</span>، قال: <span class="qpc-hafs">﴿ن﴾</span>: الدَّواة، <span class="qpc-hafs">﴿والقلم﴾</span>: القلم{19}. (١٤/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُسلم بن صُبَيْح- في قوله: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span>، قال: خَلَق الله القلم، فقال: اجْرِهْ. فجَرى بما هو كائن إلى يوم القيامة، ثم خَلَق الحوت، وهي النُّون، فكَبس عليها الأرض. ثم قال: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span>{20}. (١٤/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٥<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: <span class="qpc-hafs">﴿ن﴾</span> الحوت الذي يَحمل الأرض، واسمه: لويثا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن أبي بَكرة- قال: <span class="qpc-hafs">﴿ن﴾</span>: الحوت الذي تحت الأرض السابعة، <span class="qpc-hafs">﴿والقَلَمِ﴾</span>: الذي كُتب به الذِّكر{22}. (١٤/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ن﴾</span> الدَّواة{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٨٩<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ن﴾</span>، قالا: الدَّواة{24}. (١٤/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ن والقَلَمِ﴾</span>، يعني: الدَّواة، والقلم: هذا القلم الذي يُكتب به{25}<span class=comment-ref>٦٧١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٦٤) على القول بأنّ <span class="qpc-hafs">﴿ن﴾</span> هي الدَّواة الذي قاله ابن عباس من طريق ثابت الثُّمالي، وقاله الحسن، وقتادة، والضَّحّاك، فقال: «فهذا إما أن يكون لغة لبعض العرب، أو تكون لفظة أعجمية».</div></p><p><div></p><p><p><span class="item-no">٧٧٩٩١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ن﴾</span> افتتاح اسمه: نور، وناصر، ونصير{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span> يُقسم الله بما شاء{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٣<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: أقسم الله تعالى بنُصرته المؤمنين{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٤<span class="dash">-</span></span> قال <span class="name-2">مُرّة الهَمداني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٥<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٦<span class="dash">-</span></span> و<span class="name-2">عطاء الخُراسانيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٧<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٨<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي</span>: هو الحوت الذي على ظهره الأرض. وعن <span class="name-3">الكلبي</span>، و<span class="name-3">مقاتل</span>: أنّ اسمه: يهموت{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٩٩<span class="dash">-</span></span> قال <span class="name-3">جعفر الصادق</span>: هو نهر في الجنة{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ن والقَلَمِ﴾</span> يعني بنون: الحوت، وهو في بحرٍ تحت الأرض السُّفلى، والقلم قلم من نور يُكتب به، طوله كما بين السماء والأرض، كُتب به اللوح المحفوظ{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ن﴾</span>، قال: هو الحوت الذي عليه الأرض{32}. (١٤/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٢<span class="dash">-</span></span> قال <span class="name-3">الواقديّ</span>: <span class="qpc-hafs">﴿ن﴾</span> هو الحوت الذي عليه الأرض، واسمه: ليوثا{33}<span class=comment-ref>٦٧١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٤</span> ساق <u>ابنُ كثير</u> (١٤/٨٢ بتصرف) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «ومن العجيب أنّ بعضهم حمل على هذا المعنى <span class="mustanad">الحديث</span> الذي رواه الإمام أحمد ... عن أنس: أنّ عبد الله بن سلام بلغه مَقدم رسول الله ﷺ المدينة، فأتاه، فسأله عن أشياء، قال: إني سائلك عن أشياء لا يعلمها إلا نبي. قال: ما أول أشراط الساعة؟ وما أول طعام يأكله أهل الجنة؟ وما بال الولد يَنزع إلى أبيه، والولد يَنزع إلى أمه؟ قال: «<b>أخبَرني بهن جبريل آنفًا</b>». قال ابن سلام: فذاك عدو اليهود من الملائكة. قال: «<b>أمّا أول أشراط الساعة فنار تَحشرهم من المشرق إلى المغرب، وأول طعام يأكله أهل الجنة زيادة كبد حوت، وأما الولد فإذا سَبق ماء الرجل ماء المرأة نَزع الولد، وإذا سَبق ماء المرأة ماء الرجل نَزعتْ</b>»».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</span>، قال: هذا قَسمٌ أقسم الله به{27}<span class=comment-ref>٦٧١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٥</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿ن﴾</span> على أقوال: <b>الأول</b>: أنّ النُّون: الحوت الذي عليه الأرض. <b>الثاني</b>: أنّ النُّون: الدَّواة. <b>الثالث</b>: حرف من حروف الرحمن. <b>الرابع</b>: لَوح من نور. <b>الخامس</b>: اسم من أسماء السورة. <b>السادس</b>: قَسمٌ أقسم الله به. <b>السابع</b>: حرف من حروف المعجم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٣/١٧٦) القول الأخير، فقال: «الصحيح أنّ <span class="qpc-hafs">﴿ن﴾</span> و<span class="qpc-hafs">﴿ق﴾</span> و<span class="qpc-hafs">﴿ص﴾</span> من حروف الهجاء التي يَفتتح بها الرّبّ سبحانه بعض السور». ولم يذكر مستندًا.</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٨/٣٦٤-٣٦٥) المراد بالقلم على القول بأنّ <span class="qpc-hafs">﴿ن﴾</span> اسم الحوت بأنه القلم الذي خَلَقه الله تعالى وأمره فكَتب الكائنات، وأنّ الضمير في <span class="qpc-hafs">﴿يسطرون﴾</span> للملائكة، وعلى القول بأنّ <span class="qpc-hafs">﴿ن﴾</span> اسم للدَّواة، فـ<span class="qpc-hafs">﴿القلم﴾</span> هو المتعارف بأيدي الناس، وأنّ الضمير في <span class="qpc-hafs">﴿يسطرون﴾</span> للناس. ثم <span class="comment-type-4">علَّق</span> على هذا القول بقوله: «فجاء القَسم -على هذا- بمجموع أمر الكتاب الذي هو قوام للعلوم والمعارف، وأمور الدنيا والآخرة، فإنّ القلم أخو اللسان، ومَطية الفِطنة، ونعمة من الله عامة».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/١٤٥) -<span class="mustanad">مستندًا إلى السنة</span>- أنّ القلم المُقسَم به هو ما كُتب به القدَر، فقال: «وأما القلم: فهو القلم المعروف، غير أنّ الذي أقسم به ربنا من الأقلام: القلم الذي خَلَقه الله -تعالى ذِكْره-، فأمره فجَرى بكتابة جميع ما هو كائن إلى يوم القيامة». ثم ساق الأحاديث في ذلك.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٤/٨٣) -<span class="mustanad">مستندًا إلى النظائر</span>- أنّ المراد بالقلم: جنس القلم، فقال: «وقوله: <span class="qpc-hafs">﴿والقلم﴾</span> الظاهر أنه جنس القلم الذي يُكتب به، كقوله: <span class="qpc-hafs">﴿اقرأ وربك الأكرم الذي علم بالقلم علم الإنسان ما لم يعلم﴾</span> [العلق:٣-٥]، فهو قَسمٌ منه تعالى، وتنبيه لخَلْقه على ما أنعم به عليهم من تعليم الكتابة التي بها تُنال العلوم؛ ولهذا قال: <span class="qpc-hafs">﴿وما يسطرون﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿نۤۚ وَٱلۡقَلَمِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٠٤<span class="dash">-</span></span> عن عُبادة بن الصّامت، سمعتُ رسول الله ﷺ يقول: «<b>إنّ أول ما خَلَق الله القلم، فقال له: اكتب. فجَرى بما هو كائن إلى الأبد</b>»{35}. (١٤/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>: أن اسم الحوت: بلهوت{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٦<span class="dash">-</span></span> عن مجاهد، قال: قلتُ <span class="name-1">لابن عباس</span>: إنّ ناسًا يُكَذِّبون بالقدَر. فقال: إنهم يُكذِّبون بكتاب الله، لآخذنّ بشعر أحدهم، فلأَنفُضنّ به، إنّ الله كان على عرشه قبل أن يَخلق شيئًا، فكان أول ما خَلَق الله القلم، فجَرى بما هو كائن إلى يوم القيامة، فإنما يجري الناس على أمر قد فُرغ منه{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٧<span class="dash">-</span></span> عن أبي هاشم، أنه سمع مجاهدًا قال: سمعتُ <span class="name-1">عبد الله</span> -لا يدري ابن عمر أو ابن عباس- قال: إنّ أول ما خَلَق الله القلم، فجَرى القلم بما هو كائن، وإنما يَعمل الناس اليوم فيما قد فُرغ منه{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: القلم نعمة من الله عظيمة؛ لولا القلم ما قام دِين، ولم يَصلح عَيشٌ، والله أعلم بما يُصلِح خَلْقَه{32}. (١٤/٦٢١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَسۡطُرُونَ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وما يَسْطُرُونَ﴾</span>، قال: وما يَعملون{40}. (١٤/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وما يَسْطُرُونَ﴾</span>، قال: وما يَكتبون{41}. (١٤/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠١٢<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر-، مثله{42}. (١٤/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿وما يَسْطُرُونَ﴾</span>: وما يَكتبون{43}<span class=comment-ref>٦٧١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٢٣/١٤٥) على هذا القول بقوله: «وإذا وُجّه التأويل إلى هذا الوجه كان القَسم بالخَلْق وأفعالهم». ثم أورد <b>احتمالًا آخر</b> وهو أن يكون معناه: وسَطرهم ما يَسطرون. فتكون «ما» بمعنى المصدر. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وإذا وُجِّه التأويل إلى هذا الوجه كان القَسَم بالكتاب، كأنه قيل: ن والقلم والكتاب».</div></p><p><div></p><p><p><span class="item-no">٧٨٠١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يَسْطُرُونَ﴾</span>، يقول: وما تَكتب الملائكة مِن أعمال بني آدم{31}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس (١٧).أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٤٩) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٠١.أخرجه الطبراني في الكبير ١١/٤٣٣ (١٢٢٢٧)، من طريق مؤمل بن إسماعيل، عن حماد بن زيد، عن عطاء بن السّائِب، عن مسلم بن صبيح، عن ابن عباس به.</p><p>قال الطبراني: «لم يرفعه عن حماد بن زيد إلا مؤمل بن إسماعيل». وقال الهيثمي في المجمع ٧/١٢٨ (١١٤٣٤): «ومؤمل ثقة كثير الخطأ، وقد وثّقه ابن معين وغيره، وضعّفه البخاري وغيره، وبقية رجاله ثقات».عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/١٤٤.</p><p>قال ابن كثير في تفسيره ٨/٢١٢: «وهذا مرسل غريب».أخرجه الرافعي في التدوين في أخبار قزوين ٢/٤١٤، من طريق عبد الغفار بن عبد الحكم القرشي، عن جعفر بن محمد الحنظلي، عن جرير، عن الضَّحّاك بن مُزاحِم، عن عبد الله بن عباس به.</p><p>إسناده ضعيف جدًّا. وينظر: مقدمة الموسوعة. وفي سنده عبد الغفار بن عبد الحكم القرشي، عن جعفر بن محمد الحنظلي، ولم أقف لهما على ترجمة.أخرجه الفريابي في القدر ص٢٩-٣٠ (١٨)، وابن عساكر في تاريخ دمشق ٦١/٣٨٥، من طريق هشام بن خالد الأزرق الدمشقي، عن الحسن بن يحيى الخشني، عن أبي عبد الله مولى بني أُميّة، عن أبي صالح، عن أبي هريرة به.</p><p>وأخرجه ابن عدي في الكامل ٧/٥٢٢، وابن عساكر في تاريخ دمشق ٥٦/٢٠٨، من طريق محمد بن وهب الدمشقي، عن الوليد بن مسلم، عن مالك بن أنس، عن سمي، عن أبي صالح، عن أبي هريرة به.</p><p>قال ابن عدي: «وهذا بهذا الإسناد باطل مُنكر». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١٠٢٤ (٢١٥٥): «رواه محمد بن وهب الدمشقي، عن الوليد بن مسلم، عن مالك بن أنس، عن سمي، عن أبي صالح، عن أبي هريرة. وهذا بهذا الإسناد باطل مُنكر، والحمل فيه على ابن وهب هذا». وذكر ابن كثير في تفسيره ١٤/٨٣ أنّ هذا الحديث غريب جدًّا. وأورده السيوطي في اللآلئ المصنوعة ١/١٢١. وقال الألباني في الضعيفة ٣/٤٠٨ (١٢٥٣): «باطل». وقال في موضع آخر منه ١٣/٦٧٦ (٦٣٠٩): «مُنكر».أخرجه ابن جرير ٢٣/١٤٢.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٧، وابن جرير ٢٣/١٤٠-١٤١، وفي تاريخه ١/٣٣، ٥١، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢١٠-، وأبو الشيخ في العظمة (٩٠٠)، والحاكم ٢/٤٩٨، والبيهقي في الأسماء والصفات (٨٠٤)، والخطيب في تاريخه ٩/٥٩، والضياء في المختارة ١٠/١٨ (٨). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٣/١٤٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٤/١٠١ مختصرًا، وابن جرير ٢٣/١٤٣ مطولًا. وعزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٨-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٨-، وابن جرير ٢٣/١٤٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٨٢.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرج شطره الأول ابن جرير ٢٣/١٤١.تفسير الثعلبي ١٠/٦، وتفسير البغوي ٨/١٨٦.أخرجه عبد الرزاق ٢/٣٠٧، وابن جرير ٢٣/١٤٣. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٨-.تفسير الثعلبي ١٠/٦، وتفسير البغوي ٨/١٨٧.أخرجه ابن جرير ٢٣/١٤٤.تفسير الثعلبي ١٠/٦، وتفسير البغوي ٨/١٨٧.تفسير الثعلبي ١٠/٥، وتفسير البغوي ٨/١٨٦ دون عطاء الخُراسانيّ، ومُرّة الهَمداني.تفسير الثعلبي ١٠/٧.تفسير مقاتل بن سليمان ٤/٤٠٣.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/١٨٢، وتفسير الثعلبي ١٠/٥ بلفظ: لوسا.أخرجه ابن جرير ٢٣/١٤٤.أخرجه أحمد ٣٧/٣٧٨-٣٧٩، ٣٨١ (٢٢٧٠٥، ٢٢٧٠٧)، وأبو داود ٧/٨٦ (٤٧٠٠)، والترمذي ٤/٢٣٠-٢٣١ (٢٢٩٤)، ٥/٥١٤ (٣٦٠٧)، وابن جرير ٢٣/١٤٥، ١٤٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/١٨٧-، من طريق الوليد بن عبادة، عن عبادة به.</p><p>قال الترمذي في الموضع الأول: «هذا حديث غريب». وقال في الموضع الثاني: «هذا حديث حسن صحيح غريب». وقال البوصيري في إتحاف الخيرة المهرة ١/١٧٣ (٢٠٤): «هذا إسناد صحيح، رجاله ثقات».تفسير الثعلبي ١٠/٥، وفي تفسير البغوي ٨/١٨٢: بلهوث -بالثاء-.أخرجه ابن جرير ٢٣/١٤٦.أخرجه ابن جرير ٢٣/١٤٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/١٤٨، والحاكم ٢/٤٩٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٠٧، وابن جرير ٢٣/١٤٨ عن مجاهد، وقتادة، ومن طريق سعيد بلفظ: وما يَخُطُّون. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٧.تفسير مقاتل بن سليمان ٤/٤٠٣.
  68,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَاۤ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونࣲ ۝٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... وذلك حين قال كفار مكة؛ أبو جهل بن هشام، وعُتبة بن ربيعة، وشيبة بن ربيعة، وغيرهم: إنّ محمدًا مجنون. فأقسم الله تعالى بالحوت، والقلم، وما يَسطرون -الملائكة- من أعمال بني آدم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠١٦<span class="dash">-</span></span> عن عبد الملك ابن جُرَيْج، قال: كانوا يقولون للنبي ﷺ: إنه لمجنون، به شيطان. فنَزلت: <span class="qpc-hafs">﴿ما أنْتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ﴾</span>{2}. (١٤/٦٢٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَاۤ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونࣲ ۝٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> فقال: <span class="qpc-hafs">﴿ما أنْتَ﴾</span> يا محمد <span class="qpc-hafs">﴿بِنِعْمَةِ رَبِّكَ﴾</span> يعني: برحمة ربك <span class="qpc-hafs">﴿بِمَجْنُونٍ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٣.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٣.
  68,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ لَكَ لَأَجۡرًا غَیۡرَ مَمۡنُونࣲ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ﴾</span>، قال: غير محسوب{1}<span class=comment-ref>٦٧١٧</span>. (١٤/٦٢٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٦٦) على قول مجاهد بقوله: «أي: بغير حساب».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٨٥) أنّ قوله: <span class="qpc-hafs">﴿غير ممنون﴾</span> هو الأجر الذي لا يَنقطع ولا يَبيد، وساق قول مجاهد، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهو راجع إلى ما قلناه».</div></p><p><div></p><p><p><span class="item-no">٧٨٠١٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿غَيْرَ مَمْنُونٍ﴾</span>، أي: لا يَمُنّ عليك به مِن أذًى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ﴾</span>، يقول: غير منقوص لا يَمُنّ به عليك{3}<span class=comment-ref>٦٧١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٦٦) على هذا القول بقوله: «أي: لا يُكَدِّره مَنٌّ به». و<span class="comment-type-4">ذكر</span> أنّ أكثر المفسرين قالوا بأنّ معنى <span class="qpc-hafs">﴿ممنون﴾</span>: الواهن المُنقطع. و<span class="comment-type-4">علَّق</span> عليه بقوله: «يقال: حبل منين، أي: ضعيف».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٩-.تفسير مقاتل بن سليمان ٤/٤٠٣.
  68,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِیمࣲ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٢١<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عُروة- قالت: ما كان أحد أحسن خُلُقًا مِن رسول الله ﷺ؛ ما دعاه أحد مِن أصحابه ولا مِن أهل بيته إلا قال: لبّيك. فلذلك أنزل الله: <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>{1}. (١٤/٦٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٢<span class="dash">-</span></span> عن سعد بن هشام، قال: أتيتُ <span class="name-1">عائشة</span>، فقلتُ: يا أُمّ المؤمنين، أخبِريني بخُلُق رسول الله ﷺ. قالت: كان خُلُقه القرآن، أما تقرأ القرآن: <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>؟{2}<span class=comment-ref>٦٧١٩</span>. (١٤/٦٢٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٧١٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/٨٥) على هذا الحديث بقوله: «هذا حديث طويل. وقد رواه الإمام مسلم في صحيحه، من حديث قتادة بطوله».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، قال: القرآن{3}. (١٤/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، قال: دين عظيم، وهو الإسلام{4}<span class=comment-ref>٦٧٢٠</span>. (١٤/٦٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٦٦) على تفسير الخُلُق بالدّين، بقوله: «وذلك لا محالة رأس الخُلُق، ووَكِيدُه». ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى السياق</span>- أنّ المراد به في الآية: ما يُضاد الجنون، فقال: «أما إنّ الظاهر من الآية أنّ الخُلُق هو الذي يُضاد مقصد الكفار في قولهم: مجنون. أي: غير محصّل لما يقول».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٦/٣٦٩) على تفسير الخُلُق بالدّين، بقوله: «الدِّين والعادة والخُلُق ألفاظ متقاربة المعنى في الذات، وإن تَنوّعتْ في الصفات كما قيل في لفظة الدّين».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٥<span class="dash">-</span></span> عن أنس بن مالك -من طريق ثابت- قال: خدمتُ رسولَ الله ﷺ إحدى عشرة سنة، ما قال لي قطّ: ألا فعلتَ هذا، أو لِمَ فعلتَ هذا؟ قال <span class="name-2">ثابت</span>: فقلتُ: يا أبا حمزة، إنه كما قال الله تعالى: <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>{5}. (١٤/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٦<span class="dash">-</span></span> عن <span class="name-2">ابن أبْزى</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٧<span class="dash">-</span></span> و<span class="name-2">سعيد بن جُبَير</span>، قالا: على دِين عظيم{6}. (١٤/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، قال: الدّين{7}. (١٤/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٢٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [غَزْوان الغفاري]</span>، <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، قال: الإسلام{6}. (١٤/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كان خلقه آداب القرآن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣١<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span> -من طريق فُضيل بن مرزوق- في قوله: <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، قال: على أدَب القرآن{10}. (١٤/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٢<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: هو ما كان يَأتمر به من أمر الله، ويَنتهي عنه من نهى الله سبحانه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، قال: الدِّين{6}. (١٤/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</span>، يعني: دين الإسلام{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِیمࣲ ۝٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٣٥<span class="dash">-</span></span> عن جابر، أنّ النبيَّ ﷺ قال: «<b>إنّ الله بعثني لِتمام مكارم الأخلاق، وتَمام محاسن الأفعال</b>»{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>بُعِثتُ لِأُتمّمَ مكارم الأخلاق</b>»{15}. (ز)= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٧<span class="dash">-</span></span> وقال: «<b>أدّبني ربي فأَحسن تَأديبي</b>»{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٨<span class="dash">-</span></span> عن ميمونة، قالت: خرج رسول الله ﷺ ذات ليلة مِن عندي، فأَغلقتُ دونه الباب، فجاء يَستفتح الباب، فأَبيتُ أنْ أفتح له، فقال: «<b>أقسمتُ عليكِ إلا فَتحتِ لي</b>». فقلتُ له: تذهب إلى أزواجك في ليلتي! قال: «<b>ما فعلتُ، ولكن وجدتُ حَقْنًا مِن بَولي</b>»{17}. (١٤/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٣٩<span class="dash">-</span></span> عن أنس: أنّ امرأة كان في عقلها شيء، فقالت: يا رسول الله، إنّ لي إليكَ حاجة. فقال: «<b>يا أم فلان، انظري أيَّ السِّكَك شئت، حتى أقضي لك حاجتك</b>». فخلا معها في بعض الطرق، حتى فرغت من حاجتها{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٠<span class="dash">-</span></span> عن أنس بن مالك، قال: كنتُ أمشي مع رسول الله ﷺ وعليه بُرد نجراني غليظ الحاشية، فأَدركه أعرابيٌّ، فجَبذه بردائه جَبذة شديدة، حتى نظرتُ إلى صفْحة عاتق رسول الله ﷺ قد أثّرت بها حاشية البُرد مِن شدة جَبْذته، ثم قال: يا محمد، مُرْ لي مِن مال الله الذي عندك. فالتفتَ إليه رسول الله ﷺ، ثم ضحك، ثم أمَر له بعطاء{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤١<span class="dash">-</span></span> عن عبد الله بن عمر، قال: إنّ رسول الله ﷺ لم يكن فاحِشًا ولا مُتَفَحِّشًا، وكان يقول: «<b>خياركم أحسنكم أخلاقًا</b>»{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٢<span class="dash">-</span></span> عن أبي الدّرداء، قال: سُئِلَتْ <span class="name-1">عائشةُ</span> عن خُلُق رسول الله ﷺ. فقالت: كان خُلُقه القرآن؛ يَرضى لرضاه، ويَسخط لسَخطه{21}. (١٤/٦٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٣<span class="dash">-</span></span> عن أبي عبد الله الجَدَليّ، قال: قلتُ ل<span class="name-1">عائشة</span>: كيف كان خُلُق رسول الله ﷺ؟ قالت: لم يكن فاحشًا، ولا مُتفاحِشًا، ولا سَخّابًا{22} في الأسواق، ولا يَجزي بالسيئة السيئة، ولكن يعفو ويصفح{23}. (١٤/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٤<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، قالت: ما ضَرب رسول الله ﷺ بيده شيئًا قطّ إلا أن يُجاهد في سبيل الله، ولا ضَرب خادمًا ولا امرأة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٥<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، أنّ رسول الله ﷺ كان إذا صافح الرجل لم يَنزع يده من يده حتى يكون هو الذي يَنزع يده، ولا يَصرف وجهه عن وجهه حتى يكون هو الذي يَصرف وجهه عن وجهه، ولم يُر مقدِّمًا رُكْبتيه بين يدي جليس له{25}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو نعيم في الدلائل (١١٩)، والواحدي (٣٢٨). وعزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٣٠٧، وعبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٦ (٣٢٢) بنحوه، وابن أبي شيبة ١٤/٢١٤ عن رجل من بني سواءة، عن عائشة، ومسلم (٧٤٦) مطولًا، والحاكم ٢/٤٩٩، وابن جرير ٢٣/١٥٠-١٥١، وبنحوه من طريق قتادة. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٥٠، وبنحوه من طريق علي. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى الخرائطي في مكارم الأخلاق.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٠. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٩، وتفسير البغوي ٨/١٨٧.أخرجه ابن المبارك في الزهد (٦٧٨) واللفظ له، والبيهقي في الدلائل ١/٣١٠، وابن جرير ٢٣/١٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٩، وتفسير البغوي ٨/١٨٨.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٠٣.أخرجه الطبراني في الأوسط ٧/٧٤ (٦٨٩٥)، والبغوي في شرح السنة ١٣/٢٠٢ (٣٦٢٢، ٣٦٢٣) واللفظ له، من طريق عمر بن إبراهيم القرشي، عن يوسف بن محمد بن المنكدر، عن أبيه، عن جابر به.</p><p>قال البيهقي في الشعب ١٠/٣٥٣ (٧٦١٠): «إسناده ضعيف». وقال الهيثمي في المجمع ٨/١٨٨ (١٣٦٨٤): «فيه عمر بن إبراهيم القرشي، وهو ضعيف». وقال السخاوي في المقاصد الحسنة ص١٨٠ (٢٠٤): «سنده فيه عمر بن إبراهيم القرشي، وهو ضعيف عن جابر». وقال الألباني في الضعيفة ٥/١٠٤ (٢٠٨٧): «ضعيف».أخرجه الثعلبي ١٠/١٠، والبزار -كما في كشف الأستار ٣/١٥٧ (٢٤٧٠)-.</p><p>قال الهيثمي في المجمع ٩/١٥ (١٤١٨٨) عن رواية البزار: «ورجاله رجال الصحيح ...، غير محمد بن رزق الله الكلوذاني، وهو ثقة».أورده الثعلبي ١٠/١٠ عقب الحديث السابق.</p><p>قال ابن الجوزي: «لا يصحّ، وصحّحه أبو الفضل بن ناصر». وقال ابن تيمية في مجموع الفتاوى ١٨/٣٧٥: «معناه صحيح، لكن لا يُعرف له إسناد ثابت». وقال الفتني في تذكرة الموضوعات ص٨٧: «سنده ضعيف، ولا يُعرف له إسناد ضعيف ثابت». وقال الشوكاني في الفوائد المجموعة ص٣٢٧ (٢٥): «لا يُعرف له إسناد ثابت». وقال الألباني في الضعيفة ١/١٧٣ (٧٢): «ضعيف».أخرجه الحاكم ٤/٣٤ (٦٨٠٠) مع اختلاف يسير، من طريق الحُسين بن الفرج، عن محمد بن عمر، عن إبراهيم بن محمد مولى خزاعة، عن صالح بن محمد، عن أم درة، عن ميمونة به.</p><p>وسنده شديد الضعف؛ فيه الحُسين بن الفرج الخياط، وهو متروك. الميزان ١/٥٤٥. وفيه محمد بن عمر الواقديّ، قال عنه ابن حجر في التقريب (٦١٧٥): «متروك مع سعة علمه».أخرجه مسلم ٤/١٨١٢ (٢٣٢٦)، والبغوي ٨/١٨٩ واللفظ له.أخرجه البخاري ٤/٩٤-٩٥ (٣١٤٩)، ٧/١٤٦ (٥٨٠٩)، ٨/٢٤ (٦٠٨٨) واللفظ له، ومسلم ٢/٧٣٠ (١٠٥٧).أخرجه أبو الشيخ في أخلاق النبي ١/١٩٨ (٥٤)، والبغوي ٨/١٨٩، من طريق سفيان الثوري، عن الأعمش، عن شقيق، عن مسروق، عن ابن عمر به.</p><p>وسنده صحيح.أخرجه البيهقي في الدلائل ١/٣٠٩-٣١٠. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.السَّخَب والصَّخَب: الصياح. لسان العرب (سخب)، (صخب).أخرجه ابن أبي شيبة ٨/٣٣٠، والترمذي وصححه (٢٠١٦). وعزاه السيوطي إلى ابن مردويه.أخرجه البغوي ٨/١٩٠.أخرجه البغوي ٨/١٨٩.
  68,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسَتُبۡصِرُ وَیُبۡصِرُونَ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَسَتُبْصِرُ ويُبْصِرُونَ﴾</span>، قال: تَعلم ويَعلمون يوم القيامة{1}. (١٤/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فَسَتُبْصِرُ ويُبْصِرُونَ * بِأَيِّكُمُ المَفْتُونُ﴾</span>، يقول: يَتبيّن لكم المَفتون{1}. (١٤/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فَسَتُبْصِرُ ويُبْصِرُونَ﴾</span>، يقول: تَرى ويَرون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسَتُبْصِرُ ويُبْصِرُونَ بِأَيِّكُمُ المَفْتُونُ﴾</span>، يعني: سَترى -يا محمد- ويَرى أهل مكة إذا نَزل بهم العذاب ببدر{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٥٢.تفسير مقاتل بن سليمان ٤/٤٠٣.
  68,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بِأَییِّكُمُ ٱلۡمَفۡتُونُ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فَسَتُبْصِرُ ويُبْصِرُونَ بِأَيِّكُمُ المَفْتُونُ﴾</span>، يقول: بأيّكم الجنون{1}. (١٤/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: الشيطان، كانوا يقولون: إنه شيطان، إنه مجنون{2}. (١٤/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٢<span class="dash">-</span></span> عن <span class="name-2">ابن أبْزى</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٣<span class="dash">-</span></span> و<span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قالا: المجنون{3}. (١٤/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span>، <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: المجنون{4}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: بأيّكم المجنون{5}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: الشيطان{6}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>: يعني: الجنون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: المجنون{4}<span class=comment-ref>٦٧٢١</span>. (١٤/٦٢٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢١</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (٢٣/١٥٣) هذا القول الذي قاله سعيد بن جُبَير، وأبي الجَوْزاء، ومجاهد، والحسن، ومقاتل بأنه وُجّه فيه معنى الباء في قوله: <span class="qpc-hafs">﴿بأيكم﴾</span> إلى معنى: في، ثم قال <span class="comment-type-4">مُعلّقًا</span>: «وإذا وُجّهت الباء إلى معنى»في«كان تأويل الكلام: ويُبْصِرون في أي الفريقين المجنون؛ في فريقك -يا محمد- أو فريقهم، ويكون»المجنون«اسمًا مرفوعًا بالباء».</p><p>و<span class="comment-type-4">علَّق</span> عليه <u>ابنُ عطية</u> (٨/٣٦٧) بقوله: «وهذا قول حسن قليل التَّكلّف، ولا نقول: إنّ حرفًا بمعنى حرف، بل نقول: إن هذا المعنى يُتوصّل إليه بـ»في«وبالباء أيضًا، وقرأ ابن عبلة: (فِي أيِّكُمُ المَفْتُونُ)».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿فَسَتُبْصِرُ ويُبْصِرُونَ بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: أيّكم أولى بالشيطان. فكانوا أولى بالشيطان منه{2}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٦٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، يعني: أيّكم الضُّلّال{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٦١<span class="dash">-</span></span> عن يحيى بن سلّام: تفسير <span class="name-2">الحسن [البصري]</span>: <span class="qpc-hafs">﴿بأيكم المفتون﴾</span> يعني: بأيّكم الضّال، والباء صلة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span>، قال: أيّكم أولى بالشيطان{12}<span class=comment-ref>٦٧٢٢</span>. (١٤/٦٢٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/١٤٥) أنه على هذا القول الذي قاله قتادة، والحسن، فالباء في قوله: <span class="qpc-hafs">﴿بأيكم﴾</span> زائدة.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٣٦٧).</div></p><p><div></p><p><p><span class="item-no">٧٨٠٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بِأَيِّكُمُ المَفْتُونُ﴾</span> يعني: المجنون، فهذا وعيد، العذاب ببدر، القتْل، وضرْب الملائكة الوجوه والأدبار{13}<span class=comment-ref>٦٧٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٣</span> اختُلف في المراد بـ<span class="qpc-hafs">﴿المفتون﴾</span> على أقوال: <b>الأول</b>: أنه المجنون. <b>الثاني</b>: الضّال. <b>الثالث</b>: أولى بالشيطان. <b>الرابع</b>: الجنون.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٢٣/١٥٣) القول الأخير الذي قاله ابن عباس من طريق العَوفيّ، والضَّحّاك، بأنه وُجّه فيه المفتون إلى معنى الفتنة أو الفتون، كما قيل: ليس له معقول ولا معقود، أي: بمعنى: ليس له عقل ولا عقد رأي.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٣٦٧).</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ جرير</u> (٢٣/١٥٥) <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «لأنّ ذلك أظهر معاني الكلام، إذا لم ينو إسقاط الباء، وجَعلنا لدخولها وجهًا مفهومًا. وقد بَيّنا أنه غير جائز أن يكون في القرآن شيءٌ لا معنى له».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ تيمية</u> (٦/٣٧٧) <span class="mustanad">مستندًا للغة</span>، فقال: «وكون المفتون بمعنى الفتنة لا أصل له في اللغة ألبتة، وجَعْل المصدر على زنة»مفعول«لو صحّ لم يكن قياسًا. بل مقصورًا على السماع».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ القيم</u> (٣/١٨٥) هذه الأقوال، و<span class="comment-type-3">رجَّح</span> أنّ الباء إنما دَخَلتْ لتدلّ على تضمين الفعل «تبصر» معنى «تَشعر وتَعلم»- <span class="mustanad">مستندًا إلى النظائر</span>-، فقال: «وهذه الأقوال كلّها تَكلُّف ظاهر لا حاجة إلى شيء منه، و»سَتُبصِر«مُضمّن معنى»تَشعر وتَعلم«، فعدي بالباء كما تقول: سَتشعر بكذا وتَعلم به، قال تعالى: <span class="qpc-hafs">﴿ألَمْ يَعْلَمْ بِأَنَّ اللَّهَ يَرى﴾</span> [العلق:١٤]. وإذا دعاك اللفظ إلى المعنى من مكان قريب فلا تُجب مَن دعاك إليه من مكان بعيد».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٤/٨٨) القول الثاني الذي قاله الحسن <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «ومعنى <span class="qpc-hafs">﴿المفتون﴾</span> ظاهر، أي: الذي قد افتُتن عن الحق وضَلّ عنه، وإنما دَخَلت الباء في قوله: <span class="qpc-hafs">﴿بأييكم المفتون﴾</span> لتدلّ على تَضمين الفعل في قوله: <span class="qpc-hafs">﴿فستبصر ويبصرون﴾</span>، وتقديره: فسَتعلم ويَعلمون، أو: فسَتُخبر ويُخبرون بأيكم المفتون».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٦/٣٧٥) -<span class="mustanad">مستندًا إلى القراءات، وأقوال السلف</span>- القول الثالث الذي قاله مجاهد، والحسن، وقتادة، فقال: «قوله تعالى: <span class="qpc-hafs">﴿بأيكم المفتون﴾</span> حار فيها كثير من الناس، والصواب فيها التفسير المأثور عن السلف». ثم <span class="comment-type-4">عَلّق</span> على قول الحسن بقوله: «فبَيّن الحسن المعنى المراد وإن لم يَتكلّم على اللفظ، كعادة السلف في اختصار الكلام مع البلاغة وفهم المعنى». ثم قال: «ويدلّ أيضًا على هذا المعنى في الآية أنّ في قراءة أُبيّ بن كعب، والجَوْنيّ، وابن عبلة: (فِي أيِّيكُمُ المَفْتُونُ) والشيطان مفتون بلا ريب». و<span class="comment-type-4">ذكر</span> (٦/٣٧٥-٣٧٦) أنّ القول الثاني الوارد عن الحسن أيضًا موافق لما ذُكر؛ فإنّ الضّال به المفتون الذي هو شيطان، ثم قال: «وإنما ذَكر الحسن لفظ الضّال؛ لأنهم لم يريدوا بالمجنون الذي يَخرق ثيابه، ويَقذف بالحجارة، ويَتكلّم بالهذَيان».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٥٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٣، ومن طريق ليث أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٣-١٥٤.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٩-.أخرجه أبو عمرو الداني في المكتفى ص٢٢٠ (٤١).أخرجه عبد الرزاق ٢/٣٠٨، وابن جرير ٢٣/١٥٤، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٠٣.
  68,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِیلِهِۦ وَهُوَ أَعۡلَمُ بِٱلۡمُهۡتَدِینَ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنَّ رَبَّكَ هُوَ أعْلَمُ بِمَن ضَلَّ عَنْ سَبِيلِهِ﴾</span> الهُدى، <span class="qpc-hafs">﴿وهُوَ أعْلَمُ بِالمُهْتَدِينَ﴾</span> مِن غيره{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٣.
  68,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَا تُطِعِ ٱلۡمُكَذِّبِینَ ۝٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَلا تُطِعِ المُكَذِّبِينَ﴾</span> حين دعا إلى دين آبائه ومِلّتهم، نزلت هذه الآية في بني المُغيرة بن عبد الله بن عمر بن مخزوم؛ منهم الوليد بن المُغيرة، وأبو قيس بن الفاكه بن المُغيرة، وعبد الله بن أبي أُمَيّة، وعبد الله بن مخزوم، وعثمان ونوفل ابني عبد الله بن المُغيرة، والعاص، وقيس، وعبد شمس، وبني الوليد سبعة؛ الوليد، وخالد، وعمارة، وهشام، والعاص، وقيس، وعبد شمس، بنو الوليد بن المُغيرة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٣-٤٠٤. كذا جاءت الأسماء، ويظهر وجود تصحيف وسقط وتكرار.
  68,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَدُّوا۟ لَوۡ تُدۡهِنُ فَیُدۡهِنُونَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، قال: لو تُرُخِّص لهم فيُرخِّصون{1}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، يقول: ودُّوا لو تَكفر فيَكفُرون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، يقول: لو تَرْكن إليهم، وتَترك ما أنتَ عليه مِن الحق؛ فيُمالِئونك{3}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٦٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، قال: تَكفر فيكفرون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، قال: لو تَكفر فيكفرون{5}. (١٤/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span> لو تُصانعهم في دينك؛ فيُصانعونك في دينهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَوْف- <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>: لو تَرفض بعض أمْرك؛ فيَرفضون بعض أمْرهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٣<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span> لو تَكْذِبُ فيَكْذِبُون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، قال: ودُّوا لو يُدهِن رسولُ الله فيُدهِنون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، قال: ودُّوا لو وهِن نبيُّ الله ﷺ عن هذا الأمر؛ فوَهِنوا عنه{5}. (١٤/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٦<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span> لو تَنافق وتُرائي؛ فيُنافِقون ويُراؤون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span> لو تَلين لهم فيَلينون لك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ودُّوا﴾</span> حين دعا إلى دين آبائه <span class="qpc-hafs">﴿لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span> يقول: ودُّوا لو تَكفر -يا محمد- فيَكفرون فلا يُؤمنون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٧٩<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</span>، قال: تَكفر فيكفرون{2}<span class=comment-ref>٦٧٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٤</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿ودوا لو تدهن فيدهنون﴾</span> على قولين: <b>الأول</b>: أنّ المعنى ذلك: ودّ المُكذِّبون بآيات الله لو تَكفر بالله -يا محمد- فيكفرون. <b>الثاني</b>: ودُّوا لو تُرخِّص لهم فيُرخِّصون، أو تَلين في دينك فيَلينون في دينهم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/١٥٧) -<span class="mustanad">مستندًا إلى النظائر، واللغة</span>- القول الثاني الذي قاله ابن عباس من طريق العَوفيّ، ومجاهد، وقتادة، فقال: «وأولى القولين في ذلك بالصواب: قولُ مَن قال: معنى ذلك: ودّ هؤلاء المشركون -يا محمد- لو تَلين لهم في دينك بإجابتك إياهم إلى الرُّكون إلى آلهتهم، فيَلينون لك في عبادتك إلهك، كما قال -جلّ ثناؤه-: <span class="qpc-hafs">﴿ولولا أن ثبتناك لقد كدت تركن إليهم شيئًا قليلا إذا لأذقناك ضعف الحياة وضعف الممات﴾</span> [الإسراء:٧٤-٧٥]. وإنما هو مأخوذ من الدُّهن، شبّه التّليين في القول بَتليين الدُّهن».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٥٦. وعزاه السيوطي إلى ابن المنذر، وأبي حاتم.أخرجه ابن جرير ٢٣/١٥٦.أخرجه ابن جرير ٢٣/١٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٥٦.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.تفسير الثعلبي ١٠/١٢.تفسير الثعلبي ١٠/١٢.أخرجه عبد الرزاق ٢/٣٠٨، وابن جرير ٢٣/١٥٧، وبنحوه من طريق سعيد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.تفسير الثعلبي ١٠/١٢، تفسير البغوي ٨/١٩٢.تفسير مقاتل بن سليمان ٤/٤٠٤.أخرجه ابن جرير ٢٣/١٥٦.
  68,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تُطِعۡ كُلَّ حَلَّافࣲ مَّهِینٍ ۝١٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٨٠<span class="dash">-</span></span> عن أبي عثمان النَّهدي، قال: قال مروان بن الحكم لَمّا بايع الناسُ ليزيد: سُنّة أبي بكر وعمر. فقال عبد الرحمن بن أبي بكر: إنّها ليست بسُنّة أبي بكر وعمر، ولكنها سُنّة هِرَقْل. فقال مروان: هذا الذي أُنزِل فيه: <span class="qpc-hafs">﴿والَّذِي قالَ لِوالِدَيْهِ أُفٍّ لَكُما﴾</span> الآية [الأحقاف:١٧]. قال: فسمِعَتْ ذلك <span class="name-1">عائشةُ</span>، فقالتْ: إنّها لم تنزِل في عبد الرحمن، ولكن نزلت في أبيك: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ هَمّازٍ مَشّاءٍ بِنَمِيمٍ﴾</span>{1}. (١٤/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ﴾</span> الآية، قال: يعني: الأسود بن عبد يَغوث{2}. (١٤/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٢<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، في قوله: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span>، قال: نزلت في الأَخْنس بن شَرِيق{3}. (١٤/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٣<span class="dash">-</span></span> عن محمد بن السّائِب الكلبي -من طريق معمر-، مثله{4}. (١٤/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٤<span class="dash">-</span></span> عن مجاهد بن جبر، في قوله: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span>، قال: هو الأسود بن عبد يَغوث{3}. (١٤/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٥<span class="dash">-</span></span> عن عامر الشعبي، <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ﴾</span> الآية، قال: هو رجل من ثَقيف، يُقال له: الأَخْنس بن شَرِيق{6}. (١٤/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٦<span class="dash">-</span></span> قال عطاء: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span> الأَخْنس بن شَرِيق{7}<span class=comment-ref>٦٧٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٥</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٦٨) على هذا القول الذي قاله السُّدِّيّ، والكلبي، والشعبي، وعطاء، <span class="mustanad">مستندًا إلى التاريخ</span>، فقال: «ويؤيّد ذلك أنه كانت له هَنة في حلقه كزنَمة الشاة، وأيضًا فكان من ثقيف مُلصقًا في قريش». و<span class="comment-type-4">ذكر</span> (٨/٣٧٠) أنّ أكثر المفسرين على هذا القول.</div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٧<span class="dash">-</span></span> عن الربيع بن أنس -من طريق عيسى بن عبد الله التميمي- قال: نزلت في الوليد بن المغيرة: <span class="qpc-hafs">﴿عتل بعد ذلك زنيم﴾</span>، قال: فاحش مع ذلك لئيم{8}<span class=comment-ref>٦٧٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٦٨) على هذا القول الذي قاله الربيع، ومقاتل، <span class="mustanad">مستندًا إلى التاريخ،</span> فقال: «ويؤيد ذلك غناه، وأنه أشهرهم بالمال والبنين».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٨٨<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span>، يعني: الوليد بن المُغيرة المخزوميّ{9}<span class=comment-ref>٦٧٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٦٨) أنّ كثيرًا من المفسرين ذهب إلى أنّ هذه الأوصاف هي أجناس لم يُرد بها رجل بعينه، و<span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى العموم</span>، فقال: «وظاهر اللفظ عمومُ مَن هذه صفته». ثم قال: «والمخاطبة بهذا المعنى مُستمرّة باقي الزمن، لا سيما لولاة الأمور».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تُطِعۡ كُلَّ حَلَّافࣲ مَّهِینٍ ۝١٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿مَهِينٍ﴾</span>، قال: الكذّاب{10}<span class=comment-ref>٦٧٢٨</span>. (١٤/٦٣٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٨</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٢٣/١٥٨) تفسير ابن عباس للمَهين بالكذّاب، بقوله: «وأحسبه فعل ذلك؛ لأنه رأى أنه إذا وُصف بالمهانة، فإنما وُصف بها لمهانة نفسه وكانت عليه، وكذلك صفة الكذوب، إنما يَكذب لمهانة نفسه عليه».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿حَلّافٍ مَهِينٍ﴾</span>: ضعيف{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span> يقول: مِكثار في الحَلِف، <span class="qpc-hafs">﴿مَهِينٍ﴾</span> يقول: ضعيف{12}<span class=comment-ref>٦٧٢٩</span>. (١٤/٦٢٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٢٩</span> ساق <u>ابنُ عطية</u> (٨/٣٦٨) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهو مِن: مهُن إذا ضعف، والميم فاء الفعل».</div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span>: وهو المِكثار في الشّرِّ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span>، قال: المَهين: المِكثار في الشّرّ{14}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</span>، يعني: الوليد بن المُغيرة المخزوميّ. يقول: كان تاجرًا ضعيف القلب، وذلك أنه كان عَرض على النبي ﷺ المالَ على أن يَرجع عن دينه، وذلك قوله تعالى: <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا أوْ كَفُورًا﴾</span> [الإنسان:٢٤]، يعني: الوليد، وعُتبة{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى ١٠/٢٥٧ (١١٤٢٧)، والحاكم في المستدرك ٤/٥٢٨ (٨٤٨٣)، من طريق محمد بن زياد، عن عائشة بنحوه.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وتعقّبه الذهبي، فقال: «فيه انقطاع».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٠٨. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٩٢.أخرجه ابن إسحاق في سيرته ص١٤٠.تفسير مقاتل بن سليمان ٤/٤٠٤. وهو في تفسير البغوي ٨/١٩٢ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢٣/١٥٨. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٣/١٥٨.أخرجه عبد الرزاق ٢/٣٠٨، وابن جرير ٢٣/١٥٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٥٩.أخرجه ابن جرير ٢٣/١٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٤.
  68,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَمَّازࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٠٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿هَمّازٍ﴾</span>: يعني: الاغتياب{1}. (١٤/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿هَمّازٍ﴾</span> هو الذي يَغمز بأخيه في المجلس{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿هَمّازٍ﴾</span>، قال: يأكل لحوم الناس{3}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿هَمّازٍ﴾</span>، يعني: مُغتاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٠٩٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هَمّازٍ﴾</span>، قال: الهمّاز: الذي يَهمز الناس بيده، ويَضربهم، وليس باللسان. وقرأ: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span> [الهمزة:١]، الذي يَلمز الناس بلسانه، والهَمْز أصله الغَمْز، فقيل للمُغتاب: هَمّاز؛ لأنه يَطعن في أعراض الناس بما يَكرهون، وذلك غمْزٌ عليهم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّشَّاۤءِۭ بِنَمِیمࣲ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿مَشّاءٍ بِنَمِيمٍ﴾</span>: يمشي بالكذب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿مَشّاءٍ بِنَمِيمٍ﴾</span>: يَنقل الأحاديث مِن بعض الناس إلى بعض{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿مَشّاءٍ بِنَمِيمٍ﴾</span>، قال: هو الأَخْنس بن شَريق، أصله من ثَقيف، وعِداده في بني زهرة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَمّازٍ﴾</span> يعني: مغتاب، <span class="qpc-hafs">﴿مَشّاءٍ بِنَمِيمٍ﴾</span> كان يَمشي بالنَّميمة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٥٩. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.أخرجه ابن جرير ٢٣/١٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٤.أخرجه ابن جرير ٢٣/١٥٩.أخرجه ابن جرير ٢٣/١٦٠.أخرجه ابن جرير ٢٣/١٦٠.أخرجه ابن جرير ٢٣/١٦٠.تفسير مقاتل بن سليمان ٤/٤٠٤.
  68,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّنَّاعࣲ لِّلۡخَیۡرِ مُعۡتَدٍ أَثِیمٍ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٠٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿مَنّاعٍ لِلْخَيْرِ﴾</span> أي: للإسلام، يَمنع ولده وعشيرته عن الإسلام، يقول: لئن دَخل واحدٌ منكم في دين محمد لا أنفعه بشيء أبدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿مَنّاعٍ لِلْخَيْرِ﴾</span> قال: فلا يُعطي خيرًا، <span class="qpc-hafs">﴿مُعْتَدٍ﴾</span> قال: مُعتدٍ في قوله، مُعتدٍ في عمله، <span class="qpc-hafs">﴿أثِيمٍ﴾</span> بربّه{2}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَنّاعٍ لِلْخَيْرِ﴾</span> يعني: الإسلام، منع ابن أخيه وأهله الإسلام، <span class="qpc-hafs">﴿مُعْتَدٍ﴾</span> يعني: في الغَشْم والظُّلم، <span class="qpc-hafs">﴿أثِيمٍ﴾</span> يعني: أثيم بربّه لغَشْمه وظُلمه، نظيرها في <span class="qpc-hafs">﴿ويْلٌ لِلْمُطَفِّفِينَ﴾</span>{3}<span class=comment-ref>٦٧٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٦٩) أنّ كثيرًا من المفسرين قالوا: الخير هنا المال، فوصَفه بالشحّ. و<span class="comment-type-4">نَقل</span> عن آخرين أنه على عمومه في المال والأفعال الصالحة، و<span class="comment-type-4">علَّق</span> عليه بقوله: «ومَن يَمنع إيمانه وطاعته لله تعالى فقد مَنع الخير».</div></p></div>",footnotes:1:تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.أخرجه ابن جرير ٢٣/١٦٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٤. والمراد بنظيرها هنا هو قوله تعالى: <span class="qpc-hafs">﴿وما يُكَذِّبُ بِهِ إلّا كُلُّ مُعْتَدٍ أثِيمٍ﴾</span> [المطففين:١٢].
  68,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عُتُلِّۭ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٠٧<span class="dash">-</span></span> عن أبي الدّرداء، عن رسول الله ﷺ، في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: «<b>العُتلّ: كلّ رَحيب الجوف، وثيق الخَلْق{1}، أكولٌ، شَروبٌ، جَموعٌ للمال، مَنوعٌ للخير</b>»{2}. (١٤/٦٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠٨<span class="dash">-</span></span> عن شَدادّ بن أوْس، قال: قال رسول الله ﷺ: «<b>لا يَدخل الجنة جَوّاظ، ولا جَعْظَريّ، ولا عُتُلّ، ولا زَنيم</b>». قال: قلت: فما الجوّاظ؟ قال: «<b>كلُّ جمّاع منّاع</b>». قلت: فما الجَعْظَريّ؟ قال: «<b>الفَظّ الغَليظ</b>». قلت: فما العُتُلّ الزَّنيم؟ قال: «<b>كلّ رَحب الجوف، وثيق الخَلْق، أكولٌ، شَروبٌ، غَشومٌ، ظَلومٌ</b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٠٩<span class="dash">-</span></span> عن عبد الرحمن بن غَنْم، أنّ رسول الله ﷺ قال: «<b>لا يَدخل الجنة جَوّاظ، ولا جَعْظَريّ، ولا العُتُلّ الزَّنيم</b>». فقال له رجل من المسلمين: ما الجَوّاظ، والجَعْظَريّ، والعُتُل الزَّنيم؟ فقال رسول الله ﷺ: «<b>أما الجَوّاظ فالذي جَمع ومَنع، تدعوه لَظى، نَزّاعة للشَّوى، وأما الجَعْظَريّ فالفَظّ الغليظ، قال الله: <span class="qpc-hafs">﴿فَبِما رَحْمَةٍ مِنَ اللَّهِ لِنْتَ لَهُمْ ولَوْ كُنْتَ فَظًّا غَلِيظَ القَلْبِ لانْفَضُّوا مِن حَوْلِكَ﴾</span></b> [آل عمران:١٥٩]، <b>وأما العُتُلّ الزَّنيم فشديد الخَلْق، رَحيب الجوف، مُصحّح، أكولٌ، شَروبٌ، واجدٌ للطعام والشراب، ظَلومٌ للناس</b>»{4}. (١٤/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٠<span class="dash">-</span></span> عن زيد بن أسلم، قال: قال رسول الله ﷺ: «<b>تبكي السماء مِن عبدٍ أصحّ اللهُ جسمَه، وأَرحب جوفه، وأعطاه من الدنيا مَقْضمًا{5}، فكان للناس ظَلومًا، فذلك العُتُلّ الزَّنيم</b>»{6}. (١٤/٦٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١١<span class="dash">-</span></span> عن القاسم مولى معاوية، وموسى بن عُقبة، قالا: سُئِل رسول الله ﷺ عن العُتلّ الزنيم. قال: «<b>هو الفاحش اللئيم</b>»{7}. (١٤/٦٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٢<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: <span class="qpc-hafs">﴿عُتُلٍّ﴾</span>، العُتُلّ: الفاحش الخُلُق، السيئ الخُلُق{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- قال: العُتُلّ: هو الدَّعِيُّ{9}. (١٤/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿عُتُلٍّ﴾</span>، قال: الشّديد الفاتك{10}. (١٤/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٥<span class="dash">-</span></span> عن شَهْر بن حَوْشَب، عن <span class="name-1">عبد الله بن عباس</span>، قال: ستة لا يدخلون الجنة أبدًا: العاقُّ، والمُدمن، والجَعْثَلُ{11}، والجَوّاظ، والقَتّات، والعُتُلّ الزَّنيم. فقلتُ: يا ابن عباس، أما اثنتان فقد عَلمتُ، فأَخبِرني ما الأربع. قال: أما الجَعْثَل فالفَظّ الغليظ، وأما الجَوّاظ فمَن يَجمع المال ويَمنع، وأما القَتّات فمَن يأكل لحوم الناس، وأما العُتُلّ الزَّنيم فمَن يمشي بين الناس بالنَّميمة{12}. (١٤/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، أنه تلا: <span class="qpc-hafs">﴿مَنّاعٍ لِلْخَيْرِ﴾</span> إلى <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>. فقال: سمعتُ رسول الله ﷺ يقول: «<b>أهل النار كلّ جَعْظَريّ، جَوّاظ، مُستكبر، جمّاع، منّاع، وأهل الجنة الضّعفاء المَغلوبون</b>»{13}. (١٤/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٧<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: هو الفاحش اللئيم{12}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١١٩<span class="dash">-</span></span> <span class="name-2">وأبي العالية الرِّياحيّ</span>، مثله{15}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٠<span class="dash">-</span></span> عن <span class="name-2">عُبيد بن عُمير</span> -من طريق أبي الزّبير- قال: العُتُلّ: الأَكُول الشَّروب، القوي الشديد، يُوضع في الميزان فلا يَزن شعيرة، يَدفع الملَك مِن أولئك سبعين ألفًا دفعةً في جهنم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢١<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق سفيان، عن منصور- في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: العُتُلّ: الشديد{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين</span> -من طريق جرير، عن منصور- قال: العُتُلّ: الصحيح{18}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين</span> -من طريق جرير، عن منصور- <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: هو الفاجر الصحيح{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- في قوله تعالى: <span class="qpc-hafs">﴿عتل بعد ذلك زنيم﴾</span>، قال: العُتُلّ: الفاجر{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> –من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عُتُلٍّ﴾</span>، قال: شَديد الأَسْر{21}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿عُتُلٍّ﴾</span>، قال: العُتلّ: الشديد{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمر بن نافع- أنه سُئل عن: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>. فقال: ذلك الكافر اللئيم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- قال: هو الفاحش اللئيم الضَرِيبة{24}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٢٩<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span>، قال: العُتُلّ: الصحيح، الأَكُول، الشَّرُوب{12}. (١٤/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٠<span class="dash">-</span></span> عن <span class="name-2">وهْب الذِّماري</span> -من طريق عطاء بن يَسار- قال: تبكي السماء والأرض مِن رجل أتمّ الله خَلْقه، وأَرحبَ جوفه، وأعطاه مَقْضَمًا من الدنيا، ثم يكون ظَلومًا للناس، فذلك العُتُلّ الزَّنيم{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عُتُلٍّ﴾</span>: هو الفاحش اللئيم الضَّرِيبة. وذُكر لنا: أنّ النبي ﷺ قال: «<b>لا تقوم الساعة حتى يَظهر الفُحْش، والتَّفحُّش، وسُوء الجوار، وقَطيعة الرَّحِم</b>»{27}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق عيسى بن عبد الله التميمي- <span class="qpc-hafs">﴿عتل بعد ذلك زنيم﴾</span>، قال: فاحش مع ذلك لئيم{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿عُتُلٍّ﴾</span> هو الشديد في كُفره{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿عُتُلٍّ﴾</span> الضَّخم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذلِكَ﴾</span> يقول: مع ذلك النَّعت <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>، يعني بالعُتُلّ: رَحيب الجوف، مُوثق الحلق{31}، أكولٌ، شَروبٌ، غَشومٌ، ظَلوم{32}<span class=comment-ref>٦٧٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٦٩) أنّ العُتُلّ: القويّ البنية، الغليظ الأعضاء، المُصحَّح، القاسي القلب، البعيد الفهم، الأَكُول الشَّروب، الذي هو بالليل جيفة وبالنهار حمار. ثم <span class="comment-type-4">علَّق</span> بقوله: «فكلّ ما عبّر به المفسرون عنه من خلال النقص فعن هذه التي ذكرتُ تصْدر». ثم <span class="comment-type-4">بيّن</span> أنّ هذه الصفات كثيرة التلازم.</div></p><p><h3><span class="qpc-hafs">﴿عُتُلِّۭ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨١٣٦<span class="dash">-</span></span> عن حارثة بن وهب، قال: سمعتُ رسول الله ﷺ يقول: «<b>ألا أُخبِركم بأهل الجنة! كلّ ضعيف مُتضعّف، لو أقسم على الله لأَبرّه، ألا أُخبِركم بأهل النار! كلّ عُتلِّ جَوّاظٍ مُستكبر</b>»{33}. (١٤/٦٣٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَعۡدَ ذَ ٰ⁠لِكَ زَنِیمٍ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٣٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق قتادة- قال: الزَّنيم: هو الهَجِين الكافر{34}. (١٤/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٨<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: الزَّنيم: الذي لا أصل له{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: الزَّنيم: هو الرجل يَمُرّ على القوم، فيقولون: رجل سُوء{36}. (١٤/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>، قال: الدَّعِيّ، الفاحش، اللئيم{36}. (١٤/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>، قال: ظَلوم{38}. (١٤/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شعبة، عن أبي إسحاق، عن سعيد بن جُبَير- أنه قال في الزَّنيم: الذي يُعرف بأُبْنة{39}{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شريك، عن أبي إسحاق، عن سعيد بن جُبَير- قال: الزَّنيم: هو المُريب الذي يُعرف بالشّرّ{41}. (١٤/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: هو الرجل يُعرف بالشّرّ؛ كما تُعرف الشاة بزَنَمتها{42}. (١٤/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي حصين، عن مجاهد- في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: هو رجل من قريش، كانت له زَنَمة زائدة مثل زَنَمة الشاة، يُعرف بها{43}. (١٤/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي نجيح، عن مجاهد- قال: الزَّنيم: المُلحق النَّسب{44}. (١٤/٦٢٨، ٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق علي بن عاصم، عن داود بن أبي هند، عن عكرمة- قال: نَزل على النبي ﷺ: <span class="qpc-hafs">﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ هَمّازٍ مَشّاءٍ بِنَمِيمٍ﴾</span> فلم يُعرف، حتى نَزل عليه بعد ذلك: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span> فعرفناه، له زَنَمَةٌ{45} كزَنَمَةِ الشاة{46}. (١٤/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> - من طريق عبد الأعلى، عن داود، عن عكرمة - في الآية، قال: نُعِتَ فلم يُعرف، حتى قيل: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>، وكانت له زَنَمة في عُنُقه يُعرف بها{47}. (١٤/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق هشام، عن عكرمة- في قوله: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>، قال: هو الدَّعِيُّ، أما سمعتَ قول الشاعر:</p><p>زَنيمٌ تداعتْه الرجال زِيادة كما زِيد في عَرْضِ الأديمِ الأَكارِع؟{48}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صفية، عن شيخ يكنى أبا عبد الرحمن- قال: الزَّنيم: الدَّعِيُّ الفاحش، اللئيم المُلزَق. ثم أنشد هذ البيت:</p><p>زنيمٌ تَداعاه الرجال زِيادة كما زِيد في عَرْضِ الأديم الأَكارعِ{49}. (١٤/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>. قال: ولد الزِّنا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر:</p><p>زنيمٌ تداعتْه الرجال زِيادة كما زِيد في عَرْضِ الأديم الأَكارِع؟{50}. (١٤/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>، قال: والزَّنيم: الدَّعِيُّ. ويقال: الزَّنيم رجل كانت به زَنَمة يُعرف بها. ويقال: هو الأَخْنس بن شَريق الثَّقَفي حَليف بني زهرة. وزعم ناس من بني زهرة: أنّ الزَّنيم هو الأسود بن عبد يَغوث الزُّهريّ، وليس به{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٣<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق منصور- قال: الزَّنيم: الفاجر. وفي لفظ: الكافر{52}. (١٤/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span> -من طريق عبد الرحمن بن حَرْملة- في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: هو المُلزَق في القوم ليس منهم{53}. (١٤/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق الحسن- قال: الزَّنيم: الذي يُعرف بالشّرّ، كما تُعرف الشاة بزَنَمتها، المُلصق{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٦<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span> هو الكافر، الهَجِين، المعروف بالشّرّ، المُريب{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- في قوله تعالى: <span class="qpc-hafs">﴿عتل بعد ذلك زنيم﴾</span>، قال: الزَّنيم: اللئيم في أخلاق الناس{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٨<span class="dash">-</span></span> قال <span class="name-2">مُرّة الهَمداني</span>: إنما ادّعاه أبوه بعد ثماني عشرة سنة{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: الزَّنيم يُعرف بهذا الوصف، كما تُعرف الشاة الزَّنماء من التي لا زَنَمة لها{58}. (١٤/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: العُتُلّ الزَّنيم: رجل ضخم شديد، كانت له زَنَمة زائدة في يده، وكانت علامته{12}. (١٤/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الثُّمالي- في الزَّنيم، قال: كانت له سِتّ أصابع في يده، في كلّ إبهام له إصبع{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: الزَّنيم، يقول: كانت له زَنَمة في أصل أُذُنه. يقال: هو اللئيم، المُلصَق في النَّسب{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٣<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق هشام- الزَّنيم: هو الدَّعِيُّ{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</span>، قال: يُعرف الكافر من المؤمن مثل الشاة الزَّنماء، والزَّنماء التي في حلقها كالمُتَعلِّقتين في حَلْق الشاة{12}. (١٤/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> أنه سُئل عن الزَّنيم. قال: هو ولد الزِّنا. وتمثّل بقول الشاعر:</p><p>زَنيمٌ ليس يُعرف مَن أبوه بَغيُّ الأُمِّ ذو حسبٍ لئيم{64}. (١٤/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٦<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيف- الزَّنيم: الذي يُعرف باللؤم كما تُعرف الشاة بزَنَمتها{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، أنه سُئل عن الزَّنيم. قال: هو الرجل تكون له الزَّنمة من الشّرّ يُعرف بها، وهو رجل من ثقيف يُقال له: الأَخْنس بن شَريق{66}. (١٤/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٨<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span> -من طريق داود بن أبي هند- قال: هو الجِلف الجافي، الأَكُول الشَّروب مِن الحرام{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٦٩<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span>، قال: الزَّنيم: الفاجر{12}. (١٤/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧٠<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span> هو الكافر، الهَجِين، المعروف بالشّرّ، المُريب{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق عيسى بن عبد الله التميمي- <span class="qpc-hafs">﴿عتل بعد ذلك زنيم﴾</span>، قال: فاحش مع ذلك لئيم{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ومعنى <span class="qpc-hafs">﴿زَنِيمٍ﴾</span>: أنه كان في أصل أُذُنه مثل زَنَمة الشاة، مثل الزَّنَمة التي تكون مُعلَّقة في لحى الشاة، زيادة في خَلْقه{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧٣<span class="dash">-</span></span> قال <span class="name-3">معمر بن راشد</span>: <span class="qpc-hafs">﴿زَنِيمٍ﴾</span> هو ولد الزنا في بعض اللغة{72}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧٤<span class="dash">-</span></span> عن ابن إدريس، عن أصحاب التفسير، قالوا: هو الذي يكون له زَنَمة كزَنَمة الشاة{73}<span class=comment-ref>٦٧٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٢</span> ساق <u>ابنُ كثير</u> (١٤/٩٢) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «ومعنى هذا: أنه كان مشهورًا بالشّرّ كشُهرة الشاة ذات الزَّنمة من بين أخواتها». ثم قال (١٤/٩٣): «والأقوال في هذا كثيرة، وتَرجع إلى ما قلناه، وهو أنّ الزَّنيم هو: المشهور بالشر، الذي يُعرف به من بين الناس، وغالبًا يكون دعيًّا ولد زنا، فإنه في الغالب يَتسلّط الشيطان عليه ما لا يَتسلّط على غيره، <span class="mustanad">كما جاء في الحديث</span>: «<b>لا يدخل الجنة ولد زنا</b>»».</div></p></div>",footnotes:1:وثيق: عظيم الخلقة. فيض القدير ٤/٣٧٥.عزاه السيوطي إلى أبي الشيخ، وابن مردويه، والديلمي.أخرجه الجصاص في أحكام القرآن ٣/٦٢٥، والثعلبي ١٠/١٣-١٤ واللفظ له، من طريق الوليد بن مسلم، عن أبي شيبة إبراهيم بن عثمان، عن عثمان بن عمير البجلي، عن شَهْر بن حَوْشَب، عن شَدّاد بن أوْس به.</p><p>وسنده شديد الضعف؛ فيه إبراهيم بن عثمان أبو شيبة، قال عنه ابن حجر في التقريب (٢١٥): «متروك الحديث».أخرجه أحمد ٢٩/٥١٦، ٥١٧ (١٧٩٩١، ١٧٩٩٣) مختصرًا، من طريق شَهْر بن حَوْشَب، عن عبد الرحمن بن غَنْم به.</p><p>قال الهيثمي في المجمع ٧/١٢٨ (١١٤٣٥): «فيه شَهْر، وثّقه جماعة، وفيه ضعف، وعبد الرحمن بن غَنْم ليس له صحبة على الصحيح». وقال أيضًا ١٠/٣٩٣ (١٨٦١٨): «إسناده حسن، إلا أن ابن غَنْم لم يسمع من النبي ﷺ». وقال ابن حجر في الفتح ٨/٦٦٣: «مختلف في صحته».المقضم: ما يقضم عليه، ويعني به هنا: المأكل والميرة. اللسان (قضم).أخرجه عبد الرزاق ٢/٣٠٨، وبنحوه عن عطاء بن يَسار مرفوعًا في تفسير <span class="qpc-hafs">﴿زنيم﴾</span>، وابن جرير ٢٣/١٦٣. وعزاه السيوطي إلى ابن المنذر مرسلًا.</p><p>قال ابن كثير ١٤/٩٢: «هكذا رواه ابن أبي حاتم من طريقين مُرسلين».أخرجه ابن جرير ٢٣/١٦٢. وعزاه السيوطي إلى ابن أبي حاتم مرسلًا.تفسير الثعلبي ١٠/١٢.أخرجه ابن جرير ٢٣/١٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/١٦١. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.الجعثل قيل: هو مقلوب الجثعل، وهو العظيم البطن. قال الخطابي: إنما هو العثجل وهو العظيم البطن. وكذا قال الجوهري. اللسان (جثعل، جعثل، عثجل).عزاه السيوطي إلى عبد بن حميد.أخرجه أحمد ١١/١٤٥ (٦٥٨٠)، ١١/٥٨٥ (٧٠١٠)، والحاكم ٢/٥٤١ (٣٨٤٤)، كلاهما عن عبد الله بن عمرو، وهو الراوي للحديث كما في الدُّر ١٤/٦٣٣.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه بهذه السياقة». ووافقه الذهبي في التلخيص. وقال الهيثمي في المجمع ١٠/٣٩٣ (١٨٦١٧): «رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢١٤ (٧٨٠٩): «رواته تقات». وقال الألباني في الصحيحة ٤/٣٢١ (١٧٤١) بعد نقله لقول الحاكم والذهبي: «وهو كما قالا».عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٠٩-٣١٠ (٣٦١٤٤)، وابن جرير ٢٣/١٦١.أخرجه ابن جرير ٢٣/١٦٢.أخرجه ابن جرير ٢٣/١٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٤ (٢٢٦٩).أخرجه أبو نعيم في حلية الأولياء ٤/٢٣٢.أخرجه ابن جرير ٢٣/١٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٦٤.أخرجه ابن جرير ٢٣/١٦٣.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٦٢، كذا من طريق سعيد، وأبي الأشهب، وأبي رجاء أيضًا. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٩- بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٦١.أخرجه ابن جرير ٢٣/١٦٢ دون الحديث، ومن طريق هشام أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن إسحاق في سيرته ص١٤٠.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.تفسير الثعلبي ١٠/١٢.كذا في المطبوع، ولعلها: الخلق.تفسير مقاتل بن سليمان ٤/٤٠٤-٤٠٥.أخرجه البخاري ٦/١٥٩ (٤٩١٨)، ٨/٢٠ (٦٠٧١)، ٨/١٣٤ (٦٦٥٧)، ومسلم ٤/٢١٩٠ (٢٨٥٣).أخرجه عبد الرزاق ٢/٣٠٩. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٣.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٣/١٦٧، وابن أبي حاتم -كما في الإتقان ٢/٤٨-. وعزاه السيوطي إلى ابن المنذر.الأُبنة: العيب. لسان العرب (أبن).أخرجه ابن جرير ٢٣/١٦٧، وقال عقبه: قال أبو إسحاق: وسمعتُ الناس في إمرة زياد يقولون: العُتُلّ: الدّعيّ.أخرجه ابن جرير ٢٣/١٦٧، وعبد الله بن وهب في الجامع -تفسير القرآن ١/١٤٧-١٤٨ (٣٤٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٩-، والخرائطي في مساوئ الأخلاق (٢٢٩)، والحاكم ٢/٤٩٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه البخاري (٤٩١٧)، والنسائي في الكبرى (١١٦١٦)، وأبو نعيم في مستخرجه -كما في فتح الباري ٨/٦٣٣- واللفظ له.أخرجه ابن جرير ٢٣/١٦٥. وعزا السيوطي إلى عبد بن حميد، وابن المنذر نحوه.الزنمة: أصلها هنة معلقة في أذن الشاة، فإذا كانت في الحلق فهي زلمة. لسان العرب (زلم، زنم).أخرجه ابن جرير ٢٣/١٦٦. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/١٦٥-١٦٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٢٣/٣٨٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٨/٥٢٩، ١٠/٤٧٥-٤٧٦. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه الطستي -كما في الإتقان ٢/٨١-.أخرجه ابن جرير ٢٣/١٦٤.أخرجه ابن جرير ٢٣/١٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٦٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٦٥.تفسير الثعلبي ١٠/١٣.أخرجه أبو نعيم في حلية الأولياء ٤/٢٣٢.تفسير الثعلبي ١٠/١٣، وتفسير البغوي ٨/١٩٣.أخرجه ابن جرير ٢٣/١٦٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٤.أخرجه ابن جرير ٢٣/١٦٦.أخرجه ابن جرير ٢٣/١٦٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٣ (٢٢٦٨)، وابن جرير ٢٣/١٦٨.عزاه السيوطي إلى ابن سعد، وعبد بن حميد.أخرجه ابن جرير ٢٣/١٦٧-١٦٨.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٣.أخرجه ابن إسحاق في سيرته ص١٤٠.تفسير مقاتل بن سليمان ٤/٤٠٤-٤٠٥.أخرجه عبد الرزاق ٢/٣٠٩.أخرجه ابن جرير ٢٣/١٦٦. وعزاه ابن كثير إلى ابن جرير وفيه: «ابن إدريس عن أبيه».
  68,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَن كَانَ ذَا مَالࣲ وَبَنِینَ ۝١٤ إِذَا تُتۡلَىٰ عَلَیۡهِ ءَایَـٰتُنَا قَالَ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝١٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٨١٧٥<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: ‹ءَأَن كانَ ذا مالٍ وبَنِينَ› يَستفهم بهمزتين{1}<span class=comment-ref>٦٧٣٣</span>. (١٤/٦٣٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/١٦٩) أنّ هذه القراءة تتخرّج على وجهين: <b>الأول</b>: «أن يكون مرادًا به: ألأن كان ذا مال وبنين تُطيعه؟ على وجه التوبيخ لمن أطاعه». <b>الثاني</b>: «أن يكون مرادًا به تقريع هذا الحلّاف المَهين، فقيل: ألأن كان هذا الحلّاف المَهين ذا مال وبنين إذا تُتلى عليه آياتنا قال: أساطير الأولين». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا أظهر وجهيه».</div></p><p><h3><span class="qpc-hafs">﴿أَن كَانَ ذَا مَالࣲ وَبَنِینَ ۝١٤ إِذَا تُتۡلَىٰ عَلَیۡهِ ءَایَـٰتُنَا قَالَ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝١٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨١٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنْ كانَ﴾</span> يعني: إذا كان <span class="qpc-hafs">﴿ذا مالٍ وبَنِينَ * إذا تُتْلى عَلَيْهِ﴾</span> يعني: الوليد <span class="qpc-hafs">﴿آياتُنا﴾</span> يعني: القرآن <span class="qpc-hafs">﴿قالَ أساطِيرُ الأَوَّلِينَ﴾</span> يقول: أحاديث الأوّلين وكذبهم، وهو حديث رُستم وإسفنديار{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها ابن عامر، وشعبة، وحمزة، وأبو جعفر، ويعقوب، وهم على أصولهم في تحقيق الهمزة وتسهيلها، والإدخال وعدمه. وقرأ بقية العشرة: <span class="qpc-hafs">﴿أن كانَ﴾</span> بهمزة واحدة. انظر: الإتحاف ص٥٥٢.تفسير مقاتل بن سليمان ٤/٤٠٥.
