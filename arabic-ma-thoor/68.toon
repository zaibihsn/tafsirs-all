  68,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَنَسِمُهُۥ عَلَى ٱلۡخُرۡطُومِ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٧٧<span class="dash">-</span></span> عن عبد الله بن عمرو، عن النبي ﷺ، قال: «<b>مَن مات همّازًا لمّازًا مُلَقِّبًا للناس كان علامته يوم القيامة أن يَسِمَه الله على الخُرطوم مِن كِلا الشِّدْقين</b>»{1}. (١٤/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</span>: فقاتل يوم بدر، فخُطم بالسيف في القتال{2}. (١٤/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٧٩<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٠<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>: سنشينه على أنفه، ونُسوّد وجهه، فنَجعل له عَلَمًا في الآخرة يُعرف به، وهو سواد الوجه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨١<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</span> سَنكويه على وجهه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</span>، قال: سِيما على أنفه لا تُفارقه{5}. (١٤/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</span>، قال: سَنسِمه بسِيما لا تُفارقه آخرَ ما عليه{6}. (١٤/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿سَنَسِمُهُ﴾</span> بالسّواد <span class="qpc-hafs">﴿عَلى الخُرْطُومِ﴾</span> يعني: على الأنف، وهو الوليد، وذلك أنه يَسْوَدُّ وجهه، وتزوق{7} عيناه، مَنكوس الوجه، مغلولًا في الحديد، قبل دخول النار{8}<span class=comment-ref>٦٧٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٤</span> اختُلف في <span class="qpc-hafs">﴿سنسمه على الخرطوم﴾</span> على أقوال: <b>الأول</b> أنّ المعنى: سَنخطمه بالسيف، فنجعل ذلك علامة باقية، وسمة ثابتة فيه ما عاش. <b>الثاني</b>: سِيما على أنفه. <b>الثالث</b>: سَنسمه سمة أهل النار. أي: سنُسوّد وجهه. <b>الرابع</b>: سَنشينه شينًا باقيًا.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٧٢) على القول الأخير الذي قاله قتادة من طريق سعيد، بقوله: «فيكون ذلك كالوسم على الأنف ثابتًا بيّنًا، وهذا المعنى كما تقول: سأطوقك طوق الحمامة، أي: أُثبت الأمر بَيّنًا فيك».</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ جرير</u> (٢٣/١٧٠-١٧١)، فقال: «وأولى القولين بالصواب في تأويل ذلك عندي قول مَن قال: معنى ذلك: سُنبين أمره بيانًا واضحًا حتى يعرفوه، فلا يخفى عليهم، كما لا تخفى السمة على الخرطوم». ولم يذكر مستندًا، ثم <span class="comment-type-4">قال</span>: «وقد يحتمل أيضًا أن يكون خطم بالسيف، فجمع له مع بيان عيوبه للناس الخطم بالسيف».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/٩٤) عليه بقوله: «وهو مُتَّجِه».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٢١-، والطبراني في الأوسط (٨٨٠١)، والبيهقي في شعب الإيمان (٦٧٤٤). وعزاه السيوطي إلى ابن مردويه.</p><p>وقال الهيثمي في مجمع الزوائد ٧/٢١٣: «فيه عبد الله بن صالح، وثَّقه عبد الملك بن شعيب، وضعّفه غيره».أخرجه ابن جرير ٢٣/١٧٠. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.تفسير الثعلبي ١٠/١٥، وتفسير البغوي ٨/١٩٤.تفسير الثعلبي ١٠/١٥، وتفسير البغوي ٨/١٩٤.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٧٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٧٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.كذا في مطبوعة المصدر، ولعلها: وتَزْرَقُّ.تفسير مقاتل بن سليمان ٤/٤٠٥.
  68,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا بَلَوۡنَـٰهُمۡ كَمَا بَلَوۡنَاۤ أَصۡحَـٰبَ ٱلۡجَنَّةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span> قال: كانوا من أهل الكتاب{1}. (١٤/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span>، قال: هم ناس مِن الحبشة، كانت لأبيهم جَنَّة، وكان يُطعم منها المساكين، فمات أبوهم، فقال بنوه: إن كان أبونا لَأحمق؛ حين كان يُطعم المساكين. فأَقسموا ليَصْرِمُنَّها مصبحين، وأن لا يُطعموا مسكينًا{2}. (١٤/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- في قوله ﷿: <span class="qpc-hafs">﴿إنّا بَلَوْناهُمْ كَما بَلَوْنا أصْحابُ الجَنَّةِ﴾</span>، قال: كان بُستانٌ باليمن يقال له: الضَّرَوان، دون صنعاء بفَرسَخيْن، يطؤه أهل الطريق، كان غَرسَه قومٌ مِن أهل الصلاة، وكان لرجل، فمات، فورثه ثلاثة بنين له، وكان يكون للمساكين إذا صَرموا نخلهم كلُّ شيء تَعدّاه المِنجَل{3} فلم يجزُّه، وإذا طُرح من فوق النخل إلى البساط فكلّ شيء يَسقط على البساط فهو أيضًا للمساكين، وإذا حَصدوا زَرْعهم فكلّ شيء تَعدّاه المِنجَل فهو للمساكين، وإذا داسُوه كان لهم كلّ شيء يَنتثر أيضًا، فلمّا مات الأب ووَرثه هؤلاء الإخوة عن أبيهم فقالوا: واللهِ، إنّ المال لَقليل، وإنّ العيال لَكثير، وإنما كان هذا الأمر يفعل إذ كان المال كثيرًا والعيال قليلًا، فأمّا إذا قلَّ المال وكثُر العيال فإنّا لا نستطيع أن نفعل هذا. فتَحالفوا بينهم يومًا لَيَغدُوُّن غدوة قبل خروج الناس، فليصرِمُنَّ نخلهم، ولم يستثنوا، يقول: لم يقولوا: إن شاء الله. فغدا القوم بِسُدْفَة{4} من الليل إلى جنتهم لِيَصرموها قبل أن يَخرج المساكين، فرَأوها مُسوَدَّة، وقد طاف عليها من الليل طائف من العذاب، فأَحرقها، فأصبحت كالصريم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق تميم بن عبد الرحمن- في قوله: <span class="qpc-hafs">﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span>، قال: هي أرض باليمن يُقال لها: ضَرَوان، بينها وبين صنعاء ستة أميال{6}. (١٤/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٨٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- في قوله: <span class="qpc-hafs">﴿لا يدخلنها اليوم عليكم مسكين﴾</span>، قال: هم ناس من الحبشة، كانت لأبيهم جَنّة، وكان يُطعم المساكين منها، فمات أبوهم، فقال بنوه: واللهِ، إن كان أبونا لَأحمق حتى يُطعم المساكين. فأجمعوا <span class="qpc-hafs">﴿ليصرمنها مصبحين ولا يستثنون﴾</span>، وألّا يُطعموا مسكينًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إنّا بَلَوْناهُمْ كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span>، قال: هؤلاء ناسٌ قصّ الله عليكم حديثهم، وبيّن لكم أمْرهم{8}. (١٤/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: كانت الجَنّةُ لشيخ مِن بني إسرائيل، وكان يُمسك قُوت سَنَتِه، ويَتصدّق بالفضل، وكان بنوه يَنْهَونَه عن الصّدقة، فلمّا مات أبوهم غَدَوْا عليها، فقالوا: لا يَدخُلنّها اليوم عليكم مسكين{9}. (١٤/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span> أنهم كانوا أبناء قوم صالحين، وأنّ آباءهم كانوا جعلوا مِن جنّتهم حظًّا للمساكين وأبناء السبيل، فخَلف مِن بعدهم أبناؤهم، فقالوا: كَبرنا وكثُر عيالنا، فليس للمساكين عندنا شيء؛ فتَقاسموا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع في التقديم، فقال: <span class="qpc-hafs">﴿إنّا بَلَوْناهُمْ﴾</span> يقول: إنّا ابتليناهم -يعني: أهل مكة- بالجوع <span class="qpc-hafs">﴿كَما بَلَوْنا﴾</span> يقول: كما ابتلينا <span class="qpc-hafs">﴿أصْحابَ الجَنَّةِ﴾</span> بالجوع حين هَلكتْ جَنّتهم، كان فيها نخل وزرع وأعناب، ورثوها عن آبائهم، واسم الجَنّة: الصّريم. وهذا مَثلٌ ضربه الله تعالى لأهل مكة؛ ليَعتبروا عن دينهم، وكانت جَنّتهم دون صنعاء اليمن بفَرسَخين، وكانوا مسلمين، وهذا بعد عيسى ابن مريم ﵇، وكان آباؤهم صالحين، يَجعلون للمساكين من الثمار والزرع والنخل ما أخطأ الرجل، فلم يَره حين يَصْرِمهُ، وما أخطأ المِنجَلُ، وما ذَرتْه الريح، وما بقي في الأرض مِن الطعام حين يُرفع، وكان هذا شيئًا كثيرًا، فقال القوم: كَثُرت العيال، وهذا طعام كثير، اغدُوا سِرًّا جنّتكم، فاصرِموها، ولا تُؤذِنوا المساكين، كان آباؤهم يُخبِرون المساكين، فيَجتمعون عند صِرامِ جَنّتهم، وعند الحصاد{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ أَقۡسَمُوا۟ لَیَصۡرِمُنَّهَا مُصۡبِحِینَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٩٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، في قوله: <span class="qpc-hafs">﴿لَيَصْرِمُنَّها مُصْبِحِينَ﴾</span>، قال: ليَحْضُرُنّها{12}. (١٤/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذْ أقْسَمُوا لَيَصْرِمُنَّها مُصْبِحِينَ﴾</span> ليَصرِمُنّها إذا أصبحوا{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٧٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.المِنجَل: ما يُحْصَد به، من النَّجْل: وهو القَطْع. لسان العرب (نجل).السُّدْفة: من الأضْداد، تقع على الضياء والظُّلْمة، ومنهم من يجعلها اختلاط الضوء والظُّلمة معًا كوقت ما بين طلوع الفجر والإسْفار. النهاية (سدف).أخرجه الثعلبي ١٠/١٦، والبغوي ٨/١٩٤-١٩٥.أخرجه عبد الرزاق ٢/٣١١، وابن جرير ٢٣/١٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٤-١٤٥ (٢٢٧٠).عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٠-٢١-.تفسير مقاتل بن سليمان ٤/٤٠٥-٤٠٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٥-٤٠٦.
  68,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا یَسۡتَثۡنُونَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٩٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح</span>، في قوله: <span class="qpc-hafs">﴿ولا يَسْتَثْنُونَ﴾</span>، قال: كان استثناؤهم: سبحان الله{1}. (١٤/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَسْتَثْنُونَ﴾</span> فيقولون: إن شاء الله{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦.
  68,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَطَافَ عَلَیۡهَا طَاۤىِٕفࣱ مِّن رَّبِّكَ وَهُمۡ نَاۤىِٕمُونَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظَبْيان- في قوله: <span class="qpc-hafs">﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ﴾</span>، قال: هو أمرٌ من الله{1}. (١٤/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨١٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ وهُمْ نائِمُونَ﴾</span>، قال: أتاها أمرُ اللهِ ليلًا{2}. (١٤/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فسمع الله تعالى قولَهم، فبعث نارًا مِن السماء في الليل على جَنّتهم، فأَحْرقتْها حتى صارت سوداء، فذلك قوله: <span class="qpc-hafs">﴿فَطافَ عَلَيْها﴾</span> يعني: على الجنة <span class="qpc-hafs">﴿طائِفٌ﴾</span> يعني: عذاب <span class="qpc-hafs">﴿مِن رَبِّكَ﴾</span> يا محمد ليلًا، <span class="qpc-hafs">﴿وهُمْ نائِمُونَ﴾</span>{3}<span class=comment-ref>٦٧٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٧٣) أنّ الفراء خصص «الطائف» بأنه الأمر الذي يأتي بالليل، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى النظائر</span>، فقال: «ويرُدّه قوله تعالى: <span class="qpc-hafs">﴿إذا مسهم طائف من الشيطان﴾</span> [الأعراف:٢٠١]».</div></p><p><div></p><p><p><span class="item-no">٧٨٢٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ﴾</span>، قال: عذاب، عُنُق مِن نار خَرجتْ من وادي الجنة؛ جَنّتهم{4}. (١٤/٦٣٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٨١، ٢٣/١٧٣، ومن طريق العَوفيّ أيضًا.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦.عزاه السيوطي إلى ابن المنذر.
  68,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحَتۡ كَٱلصَّرِیمِ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٠٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿كالصَّرِيمِ﴾</span> كالرّماد الأسود؛ بلغة خزيمة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شيخ مِن كلب يُقال له: سليمان- في قوله: <span class="qpc-hafs">﴿كالصَّرِيمِ﴾</span>، قال: مثل الليل الأسود{2}. (١٤/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿كالصَّرِيمِ﴾</span>، قال: الذّاهِب. قال: وهل تَعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر:</p><p>غدوتُ عليه غُدوة فوجدتُه قُعودًا لديه بالصّريم عواذله؟{3}. (١٤/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال: أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span>، ما الصريم؟ قال: كالليل المُظلِم. قال: وهل كانت العرب تَعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: نعم، أما سمعتَ قول نابغة بني ذبيان:</p><p>لا تَزْجُرُوا مُكَفَهِرُّ الأَكْفاءِ لَهُ كالليل يَخْلُطُ أصْرامًا بأَصْرامِ؟</p><p>قال: صَدَقتَ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق تميم بن عبد الرحمن- قال: هي أرض باليمن يُقال لها: ضَرَوان، بينها وبين صنعاء ستة أميال{5}<span class=comment-ref>٦٧٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/ ١٧٤) أنه «اختلف أهل التأويل في الذي عُني بالصريم؛ <b>فقال بعضهم</b>: عُني به: الليل الأسود. و<b>قال بعضهم</b>: معنى ذلك: فأصبحت جنتهم محترقة سوداء كسواد الليل المظلم البهيم». ثم ساق أثر ابن عباس مِن طريق شيخ من كلب، ثم قال: «<b>وقال آخرون</b>: بل معنى ذلك: فأصبحت كأرض تُدعى الصريم معروفة بهذا الاسم». ثم ساق قول سعيد بن جبير. وقد تقدم الأثر في أول القصة على أنه اسم للجنة كما ورد في بعض المصادر.</div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span>، قال: كالليل المُظلِم{6}. (١٤/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٨<span class="dash">-</span></span> عن <span class="name-2">مَطر بن ميمون</span>، مثله{6}. (١٤/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٠٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span>، أي: صُرم منها الخير، فليس فيها شيء{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span>، قال: كأنها قد صُرِمَتْ{9}. (١٤/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span> أصبحتْ -يعني: الجَنّة- سوداء مثل الليل{10}<span class=comment-ref>٦٧٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٧٣) على هذا القول بقوله: «من حيث اسودت جنتهم». ونَقل عن <b>آخرين</b> أنهم قالوا: أراد به الصبح، و<span class="comment-type-4">علَّق</span> عليه بقوله: «مِن حيث ابيضتْ كالحصيد». و<span class="comment-type-4">ذكر</span> أنّ سفيان الثوري قال: الصريم يُقال لليل والنهار، و<span class="comment-type-1">وجّهه</span> بقوله: «من حيث كلّ واحد منهما ينصرم من صاحبه».</div></p><p><div></p><p><p><span class="item-no">٧٨٢١٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: <span class="qpc-hafs">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span> كالأرض المَصْرومة{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحَتۡ كَٱلصَّرِیمِ ۝٢٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٢١٣<span class="dash">-</span></span> عن ابن مسعود، قال: قال رسول الله ﷺ: «<b>إيّاكم والمعاصيَ، فإنّ العبد لَيُذنب الذّنب فيَنسى به الباب مِن العلم، وإنّ العبد ليُذنب الذّنب فيُحرم به قيام الليل، وإنّ العبد ليُذنب الذّنب فيَنسى فيُحرم به رزقًا قد كان هُيِّئ له</b>». ثم تلا رسول الله ﷺ: «<b><span class="qpc-hafs">﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ وهُمْ نائِمُونَ فَأَصْبَحَتْ كالصَّرِيمِ﴾</span>، قد حُرموا خير جنتهم بذنبهم</b>»{12}. (١٤/٦٣٨)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/١٦، وتفسير البغوي ٨/١٩٥.أخرجه ابن جرير ٢٣/١٧٤. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأورد ابن جرير في آخر الآثر عن بعض رواته –كما يظهر-: "قال: وقال في ذلك أبو عمرو بن العلاء ﵀:أخرجه الطستي في مسائل نافع (١٦).أخرجه الطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه ابن جرير ٢٣/١٧٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٦، وتفسير البغوي ٨/١٩٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦.تفسير الثعلبي ١٠/١٦.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٩٦- وفي إسناده: عمر بن صبح. وأورده الديلمي في الفردوس ١/٣٨٣ (١٥٤٢).</p><p>قال ابن عدي في الكامل ٦/٤٧ (١١٩٧) في ترجمة عمر بن صبح: «منكر الحديث». وقال الذهبي في ميزان الاعتدال ٣/٢٠٦ (٦١٤٧) في ترجمة عمر بن صبح: «ليس بثقة، ولا مأمون. قال ابن حبان: كان ممن يضع الحديث ...، قال الدارقطني وغيره: متروك. وقال الأزدي: كذاب».
  68,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَنَادَوۡا۟ مُصۡبِحِینَ ۝٢١ أَنِ ٱغۡدُوا۟ عَلَىٰ حَرۡثِكُمۡ إِن كُنتُمۡ صَـٰرِمِینَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: أن <span class="qpc-hafs">﴿اغْدُوا عَلى حَرْثِكُمْ﴾</span>، قال: كان عِنَبًا{1}. (١٤/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَنادَوْا مُصْبِحِينَ﴾</span> يقول: لَمّا أصبحوا قال بعضهم لبعض: <span class="qpc-hafs">﴿أنِ اغْدُوا عَلى حَرْثِكُمْ إنْ كُنْتُمْ صارِمِينَ﴾</span> الجَنّة، يقول: الحرْث والثمار والزرع، ولا يَعلمون أنها احترقتْ{2}<span class=comment-ref>٦٧٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٧٣) أنّ قوله: <span class="qpc-hafs">﴿إن كنتم صارمين﴾</span> يحتمل احتمالين: <b>الأول</b>: «أن يكون من صِرام النخل». <b>الثاني</b>: «أن يريد: إن كنتم من أهل عزم وإقدام على آرائكم، من قولك: سيف صارم».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٠٦.
  68,22,""
  68,17,""
  68,18,""
  68,19,""
  68,20,""
  68,21,""
  68,22,""
  68,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱنطَلَقُوا۟ وَهُمۡ یَتَخَـٰفَتُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وهُمْ يَتَخافَتُونَ﴾</span>، قال: الإسرار، والكلام الخفِيُّ{1}. (١٤/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وهُمْ يَتَخافَتُونَ﴾</span>، قال: يُسِرِّون بينهم أن لا يَدخُلنّها اليومَ عليكم مسكين{2}. (١٤/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فانْطَلَقُوا وهُمْ يَتَخافَتُونَ﴾</span> يعني: يَتشاورون{3} فيما بينهم، وهو الخفيّ من الكلام، فقالوا سِرًّا: <span class="qpc-hafs">﴿أنْ لا يَدْخُلَنَّها اليَوْمَ عَلَيْكُمْ مِسْكِينٌ﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٧٦، وبنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.ذكر محققه أن في بعض النسخ تعليق في الحاشية على الكلمة: يتسارّون. وهو أقرب للسياق.تفسير مقاتل بن سليمان ٤/٤٠٦.
  68,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَن لَّا یَدۡخُلَنَّهَا ٱلۡیَوۡمَ عَلَیۡكُم مِّسۡكِینࣱ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿أنْ لا يَدْخُلَنَّها اليَوْمَ عَلَيْكُمْ مِسْكِينٌ﴾</span>، قال: أضمَروا في أنفسهم أن لا يدخل عليهم مسكين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦٦٩.
  68,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَغَدَوۡا۟ عَلَىٰ حَرۡدࣲ قَـٰدِرِینَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿عَلى حَرْدٍ قادِرِينَ﴾</span>، يقول: ذو قدرة{1}. (١٤/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢١<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span> على جدّ وجَهد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٢<span class="dash">-</span></span> قال <span class="name-2">إبراهيم النَّخْعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٣<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span> على أمْرٍ مُجمع قد أسّسوه بينهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حجّاج، عمّن حدثه- في قول الله: <span class="qpc-hafs">﴿على حرد قادرين﴾</span>، قال: على جِدٍّ قادرين في أنفسهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>، قال: غَدَوا على أمْرٍ قد قَدَرُوا عليه، وأجمعوا عليه في أنفسهم أن لا يَدخل عليهم مسكين{5}. (١٤/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن المهاجر- قال: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span> قال: كان حرْثٌ لأبيهم، وكانوا إخوة، فقالوا: لا نُطعم مسكينًا منه حتى نَعلم ما يَخرج منه، <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span> على أمْرٍ قد أسّسوه بينهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ﴾</span>، قال: على غيظ{7}. (١٤/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ﴾</span>، قال: على أمْرٍ مُجمَع{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٢٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ﴾</span>: يعني: المساكين؛ بجِدٍّ{9}. (١٤/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٠<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ﴾</span> على حَنق وغضبٍ مِن المساكين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ﴾</span>، قال: على فَقْر{11}. (١٤/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>، قال: على جَهد. أو قال: على جِدٍّ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>، قال: غدا القومُ وهم مُحرِدون{13} إلى جَنّتهم، قادرون عليها في أنفسهم{14}. (١٤/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>، يقول: على جِدٍّ مِن أمْرهم{15}. (١٤/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>، الحَرْد: اسم الجنة{16}<span class=comment-ref>٦٧٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٣٩</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٤/٩٦) قول السُّدِّيّ بقوله: «أبْعَد السُّدِّيُّ في قوله هذا».</div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span> على حِدّة في أنفسهم، قادرين على جَنّتهم{17}<span class=comment-ref>٦٧٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٤٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/٣٧٨) «أنّ»الحرد«يرجع إلى القصد، وأنهم غَدوا بإرادة جازمة وقدرة، ولكنّ الله أعجزهم». ثم ساق هذا القول الذي قاله مجاهد، وقتادة، ومقاتل، و<span class="comment-type-4">علَّق</span> بقوله: «وقول مَن قال: ... أي: ظنّوا أنّ الأمر يبقى كما كان، ولو كان كذلك لتمّتْ قدرتهم، لكن سُلبوا القدرة بإهلاك جَنّتهم».</div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>، قال: على حَنق{18}<span class=comment-ref>٦٧٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٤١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٢٣/١٧٨) على هذا القول بقوله: "وكأنّ سفيان ذهب في تأويله هذا إلى مثل قول الأشهب بن رميلة:</p><p>سُودُ شَرًى لاقتْ أُسُود خفيَّةٍ تَساقَوْا على حَرْدٍ دماءَ الأساوِدِ</p><p>يعني: على غضب".</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٣٧٤)، وزاد فقال: «يقال: حَرِد الرجل يحرد حرَدًا: إذا غضب».</div></p><p><div></p><p><p><span class="item-no">٧٨٢٣٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span>: على جِدٍّ، قادرين في أنفسهم{4}<span class=comment-ref>٦٧٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٤٢</span> اختُلف في معنى الحرد على أقوال: <b>الأول</b>: أنّ معناه: على قصد. <b>الثاني</b>: على قدرة في أنفسهم وجِدّ. <b>الثالث</b>: على فاقة وحاجة. <b>الرابع</b>: على حَنق. <b>الخامس</b>: أنّ «الحرد» اسم الجنة. <b>السادس</b>: على منع.</p><p><span class="comment-type-4">ذكره</span> <u>ابنُ جرير</u> (٢٣/١٧٨-١٧٩)، ونسبه لبعض أهل اللغة من البصرة. و<span class="comment-type-4">ذكر</span> أنّ مَن قال بالقول الأخير وجّه المعنى إلى أنه من قولهم: حارَدت السنة إذا لم يكن فيها مطر.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٣٧٤).</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ جرير</u> <span class="mustanad">مستندًا لأقوال السلف</span>، فقال: «وهذا قول لا نَعلم له قائلًا مِن متقدمي العلم قاله، وإن كان له وجْه، فإذا كان ذلك كذلك، وكان غير جائز عندنا أن يُتعدى ما أجمعتْ عليه الحُجّة، فما صحّ من الأقوال في ذلك إلا أحد الأقوال التي ذكرناها عن أهل العلم».</p><p>و<span class="comment-type-3">رجَّح</span> <span class="mustanad">-مستندًا إلى اللغة، وأقوال السلف</span>- القول الأول الذي قاله وعكرمة، ومجاهد، من طريقي إبراهيم بن المهاجر، وابن أبي نجيح، وذلك أنّ «المعروف من معنى الحرد في كلام العرب: القصد، من قولهم: قد حرَد فلان حرْد فلان: إذا قصد قصده؛ يعني: يقصد قصدها».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٧٤) على القول الأول بقوله: «وبذلك فسّر بعض اللغويين».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/٣٧٩) «أنّ»الحرد«<b>يحتمل</b> أن يُراد به: المنع، والقصْد، والغضب». فقال: «الحرد فيه معنى العزم الشديد؛ فإنّ هذا اللفظ يقتضي هذا، وحرد السنة والناقة لما فيه من معنى الشدة، وكذلك الحَنق والغضب فيه شدة؛ فكان لهم عزم شديد على أخْذها، وعلى حرمان المساكين».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٣٧٤). و<span class="comment-type-4">ذكر</span> (٨/٣٧٥) أنّ قوله تعالى: <span class="qpc-hafs">﴿قادرين﴾</span> يحتمل احتمالين: <b>الأول</b>: «أن يكون من القدرة، أي: هم قادرون في زعمهم». <b>الثاني</b>: «أن يكون من التقدير، كأنهم قد قَدَروا على المساكين، أي: ضيّقوا عليهم». و<span class="comment-type-4">علَّق</span> عليه بقوله: «<span class="mustanad">ومنه قوله تعالى</span>: <span class="qpc-hafs">﴿ومن قُدِر عليه رزقه﴾</span> [الطلاق:٧]».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٧٦. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/١٧، وتفسير البغوي ٨/١٩٦.تفسير الثعلبي ١٠/١٧، وتفسير البغوي ٨/١٩٦ عن القُرَظيّ.أخرجه ابن جرير ٢٣/١٧٧.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد. وعند ابن جرير ٢٣/١٧٧ من طريق ابن أبي نجيح بلفظ: على أمر مجمع.أخرجه ابن جرير ٢٣/١٧٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٤-١٤٥ (٢٢٧٠)، وابن جرير ٢٣/١٧٨.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٩٦.أخرجه عبد الرزاق ٢/٣١٠، وابن جرير ٢٣/١٧٨ بلفظ: على فاقة. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٧٦.محردون: مِن الحَرْدِ، والحَرْدُ: القصد والمنع والغيظ والغضب. لسان العرب (حرد).أخرجه ابن جرير ٢٣/١٧٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٧٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/١٧.تفسير مقاتل بن سليمان ٤/٤٠٦.أخرجه ابن جرير ٢٣/١٧٨.أخرجه ابن جرير ٢٣/١٧٧.
  68,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا رَأَوۡهَا قَالُوۤا۟ إِنَّا لَضَاۤلُّونَ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قالُوا إنّا لَضالُّونَ﴾</span>، قال: أضلَلنا مكان جَنّتنا{1}. (١٤/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إنّا لَضالُّونَ﴾</span>، قال: أخطأنا الطريق{2}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا رَأَوْها﴾</span> ليس فيها شيءٌ ظنّوا أنهم أخطأوا الطريق؛ <span class="qpc-hafs">﴿قالُوا إنّا لَضالُّونَ﴾</span> عنها{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٠٩-٣١٠، وابن جرير ٢٣/١٨٠ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦-٤٠٧.
  68,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ نَحۡنُ مَحۡرُومُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، قال: بل حُورِفْنا{1} فحُرمناها{2}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أيوب بن موسى- قال: المحروم: الذي تُصيبه الجائحة، قال الله: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ فَلَمّا رَأَوْها قالُوا إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، وقال: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٥-٦٧]، قال: المحروم: الذي تُصيبه الجائحة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٤<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span> -من طريق ابن عيّاش-: ... المحروم: الذي يُصاب زرْعه أو حرْثه أو نسْل ماشيته، فيكون له حقٌّ على مَن لم يُصِبْه من المسلمين، كما قال لأصحاب الجنة حين أهلك جَنّتهم، فقالوا: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، وقال أيضًا: <span class="qpc-hafs">﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٥-٦٧]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم إنهم عرفوا الأعلام، فعَلموا أنهم عقوبة، فقالوا: <span class="qpc-hafs">﴿بَلْ نَحْنُ﴾</span> يعني: ولكن نحن <span class="qpc-hafs">﴿مَحْرُومُونَ﴾</span> يقول: حُرمنا خير هذه الجَنّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> قال: لَمّا تبيّنوا وعرفوا معالم جَنّتهم قالوا: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> مُحارَفون{6}. (١٤/٦٤١)</p></p><p></div></p></div>",footnotes:1:حُورِف كسْب فلان: إذا شُدِّدَ عليه في معاشه، وضُيِّق كأنه مِيلَ برزقه عنه، من الانحراف عن الشيء وهو المَيْل عنه. النهاية (حرف).أخرجه عبد الرزاق ٢/٣٠٩-٣١٠، وابن جرير ٢٣/١٨٠ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٠٣-١٠٤ (٢٠٢).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦١-٦٢ (١٣٦).تفسير مقاتل بن سليمان ٤/٤٠٦-٤٠٧.عزاه السيوطي إلى ابن المنذر.
  68,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَوۡسَطُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span>، قال: أعْدلهم{1}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span> قال: أعْدلهم، ويقال: قال خيرُهم، وقال في البقرة [١٤٣]: <span class="qpc-hafs">﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا﴾</span>، قال: الوَسَط: العَدْل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٤٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span>، قال: أعْدلهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span>، قال: أعْدلهم{4}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span>، يقول: أعْدلهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span>: يعني: أعْدلهم، وكلّ شيء في كتاب الله أوْسط فهو أعْدل{6}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span>، قال: أعْدلهم قولًا، وكان أسرع القوم فزعًا، وأحسنهم رَجعة{7}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٤<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله الله ﷿: <span class="qpc-hafs">﴿قال أوسطهم﴾</span>، يقول: أفضلهم، وأَعْدلهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span> يعني: أعْدلهم قولًا. نظيرها في سورة البقرة [١٤٣]: <span class="qpc-hafs">﴿أُمَّةً وسَطًا﴾</span>، يعني: عَدلًا{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَمۡ أَقُل لَّكُمۡ لَوۡلَا تُسَبِّحُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- <span class="qpc-hafs">﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</span>، قال: يقول: تَستَثنُون، فكان التسبيح فيهم الاستثناء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٧<span class="dash">-</span></span> قال <span class="name-2">أبو صالح [باذام]</span>: <span class="qpc-hafs">﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</span> كان استثناؤهم سبحان الله{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</span>، قال: كان استثناؤهم في ذلك الزمان: التسبيح{12}. (١٤/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</span>، فتقولون: إن شاء الله تعالى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٢٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿لَوْلا تُسَبِّحُونَ﴾</span>، قال: لولا تَستَثنُون، عند قولهم: <span class="qpc-hafs">﴿ليَصْرِمُنّها مُصبحين﴾</span>. ولا يَستَثنُون عند ذلك، وكان التسبيح استثناؤهم، كما نقول نحن: إن شاء الله{14}<span class=comment-ref>٦٧٤٣</span>. (١٤/٦٤٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٤٣</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٨/٣٧٥) هذا القول <span class="mustanad">مستندًا لظاهر الآية</span>، فقال: «وهذا يردّ عليه قولهم: <span class="qpc-hafs">﴿سبحان ربنا﴾</span>. فبادر القوم، وتابوا عند ذلك، وسبّحوا، واعترفوا بظُلمهم في اعتقادهم منع الفقراء».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٨١، وابن أبي حاتم -كما في الإتقان ٢/٤٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٨١.أخرجه ابن جرير ٢٣/١٨١.أخرجه ابن جرير ٢٣/١٨١، ومن طريق إبراهيم أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٨٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٨١، كما أخرجه عبد الرزاق ٢/٣٠٩-٣١٠ بنحوه من طريق معمر، وكذا ابن جرير. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٢.تفسير مقاتل بن سليمان ٤/٤٠٧.أخرجه ابن جرير ٢٣/١٨٢، ومن طريق إبراهيم أيضًا.تفسير الثعلبي ١٠/١٧، وتفسير البغوي ٨/١٩٦. وقد تقدمت رواية السيوطي لها في الدر ١٤/٦٣٧ عند قوله تعالى: <span class="qpc-hafs">﴿ولا يَسْتَثْنُونَ﴾</span>. وعزاها إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٠٧.عزاه السيوطي إلى ابن المنذر.
  68,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ سُبۡحَـٰنَ رَبِّنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝٢٩ فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَلَـٰوَمُونَ ۝٣٠ قَالُوا۟ یَـٰوَیۡلَنَاۤ إِنَّا كُنَّا طَـٰغِینَ ۝٣١ عَسَىٰ رَبُّنَاۤ أَن یُبۡدِلَنَا خَیۡرࣰا مِّنۡهَاۤ إِنَّاۤ إِلَىٰ رَبِّنَا رَ ٰ⁠غِبُونَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٢٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَلاوَمُونَ﴾</span> يقول: يلوم بعضهم بعضًا في منْع حقوق المساكين، <span class="qpc-hafs">﴿قالُوا يا ويْلَنا إنّا كُنّا طاغِينَ﴾</span> يقول: لقد طَغَينا في نعمة الله تعالى، قالوا: <span class="qpc-hafs">﴿عَسى رَبُّنا أنْ يُبْدِلَنا خَيْرًا مِنها﴾</span> يعني: خيرًا مِن جَنّتنا التي هَلكتْ؛ <span class="qpc-hafs">﴿إنّا إلى رَبِّنا راغِبُونَ﴾</span> في الدعاء إليه{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٧.
