  68,41,""
  68,42,""
  68,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۖ وَقَدۡ كَانُوا۟ یُدۡعَوۡنَ إِلَى ٱلسُّجُودِ وَهُمۡ سَـٰلِمُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</span>، قال: هم الكفار، يُدعَون في الدنيا وهم آمنون، فاليوم يُدعَون وهم خائفون، ثم أخبر الله سبحانه أنه حال بين أهل الشرك وبين طاعته في الدنيا والآخرة، فأمّا في الدنيا فإنه قال: <span class="qpc-hafs">﴿ما كانُوا يَسْتَطِيعُونَ السَّمْعَ﴾</span> وهي طاعته، <span class="qpc-hafs">﴿وما كانُوا يُبْصِرُونَ﴾</span> [هود:٢٠]. وأمّا الآخرة فإنه قال: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ خاشِعَةً أبْصارُهُمْ﴾</span>{1}. (١٤/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>-من طريق أبي سِنان، عن سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</span>، قال: الرجل يَسمع الأذان فلا يجيب الصلاة{2}. (١٤/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣١٩<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، قال: والذي أنزل التوراة على موسى، والإنجيل على عيسى، والزّبور على داود، والفرقان على محمد؛ لنَزَلَتْ هذه الآية في الصلوات المكتوبات حيث يُنادى بهن: <span class="qpc-hafs">﴿يَوْمَ يُكْشَفُ عَنْ ساقٍ﴾</span> إلى قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</span> الصلوات الخمس إذا نُودِي بها{3}. (١٤/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي سِنان- في قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</span>، قال: الصلوات في الجماعات{4}. (١٤/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم التيميّ</span> -من طريق منصور- <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</span>، قال: إلى الصلاة المكتوبة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خاشِعَةً أبْصارُهُمْ﴾</span> عند معاينة النار، <span class="qpc-hafs">﴿تَرْهَقُهُمْ ذِلَّةٌ﴾</span> يعني: تغشاهم مَذَلّة، <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</span> يعني: يُؤمرون بالصلاة{6} الخمس <span class="qpc-hafs">﴿وهُمْ سالِمُونَ﴾</span> يقول: كانوا مُعافون في الدنيا، فتصير أصلابهم مثل سفافيد الحديد{7}<span class=comment-ref>٦٧٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٨٠) على الأقوال الواردة في السجود بقوله: «وهذا كلّه قريب بعضه من بعض».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٩٧. وعزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في الشعب (٢٩١٥).عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في شعب الإيمان (٢٩١٤)، وابن جرير ٢٣/١٩٦-١٩٧ بلفظ: يسمع المنادي إلى الصلاة المكتوبة فلا يجيبه.أخرجه ابن جرير ٢٣/١٩٦.كذا في المصدر، ولعلها: الصلوات.تفسير مقاتل بن سليمان ٤/٤٠٨-٤٠٩.
  68,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَذَرۡنِی وَمَن یُكَذِّبُ بِهَـٰذَا ٱلۡحَدِیثِۖ سَنَسۡتَدۡرِجُهُم مِّنۡ حَیۡثُ لَا یَعۡلَمُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَذَرْنِي﴾</span> هذا تهديد <span class="qpc-hafs">﴿ومَن يُكَذِّبُ بِهَذا الحَدِيثِ﴾</span> يقول: خَلِّ بيني وبين مَن يُكذّب بهذا القرآن، فأنا أنفرد بهلاكهم؛ <span class="qpc-hafs">﴿سَنَسْتَدْرِجُهُمْ مِن حَيْثُ لا يَعْلَمُونَ﴾</span> سَنأخذهم بالعذاب من حيث يَجهلون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٤<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: يُسبِغ عليهم النِّعم، ويُنسيهم الشكر{2}<span class=comment-ref>٦٧٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٠) «أنّ الاستدراج هو: الحمْل من رتبة إلى رتبة، حتى يصير المحمول إلى شرّ». ثم <span class="comment-type-4">علَّق</span> بقوله: «وإنما يُستعمل الاستدراج في الشّرّ، وهو مأخوذ من الدرَج». وساق الأقوال.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١٠-٤١١.تفسير الثعلبي ١٠/٢٢.
  68,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُمۡلِی لَهُمۡۚ إِنَّ كَیۡدِی مَتِینٌ ۝٤٥﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأُمْلِي لَهُمْ﴾</span> يقول: لا أعْجَل عليهم بالعذاب، <span class="qpc-hafs">﴿إنَّ كَيْدِي مَتِينٌ﴾</span> يقول: إنّ أخذي بالعذاب شديد. نَزَلَتْ هذه الآية في المُستهزئين من قريش، قَتلهم الله تعالى في ليلة واحدة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١١.
  68,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا فَهُم مِّن مَّغۡرَمࣲ مُّثۡقَلُونَ ۝٤٦ أَمۡ عِندَهُمُ ٱلۡغَیۡبُ فَهُمۡ یَكۡتُبُونَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ أجْرًا﴾</span> يعني: خَراجًا على الإيمان؛ <span class="qpc-hafs">﴿فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</span> يقول: أثقَلهم الغُرم؛ فلا يستطيعون الإكثار من أجل الغُرم، <span class="qpc-hafs">﴿أمْ عِنْدَهُمُ﴾</span> يقول: أعندهم علم <span class="qpc-hafs">﴿الغَيْبُ﴾</span> بأنّ الله لا يَبعثهم، وأنّ الذي يقول محمد غير كائن، أم عندهم بذلك كتاب <span class="qpc-hafs">﴿فَهُمْ يَكْتُبُونَ﴾</span> ما شاؤوا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١١-٤١٢.
  68,47,""
  68,44,""
  68,45,""
  68,46,""
  68,47,""
  68,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلۡحُوتِ إِذۡ نَادَىٰ وَهُوَ مَكۡظُومࣱ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وهُوَ مَكْظُومٌ﴾</span>، قال: مغموم{1}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهُوَ مَكْظُومٌ﴾</span>، قال: مغموم{2}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٩<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق عبد المنعم بن إدريس، عن أبيه- قال: كان في خُلُق يونس ضِيق، فلمّا حُمِّلتْ عليه أثقالُ النّبوة تفسخّ منها تفسخ الرَّبَع{3}، فقذفها من يديه، وهرب، قال تعالى لنبيّه: <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ إذْ نادى وهُوَ مَكْظُومٌ﴾</span>{4}. (١٤/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</span>، قال: لا تَعجَل كما عَجِل، ولا تُغاضِب كما غاضب{5}. (١٤/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال للنبي ﷺ: <span class="qpc-hafs">﴿فاصْبِرْ﴾</span> على الأذى <span class="qpc-hafs">﴿لِحُكْمِ رَبِّكَ﴾</span> يعني: لقضاء ربّك والذي هو آتٍ عليك، <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</span> يعني: يونس بن متّى مِن أهل نَيْنَوى ﵇. يقول: لا تَضْجر كما ضجر يونس، فإنه لم يصبر. يقول: لا تَعجَل كما عَجِل يونس، ولا تُغاضِب كما غاضب يونس بن متّى، فتُعاقَب كما عُوقب يونس <span class="qpc-hafs">﴿إذْ نادى﴾</span> ربَّه في بطن الحوت، وكان نداؤه في سورة الأنبياء [٨٧]: <span class="qpc-hafs">﴿لا إلَهَ إلّا أنْتَ سُبْحانَكَ إنِّي كُنْتُ مِنَ الظّالِمِينَ﴾</span>، <span class="qpc-hafs">﴿وهُوَ مَكْظُومٌ﴾</span> يعني: مكروب في بطن الحوت، يعني: السمكة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</span>، قال: لا تُغاضِب كما غاضب يونس{7}. (١٤/٦٥٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٠٠. وعزاه السيوطي إلى عبد بن حميد.تفسخ الربع -وهو الفصيل- تحت الحمل الثقيل: ضعف وعجز، وذلك إذا لم يطقه. تاج العروس (فسخ).أخرجه الحاكم ٢/٥٨٤-٥٨٥، وأخرج ابن جرير ١٦/٣٧٦ نحوه طريق ربيعة.أخرجه عبد الرزاق ٢/٣١٠-٣١١، وابن جرير ٢٣/٢٠٠، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى أحمد في الزهد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤١٢.عزاه السيوطي إلى ابن المنذر.
  68,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ نِعۡمَةࣱ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلۡعَرَاۤءِ وَهُوَ مَذۡمُومࣱ ۝٤٩ فَٱجۡتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وهُوَ مَذْمُومٌ﴾</span>، قال: مُلِيم{1}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٤<span class="dash">-</span></span> عن <span class="name-2">بكر [بن عبد الله المزني]</span> -من طريق المعتمر، عن أبيه- <span class="qpc-hafs">﴿وهُوَ مَذْمُومٌ﴾</span>، قال: هو مُذنِب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوْلا أنْ تَدارَكَهُ نِعْمَةٌ مِن رَبِّهِ لَنُبِذَ بِالعَراءِ وهُوَ مَذْمُومٌ﴾</span> ولكن تَداركه نعمة، يعني: رحمة من ربّه، فنبذناه بالعراء وهو سقيم، والعراء: البَراز، يعني: لأُلقِي بالبَراز وهو مذموم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ نِعۡمَةࣱ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلۡعَرَاۤءِ وَهُوَ مَذۡمُومࣱ ۝٤٩ فَٱجۡتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٦<span class="dash">-</span></span> عن عبد الله بن عباس، أن النبي ﷺ قال: «<b>لا ينبغي لأحد أن يقول</b>: <b>إني خير من يونس بن متّى</b> -نسبه إلى أمه-. <b>أصاب ذنبًا، ثم اجتباه ربه</b>»{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٠١.تفسير مقاتل بن سليمان ٤/٤١٢.أخرجه عبد الرزاق ٢/١٥٥-١٥٦، وأحمد في مسنده ٥/ ٣٠٣ (٣٢٥٢)، وعنده: نسبه إلى أمه. وأصله عند البخاري ٤/١٣٢، ومسلم ٧/١٠٣، والترمذي ٥/٥١ دون قوله: أصاب ذنبًا ثم اجتباه ربه.</p><p>قال محققو المسند: «إسناده صحيح، على شرط الشيخين».
  68,50,""
  68,49,""
  68,50,""
  68,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- أنه قرأ: (لَيُزْهِقُونَكَ بِأَبَصارِهِمْ){1}. (١٤/٦٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: كان رجل من العرب يَمكث لا يأكل يومين أو ثلاثة، ثم يَرفع جانب خِبائه، فتَمُرّ به النّعم، فيقول: ما رعى اليوم إبل ولا غنم أحسن مِن هذه. فما تَذهب إلا قريبًا حتى يَسقط منها طائفة وعِدّة. فسأل الكفارُ هذا الرجل أن يُصيب رسول الله ﷺ بالعين، ويَفعل به مثل ذلك، فعَصم الله تعالى نبيّه، وأَنزَل هذه الآية: <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: يَنفُذُونك بأبصارهم{3}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- أنه كان يقرأ: <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>. قال: يقول: يَنفُذُونك بأبصارهم مِن شِدّة النظر إليك. قال ابن عباس: فكيف يقولون: زَلَق السهم أو زَهَق السهم{4}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>: ليُزْهِقُونك بأبصارهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: ليَنفُذُونك بأبصارهم{6}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، يقول: يَنفُذُونك بأبصارهم؛ مِن العداوة والبغضاء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> ليَقْتلونك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٥<span class="dash">-</span></span> قال <span class="name-2">عطية العَوفيّ</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> يرمونك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: ليَنفُذُونك بأبصارهم؛ معاداةً لكتاب الله، ولِذِكْر الله{6}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: لَيُزْهِقُونك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> يُصيبونك بعيونهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله: <span class="qpc-hafs">﴿ليزلقونك بأبصارهم﴾</span>، قال: لَيُزِيلُونك بأبصارهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٠<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> لَيمَسّوك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>-من طريق معمر- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>: ليَصْرعُونك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق حيّان- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>: يَصْرفُونك عمّا أنت عليه من تبليغ الرسالة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ يَكادُ﴾</span> يقول: قد كاد <span class="qpc-hafs">﴿الَّذِينَ كَفَرُوا﴾</span> يعني: المُستهزئين من قريش <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> يعني: يُبعِدونك <span class="qpc-hafs">﴿لَمّا سَمِعُوا الذِّكْرَ﴾</span> يقول: حين سمعوا القرآن كراهيةً له، <span class="qpc-hafs">﴿ويَقُولُونَ إنَّهُ﴾</span> إنّ محمدًا <span class="qpc-hafs">﴿لَمَجْنُونٌ﴾</span>{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٥٤<span class="dash">-</span></span> عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «<b>العين حق، ولو كان شيء سابق القدَر سبقته العين، وإذا استُغسلتم فاغسلوا</b>»{18}. (١٤/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٥<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: «<b>العين تُدخِلُ الرجلَ القبرَ، والجملَ القِدْرَ</b>»{19}. (١٤/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٦<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: «<b>أكثر مَن يموت مِن أمتي بعد قضاء الله وقدَره بالعين</b>»{20}. (١٤/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٧<span class="dash">-</span></span> عن أسماء بنت عُمَيْس أنها قالتْ: يا رسول الله، إنّ بني جعفر تُصيبهم العين، أفأَسترقي لهم؟ قال: «<b>نعم، فلو كان شيءٌ يَسبق القضاءَ لَسَبَقتْه العين</b>»{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: دواء إصابة العين أن يَقرأ الإنسانُ هذه الآية{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائله (١٧٨)، وابن جرير ٢٣/٢٠٣.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عباس. انظر: مختصر ابن خالويه ص١٦١.تفسير الثعلبي ١٠/٢٣، وأسباب النزول للواحدي ص٦٩٤، وتفسير البغوي ٨/٢٠٢.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٣/٢٠٣.أخرجه ابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٠٣-٢٠٤.تفسير الثعلبي ١٠/٢٤.تفسير الثعلبي ١٠/٢٣.أخرجه ابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٠٣.تفسير الثعلبي ١٠/٢٤، وتفسير البغوي ٨/٢٠٢.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٢.تفسير الثعلبي ١٠/٢٤.أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٠٣، والثعلبي ١٠/٢٣.تفسير الثعلبي ١٠/٢٣.تفسير مقاتل بن سليمان ٤/٤١٢.أخرجه مسلم ٤/١٧١٩ (٢١٨٨).أخرجه ابن عدي في الكامل ٦/٣١٦، ٨/١٤٨، وأبو نعيم في الحلية ٧/٩٠-٩١، من طريق شعيب بن أيوب، عن معاوية بن هشام، عن سفيان الثوري، عن محمد بن المُنكَدر، عن جابر به.</p><p>قال أبو نعيم: «غريب من حديث الثوري، تفرد به معاوية». وأورده الألباني في الصحيحة ٣/٢٥٠-٢٥١ (١٢٤٩).أخرجه ابن عدي في الكامل ٥/١٩١، والبزار -كما في كشف الأستار ٣/٤٠٣ (٣٠٥٢)-، من طريق طالب بن حبيب الأنصاري، عن عبد الرحمن بن جابر الأنصاري، عن أبيه به.</p><p>وقال العراقي في طرح التثريب ٨/١٩٨ عن رواية البزار: «ورجاله ثقات». وقال الهيثمي في المجمع ٥/١٠٦ (٨٤٢٣): «رجاله رجال الصحيح، خلا الطالب بن حبيب بن عمرو، وهو ثقة». وقال ابن حجر في الفتح ١٠/٢٠٠، ٢٠٤: «سنده حسن». وتابعه السخاوي في المقاصد الحسنة ص٤٧٠، والزرقاني في شرحه على الموطأ ٤/٥١١، والعجلوني في كشف الخفاء ٢/٨٩، والشوكاني في نيل الأوطار ٨/٢٤٨، والألباني في الصحيحة ٢/٣٧٢-٣٧٣ (٧٤٧).أخرجه أحمد ٤٥/٤٦٢ (٢٧٤٧٠)، والترمذي ٤/١٤٦-١٤٧ (٢١٨٦، ٢١٨٧)، وابن ماجه ٤/٥٤٣ (٣٥١٠)، والبغوي ٨/٢٠٣ واللفظ له.</p><p>قال الترمذي: «وهذا حديث حسن صحيح». وقال ابن عدي في الكامل ٥/٤٣١: «وهذه الأحاديث غير محفوظة». وأورده الدارقطني في العلل ١٥/٣٠٤ (٤٠٥١). وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٦٩٣ (٣٨١٠): «رواه عبد الله بن شبيب أبو سعيد، عن يحيى بن إبراهيم، عن أسامة بن حفص، عن عبيد الله بن عمر، عن أيوب البصري رجل من أهل الفضل، عن عمرو بن دينار، عن عروة بن عامر، عن عبيد بن رفاعة، عن أسماء بنت عُمَيْس. وهذا غير محفوظ، وإسناده كما ترى، وعبد الله متروك الحديث». وقال المناوي في التيسير ٢/٣١٠: «إسناد صحيح». وقال في فيض القدير ٥/٣٢٦ (٧٤٧٤): «رمز المصنف-السيوطي- لصحته». وقال الألباني في الصحيحة ٣/٢٥٢ (١٢٥٢): «ورجاله ثقات مشهورون من رجال الشيخين، غير عبيد بن رفاعة، وهو ثقة».تفسير الثعلبي ١٠/٢٤، وتفسير البغوي ٨/٢٠٣.
  68,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا هُوَ إِلَّا ذِكۡرࣱ لِّلۡعَـٰلَمِینَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٥٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إلا ذِكْرٌ لِلْعالَمِينَ﴾</span> موعظة للمؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما هُوَ﴾</span> يعني: إنْ هو <span class="qpc-hafs">﴿إلّا ذِكْرٌ لِلْعالَمِينَ﴾</span> يعني: ما القرآن إلا تَذْكِرة للعالمين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٢٠٢.تفسير مقاتل بن سليمان ٤/٤١٢.
  69,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٦١<span class="dash">-</span></span> عن عمر بن الخطاب، قال: خَرجتُ أتعرّض لرسول الله ﷺ قبل أنْ أُسلِم، فوجَدتُه قد سبقني إلى المسجد، فقمتُ خَلفه، فاستفتحَ سورة الحاقة، فجَعلتُ أعجب من تأليف القرآن، فقلتُ: هذا -واللهِ- شاعر كما قالتْ قريش. فقرأ: <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ وما هُوَ بِقَوْلِ شاعِرٍ قَلِيلًا ما تُؤْمِنُونَ﴾</span> [الحاقة:٤٠-٤١]. قلتُ: كاهن. قال: <span class="qpc-hafs">﴿ولا بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ تَنْزِيلٌ﴾</span> إلى آخر السورة [الحاقة:٤٢-٥٢]، فوقع الإسلام في قلبي كلّ موقع{1}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نَزَلَتْ سورةُ الحاقة بمكة{2}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٣<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{3}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلت بعد <span class="qpc-hafs">﴿تبارك﴾</span> المُلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٦<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٨<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة المُلك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٩<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٠<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الحاقة مكّيّة، عددها اثنتان وخمسون آية كوفي{9}<span class=comment-ref>٦٧٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٤) أنّ هذه السورة مكية <span class="mustanad">بإجماع</span>.</div></p></div>",footnotes:1:أخرجه أحمد ١/٢٦٢ (١٠٧).</p><p>وقال محقّقوه: «إسناده ضعيف».أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٤٩ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤١٩.
  69,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلۡحَاۤقَّةُ ۝١ مَا ٱلۡحَاۤقَّةُ ۝٢ وَمَاۤ أَدۡرَىٰكَ مَا ٱلۡحَاۤقَّةُ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span>، قال: من أسماء يوم القيامة{1}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span>: يعني: القيامة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- قال: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span> القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span> قال: يعني: الساعة، أحقّتْ لكلِّ عاملٍ عمَلَه، <span class="qpc-hafs">﴿وما أدْراكَ ما الحاقَّةُ﴾</span> قال: تعظيمًا ليوم القيامة، كما تَسمعون{4}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن</span> <span class="name-3">سليمان</span>: قوله تعالى: <span class="qpc-hafs">﴿الحاقَّةُ ما الحاقَّةُ﴾</span> ثم بيّن ما الحاقة؛ يعني: الساعة التي فيها حقائق الأعمال، يقول: يحقّ للمؤمنين عملهم، ويحقّ للكافرين عملهم. ثم قال للنبي ﷺ: <span class="qpc-hafs">﴿وما أدْراكَ ما الحاقَّةُ﴾</span> تعظيمًا لها لشِدّتها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span>، قال: حقَّقتْ لكل عامل عمَله؛ للمؤمن إيمانه، وللمنافق نفاقه{6}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق مهران- قال: ما في القرآن: <span class="qpc-hafs">﴿وما يُدْرِيكَ﴾</span> [الأحزاب:٦٣، الشورى:١٧، عبس:٣] فلم يُخبِره، وما كان: <span class="qpc-hafs">﴿وما أدْراكَ﴾</span> فقد أخبَره{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الحاقَّةُ ما الحاقَّةُ﴾</span>، و<span class="qpc-hafs">﴿القارِعَةُ ما القارِعَةُ﴾</span> [القارعة:١-٢]، و<span class="qpc-hafs">﴿الواقِعَةُ﴾</span> [الواقعة:١]، و<span class="qpc-hafs">﴿الطّامَّةُ﴾</span> [النازعات:٣٤]، و<span class="qpc-hafs">﴿الصّاخَّةُ﴾</span> [عبس:٣٣]، قال: هذا كلّه يوم القيامة؛ الساعة. وقرأ قول الله: <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ خافِضَةٌ رافِعَةٌ﴾</span> [الواقعة:٢-٣]، والخافضة مِن هؤلاء أيضًا خَفَضَتْ أهل النار، ولا نَعلَم أحدًا أخْفَض من أهل النار، ولا أذلّ، ولا أخْزى، ورَفعَتْ أهل الجنة، ولا نَعلَم أحدًا أشرف من أهل الجنة، ولا أكرم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: وبلغني أنّ كلّ شيء في القرآن <span class="qpc-hafs">﴿وما أدْراكَ﴾</span> فقد أدراه إياه، وكلّ شيء <span class="qpc-hafs">﴿وما يُدْرِيكَ﴾</span> [الأحزاب:٦٣، الشورى:١٧، عبس:٣] فهو ما لم يُعْلِمه إياه بعد{9}<span class=comment-ref>٦٧٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٣</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/٣٨٤) أنّ بعض المفسرين قال بأن «الحاقة» مصدر كالعافية والعاقبة، و<span class="comment-type-4">علَّق</span> عليه بقوله: «كأنه قال: ذات الحق».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٢٠٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧١-، وابن جرير ٢٣/٢٠٥.أخرجه عبد الرزاق ٢/٣١٢ بنحوه، وابن جرير ٢٣/٢٠٦-٢٠٧ بنحوه، ومن طريق سعيد أيضًا. وعلقه الحاكم ٢/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٠٧.أخرجه ابن جرير ٢٣/٢٠٦.تفسير ابن أبي زمنين ٥/٢٦.
