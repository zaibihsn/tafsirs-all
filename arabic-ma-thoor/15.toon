  15,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰا قَالَ إِنَّا مِنكُمۡ وَجِلُونَ ۝٥٢ قَالُوا۟ لَا تَوۡجَلۡ إِنَّا نُبَشِّرُكَ بِغُلَـٰمٍ عَلِیمࣲ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٣٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿قالوا لا توجل﴾</span>، قال: لا تَخَفْ{1}. (٨/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ دخلوا عليه﴾</span> على إبراهيم، <span class="qpc-hafs">﴿فقالوا سلاما﴾</span> فسَلَّموا عليه، وسَلَّم عليهما، <span class="qpc-hafs">﴿قال إنا منكم وجلون﴾</span> يعني: خائفين، وذلك أنّ إبراهيم ﵇ قرَّب إليهم العِجْل، فلم يأكلوا منه، فخاف إبراهيم ﵇، وكان في زمان إبراهيم ﵇ إذا أكل الرجلُ عند الرجل طعامًا أمِنَ مِن شَرِّه، فلمّا رأى إبراهيم ﵇ أيديَهم لا تصل إلى العِجْل خاف شرَّهم، <span class="qpc-hafs">﴿قالوا﴾</span> قال له جبريل ﵇: <span class="qpc-hafs">﴿لا توجل﴾</span> يقول: لا تَخَفْ، <span class="qpc-hafs">﴿إنا نبشرك بغلام عليم﴾</span> وهو إسحاق ﵇{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣١.
  15,53,""
  15,53,""
  15,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَبَشَّرۡتُمُونِی عَلَىٰۤ أَن مَّسَّنِیَ ٱلۡكِبَرُ فَبِمَ تُبَشِّرُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فبِم تبشرون﴾</span>، قال: عَجِب مِن كِبَرِه، وكِبَرِ امرأتِه{1}. (٨/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> لهم إبراهيم ﵇: <span class="qpc-hafs">﴿أبشرتموني﴾</span> بالولد <span class="qpc-hafs">﴿على أن مسني الكبر﴾</span> على كِبَر سِنِّي، <span class="qpc-hafs">﴿فبم تبشرون﴾</span> قال ذلك إبراهيم ﵇ تَعَجُّبًا لِكِبَرِه، وكِبَر امرأتِه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٨٣-٨٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣١.
  15,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٢<span class="dash">-</span></span> عن <span class="name-2">يحيى</span> -من طريق الأعمش- أنّه قرأها: (فَلا تَكُن مِّنَ القَنِطِينَ) بغير ألف. قال: وقرأ: <span class="qpc-hafs">﴿ومَن يَقْنَطُ مِن رَّحْمَةِ رَبِّهِ﴾</span> مفتوحة النون{1}<span class=comment-ref>٣٦١٦</span>. (٨/٦٣٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٦١٦</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿فَلا تَكُنْ مِنَ القانِطِينَ﴾</span> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿القانِطِين﴾</span> بالألف. <b>الثانية:</b> (القَنِطِين) بدون ألف.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٨٤-٨٥) القراءة الأولى <span class="mustanad">مستندًا إلى إجماع الحجة مِن القرأة عليها، وشذوذ ما خالفه</span>.</div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿من القانطين﴾</span>، قال: الآيِسِين{2}. (٨/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> قال جبريل ﵇: <span class="qpc-hafs">﴿بشرناك﴾</span> يعني: نُبَشِّرك <span class="qpc-hafs">﴿بالحق﴾</span> يعني: بالصِّدق أنّ الولد لَكائن، <span class="qpc-hafs">﴿فلا تكن﴾</span> يا إبراهيم <span class="qpc-hafs">﴿من القانطين﴾</span> يعني: لا تَيْأَس{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>(فَلا تَكُن مِّنَ القَنِطِينَ) بغير ألف قراءة شاذة، تروى أيضًا عن الأعمش، وطلحة بن مصرّف، وغيرهما. انظر: مختصر ابن خالويه ص٧٥، والمحتسب ٢/٤.</p><p>وأما <span class="qpc-hafs">﴿ومَن يَقْنَطُ﴾</span> بفتح النون، فهي قراءة متواترة، قرأ بها ابن كثير، ونافع، وعاصم، وابن عامر، وحمزة، وأبو جعفر، وقرأ بقية العشرة: ‹ومَن يَقْنِطُ› بكسر النون. انظر: النشر ٢/٣٠٢، والإتحاف ص٣٤٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ وَمَن یَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿ومن يقنَط من رحمة ربه﴾</span>، قال: مَن ييأس مِن رحمة ربِّه{1}. (٨/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> إبراهيم ﵇: <span class="qpc-hafs">﴿ومن يقنط﴾</span> يعني: ومَن يَيْئَس <span class="qpc-hafs">﴿من رحمة ربه إلا الضالون﴾</span> يعني: المشركين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span>، قال: مَن ذهب يُقَنِّطُ الناسَ مِن رحمة الله، أو يُقَنِّطُ نفسَه؛ فقد أخطأ. ثم نَزَعَ{3} بهذه الآية: <span class="qpc-hafs">﴿ومن يقنَط من رحمة ربه إلا الضآلون﴾</span>{1}. (٨/٦٣٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ وَمَن یَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٨<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>الفاجر الرّاجي لِرَحمة اللهِ أقربُ مِن العابد المُقَنِّطِ</b>»{5}. (٨/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٩<span class="dash">-</span></span> عن موسى بن علي، عن أبيه، قال: بَلَغَني: أنّ نوحًا ﵇ قال لابنه سام: يا بُنَيَّ، لا تَدْخُلَنَّ القبرَ وفي قلبك مثقال ذَرَّةٍ مِن الشرك بالله؛ فإنه مَن يأت اللهَ ﷿ مُشْرِكًا فلا حُجَّةَ له، ويا بُنَيَّ، لا تَدْخُلَنَّ القبر وفي قلبك مِثقال ذرَّةٍ مِن الكبر؛ فإنّ الكبرياء رِداءُ الله، فمَن يُنازِع اللهَ رداءَه يغضب الله عليه، ويا بُنَيَّ، لا تَدْخُلَنَّ القبر وفي قلبك مثقال ذرة مِن القنَط؛ فإنّه لا يقنَط مِن رحمة الله إلا ضالٌّ{6}. (٨/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٠<span class="dash">-</span></span> عن أبي توبة الربيع بن نافع، قال: سُئِل <span class="name-3">سفيان بن عيينة</span> عن قول <span class="name-1">عليٍّ</span>: الفقيهُ كُلَّ الفقيه مَن لم يُقَنِّط الناس من رحمة الله، ولم يُرَخِّص لهم في معاصي الله. فقال: صدق، لا يكون الترخيص إلا في المستقبل، ولا التَّقنيط إلا فيما مضى.=</p><p>قال سفيان: وقال <span class="name-1">عبد الله</span>: اثنتان مُنجِيَتان، واثنتان مُهْلِكتان؛ فالمُنجِيَتان: النِّيَّة، والنهي؛ فالنِّيَّة أن تنوي أن تطيع الله فيما يستقبل، والنهي أن تنهى نفسك عمّا حرم الله ﷿. والمهلكتان: العجب، والقنوط.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥١<span class="dash">-</span></span> قال <span class="name-3">سفيان</span>: وأكبر الكبائر: الشرك بالله، والقنوط من رحمة الله، واليأس من روح الله، والأمن من مكر الله. ثم تلا: <span class="qpc-hafs">﴿فلا يأمن مكر الله إلا القوم الخاسرون﴾</span> [الأعراف:٩٩]، <span class="qpc-hafs">﴿أنه من يشرك بالله فقد حرم الله عليه الجنة﴾</span> [المائدة:٧٢]، <span class="qpc-hafs">﴿لا ييأس من روح الله إلا القوم الكافرون﴾</span> [يوسف:٨٧]، <span class="qpc-hafs">﴿ومن يقنط من رحمة ربه إلا الضالون﴾</span> [الحجر:٥٦]{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٢.نَزَع بالآية والشِّعر وانتَزَع: تمثّل، ويقال للرجل إذا استنبط معنى آية من كتاب الله ﷿: قد انتزع معنى جيدًا. اللسان (نزع).عزاه السيوطي إلى ابن أبي حاتم.أورده الحكيم الترمذي في نوادر الأصول ١/٩٣، والديلمي في مسند الفردوس ٣/١٥٩ (٤٤٢٧) بلفظ: من العبد المجتهد الآيس منها الذي لا يرجو أن ينالها وهو مطيع لله.</p><p>قال المناوي في التيسير ٢/١٧٩ عن رواية الحكيم الترمذي والشيرازي في الألقاب: «بإسناد ضعيف». وقال في فيض القدير ٤/٤٦٠-٤٦١ (٥٩٧١): «وفيه عبد الله بن يحيى الثقفي، أورده الذهبي في ذيل الضعفاء وقال: صُوَيْلح ضعَّفه ابن معين، وسلام بن مسلم قال في الضعفاء: تركوه باتفاق، وزيد العمي ضعيف متماسك». وقال الألباني في الضعيفة ٩/٢٨ (٤٠٢٥) عن رواية الديلمي: «موضوع».أخرجه أحمد في الزهد ص٥١.أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
  15,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فَمَا خَطۡبُكُمۡ أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> إبراهيم: <span class="qpc-hafs">﴿فما خطبكم﴾</span> يعني: فما أمَرَكُم <span class="qpc-hafs">﴿أيها المرسلون﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٥٨ إِلَّاۤ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمۡ أَجۡمَعِینَ ۝٥٩ إِلَّا ٱمۡرَأَتَهُۥ قَدَّرۡنَاۤ إِنَّهَا لَمِنَ ٱلۡغَـٰبِرِینَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٥٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>، قال: بيني وبين القَدَرِيَّة هذه الآية: <span class="qpc-hafs">﴿إلا امرأته قدَّرنا إنها لمن الغابرين﴾</span>{1}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إنها لمن الغابرين﴾</span>، يعني: الباقين في عذاب الله{1}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿إنها لمن الغابرين﴾</span>، قال: مِمَّن غَبَر فهَلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> أي: قال جبريل ﵇: <span class="qpc-hafs">﴿إنا أرسلنا﴾</span> بالعذاب <span class="qpc-hafs">﴿إلى قوم مجرمين* إلا آل لوط إنا لمنجوهم أجمعين﴾</span> ثم استثنى جبريل ﵇ امرأةَ لوط، فقال: <span class="qpc-hafs">﴿إلا امرأته قدرنا إنها لمن الغابرين﴾</span> يعني: الباقين في العذاب{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق في تفسيره ٢/٣٤٩.تفسير مقاتل بن سليمان ٢/٤٣٢.
