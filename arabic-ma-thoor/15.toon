  15,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذَتۡهُمُ ٱلصَّیۡحَةُ مُصۡبِحِینَ ۝٨٣ فَمَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یَكۡسِبُونَ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٥٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخذتهم الصيحة﴾</span> يعني: صيحة جبريل ﵇ <span class="qpc-hafs">﴿مصبحين﴾</span> يومَ السبت، فخمدوا أجمعون، يقول الله ﷿: <span class="qpc-hafs">﴿فما أغنى عنهم﴾</span> مِن العذاب الذي نزل بهم <span class="qpc-hafs">﴿ما كانوا يكسبون﴾</span> مِن الكفر والتكذيب، فعقروا الناقة يوم الأربعاء، فأهلكهم الله يوم السبت{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخَذَتۡهُمُ ٱلصَّیۡحَةُ مُصۡبِحِینَ ۝٨٣ فَمَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یَكۡسِبُونَ ۝٨٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٥٥٧<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ لأصحاب الحِجْر: «<b>لا تدخلوا على هؤلاء القوم إلا أن تكونوا باكين، فإن لم تكونوا باكين فلا تدخلوا عليهم؛ أن يصيبكم مثل ما أصابهم</b>»{2}. (٨/٦٤٤)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٥-٤٣٦.أخرجه البخاري ١/٩٤ (٤٣٣)، ٤/١٤٩ (٣٣٨٠، ٣٣٨١)، ٦/٧-٨ (٤٤١٩، ٤٤٢٠)، ٦/٨١ (٤٧٠٢)، ومسلم ٤/٢٢٨٥-٢٢٨٦ (٢٩٨٠)، ويحيى بن سلام في تفسيره ٢/٥٥٣، وعبد الرزاق في تفسيره ٢/٨٤ (٩١٨)، وابن جرير ١٢/٤٦٣، ١٤/١٠٣-١٠٤، وأورده الثعلبي ٥/٣٤٧.
