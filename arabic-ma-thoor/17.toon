  17,94,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا مَنَعَ ٱلنَّاسَ أَن یُؤۡمِنُوۤا۟ إِذۡ جَاۤءَهُمُ ٱلۡهُدَىٰۤ إِلَّاۤ أَن قَالُوۤا۟ أَبَعَثَ ٱللَّهُ بَشَرࣰا رَّسُولࣰا ۝٩٤ قُل لَّوۡ كَانَ فِی ٱلۡأَرۡضِ مَلَـٰۤىِٕكَةࣱ یَمۡشُونَ مُطۡمَىِٕنِّینَ لَنَزَّلۡنَا عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ مَلَكࣰا رَّسُولࣰا ۝٩٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٤٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في المستهزئين، والمطعمين ببدر{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا مَنَعَ ٱلنَّاسَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٠١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما منع الناس﴾</span>، يعني: رؤوس كفار مكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٠١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وما منع الناس﴾</span>، يعني: المشركين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن یُؤۡمِنُوۤا۟ إِذۡ جَاۤءَهُمُ ٱلۡهُدَىٰۤ إِلَّاۤ أَن قَالُوۤا۟ أَبَعَثَ ٱللَّهُ بَشَرࣰا رَّسُولࣰا ۝٩٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٠١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن يؤمنوا﴾</span> يعني: أن يُصَدِّقوا بالقرآن <span class="qpc-hafs">﴿إذ جاءهم الهدى﴾</span> يعني: البيان، وهو القرآن؛ لأنّ القرآن هُدًى مِن الضلالة، <span class="qpc-hafs">﴿إلا أن قالوا أبعث الله بشرا رسولا﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٠١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أن يؤمنوا إذ جاءهم الهدى إلا أن قالوا أبعث الله بشرا رسولا﴾</span>، على الاستفهام، وهذا الاستفهام على إنكار منهم، أي: لم يبعث الله بشرًا رسولًا؛ فلو كان من الملائكة لآمنّا به{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُل لَّوۡ كَانَ فِی ٱلۡأَرۡضِ مَلَـٰۤىِٕكَةࣱ یَمۡشُونَ مُطۡمَىِٕنِّینَ لَنَزَّلۡنَا عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ مَلَكࣰا رَّسُولࣰا ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل لو كان في الأرض ملائكة يمشون مطمئنين﴾</span> يعني: مقيمين بها، مثل قوله سبحانه في النساء [١٠٣]: <span class="qpc-hafs">﴿فإذا اطمأننتم﴾</span> يقول: فإذا أقمتم <span class="qpc-hafs">﴿فأقيموا الصلاة﴾</span>، <span class="qpc-hafs">﴿لنزلنا عليهم من السماء ملكا رسولا﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٠١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله لنبيه: <span class="qpc-hafs">﴿قل لو كان﴾</span> معه <span class="qpc-hafs">﴿في الأرض ملائكة يمشون مطمئنين﴾</span> قد اطمأنت بهم الدار، أي: هي مسكنهم؛ <span class="qpc-hafs">﴿لنزلنا عليهم من السماء ملكا رسولا﴾</span> ولكن فيها بشر، فأرسلنا إليهم بشرًا مثلهم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير يحيى بن سلام ١/١٦٣.تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير يحيى بن سلام ١/١٦٣.تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير يحيى بن سلام ١/١٦٤.
