  30,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ حِینَ تُمۡسُونَ وَحِینَ تُصۡبِحُونَ ۝١٧ وَلَهُ ٱلۡحَمۡدُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَعَشِیࣰّا وَحِینَ تُظۡهِرُونَ ۝١٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كل تسبيح في القرآن فهو صلاة{1}. (١١/٥٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: أدنى ما يكون مِن الحين بكرةً وعَشِيًّا. ثم قرأ: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ﴾</span>{2}. (١١/٥٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٧٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</span> يحمده أهل السموات والأرض، ويُصَلُّون له{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رزين- أنّه سأله نافع بن الأزرق، فقال: هل تجد الصلوات الخمس في القرآن؟ قال: نعم. فقرأ: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> صلاة المغرب، <span class="qpc-hafs">﴿وحين تُصبحُونَ﴾</span> صلاة الصبح، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> صلاة العصر، <span class="qpc-hafs">﴿وحين تظْهرُونَ﴾</span> صلاة الظهر. وقرأ: <span class="qpc-hafs">﴿ومن بعد صَلاة العشاء﴾</span> [النور:٥٨]{4}. (١١/٥٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي عياض- قال: جمعت هذه الآيةُ مواقيتَ الصلاة؛ <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> قال: المغرب والعشاء، <span class="qpc-hafs">﴿وحين تُصبحُونَ﴾</span> الفجر، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> العصر، <span class="qpc-hafs">﴿وحين تظْهرُونَ﴾</span> الظهر{5}. (١١/٥٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث-، مثله{6}. (١١/٥٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- <span class="qpc-hafs">﴿وإبراهيم الذي وفى﴾</span> [النجم:٣٧]، قال: <span class="qpc-hafs">﴿سبحان الله حين تمسون وحين تصبحون﴾</span> الآيةَ؛ ثلاثٌ غدوة، وثلاثٌ عشية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري:</span> أن الصلوات الخمس كلها في هذه الآية يقول: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> المغرب والعشاء {8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> لصلاة المغرب، <span class="qpc-hafs">﴿وحين تُصبحُونَ﴾</span> لصلاة الصبح، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> لصلاة العصر، <span class="qpc-hafs">﴿وحين تظْهرُونَ﴾</span> صلاة الظهر؛ أربع صلوات{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> تنشرون، وتنبسطون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ﴾</span> يعني: فصلُّوا لله ﷿ <span class="qpc-hafs">﴿حِينَ تُمْسُونَ﴾</span> يعني: صلاة المغرب، وصلاة العشاء، <span class="qpc-hafs">﴿وحِينَ تُصْبِحُونَ﴾</span> يعني: صلاة الفجر، <span class="qpc-hafs">﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ﴾</span> يحمده الملائكة في السماوات، ويحمده المؤمنون في الأرض <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> يعني: صلاة العصر، <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> يعني: صلاة الأولى {11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ * ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</span>، قال: <span class="qpc-hafs">﴿حِينَ تُمْسُونَ﴾</span> صلاة المغرب، <span class="qpc-hafs">﴿وحِينَ تُصْبِحُونَ﴾</span> صلاة الصبح، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> صلاة العصر، <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> صلاة الظهر، <span class="qpc-hafs">﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ﴾</span> يقول: وله الحمد مِن جميع خلقه دون غيره <span class="qpc-hafs">﴿في السماوات﴾</span> مِن سكانها من الملائكة، <span class="qpc-hafs">﴿والأرض﴾</span> من أهلها؛ من جميع أصناف خلقه فيها، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> يقول: وسبِّحوه أيضًا عشيًّا، وذلك صلاة العصر، <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> يقول: وحين تدخلون في وقت الظهر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: كل صلاة ذُكِرت في المكيِّ مِن القرآن قبل الهجرة بسنة فهي ركعتان غدوة، وركعتان عشية، وذلك قبل أن تفرض الصلوات الخمس، وإنما افترضت الصلوات الخمس قبل أن يهاجر النبيُّ ﵇ بسنة؛ ليلة أُسْرِي به، فما كان مِن ذكر الصلاة بعد ذلك يعني: فهي الصلوات الخمس. وهذه الآية نزلت بعدما أُسْرِي بالنبي ﵇، وفُرضت عليه الصلوات الخمس{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ حِینَ تُمۡسُونَ وَحِینَ تُصۡبِحُونَ ۝١٧ وَلَهُ ٱلۡحَمۡدُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَعَشِیࣰّا وَحِینَ تُظۡهِرُونَ ۝١٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٨٩<span class="dash">-</span></span> عن معاذ بن أنس، عن رسول الله ﷺ، قال: «<b>ألا أخبركم لِمَ سَمّى اللهُ إبراهيمَ: خليلَه الذي وفّى؟ لأنّه كان يقول كُلَّما أصبح وأمسى</b>: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ * ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</span>»{14}. (١١/٥٩٢). (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه، والفريابي.عزاه السيوطي إلى الفريابي، وابن أبي حاتم.تفسير البغوي ٦/٢٦٤.أخرجه يحيى بن سلام ٢/٦٤٩، وعبد الرزاق (١٧٧٢)، وابن جرير ١٨/٤٧٤، وابن المنذر في الأوسط ٢/٣٢١ (٩٣٢)، والطبراني (١٠٥٩٦)، والحاكم ٢/٤١٠-٤١١. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ١٨/٤٧٤-٤٧٥، وابن المنذر ٢/٣٢٢ (٩٣٣). وعزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن جرير ١٨/٤٧٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه إسحاق البستي ص٧٧.علقه يحيى بن سلام ٢/٦٤٩.أخرجه ابن جرير ١/٤٧٥.علقه يحيى بن سلام ٢/٦٤٩.تفسير مقاتل بن سليمان ٣/٤٠٩.أخرجه ابن جرير ١٨/٤٧٥.تفسير يحيى بن سلام ٢/٦٤٩-٦٥٠.أخرجه أحمد ٢٤/٣٨٨ (١٥٦٢٤)، وابن جرير ٢/٥٠٧، ٢٢/٧٧-٧٨، والثعلبي ٩/١٥٢.</p><p>قال الزيلعي في تخريج أحاديث الكشاف ٣/٣٨٤-٣٨٥ (١٢٧٢): «رواه الطبري، وابن مردويه، والثعلبي، وابن أبي حاتم في تفاسيرهم، وهو مشتمل على جماعة من الضعفاء». وقال الهيثمي في المجمع ١٠/١١٧ (١٧٠١٠): «رواه الطبراني، وفيه ضعفاء وُثِّقوا». وقال ابن حجر الفتح ٨/٦٠٥: «بإسناد ضعيف». وقال الشوكاني في فتح القدير ٤/٢٥٦: «وفي إسناده ابن لهيعة».
