quran[30]{c,v,t}:
  89,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٢٨٩٧<span class="dash">-</span></span> عن عائشة، قالت: نزلت سورة <span class="qpc-hafs">﴿والفَجْرِ﴾</span> بمكة{1}. (١٥/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{2}. (١٥/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٨٩٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمُسمّى: <span class="qpc-hafs">﴿والفَجْرِ ولَيالٍ عَشْرٍ﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿واللَّيْلِ إذا يَغْشى﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٠<span class="dash">-</span></span> عن عبد الله بن الزُّبير، قال: أُنزِلَتْ: <span class="qpc-hafs">﴿والفَجْرِ﴾</span> بمكة{1}. (١٥/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠١<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٢<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٣<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٤<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، وذكرها بمُسمّى: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿واللَّيْلِ إذا يَغْشى﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٥<span class="dash">-</span></span> عن علي بن أبي طلحة: مدنية{8}<span class=comment-ref>٧١٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٠</span> ذكر <u>ابنُ عطية</u> (٨/٦٠٤) أنّ سورة الفجر «مكّيّة عند جمهور المفسرين». ونقل عن بعض العلماء -حكاية عن الداني-: أنها مدنية، ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأول أشهر، وأصحّ». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٦<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الفجر مكّيّة، عددها ثلاثون آية كوفي{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡفَجۡرِ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٩٠٧<span class="dash">-</span></span> عن عطية العَوفيّ، في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: هذا الذي تعرفون. قيل: هل تروي هذا عن أحد مِن أصحاب النبي ﷺ؟ قال: نعم، عن أبي سعيد الخدريّ، عن النبي ﷺ{1}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي نصر- في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: فجر النهار{11}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٠٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، مثله{12}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-، مثله{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: يعني: صلاة الفجر{14}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عثمان- في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: هو المُحرّم أول فجر السنة{15}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزُّبير</span> -من طريق محمد بن المرتفع- في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: قَسمٌ أقسم الله به{16}. (١٥/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٤<span class="dash">-</span></span> عن <span class="name-2">الأسود بن يزيد</span> -من طريق أبي إسحاق- في قوله: <span class="qpc-hafs">﴿والفجر﴾</span>، قال: هو فجركم هذا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: فجر يوم النَّحر، وليس كلّ فجر{18}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، مثله{18}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿والفَجْرِ﴾</span> فجر ذي الحِجّة؛ لأنّ الله سبحانه قرن الأيّام بها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عاصم الأحول- في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: هو الصبح{21}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: طلوع الفجر غداة جَمع{12}. (١٥/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٠<span class="dash">-</span></span> عن <span class="name-2">عطية العَوفيّ</span>، في قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، قال: هذا الذي تعرفون{1}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢١<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span>، قال: إنّ الله تعالى يُقسم بما يشاء من خَلْقه، وليس لأحد أن يُقسم إلا بالله{24}. (١٥/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، يعني: غداة جَمع يوم النَّحر{25}<span class=comment-ref>٧١٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥١</span> زاد <u>ابنُ عطية</u> (٨/٦٠٤) في معنى الآية <b>قولين آخرين</b>، فقال: «وقيل: المراد: فجر العيون من الصخور وغيرها. وقال عكرمة: المراد: فجر يوم الجمعة».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابن القيم</u> (٣/٢٩٦) أنّ قوله تعالى: <span class="qpc-hafs">﴿والفَجْرِ﴾</span> «إنْ أريد به جنس الفجر كما هو ظاهر اللفظ فإنه يتضمّن وقت صلاة الصبح، التي هي أول الصلوات، فافتتح القسم بما يتضمّن أول الصلوات، وختمه بقوله: <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span> المتضمّن لآخر الصلوات: وإنْ أريد بالفجر فجر مخصوص فهو فجر يوم النَّحر وليلته التي هي ليلة عرفة، فتلك الليلة من أفضل ليالي العام، وما رئي الشيطان في ليلة أدحر ولا أحقر ولا أغيظ منه فيها، وذلك الفجر فجر يوم النَّحر الذي هو أفضل الأيام عند الله ... وعلى هذا فقد تضمّن القَسم المناسك والصلوات، وهما المختصان بعبادة الله والخضوع له والتواضع لعظمته، <span class="mustanad">ولهذا قال الخليل</span> ﵇: <span class="qpc-hafs">﴿قُلْ إنَّ صَلاتِي ونُسُكِي ومَحْيايَ ومَماتِي لِلَّهِ رَبِّ العالَمِينَ﴾</span> [الأنعام:١٦٢]، <span class="mustanad">وقيل لخاتم الرسل</span> ﷺ: <span class="qpc-hafs">﴿فَصَلِّ لِرَبِّكَ وانْحَرْ﴾</span> [الكوثر:٢]، بخلاف حال المشركين المُتكبِّرين الذين لا يعبدون الله وحده، بل يُشركون به، ويستكبرون عن عبادته كحال مَن ذُكر في هذه السورة من قوم عاد وثمود وفرعون».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٦٨٥.عزاه السيوطي إلى ابن مردويه.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٢٦-، وابن جرير ٢٤/٣٤٤، والحاكم ٢/٥٢٢، والبيهقي في شعب الإيمان (٣٧٤٥). وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٢٦.أخرجه ابن جرير ٢٤/٣٤٤.أخرجه البيهقي في شعب الإيمان (٣٧٧١)، وابن عساكر ١/٥٢. وعزاه السيوطي إلى سعيد بن منصور.</p><p><b>وقد أورد السيوطي عقب هذا الأثر آثارًا كثيرة ١٥/ ٣٩٤-٣٩٨ في فضل شهر المحرم ويوم عاشوراء.</b>أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٤٩-٥٠ (١٠٧)، وابن جرير ٢٤/٣٤٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الفراء في معاني القرآن ٣/٢٥٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/١٩١، وتفسير البغوي ٨/٤١٢.أخرجه ابن جرير ٢٤/٣٤٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٩.تفسير مقاتل بن سليمان ٤/٦٨٧.
  89,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَیَالٍ عَشۡرࣲ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٩٢٣<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: <span class="qpc-hafs">﴿والفَجْرِ ولَيالٍ عَشْرٍ﴾</span>، قال: «<b>إنّ العَشر عَشرُ الأضحى</b>»{1}. (١٥/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٤<span class="dash">-</span></span> عن عطية العَوفيّ، في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: عَشرُ الأضحى. قيل: هل تروي هذا عن أحد من أصحاب النبي ﷺ؟ قال: نعم، عن أبي سعيد الخدريّ، عن النبي ﷺ{2}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي نصر- في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: عشرة الأضحى. وفي لفظ قال: هي ليال العشر الأُوَل من ذي الحِجّة{3}. (١٥/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: هي العشر الأواخر من رمضان{4}. (١٥/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>: عَشرُ الأضحى. قال: ويقال: العشر: أول السنة مِن المُحرّم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزُّبير</span> -من طريق محمد بن المرتفع- في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: أول ذي الحِجّة إلى يوم النَّحر{6}. (١٥/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٢٩<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span> -من طريق أبي الزُّبير- <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>: هي أيام العشر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٠<span class="dash">-</span></span> عن طلحة بن عبد الله، أنه دخل على ابن عمر، هو و<span class="name-2">أبو سَلمة بن عبد الرحمن</span>، فدعاهم ابنُ عمر إلى الغداء يوم عرفة، فقال أبو سَلمة: أليس هذه الليالي العشر التي ذكرها الله في القرآن؟= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣١<span class="dash">-</span></span> فقال <span class="name-1">ابن عمر</span>: وما يدريك؟ قال: ما أشكّ. قال: بلى، فاشكك{8}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٢<span class="dash">-</span></span> عن <span class="name-2">مسروق بن الأَجْدع الهَمداني</span> -من طريق أبي الضُّحى- في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: هي عَشرُ الأضحى، هي أفضل أيام السنة{9}. (١٥/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٣<span class="dash">-</span></span> عن <span class="name-2">مسروق بن الأَجْدع الهَمداني</span>، <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: عَشرُ الأضحى، وهي التي وعد الله موسى؛ قوله: <span class="qpc-hafs">﴿وأَتْمَمْناها بِعَشْرٍ﴾</span> [الأعراف:١٤٢]{8}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: عَشرُ ذي الحِجّة{11}. (١٥/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-، مثله{12}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عاصم الأحول-، مثله{13}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق يزيد بن أبي زياد- قال: ليس عملٌ في ليالٍ مِن ليالي السنة أفضل منه في ليالي العشر، وهي عَشرُ موسى التي أتمّها الله له{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: عَشرُ الأضحى، أقسم بهنّ لفضلهنّ على سائر الأيام{15}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٣٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿وليال عشر﴾</span>، قال: عَشرُ الأضحى{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span> فهي عَشرُ ليال قبل الأضحى، ... سمّاها الله ﷿ ليالٍ عشرٍ لأنها تسعة أيام وعشر ليال{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ﴾</span>، قال: أول ذي الحِجّة{18}<span class=comment-ref>٧١٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٢</span> اختُلف في «الليالي العشر» ما هي؟ على أقوال: <b>الأول:</b> هي ليال عشر ذي الحِجّة. <b>الثاني:</b> العشر الأُوَل من المُحرّم. <b>الثالث:</b> العشر الأواخر من رمضان.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٣٤٨) -<span class="mustanad">مستندًا إلى السنة، وإجماع أهل التأويل</span>- القول الأول، وهو قول ابن عباس من طريق أبي نصر، وما في معناه، وعلَّل ذلك بقوله: «لإجماع الحجّة من أهل التأويل عليه، وأنّ عبد الله بن أبي زيادٍ القَطواني حدَّثني قال: ثني زيد بن حباب، قال: أخبرني عيّاش بن عقبة، قال: ثني خير بن نُعيم، عن أبي الزُّبير، عن جابر، أنّ رسول الله ﷺ قال: <span class="qpc-hafs">﴿والفَجْرِ ولَيالٍ عَشْرٍ﴾</span>، قال: «عَشرُ الأضحى»».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ كثير</u> (١٤/٣٣٨).</p><p>و<span class="comment-type-4">زاد</span> <u>ابنُ عطية</u> (٨/٦٠٤، ٦٠٥) <b>قولين آخرين</b> نقلهما: الأول عن بعض الرواة: «هي العشر الأُوَل من رمضان»، والثاني عن مجاهد: «هي عَشرُ موسى ﵇ التي أتمَّها الله تعالى له».</div></p><p><h3><span class="qpc-hafs">﴿وَلَیَالٍ عَشۡرࣲ ۝٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٩٤٢<span class="dash">-</span></span> عن عبد الله بن عباس، عن رسول الله ﷺ، قال: «<b>ما مِن أيام فيهنّ العمل أحبّ إلى الله ﷿ أفضل مِن أيام العشر</b>». قيل: يا رسول الله، ولا الجهاد في سبيل الله؟ قال: «<b>ولا الجهاد في سبيل الله، إلا رجل جاهد في سبيل الله بماله ونفسه فلم يرجع من ذلك بشيء</b>»{19}. (١٥/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٣<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>ما مِن أيام أفضل عند الله، ولا العمل فيهنّ أحبّ إلى الله ﷿، مِن هذه الأيام العشر، فأكثِروا فيهنَّ مِن التهليل والتكبير، فإنها أيام التهليل والتكبير وذِكْر الله، وإنّ صيام يوم منها يَعدِل بصيام سنة، والعمل فيهنّ يُضاعف بسبعمائة ضعف</b>»{20}. (١٥/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٤<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>ما من أيام أفضل عند الله ولا أحبّ إليه العمل فيهنّ مِن أيام العشر؛ فأكثِروا فيها مِن التهليل والتكبير والتحميد</b>»{21}. (١٥/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٥<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>ما من أيام مِن أيام الدنيا العمل فيها أحبّ إلى الله أن يُتعبّد له فيها مِن أيام العشر، يَعدِل صيام كلّ يوم منها بصيام سنة، وقيام كلّ ليلة بقيام ليلة القدر</b>»{22}. (١٥/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٦<span class="dash">-</span></span> عن الأوزاعي، قال: بلغني: أنّ العمل في اليوم من أيام العشر كقدر غزوة في سبيل الله، يُصام نهارها، ويُحرس ليلها، إلا أن يُختصّ امرؤ بشهادة. قال الأوزاعي: حدَّثني بهذا الحديث رجل من قريش من بني مخزوم، عن النبي ﷺ{23}. (١٥/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٧<span class="dash">-</span></span> عن بعض أزواج النبي ﷺ -من طريق امرأة هنيدة بن خالد-: أنّ النبي ﷺ كان يصوم تسع ذي الحجة، ويوم عاشوراء، وثلاثة أيام من كلّ شهر؛ أول اثنين من الشهر، وخميسين{24}. (١٥/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي عثمان</span>، قال: كانوا يعظّمون ثلاث عشرات؛ العشر الأُوَل من المُحرّم، والعشر الأُوَل من ذي الحجة، والعشر الأُخَر من رمضان{25}. (١٥/٤٠٢)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٢٢/٣٨٩ (١٤٥١١)، والنسائي في الكبرى ٤/١٩٤ (٤٠٨٦)، ١٠/٣٣٤ (١١٦٠٧)، ١٠/٣٣٥ (١١٦٠٨)، والحاكم ٤/٢٤٥ (٧٥١٧)، وابن جرير ٢٤/٣٤٨، والثعلبي ١٠/١٩٢.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٨/٣٩١: «وهذا إسناد رجاله لا بأس بهم، وعندي أن المتن في رفعه نكارة». وقال ابن رجب في لطائف المعارف (ص ٢٦٨): «وهو إسناد حسن». وقال الزيلعي في تخريج أحاديث الكشاف ٤/٢٠٥ (١٤٨٧): «وهذا سند لا بأس برجاله». وقال الألباني في الضعيفة ٧/١٦٢ (٣١٧٨): «منكر».عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٤/٣٤٥-٣٤٧، كذلك من طريق زرارة أيضًا، والحاكم ٢/٥٢٢، والبيهقي في شعب الإيمان (٣٧٤٥). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٤٥-٣٤٦.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٤٩-٥٠ (١٠٧)، وابن جرير ٢٤/٣٤٦. وعزاه السيوطي إلى عبد الرزاق، وابن سعد، وابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٩٩ (١٩١).عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق في تفسيره ٢/٣٦٩، وفي المصنف (٨١٢٠)، وابن جرير ٢٤/٣٤٧، والبيهقي في شعب الإيمان (٣٧٤٨). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٦٩ بنحوه، والفريابي -كما في تغليق التعليق ٤/٤-، وابن جرير ٢٤/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٦٩، وابن جرير ٢٤/٣٤٧، كذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٤٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٤٧.أخرجه ابن جرير ٢٤/٣٤٧-٣٤٨. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٥.تفسير مقاتل بن سليمان ٤/٦٨٧.أخرجه ابن جرير ٢٤/٣٤٨.أخرجه البخاري ٢/٢٠ (٩٦٩)، والبيهقي في الشعب ٥/٣٠٧ (٣٤٧٣) واللفظ له.أخرجه البيهقي في الشعب ٥/٣١١-٣١٢ (٣٤٨١)، من طريق عبد الله بن محمد بن وهب الدينوري، حدثنا العباس بن الوليد الأزدي، حدثنا يحيى بن عيسى الرملي، حدثنا يحيى بن أيوب البجلي، عن عدي بن ثابت، عن سعيد بن جُبَير، عن ابن عباس به.</p><p>إسناده ضعيف، وفي متنه نكارة؛ ففيه يحيى بن عيسى الرملي، قال عنه ابن حجر في التقريب (٧٦١٩): «صدوق يُخطئ». ومثله لا يحتمل التفرّد، وقد زاد في آخر الحديث زيادات على المحفوظ عند البخاري وغيره! كقوله: «صيام يوم منها يَعدِل بصيام سنة». وقوله: «والعمل فيهن يُضاعف بسبعمائة ضعف».أخرجه أحمد ٩/٣٢٣-٣٢٤ (٥٤٤٦)، ١٠/٢٩٦ (٦١٥٤)، والبيهقي في الشعب ٥/٣٠٨ (٣٤٧٤) واللفظ له.</p><p>قال ابن حجر في الأمالي المطلقة ص١٤: «هذا حديث حسن». وقال البوصيري في إتحاف الخيرة المهرة ٣/١٧٠ (٢٤٦٥): «رواه أبو بكر بن أبي شيبة، وعبد بن حميد، وأبو يعلى، والبيهقي في الشعب بسند صحيح».أخرجه الترمذي ٢/٢٨٤-٢٨٥ (٧٦٨)، وابن ماجه ٢/٦٢٠-٦٢١ (١٧٢٨)، والبيهقي في الشعب ٥/٣١١ (٣٤٨٠) واللفظ له.</p><p>قال البزار ١٤/٢٤٢ (٧٨١٦): «وهذا الحديث لا نعلم رواه عن قتادة إلا النهاس بن قهم، وهو رجل من أهل البصرة ليس به بأس، ولا حدّث به عنه إلا مسعود بن واصل، وهو رجل بصري لا بأس به». وقال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث مسعود بن واصل عن النهاس. وسألتُ محمدًا عن هذا الحديث فلم يعرفه من غير هذا الوجه مثل هذا، قال: وقد رُوي عن قتادة، عن سعيد بن المسيب، عن النبي ﷺ مرسلًا شيء من هذا. وقد تَكلّم يحيى بن سعيد في نهّاس بن قهم من قِبَل حفظه». وقال النووي في خلاصة الأحكام ٢/٨٤٦ (٢٩٩٥): «ضعيف». وقال ابن الجوزي في العلل المتناهية ٢/٧٢ (٩٢٥): «هذا حديث لا يصحّ عن رسول الله ﷺ؛ تفرّد به مسعود بن واصل عن النهاس، فأما مسعود فضعّفه أبو داود الطيالسي، وأما النهاس فيضطرب الحديث، تركه يحيى القطان، وقال يحيى بن معين: ليس بشيء ضعيف. وقال ابن عدي: لا يساوي شيئًا. وقال ابن حبان: لا يجوز الاحتجاج به». وقال ابن رجب في فتح الباري ٩/١٧: «والنهّاس ضعّفوه». وقال الألباني في الضعيفة ١١/٢٤٢ (٥١٤٢): «ضعيف بهذا التمام».أخرجه البيهقي (٣٧٥٣).أخرجه أحمد ٣٧/٢٤ (٢٢٣٣٤)، ٤٤/٦٩ (٢٦٤٦٨)، ٤٥/٣٧٥ (٢٧٣٧٦)، وأبو داود ٤/١٠١ (٢٤٣٧)، والنسائي ٤/٢٠٥ (٢٣٧٢)، ٤/٢٢٠ (٢٤١٧)، ٤/٢٢١ (٢٤١٨).</p><p>قال الزيلعي في نصب الراية ٢/١٥٧: «وهو ضعيف، قال المنذري في مختصره: اختلف فيه على هنيدة، فرُوي كما ذكرنا، وروي عنه، عن حفصة زوج النبي ﷺ، ورُوي عنه، عن أُمّه، عن أُمّ سَلمة، مختصرًا». وقال المناوي في فيض القدير ٥/٢٢٧ (٧٠٧٨): «رمز المصنّف -السيوطي- لحُسنه». وقال الألباني في صحيح أبي داود ٧/١٩٦ (٢١٠٦): «إسناده صحيح».ذكره محمد بن نصر في مختصر قيام الليل ص١٠٣.
  89,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلشَّفۡعِ وَٱلۡوَتۡرِ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٩٤٩<span class="dash">-</span></span> عن عمران بن حصين، أنّ النبي ﷺ سُئِل عن الشفع والوتر. فقال: «<b>هي الصلاة؛ بعضها شفعٌ، وبعضها وترٌ</b>»{1}. (١٥/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٠<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: «<span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، <b>والوتر يوم عرفة، والشَّفع يوم النَّحر</b>»{2}. (١٥/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥١<span class="dash">-</span></span> عن جابر، أنّ رسول الله ﷺ قال: «<b>الشَّفع اليومان، والوتر اليوم الثالث</b>»{3}. (١٥/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٢<span class="dash">-</span></span> عن أبي أيوب، عن النبي ﷺ، أنه سئل عن الشَّفع والوتر. فقال: «<b>يومان وليلة؛ يوم عرفة ويوم النَّحر، والوتر ليلة النَّحر ليلة جَمع</b>»{4}. (١٥/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٣<span class="dash">-</span></span> عن عطية، في قوله: <span class="qpc-hafs">﴿والشَّفْعِ﴾</span> قال: يقول الله: <span class="qpc-hafs">﴿وخَلَقْناكُمْ أزْواجًا﴾</span> [النبأ:٨]، <span class="qpc-hafs">﴿والوَتْرِ﴾</span> قال: الله. قيل: هل تروي هذا عن أحد من أصحاب النبي ﷺ؟ قال: نعم، عن أبي سعيد الخدريّ، عن النبي ﷺ{5}. (١٥/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٥<span class="dash">-</span></span> و<span class="name-1">أبي سعيد الخدريّ</span>: الشَّفع: الخَلْق، قال الله تعالى: <span class="qpc-hafs">﴿وخَلَقْناكُمْ أزْواجًا﴾</span> [النبأ:٨]، والوتر: هو الله ﷿{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٦<span class="dash">-</span></span> عن <span class="name-1">عمران بن حصين</span> -من طريق قتادة- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: الصلاة المكتوبة؛ منها شفعٌ، ومنها وترٌ{7}. (١٥/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: الله وترٌ، وأنتم شفعٌ. ويقال: الشَّفع: صلاة الغداة، والوتر: صلاة المغرب{8}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: الشَّفع: يوم النَّحر، والوتر: يوم عرفة{9}. (١٥/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: كل شيء شفع فهو اثنان، والوتر واحد{10}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية-: <span class="qpc-hafs">﴿الشَّفْعِ﴾</span> صلاة الغداة، <span class="qpc-hafs">﴿والوَتْرِ﴾</span> صلاة المغرب{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: الوتر: آدم، شُفِع بزوجته{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزُّبير</span> -من طريق محمد بن المرتفع- أنه سئل عن الشَّفع والوتر. فقال: الشَّفع: قول الله: <span class="qpc-hafs">﴿فَمَن تَعَجَّلَ فِي يَوْمَيْنِ فَلا إثْمَ عَلَيْهِ﴾</span> [البقرة:٢٠٣]، والوتر: اليوم الثالث. وفي لفظ: الشَّفع: أوسط التشريق، والوتر: آخر أيام التشريق{13}. (١٥/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span>، <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: ذلك صلاة المغرب؛ الشَّفع الركعتان، والوتر الركعة الثالثة{14}. (١٥/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-، مثله{15}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٥<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>، قال: الشَّفع: الزوج، والوتر: الفرد{16}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق معمر، عن ابن أبي نجيح- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: الخَلْق كلّه شفعٌ ووتر، فأَقسم بالخَلْق{17}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span> قال: كلّ خَلْق الله شفعٌ؛ السماء والأرض، والبَرّ والبحر، والإنس والجن، والشمس والقمر، ونحو هذا شفعٌ، والوتر الله وحده{18}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿والشفع والوتر﴾</span>، قال: الشَّفع: الزوج، والوتر: الله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: الله الوتر، وخَلْقه الشَّفع؛ الذَّكَر والأنثى{20}. (١٥/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: الشَّفع: آدم وحواء، والوتر: الله{10}. (١٥/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي سنان- قال: <span class="qpc-hafs">﴿ولَيالٍ عَشْرٍ والشَّفْعِ والوَتْرِ﴾</span>، الشَّفع: يوم النَّحر، والوتر: يوم عرفة، أقسم بهما ربّهما لفضْلهما على العَشر{22}. (١٥/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق إسماعيل بن شروس- قال: عرفة وترٌ، ويوم النَّحر شفعٌ؛ عرفة يوم التاسع، والنَّحر يوم العاشر{23}. (١٥/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: أقسم ربّنا بالعدد كلّه؛ الشَّفع منه والوتر{10}. (١٥/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق معمر-: الخَلْق كلّه شفعٌ ووترٌ{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٥<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق واصل بن السّائِب- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: هي أيام النُّسك؛ عرفة والأضحى هما الشَّفع، وليلة الأضحى هي الوتر{26}. (١٥/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق عبد الملك بن أبي سليمان- قال الله -تبارك وتعالى-: الوتر والشَّفع{27}: خَلْقُه{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: خَلَق الله مِن كلّ زوجين اثنين، والله وترٌ واحد صمد.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٨<span class="dash">-</span></span> قال إسماعيل: فذكرتُ ذلك للشعبي، فقال: كان <span class="name-2">مسروق</span> يقول ذلك{29}. (١٥/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، قال: إنّ من الصلاة شفعًا، وإنّ منها وترًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٠<span class="dash">-</span></span> قال: وقال <span class="name-2">الحسن</span>: هو العدد؛ منه شفعٌ، ومنه وترٌ{30}. (١٥/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span> الشَّفع: الخَلْق، والوتر: الله تعالى{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span> الزوج والفرد{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿والشفع والوتر﴾</span>، قال: الزوج والفرد{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الرحمن بن زيد- <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>: كلّ شيء خَلَق الله شفعٌ ووترٌ، فأَقسم بما خَلَق، وأَقسم بما تُبصِرون وبما لا تُبصِرون{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والشَّفْعِ والوَتْرِ﴾</span>، أمّا الشَّفع: فهو آدم وحواء ﵉، وأمّا الوتر: فهو الله ﷿{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿الشَّفْعِ﴾</span> الأيام والليالي، و<span class="qpc-hafs">﴿والوَتْرِ﴾</span> اليوم الذي لا ليلة بعده، وهو يوم القيامة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق عبد الجبّار بن العلاء العطّار- يقول: الوتر هو الله ﷿، وهو الشَّفع أيضًا؛ لقوله: <span class="qpc-hafs">﴿ما يَكُونُ مِن نَجْوى ثَلاثَةٍ إلّا هُوَ رابِعُهُمْ﴾</span> [المجادلة:٧]{37}<span class=comment-ref>٧١٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٣</span> اختُلف في معنى: «الشَّفع والوتر» على أقوال: <b>الأول:</b> الشَّفع: يوم النَّحر، والوتر: يوم عرفة. <b>الثاني:</b> الشَّفع: اليومان بعد يوم النحر، والوتر: اليوم الثالث. <b>الثالث:</b> الشَّفع: الخَلْق كلّه، والوتر: الله. <b>الرابع:</b> الشَّفع والوتر: الخَلْق كلّه. <b>الخامس:</b> الصلاة المكتوبة؛ منها الشَّفع، ومنها الوتر. <b>السادس:</b> العدد؛ منه الشَّفع، ومنه الوتر. <b>السابع:</b> الشَّفع الركعتان من المغرب، والوتر الركعة الثالثة. <b>الثامن:</b> الشَّفع الأيام والليالي، والوتر يوم القيامة لأنه لا ليل بعده. <b>التاسع:</b> الشَّفع آدم وحواء ﵉، والوتر الله ﷿.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٣٥٥) <span class="mustanad">العموم</span>، فقال: «إنّ الله -تعالى ذِكْره- أقسم بالشَّفع والوتر، ولم يَخْصُص نوعًا من الشَّفع ولا من الوتر دون نوعٍ بخبرٍ ولا عقلٍ، فكلّ شفعٍ ووترٍ فهو مما أقسم به مما قال أهل التأويل إنه داخلٌ في قَسَمه هذا؛ لعموم قَسَمه بذلك».</p><p>و<span class="comment-type-4">زاد</span> <u>ابنُ عطية</u> (٨/٦٠٥-٦٠٦) أقوالًا أخرى نقلها عن آخرين، فقال: «وقيل: الشَّفع: الصفا والمروة، والوتر: البيت. وقال الحسين بن الفضل: الشَّفع: أبواب الجنة لأنها ثمانية أبواب، والوتر: أبواب النار لأنها سبعة أبواب. وقال مقاتل: الشفع: الأيام والليالي، والوتر:يوم القيامة؛ لأنه لا ليل بعده. وقال أبو بكر الوَرّاق: الشَّفع: تضاد أوصاف المخلوقين كالعِزِّ والذُّل ونحوه، والوتر: اتحاد صفات الله تعالى، عِزٌّ محض وكرمٌ محض، ونحوه. وقيل: الشَّفع: قِرانُ الحج والعمرة، والوتر: الإفراد بالحج ... وقال بعض المفسرين: الشَّفع: حواء، والوتر: آدم ﵉ ... وقال بعض العلماء: الشَّفع: تنفُّلُ الليل مثنى مثنى، والوتر: الركعة الأخيرة المعروفة».</div></p></div>",footnotes:1:أخرجه أحمد ٣٣/١٤٨ (١٩٩١٩)، ٣٣/١٦٠-١٦١ (١٩٩٣٥)، ٣٣/١٨٤ (١٩٩٧٣)، والترمذي ٥/٥٣٤ (٣٦٣٦)، والحاكم ٢/٥٦٨ (٣٩٢٨)، وابن جرير ٢٤/٣٥٤، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٩٣-.</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث قتادة». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن كثير: «عندي أنّ وقفه على عمران بن حصين أشبه». وقال ابن حجر في الفتح ٨/٧٠٢: «ورجاله ثقات، إلا أنّ فيه راويًا مُبهمًا، وقد أخرجه الحاكم من هذا الوجه، فسقط من روايته المبهم، فاغترّ فصحّحه». وقال الشوكاني في فتح القدير ٥/٥٣٢: «وفي إسناده رجل مجهول، وهو الراوي له عن عمران بن حصين».أخرجه أحمد ٢٢/٣٨٩ (١٤٥١١)، والنسائي في الكبرى ٤/١٩٤ (٤٠٨٦)، ١٠/٣٣٤ (١١٦٠٧)، ١٠/٣٣٥ (١١٦٠٨)، والحاكم ٤/٢٤٥ (٧٥١٧)، والثعلبي ١٠/١٩٢.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٨/٣٩١: «وهذا إسناد رجاله لا بأس بهم، وعندي أنّ المتن في رفعه نكارة». وقال ابن رجب في لطائف المعارف (ص٢٦٨): «وهو إسناد حسن». وقال الزيلعي في تخريج أحاديث الكشاف ٤/٢٠٥ (١٤٨٧): «وهذا سند لا بأس برجاله». وقال الألباني في الضعيفة ٧/١٦٢ (٣١٧٨): «منكر».أخرجه ابن جرير ٢٤/٣٥٥.</p><p>قال ابن كثير في تفسيره ٨/٣٩٢: «هكذا ورد هذا الخبر بهذا اللفظ، وهو مخالف لما تقدّم من اللفظ في رواية أحمد، والنسائي، وابن أبي حاتم». يعني: حديث: «الوتر يوم عرفة، والشَّفع يوم النَّحر»، وقد تقدّم قريبًا.أخرجه الطبراني ٤/١٨٠ (٤٠٧٣).</p><p>قال الهيثمي في المجمع ٧/١٣٧ (١١٤٩١): «رواه الطبراني في حديث طويل، وفيه واصل بن السّائِب، وهو متروك». وقال السيوطي: «بسند ضعيف».عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٨/٤١٦.أخرجه عبد الرزاق ٢/٣٧٠، وابن جرير ٢٤/٣٥٣.أخرجه ابن جرير ٢٤/٣٥١.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٢٦- من طريق أبي نصر، وابن جرير ٢٤/٣٤٩، ومن طريق زرارة أيضًا، والبيهقي في شعب الإيمان (٣٧٤٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٩٣، وتفسير البغوي ٨/٤١٦.أخرجه الفراء في معاني القرآن ٣/٢٦٠.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٤٩-٥٠ (١٠٧)، وسعيد بن منصور -كما في فتح الباري ٨/٧٠٢-، وأخرجه ابن جرير ٢٤/٣٥٠، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤١٣-. وعزاه السيوطي إلى عبد الرزاق، وابن سعد، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٥٣. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٦٩.تفسير مجاهد ص٧٢٦، وأخرجه الفريابي -كما في التغليق ٤/٤-، وابن جرير ٢٤/٣٥١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٥٢ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤١٤-، كما أخرج نحوه عبد الرزاق في مصنفه ٥/٤٩ (٩٨٠٣) من طريق ابن جُرَيْج.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم. وعند ابن جرير ٢٤/٣٥٢ من طريق جابر بلفظ: الله، وما خَلَق الله من شيء فهو شفعٌ.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٤٩-٣٥٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٧٠، وابن جرير ٢٤/٣٥٠ من طريق قتادة، وعبيد الله، وعاصم، وسفيان عن أبيه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٧٠، وابن جرير ٢٤/٣٥٢، ٣٥٥، كذلك من طريق قتادة أيضًا بنحوه.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤١٣-. وعزاه السيوطي إلى عبد بن حميد.قال المحقق: «كذا في النسخ بتقديم الوتر، كأنه لا يريد التلاوة». ويظهر أن قراءتها هكذا: قال: «اللهُ -تبارك وتعالى- الوترُ، والشَّفعُ خَلْقُه».أخرجه الفراء في معاني القرآن ٣/٢٥٩.أخرجه ابن جرير ٢٤/٣٥١ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٥٤. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٦-.تفسير الثعلبي ١٠/١٩٣.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٦.أخرجه ابن جرير ٢٤/٣٥٢-٣٥٣.تفسير مقاتل بن سليمان ٤/٦٨٧.تفسير الثعلبي ١٠/١٩٣، وتفسير البغوي ٨/٤١٦.أخرجه الثعلبي ١٠/١٩٣.
  89,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّیۡلِ إِذَا یَسۡرِ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٩٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: إذا ذهب{1}<span class=comment-ref>٧١٥٤</span>. (١٥/٤٠٧)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٤</span> ذكر <u>ابنُ عطية</u> (٨/٦٠٦) أنّ «سُرى الليل: ذهابه وانقراضه، هذا قول الجمهور». ثم نقل عن ابن قُتيبة، والأخفش وغيرهما أنّ المعنى: «إذا يُسرى فيه». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فيخرج هذا الكلام مخرج: ليل نائم، ونهار صائم».</div></p><p><div></p><p><p><span class="item-no">٨٢٩٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزُّبير</span> -من طريق محمد بن المرتفع- <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: حتى يُذهِب بعضُه بعضًا{2}. (١٥/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span>، <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، يقول: إذا أقبل{3}. (١٥/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩١<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق الربيع- <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: والليل إذا سار{1}<span class=comment-ref>٧١٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٥</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/٣٤٢) على قول أبي العالية وما في معناه بقوله: «وهذا يمكن حمْله على ما قال ابن عباس، أي: ذهب. و<b>يحتمل</b> أن يكون المراد: إذا سار، أي: أقبل. وقد يقال: إنّ هذا أنسب؛ لأنه في مقابلة قوله: <span class="qpc-hafs">﴿والفَجْرِ﴾</span>، فإنّ الفجر هو إقبال النهار وإدبار الليل، فإذا حمل قوله: <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span> على إقباله كان قَسمًا بإقبال الليل وإدبار النهار، وبالعكس، <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿واللَّيْلِ إذا عَسْعَسَ والصُّبْحِ إذا تَنَفَّسَ﴾</span> [التكوير:١٧-١٨]».</div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٣<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span> هي ليلة المُزدلفة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: إذا سار{6}. (١٥/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: يجري{7}. (١٥/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: ليلة جَمع{3}. (١٥/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: ليلة جَمع. قال: وكانوا يقولون: سرى الليلُ بجَمع فمضى. يعني: مضى الليل والناس بجَمع. قال <span class="name-2">عكرمة</span>: هذا القَسم في أيام العشر كلّه{9}. (١٥/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: إذا سار{10}. (١٥/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٩٩٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق كثير بن عبد الله بن عمرو- أنه قيل له: ما <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>؟ قال: هذه الإفاضة، اسْرِ، يا ساري، ولا تَبِيتنّ إلا بجَمع{11}. (١٥/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، يعني: إذا أقبل، وهي ليلة الأضحى، فأَقسم الله بيوم النَّحر، والعشر، وبآدم وحواء، وأَقسم بنفسه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿واللَّيْلِ إذا يَسْرِ﴾</span>، قال: الليل إذا يسير{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٥٧.أخرجه ابن جرير ٢٤/٣٥٦. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٥٧.تفسير الثعلبي ١٠/١٩٤، وتفسير البغوي ٨/٤١٧.أخرجه ابن جرير ٢٤/٣٥٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٥٧-٣٥٨ مختصرًا، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤١٦-. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه عبد الرزاق ٢/٣٧٠، وابن جرير ٢٤/٣٥٧ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤١٦-.تفسير مقاتل بن سليمان ٤/٦٨٧.أخرجه ابن جرير ٢٤/٣٥٧.
  89,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ فِی ذَ ٰ⁠لِكَ قَسَمࣱ لِّذِی حِجۡرٍ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٠٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي نصر- في قوله: <span class="qpc-hafs">﴿قَسَمٌ لِذِي حِجْرٍ﴾</span>، قال: لذي حِجًا وعقل ونُهى{1}<span class=comment-ref>٧١٥٦</span>. (١٥/٤٠٨)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٦</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٣٦٠) في معنى: <span class="qpc-hafs">﴿لِذِي حِجْرٍ﴾</span> سوى قول ابن عباس من طريق أبي نصر، وما في معناه.</div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لِذِي حِجْرٍ﴾</span>، قال: لذي عَقْل{2}. (١٥/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عاصم-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٥<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر-، مثله{3}. (١٥/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٧<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>، مثله{4}. (١٥/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿لِذِي حِجْرٍ﴾</span>، قال: سِتْر من الناس{5}. (١٥/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٠٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿لِذِي حِجْرٍ﴾</span>، قال: لذي حِلم{6}. (١٥/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لِذِي حِجْرٍ﴾</span>، قال: لذي لُبٍّ، قال الحارث بن ثعلبة:</p><p>وكيف رجائي أنْ أتوب وإنما يُرجّى مِن الفتيان مَن كان ذا حِجر{7}. (١٥/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿قسم لذي حجر﴾</span>، قال: لذي نُهى، وحِلم، وحياء{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ فِي ذلِكَ قَسَمٌ لِذِي حِجْرٍ﴾</span>، يعني: إنّ في ذلك القَسم كفاية لذي اللُّبّ، يعني: ذا عقل، فيعرف عِظَم هذا القَسم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هَلْ فِي ذَلِكَ قَسَمٌ لِذِي حِجْرٍ﴾</span>، قال: لذي عقل. وقرأ: <span class="qpc-hafs">﴿لِقَوْمٍ يَعْقِلُونَ﴾</span> [البقرة:١٦٤]، و<span class="qpc-hafs">﴿لِأُولِي الأَلْبابِ﴾</span> [آل عمران:١٩٠]، وهم الذين عاتبهم الله. وقال: العقل واللُّبّ واحد، إلا أنه يفترق في كلام العرب{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ٨/٤٨٨، وابن جرير ٢٤/٣٥٩، كذلك من طريق أبي ظَبْيان، عن أبيه، وعلي، وعطية بنحوه، والبيهقي في شعب الإيمان (٣٧٤٥). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ٨/٤٨٩، والبيهقي (٤٦٥٢)، وابن جرير ٢٤/٣٥٩ -٣٦٠ من طريق هلال، وأبي يحيى أيضًا. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة ٨/٤٨٩. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٣٧٠، وابن جرير ٢٤/٣٦٠ عن قتادة.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٦٠، وكذلك من طريق قتادة، وعبد الرزاق ٢/٣٧٠ من طريق معمر بلفظ: لذي لب. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٥.تفسير مقاتل بن سليمان ٤/٦٨٧.أخرجه ابن جرير ٢٤/٣٦٠.
  89,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ تَرَ كَیۡفَ فَعَلَ رَبُّكَ بِعَادٍ ۝٦ إِرَمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٠١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ألَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعادٍ إرَمَ﴾</span>، قال: يعني بالإرَم: الهالك، ألا تَرى أنك تقول: أرِم بنو فلان{1}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مكحول- قال: ... ومَن أراد أن ينظر إلى إرَم فليأتِ نهرًا في حفر دمشق يقال له: برَدى ...{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٦<span class="dash">-</span></span> عن <span class="name-2">خالد بن معدان</span>، في قول الله تعالى: <span class="qpc-hafs">﴿لم يخلق مثلها في البلاد﴾</span> [الفجر:٨]، قال: يعني: دمشق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بِعادٍ إرَمَ﴾</span>، قال: القديمة{4}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- في قوله: <span class="qpc-hafs">﴿إرَمَ﴾</span>، قال: أُمّة{5}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: <span class="qpc-hafs">﴿إرَم﴾</span> هي دمشق{6}. (١٥/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span> -من طريق محمد بن إسحاق، عمن يخبره-، مثله{7}. (١٥/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن أبي سعيد المقبريّ</span> -من طريق ابن أبي ذئب-، مثله{8}. (١٥/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٢<span class="dash">-</span></span> عن <span class="name-3">خالد الربعي</span>، مثله{9}. (١٥/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: الإرَم: الهلاك، ألا تَرى أنه يقال: أرِم بنو فلان، أي: هلكوا{10}. (١٥/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٤<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span>، (أرَمَّ)، قال: رمّهم رمًّا فجعلهم رِممًا{11}. (١٥/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: كُنّا نُحدَّث أنّ إرَم قبيلة من عاد، كان يقال لهم: ذات العماد، كانوا أهل عمود{12}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- قال: <span class="qpc-hafs">﴿إرَمَ ذاتِ العِمادِ﴾</span> إرَم هي الإسكندرية{13}. (١٥/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿بِعادٍ إرَمَ﴾</span>، قال: عاد بن إرَم، نَسبَهم إلى أبيهم الأكبر{14}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿إرَمَ﴾</span> هو الذي يجتمع إليه نَسب عاد وثمود وأهل الجزيرة، كان يقال: عاد إرَم، وثمود إرَم، فأهلك الله عادًا ثم ثمود، وبقي أهل السواد والجزيرة، وكانوا أهل عمد وخيام وماشية سيّارة في الربيع، فإذا هاج العود رجعوا إلى منازلهم، وكانوا أهل جنان وزروع، ومنازلهم بوادي القرى{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعادٍ﴾</span> يعني: بقوم هود، وإنما سمّاهم: قوم هود؛ لأنّ أباهم كان اسمه ابن سمل بن لملك بن سام بن نوح، مثل ما تقول العرب: ربيعة، ومُضر، وخُزاعة، وسليم، وكذلك عاد وثمود إرَم، وهي قبيلة من قبائلهم اسمها: إرَم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿ألَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعادٍ إرَمَ﴾</span>: يقول الله: <span class="qpc-hafs">﴿بِعادٍ إرَمَ﴾</span>، أي: إنّ عاد بن إرَم بن عوص بن سام بن نوح{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣١<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span> -من طريق أشهب بن عبد العزيز- قال: يقال: إنّ <span class="qpc-hafs">﴿إرم ذات العماد﴾</span> دمشق{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿إرَمَ ذاتِ العِمادِ﴾</span>، قال: هي عاد{19}<span class=comment-ref>٧١٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٧</span> اختُلف في معنى: <span class="qpc-hafs">﴿إرَمَ﴾</span> على أقوال: <b>الأول:</b> أنها اسم بلدة، واختُلف في تعيينها على قولين: أحدهما: الإسكندرية. ثانيهما: دمشق. <b>الثاني:</b> عُنِيَ بها: أُمّة. <b>الثالث:</b> القديمة. <b>الرابع:</b> أنها قبيلة من عاد. <b>الخامس:</b> هو جَدُّ عادٍ. <b>السادس:</b> الهالك.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/٣٤٣) على القول الرابع -وهو قول قتادة، والسُّدِّيّ- بقوله: «وهذا قول حسن جيد قوي».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٤/٣٦٤) -<span class="mustanad">مستندًا إلى اللغة</span>- أنّ الصواب «أن يقال: إنّ إرَم إمّا اسم بلدةٍ كانت عاد تسكنها، فلذلك رُدَّتْ على عادَ على الإتباع لها، ولم تُجْرَ مِن أجل ذلك، وإمّا اسم قبيلة فلم تُجْرَ أيضًا كما لا تُجْرى أسماء القبائل كتميم وبكر وما أشبه ذلك إذا أرادوا به قبيلةً».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ كثير</u> (١٤/٣٤٥) -<span class="mustanad">مستندًا إلى السياق</span>- قائلًا: «وقول ابن جرير: يحتمل أن يكون المراد بقوله: <span class="qpc-hafs">﴿إرم﴾</span> قبيلة أو بلدة كانت عاد تسكنها فلذلك لم تُصرف. فيه نظر؛ لأنّ المراد من السياق إنما هو الإخبار عن القبيلة، ولهذا قال بعده: <span class="qpc-hafs">﴿وثَمُودَ الذيْنَ جابُوا الصَّخْرَ بِالوادِ﴾</span>، يعني: يقطعون الصخر بالوادي».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> -<span class="mustanad">مستندًا إلى القراءات</span>- القول الرابع، وهو قول قتادة، فقال: «وأشبه الأقوال فيه بالصواب عندي: أنها اسمُ قبيلةٍ من عاد، ولذلك جاءت القراءة بتَرْك إضافة عاد إليها، وتَرْكِ إجرائها، كما يقال: ألم تَر ما فعل ربّك بتميم نهشل. فتُرِك نهشل -وهي قبيلةٌ- فتُرِك إجراؤها لذلك، وهي في موضع خفضٍ بالرَّد على تميمَ، ولو كانت»إرم«اسمَ بلدة أو اسمَ جدٍّ لعادٍ لجاءت القراءة بإضافة عادَ إليها، كما يقال: هذا عمرو زبيد، وحاتم طيئ، وأعشى هَمْدان، ولكنها اسم قبيلةٍ منها فيما أرى كما قال قتادة، والله أعلم، فلذلك أجمعت القرأة فيها على ترك الإضافة وترك الإجراء».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٢٤/٣٦٤) القول الثالث -وهو قول مجاهد- -<span class="mustanad">مستندًا إلى اللغة</span>- بأنه «قولٌ لا معنى له؛ لأنّ ذلك لو كان معناه لكان مخفوضًا بالتنوين، وفي تَرْك الإجراء الدليل على أنه ليس بنعتٍ ولا صفةٍ».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٨/٦٠٧) مَن عيَّن البلدة بالإسكندرية أو دمشق قائلًا: «وهذان القولان ضعيفان».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ كثير</u> (١٤/٣٤٤) -<span class="mustanad">مستندًا إلى السياق، والدلالة العقلية</span>- فقال: «ومَن زعم أنّ المراد بقوله: <span class="qpc-hafs">﴿إرم ذات العماد﴾</span> مدينة إمّا دمشق، كما رُوي عن سعيد بن المسيّب، وعكرمة، أو إسكندرية كما روي عن القُرَظيّ أو غيرهما، ففيه نظر، فإنه كيف يلتئم الكلام على هذا: <span class="qpc-hafs">﴿ألَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعادٍ إرَمَ ذاتِ العِمادِ﴾</span> إن جُعل ذلك بدلًا أو عطف بيان، فإنه لا يتسق الكلام حينئذ. ثم المراد إنما هو الإخبار عن إهلاك القبيلة المُسمّاة بعاد، وما أحلّ الله بهم من بأسه الذي لا يُردُّ، لا أنّ المراد الإخبار عن مدينة أو إقليم».</div></p><p><h3><span class="qpc-hafs">﴿ذَاتِ ٱلۡعِمَادِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٠٣٣<span class="dash">-</span></span> عن المقدام بن معدِيكرِب، عن النبي ﷺ، أنه ذكر إرَم ذات العماد، فقال: «<b>كان الرجل منهم يأتي على الصخرة، فيحملها على كاهله، فيُلقيها على أيِّ حيٍّ أراد، فيهلكهم</b>»{20}. (١٥/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span>: يعني: طولهم مثل العماد{21}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span>، قال: أهل عمود، لا يُقيمُون{22}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- في قوله: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span>، قال: كان لها جسم في السماء{23}. (١٥/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد-: (ذاتَ العِمادِ) ذات الشدة والقوة{24}. (١٥/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span> ذات البناء الرفيع{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span>، قال: ذُكر لنا: أنهم كانوا أهل عمود، لا يقيمون؛ سيّارة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٤٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span> وسُمّوا ذات العماد لهذا؛ لأنهم كانوا أهل عمد سيارة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٤١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: كان طول الرجل منهم أربعمائة ذراع{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span> كان طول أحدهم اثني عشر ذراعًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span>، يعني: ذات الأساطين، وهي أساطين الرهبانيين التي تكون في الفيافي والرّمال، فشبّه الله ﷿ طولهم إذ كانوا قيامًا في البريّة بأنه مثل العماد، وكان طول أحدهم ثمانية عشر ذراعًا، ويقال: اثني عشر ذراعًا في السماء، مثل أعظم أسطوانة تكون{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٠٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إرَمَ ذاتِ العِمادِ﴾</span>، قال: عاد قوم هود، بَنَوها وعملوها حين كانوا في الأحقاف{31}<span class=comment-ref>٧١٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٥٨</span> اختُلف في معنى: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span> في هذه الآية على أقوال: <b>الأول:</b> ذات الطُّول، وقالوا: كانوا طوال الأجسام. <b>الثاني:</b> ذات العماد؛ لأنهم كانوا أهل خيام وأعمدة، ينتجعون الغيوث. <b>الثالث:</b> لبناءٍ بناه بعضهم، فشيَّد عمده ورفع بناءه. <b>الرابع:</b> ذات القوة والشدة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٣٦٦-٣٦٧) القول الثاني، وهو قول مجاهد من طريق ابن أبي نجيح، وقول قتادة، ومحمد بن السّائِب الكلبي، و<span class="comment-type-2">انتقد</span> القول الثالث <span class="mustanad">مستندًا إلى الأغلب من لغة العرب</span>، فقال معلِّلًا: «لأنّ المعروف في كلام العرب من العماد: ما عُمِد به الخيام من الخشب، أو السواري التي يُحمَل عليها البناء، ولا يُعلَم بناءٌ كان لهم بالعماد بخبر صحيح، بل وجَّه بعض أهل التأويل قوله: <span class="qpc-hafs">﴿ذاتِ العِمادِ﴾</span> إلى أنه عُنِيَ به طول أجسامهم، وبعضهم إلى أنه عُنِيَ به عمادُ خيامهم، فأمّا عماد البنيان فلا نعلم كبير أحدٍ من أهل التأويل وجَّهَه إليه، وتأويل القرآن إنما يوجَّه إلى الأعرف الأغلب الأشهر من معانيه -ما وُجِد إلى ذلك سبيلٌ- دون الأنكر».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٦٠٨) أنّ مَن «قال:»إرَمَ مدينة«قال: العماد أعمدة الحجارة التي بُنيتْ بها. وقيل: القصور العالية والأبراج، يقال لها: عماد. ومَن قال:»إرَمَ قبيلة«قال: العِمادِ إمّا أعمدة أبْنِيَتِهم، وإمّا أعمدة بيوتهم التي يرحلون بها؛ لأنهم كانوا أهل عمود ينتجعون البلاد. قاله مقاتل وجماعة».</div></p><p><h3><span class="qpc-hafs">﴿ذَاتِ ٱلۡعِمَادِ ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٠٤٥<span class="dash">-</span></span> عن ثور بن زيد الدّيلميِّ، قال: قرأتُ كتابًا: أنا شدادُ بن عاد، أنا الذي رفعتُ العماد، وأنا الذي سدَدْتُ بذراعي بطنَ وادٍ، وأنا الذي كنَزتُ كنزًا في البحر على تسعِ أذرُعٍ لا يُخرِجُه إلا أمة محمد ﷺ{32}. (٦/٤٤٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٦٣.أخرجه ابن عساكر في تاريخ دمشق ٢/٤١١.أخرجه ابن عساكر في تاريخ دمشق ١/٢١٦.تفسير مجاهد ص٥٠٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٦، وفتح الباري ٨/٧٠١-، وابن جرير ٢٤/٣٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٧٠٢-، وابن جرير ٢٤/٣٦٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٧٠٢-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن عساكر ١/٢١٧.أخرجه ابن جرير ٢٤/٣٦١-٣٦٢، وابن عساكر ١/٢١٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٦٤، وابن أبي حاتم -كما في فتح الباري ٨/٧٠٢-. ونقل السيوطي عقب هذا الأثر قول الحافظ ابن حجر: «هذا التفسير على قراءة شاذة (أرَّم) بفتحتين وتشديد الراء، على أنه فعل ماض، و(ذات) بفتح التاء، مفعول، أي: أهلك الله ذات العماد». وينظر: الفتح ٨/٧٠٢.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٧٠٢-.أخرجه عبد الرزاق ٢/٣٧٠، وابن جرير ٢٤/٣٦٢-٣٦٣، ٣٦٦، ومن طريق سعيد أيضًا، وابن أبي حاتم -كما في فتح الباري ٨/٧٠٢- مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٢٥-١٢٦ (٢٤٩)، وابن جرير ٢٤/٣٦١. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٨/٤١٨.تفسير مقاتل بن سليمان ٤/٦٨٧.أخرجه ابن جرير ٢٤/٣٦٣.أخرجه ابن عساكر في تاريخ دمشق ١/٢١٨.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٦٣ (٣٤٤).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٩٥-، والثعلبي ١٠/١٩٦.</p><p>قال الشوكاني في فتح القدير ٥/٥٣٣: «وفي إسناده رجل مجهول؛ لأنّ معاوية بن صالح رواه عمّن حدّثه عن المقدام».أخرجه ابن جرير ٢٤/٣٦٥.تفسير مجاهد ص٥٠٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٦، وفتح الباري ٨/٧٠١-، وابن جرير ٢٤/٣٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٧٠٢-، وابن جرير ٢٤/٣٦٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٣٦٦، وابن أبي حاتم -كما في فتح الباري ٨/٧٠٢-.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٧-.أخرجه ابن جرير ٢٤/٣٦٥.تفسير البغوي ٨/٤١٨.تفسير الثعلبي ١٠/١٩٦.تفسير الثعلبي ١٠/١٩٦، وتفسير البغوي ٨/٤١٨.تفسير مقاتل بن سليمان ٤/٦٨٧-٦٨٨.أخرجه ابن جرير ٢٤/٣٦٦.عزاه السيوطي إلى الزبير بن بكار في الموفَّقِيّات.
