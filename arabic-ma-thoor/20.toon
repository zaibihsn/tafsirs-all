  20,114,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَعَـٰلَى ٱللَّهُ ٱلۡمَلِكُ ٱلۡحَقُّۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتعالى الله﴾</span> يعني: ارتفع الله <span class="qpc-hafs">﴿الملك الحق﴾</span> لأنّ غيرَه ﷿ وما سواه مِن الآلهة باطل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فتعالى الله﴾</span> مِن باب العُلُوِّ: ارتفع <span class="qpc-hafs">﴿الملك الحق﴾</span> والحقُّ اسم من أسماء الله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأ: ‹مِن قَبْلِ أن نَّقْضِيَ إلَيْكَ وحْيَهُ›{3}. (١٠/٤٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٥<span class="dash">-</span></span> عن الحسن البصري، قال: لطَم رجلٌ امرأتَه، فجاءتْ إلى النبيِّ ﷺ تطلب قصاصًا، فجعل النبي ﷺ بينهما القصاص؛ فأنزل الله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه وقل رب زدني علما﴾</span>. فوقف النبي ﷺ حتى نزلت: <span class="qpc-hafs">﴿الرجال قوامون على النساء﴾</span> الآية [النساء:٣٤]{4}. (١٠/٢٤٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٦<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، قال: كان النبيُّ ﷺ إذا نزل عليه جبريلُ بالقرآن أتْعَبَ نفسَه في حفظه حتى يَشُقَّ على نفسه؛ يتخوف أن يصعد جبريل ولم يحفظه؛ فينسى ما علَّمَه، فقال الله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه﴾</span>. وقال: <span class="qpc-hafs">﴿لا تحرك به لسانك لتعجل به﴾</span> [القيامة:١٦]{5}. (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه﴾</span>، يقول: لا تعجل حتى نُبَيِّنه لك{6}. (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن﴾</span>، قال: لا تَتْلُهُ على أحد حتى نُتِمَّه لك{7}. (١٠/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span>: معناه: لا تُقْرِئه أصحابَك، ولا تُمْلِه عليهم حتى يتبين لك معانيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: فرائضه، وحدوده، وأحكامه، وحلاله، وحرامه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿من قبل أن يقضى إليك وحيه﴾</span>، قال: تِبيانه{10}. (١٠/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿من قبل أن يقضى إليك وحيه﴾</span>، يعني: لا تعجل بالقرآن مِن قبل أن ينزل إليك جبريلُ بالوحي{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تعجل بالقرآن﴾</span> وذلك أنّ جبريل ﵇ كان إذا أخبر النبيَّ ﷺ بالوحى لم يفرغ جبريل ﵇ من آخر الكلامِ حتى يتكلم النبيُّ ﷺ بأوله؛ فقال الله ﷿: <span class="qpc-hafs">﴿ولا تعجل﴾</span> بقراءة القرآن <span class="qpc-hafs">﴿من قبل أن يقضى إليك وحيه﴾</span> يقول: مِن قبل أن يُتِمَّه لك جبريل ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: كان النبيُّ ﵇ إذا نزل عليه الوحي يقرأه، ويُدْئِبُ فيه نفسَه مخافةَ أن ينسى؛ فأنزل الله: <span class="qpc-hafs">﴿لا تحرك به لسانك لتعجل به﴾</span> [القيامة:١٦] نحن نحفظه عليك فلا تنسى. قال الله: <span class="qpc-hafs">﴿إلا ما شاء الله﴾</span>، وهو قوله: <span class="qpc-hafs">﴿سنقرئك فلا تنسى (٦) إلا ما شاء الله﴾</span> [الأعلى:٦-٧]، وهو قوله: <span class="qpc-hafs">﴿ما ننسخ من آية أو ننسها﴾</span> [البقرة:١٠٦] يُنسِها نبيَّه. قال: <span class="qpc-hafs">﴿فإذا قرأناه فاتبع قرءانه﴾</span> [القيامة:١٨] فرائضه، وحدوده، والعمل به{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ زِدۡنِی عِلۡمࣰا ۝١١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقل رب زدني علما﴾</span>، يعني: قرآنًا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ زِدۡنِی عِلۡمࣰا ۝١١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٢٧<span class="dash">-</span></span> عن أبي هريرة، قال: كان رسولُ الله ﷺ يقول: «<b>اللَّهُمَّ، انفعني بما علَّمْتَني، وعلِّمني ما ينفعني، وزِدْني عِلْمًا، والحمدُ لله على كل حال</b>»{15}. (١٠/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنّه كان يدعو: اللَّهُمَّ، زِدني إيمانًا، وفِقْهًا، ويقينًا، وعِلْمًا{16}. (١٠/٢٤٧)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٣.تفسير يحيى بن سلّام ١/٢٨٢.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مِن قَبْلِ أن يُقْضى إلَيْكَ وحْيُهُ﴾</span> بالياء مضمومة في <span class="qpc-hafs">﴿يقضى﴾</span> ورفع <span class="qpc-hafs">﴿وحيه﴾</span>. انظر: النشر ٢/٣٢٢، والإتحاف ص٣٨٩.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/١٨٩ (٢٨٠٦٤)، وأبو داود في المراسيل ١/٢٢١ مختصرًا، وابن جرير ٦/٦٨٨، وابن المنذر ٢/٦٨٥، وابن أبي حاتم ٣/٩٤٠، كلهم عن الحسن البصري مرسلًا. وعزاه السيوطي إلى الفريابي، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/١٨٠. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٦/١٨٠. وعلَّقه يحيى بن سلّام ١/٢٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٢٦٢، وتفسير البغوي ٥/٢٩٧.علَّقه يحيى بن سلّام ١/٢٨٣.أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٨١، ويحيى بن سلّام ١/٢٨٢ من طريق سعيد بلفظ: بيانه. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ١/٢٨٣.تفسير مقاتل بن سليمان ٣/٤٣.تفسير يحيى بن سلّام ١/٢٨٣.تفسير مقاتل بن سليمان ٣/٤٣.أخرجه الترمذي ٦/١٩٠-١٩١ (٣٩١٦)، وابن ماجه ١/١٦٨-١٦٩ (٢٥١)، ٥/٩ (٣٨٣٣).</p><p>قال الترمذي: «هذا حديث غريب مِن هذا الوجه». وقال البغوي في شرح السنة ٥/١٧٣ (١٣٧٢): «هذا حديث غريب». وقال المناوي في فيض القدير ٢/١٣٤ (١٥٠٦): «وفيه موسى بن عبيدة، عن محمد بن ثابت، عن الزهري، وموسى ضعّفه النسائيُّ وغيرُه، ومحمد بن ثابت لم يروه عنه غير موسى، قال الذهبي: مجهول». وقال ابن حجر في بلوغ المرام ٢/٢٣١ (١٥٦٦): «وإسناده حسن». وقال الألباني في الضعيفة ٧/٤٢٩: «وهذا إسناد ضعيف؛ موسى بن عُبيدة ضعّفه الجمهور».عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.
  20,115,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ عَهِدۡنَاۤ إِلَىٰۤ ءَادَمَ مِن قَبۡلُ فَنَسِیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قال: إنّما سمي: الإنسان؛ لأنّه عُهِد إليه فنسي{1}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم﴾</span> قال: ألا يقرب الشجرة، <span class="qpc-hafs">﴿فنسي﴾</span> فترك عهدي{2}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فنسي﴾</span>، قال: فترك{3}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله تعالى: <span class="qpc-hafs">﴿فنسي﴾</span>، قال: تَرَك أمرَ الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فنسي﴾</span>، قال: ترك ما قَدمَ إليه، ولو كان منه نسيانٌ ما كان عليه شيء؛ لأنّ الله قد وضع عن المؤمنين النسيان والخطأ، ولكن آدم ترك ما قَدمَ إليه مِن أكل الشجرة{5}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٤<span class="dash">-</span></span> عن ابن أبي عمر، قال: حدثنا سفيان [بن عيينة]، عن هشام أو غيره، عن <span class="name-2">الحسن [البصري]</span>، قال: حَلَف الحسنُ ما مال إليها أحد -يعني: الدنيا-؛ أصحابُ النبيِّ ﷺ فمَن سواهـ[ـم] إلا سقطوا، ونسوا العهد. ثم قرأ سفيان: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل﴾</span> محمد ﷺ ألّا يأكلَ مِن الشجرة، <span class="qpc-hafs">﴿فنسي﴾</span> يقول: فترك آدمُ العهد. كقوله: <span class="qpc-hafs">﴿وإله موسى فنسي﴾</span> [طه:٨٨]، يقول: ترك، وكقوله سبحانه: <span class="qpc-hafs">﴿إنا نسيناكم﴾</span> [السجدة:١٤]، يقول: تركناكم، وكقوله: <span class="qpc-hafs">﴿فنسوا حظا﴾</span> [المائدة:١٤]، يعني: تركوا. فلمّا نسِي العهدَ سُمي: الإنسان، فأكل منها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي ولم نجد له عزما﴾</span>، قال: قال له: <span class="qpc-hafs">﴿يا آدم إن هذا عدو لك ولزوجك فلا يخرجنكما من الجنة فتشقى﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿لا تظمأ فيها ولا تضحى﴾</span>، وقرأ حتى بلغ: <span class="qpc-hafs">﴿وملك لا يبلى﴾</span>، قال: فنسي ما عَهِد إليه في ذلك. قال: وهذا عَهْد الله إليه. قال: ولو كان له عَزْمٌ ما أطاع عَدُوَّه الذي حَسَدَه، وأبى أن يسجد له مَعَ من سجد له؛ إبليس، وعصى اللهَ الذي كَرَّمه وشَرَّفه، وأمر ملائكته فسجدوا له{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي﴾</span>، يعني: فترك العهد. يقول: فترك ما أمر به ألا يأكل من الشجرة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ نَجِدۡ لَهُۥ عَزۡمࣰا ۝١١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، يريد: صبرًا على أكل الشجرة{10}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، يقول: لم نجعل له عزمًا{3}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: حِفْظًا{12}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤١<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة الباهلي</span> -من طريق لقمان بن عامر- قال: لو أنّ أحلام بني آدم جُمِعَتْ منذ يوم خُلِق آدم إلى أن تقوم الساعة، فوُضِعت في كفة، وحلم آدم في كفة؛ لرجح حلمه بأحلامهم، قال الله: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، قال: حِفظًا{13}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٢<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: عزيمة الصَّبْر{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: حِفْظًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مزاحم</span>: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>: صَرِيمة أمره{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لم نجد له صبرًا عما نُهِي عنه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٦<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق ابن إدريس عن أبيه وعمرو بن قيس- <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: حِفْظًا لِما أُمِر به{18}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٧<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: رَأْيًا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: صَبْرًا{20}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، يعني: صَبْرًا عن أكلِها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فنسي ولم نجد له عزما﴾</span>، قال: حِفْظًا{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: العزم: المحافظة على ما أمر اللهُ ﷿، والتَّمَسُّكُ به{23}<span class=comment-ref>٤٣١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٥</span> أفادت الآثار اختلاف المفسرين في معنى: «العزم»؛ <b>فقيل:</b> معناه: الصبر. <b>وقيل:</b> معناه: الحفظ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/١٨٥) <span class="mustanad">مستندًا إلى لغة العرب</span> أنّ كِلا القولين يَصْدُق عليه لفظ «العزم»، فقال مبيِّنًا ذلك: «وأصل العزم: اعتقاد القلب على الشيء، يُقال مِنه: عزم فلانٌ على كذا: إذا اعتَقَد عليه ونواه. ومِن اعتقاد القلب: حفظُ الشيء، ومنه: الصبرُ على الشيء؛ لأنه لا يَجْزَع جازعٌ إلا مِن خَوَرِ قلبه وضعفه. فإذ كان ذلك كذلك فلا معنى لذلك أبلغ مما بيَّنه الله -تعالى ذِكْره-، وهو قوله: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، فيكون تأويله: ولم نجد له عزم قلبٍ على الصبر على الوفاء لله بعهده، ولا على حفظ ما عهد إليه».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/١٣٨) على هذين القولين بقوله: «وعبَّر بعضُ المفسرين عن العزم هنا بالصبر والحفظ وغير ذلك مما هو أعمُّ مِن حقيقة العزم».</div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ نَجِدۡ لَهُۥ عَزۡمࣰا ۝١١٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٥٢<span class="dash">-</span></span> عن ابن عباس أنّه قال <span class="name-1">لعمر بن الخطاب</span>: يا أمير المؤمنين، مِمَّ يَذْكُرُ الرجلُ، ومِمَّ ينسى؟ فقال: إن علا القلبَ طَخاءةٌ كطَخاءةِ القمر{24}، فإذا تَغَشَّتِ القلبَ نسي ابنُ آدم ما كان يذكر، فإذا تَجَلَّت ذكر ما نسي{25}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: سألت عمر بن الخطاب عن قول الله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا لا تسألوا عن أشياء أن تبد لكم تسؤكم﴾</span> [المائدة:١٠١]. قال: كان رجال من المهاجرين في أنسابهم شيء، فقالوا يومًا: واللهِ، لوددنا أنّ الله أنزل قرآنًا في نسبنا. فأنزل الله ما قرأت. ثم قال لي: إن صاحبكم هذا -يعني: علي بن أبي طالب- إن وُلِّيَ زَهِدَ، ولكني أخشى عُجْبَه بنفسه أن يذهب به. قلت: يا أمير المؤمنين، إنّ صاحبنا مَن قد علِمت، واللهِ، ما نقول: إنه غيَّر ولا بدَّل، ولا أسخط رسولَ الله ﷺ أيام صحبته. فقال: ولا في بنت أبي جهل، وهو يريد أن يَخْطُبَها على فاطمة؟! قلت: قال الله في معصية آدم: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، وصاحبنا لم يعزم على إسخاط رسول الله ﷺ، ولكنه الخواطر التي لم يقدر على دفعها عن نفسه، وربما كانت مِن الفقيه في دين الله العالم بأمر الله، فإذا نُبِّه عليها رجع وأناب. فقال: يا ابن عباس، مَن ظن أنه يَرِدُ بحورَكم فيغوص فيها حتى يبلغ قَعْرَها فقد ظن عجزًا{26}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك بن مُزاحِم- قال: لا تأكلوا بشمائلكم، ولا تشربوا بشمائلكم؛ فإنّ آدم أكل بشماله فنسي، فأورثه ذلك النسيان{27}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٥<span class="dash">-</span></span> عن <span class="name-2">عُبيد بن عُمير</span>، قال: لم يكن آدمُ مِن أُولِي العَزْم{5}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام بن حسان- قال: كان عقل آدم مثل عقل جميع ولده، قال الله: <span class="qpc-hafs">﴿فنسي ولم نجد له عزما﴾</span>{29}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب</span>، قال: لو وُزِن حِلْمُ آدم بحِلْمِ العالمين لَوَزَنَه{30}. (١٠/٢٤٩)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٨٣، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣١٣-، والطبراني في الصغير ٢/٥٥، وابن منده في التوحيد ١/٢١٠، وفي الرد على الجهمية (١٨)، والحاكم ٢/٣٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.أخرجه ابن جرير ١٦/١٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٨٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٧٨.تفسير مقاتل بن سليمان ٣/٤٣.أخرجه ابن جرير ١٦/١٨٢.تفسير يحيى بن سلّام ١/٢٨٣.أخرجه ابن منده في الرد على الجهمية (٢١) من طريق عبد الغني بن سعيد. وعزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.أخرجه ابن جرير ١٦/١٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٨٤، وابن منده في الرد على الجهمية (٢٠).أخرجه ابن جرير ١٦/١٨٥، وابن عساكر ٧/٤٤٤. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن عساكر في تاريخ دمشق ٧/٤٠٠-٤٠١.أخرجه إسحاق البستي في تفسيره ص٢٧٩.كذا في طبعتي تفسير الثعلبي ٦/٢٦٣، ١٨/٦٨، وفي تفسير القرطبي ١١/٢٥٢: عزيمة أمر.تفسير البغوي ٥/٢٩٧.أخرجه ابن جرير ١٦/١٨٣ من طرق. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٢٦٣.أخرجه يحيى بن سلّام ١/٢٨٣، وابن جرير ١٦/١٨٣ من طرق. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣.أخرجه الثوري في تفسيره ص١٩٧.أخرجه ابن جرير ١٦/١٨٤.طَخاءة القمر: هي كلُّ قطعةٍ مستدِيرةٍ تَسُدُّ ضوءَ القمر وتُغَطِّي نُورَهُ. اللسان (طخا).أخرجه الحكيم الترمذي في نوادر الأصول ١/١٦٩.عزاه السيوطي إلى الزبير بن بكار في الموفقيات.أخرجه ابن أبي شيبة ٨/١٠٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو الشيخ في العظمة (١٠٣٢).عزاه السيوطي إلى ابن المنذر.
  20,116,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قُلۡنَا لِلۡمَلَـٰۤىِٕكَةِ ٱسۡجُدُوا۟ لِـَٔادَمَ فَسَجَدُوۤا۟ إِلَّاۤ إِبۡلِیسَ أَبَىٰ ۝١١٦ فَقُلۡنَا یَـٰۤـَٔادَمُ إِنَّ هَـٰذَا عَدُوࣱّ لَّكَ وَلِزَوۡجِكَ فَلَا یُخۡرِجَنَّكُمَا مِنَ ٱلۡجَنَّةِ فَتَشۡقَىٰۤ ۝١١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك- في قوله: <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span>، قال: طَلَبُ المَعاشِ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر بن أبي المغيرة- قال: إنّ آدم ﵇ لَمّا أُهْبِط إلى الأرض استقبله ثَوْرٌ أبْلَق، فقيل له: اعمل عليه. فجعل يمسح العرق عن جبينه، ويقول: هذا ما وعدني ربي: <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span>. ثم نادى حواء: حواء، أنتِ عملتِ بي هذا. فليس أحدٌ مِن بني آدم يعمل على ثورٍ إلا قال: حو. دخلت عليهم مِن قِبَل آدم ﵇{2}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عُمارة بن القَعْقاع- في قوله: <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span>، قال: عَنى به شقاء الدنيا، فلا تلقى ابنَ آدم إلا شقِيًّا ناصِبًا{3}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: الحرث، والزرع، والحصيد، والطَّحن، والخبيز{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذ قلنا﴾</span> يعني: وقد قلنا <span class="qpc-hafs">﴿للملائكة اسجدوا لآدم﴾</span> إذ نفخ فيه الروح، <span class="qpc-hafs">﴿فسجدوا﴾</span>، ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا إبليس﴾</span> لم يسجد فـ<span class="qpc-hafs">﴿أبى﴾</span> أن يسجد، <span class="qpc-hafs">﴿فقلنا يا آدم إن هذا عدو لك ولزوجك﴾</span> حواء؛ <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span> بالعمل بيديك، وكان يأكل مِن الجنة رغدًا مِن غير أن يعمل بيده، فلما أصاب الخطيئة أكل مِن عمل يده، فكان يعمل ويأكل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span>، قال: لم يقل: فتَشْقَيان. لأنها دخلت معه، فوقع المعنى عليهما جميعًا وعلى أولادهما، كقوله: <span class="qpc-hafs">﴿يا أيها النبي إذا طلقتم﴾</span> [الطلاق:١]، و<span class="qpc-hafs">﴿يا أيها النبي لم تحرم ما أحل الله لك﴾</span> ... <span class="qpc-hafs">﴿قد فرض الله لكم تحلة أيمانكم﴾</span> [التحريم:١-٢]، فدخلوا في المعنى معه، وإنما كلَّم النبيَ ﷺ وحدَه{6}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس أبى﴾</span> أن يسجد، <span class="qpc-hafs">﴿فقلنا يا آدم إن هذا عدو لك ولزوجك فلا يخرجنكما من الجنة فتشقى﴾</span> أي: إنكما إذا عصيتما الله أخرجكما مِن الجنة؛ <span class="qpc-hafs">﴿فتشقى﴾</span> في الدنيا، الكدُّ فيها. وقال بعضهم: تأكل مِن عَمَل يديك، وعَرَقِ جبينك{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٧/٤١٢-٤١٣.أخرجه أبو نعيم في الحلية ٤/٢٨٢، وابن عساكر ٧/٤١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١٣/٥٢٨-٥٢٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٢٩٨.تفسير مقاتل بن سليمان ٣/٤٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٨٣-٢٨٤.
