  55,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِنَّ خَیۡرَ ٰ⁠تٌ حِسَانࣱ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٠١<span class="dash">-</span></span> عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿حُورٌ عِينٌ﴾</span> [الواقعة:٢٢]. قال: «<b>حُور: بِيض، عِين: ضخام العيون، شَفر الحوراء بمنزلة جَناح النّسور</b>». وفي لفظ ابن مردويه: «<b>شَفر الجُفون بمنزلة جَناح النّسر</b>». قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿كَأَنَّهُمْ لُؤْلُؤٌ مَكْنُونٌ﴾</span> [الطور:٢٤]. قال: «<b>صفاؤهنّ صفاء الدُّر في الأصداف التي لم تمسّه الأيدي</b>». قلت: يا رسول الله، أخبرِني عن قوله: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>. قال: «<b>خَيْرات الأخلاق، حِسان الوجوه</b>». قلت: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span> [الصافات:٤٩]. قال: «<b>رِقّتهن كرقَّة الجِلدة التي في داخل البيضة مما يلي القشر</b>». قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿عُرُبًا أتْرابًا﴾</span> [الواقعة:٣٧]. قال: «<b>هُنّ اللواتي قُبِضن في دار الدنيا عجائز رُمْصًا{1} شُمْطًا{2}، خلقهنّ الله بعد الكِبر، فجعلهنّ عذارى، عُربًا متعشِّقات مُحبّبات، أترابًا على ميلاد واحد</b>». قلتُ: يا رسول الله، أنساء الدنيا أفضل أم الحُور العين؟ قال: «<b>بل نساء الدنيا أفضل من الحُور العين؛ كفضل الظِّهارَةِ على البِطانة</b>». قلت: يا رسول الله، وبِمَ ذاك؟ قال: «<b>بصلاتهنّ وصيامهنّ وعبادتهنّ الله، ألبس الله وجوههنّ النور، وأجسادهنّ الحرير، بِيض الألوان، خُضر الثياب، صُفر الحلي، مَجامرُهنّ الدُّرّ، وأمشاطهنّ الذهب. يقلن: ألا نحن الخالدات فلا نموت أبدًا، ألا ونحن الناعمات فلا نبأس أبدًا، ألا ونحن المُقيمات فلا نَظْعن أبدًا، ألا ونحن الراضيات فلا نَسخط أبدًا، طُوبى لمن كُنّا له وكان لنا</b>». قلت: يا رسول الله، المرأة منا تتزوج الزوجين والثلاثة والأربعة، ثم تموت، فتدخل الجنة، ويدخلون معها، مَن يكون زوجها؟ قال: «<b>يا أُمّ سلمة، إنها تُخيّر، فتختار أحسنهم خُلقًا، فتقول: أي ربّ، إنّ هذا كان أحسنهم معي خُلقًا في دار الدنيا، فزوّجنيه. يا أُمّ سلمة، ذهب حُسن الخُلق بخير الدنيا والآخرة</b>»{3}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>: في كلّ خيمة زوجة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٣<span class="dash">-</span></span> قال <span class="name-1">جرير بن عبد الله</span>: مختارات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>، قال: النساء{6}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> خيِّرات فاضلات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- قال: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> عذارى الجنة{8}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> خَيرات الأخلاق، حِسان الوجوه{9}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل بن أبي خالد</span>: عذارى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ﴾</span> يعني: في الجنان الأربع <span class="qpc-hafs">﴿حِسانٌ﴾</span> يعني: خَيْرات الأخلاق، حِسان الوجوه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٠<span class="dash">-</span></span> عن <span class="name-3">الأوزاعي</span> -من طريق أبي عصام العسقلاني- <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>، قال: لَسْنَ بذَرِبات اللسان{12}، ولا يغَرْنَ، ولا يؤذين{13}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> الخَيرات الحسان: الحُور العين{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِیهِنَّ خَیۡرَ ٰ⁠تٌ حِسَانࣱ ۝٧٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٦١٢<span class="dash">-</span></span> عن أنس بن مالك، عن النبيِّ ﷺ، قال: «<b>إنّ الحُور العين يتَغنّين في الجنة، يقلن: نحن الخَيرات الحسان، خُبِّئنا لأزواج كرام</b>»{15}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- قال: لكل مسلم خَيْرة{16}، ولكل خَيْرة خيمة، ولكل خيمة أربعة أبواب، يدخل عليها كلّ يوم مِن الله تحفة وكرامة وهديّة لم تكُن قبل ذلك، لا مَرِحات، ولا طمّاحات{17}، ولا بَخِرات{18}، ولا ذفِرات{19}، حُور عِين، كأنهنّ بَيضٌ مكنون{20}. (١٤/١٥٨)</p></p><p></div></p></div>",footnotes:1:الرَّمَصُ: هو البياض الذي تَقْطَعه العين ويجتمع في زوايا الأجفان. النهاية (رمص).الشَّمَطُ: بياضُ شعر الرأس يخالط سواده، ولا يقال للمرأة: شيباء، ولكن شمطاء. لسان العرب (شمط).أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، واللفظ له، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥، من طريق عمرو بن هاشم البيروتي، عن سليمان بن أبي كريمة، عن هشام بن حسان، عن الحسن، عن أمه، عن أم سلمة به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال الطبراني في الأوسط: «لم يروِ هذا الحديثَ عن هشام بن حسان إلا سليمان بن أبي كريمة، تفرّد به عمرو بن هاشم». وقال ابن الجوزي في العلل المتناهية ٢/١٦١ (١٠٧٧): «هذا حديث لا يصِحّ». وقال الضياء المقدسي في صفة الجنة ص١٢٤ (١١٩): «لا أعلمه رُوي إلا من طريق سليمان بن أبي كريمة، وفيه كلام». وقال ابن القيم في حادي الأرواح ص٢٢٩: «تفرد به سليمان بن أبي كريمة، ضعّفه أبو حاتم، وقال ابن عدي: عامة أحاديثه مناكير، ولم أر للمتقدمين فيه كلامًا. ثم ساق هذا الحديث من طريقه، وقال: لا يُعرف إلا بهذا السند». وقال ابن مفلح في الآداب الشرعية ٢/٢٠٧: «في إسناده سليمان بن أبي كريمة، وهو ضعيف». وقال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «فيه سليمان بن أبي كريمة، ضعّفه أبو حاتم، وابن عدي».أخرجه ابن جرير ٢٢/٢٦٢.تفسير الثعلبي ٩/١٩٥.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٩/١٩٤.أخرجه ابن أبي شيبة ١٣/٣٣٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٦٢، كذلك من طريق سعيد، وأبي العوام بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٩٥.تفسير مقاتل بن سليمان ٤/٢٠٥.ذَرِبَة: صخّابة، حديدة، سَلِيطة اللسان، فاحِشَة، طويلة اللسان. وذَرَبُ اللسان: حِدَّتُه. لسان العرب (ذرب).أخرجه ابن المبارك في الزهد (١٥٣٩).أخرجه ابن جرير ٢٢/٢٦٢.أخرجه ابن أبي الدنيا في صفة الجنة ص١٨٦ (٢٤٩)، من طريق إسماعيل بن عمر، عن ابن أبي ذئب، عن ابن عبد الله بن رافع، عن بعض ولد أنس بن مالك، عن أنس بن مالك به.</p><p>وأخرجه ابن أبي شيبة ٧/٣٢ (٣٣٩٨٨)، من طريق شبابة بن سوار، عن ابن أبي ذئب، عمن سمع أنسًا به.</p><p>وسنده ضعيف؛ لجهالة الراوي عن أنس بن مالك.الخَيْرَة: الفاضلة من كل شيء، جمعها الخَيْرات. التاج (خير).امرأة طمّاحة: تَكُرُّ بنظرها يمينًا وشمالًا إلى غير زوجها. لسان العرب (طمح).البَخَر: تَغَيُّر رِيح الفم. النهاية (بخر).الدَّفْر -بالمهملة-: النَّتَن خاصة. وأما بالمعجمة والتحريك: فإنه يعم شدة ذكاء الرائحة؛ طيبة كانت أو خبيثة. التاج (دفر)، (ذفر).أخرجه ابن أبي شيبة ١٣/٣٣٣، وابن أبي الدنيا في صفة الجنة (٣٢٠). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه. وعزاه السيوطي إلى ابن مردويه مرفوعًا أيضًا.
  55,70,""
  55,70,""
  55,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حُورࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦١٤<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>لما أُسري بي دخلتُ الجنة، موضعًا يسمى: البَيْدَخ{1}، عليه خيام اللؤلؤ والزّبَرْجَد الأخضر والياقوت الأحمر، فنُوديتُ: السلام عليك، يا رسول الله. فقلتُ: يا جبريل، ما هذا النداء؟ قال: هؤلاء المقصورات في الخِيام، استأذَنّ ربّهنّ في السلام عليك، فأَذِن لهنّ، فطَفِقنَ يقُلنَ: نحن الراضيات فلا نسخط أبدًا، ونحن المُقيمات -وفي لفظ: الخالدات- فلا نَظْعن أبدًا</b>». وقرأ رسول الله ﷺ هذه الآية: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>{2}. (١٤/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿حُورٌ﴾</span>: بِيض{3}. (١٤/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: الحُور: سُود الحَدَق{4}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿حُورٌ﴾</span> النساء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: الحُور: البِيض، قلوبهم وأنفسهم وأبصارهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿حُورٌ﴾</span>: الحَوراء: العَيناء الحسناء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- قال: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span> عذارى الجنة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span>، قال: الحُور: السُّود الحَدَق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، يعني بالحُور: البيضاء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران-: الحَوَر: سواد في بياض{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّقۡصُورَ ٰ⁠تࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span>: محبوسات{12}. (١٤/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق الربيع- <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span>: محبوسات في الخيام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> لا يَخرجن من بيوتهنّ{14}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> مقصورات قلوبهنّ وأبصارهنّ وأنفسهنّ على أزواجهنّ في خيام اللؤلؤ، لا يُرِدْن غيرهم{15}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span>: محبوسات، قصرن طرفهن وأنفسهن على أزواجهن{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ فِي الخِيامِ﴾</span> محبوسات في خيام اللؤلؤ{17}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> محبوسات، ليس بطوّافات في الطُّرق{18}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿مقصورات﴾</span>، قال: محبوسات{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٢<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span> -من طريق ابن يمان، عن أبي جعفر- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> محبوسات في الخِيام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٣<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span> -من طريق عبيد الله وابن اليمان، عن أبي جعفر- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> قُصِر طَرفهنّ على أزواجهنّ{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> و[يعني] بالمقصورات: المحبوسات على أزواجهنّ{10}<span class=comment-ref>٦٤٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٧</span> اختُلف في قوله: <span class="qpc-hafs">﴿مقصورات﴾</span> على قولين: <b>الأول</b>: قُصرن على أزواجهنّ فلا يُرِدن غيرهم. <b>الثاني</b>: محبوسات في الخيام.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢٢/٢٦٧) القولين، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">العموم</span>، فقال: «والصواب من القول في ذلك عندنا أن يُقال: إنّ الله -تبارك وتعالى- وصفهنّ بأنهنّ مقصورات في الخيام، والقصر: هو الحبس، ولم يخصّص وصفهنّ بأنهنّ محبوسات على معنًى من المعنيين اللذين ذكرنا دون الآخر، بل عمّ وصفهن بذلك، والصواب أن يعمّ الخبر عنهنّ بأنهنّ مقصورات في الخيام على أزواجهنّ فلا يُردن غيرهم، كما عمّ ذلك».</div></p><p><h3><span class="qpc-hafs">﴿فِی ٱلۡخِیَامِ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٣٥<span class="dash">-</span></span> عن الضَّحّاك بن مُزاحِم، قال: كان ابن مسعود يُحَدِّث عن نبيِّ الله ﷺ أنه قال: «<b>هي الدُّرّ المُجَوّف</b>». يعني: الخيام في قوله: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>{23}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٦<span class="dash">-</span></span> عن أبي مِجلز، أن رسول الله ﷺ قال في قول الله: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>: «<b>دُرّ مُجَوّف</b>»{24}. (١٤/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٧<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق أبي الأَحوص- قال: أتدرون ما <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>؟ قال: الخيام دُرّ مُجَوّف{25}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأَحوص- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> الدُّرّ المُجَوّف{26}. (١٤/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: لكلّ زوجة خيمةٌ مِن ياقوت أو لؤلؤة، طولها ستون ميلًا{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد- <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span>، قال: خيام اللؤلؤ، والخيمة من لؤلؤة واحدة مُجَوّفة، أربعة فراسخ في أربعة فراسخ، لها أربعة آلاف مِصراع من ذهب{28}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤١<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span>: ذُكر لنا: أنّ <span class="name-1">ابن عباس</span> كان يقول: الخَيمة دُرّة مُجَوّفة، فرسخٌ في فرسخٍ، لها أربعة آلاف باب من ذهب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span>، قال: الخيمة ميل في ميل، والميل ثلث الفرسخ{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون الأَوْدي</span> -من طريق حرب- قال: الخَيمة دُرّة مُجَوّفة{31}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٤<span class="dash">-</span></span> عن <span class="name-2">عمر بن ميمون</span> -من طريق حَزْن بن بِشر- في قوله تعالى: <span class="qpc-hafs">﴿مقصورات في الخيام﴾</span>: خَيمة مِن لؤلؤة واحدة، قصورها وأبوابها منها{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق موسى- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> دُرّ مُجَوّف{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: الخَيمة دُرّة مُجَوّفة{34}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> الخيام: اللؤلؤ والفِضة، كما يُقال، والله أعلم{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق محمد بن مروان- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> دُرّ مُجَوّف{36}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سلمة-، مثله{37}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> الخيام: الدُّرّ المُجَوّف{38}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥١<span class="dash">-</span></span> عن <span class="name-2">خُلَيد العَصَريّ</span> -من طريق قتادة- قال: لقد ذُكر لي: أنّ الخيمة لؤلؤة مُجَوّفة، لها سبعون مِصراعًا، كلّ ذلك من دُرّ{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، قال: في الحِجال{40}. (١٤/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: كان يُقال: مسكن المؤمن في الجنة يسير الراكب الجواد فيه ثلاث ليال، وأنهاره وجنانه وما أعدّ الله له مِن الكرامة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن جُحادَةَ</span>، في قول الله ﷾: <span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span>، قال: الخَيمة دُرّة، فرسخٌ في فرسخٍ، عليها أربعة ألف مِصراع من ذهب{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> في الحِجال{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> يعني: الدُّرّ المُجَوّف، الدُّرّة الواحدة مثل القصر العظيم، جوفاء على قدر ميل في السماء، طولها فرسخ، وعرضها فرسخ، لها أربعة آلاف مِصراع من ذهب، فذلك قوله تعالى: <span class="qpc-hafs">﴿والمَلائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِن كُلِّ بابٍ﴾</span> [الرعد:٢٣]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، يُقال: خيامهم في الجنة من لؤلؤ{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی ٱلۡخِیَامِ ۝٧٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٥٨<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النَّبِيّ ﷺ، قال: «<b>الخَيمة دُرّة مُجَوّفة، طولها في السماء ستون ميلًا، في كلّ زاوية منها للمؤمن أهلٌ لا يراهم الآخرون، يطوف عليهم المؤمن</b>»{46}. (١٤/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٩<span class="dash">-</span></span> عن <span class="name-1">أبي الدّرداء</span>، قال: الخَيمة لؤلؤة واحدة، لها سبعون بابًا من دُرّ{47}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٠<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي المُهَزَّم- قال: دار المؤمن في الجنة من لؤلؤة، فيها أربعون بيتًا، في وسطها شجرة تُنبِت الحُلَل، فيأتيها، فيأخذ بأصبعه سبعين حُلّة مُمنطقَة{48} باللؤلؤ والمرجان{49}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦١<span class="dash">-</span></span> عن <span class="name-2">حِبّان بن أبي جَبَلة</span>، قال: إنّ نساء أهل الدنيا إذا دَخلن الجنة فُضِّلن على الحور العين؛ بأعمالهنَّ في الدنيا{50}. (١٤/١٦٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٦٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق رجل- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: منذ أُنشِئن{51}. (١٤/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span> لأنهنّ خُلقن في الجنة، يعني: لم يطأهنّ إنسٌ قبل أهل الجنة، <span class="qpc-hafs">﴿ولا جان﴾</span> يعني: ولا جنِّي{10}. (ز)</p></p><p></div></p></div>",footnotes:1:جاء في مسند أحمد (١٣٦٩٨) من حديث أنس: أنه اسم نهر في الجنة.أخرجه البيهقي في البعث والنشور ص٢١٥ (٣٤٠)، والثعلبي ٩/١٩٦، من طريق علي بن أحمد بن عبدان، عن أحمد بن عبيد، عن الكديمي، عن حبان بن هلال، عن سليمان بن المغيرة، عن ثابت، عن أنس بن مالك به.</p><p>وسنده ضعيف؛ فيه محمد بن يونس الكديمي، قال عنه ابن حجر في تقريب التهذيب (٦٤١٩): «ضعيف».أخرجه ابن جرير ٢٢/٢٦٤، ٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٣٠٣، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٣٣-٣٣٤-، وابن المنذر -كما في الفتح ٨/٦٢٤-.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٧، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٨/٤٦١ (٣٥١٩٤)، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٨٣ (٣١٢)-.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣. والحَدَق: جمع حَدَقة وهي العين. النهاية (حدق).تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٦٦.تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٦٥ وبنحوه من طريق أبي يحيى، وابن أبي شيبة ١٣/٥٦٨-٥٦٩، وهناد (١٧).أخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤-.أخرجه هناد (١٥)، وابن جرير ٢٢/٢٦٧ من طريق عبيد بنحوه.أخرجه ابن جرير ٢٢/٢٦٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.أخرجه ابن جرير ٢٢/٢٦٦.أخرجه ابن جرير ٢٢/٢٦٥.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧٢، قال: حدثت عن الحسين، عن أبي معاذ، عن عبيد، عن الضَّحّاك، عن ابن مسعود به. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>وسنده ضعيف؛ لجهالة الراوي عن الحسين، والضحاك لم يدرك ابن مسعود.أخرجه ابن جرير ٢٢/٢٧١، وابن أبي شيبة ١٣/١٣٤مرسلًا.أخرجه ابن جرير ٢٢/٢٦٨-٢٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٦٨، ومسدد -كما في المطالب العالية (٤١٣٢)-، وابن أبي شيبة ١٣/١٣٤.تفسير الثعلبي ٩/١٩٦.أخرجه ابن أبي شيبة ١٣/١٣٣-١٣٥، وابن أبي الدنيا في صفة الجنة (٣٢٨)، وابن جرير ٢٢/٢٦٨-٢٦٩، وبنحوه من طريق مجاهد، وعكرمة، والبيهقي في البعث (٣٣٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٧١.أخرجه عبد بن حميد -كما في الفتح ٨/٦٢٥-.أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٥، وهناد (٥٢).أخرجه أبو نعيم في حلية الأولياء ٤/١٤٩.أخرجه ابن جرير ٢٢/٢٦٩.أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٦، وهناد (١٧، ١٥٤).تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٧٠، ٢٧١، ٢٧٢، من طريق منصور أيضًا.أخرجه ابن أبي شيبة ١٣/١٣٥.أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٦.أخرجه ابن جرير ٢٢/٢٧١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٦٩.أخرجه ابن جرير ٢٢/٢٦٦ بزيادة: محبوسات، وابن أبي شيبة ١٣/١٣٥.أخرجه ابن جرير ٢٢/٢٧١.أخرجه ابن المبارك في الزهد ١/٤٢١.أخرجه ابن جرير ٢٢/٢٧٠.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧١.أخرجه البخاري ٤/١١٧-١١٨ (٣٢٤٣)، ٦/١٤٥ (٤٨٧٩)، ومسلم ٤/٢١٨٢ (٢٨٣٨).أخرجه عبد الله بن أحمد في زوائد الزهد ص٢٣٣. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.المِنطَق والمِنطقة والنِّطاق: كل ما شُد به وسطه. لسان العرب (نطق).أخرجه ابن أبي شيبة ١٣/١٢٩.أخرجه هناد (٢٣).أخرجه هناد (٢٢).تفسير مقاتل بن سليمان ٤/٢٠٥.
  55,72,""
  55,72,""
  55,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٦٤<span class="dash">-</span></span> عن أبي بَكرة، عن النَّبِيّ ﷺ، قرأ: <b>(مُتَّكِئِينَ عَلى رَفارِفَ خُضْرٍ وعَباقِرِيَّ حِسانٍ)</b>{1}<span class=comment-ref>٦٤٠٨</span>. (١٤/١٦٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٨</span> ذكر <u>ابن جرير</u> (٢٢/٢٧٧ بتصرف) هذا الأثر عن النبي ﷺ، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لضعف السند، واللغة</span>، فقال: «وذُكر عن النبي ﷺ خبر غير محفوظ، ولا صحيح السند (رَفارِفَ خُضْرٍ وعَباقِرِيَّ) بالألف والإجراء، وهذه القراءة لو كانت صحيحة لوجب أن تكون الكلمتان غير مجراتين».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٨٤) هذه القراءة عن النبي ﷺ، وعن عثمان، وأورد <span class="comment-type-2">انتقاد</span> الزّجاج والرّماني عليها، فقال: «وغلّط الزّجاج والرّماني هذه القراءة». وذكر ابن عطية عن عثمان ﵁ أنه قرأ ذلك: (عَباقَريَّ) بفتح القاف والياء، ثم <span class="comment-type-4">علّق</span> بقوله: "وهذا على أن اسم الموضع (عباقر) بفتح القاف، والصحيح في اسم الموضع: (عبقر)، <span class="mustanad">قال الشاعر</span>:</p><p>كأن صليل المروحين تشذه صليل الزيوف يُنتقدن بعبقرا".</div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٥<span class="dash">-</span></span> عن أبي بكر بن عيّاش، قال: كان <span class="name-3">زُهير الفُرْقُبيّ</span> -وكان نحويًّا بصريًّا- يقرأ: (رَفارِفَ خُضْرٍ وعَباقِرِيَّ حِسانٍ){2}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٦<span class="dash">-</span></span> عن أبي طُعْمة -من طريق ابن لهيعة- يقرأ: (مُتَّكِئِينَ عَلى رَفارِفَ خُضْرٍ){3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٦٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، قال: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> فُضول المحابس{2}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: فُضول المحابس، والفُرُش، والبُسط{5}. (١٤/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: المحابس{6}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span> الرّفرف: الرياض{2}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧١<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span> الرّفرف: رياض الجنة، <span class="qpc-hafs">﴿خضر﴾</span> مُخضبة{8}<span class=comment-ref>٦٤٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٩</span> ذكر <u>ابنُ عطية</u> (٨/١٨٤) أنّ «الرَّفْرَف: ما تدلّى مِن الأَسِرّة مِن غالي الثياب والبُسُط». ونقل قول ابن جُبير في معنى: «الرفرف»، و<span class="comment-type-1">وجَّهه</span> بقوله: «ووَجْه قول ابن جُبير: أنه مِن رفَّ النَّبت: إذا نعُم وحسُن». ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأول أصوب وأبين». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: فُضول الفُرش{9}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: الرّفرف: المحابس{10}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: البُسط{11}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-: الرفرف: مرافق خُضر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: محابس خُضر{13}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٧<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span> البُسُط{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحسن بن يزيد بن الأصمّ- قال: <span class="qpc-hafs">﴿متكئين على رفرف﴾</span> المحابس{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٩<span class="dash">-</span></span> عن <span class="name-2">عاصم الحجدري</span>، (رَفْارَفٍ)، قال: وسائد{16}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن جُحادَةَ</span>، في قول الله ﷾: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفارَفٍ خُضْرٍ﴾</span>، قال: مجالس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿رفرف خضر﴾</span>، قال: الرّفرف: فُضول الفُرُش والمحابس{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span>، يعني: المحابس فوق الفُرش{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> الرّفرف: المحابس{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٤<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span>: هي الزّرابي{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٥<span class="dash">-</span></span> عن غَزْوان -من طريق سفيان- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: فضول المحابس{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الزَّرابِيُّ{23}{6}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الزّرابي{6}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: والعبقري: الزّرابي{2}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، يعني: الوسائد{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿ولمن خافَ مقام ربه جنتان﴾</span> فذكر فضل ما بينهما، ثُمَّ ذكر <span class="qpc-hafs">﴿ومن دونهما جنتان فَبِأَي آلاء رَبكُما تُكَذِّبانِ مُدْهامّتان﴾</span> قال: خَضْراوان، <span class="qpc-hafs">﴿فيهما عَيْنان نَضّاخَتان﴾</span> وفي تلك <span class="qpc-hafs">﴿تَجْرِيانِ﴾</span>، <span class="qpc-hafs">﴿فيهما فاكِهَة ونَخلٌ ورُمّان﴾</span> وفي تلك <span class="qpc-hafs">﴿مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span>، <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حسان﴾</span> وفي تلك <span class="qpc-hafs">﴿قاصِراتُ الطّرفِ لم يَطْمِثهنّ إنْسٌ قبلهم ولا جان﴾</span>، <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> وفي تلك <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى فُرُشٍ بَطائِنُها من إسْتَبْرق﴾</span> قالَ: الدِّيباج، والعبقري: الزّرابي{28}. (١٤/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩١<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> هي الطّنافس المُخْملة إلى الرّقة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> العبقري: عتاق الزّرابي{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الدِّيباج الغليظ{31}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: العبقري: الزّرابي، وهي البُسُط{10}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الطَّنافس{33}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الزّرابي{34}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحسن بن يزيد بن الأصمّ- قال: <span class="qpc-hafs">﴿وعبقري حسان﴾</span> الزّرابي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن جُحادَةَ</span>، في قول الله ﷾: (وعَباقِرِيَّ حِسانٍ)، قال: طَنافس. وكان يقرأها: (وعَباقِرِيَّ){17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿عبقري﴾</span>: الزّرابي{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> يعني: الزّرابي، وهي الطّنافس المُخْملة، وهي الحِسان{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> العبقري: الطنافس{39}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٢٧٣ (٢٩٨٦) وفيه: <span class="qpc-hafs">﴿رَفْرَفٍ﴾</span>، <span class="qpc-hafs">﴿(وعَبْقَرِيٍّ﴾</span>، وحفص بن عمر في جزء قراءات النبي ص١٥٧ (١١٤)، والثعلبي ٩/١٩٨، من طريق أبي عبد الرحمن عبد الله بن حفص الأرطباني، عن عاصم الجحدري، عن أبي بكرة به.</p><p>قال ابن جرير في التفسير ٢٢/٢٧٧: «ذُكر عن النبي ﷺ خبر غير محفوظ، ولا صحيح السند». فذكره. وقال: قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع، وعاصم لم يدرك أبا بكرة».</p><p>وهي قراءة شاذة، تروى أيضًا عن الفرقبي، وابن محيصن، وغيرهما. انظر: المحتسب ٢/٣٠٥، ومختصر ابن خالويه ص١٥١.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٦٢ (١٤٤)-.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٣٠٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٧٤-٢٧٥، وبنحوه من طريق عنترة، وابن أبي شيبة ١٣/١٣٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن حجر في تغليق التعليق ٤/٦٣ بسنده إلى أبي نعيم عن سعيد بن جبير من طريق أبي بشر بلفظ: الرفرف: رياض الجنة، وتفسير البغوي ٧/٤٥٨.أخرجه ابن جرير ٢٢/٢٧٧ مقتصرًا على آخره، وابن أبي شيبة ١٣/١٣٧، وهناد (٨٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٥ مقتصرًا على أوله، وابن أبي شيبة ١٣/١٣٦، وهناد (٨٢).أخرجه ابن جرير ٢٢/٢٧٤ بنحوه، وابن أبي شيبة ١٣/١٣٧، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٣ (١٦٠)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٥.أخرجه عبد الرزاق ٢/٢٦٧، وابن جرير ٢٢/٢٧٥-٢٧٧، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٩٧.أخرجه سعيد بن منصور في سننه -التفسير ٧/٥١٦ (٢١٤٣).عزاه السيوطي إلى ابن المنذر.أخرجه ابن المبارك في الزهد ١/٤٢١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧٥.تفسير الثعلبي ٩/١٩٧، وتفسير البغوي ٧/٤٥٩.أخرجه ابن جرير ٢٢/٢٧٤.الزَّرابي: البُسُط، وقيل: كل ما بُسط واتُّكِئ عليه. لسان العرب (زرب).أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٥-.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/١٩٧، وتفسير البغوي ٧/٤٥٩.أخرجه ابن جرير ٢٢/٢٧٦، وأخرجه ابن حجر في تغليق التعليق ٤/٦٣ بسنده إلى أبي نعيم عن سعيد بن جبير من طريق أبي بشر بلفظ: العبقري: الزرابي. وعزاه ابن حجر في الفتح ٧/٤٦ إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٧٧، وابن أبي شيبة ١٣/١٣٧، وهناد (٨٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٥ مقتصرًا على أوله، وابن أبي شيبة ١٣/١٣٦، وهناد (٨٢).أخرجه ابن أبي شيبة ١٣/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٦٧، وابن جرير ٢٢/٢٧٥-٢٧٧، ومن طريق أبي العوام. وعزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه -التفسير ٧/٥١٦ (٢١٤٣).أخرجه ابن المبارك في الزهد ١/٤٢١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧٧.
  55,74,""
  55,74,""
  55,75,""
  55,76,""
  55,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ذِي الجَلالِ والإكْرامِ﴾</span> يقول: ذو العظمة والكبرياء{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَبارَكَ اسْمُ رَبِّكَ ذِي الجَلالِ﴾</span> يعني بالجلال: العظيم، <span class="qpc-hafs">﴿والإكْرامِ﴾</span> يعني: الكريم؛ فلا أكرم منه، يمدح الرّبُّ نفسه -تبارك وتعالى-{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٠٤<span class="dash">-</span></span> عن أنس بن مالك، أنّ رسول الله ﷺ قال: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام</b>»{3}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٥<span class="dash">-</span></span> عن عبد الله بن عمر، عن النبيِّ ﷺ، قال: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام</b>»{4}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٦<span class="dash">-</span></span> عن ربيعة بن عامر، سمعتُ رسول الله ﷺ يقول: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام</b>»{5}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٧<span class="dash">-</span></span> عن أنس بن مالك قال: قال رسول الله ﷺ: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام؛ فإنهما اسمان من أسماء الله العِظام</b>» {6}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٨<span class="dash">-</span></span> عن معاذ بن جبل، قال: سمع النبيُّ ﷺ رجلًا يقول: يا ذا الجلال والإكرام. قال: «<b>قد استُجيب لك؛ فَسَل</b>»{7}. (١٤/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٩<span class="dash">-</span></span> عن ثوبان، قال: كان رسول الله ﷺ إذا انصرف من صلاته استغفر الله ثلاثًا، ثم قال: «<b>اللهم، أنت السلام، ومنك السلام، تباركتَ يا ذا الجلال والإكرام</b>»{8}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٠<span class="dash">-</span></span> عن أنس بن مالك، قال: كنتُ مع رسول الله ﷺ جالسًا في الحلقة، ورجل قائم يصلي، فلمّا ركع وسجد تشهَّد ودعا، فقال في دعائه: اللهم، إني أسألك بأنّ لك الحمد، لا إله إلا أنت وحدك لا شريك لك، المنّان بديع السموات والأرض، يا ذا الجلال والإكرام، يا حيّ يا قيّوم، إني أسألك. فقال النبيُّ ﷺ: «<b>لقد دعا اللهَ باسمه العظيم؛ الذي إذا دُعِي به أجاب، وإذا سُئِل به أعطى</b>»{9}. (١٤/١٧٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٧٨.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه الترمذي ٦/١٢٧ (٣٨٣٤)، من طريق محمد بن حاتم المكتب، عن أبي بدر شجاع بن الوليد، عن الرحيل بن معاوية، عن الرّقاشي، عن أنس بن مالك به.</p><p>وأخرجه أيضًا ٦/١٢٩ (٣٨٣٥)، والبزار ١٣/١٨٠ (٦٦٢٥)، من طريق المؤمل، عن حماد بن سلمة، عن حميد، عن أنس به.</p><p>قال الترمذي: «هذا حديث غريب، وقد رُوي هذا الحديث عن أنس مِن غير هذا الوجه». وقال في الموضع الثاني: «هذا حديث غريب، وليس بمحفوظ، وإنما يُروى هذا عن حماد بن سلمة، عن حميد، عن الحسن البصري، عن النبي ﷺ، وهذا أصح. والمؤمل غلط فيه، فقال: عن حميد، عن أنس، ولا يُتابع فيه». وأورده الدارقطني في العلل ١٢/٢٦ (٢٣٦٥). وقال ابن حجر في الكافي الشاف ص١٦٢ (٧٧): «يزيد ضعيف».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٣٩٦-، من طريق المعافى بن عمران، عن ابن عياش، عن عمر بن محمد بن زيد بن عبد الله بن عمر بن الخطاب، عن أبيه، عن عبد الله بن عمر به.</p><p>قال ابن حجر في الكافي الشاف ص١٦٢: «إسناده ضعيف».أخرجه أحمد ٢٩/١٣٨ (١٧٥٩٦)، والحاكم ١/٦٧٦ (١٨٣٦)، من طريق عبد الله بن المبارك، عن يحيى بن حسان، عن ربيعة بن عامر به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن عساكر في تاريخه ١٨/٦٧: «قال ابن منده: هذا حديث غريب، لم نكتبه إلا من هذا الوجه». وأورده الألباني في الصحيحة ٤/٤٩ (١٥٣٦).عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ٣٦/٣٤٧-٣٤٨ (٢٢٠١٧)، ٣٦/٣٧٩ (٢٢٠٥٦)، والترمذي ٦/١٣١-١٣٢ (٣٨٣٧-٣٨٣٨)، من طريق سعيد الجريري، عن أبي الورد بن ثمامة، عن اللجلاج، عن معاذ بن جبل به.</p><p>قال الترمذي: «هذا حديث حسن». وأورده ابن أبي حاتم في علل الحديث ٥/٣٨٢ (٢٠٦٣). وقال الألباني في الضعيفة ٧/٤٢٥ (٣٤١٦)، ١٠/٢٤ (٤٥٢٠): «ضعيف».أخرجه مسلم ١/٤١٤ (٥٩١).أخرجه أحمد ١٩/٢٣٨ (١٢٢٠٥)، وابن ماجه (٣٨٥٨)، من طريق وكيع، عن أبي خزيمة، عن أنس بن سيرين، عن أنس بن مالك به.</p><p>وأخرجه أحمد ٢٠/٦١ (١٢٦١١)، ٢١/١٩٢ (١٣٥٧٠)، وأبو داود ٢/٦١٢-٦١٣ (١٤٩٥)، والنسائي ٣/٥٢ (١٣٠٠)، وابن حبان ٣/١٧٥-١٧٦ (٨٩٣)، والحاكم ١/٦٨٣ (١٨٥٦)، من طريق خلف بن خليفة، عن حفص بن عمر، عن أنس به.</p><p>قال الترمذي: «هذا حديث غريب من هذا الوجه، وقد روي من غير هذا الوجه عن أنس». وقال الهيثمي في المجمع ١٠/١٥٦ (١٧٢٥٨): «رواه أحمد، والطبراني في الصغير، ورجال أحمد ثقات، إلا أن ابن إسحاق مدلّس، وإن كان ثقة». وقال الألباني في صحيح أبي داود ٥/٢٣٣ (١٣٤٢): «حديث صحيح». وأورده في الصحيحة ٧/١٢٠٩ (٣٤١١).
  55,78,""
