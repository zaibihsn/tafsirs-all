  55,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ ۝٤٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٠٨<span class="dash">-</span></span> عن الجُرَيريّ، عن أخيه، قال: سمعتُ محمد بن سعد يقرأ هذه الآية: (ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ وإن زَنى وإن سَرَقَ). فقلت: ليس فيه: (وإن زَنى وإن سَرَقَ). قال: سمعتُ أبا الدّرداء يقرؤها كذلك، فقلتُ: ليس فيه: (وإن زَنى وإن سَرَقَ). قال: سمعتُ رسول الله ﷺ يقرؤها كذلك؛ فأنا أقرؤها كذلك حتى أموت{1}. (١٤/١٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٠٩<span class="dash">-</span></span> عن أبي الدّرداء: أن النبيَّ ﷺ قرأ هذه الآية: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقلتُ: وإن زَنى وإن سَرق، يا رسول الله؟ فقال النبيُّ ﷺ الثانية: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقلت: وإن زَنى وإن سَرق؟ فقال الثالثة: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقلت: وإن زَنى وإن سَرق؟ قال: «<b>نعم، وإن رَغِم أنفُ أبي الدّرداء</b>»{2}. (١٤/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٠<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقال أبو الدرداء: وإن زَنى وإن سَرق، يا رسول الله؟ قال: «<b>وإن زَنى وإن سَرق</b>، <b>وإن رَغِم أنفُ أبي الدّرداء</b>». فكان أبو الدّرداء يَقُصّ ويقول: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، وإن رَغِم أنف أبي الدّرداء{3}. (١٤/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١١<span class="dash">-</span></span> عن أبي الدّرداء، قال: قال رسول الله ﷺ: «<b>مَن شهد أن لا إله إلا الله وأني رسول الله دخل الجنة</b>». ثم قرأ: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>{3}. (١٤/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٢<span class="dash">-</span></span> عن <span class="name-1">أبي الدّرداء</span> -من طريق سيار- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> أنه قيل له: يا أبا الدّرداء، وإن زَنى وإن سَرق؟ قال: مَن خاف مقام ربّه لم يزنِ ولم يسرق{5}. (١٤/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> لِمَن خافه في الدنيا{6}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي وائل- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: وإن زَنى وإن سَرق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٥<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span> -من طريق أبي بكر- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> جنتان مِن ذهب للسابقين، وجنتان مِن فِضّة للتابعين{8}. (١٤/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> وعد الله المؤمنين الذين خافوا مَقامه فأَدّوا فرائضه الجنةَ{9}. (١٤/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، يقول: خاف ثم اتقى، والخائف مَن ركب طاعةَ الله وترك معصيته{9}. (١٤/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> إذا أراد أن يُذنِب أمسك مخافة الله{11}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: هو الرجل يَهِمّ بالمعصية، فيذكر مقامه، فيَنزِع عنها{12}. (١٤/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> الرجل يريد الذَّنب، فيَذكر الله، فيَدَع الذنب{13}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢١<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> هذا لِمَن راقب اللهَ في السّر والعلانية بعلْمه، ما عرض له مِن مُحرّم تركه مِن خشية الله، وما عمل مِن خير أفضى به إلى الله، لا يحب أن يَطَّلِع عليه أحدٌ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، يعني: الذي يقوم بين يدي ربّه للحساب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: إنّ المؤمنين خافوا ذلك المَقام، فعمِلوا لله، ودَأبُوا ونَصَبوا له بالليل والنهار{16}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> مَن خاف مَقام الله عليه{6}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، مثله{6}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> إنّ لله مقامًا قد خافه المؤمنون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٧<span class="dash">-</span></span> عن <span class="name-2">عطية بن قيس</span>، قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> نَزَلَتْ في الذي قال: أحْرِقوني بالنار لعلّي أُضِلّ الله. قال: تاب يومًا وليلة بعد أن تكلّم بهذا، فقَبل الله منه ذلك، وأدخله الجنة{20}<span class=comment-ref>٦٣٩٥</span>. (١٤/١٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٥</span> ذكر <u>ابنُ كثير</u> (١٣/٣٢٩) هذا الأثر، ثم <span class="comment-type-3">رجّح</span> أنّ الآية <span class="mustanad">عامة</span> في كلّ مَن خاف مقام ربّه، وأضاف مستدلًا بعمومها على دخول مَن آمن من الجنّ الجنة، فقال: «وهذه الآية عامة في الإنس والجنّ، فهي مِن أدل دليل على أنّ الجنّ يدخلون الجنة إذا آمنوا واتقوا؛ ولهذا امتنّ الله تعالى على الثقلين بهذا الجزاء، فقال: <span class="qpc-hafs">﴿ولمن خاف مقام ربه جنتان فبأي آلاء ربكما تكذبان﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span>، قال: كنتُ عند هشام بن عبد الملك، فقال: قال أبو هريرة: قال رسول الله ﷺ: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقال أبو هريرة: وإن زَنى وإن سَرق؟ فقلتُ: إنّما كان ذلك قبل أن تنزل الفرائض، فلمّا نَزَلَت الفرائضُ ذهب هذا{3}. (١٤/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ﴾</span> يوم القيامة في الآخرة ...، وهو الرجل يَهِمّ بالمعصية، فيَذكر مقامه بين يدي الله ﷿، فيخاف، فيتركها، فله جنتان{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> مقامه حين يقوم العباد يوم القيامة. وقرأ: <span class="qpc-hafs">﴿يَوْمَ يَقُومُ النّاسُ لِرَبِّ العالَمِينَ﴾</span> [المطففين:٦]، وقال: ذاك مقام ربّك{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَنَّتَانِ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٣١<span class="dash">-</span></span> عن عِياض بن غَنْم: أنه سمع رسولَ الله ﷺ تلا: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: «<b>بستانان، عَرض كلّ واحد منهما مسيرة مائة عام، فيها أشجار، وفرْعها ثابت، وشجرها ثابت، وعَرْصَتُها{24} عريضة، ونعيمها عظيم، وخَيرها دائم، ولذّتها قائمة، وأنهارها جارية، ورِيحها طيّب، وبركتها كثيرة، وحَياتها طويلة، وفاكهتها كثيرة</b>»{3}. (١٤/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٢<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، وقوله: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span>، قال: «<b>جنتان مِن ذهبٍ للمُقرّبين، وجنتان مِن ورِق لأصحاب اليمين</b>»{26}. (١٤/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٣<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ أنه قال: «<b>هل تَدرُون ما الجنتان؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>هما بستانان في رَبَض الجنة، كل واحد منهما مسيرة خمسمائة عام، في وسط كلّ بستان دار في دار مِن نور على نور، ليس منهما بستان إلا يهتزّ بنعمة وخُضرة، قرارها ثابت، وفرعها ثابت، وشجرها نابت</b>»{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> هي أربع جنات: جنتان للسابقين، وهم أصحاب الأنبياء، وجنتان للتابعين{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَنَّتانِ﴾</span> يعني: جنة عَدن، وجنة النعيم، وهما للصِّدِّيقين والشهداء والمُقَرّبين والسابقين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> جنتا السابقين. فقرأ: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> [الرحمن:٥٨]، ثم رجع إلى أصحاب اليمين، فقال: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> [الرحمن:٦٢] فذكر فَضلهما، وما فيهما{7}<span class=comment-ref>٦٣٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٦</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٢/٢٣٥) <span class="mustanad">مستندًا لأقوال السلف:</span> «يقول -تعالى ذكره-: ولمن اتقى الله من عباده، فخاف مقامه بين يديه، فأطاعه بأداء فرائضه، واجتناب معاصيه؛ جنتان، يعني: بُستانين، وبنحو الذي قلنا في ذلك قال أهل التأويل، وإن اختلفتْ ألفاظهم في البيان عن تأويله، غير أنّ معنى جميعهم يقول إلى هذا». وذكر أقوال السلف على هذا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٧٧) في قوله: «مَن» احتمالين، فقال: «»مَن«في قوله تعالى: <span class="qpc-hafs">﴿ولمن﴾</span> <b>يحتمل</b> أن تقع على جميع المتصفين بالخوف الزاجر عن معاصي الله تعالى، و<b>يحتمل</b> أن تقع لواحد منهم، وبحسب هذا قال بعض الناس في هذه الآية: إنّ كلّ خائف له جنتان. وقال بعضهم: إن جميع الخائفين لهم جنتان».</p><p>ونقل <u>ابنُ عطية</u> (٨/١٧٧) عن <b>قوم</b> قولهم: «أراد: جنة واحدة، وثنّى <span class="mustanad">على نحو قوله تعالى</span>: <span class="qpc-hafs">﴿ألْقِيا فِي جَهَنَّمَ كُلَّ كَفّارٍ عَنِيدٍ﴾</span> [ق:٢٤]، <span class="mustanad">وقول الحجاج</span>: يا غلام اضربا عنقه». و<span class="comment-type-2">انتقد</span> (٥/٢٣٣ دار الكتب العلمية) قولهم -<span class="mustanad">مستندًا إلى القرآن، وإلى اللغة-</span> قائلًا: «وهذا ضعيف؛ لأن معنى التثنية متوجّه، فلا وجه للفرار إلى هذه الشاذة، <span class="mustanad">ويؤيد التثنية قوله</span>: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> وهي تثنية»ذات«على الأصل؛ لأن أصل»ذات«: ذوات».</div></p><p><h3><span class="qpc-hafs">﴿جَنَّتَانِ ۝٤٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٣٧<span class="dash">-</span></span> عن أبي موسى الأشعري، أنّ رسول الله ﷺ قال: «<b>جنان الفردوس أربع: جنتان من ذهب حِلْيَتهما وآنِيتهما وما فيهما، وجنتان من فِضّة حِلْيَتهما وآنِيتهما وما فيهما، وما بين القوم وبين أن ينظروا إلى ربهم إلا رِداء الكبرياء على وجهه في جنة عَدن</b>»{31}. (١٤/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٨<span class="dash">-</span></span> عن الحسن البصري، قال: كان شابٌّ على عهد عمر بن الخطاب مُلازِم المسجد والعبادة، فعشِقَته جارية، فأتته في خُلْوة، فكلّمته، فحدّث نفسه بذلك، فشهِق شَهقة، فغُشي عليه، فجاء عمٌّ له إلى بيته، فلمّا أفاق، قال: يا عمّ، انطلِق إلى عمر، فأقرِئه مِنِّي السلام، وقل له: ما جزاء مَن خاف مقام ربّه؟ فانطلق عمّه، فأخبر عمر وقد شهِق الفتى شَهقة أخرى فمات منها، فوقف عليه عمر، فقال: لك جنتان، لك جنتان{32}. (١٤/١٣٨)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى (١١٤٩٧)، وابن خزيمة في كتاب التوحيد ٢/٨١٠-٨١١ كلاهما بنحوه، من طريق سعيد الجريري، عن موسى، عن محمد بن سعد بن أبي وقاص، عن أبي الدرداء به. وعزاه السيوطي إلى الطبراني، وابن مردويه.</p><p>وسنده ضعيف؛ موسى شيخ الجريري قال عنه ابن حجر في تقريب التهذيب (٧٠٢٨): «مجهول».</p><p>والقراءة المذكورة قراءة شاذة.أخرجه أحمد ١٤/٣١١-٣١٢ (٨٦٨٣)، وابن جرير ٢٢/٢٣٧، من طريق محمد بن أبي حرملة، عن عطاء بن يسار، عن أبي الدّرداء به.</p><p>قال الذهبي في ميزان الاعتدال ٣/٧٧: «قال البخاري: هو مرسل». وقال العراقي في تخريج أحاديث الإحياء ص١٩٣٨: «إسناد صحيح». وقال الهيثمي في المجمع ٧/١١٨ (١١٣٩٠): «رجال أحمد رجال الصحيح». وقال ابن حجر في الفتح ١١/٢٦٧: «قد وقع التصريح بسماع عطاء بن يسار له من أبي الدّرداء».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٣٨. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٣٩.أخرجه ابن أبي شيبة ١٣/٣٨٣، والحاكم ١/٨٤، والبيهقي في البعث (٢٤٠-٢٤١). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٢/٢٣٥.أخرجه ابن جرير ٢٢/٢٣٥.أخرجه ابن جرير ٢٢/٢٣٦-٢٣٧.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٣١-، وعبد الرزاق ٢/٢٥٦، وابن جرير ٢٢/٢٣٥ بنحوه، وابن أبي شيبة ١٣/٥٧٠، وهناد (٨٩٩-٩٠٠)، وابن أبي الدنيا في التوبة (٥٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٣٦، والبيهقي في شعب الإيمان (٧٣٨-٧٣٩). وعزاه السيوطي إلى عبد بن حميد، وابن أبي الدنيا.تفسير البغوي ٧/٤٥١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٢-.أخرجه ابن جرير ٢٢/٢٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٣٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٠٢.أخرجه ابن جرير ٢٢/٢٣٩.العَرْصَة: كلُّ موضِع واسع لا بناء فيه. النهاية (عرص).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٣٨، من طريق علي بن سهل، عن مؤمل، عن حماد بن سلمة، عن ثابت، عن أبي بردة بن أبي موسى، عن أبيه به.</p><p>قال ابن حجر في الفتح ١٣/٤٣١: «رجاله ثقات».أورده مقاتل بن سليمان في تفسيره ٤/٢٠٢.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.تفسير مقاتل بن سليمان ٤/٢٠٢.أخرجه ابن جرير ٢٢/٢٣٩.أخرجه أحمد ٣٢/٥٠٥ (١٩٧٣١)، وابن جرير ١٥/٤٣٥، والثعلبي ٦/٢٠١-٢٠٢، من طريق أبي قدامة الحارث بن عبيد الإيادي، عن أبي عمران الجَوْني، عن أبي بكر بن عبد الله بن قيس، عن أبيه به.</p><p>قال الألباني في الضعيفة ٧/٤٦٥ (٣٤٦٥): «ضعيف».أخرجه البيهقي في شعب الإيمان (٧٣٦).
