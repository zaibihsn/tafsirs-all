  55,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ جَزَاۤءُ ٱلۡإِحۡسَـٰنِ إِلَّا ٱلۡإِحۡسَـٰنُ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٢٥<span class="dash">-</span></span> عن علي بن أبي طالب، في قوله: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: قال رسول الله ﷺ: «<b>قال الله ﷿: هل جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة</b>»{1}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>أنزل اللهُ عَلَيَّ هذه الآية مُسجَلة</b>{2} <b>في سورة الرحمن للكافر والمسلم: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span></b>»{3}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٧<span class="dash">-</span></span> عن عبد الله بن عباس، في قوله: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال رسول الله ﷺ: «<b>هل جزاء مَن قال: لا إله إلا الله في الدنيا إلا الجنة في الآخرة؟!</b>»{4}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٨<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ في قوله: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> قال: «<b>ما جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة</b>»{5}. (١٤/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٩<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ في هذه الآية: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> قال: «<b>هل جزاء مَن أنعمنا عليه بالإسلام إلا أن أُدخله الجنة؟!</b>»{6}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٠<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، وقال: «<b>هل تدرون ما قال ربكم؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>يقول: هل جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة</b>»{7}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: نَزَلَتْ هذه الآيةُ في المسلم والكافر: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>{6}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: إنّ لله عمودًا أحمر، رأسه مَلويٌّ على قائمة مِن قوائم العرش، وأسفله تحت الأرض السابعة على ظَهْر الحُوت، فإذا قال العبد: لا إله إلا الله. تحرّك الحوت؛ تحرّك العمود؛ تحرّك العرش؛ فيقول الله للعرش: اسكُن. فيقول: لا، وعزّتك، لا أسكُن حتى تغفر لقائلها ما أصاب قبلها من ذنبٍ. فيَغفر الله له{9}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن الحنَفيّة</span> -من طريق أبي يعلى- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: هي مُسجَلة للبَرِّ والفاجر{10}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله ﷿: <span class="qpc-hafs">﴿هل جزاء الإحسان إلا الإحسان﴾</span>، قال: هل جزاء لا إله إلا الله إلاّ الجنة؟!{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: هل جزاء مَن قال: لا إله إلا الله؛ إلا الجنة؟!{12}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، مثله{12}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> هي مُسجَلة للبَرِّ والفاجر؛ للفاجر في دنياه، وللبَرّ في آخرته{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: عمِلوا خيرًا فجُوزوا خيرًا{15}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن المُنكَدِر</span> -من طريق محمد بن جابر اليمامي- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: هل جزاء مَن أنعمتُ عليه بالإسلام إلّا الجنّة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ﴾</span> في الدنيا <span class="qpc-hafs">﴿إلّا الإحْسانُ﴾</span> في الآخرة، يعني: هل جزاء أهل التوحيد في الآخرة إلا الجنة؟!{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> ألا تراه ذَكرهم ومنازلهم وأزواجهم، والأنهار التي أعدّها لهم، وقال: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> حين أحسَنوا في هذه الدنيا أحسَنّا إليهم؛ أدخلناهم الجنة{18}<span class=comment-ref>٦٤٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٤</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٢/٢٥٢): «وقوله: <span class="qpc-hafs">﴿هل جزاء الإحسان إلا الإحسان﴾</span> يقول -تعالى ذِكْرُه-: هل ثواب خَوف مقام الله ﷿ لِمَن خافه فأحسن في الدنيا عمله، وأطاع ربّه، إلا أن يُحسن إليه في الآخرة ربُّه، بأن يجازيه على إحسانه ذلك في الدنيا ما وصف في هذه الآيات من قوله: <span class="qpc-hafs">﴿ولمن خاف مقام ربه جنتان﴾</span> إلى قوله: <span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span>، <span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span>، وإن اختلفت ألفاظهم بالعبارة عنه». وذكر على ذلك آثار السلف.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن النجار في تاريخه.أي: مرسلة مطلقة في الإحسان إلى كل أحد؛ بَرًّا كان أو فاجرًا. النهاية (سجل).أخرجه ابن عدي في الكامل في الضعفاء ٨/٤٠١ بلفظ: مجملة للكافر والمسلم، والبيهقي في شعب الإيمان ١١/٣٩٤-٣٩٥ (٨٧٢٦)، من طريق الهيثم بن عدي، عن عبد الله بن عياش، عن جعفر بن إياس، عن سعيد بن جُبَير، عن ابن عباس به.</p><p>قال البيهقي: «الهيثم بن عدي الكوفي متروك الحديث».عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه البيهقي في شعب الإيمان ٢/٢٢ (٤٢٥)، من طريق إبراهيم بن محمد بن إسماعيل الكوفي، عن حبيب بن أبي العالية، عن مجاهد، عن ابن عمر به.</p><p>قال البيهقي: «تفرَّد به إبراهيمُ بن محمد الكوفي، وهو منكر».عزاه السيوطي إلى ابن مردويه.أخرجه أبو نعيم في أخبار أصبهان ١/٢٨٠، والواحدي في التفسير الوسيط ٤/٢٢٧ (١١٥٦)، والثعلبي ٩/١٩٢، من طريق بشر بن الحسين، عن الزبير بن عدي، عن أنس بن مالك به.</p><p>وسنده ضعيف؛ فيه بشر بن الحسين الأصبهاني، وهو متروك. كما في ميزان الاعتدال ١/٣١٥.عزاه السيوطي إلى ابن مردويه.أخرجه الخطيب في تاريخه ٥/٣٨.أخرجه ابن جرير ٢٢/٢٥٣، والبخاري في الأدب (١٣٠)، والبيهقي في شعب الإيمان (٩١٥٢). وقال: مُسجلة يعني: مُرسلة. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الطبراني في الدعاء ٣/١٥٠٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٩٢.أخرجه ابن جرير ٢٢/٢٥٢.أخرجه الثعلبي ٩/١٩٢.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥٢-٢٥٣.
  55,60,""
  55,60,""
  55,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن دُونِهِمَا جَنَّتَانِ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: كان عرش الله على الماء، ثم اتخذ لنفسه جنة، ثم اتخذ دونها جنة أخرى، ثم أطبقهما بلؤلؤة واحدة، قال: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> وهي التي لا تُعلَم -أو قال- وهما التي <span class="qpc-hafs">﴿لا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ جَزاءً بِما كانُوا يَعْمَلُونَ﴾</span> [السجدة:١٧]، وهي التي لا تَعلَم الخلائق ما فيهما، أو ما فيها، يأتيهم كلَّ يوم منها أو منهما تُحفةٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> من دونهما في الدَّرَج{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> الجنتان الأُوليان من ذهب وفِضّة، والأُخريان من ياقوت{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> قال: هما دون <span class="qpc-hafs">﴿تَجْرِيانِ﴾</span>{4}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما﴾</span> يعني: ومن دون جَنتي المُقرّبين والصِّدّيقين والشهداء في الفضل <span class="qpc-hafs">﴿جَنَّتانِ﴾</span> وهما جنة الفردوس، وجنة المأوى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٧<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> هن أربع: جنتان للمُقرّبين السابقين، فيهما مِن كلّ من فاكهة زوجان، وجنتان لأصحاب اليمين، فيهما فاكهة ونخل ورمان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span>، قال: هما أدنى مِن هاتين لأصحاب اليمين{7}<span class=comment-ref>٦٤٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٥</span> اختُلف في معنى قوله تعالى: <span class="qpc-hafs">﴿ومن دونهما جنتان﴾</span> على قولين: <b>الأول</b>: من دونهما في الفَضل. <b>الثاني</b>: من دونهما في الدَّرَج.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٨١ بتصرف) أنّ «أكثر الناس على التأويل الأول، وهذه استدلالات ليست بقواطع، وأنه رُوي عن أبي موسى الأشعري ﵄ أنه قال: جنتان للمُقرّبين مِن ذهب، وجنتان لأهل اليمين مِن فِضة مما دون الأولَيَيْن».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ القيم</u> (٣/١٠١-١٠٣ بتصرف) <span class="mustanad">-مستندًا إلى الدلالة العقلية، وظاهر اللفظ والسياق-</span> القول الثاني من وجوه، أهمها ما يلي: <b>الأول</b>: قوله: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> وفيه قولان: أحدهما: أنه جمع فَنن، وهو الغُصن. والثاني: أنه جمع فَن، وهو الصنف، أي: ذواتا أصناف شتّى مِن الفواكه وغيرها، ولم يذكر ذلك في اللتين بعدهما. <b>الثاني</b>: قوله: <span class="qpc-hafs">﴿فِيهِما عَيْنانِ تَجْرِيانِ﴾</span>، وفي الأخريين: <span class="qpc-hafs">﴿فيهما عينان نضاختان﴾</span>، والنَّضّاخة هي الفوّارة، والجارية: السارحة، وهي أحسن مِن الفوارة؛ فإنها تضمن الفوران والجريان. <b>الثالث</b>: أنه قال: <span class="qpc-hafs">﴿فيهما من كل فاكهة زوجان﴾</span>، وفي الأخريين: <span class="qpc-hafs">﴿فيهما فاكهة ونخل ورمان﴾</span>، ولا ريب أنّ وصف الأُوليين أكمل. <b>الرابع</b>: أنه قال: <span class="qpc-hafs">﴿متكئين على فرش بطائنها من استبرق﴾</span>، وهذا تنبيه على فضل الظهائر وخطرها، وفي الأخريين قال: <span class="qpc-hafs">﴿متكئين على رفرف خضر وعبقري حسان﴾</span>، وفسّر الرّفرف بالمحابس والبُسط، وفسّر بالفُرش، وفسّر بالمحابس فوقها، وعلى كلّ قول فلم يصفه بما وصف به فُرش الجنتين الأوليين. <b>الخامس</b>: أنه قال: <span class="qpc-hafs">﴿وجنى الجنتين دان﴾</span> أي: قريب وسهل، يتناولونه كيف شاءوا، ولم يذكر ذلك في الأخريين. <b>السادس</b>: أنه قال: <span class="qpc-hafs">﴿فيهن قاصرات الطرف﴾</span> أي: قد قَصَرن طَرفهنَ على أزواجهنّ، فلا يرون غيرهم؛ لرضاهنّ بهم، ومحبتهنّ لهم، وذلك يتضمّن قَصرهنّ أطراف أزواجهنّ عليهنّ، فلا يدعهم حُسنهنّ أن ينظروا إلى غيرهنّ، وقال في الأخريين: <span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span>، ومَن قَصرت طرفها على زوجها باختيارها أكمل ممن قَصرت بغيرها. <b>السابع</b>: أنه وصفهنّ بشبَه الياقوت والمرجان في صفاء اللون وإشراقه وحُسنه، ولم يذكر ذلك في التي بعدها. <b>الثامن</b>: أنه قال ﷾ في الجنتين الأوليين: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، وهذا يقتضي أنّ أصحابهما مِن أهل الإحسان المطلق الكامل، فكان جزاؤهم بإحسان كامل. <b>التاسع</b>: أنه بدأ بوصف الجنتين الأوليين، وجعلهما جزءًا لِمَن خاف مقامه، وهذا يدل على أنهما أعلى جزاء الخائف لمقامه، فرتّب الجزاء المذكور على الخوف ترتيب المسبب على سببه، ولما كان الخائفون على نوعين مُقرّبين وأصحاب يمين ذكر جنتي المُقرّبين، ثم ذكر جنتي أصحاب اليمين.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٣/٣٣٨-٣٣٩).</div></p><p><h3><span class="qpc-hafs">﴿وَمِن دُونِهِمَا جَنَّتَانِ ۝٦٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٤٩<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النبي ﷺ، قال: «<b>جنتان من فِضّة آنِيتهما وما فيهما، وجنتان من ذهب آنِيتهما وما فيهما، وما بين القوم وبين أن يَنظُروا إلى ربهم إلا رِداء الكبرياء على وجهه في جنة عَدن</b>»{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٣٣٣، ٢٢/٢٥٣، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٦١ (٢٠٣)-.تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٦.تفسير البغوي ٧/٤٥٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢٠٤.تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٦.أخرجه ابن جرير ٢٢/٢٥٤.أخرجه البخاري ٦/١٤٥ (٤٨٧٨) باب قوله: <span class="qpc-hafs">﴿ومن دونهما جنتان﴾</span>، ٩/١٣٢ (٧٤٤٤)، ومسلم ١/١٦٣ (١٨٠)، والثعلبي ٦/٢٠١-٢٠٢.
  55,62,""
  55,62,""
  55,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُدۡهَاۤمَّتَانِ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٥٠<span class="dash">-</span></span> عن أبي أيوب الأنصاري، قال: سألت النبيَّ ﷺ عن قوله: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span>، قال: «<b>خضراوان</b>»{1}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥١<span class="dash">-</span></span> عن <span class="name-1">أبي أيوب الأنصاري</span>، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> هما جنتان خضراوان{2}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span>، قال: خضروان{3}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> قد اسودتا من الخضرة؛ من الرّيّ من الماء{4}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزبير</span> -من طريق جارية- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خضراوان من الريّ{5}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٥<span class="dash">-</span></span> عن يحيى بن سلمة، عن أبيه، قال: سمعتُ <span class="name-1">عبد الله بن أبي أوْفى</span> في قوله: <span class="qpc-hafs">﴿مدهامتان﴾</span> قال: خَضْراوان{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان{7}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> علاهما الرِّيّ من السواد والخُضرة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> مُسْودّتان{9}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان{10}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦١<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>، قالا: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> سَوداوان من الرِّيّ{11}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان{12}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> سَوداوان من الرِّيّ{13}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> ناعمتان{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٥<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span> -من طريق إدريس، عن أبيه- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان من الرِّيّ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٦<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span>، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> هما جنتان خَضْراوان{16}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل بن أبي خالد- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان من الرِّيّ، ناعمتان، إذا اشتدّت الخُضْرة ضربت إلى السواد{17}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان من الرِّيّ، ناعمتان، إذا اشتدّت الخُضْرة ضربت إلى سواد{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿مدهامتان﴾</span>، قال: كثرة الشجر وخُضرته{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٠<span class="dash">-</span></span> عن <span class="name-3">أبي سنان [سعيد بن سنان البرجمي]</span> -من طريق مهران- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> مُسْودَّتان من الرِّيّ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نَعَتهما، فقال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> سَوداوان مِن الرِّيّ والخُضْرة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>: جنتا السابقين، فقرأ: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، فقرأ حتى بلغ: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span>، ثم رجع إلى أصحاب اليمين، فقال: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span>، فذكر فضلهما وما فيهما، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> من الخُضْرة؛ من شدة خُضْرتهما، حتى كادتا تكونان سَوداوين{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عدي في الكامل في الضعفاء ٨/٣٧٢ (٢٠٠٩)، والطبراني في الكبير ٤/١٨٠ (٤٠٧٤)، من طريق سعيد بن مسلمة، عن واصل بن السّائِب، عن أبي سورة، عن أبي أيوب به.</p><p>قال ابن القيسراني في ذخيرة الحفاظ ٣/١٤٤١ (٣١٥٩): «واصل هذا متروك الحديث». وقال الهيثمي في المجمع ٧/١١٨ (١١٣٩٢): «فيه واصل بن السّائِب، وهو متروك».عزاه السيوطي إلى هناد، وعبد بن حميد.أخرجه ابن جرير ٢٢/٢٥٥-٢٥٦، ومن طريق سعيد بن جُبَير أيضًا، وهناد (٤٢). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٢/٢٥٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٥٥، وابن أبي شيبة ١٣/١٣١، وهناد (٤١). وعزاه السيوطي إلى عبد بن حميد، والفريابي.أخرجه ابن المبارك في الزهد ١/٥٢٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٣٩-، وابن جرير ٢٢/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٥٦.تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ١٣/١٣٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٥- عن مجاهد. وعزاه السيوطي إلى عبد بن حميد.أخرجه الخطيب في المتفق والمفترق (٦٩١).أخرجه هناد (٤٣).أخرجه ابن جرير ٢٢/٢٥٧.أخرجه ابن جرير ٢٢/٢٥٦.أخرجه ابن أبي شيبة ١٣/١٣٢، وهناد (٣٩-٤٠). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٥٦ مقتصرًا على أوله. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٥٧، وبنحوه من طريق سعيد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.أخرجه ابن جرير ٢٢/٢٥٧.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥٧-٢٥٨.
