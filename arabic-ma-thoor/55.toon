  55,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَخۡرُجُ مِنۡهُمَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٢٦<span class="dash">-</span></span> قال <span class="name-2">يحيى بن يَعْمَر</span>: <span class="qpc-hafs">﴿يَخْرُجُ مِنهُما﴾</span>، أي: مِن أحدهما{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَخْرُجُ مِنهُما﴾</span> من الماءين جميعًا؛ ماء الملح وماء العَذب، ومن ماء السماء{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير ابن أبي زمنين ٤/٣٢٨.تفسير مقاتل بن سليمان ٤/١٩٧-١٩٨.
  55,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱللُّؤۡلُؤُ وَٱلۡمَرۡجَانُ ۝٢٢ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عمرو بن ميمون الأَوْدي- قال: <span class="qpc-hafs">﴿اللُّؤْلُؤُ والمَرْجانُ﴾</span>، المرجان: حَجرٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- قال: المرجان: الخَرز الأحمر{2}. (١٤/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق سفيان، عن جابر، عن عبد الله بن نُجيّ- قال: <span class="qpc-hafs">﴿اللُّؤْلُؤُ﴾</span> العظام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق زهير، عن جابر، عن عبد الله بن نُجيّ- قال: المرجان: عظام اللؤلؤ{4}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق إسرائيل، عن جابر الجعفي، عن عبد الله بن يحيى{5}- قال: <span class="qpc-hafs">﴿اللُّؤْلُؤُ﴾</span> الصغار منه، <span class="qpc-hafs">﴿والمرجان﴾</span> العِظام{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: المرجان: عظام اللؤلؤ{7}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: اللؤلؤ: ما عظُم منه. والمرجان: اللؤلؤ الصغار{3}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿يَخْرُجُ مِنهُما اللُّؤْلُؤُ﴾</span>، قال: إذا أمطرت السماء فَتَحت الأصدافُ في البحر أفواهها، فما وقع فيها مِن قَطْر السماء فهو اللؤلؤ{9}. (١٤/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٦<span class="dash">-</span></span> عن عبد الله بن مَيسرة الحرّاني، قال: حدَّثني شيخ بمكة من أهل الشام أنه سمع <span class="name-2">كعب الأحبار</span> يُسأل عن المرجان، فقال: هو البُسَّذ{10}<span class=comment-ref>٦٣٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٧٤</span> ذكر <u>ابن جرير</u> (٢٢/٢٠٦) هذا القول، ثم <span class="comment-type-4">علّق</span> قائلًا: «البُسَّذُ له شُعبٌ، وهو جنس من اللؤلؤ».</div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خُثَيْم</span>، قال: اللؤلؤ: الصغار منه. والمرجان: الكبار منه{11}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٨<span class="dash">-</span></span> عن <span class="name-2">مُرّة الهَمداني</span> -من طريق موسى بن أبي عائشة- قال: المرجان: جيد اللؤلؤ{12}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٣٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: إذا نزل القَطْر من السماء تَفتّحتْ له الأصداف، فكان لؤلؤًا{13}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: المرجان: ما عظُم من اللؤلؤ{4}. (١٤/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: اللؤلؤ: عظام اللؤلؤ. والمرجان: اللؤلؤ الصغار{15}. (١٤/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: اللؤلؤ: العظام. والمرجان: الصغار{16}. (١٤/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عبد الرحمن بن الأصبهاني- قال: ما نَزَلَتْ قطرة من السماء في البحر إلا كانت بها لؤلؤة، أو نَبتَت بها عنبرة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>-من طريق السُّديّ-: أنّ المرجان: الخَرز الأحمر{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: اللؤلؤ: العِظام، والمرجان: الصغار{19}. (١٤/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: اللؤلؤ: عظام اللؤلؤ. والمرجان: صغار اللؤلؤ{20}. (١٤/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يَخْرُجُ مِنهُما اللُّؤْلُؤُ والمَرْجانُ﴾</span>: أما اللؤلؤ فعظامه، وأما المرجان فصغاره، وإنّ لله فيهما خِزانة دُلّ عليها عامة بني آدم، فأَخرَجوا متاعًا ومنفعة وزينة، وبُلْغةً إلى أجل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٨<span class="dash">-</span></span> قال <span class="name-2">عطاء الخُراسانيّ</span>: <span class="qpc-hafs">﴿يَخْرُجُ مِنهُما اللُّؤْلُؤُ والمَرْجانُ﴾</span> هو البُسَّذ{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اللُّؤْلُؤُ﴾</span> الصغار، <span class="qpc-hafs">﴿والمَرْجانُ﴾</span> يعني: الدُّرّ العظام، <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ﴾</span> يعني: نعماء <span class="qpc-hafs">﴿رَبِّكُما تُكَذِّبانِ﴾</span> فهذا مِن النِّعَم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج بن محمد- أنه قرأ: <span class="qpc-hafs">﴿يَخْرُجُ مِنهُما اللُّؤْلُؤُ والمَرْجانُ﴾</span>، قال: إذا مَطرت السماء فَتَحت الأصدافُ أفواهَها، فحيث وقَعَت قَطْرةٌ كانت لؤلؤة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: المرجان: هو اللؤلؤ الصغار{25}<span class=comment-ref>٦٣٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٧٥</span> اختُلف في صفة اللؤلؤ والمرجان على أقوال: <b>الأول</b>: أنّ اللؤلؤ: ما عظم من الدُّر، والمرجان: ما صغر منه. <b>الثاني</b>: أنّ المرجان من اللؤلؤ: الكبار، واللؤلؤ منها: الصغار. <b>الثالث</b>: أنّ المرجان: جيد اللؤلؤ. <b>الرابع</b>: أنّ المرجان حجر.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/٢٠٨) أنّ اللؤلؤ هو ما يخرج من أصداف البحر من الحبّ، فقال <span class="mustanad">مستندًا إلى اللغة</span>: «والصواب من القول في اللؤلؤ: أنه هو الذي عرفه الناس مما يخرج من أصداف البحر من الحبّ».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٣/٣١٨).</p><p>وأما المرجان فقد <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> على الأقوال الواردة فيه بقوله: «وأما المرجان فإني رأيتُ <span class="mustanad">أهل المعرفة بلسان العرب لا يتدافعون</span> أنه جمع مرجانة، وأنه الصغار من اللؤلؤ، وقد ذكرنا ما فيه من الاختلاف بين متقدمي أهل العلم».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (١٦٧/٢٢٨) في اللؤلؤ ما جاء في القول الثاني، فقال: «والوصف بالصّغر هو الصواب في اللؤلؤ». و<span class="comment-type-3">رجّح</span> في المرجان أنه حجرٌ أحمر، فقال: «وقال ابن مسعود وغيره: المرجان: حجر أحمر. وهذا هو الصواب في المرجان». ولم يذكر فيهما مستندًا.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٠٧.أخرجه عبد الرزاق ٢/٢٦٣، والطبراني (٩٠٥٨). وعزاه السيوطي إلى ابن جرير، والفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٠٥.أخرجه ابن جرير ٢٢/٢٠٧. وعزاه السيوطي إلى عبد بن حميد.كذا في المصدر، ولعل الصواب: عبد الله بن نُجيّ.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٣٧-.أخرجه ابن جرير ٢٢/٢٠٦، وبنحوه من طريق مجاهد. وعزاه السيوطي إلى الفريابي، وهناد بن السري، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٠٥.أخرجه ابن جرير ٢٢/٢٠٨، وابن أبي الدنيا في كتاب المطر (٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٠٦. وفي اللسان (مرج، بسذ): البُسَّذ: المرجان، وهو جوهر أحمر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٣، وابن جرير ٢٢/٢٠٧. وعزاه السيوطي إلى عبد بن حميد. وفي لفظ عند ابن جرير ٢٢/٢٠٦ من طريق موسى بن أبي عائشة، أو قيس بن وهب: المرجان: اللؤلؤ العظام.عزاه السيوطي إلى ابن جرير، وابن المنذر. و أخرج ابن جرير ٢٢/٢٠٩ نحوه عن ابن عباس من طريق سعيد بن جبير كما تقدم.أخرجه ابن جرير ٢٢/٢٠٧. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن جرير ٢٢/٢٠٥. وعزاه السيوطي إلى عبد بن حميد، وابن جرير.أخرجه ابن جرير ٢٢/٢٠٩.تفسير الثعلبي ٩/١٨١.أخرجه ابن جرير ٢٢/٢٠٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٣، وابن جرير ٢٢/٢٠٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٠٥.تفسير الثعلبي ٩/١٨١، وتفسير البغوي ٧/٤٤٥.تفسير مقاتل بن سليمان ٤/١٩٧-١٩٨.أخرجه الثعلبي ٩/١٨١، وتفسير البغوي ٧/٤٤٥.أخرجه ابن جرير ٢٢/٢٠٦.
  55,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَهُ ٱلۡجَوَارِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٥٢<span class="dash">-</span></span> عن عَميرة بن سعد، قال: كُنّا مع <span class="name-1">عَلِيّ [بن أبي طالب]</span> على شَطّ الفُرات، فمَرّتْ به سفينة، فقرأ هذه الآية: <span class="qpc-hafs">﴿ولَهُ الجَوارِ المُنْشَآتُ فِي البَحْرِ كالأَعْلامِ﴾</span>{1}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ولَهُ الجَوارِ المُنْشَآتُ﴾</span>، قال: هي السَّفائِن{2}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿ولَهُ الجَوارِ﴾</span>، قال: السّفن{3}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولَهُ الجَوارِ المُنْشَآتُ﴾</span>: يعني: السِّفَن{4}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَهُ الجَوارِ﴾</span>، يعني: السُّفن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَهُ الجَوارِ المُنْشَآتُ فِي البَحْرِ كالأَعْلامِ﴾</span>: يعني: السّفن{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡمُنشَـَٔاتُ فِی ٱلۡبَحۡرِ﴾</span> - قراءات الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٥٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٥٩<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span> أنهما كان يقرآن: ‹المُنشِآتُ›، قال: أي: الفاعلات{7}<span class=comment-ref>٦٣٧٦</span>. (١٤/١١٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٧٦</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (٢٢/٢١٠) القراءتين، فقال: «اختلفت القراء في قراءة ذلك، فقرأته عامة قُراء الكوفة: ‹المُنشِآتُ› بكسر الشين، بمعنى: الظاهرات السير اللاتي يُقبلن ويُدبرن. وقرأ ذلك عامة قراء البصرة والمدينة وبعض الكوفيين: <span class="qpc-hafs">﴿المُنشَآتُ﴾</span> بفتح الشين، بمعنى: المرفوعات القلاع اللاتي تقبل بهن وتدبر».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/١٦٩) في توجيهه قراءة الكسر، و<span class="comment-type-1">وجّه</span> قراءة الفتح، فقال: «وقرأ ابن كثير ونافع وأبو عمرو وابن عامر والكسائي: <span class="qpc-hafs">﴿المُنشَآتُ﴾</span> بفتح الشين، أي: أنشأها الله والناس».</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> أنهما: «قراءتان <span class="mustanad">معروفتان صحيحتا المعنى متقاربتاه</span>، فبأيّتهما قرأ القارئ فمصيب».</div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَهُ الجَوارِ المُنْشَآتُ فِي البَحْرِ كالأَعْلامِ﴾</span> قال: المنشآت ما رُفع قِلْعُه من السفن، فأما ما لم يُرفع قِلْعه فليس بمنشآت{8}<span class=comment-ref>٦٣٧٧</span>. (١٤/١١٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٧٧</span> ذكر <u>ابن عطية</u> (٨/١٦٩) قول مجاهد، ثم <span class="comment-type-1">وجّهه</span> بقوله: «وقوله: <span class="qpc-hafs">﴿كالأعلام﴾</span> هو الذي يقتضي هذا الفرق»، ثم قال: «وأما لفظة <span class="qpc-hafs">﴿المنشآت﴾</span> فيعم الكبير والصغير».</div></p><p><div></p><p><p><span class="item-no">٧٤٢٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿المُنْشَآتُ﴾</span>، قال: بالشّراع{3}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٢<span class="dash">-</span></span> عن <span class="name-2">عاصم</span>، أنه قرأها على الوجهين: <span class="qpc-hafs">﴿المُنشَآتُ﴾</span>، و‹المُنشِآتُ› بكسر الشين وفتحها{2}. (١٤/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٣<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> أنه كان يقرؤها: ‹المُنشِآتُ›، يعني: الباديات{2}. (١٤/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿المُنْشَآتُ﴾</span>، يعني: المخلوقات{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، والمحاملي في أماليه.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢١١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٩٨.أخرجه ابن جرير ٢٢/٢١١.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.</p><p>و‹المُنشِآتُ› بكسر الشين قراءة متواترة، قرأ بها حمزة، وشعبة بخلف عنه، وقرأ بقية العشرة وشعبة في الرواية الثانية عنه: <span class="qpc-hafs">﴿المُنشَآتُ﴾</span> بفتح الشين. انظر: النشر ٢/٣٨١، والإتحاف ص٥٢٧.تفسير مجاهد ص٦٣٧. وأخرجه الفريابي - كما في تغليق التعليق ٤/٣٣٠، وابن جرير ٢٢/٢١٠. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٩٨.
  55,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَٱلۡأَعۡلَـٰمِ ۝٢٤ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿كالأَعْلامِ﴾</span>، قال: كالجبال{1}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كالأَعْلامِ﴾</span>، قال: كالجبال{2}. (١٤/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي البَحْرِ كالأَعْلامِ﴾</span> يعني: كالجبال، يُشبّه السّفن في البحر كالجبال في البَرّ، فكانت السّفن من النّعم، ثم قال: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> يعني: نعماء ربكما تُكذّبان{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢١١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٩٨.
  55,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُّ مَنۡ عَلَیۡهَا فَانࣲ ۝٢٦﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٦٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: لَمّا أُنزِلَتْ هذه الآية: <span class="qpc-hafs">﴿كُلُّ مَن عَلَيْها فانٍ﴾</span> قالت الملائكة: هَلك أهل الأرض. فأنزل الله تعالى: <span class="qpc-hafs">﴿كُلُّ شَيْءٍ هالِكٌ إلّا وجْهَهُ﴾</span> [القصص:٨٨] فأيقَنتِ الملائكة بالهلاك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٦٩<span class="dash">-</span></span> عن عيسى المدني، قال: سمعتُ علي بن الحُسين سأل <span class="name-2">كعب الأحبار</span> عن قول الله ﷿: <span class="qpc-hafs">﴿فصعق من في السماوات ومن في الأرض إلا من شاء الله﴾</span> [الزمر:٦٨]. قال: الذين استثنى الله: جبريل، وميكائيل، وحمَلة العرش، ومَلك الموت. قال: فيأتي مَلك الموت، فيَقبض أرواح هؤلاء حتى لا يبقى غيره وربُّ العزّة -جل وعزّ-، فيقول: يا مَلك الموت، مُتْ. فيموت، فذلك قوله: <span class="qpc-hafs">﴿كل من عليها فان ويبقى وجه ربك ذو الجلال والإكرام﴾</span>، وذلك قوله: <span class="qpc-hafs">﴿كل شيء هالك إلا وجهه﴾</span> [القصص:٨٨]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كُلُّ مَن عَلَيْها فانٍ﴾</span> يعني: مَن على الأرض من الحيوان هالك، <span class="qpc-hafs">﴿ويَبْقى وجْهُ رَبِّكَ ذُو الجَلالِ والإكْرامِ﴾</span> فلما نَزَلَتْ هذه الآية قالت الملائكة الذين في السماء: هَلك أهل الأرض! العَجب لهم كيف تنفعهم المعيشة؟! حتى أنزل الله: <span class="qpc-hafs">﴿كُلُّ شَيْءٍ هالِكٌ إلّا وجْهَهُ﴾</span> [القصص:٨٨] يعني: كلّ شيء مِن الحيوان في السموات والأرض يموت إلا الله، فأيقنوا عند ذلك كلّهم بالهلاك{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٨٢.أخرجه أبو جعفر محمد بن عثمان بن أبي شيبة في العرش وما روي فيه ص٤٠٢-٤٠٣ (٤٢).تفسير مقاتل بن سليمان ٤/١٩٨.
  55,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَبۡقَىٰ وَجۡهُ رَبِّكَ ذُو ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٧١<span class="dash">-</span></span> قال عبد الله بن سلام: بعث إلَيَّ النبيُّ ﷺ، فقال: «<b>يا ابن سلام، إنّ الله ﷿ يقول: <span class="qpc-hafs">﴿ذُو الجَلالِ والإكْرامِ﴾</span>، فأمّا الإكرام فقد عرفتُ، فما الجلال؟</b>» فقال: بأبي أنت، إنّا نجد في الكتب أنّها الجنة{1} المحيطة بالعرش. قال: «<b>فكم بينهما وبين الجنان التي يُسكن الله عباده</b>؟». قال: مدى سبعمائة سنة. قال: فنزل جبريل بتصديقه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ذُو الجَلالِ والإكْرام﴾</span>، قال: ذو الكبرياء والعظمة{3}. (١٤/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، قال: إذا قرأتَ: <span class="qpc-hafs">﴿كُلُّ مَن عَلَيْها فانٍ﴾</span> فلا تسكُتْ حتى تقرأ: <span class="qpc-hafs">﴿ويَبْقى وجْهُ رَبِّكَ ذُو الجَلالِ والإكْرام﴾</span>{4}. (١٤/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٤<span class="dash">-</span></span> عن حُمَيْد بن هلال -من طريق أيوب- قال: قال رجل: يرحم الله رجلًا أتى على هذه الآية: <span class="qpc-hafs">﴿ويَبْقى وجْهُ رَبِّكَ ذُو الجَلالِ والإكْرام﴾</span>، فسأل الله تعالى بذلك الوجه الكافي الكريم. ولفظ البيهقي: بذلك الوجه الباقي الجميل{5}. (١٤/١١٨)</p></p><p></div></p></div>",footnotes:1:في طبعة دار التفسير ٢٥/٣٢٢: الحية.أخرجه الثعلبي ٩/١٨٣، من طريق الحارث بن عبد الله، عن عبد الرّحمن بن عثمان الوقاصي، عن محمد بن كعب القُرَظيّ، عن عبد الله بن سلام به.</p><p>وفي سنده عبد الرحمن بن عثمان الوقاصي، لم نجد من وثّقه. وذكره ابن حبان في الثقات ٧/٨٤.أخرجه ابن جرير ٢٢/٢٧٨، وأبو الشيخ في العظمة (٧٧)، والبيهقي في الأسماء والصفات (١٥٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في الأسماء والصفات ٢/١١٣ (٦٦٧). وعزاه السيوطي إلى ابن المنذر.
  55,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَسۡـَٔلُهُۥ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٢٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يَسْأَلُهُ مَن فِي السَّماواتِ والأَرْضِ﴾</span>: يعني: مسألة عباده إياه الرّزق والموت والحياة{1}. (١٤/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿يَسْأَلُهُ مَن فِي السَّماواتِ والأَرْضِ﴾</span> أهل السموات يسألونه المغفرة، ولا يسألونه الرِّزق، وأهل الأرض يسألونه الرّزق والمغفرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٧<span class="dash">-</span></span> عن <span class="name-2">عبيد الله بن أبي نَهيك</span> -من طريق الفضل بن موسى- <span class="qpc-hafs">﴿يسأله من في السموات والأرض كل يوم هو في شأن﴾</span>، قال: يُسأل كلّ يوم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَسْئَلُهُ مَن فِي السَّماواتِ والأَرْضِ﴾</span>، يعني: يسأل أهلُ الأرض اللهَ الرّزق، وتسأل الملائكةُ أيضًا لهم الرّزق والمغفرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٢٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في الآية: <span class="qpc-hafs">﴿يَسْئَلُهُ مَن فِي السَّماواتِ والأَرْضِ﴾</span>، قال: الملائكة يسألونه الرّزقَ لأهل الأرض، ويسأله أهلُها الرّزقَ لهم{5}<span class=comment-ref>٦٣٧٨</span>. (١٤/١١٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٧٨</span> ذكر <u>ابنُ عطية</u> (٨/١٧٠) في قوله: <span class="qpc-hafs">﴿يسأله﴾</span> احتمالين، و<span class="comment-type-1">وجّههما</span>، فقال: «قوله: <span class="qpc-hafs">﴿يسئله﴾</span> <b>يحتمل</b> أن يكون في موضع الحال من الوجه، والعامل فيه <span class="qpc-hafs">﴿يبقى﴾</span> أي: هو دائم في هذه الحال. و<b>يحتمل</b> أن يكون فعلًا مستأنفًا إخبارًا مجردًا، والمعنى: أنّ كلّ مخلوق من الأشياء فهو في قوامه وتمسّكه ورزقه إن كان مما يرزق بحال حاجة إلى الله تعالى، فمن كان يسأل بنطق فالأمر فيه بيّن، ومن كان من غير ذلك فحاله تقتضي السؤال، فأسند فعل السؤال إليه».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢١٢. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٩/١٨٣، وتفسير البغوي ٧/٤٤٥.أخرجه أبو الشيخ في العظمة ٢/٤٨٧-٤٨٨ (١٥٤).تفسير مقاتل بن سليمان ٤/١٩٨-١٩٩.عزاه السيوطي إلى ابن المنذر.
