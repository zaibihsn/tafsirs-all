  55,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا عَیۡنَانِ نَضَّاخَتَانِ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٧٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالمِسك والكافور على أولياء الله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span>، قال: فائضتان{2}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالماء من شدّة الرِّيّ{3}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- يقول: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> نَضّاخَتان بالخير{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٧<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span>، قال: العينان اللّتان تَجْريان خير مِن النَّضّاخَتين{5}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٨<span class="dash">-</span></span> عن يحيى بن سلمة، عن أبيه، قال: سمعتُ <span class="name-1">عبد الله بن أبي أوْفى</span> في قوله: <span class="qpc-hafs">﴿نضاختان﴾</span>، قال: نَضّاخَتان بالخير{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٩<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span>، قال: بالمِسك والعنبر، تَنضَخان على دُور الجنَّة كما يَنضَخ المطر على دُور أهل الدنيا{7}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بألوان الفاكهة{8}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سلمة- <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span>، قال: بكلّ خير{9}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> مُمتلئتان لا تنقطعان{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي الأحوص، عن سِماك- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالماء هوامش أنهار الجنة{11}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالخير{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾</span> مملوءتان مِن كلّ خير، لا ينتقصان{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالماء{14}<span class=comment-ref>٦٤٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٦</span> للسلف في قوله: <span class="qpc-hafs">﴿نضاختان﴾</span> أقوال: <b>الأول</b>: تَنضَخان الماء. <b>الثاني</b>: تَنضَخان الماء والفاكهة. <b>الثالث</b>: نَضّاخَتان بألوان الفاكهة. <b>الرابع</b>: نَضّاخَتان بالخير. <b>الخامس</b>: ممتلئتان.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/٢٦٠) -<span class="mustanad">مستندًا إلى المعروف في اللغة</span>- القول الأول، وعلّل ذلك بقوله: «لأنه المعروف بالعيون إذ كانت عيون ماء».</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٨/١٨١) أنّ <span class="qpc-hafs">﴿نضاختان﴾</span> معناه: «الفوارة: التي يهيج ماؤها». و<span class="comment-type-2">انتقد</span> القول الثالث بقوله: «وهذا ضعيف». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٧.أخرجه ابن جرير ٢٢/٢٥٩، وابن أبي حاتم -كما في تغليق التعليق ٣/٥٠٢ بلفظ: فيّاضتان، وكما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٦٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقال: ولفظ ابن حميد: قال: ما النضاختان بأفضل من اللتين تجريان.أخرجه ابن المبارك في الزهد ١/٥٢٦.أخرجه ابن أبي شيبة ٤/٥١٨، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٣٥ (٧٠)-. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن المبارك في الزهد (١٥٣٥ زيادات الحسين)، وابن جرير ٢٢/٢٥٩، وابن أبي شيبة ١٣/١٣٣، وأبو نعيم في الحلية ٤/٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ١٣/١٣٢. وعزاه السيوطي إلى عبد بن حميد بلفظ: بالخير.أخرجه ابن جرير ٢٢/٢٥٩.أخرجه هناد في الزهد (٩٧)، وابن جرير ٢٢/٢٥٨ مختصرًا بلفظ: فياضتان.أخرجه عبد الرزاق ٢/٢٦٦.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥٨.
