  55,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا عَیۡنَانِ تَجۡرِیَانِ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٥٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ الله اختار مِن الملائكة أربعة: جبريل، وميكائيل، وإسرافيل، وعزرائيل</b>». وذكر الحديث حتى قال: «<b>واختار من العيون أربعة، يقول في محكم كتابه: <span class="qpc-hafs">﴿فيهما عينان تجريان﴾</span>، وقال: <span class="qpc-hafs">﴿فيهما عينان نضاختان﴾</span></b> [الرحمن:٦٦]، <b>فأما التي تجريان: فعين بَيْسان، وعين سُلْوان، وأما النَّضّاختان: فعين زمزم، وعين عَكا</b> ...»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: تَجْريان بالزيادة والكرامة مِن الله تعالى على أهل الجنة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: تجريان بالماء الزّلال، إحداهما التّسنيم، والأخرى السّلسبيل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٩<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: إحداهما من ماء غير آسِن، والأخرى من خمرٍ لذّةٍ للشاربين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِما عَيْنانِ تَجْرِيانِ﴾</span> في [غير]{5}] أخدود، من ماء غير آسِن{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخه ١/٢٢١-٢٢٢، من طريق أبي الفضل العباس بن ميمون، عن أبي محمد المراغي، عن قتيبة، عن أبي عوانة، عن الأعمش، عن أبي صالح، عن أبي هريرة به.</p><p>قال ابن عساكر: «هذا حديث منكر بمرّة، وأبو الفضل والمراغي مجهولان». وأورده الكناني في تنزيه الشريعة ٢/٦٥.تفسير الثعلبي ٩/١٨٩، وتفسير البغوي ٧/٤٥٢.تفسير الثعلبي ٩/١٨٩، وتفسير البغوي ٧/٤٥٢.تفسير الثعلبي ٩/١٩٠، وتفسير البغوي ٧/٤٥٢.[في المطبوع: عين.تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,50,""
  55,50,""
  55,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا مِن كُلِّ فَـٰكِهَةࣲ زَوۡجَانِ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق أبي الهُذيل- قال: العنقود أبعد من صنعاء{1}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span> فما في الدنيا ثمرة حُلوة ولا مُرّة إلا وهي في الجنة، حتى الحَنظل{2}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span>، قال: فيهما من كلّ الثمرات{3}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ﴾</span> مِن كلّ لون من ألوان الفاكهة <span class="qpc-hafs">﴿زَوْجانِ﴾</span> يعني: صِنفان{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٣/٩٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقد أخرج ابن أبي حاتم ٢/٥٢٣ نحوه عن عكرمة من طريق الحكم بن أبان، في تفسير قوله تعالى: <span class="qpc-hafs">﴿لَهُ فِيها مِن كُلِّ الثَّمَراتِ﴾</span> [البقرة:٢٦٦].عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,52,""
  55,52,""
  55,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٦٥<span class="dash">-</span></span> عن الضَّحّاك، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (مُتَّكِئِينَ عَلى سُرُرٍ وفُرُشٍ بَطَآئِنُها مِن رَّفْرَفٍ مِّنْ إسْتَبْرَقٍ){1}. (١٤/١٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق هُبَيرة بن يَرِيم- <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span>، قال: أُخبرتم بالبَطائن، فكيف بالظّهائر؟!{2}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٧<span class="dash">-</span></span> قال <span class="name-1">أبو هريرة</span>: <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span> هذه البَطائن، فما ظنّكم بالظّواهر؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنه قيل له: <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span>، فما الظواهر؟ قال: ذاك مما قال الله: <span class="qpc-hafs">﴿فَلا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ﴾</span> [السجدة:١٧]{4}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>-من طريق جعفر- أنه قيل له: البَطائن مِن إسْتَبرق، فما الظواهر؟ قال: هذا مما قال الله سبحانه: <span class="qpc-hafs">﴿فَلا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ﴾</span> [السجدة:١٧]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span>، قال: ظواهرها من نور جامد{6}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿بطائنها من إستبرق﴾</span>، قال: الديباج. وفي لفظ: والإسْتَبرق لغة فارس، يُسمُّون الدِّيباج الغليظ: الإسْتَبرق{7}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق قتادة- <span class="qpc-hafs">﴿مِن إسْتَبْرَقٍ﴾</span>، قال: الدِّيباج الغليظ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span> بَطائنها يعني: ما يلي جلودهم، والإسْتَبرق: الصّفيق من الدِّيباج{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿مِن إسْتَبْرَقٍ﴾</span>، قال: هو غليظ الدِّيباج{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٥<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي إسحاق</span>، قال: قال لي سالم بن عبد الله: ما الإسْتَبرق؟ قال: قلتُ: ما غلُظ من الديباج وخشُن منه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى فُرُشٍ بَطائِنُها مِن إسْتَبْرَقٍ﴾</span> يعني: ظاهرها من الدِّيباج الأخضر، فوق الفُرُش الدِّيباج، وهي بلغة فارس، نظيرها في آخر السورة: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> يعني: المحابس الخُضر على الفُرُش{12}<span class=comment-ref>٦٣٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٨</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٢/٢٤٢-٢٤٤) أن قوله: <span class="qpc-hafs">﴿بطائنها من إستبرق﴾</span> معناه: أنّ بطائن هذه الفُرُش من غليظ الدِّيباج، <span class="mustanad">ودلّل على ذلك بآثار السلف</span>. ثم أورد عن بعض أهل اللغة -وهو موافق لما جاء في قول مقاتل، وقول سعيد بن جُبَير في الأثر في تفسير الآية- أنّ البطائن هاهنا بمعنى: الظواهر. و<span class="comment-type-1">وجّهه</span>، فقال: «وقد زعم أهل العربية أنّ البطانة قد تكون ظهارة، والظهارة تكون بطانة، وذلك أنّ كل واحد منهما قد يكون وجهًا، قال: وتقول العرب: هذا ظهر السماء، وهذا بطن السماء لظاهرها الذي نراه».</div></p><p><h3><span class="qpc-hafs">﴿وَجَنَى ٱلۡجَنَّتَیۡنِ دَانࣲ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٧٧<span class="dash">-</span></span> عن علي بن أبي طالب، أن رسول الله ﷺ قال: «<b>... وفيها ثمار متدلّية، إذا اشتَهَوها انشَعب الغُصن إليهم، فيأكلون مِن أيّ الثمار اشتَهوا؛ إن شاء قائمًا، وإن شاء مُتكئًا، وذلك قول الله ﷿: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span>...</b>»{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span>، قال: جَناها: ثمرها، والداني: القريب منك، يناله القائم والقاعد{14}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span> ما يُجتنى من قريب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span>، قال: دانٍ ثمارها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span> ثمارها دانية، لا يرُدّ أيديهم عنها بُعدٌ ولا شوك. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «<b>والذي نفس محمد بيده، لا يَقْطِف رجلٌ ثمرة من الجنة فتَصل إلى فِيه، حتى يُبدّل الله مكانها خيرًا منها</b>»{17}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span> يعني: ثمره، وجنى الشجر في الجنتين دانٍ. يقول: ما يُجتنى في الجنتين دانٍ. يقول: طول الشجر لهذا المجتني قريب، يتناوله الرجل إن شاء جالسًا، وإن شاء متكئًا أو قائمًا{12}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة. انظر: روح المعاني ٢٧/١١٨.أخرجه ابن جرير ٢٢/٢٤٣ بنحوه، والحاكم ٢/٤٧٥، والبيهقي في البعث (٣٣٩)، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٥)-. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وعبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم، وابن مردويه.تفسير الثعلبي ٩/١٩٠، وتفسير البغوي ٧/٤٥٣.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٢/٢٤٤.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٦)-، وأبو نعيم في الحلية ٤/٢٨٥-٢٨٦.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٧)-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.أخرجه ابن جرير ٢٢/٢٤٣.أخرجه ابن جرير ٢٢/٢٤٣.تفسير مقاتل بن سليمان ٤/٢٠٣.أخرجه ابن أبي الدنيا في صفة الجنة ص٣٥-٣٧ (٦) مطولًا، من طريق محمد بن عباد بن موسى العكلي، عن الضَّحّاك بن مُزاحِم، عن الحارث، عن علي به.</p><p>وسنده ضعيف؛ فيه الحارث بن عبد الله الأعور، قال عنه ابن حجر في تقريب التهذيب (١٠٢٩): «في حديثه ضعف».أخرجه ابن جرير ٢٢/٢٤٥ بلفظ: ثمارها دانية، والبيهقي في البعث (٣٠٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير -كما في الفتح ٦/٣٢٣-.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٤٥ (١١٦)-.أخرجه ابن جرير ٢٢/٢٤٤. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه عبد الرزاق ٢/٢٦٥ من طريق معمر مختصرًا.تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,54,""
  55,54,""
  55,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِنَّ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٨٣<span class="dash">-</span></span> عن علي بن حُسين، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span>، قال: «<b>لا يَنظُرْنَ إلّا إلى أزواجهنّ</b>»{1}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span>، يقول: مِن غير أزواجهنّ{2}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> قَصَرن طَرْفهنّ عن الرجال؛ فلا يَنظُرن إلا إلى أزواجهنّ{3}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> قاصرات الطّرف على أزواجهنّ، لا يُردْن غيرهم، واللهِ، ما هُنَّ متبرّجاتٍ ولا مُتطلِّعات{4}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{5}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِنَّ﴾</span> يعني: في هذه الجنان الأربع -في التقديم-: جنة عَدن، وجنة النعيم، وجنة الفِردَوس، وجنة المأوى، ففي هذه الجنان الأربع جنان كثيرة، في الكثرة مثل ورق الشجر ونجوم السماء، يقول: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> يعني: النساء{6}<span class=comment-ref>٦٣٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٩</span> ذكر <u>ابنُ عطية</u> (٨/١٧٩) أنّ «الضمير في قوله تعالى: <span class="qpc-hafs">﴿فِيهِنَّ﴾</span> للفُرُش». ثم نقل <b>احتمالًا</b> آخر فقال: «وقيل: للجنات؛ إذ الجنتان جنات في المعنى».</div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> لا يَنظُرن إلا إلى أزواجهنّ، تقول: وعزّة ربي وجلاله وجماله، إنْ أرى في الجنة شيئًا أحسن منك، فالحمد لله الذي جعلك زوجي، وجعلني زوجك{7}<span class=comment-ref>٦٤٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٠</span> أفادت آثار السلف أنّ قوله: <span class="qpc-hafs">﴿قاصرات الطرف﴾</span> أي: على أزواجهنَّ، فلا يُرِدْنَ غيرهم.</p><p>وقد ذكر <u>ابنُ القيم</u> (٣/٩٩) هذا، وأضاف <b>قولًا آخر</b>، فقال: «وقيل: قَصرن طرف أزواجهنّ عليهن، فلا يدعهم حُسنهنّ وجمالهن أن ينظروا إلى غيرهن». و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا صحيح من جهة المعنى، وأما <span class="mustanad">من جهة اللفظ</span>: فـ<span class="qpc-hafs">﴿قاصرات﴾</span> صفة مضافة إلى الفاعل الحِسان الوجوه، وأصله: قاصر طرفهن، أي: ليس بطامح مُتعدّ».</div></p><p><h3><span class="qpc-hafs">﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٩٠<span class="dash">-</span></span> عن عِياض بن غَنْم، أنه سمع رسول الله ﷺ تلا: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: «<b>لم يُصِبْهُنَّ شمسٌ ولا دُخان، لم يُعَذَّبْنَ في البلايا، ولم يُكْلَمْنَ في الرّزايا، ولم تغيّرهن الأحزان، ناعمات لا يبأسن، وخالدات فلا يمُتن، ومُقيمات فلا يَظعنَّ، لهنّ أخبار يَعجِز عن نعتهنّ الأوهام، والجنة أخضرها كالأصفر، وأصفرها كالأخضر، ليس فيها حَجرٌ ولا مَدرٌ ولا كَدرٌ، ولا عود يابس، أُكُلها دائم، وظِلّها قائم</b>»{1}. (١٤/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق رجل- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: منذ خَلقهنّ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>، قال: لم يَدنُ منهنّ، أو لم يُدْمِهنّ{10}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>. قال: كذلك نساء الجنة، لم يَدنُ منهن غير أزواجهنّ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول:</p><p>مَشين إليَّ لم يُطْمثن قبلي وهنّ أصحّ من بَيْض النّعام؟{11}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق عاصم- أنه قال له: امرأة طامث. قال: ما طامث؟ فقال رجلٌ: حائض. فقال أبو العالية: حائض؟! أليس يقول الله ﷿: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span> لم يَطأهنّ{13}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>، قال: لم يَمسّهن{14}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من عثمان بن الأسود- قال: إذا جامع الرجلُ أهلَه ولم يُسَمِّ، انطوى الجانُّ على إحليله، فجامع معه، فذلك قوله: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>{15}. (١٤/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: هنّ مِن نساء أهل الدنيا، خَلقهنّ اللهُ في الخلْق الآخر، كما قال: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً * فَجَعَلْناهُنَّ أبْكارًا﴾</span> [الواقعة:٣٥-٣٦] لم يَطْمثهن حين عُدْنَ في الخلْق الآخر إنس قبلهم ولا جان{16}. (١٤/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق مُغيرة- قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>لم يُجامعهنّ{17}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق مُغيرة- قال: لا تقُلِ المرأة: إني طامث؛ فإن الطّمث هو الجماع، وإنّ الله -جل ثناؤه- يقول: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>{18}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠١<span class="dash">-</span></span> عن أرطاة بن المنذر، قال: تَذاكرنا عند <span class="name-2">ضمرة بن حبيب</span>: أيدخل الجنُّ الجنةَ؟ قال: نعم؛ وتصديق ذلك في كتاب الله: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span> للجنّ الجنّيات، وللإنس الإنسيّات{19}<span class=comment-ref>٦٤٠١</span>. (١٤/١٤٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠١</span> اختلف السلف في قوله: <span class="qpc-hafs">﴿لم يطمثهن إنس قبلهم ولا جان﴾</span> على قولين: <b>الأول</b>: أنّ الجنّ قد تجامع نساء البشر مع أزواجهن، إذا لم يذكر الزوج الله تعالى. <b>الثاني</b>: أنّ الجنّ لهم قاصرات الطرف من الجنّ نوعهم.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٧٩) القول الأول بقوله: «فتكون الآية على هذا نافية لجميع المجامعات». و<span class="comment-type-1">وجَّه</span> القول الثاني بقوله: «فنفى في هذه الآية الافتضاض عن البشريّات والجنِّيّات». ثم بيّن احتمال الآية <b>وجهًا آخر</b>، فقال: «ويحتمل اللفظ أن يكون مبالغة وتأكيدًا، كأنه قال: لم يطمثهنّ شيء. أراد العموم التام، لكنه صرح من ذلك بالذي يعقل منه أن يَطمث».</p><p>ولم يذكر <u>ابنُ جرير</u> (٢٢/٢٤٧-٢٤٨) في معناه غير ما ورد في قول أرطاة وما في معناه.</div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿لم يطمثهن إنس قبلهم ولا جان﴾</span>، قال: لم يضاجعهم إنسٌ قبلهم، ولا جانٌّ{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span> هنّ مِن نساء الدنيا، لم يُمْسَسْنَ منذ أُنشِئن خلقًا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span> لأنهنّ خُلِقن في الجنة مع شجر الجنة، يعني: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ﴾</span> إنس قبل أهل الجنة، <span class="qpc-hafs">﴿ولا جانٌّ﴾</span> يعني: جنّ،... <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span> لم يُدميهنّ{22}<span class=comment-ref>٦٤٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٢</span> للسلف في الموصوف بهذه الصفات قولان: <b>الأول</b>: أنهن الحور العين اللواتي أُنشئن في الجنة. <b>الثاني</b>: أنهن من نساء الدنيا.</p><p>وقد ذكر <u>ابنُ القيم</u> (٣/١٠٠-١٠١) القولين، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">-مستندًا إلى ظاهر القرآن، وإلى السياق</span>- الأول، فقال: «ظاهر القرآن أنّ هؤلاء النسوة لسنَ من نساء الدنيا، وإنما هنّ من الحُور حور العين. وأما نساء الدنيا فقد طَمثهن الإنس، ونساء الجنّ قد طَمثهن الجنّ، والآية تدل على ذلك. ويدل على أنهن الحور اللاتي خُلقن في الجنة أنه سبحانه جعلهنّ مما أعده الله في الجنة لأهلها مِن الفاكهة والثمار والأنهار والملابس وغيرها، ويدل عليه أيضًا الآية التي بعدها، وهي قوله تعالى: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، ثم قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنس قَبْلَهُمْ ولا جانٌّ﴾</span>».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١٣/١٣٠، وابن جرير ٢٢/٢٤٥. وعزاه السيوطي إلى عبد بن حميد. وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤- بلفظ: لا يبغين غير أزواجهن.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٠٣.أخرجه ابن جرير ٢٢/٢٤٦.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٤٧.أخرجه ابن جرير ٢٢/٢٤٧، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطستي (٢٥٩).أخرجه ابن جرير ٢٢/٢٤٧-٢٤٨.أخرجه ابن أبي شيبة ١٣/١٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٤٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤٨، والحكيم الترمذي في نوادر الأصول ١/٣٨٤.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن أبي شيبة ١٣/١٣١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٤٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٤٨ بنحوه، وأبو الشيخ في العظمة (١١٦٢). وعزاه السيوطي إلى ابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.تفسير البغوي ٧/٤٥٤.تفسير مقاتل بن سليمان ٤/٢٠٣-٢٠٤.
