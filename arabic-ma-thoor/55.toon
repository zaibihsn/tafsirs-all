  55,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَا تَنتَصِرَانِ ۝٣٥ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٣٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَلا تَنْتَصِرانِ﴾</span>، قال: يعني: الجنّ والإنس{1}. (١٤/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلا تَنْتَصِرانِ﴾</span> يعني: فلا تمتنعان من ذلك. فذلك قوله: <span class="qpc-hafs">﴿زِدْناهُمْ عَذابًا فَوْقَ العَذابِ﴾</span> يعني: الأنهار الخمس <span class="qpc-hafs">﴿بما كانوا يُفسدون﴾</span> [النحل:٨٨]. <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ﴾</span> يعني: نعماء <span class="qpc-hafs">﴿رَبِّكُما تُكَذِّبانِ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٦٤، وابن جرير ٢٢/٢٢٦. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٠٠.
  55,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا ٱنشَقَّتِ ٱلسَّمَاۤءُ فَكَانَتۡ وَرۡدَةࣰ كَٱلدِّهَانِ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٣٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿فَإذا انْشَقَّتِ السَّماءُ فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، قال: تغيّر لونها{1}. (١٤/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> <span class="qpc-hafs">﴿فَكانَتْ ورْدَةً﴾</span> يقول: حمراء <span class="qpc-hafs">﴿كالدِّهانِ﴾</span> قال: هو الأديم الأحمر{2}. (١٤/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- <span class="qpc-hafs">﴿فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، قال: مثل لون الفَرس الوَرْدِ{3}{4}. (١٤/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء أوس بن عبد الله</span>، <span class="qpc-hafs">﴿فَكانَتْ ورْدَةً﴾</span> قال: وردة الجلِّ{5} <span class="qpc-hafs">﴿كالدِّهانِ﴾</span> قال: صفاء الدُّهن؛ ألم تر العربي يقول: الجلُّ: الورد{6}. (١٤/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٥<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>: <span class="qpc-hafs">﴿كالدِّهانِ﴾</span> كالدُّهن{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿كالدِّهانِ﴾</span>، قال: كالدُّهن{8}. (١٤/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٥٩<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿فَكانَتْ ورْدَةً كالدِّهانِ﴾</span> شبّه تَلوّن السماء بتَلوّن الوَرد من الخيل، وشّبه الوردة في اختلاف ألوانها بالدّهن واختلاف ألوانه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، قال: حمراء كالدّابة الوَردة{10}. (١٤/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿كالدِّهانِ﴾</span>، قال: صافية كصفاء الدُّهن{11}. (١٤/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- قال: <span class="qpc-hafs">﴿وردة كالدهان﴾</span>، قال: تكون ألوانًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٣<span class="dash">-</span></span> قال <span class="name-2">عطاء بن أبي رباح</span>: <span class="qpc-hafs">﴿كالدِّهانِ﴾</span> كعصير الزّيت، يتلوّن في الساعة ألوانًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٤<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق ابن أبي شيبة- <span class="qpc-hafs">﴿كالدِّهانِ﴾</span>، قال: لون السماء كلون دُهن الوَرد في الصُّفرة{14}. (١٤/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَإذا انْشَقَّتِ السَّماءُ فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، قال: هي اليوم خضراء كما ترون، وإنّ لها يوم القيامة لونًا آخر{15}. (١٤/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- <span class="qpc-hafs">﴿فَإذا انْشَقَّتِ السَّماءُ فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، قال: هي اليوم خضراء، ولونها يومئذ الحُمرة{16}<span class=comment-ref>٦٣٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٨٦</span> ذكر <u>ابنُ عطية</u> (٨/١٧٥) عن قتادة أنه قال: «السماء اليوم خضراء، وهي يوم القيامة حمراء». ثم قال <span class="comment-type-4">معلّقًا</span>: «فمعنى قوله: <span class="qpc-hafs">﴿وردة﴾</span> أي: مُحمرّة كالوردة، وهي النوار المعروف».</div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٧<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿كالدِّهانِ﴾</span>: كعَكر الزّيت{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿كالدِّهانِ﴾</span> كالأديم الأحمر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا انْشَقَّتِ السَّماءُ﴾</span> يعني: انفرجت من المَجرّة، وهو البياض الذي يُرى في وسط السماء، وهو شَرْج السماء؛ لنُزول من فيها، يعني: الرّبّ تعالى والملائكة <span class="qpc-hafs">﴿فَكانَتْ﴾</span> يعني: فصارت من الخوف <span class="qpc-hafs">﴿ورْدَةً كالدِّهان﴾</span> شبّه لونها في التغيّر والتلوّن بدهان الوَرد الصافي{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٠<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿كالدِّهانِ﴾</span> تذوب السماء كالدُّهن الذائب، وذلك حين يصيبها حرّ جهنم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، قال: مُشرقة كالدّهان{16}<span class=comment-ref>٦٣٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٨٧</span> اختُلف في قوله: <span class="qpc-hafs">﴿كالدهان﴾</span> على أقوال: <b>الأول</b>: كالدّهن صافية الحُمرة مشرقة. <b>الثاني</b>: كانت وردة كالأديم.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/٢٢٩) <span class="mustanad">-مستندًا إلى اللغة</span>- القول الأول، فقال: «وأولى القولين في ذلك بالصواب قول مَن قال: عني به: الدّهن في إشراق لونه. لأن ذلك هو المعروف في كلام العرب».</div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٢<span class="dash">-</span></span> قال <span class="name-3">أبو صالح الدنداني [الهُذيل بن حبيب]</span>: شبّه لونها بلون دُهن الوَرد، ويقال: بلون الفَرس الوَرد؛ يكون في الربيع كميتًا أشقر، وفي الشتاء أحمر، فإذا اشتد البَرد كان أغبر، فشبّه لون السماء في اختلاف أحوالها بلون الفَرس في الأزمنة المختلفة{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا ٱنشَقَّتِ ٱلسَّمَاۤءُ فَكَانَتۡ وَرۡدَةࣰ كَٱلدِّهَانِ ۝٣٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٣٧٣<span class="dash">-</span></span> عن لقمان بن عامر الحنفي: أنّ النبيَّ ﷺ مرّ بشابٍّ يقرأ: <span class="qpc-hafs">﴿فَإذا انْشَقَّتِ السَّماءُ فَكانَتْ ورْدَةً كالدِّهانِ﴾</span>، فوقف، فاقشعرّ، وخَنقَته العَبْرة، فجعل يبكي، ويقول: ويحي مِن يومٍ تنشقّ فيه السماء. فقال النبيُّ ﷺ: «<b>مثلها يا فتى، فوالذي نفسي بيده، لقد بَكَتِ الملائكةُ مِن بُكائك</b>»{23}. (١٤/١٢٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٢٧.عزاه السيوطي إلى ابن أبي حاتم.الفرس الورد: الذي لونه أحمر يضرب إلى صُفرة. لسان العرب (ورد).أخرجه ابن جرير ٢٢/٢٢٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن المنذر، وابن أبي حاتم.الجلّ: الياسَمين، وقيل: هو الورد أبيضه وأحمره وأصفره. لسان العرب (جلل).عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٨٧.تفسير مجاهد ص٦٣٨، وأخرجه ابن جرير ٢٢/٢٢٨-٢٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٧/٤٤٩.أخرجه ابن جرير ٢٢/٢٢٧-٢٢٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٢٩ بلفظ: خالصة. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن المبارك في الزهد ١/٥٠٧.تفسير الثعلبي ٩/١٨٧، وتفسير البغوي ٧/٤٤٩.أخرجه أبو الشيخ في العظمة (٥٥٨).أخرجه عبد الرزاق ٢/٢٦٤، وابن جرير ٢٢/٢٢٨ من طريقي معمر وسعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٢٨.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٢٤ (٢٨٥). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٢-.تفسير الثعلبي ٩/١٨٧، وتفسير البغوي ٧/٤٤٩.تفسير مقاتل بن سليمان ٤/٢٠٠.تفسير الثعلبي ٩/١٨٧، وتفسير البغوي ٧/٤٤٩.أخرجه ابن جرير ٢٢/٢٢٨.تفسير مقاتل بن سليمان ٤/٢٠١.عزاه السيوطي إلى محمد بن نصر.
  55,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَوۡمَىِٕذࣲ لَّا یُسۡـَٔلُ عَن ذَنۢبِهِۦۤ إِنسࣱ وَلَا جَاۤنࣱّ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٣٧٤<span class="dash">-</span></span> عن عائشة، عن رسول الله ﷺ، قال: «<b>لا يُحاسَب أحد يوم القيامة فيُغفر له، ويَرى المسلمُ عملَه في قبره؛ يقول الله: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْئَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span></b>»{1}. (١٤/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span>، قال: لا يسألهم هل عملتم كذا وكذا؟ لأنه أعلم بذلك منهم، ولكن يقول: لِم عملتم كذا وكذا؟{2}. (١٤/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span>، يقول: لا أسألهم عن أعمالهم، ولا أسأل بعضهم عن بعض. وهو مثل قوله: <span class="qpc-hafs">﴿ولا يُسْأَلُ عَنْ ذُنُوبِهِمُ المُجْرِمُونَ﴾</span> [القصص:٧٨]، ومثل قوله: <span class="qpc-hafs">﴿ولا تُسْأَلُ عَنْ أصْحابِ الجَحِيمِ﴾</span> [البقرة:١١٩]{3}. (١٤/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٧<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span> لا يَسأل غير المُجرم عن ذنب المُجرم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span> لا تَسأل الملائكة عن المُجرم؛ يعرفونهم بسيماهم{5}<span class=comment-ref>٦٣٨٨</span>. (١٤/١٢٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٨٨</span> ذكر <u>ابنُ كثير</u> (١٣/٣٢٧) قول مجاهد، ثم قال <span class="comment-type-4">معلّقًا</span>: «وكأنّ هذا بعد ما يؤمر بهم إلى النار، فذلك الوقت لا يُسألون عن ذنوبهم، بل يُقادون إليها، ويُلقَون فيها، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿يعرف المجرمون بسيماهم﴾</span> أي: بعلامات تظهر عليهم».</div></p><p><div></p><p><p><span class="item-no">٧٤٣٧٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> أنه قال: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span> إنها مواطن، يُسأل في بعضها، ولا يُسأل في بعضها{6}<span class=comment-ref>٦٣٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٨٩</span> ذكر <u>ابنُ عطية</u> (٨/١٧٥) ما جاء في هذا القول إبّان ذكره لاختلاف السلف في السؤال يوم القيامة، حيث وردت آيات تَنفيه، وأخرى تُثبته، ثم نسب قولًا لابن عباس، و<span class="comment-type-3">رجّحه</span> <span class="mustanad">مستندًا للدلالة العقلية</span>، فقال: «وقال ابن عباس -وهو الأظهر في ذلك- أنّ السؤال متى أُثبت فهو بمعنى التوبيخ والتقرير، ومتى نُفي فهو بمعنى الاستخبار المحض والاستعلام؛ لأنّ الله تعالى عليم بكل شيء».</div></p><p><div></p><p><p><span class="item-no">٧٤٣٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span> قد حَفظ اللهُ عليهم أعمالَهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span>، قال: حَفظ الله عليهم أعمالهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</span>، قال: قد كانت مسألة، ثُمّ خُتِم على ألسنة القوم، فتتكلّم أيديهم وأرجلهم بما كانوا يعملون{8}<span class=comment-ref>٦٣٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٠</span> لم يذكر <u>ابنُ جرير</u> (٢٢/٢٢٩-٢٣٠) غير قول قتادة، ومجاهد، وابن عباس من طريق عطية العَوفيّ.</div></p><p><div></p><p><p><span class="item-no">٧٤٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ لا يُسْئَلُ عَنْ ذَنْبِهِ﴾</span> يعني: عن عمله <span class="qpc-hafs">﴿إنْسٌ ولا جانٌّ﴾</span> لأنّ الرّبّ تعالى قد أحصى عليه عمله{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٤١/٢٤٢ (٢٤٧١٦)، من طريق ابن لهيعة، عن أبي الأسود، عن عروة، عن عائشة به.</p><p>قال الهيثمي في المجمع ١٠/٣٥٠ (١٨٣٩٢): «فيه ابن لهيعة، وهو ضعيف، وقد وُثّق، وبقية رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٨/١٥٥ (٧٦٨٢): «فيه ابن لِهيعة».عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٣٠. وعزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/١٨٨، وتفسير البغوي ٧/٤٥٠.تفسير مجاهد ص٦٣٨، وأخرجه ابن جرير ٢٢/٢٣٠، والبيهقي في الشعب (٢٧٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٧/٤٥٠.أخرجه عبد الرزاق ٢/٢٦٥.أخرجه ابن جرير ٢٢/٢٣٠.أخرجه ابن جرير ٢٢/٢٣٠.تفسير مقاتل بن سليمان ٤/٢٠١.
