quran[3]{c,v,t}:
  103,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٤٧٧٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٧٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت سورة <span class="qpc-hafs">﴿والعصر﴾</span> بمكة{2}. (١٥/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٧٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: أنها مكّيّة، وذكرها بمسمّى: <span class="qpc-hafs">﴿والعصر﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿ألم نشرح﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٧٨<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٧٩<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٠<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨١<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمّى: <span class="qpc-hafs">﴿والعصر﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿والعاديات﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٢<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٣<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة العصر مكّيّة، عددها ثلاث آيات كوفي{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٤<span class="dash">-</span></span> عن أبي مَدينة الدارمي -وكانت له صحبة- قال: كان الرجلان من أصحاب رسول الله ﷺ إذا التقيا لم يتفرّقا حتى يقرأ أحدُهما على الآخر سورة: <span class="qpc-hafs">﴿والعَصْرِ إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span> إلى آخرها، ثم يُسلّم أحدهما على الآخر{9}. (١٥/٦٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡعَصۡرِ ۝١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٤٧٨٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عمرو ذي مر- أنه كان يقرأ: (والعَصْرِ ونَوَآئِبِ الدَّهْرِ){10}. (١٥/٦٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡعَصۡرِ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٤٧٨٦<span class="dash">-</span></span> عن أُبيّ بن كعب، قال: قرأتُ على رسول الله صلى الله عليه وآله وسلم: <span class="qpc-hafs">﴿والعصر﴾</span>، فقلتُ: بأبي وأمي يا رسول الله، وما تفسيرها؟ فقال: <b>«<span class="qpc-hafs">﴿والعَصْرِ﴾</span> قَسَمٌ مِن الله أقسم لكم بآخر النهار، <span class="qpc-hafs">﴿إنَّ الاْنسانَ لَفِي خُسْر﴾</span></b>». قال: «<b>أبو جهل بن هشام، <span class="qpc-hafs">﴿إلاَّ الَّذِينَ آمَنُوا﴾</span> أبو بكر الصِّدِّيق، <span class="qpc-hafs">﴿وعَمِلُوا الصّالِحاتِ﴾</span> عمر بن الخطّاب، <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> عثمان بن عفّان، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> علي بن أبي طالب</b>»{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: الدَّهر{12}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: ساعة من ساعات النهار{13}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: هو ما قبل مغيب الشمس من العشي{12}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: العشي{15}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق عبد العزيز بن أبي رواد- <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: قَسمٌ أقسم به ربُّنا -وتبارك وتعالى-{16}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: ساعة من ساعات النهار{17}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، <span class="qpc-hafs">﴿والعَصْرِ﴾</span>، قال: هو في كلام العرب: الدَّهر{18}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والعَصْرِ﴾</span> قَسمُ، أقسم الله ﷿ بعصر النهار، وهو آخر ساعة من النهار، وأيضًا العصر{19} سُمّيت العصر حين تصوّبت الشمس للغروب، وهو عصر النهار، فأقسم الله ﷿ بصلاة العصر{20}<span class=comment-ref>٧٢٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٢</span> اختُلف فيما عنى الله بقوله: <span class="qpc-hafs">﴿والعصر﴾</span> على أقوال: <b>الأول</b>: الدهر. <b>الثاني</b>: العشي. <b>الثالث</b>: أنها صلاة العصر.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/٦١٢) <span class="mustanad">العموم</span>، فقال: «والصواب من القول في ذلك أن يقال: إنّ ربّنا أقسم بالعصر، والعصر اسم للدَّهر، وهو العشي والليل والنهار، ولم يخصص مما شمله هذا الاسم معنى دون معنى، فكلّ ما لزمه هذا الاسم فداخل فيما أقسم به -جلّ ثناؤه-».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ القيم</u> (٣/٣٦٧) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، فقال: "وأكثر المفسرين على أنه الدَّهر، وهذا هو الراجح، وتسمية الدَّهر عصرًا معروف في لغتهم، قال:</p><p>ولن يلبث العصران يوم وليلة إذا طلبا أن يدركا ما تيمما".</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١٤/٤٥١) فقال: «والمشهور الأول».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧، من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٨٢٧.أخرجه الطبراني في الأوسط (٥١٢٤)، والبيهقي في شعب الإيمان (٩٠٥٧).أخرجه أبو عبيد في فضائله (١٨٩)، وابن جرير ٢٤/٦١٣، والحاكم ٢/٥٣٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن الأنباري في المصاحف.</p><p>والقراءة شاذة. انظر: مختصر ابن خالويه ص١٨٠.أخرجه الثعلبي ١٠/٢٨٤، بإسناده، من طريق علي بن إسماعيل، قال: حدّثنا الحسن بن علقمة، قال: حدّثنا أسباط بن محمد، عن القاسم بن رفيعة، عن أبي أُمامة، عن أبيّ به.</p><p>علي بن إسماعيل، والحسن بن علقمة، والقاسم بن رفيعة لم نجد لهم ترجمة فيما بين أيدينا من المصادر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٦١٢.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٩٤، وابن جرير ٢٤/٦١٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.لعلها «صلاة العصر» كما يدل عليه السياق.تفسير مقاتل بن سليمان ٤/٨٢٩.
  103,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡإِنسَـٰنَ لَفِی خُسۡرٍ ۝٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٤٧٩٥<span class="dash">-</span></span> عن إسماعيل بن عبد الملك، قال: سمعتُ سعيد بن جُبَير يقرأ قراءة <span class="name-1">ابن مسعود</span>: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ * إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ){1}. (١٥/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٦<span class="dash">-</span></span> عن حَوْشَب، قال: أرسَل بشر بن مروان إلى عبد الله بن عُتبة بن مسعود، فقال: كيف كان <span class="name-1">ابن مسعود</span> يقرأ: <span class="qpc-hafs">﴿والعَصْرِ﴾</span>؟ فقال: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وهُوَ فِيهِ إلى ءاخِرِ الدَّهْرِ). فقال له بشر: هو يكفر به. فقال عبد الله: لكني أومن به{2}. (١٥/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عمرو ذي مر- أنه كان يقرأ: (إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ){3}. (١٥/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخعي</span>، قال: قراءتنا: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ لَفِيهِ إلى ءاخِرِ الدَّهْرِ * إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ){2}. (١٥/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٧٩٩<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> أنه قرأ: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ* إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ وتَواصوْا بِالحَقِّ وتَواصَوْا بِالصَّبْرِ).= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٠<span class="dash">-</span></span> ذُكر أنها في قراءة <span class="name-1">عبد الله بن مسعود</span>{2}. (١٥/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّ الإنسانَ لَفِي خُسْرٍ﴾</span>: ففي بعض القراءات: (وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ){6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡإِنسَـٰنَ لَفِی خُسۡرٍ ۝٢﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٠٢<span class="dash">-</span></span> عن أُبيّ بن كعب، قال: قال رسول الله صلى الله عليه وآله وسلم: <span class="qpc-hafs">﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span>، قال: «<b>أبو جهل بن هشام</b>»{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق رفاعة القرظي- في قوله: <span class="qpc-hafs">﴿والعَصْرِ إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span>: يعني: أبا جهل بن هشام{8}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٤<span class="dash">-</span></span> عن <span class="name-2">كعب [الأحبار]</span> – من طريق ابن علي- <span class="qpc-hafs">﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span>، قال: يعني: آدم وبنيه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span>، يعني: ضلال{10}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم [النَّخْعي]</span> -من طريق ابن عون- قال: أراد أنّ الإنسان إذا عمّر في الدنيا وهَرم لَفي نقصٍ وضعفٍ وتراجع؛ إلّا المؤمنين، فإنّهم يُكتب لهم أجورهم ومحاسن أعمالهم التي كانوا يعملونها في حال شبابهم وقوّتهم وصحّتهم، وهي مثل قوله سبحانه: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي أحْسَنِ تَقْوِيمٍ ثُمَّ رَدَدْناهُ أسْفَلَ سافِلِينَ إلّا الَّذِينَ آمَنُوا...﴾</span> [التين:٤-٦]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق عبد العزيز بن أبي رواد- <span class="qpc-hafs">﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span>، قال: الناس كلهم{12}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾</span> نزلت في أبي لهب، اسمه: عبد العُزّى بن عبد المُطَّلب، يعني: إنه لفي ضلال أبدًا حتى يدخل النار{13}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة، تروى أيضًا عن علي بن أبي طالب، وميمون بن مهران، وإبراهيم النخعي بنحوها. انظر: المحرر الوجيز ٥/٥٢٠، والجامع لأحكام القرآن ٢٢/٤٦٦.عزاه السيوطي إلى عبد بن حميد.أخرجه أبو عبيد في فضائله (١٨٩)، وابن جرير ٢٤/٦١٣، والحاكم ٢/٥٣٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن الأنباري في المصاحف.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٦١٣.أخرجه الثعلبي ١٠/٢٨٤. وقد تقدم بتمامه مع تخريجه في تفسير أول السورة.أخرجه الثعلبي ١٠/٢٨٤. وعزاه السيوطي إلى ابن مردويه.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٤٧-.تفسير مجاهد ص٧٤٧، وأخرجه الفريابي -كما في تغليق التعليق ٤/٤-، وابن جرير ٢٤/٦١٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٢٨٣-٢٨٤، وتفسير البغوي ٨/٥٢٢-٥٢٦.أخرجه عبد الرزاق ٢/٣٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٢٩.
  103,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٠٩<span class="dash">-</span></span> عن أُبيّ بن كعب، قال: قال رسول الله صلى الله عليه وآله وسلم: «<span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا﴾</span> <b>أبو بكر الصِّدِّيق</b>، <span class="qpc-hafs">﴿وعَمِلُوا الصّالِحاتِ﴾</span> <b>عمر بن الخطاب</b>، <span class="qpc-hafs">﴿وتواصوا بالحقّ﴾</span> <b>عثمان بن عفان</b>، <span class="qpc-hafs">﴿وتواصوا بالصبر﴾</span> <b>علي بن أبي طالب</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق رفاعة القرظي-: <span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا﴾</span> أبو بكر الصِّدِّيق، <span class="qpc-hafs">﴿وعَمِلُوا الصّالِحاتِ﴾</span> عمر بن الخطاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ﴾</span>: ذكر عليًّا، وسلمان{3}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>، قال: قراءتنا: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ لَفِيهِ إلى ءاخِرِ الدَّهْرِ * إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ). قال: هي مثل التي في «التين والزيتون» [٤-٦]: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنسانَ فِي أحْسَنِ تَقْوِيمٍ ثُمَّ رَدَدْناهُ أسْفَلَ سافِلِينَ إلّا الَّذِينَ ءامَنُوا وعَمِلُوا الصّالِحاتِ﴾</span>{4}. (١٥/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا﴾</span>، قال: إلا مَن آمن{5}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق عبد العزيز بن أبي رواد-: ثم استثنى، فقال: <span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا﴾</span> ثم لم يدعهم، وذاك حتى قال: <span class="qpc-hafs">﴿وعَمِلُوا الصّالِحاتِ﴾</span>{6}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ﴾</span> فليسوا في خُسران{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَوَاصَوۡا۟ بِٱلۡحَقِّ وَتَوَاصَوۡا۟ بِٱلصَّبۡرِ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٨١٦<span class="dash">-</span></span> عن أُبيّ بن كعب، قال: قال رسول الله صلى الله عليه وآله وسلم: «<span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> <b>عثمان بن عفان</b>، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> <b>علي بن أبي طالب</b>»{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق رفاعة القرظي-: <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> عثمان بن عفان، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> علي بن أبي طالب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٨<span class="dash">-</span></span> عن <span class="name-2">كعب [الأحبار]</span> -من طريق ابن علي- <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> قال: الحقّ هو الله ﷿، والإيمان به، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> على فرائض الله وحُكمه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨١٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> قال: الحقّ: كتاب الله، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> والصبر: طاعة الله{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> قال: كتاب الله، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> قال: طاعة الله{12}<span class=comment-ref>٧٢٩٣</span>. (١٥/٦٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٣</span> لم يذكر <u>ابن جرير</u> (٢٤/٦١٤-٦١٥) غير قول قتادة، والحسن.</div></p><p><div></p><p><p><span class="item-no">٨٤٨٢١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق عبد العزيز بن أبي رواد-: ثم لم يدعهم وذاك حتى قال: <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span>، ثم لم يدعهم وذاك حتى قال: <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> شروطًا يشترط عليهم{6}. (١٥/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَواصَوْا بِالحَقِّ﴾</span> يعني: بتوحيد الله ﷿، <span class="qpc-hafs">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> يعني: على أمر الله ﷿، فمَن فعل هذين كان مِن الذين آمنوا وعملوا الصالحات، فليسوا من الخُسران في شيء، ولكنهم في الجنان مُخلَّدون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وتواصوا بالحق﴾</span> يعني بالحق: الله، <span class="qpc-hafs">﴿وتواصوا بالصبر﴾</span> على فرائضه{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي ١٠/٢٨٤. وقد تقدم بتمامه مع تخريجه في تفسير أول السورة.أخرجه الثعلبي ١٠/٢٨٤.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٤٧، وأخرجه الفريابي -كما في تغليق التعليق ٤/٤-، وابن جرير ٢٤/٦١٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٢٩.أخرجه الثعلبي ١٠/٢٨٤. وقد تقدم بتمامه في تفسير أول السورة.أخرجه الثعلبي ١٠/٢٨٤.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٤٧-.أخرجه عبد الرزاق ٣/٤٥٨، وابن جرير ٢٤/٦١٤-٦١٥، وبمثل أوله من طريق عبد الرحمن بن سنان.أخرجه ابن جرير ٢٤/٦١٤-٦١٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٢٩.تفسير يحيى بن سلام ١/٤١٠.
  104,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٢٤<span class="dash">-</span></span> عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أُنزِلَتْ <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span> بمكة{2}. (١٥/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمّى <span class="qpc-hafs">﴿ويل لكل همزة﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿لا أقسم بيوم القيامة﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٢٩<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٠<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، نزلت بعد <span class="qpc-hafs">﴿ق والقرآن المجيد﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣١<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٢<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الهُمَزَة مكّيّة، عددها تسع آيات كوفي{8}<span class=comment-ref>٧٢٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٤</span> قال <u>ابنُ عطية</u> (٨/٦٨٧): «وهي مكّيّة <span class="mustanad">بلا خلاف</span>».</div></p><p><h3><span class="qpc-hafs">﴿وَیۡلࣱ لِّكُلِّ هُمَزَةࣲ لُّمَزَةٍ ۝١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> أنه قيل له: نزلت هذه الآية في أصحاب محمد ﷺ: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>؟ فقال: ابن عمر: ما عُنينا بها، ولا عُنينا بعُشر القرآن{9}. (١٥/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: ليستْ بخاصة لأحد{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: ليستْ بخاصة لأحد، نزلت في جميل بن عامر، زعم الرَّقاشيّ{11}. (١٥/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: نزلت <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span> في الأَخْنَس بن شَريق{9}. (١٥/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span> نزلت في الأَخْنَس بن شَريق بن وهب الثَّقَفيّ؛ كان يقع في الناس ويغتابهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٨<span class="dash">-</span></span> عن <span class="name-3">عثمان بن عمر</span> -من طريق ابن إسحاق- قال: ما زلنا نسمع أن: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span> نزلت في أُبيّ بن خلف{9}. (١٥/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٣٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: ما زلنا نسمع أنّ سورة الهُمَزَة نزلت في أُميّة بن خلف الجُمحيّ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span> نزلت في الوليد بن المُغيرة المخزومي، كان يغتاب النبيَّ ﷺ إذا غاب، وإذا رآه طغى في وجهه، ...، كان رجلًا نمّامًا، وكان يلقّب الناس مِن التجبر والعظمة، وكان يستهزئ بالناس، وذلك أنه أُنزِل على رسول الله ﷺ: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span> وكان له حديقتان، حديقة بمكة وحديقة بالطائف، وكان لا ينقطع خيره شتاء ولا صيفًا، فذلك قوله: <span class="qpc-hafs">﴿مالًا مَمْدُودًا وبَنِينَ شُهُودًا﴾</span> يعني: أرباب البيوت، وكان له سبعة بنين، قال: <span class="qpc-hafs">﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</span> يقول: بسَطتُ له في المال كلّ البسط <span class="qpc-hafs">﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ كَلّا إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span> [المدثر:١١-١٦] قال: واللهِ، لو قسمتُ مالي يمينًا وشمالًا على قريش ما دمت حيًّا ما فني، فكيف تَعِدني الفقر؟! قال: أما -واللهِ- إنّ الذي أعطاك قادر على أن يأخذه منك. فوقع في قلبه مِن ذلك شيء، ثم عَمد إلى ماله فعَدّه، ما كان من ذهب أو فِضّة أو أرض أو حديقة أو رقيق فعَدّه وأحصاه، فقال: يا محمد، تَعِدني الفقر؟! واللهِ، لو كان هذا خبزًا ما فني. فأنزل الله ﷿: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ الَّذِي جَمَعَ مالًا وعَدَّدَهُ يَحْسَبُ أنَّ مالَهُ أخْلَدَهُ كَلّا﴾</span> لا يُخلّده، ثم استأنف فقال: <span class="qpc-hafs">﴿لَيُنْبَذَنَّ فِي الحُطَمَةِ وما أدْراكَ ما الحُطَمَةُ﴾</span> تعظيمًا لها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤١<span class="dash">-</span></span> عن رجل من أهل الرَّقَّة -من طريق ابن أبي نجيح- قال: نزلت في جميل بن عامر الجُمحيّ{17}<span class=comment-ref>٧٢٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٥</span> اختُلف في نزول الآية على قولين: <b>الأول</b>: أنها عامة في كلّ من اتصف بهذه الصفات. <b>الثاني</b>: أنها في مُشرك بعينه، <b>فقيل</b>: نزلت في أُميّة بن خلف. <b>وقيل</b>: في جميل بن عامر الجُمحيّ. <b>وقيل</b>: في الوليد بن المُغيرة. <b>وقيل</b>: الأَخْنَس بن شَريق. <b>وقيل</b>: أُبيّ بن خلف.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/٦٢٠) <span class="mustanad">العموم</span>، فقال: «والصواب من القول في ذلك أن يُقال: إنّ الله عمّ بالقول كلّ هُمَزة لُمَزة، كلّ مَن كان بالصفة التي وصف هذا الموصوف بها، سبيله سبيله كائنًا من كان من الناس».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٦٨٨).</div></p><p><h3><span class="qpc-hafs">﴿وَیۡلࣱ لِّكُلِّ هُمَزَةࣲ لُّمَزَةٍ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٤٢<span class="dash">-</span></span> عن راشد بن سعد المَقْرائي، عن أبي هريرة، عن النبيِّ ﷺ، قال: «<b>لَمّا عُرِج بي مررتُ برجال تُقطعُ جلودهم بمقاريض مِن نار، فقلتُ: مَن هؤلاء؟ قال: الذين يتزيّنون للزّينة. قال: ثم مررتُ بجُبٍّ مُنتن الريح، فسمعتُ فيه أصواتًا شديدة، فقلتُ: مَن هؤلاء، يا جبريل؟ قال: نساء كُنّ يتزيَّنَّ للزينة، ويفعلن ما لا يحلّ لهنّ. ثم مررتُ على نساء ورجال معلَّقين بثُدِيِّهنّ، فقلتُ: مَن هؤلاء، يا جبريل؟ قال: هؤلاء الهمّازون والهمّازات، ذلك بأن الله قال: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span></b>»{18}. (١٥/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الجَوْزاء- أنه سئل عن قوله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: هو المشّاء بالنميمة، المفرّق بين الجمع، المُغري بين الإخوان{19}<span class=comment-ref>٧٢٩٦</span>. (١٥/٦٤٦)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٦</span> ذكر <u>ابنُ عطية</u> (٥/٦٨٧) قول ابن عباس، و<span class="comment-type-4">علّق</span> عليه، فقال: «قال ابن عباس: هو المشاء بالنميم. وليس به، لكنهما صفتان بتلازم، <span class="mustanad">قال الله تعالى</span>: <span class="qpc-hafs">﴿هماز مشاء بنميم﴾</span> [القلم:١١]».</div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span> قال: طعّان، <span class="qpc-hafs">﴿لُمَزَةٍ﴾</span> قال: مغتاب{20}. (١٥/٦٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: مُشرك كان يَلمِز الناس ويَهمِزهم{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق الربيع- <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span>، قال: يَهمِزه في وجهه، ويَلمِزه مِن خلفه{22}. (١٥/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: الهُمَزَة: الذي يأكل لحوم الناس ويغتابهم. واللُمَزة: الطعّان عليهم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في الآية، قال: الهُمَزَة: الطّعان في الناس. واللُّمَزة: الذي يأكل لحوم الناس{24}. (١٥/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: الهُمَزَة: يأكل لحوم الناس. واللُّمَزة: الطّعان{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: أحدهما الذي يأكل لحوم الناس، والآخر الطّعان{25}<span class=comment-ref>٧٢٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٧</span> ذكر <u>ابنُ جرير</u> (٢٤/٦١٨) قول مجاهد هذا والقولين اللَّذَيْن قبله، ثم <span class="comment-type-4">علّق</span> قائلًا: «وهذا يدل على أنّ الذي حدّث بهذا الحديث قد كان أشكل عليه تأويل الكلمتين، فلذلك اختلف نقل الرواة عنه ما رووا على ما ذكرت».</div></p><p><div></p><p><p><span class="item-no">٨٤٨٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: الهُمَزَة باليد، واللُّمَزة باللسان{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٣<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span>: الهُمَزَة: الذي يَعيب ويَطعن في وجه الرجل إذا أقبل. واللُمَزة: الذي يغتابه مِن خلفه إذا أدبَر وغاب{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: الهُمَزَة: آكل لحوم الناس. واللُّمَزة: الطَّعان عليهم{29}. (١٥/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span>، قال: يَهمِزه ويَلمِزه بلسانه وعينيه، ويأكل لحوم الناس ويطعن عليهم{30}. (١٥/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ﴾</span> يعني: الطّعان المغتاب الذي إذا غاب عنه الرجل اغتابه من خلفه، <span class="qpc-hafs">﴿لُمَزَةٍ﴾</span> يعني: الطاغي إذا رآه طغى عليه في وجهه ...{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span> فأمّا الهُمَزَة: فالذي ينمّ الكلام إلى الناس، وهو النَّمّام، وأمّا اللُّمَزة: فهو الذي يلقّب الرجل بما يكره، وهو الوليد بن المُغيرة، كان رجلًا نمّامًا، وكان يلقّب الناس من التجبر والعظمة، وكان يستهزئ بالناس ...{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق ابن المبارك- قال: الهُمَزَة بالعين والشِّدق واليد، واللُّمَزة باللسان{33}. (١٥/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٥٩<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>: يَهمِز بلسانه، ويَلمِز بعينه{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٦٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</span>، قال: الهُمَزَة: الذي يَهمِز الناس بيده، ويضربهم بلسانه. واللُّمَزة: الذي يَلمِزهم بلسانه ويَعيبهم{17}<span class=comment-ref>٧٢٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٢٩٨</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٤/٦١٦) أنّ المراد بالهُمَزَة: مَن يغتاب الناس. واللُّمَزة: مَن يَطعن فيهم ويَعيبهم. فقال: "يعني -تعالى ذِكْره- بقوله: <span class="qpc-hafs">﴿ويل لكل همزة﴾</span> الوادي يسيل من صديد أهل النار وقيحهم <span class="qpc-hafs">﴿لكل همزة﴾</span> يقول: لكلّ مغتاب للناس، يغتابهم ويغضهم، <span class="mustanad">كما قال زياد الأعجم</span>:</p><p>تُدْلِي بِوُدِّي إذا لاقَيْتَنِي كَذِبًا وإن أُغَيَّبْ فَأَنتَ الهامِزُ اللُّمَزَهْ.</p><p>ويعني باللُّمَزة: الذي يَعيب الناس، ويطعن فيهم. وبنحو الذي قلنا في ذلك قال أهل التأويل«. وذكر قول قتادة، ومجاهد، وابن عباس. ثم ذكر قول عبد الرحمن ابن زيد:»أنّ الهُمَزَة: هو الذي يَهمِز الناس بيده، ويضربهم بلسانه، واللُّمَزة: مَن يَلمِزهم بلسانه ويعيبهم".</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٨٣٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٦٢٠.عزاه السيوطي بتمامه إلى عبد بن حميد، وابن جرير، وابن أبي حاتم. وعند ابن جرير ٢٤/٦١٩ عن ورقاء موقوفًا عليه.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/٢٨٦، وتفسير البغوي ٨/٥٣٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/٢٨٦، وتفسير البغوي ٨/٥٣٠.تفسير مقاتل بن سليمان ٤/٨٣٧. ونحوه في تفسير الثعلبي ١٠/٢٨٦ منسوبا إلى مقاتل مهملًا.أخرجه ابن جرير ٢٤/٦١٩.عزاه السيوطي إلى ابن مردويه. وأخرجه البيهقي في شعب الإيمان ٩/١٠٤-١٠٥ (٦٣٢٦) دون ذكر أبي هريرة.</p><p>قال البيهقي: «هذا مرسل، وقد رويناه موصولًا فيما مضى».أخرجه سعيد بن منصور -كما في فتح الباري ٨/٧٢٩-، وابن أبي الدنيا في ذم الغيبة (١٢٦)، وابن جرير ٢٤/٦١٦-٦١٧ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٤/٦١٨.أخرجه ابن جرير ٢٤/٦١٩.أخرجه ابن جرير ٢٤/٦١٨. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٢٨٥.أخرجه ابن أبي الدنيا في ذم الغيبة (٤٧)، وابن جرير ٢٤/٦١٧، والبيهقي في شعب الإيمان (٦٧٥٣). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٦١٧.أخرجه ابن جرير ٢٤/٦١٧.أخرجه ابن جرير ٢٤/٦١٨.تفسير الثعلبي ١٠/٢٨٥.أخرجه ابن جرير ٢٤/٦١٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٩٥، وابن جرير ٢٤/٦١٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٨٣٧.تفسير مقاتل بن سليمان ٤/٨٣٨-٨٤٠.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٤٨-، والبيهقي في شعب الإيمان (٦٧٥٢).تفسير الثعلبي ١٠/٢٨٦، وتفسير البغوي ٨/٥٢٦.أخرجه ابن جرير ٢٤/٦١٩.
  104,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی جَمَعَ مَالࣰا وَعَدَّدَهُۥ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿جَمَعَ مالًا وعَدَّدَهُ﴾</span>، قال: أحصاه{1}. (١٥/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِي جَمَعَ مالًا وعَدَّدَهُ﴾</span>، يقول: الذي استعدَّ مالًا ليشتري به الخدم والحيوان{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٣٧.
  104,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَحۡسَبُ أَنَّ مَالَهُۥۤ أَخۡلَدَهُۥ ۝٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٦٣<span class="dash">-</span></span> عن جابر بن عبد الله، أنّ النبي ﷺ قرأ: ‹<b>يَحْسِبُ أنَّ مالَهُ أخْلَدَهُ</b>› بكسر السين{1}. (١٥/٦٤٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَحۡسَبُ أَنَّ مَالَهُۥۤ أَخۡلَدَهُۥ ۝٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٦٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿يَحْسَبُ أنَّ مالَهُ أخْلَدَهُ﴾</span> قال: يزيد في عمره{2}. (١٥/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَحْسَبُ أنَّ مالَهُ أخْلَدَهُ﴾</span> من الموت، فلا يموت حتى يفنى ماله{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو داود ٦/١١٨-١١٩ (٣٩٩٥)، وابن حبان ١٤/٢٤٠ (٦٣٣٢)، والحاكم ٢/٢٨١ (٣٠١٣) وفي إسناده عبد الملك بن عبد الرحمن الذماري.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي: «عبد الملك ضعيف». وقال ابن أبي حاتم في العلل ٤/٦٧٢ (١٧٢٣): «قال أبي: هذا وهم، لم يروه أحد غير الذماري».</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا ابن عامر، وعاصمًا، وحمزة، وأبا جعفر؛ فإنهم قرؤوا: <span class="qpc-hafs">﴿يحْسَبُ﴾</span> بفتح السين. انظر: الإتحاف ص٥٨٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٣٧.
  104,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٦٦<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد اللّه مولى غُفْرة</span> -من طريق حرملة بن عمران- قال: إذا سمعتَ الله سبحانه يقول: <span class="qpc-hafs">﴿كَلّا﴾</span>، فإنما يقول: كذبتَ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا﴾</span> لا يُخلّده ماله وولده{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَیُنۢبَذَنَّ فِی ٱلۡحُطَمَةِ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٦٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿كَلّا لَيُنْبَذَنَّ﴾</span>، قال: لَيُقذَفنّ{3}. (١٥/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استأنف فقال: <span class="qpc-hafs">﴿لَيُنْبَذَنَّ فِي الحُطَمَةِ﴾</span>، يقول: ليُترْكَنّ في الحُطَمة، ... وهي باب من أبواب جهنم، وهي نار تأكل النار من شدة حرّها، وما خمدتْ من يوم خَلَقها الله ﷿ إلى يوم يدخلها ...{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٤٨٧٠<span class="dash">-</span></span> عن <span class="name-3">الحسين بن واقد</span>، قال: الحُطَمة باب من أبواب جهنم{3}. (١٥/٦٤٨)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي ١٠/٢٨٦-٢٨٧.تفسير مقاتل بن سليمان ٤/٨٣٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٨٣٧.عزاه السيوطي إلى ابن أبي حاتم.
  104,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَدۡرَىٰكَ مَا ٱلۡحُطَمَةُ ۝٥ نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٤٨٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أدْراكَ ما الحُطَمَةُ﴾</span> تعظيمًا لشدّتها، تحطم العظام، وتأكل اللحم حتى تهجم على القلب، <span class="qpc-hafs">﴿نارُ اللَّهِ المُوقَدَةُ﴾</span> على أهلها لا تَخمد{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٨٣٧.
