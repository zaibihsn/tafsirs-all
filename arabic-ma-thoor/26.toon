  26,184,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱتَّقُوا۟ ٱلَّذِی خَلَقَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿الذي خلقكم﴾</span> وخلق الذين مِن قبلكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتقوا﴾</span> يقول: واخْشَوْا أن يُعَذِّبكم في الدنيا <span class="qpc-hafs">﴿الذي خلقكم و﴾</span>خلق <span class="qpc-hafs">﴿الجبلة الأولين﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِینَ ۝١٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والجبلة الأولين﴾</span>، قال: خَلْقَ الأولين{3}. (١١/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿واتقوا الذي خلقكم والجبلة﴾</span>: يعني: وخلق الجبلة <span class="qpc-hafs">﴿الأولين﴾</span> يعني: القرون الأولين الذين أُهْلِكوا بالمعاصي، ولا تهلكوا مثلهم{4}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والجبلة الأولين﴾</span>، قال: الخَلِيقَة{5}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>خلق <span class="qpc-hafs">﴿الجِبِلَّة﴾</span> يعني: الخليقة <span class="qpc-hafs">﴿الأولين﴾</span> يعني: الأمم الخالية الذين عُذِّبوا في الدنيا؛ قوم نوح، وصالح، وقوم لوط{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والجبلة الأولين﴾</span>، قال: الخَلْق الأولين. الجِبِلَّة: الخَلْقُ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿واتقوا الذي خلقكم والجبلة الأولين﴾</span>، قال: خَلْق الأولين. ثم قرأ: <span class="qpc-hafs">﴿ولقد أضل منكم جبلا كثيرا﴾</span> [يس:٦٢]{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨١٣.تفسير مقاتل بن سليمان ٣/٢٧٨.أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٧/٦٣٥، وإسحاق البستي في تفسيره ص٥٤٠ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٣. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٨.أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٣ من طريق أصبغ.أخرجه إسحاق البستي في تفسيره ص٥٤١، وابن أبي حاتم ٩/٢٨١٣.
  26,185,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span>: يعني: مِن المخلوقين{1}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span> يعني: أنت بشر مثلنا، لست بملك، ولا رسول، فذلك قوله سبحانه: <span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٣/٢٧٩. وتقدمت آثار السلف في تفسيرها عند قوله تعالى: <span class="qpc-hafs">﴿قالُوا إنَّما أنْتَ مِنَ المُسَحَّرِينَ (١٥٣)﴾</span> [الشعراء:١٥٣].
  26,186,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنتَ إِلَّا بَشَرࣱ مِّثۡلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلۡكَـٰذِبِینَ ۝١٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا﴾</span> لا تفضلنا في شيء فنتبعك، <span class="qpc-hafs">﴿وإن نظنك﴾</span> يقول: وقد نحسبك -يا شعيب- <span class="qpc-hafs">﴿لمن الكاذبين﴾</span> يعني: حين تزعم أنّك نبيٌّ رسول{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا وإن نظنك لمن الكاذبين﴾</span> فيما تَدَّعي مِن الرسالة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.تفسير يحيى بن سلّام ٢/٥٢٢.
  26,187,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَسۡقِطۡ عَلَیۡنَا كِسَفࣰا مِّنَ ٱلسَّمَاۤءِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿كسفا﴾</span>، يقول: قِطَعًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء﴾</span>: يعني: قِطَعًا من السماء{2}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٩<span class="dash">-</span></span> عن عبيد، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿كسفا من السماء﴾</span>: جانبًا من السماء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء﴾</span>، قال: قِطَعًا من السماء{4}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿كسفا من السماء﴾</span>، يقول: عذابًا مِن السماء{5}<span class=comment-ref>٤٨٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٠/٣٦٨) على قول الضحاك، وقتادة، والسدي بقوله: «وهذا شبيه بما قالت قريش فيما أخبر الله عنهم في قوله تعالى: <span class="qpc-hafs">﴿وقالُوا لَنْ نُؤْمِنَ لَكَ حَتّى تَفْجُرَ لَنا مِنَ الأرْضِ يَنْبُوعًا﴾</span> إلى أن قالوا: <span class="qpc-hafs">﴿أوْ تُسْقِطَ السَّماءَ كَما زَعَمْتَ عَلَيْنا كِسَفًا أوْ تَأْتِيَ بِاللَّهِ والمَلائِكَةِ قَبِيلا﴾</span> [الإسراء:٩٠-٩٢]، وقوله: <span class="qpc-hafs">﴿وإذْ قالُوا اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</span> [الأنفال:٣٢]، وهكذا قال هؤلاء الكفرة الجهلة: <span class="qpc-hafs">﴿فَأَسْقِطْ عَلَيْنا كِسَفًا مِنَ السَّماءِ إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأسقط علينا كسفا﴾</span> يعني: جانبًا <span class="qpc-hafs">﴿من السماء إن كنت من الصادقين﴾</span> بأنّ العذاب نازل بنا؛ لقوله في هود [٨٤]: <span class="qpc-hafs">﴿وإني أخاف عليكم عذاب يوم محيط﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء﴾</span>، قال: ناحية من السماء، عذابٌ، ذلك الكِسَفُ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن كنت من الصادقين﴾</span> بما جئت به{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦٣٦.أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٧/٦٣٦، وإسحاق البستي في تفسيره ص٥٤١، وابن أبي حاتم ٩/٢٨١٤.أخرجه ابن أبي حاتم ٩/٢٨١٤. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨١٤.تفسير مقاتل بن سليمان ٣/٢٧٩.أخرجه ابن جرير ١٧/٦٣٦.تفسير يحيى بن سلّام ٢/٥٢٢.
  26,188,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّیۤ أَعۡلَمُ بِمَا تَعۡمَلُونَ ۝١٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> شعيب: <span class="qpc-hafs">﴿ربي أعلم﴾</span> مِن غيره <span class="qpc-hafs">﴿بما تعملون﴾</span> مِن نقصان الكيل والميزان{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.
  26,189,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَذَّبُوهُ فَأَخَذَهُمۡ عَذَابُ یَوۡمِ ٱلظُّلَّةِۚ إِنَّهُۥ كَانَ عَذَابَ یَوۡمٍ عَظِیمٍ ۝١٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٧٦<span class="dash">-</span></span> عن قتادة، قال: قال <span class="name-1">عبد الله بن عمرو بن العاص</span>: تدرون كيف كان أمرُ أصحاب الأيكة؟ قالوا: الله أعلم. قال: كان أمرهم أنّ الله سلَّط عليهم الحرَّ سبعة أيام، حتى ما يُظِلُّهم منه شيء، ثم إنّ الله أنشا لهم سحابةً، فانطلق إليها أحدُهم، فاسْتَظَلَّ بها، فأصاب تحتها بردًا وراحة، فأعلم بذلك قومه، فأتوا جميعًا، فاسْتَظَلُّوا تحتها، فأجَّجَتْ عليهم نارًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٧<span class="dash">-</span></span> قال قتادة: فحدثنا <span class="name-2">شهر بن حوشب</span>: أنّه رأى مكانهم، وأنه لا يذكر منهم إلا كموضع المِسَلَّة{1}، صاروا رمادًا، قال الله ﷿: <span class="qpc-hafs">﴿إنه كان عذاب يوم عظيم﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الشعبي- قال: مَن حدَّثك مِن العلماء ما عذابُ يوم الظلة فكذِّبه{3}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٩<span class="dash">-</span></span> عن يزيد الباهلي، قال: سألتُ <span class="name-1">عبد الله بن عباس</span> عن قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>. فقال: بعث الله عليهم ومَدَة{4}، وحرًّا شديدًا، فأخذ بأنفاسهم، فدخلوا أجواف البيوت، فدخل عليهم أجواف البيوت، فأخذ بأنفاسهم، فخرجوا مِن البيوت هرابًا إلى البرية، فبعث الله عليهم سحابة، فأظلَّتهم مِن الشمس، فوجدوا لها بردًا ولَذَّة، فنادى بعضُهم بعضًا، حتى إذا اجتمعوا تحتها أسقطها اللهُ عليهم نارًا، فذلك عذاب يوم الظلة{5}. (١١/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>: أرسل الله عليهم سَمُومًا مِن جهنم، فأطاف بهم سبعة أيام، حتى أنضجهم الحرُّ، فحميت بيوتهم، وغَلَتْ مياهُهم في الآبار والعيون، فخرجوا مِن منازلهم ومحلتهم هاربين، والسموم معهم، فسلط الله عليهم الشمسَ مِن فوق رؤوسهم، فتغشتهم حتى تفَلَّقت فيها جماجمهم، وسلَّط الله عليهم الرَّمضاء مِن تحت أرجلهم، حتى تساقطت لحومُ أرجلهم، ثم أنشئت لهم ظلة كالسحابة السوداء، فلمّا رأوها ابتدروها يستغيثون بظِلِّها، حتى إذا كانوا تحتها جميعًا أطبقت عليهم، فهلكوا، ونَجّى الله شعيبًا والذين آمنوا معه{6}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨١<span class="dash">-</span></span> عن <span class="name-2">علقمة</span> -من طريق زيد بن معاوية- <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: أصابهم الحرُّ، حتى أقلعهم من بيوتهم، فخرجوا، ورُفِعَت لهم سحابةٌ، فانطلقوا إليها، فلمّا استظلوا بها أرسلت إليهم، فلم ينفلِت منهم أحدٌ{7}. (١١/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن معاوية</span> -من طريق أبي إسحاق السبيعي- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: أصابهم حرٌّ أقلقهم مِن بيوتهم، فنشأت لهم سحابةٌ كهيئة الظُّلَّة، فابتدروها، فلما تَتامُّوا تحتها أخذتهم الرجفة{8}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قول الله: <span class="qpc-hafs">﴿عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</span>، قال: كانت الظلة سحابةً، وكانوا يحفرون الأسراب{9}، يدخلونها، فيَتَبَرَّدون بها، فإذا دخلوها وجدوها أشدَّ حرًّا مِن ظَهْرِها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: ظلل العذاب إيّاهم{11}. (١١/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: قوم شعيب، حبس الله عنهم الظل والريح، فأصابهم حرٌّ شديد، ثم بعث الله لهم سحابةً فيها العذاب، فلمّا رأوا السحابة انطلقوا يَؤُمُّونها -زعموا- يستظلون، فاضطرمت عليهم نارًا، فأهلكتهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جويبر- في قوله ﷿: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: الأيكة: الغيضة، أهلكهم ﷿ فيها، لَمّا أراد الله تعالى هلاكهم أرسل عليهم حرًّا شديدًا، حتى امتنع منهم طلاع البيوت والشراب{13}، وبعث الله سحابةً، فعامت على الغَيْضَة، فلمّا رأوها حسُّوا أنّ لها ظِلًّا، فدخلوا، فلما تتامُّوا تحتها أرسل الله عليهم نارًا، فأحرقهم، فذلك قوله ﷿: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ميسرة- في قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>، قال: الظلة فيها نار نزلت من السماء، فلمّا رأت الأرضُ ذلك أشفقت، وظنَّت أن إيّاها يُراد، فائتَفَكَتْ{15}، فكانت الأفكة{16} بقوم شعيب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الوليد بن حسان- قال: سلَّط اللهُ الحرَّ على قوم شعيب سبعة أيام ولياليهن، حتى كانوا لا ينتفعون بظلِّ بيت، ولا ببرد ماء، ثم رُفِعَت لهم سحابةٌ في البَرِّيَّة، فوجدوا تحتها الرَّوح، فجعل يدْعُو بعضُهم بعضًا، حتى إذا اجتمعوا تحتها أشعلها الله عليهم نارًا، فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>{18}. (١١/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر- قال: إنّ أهل مدين عُذِّبوا بثلاثة أصناف من العذاب: أخذتهم الرجفة في دارهم حتى خرجوا منها، فلما خرجوا منها أصابهم فزع شديد، ففرقوا أن يدخلوا البيوت أن تسقط عليهم، فأرسل الله عليهم الظلة، فدخل تحتها رجل، قال: ما رأيت كاليوم ظِلًّا أطيب، ولا أبرد، هلمُّوا، أيها الناس. فدخلوا جميعًا تحت الظلة، فصاح فيهم صيحة واحدة، فماتوا جميعًا{19}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: ذُكِر لنا: أنّه سلط الله عليهم الحرَّ سبعة أيام، لا يُظِلُّهم ظل، ولا ينفعهم منه شيء، فبعث الله عليهم سحابة، فلجُّوا إليها يلتمسون الرَّوح في ظلها، فجعلها الله عليهم عذابًا، فأحرقتهم، بعثت عليهم نارًا، فاضطرمت، فأكلتهم، فذلك عذاب يوم الظلة{20}. (١١/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق جرير بن حازم- قال: بعث شعيب إلى أمتين: إلى قومه أهل مدين، وإلى أصحاب الأيكة. وكانت الأيكة مِن شجر ملتف، فلما أراد الله أن يُعَذِّبهم بعث الله عليهم حرًّا شديدًا، ورفع لهم العذابَ كأنه سحابة، فلما دنت منهم خرجوا إليها رجاءَ بردها، فلما كانوا تحتها مطرت عليهم نارًا. قال: فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: بعث الله شعيبًا إلى أصحاب الأيكة، والأيكة: غيضة، فكذبوه، فأخذهم عذاب يوم الظلة. قال: فتح الله عليهم بابًا مِن أبواب جهنم، فغشيهم مِن حرِّه ما لم يُطيقوه، فتَغَوَّثوا بالماء وبما قدروا عليه، فبينما هم كذلك إذا رُفِعت لهم سحابةٌ فيها ريح باردة طيبة، فلمّا وجدوا بردها –الظلة- تنادوا: عليكم الظلة. فأتوها يتغوثون بها، فخرجوا من كل شيء كانوا فيه، فلما تكاملوا تحتها طبقت عليهم بالعذاب، فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>{22}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٣<span class="dash">-</span></span> عن <span class="name-2">منصور [بن المعتمر]</span> -من طريق محمد بن جابر- <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: بعث الله عليهم سحابة تنضح عليهم بالنار{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق مالك- قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>، قال: صارت الغمام عليهم نارًا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق داود بن قيس الفراء- قال: كان ينهاهم عن قطع الدراهم، فأخذهم عذاب يوم الظلة، حتى إذا اجتمعوا كلهم كشف الله عنهم الظلة، وأحمى عليهم الشمس، فاحترقوا كما يحترق الجراد في المقلى{25}. (١١/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٦<span class="dash">-</span></span> عن <span class="name-3">جعفر [بن محمد بن علي]</span> -من طريق يعقوب- في قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>، قال: كانوا يحفرون الأسراب لِيَتَبَرَّدوا فيها، فإذا دخلوها وجدوها أشدَّ حرًا مِن الظاهر، وكانت الظلة سحابة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكذبوه﴾</span> بالعذاب، <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span> وذلك أنّ الله ﷿ كان حبس عنهم الريح والظل، فأصابهم حر شديد، فخرجوا من منازلهم، فرفع الله ﷿ سحابةً فيها عذاب بعد ما أصابهم الحر سبعة أيام، فانقلبوا ليستظلوا تحتها، فأهلكهم الله ﷿ حرًّا وغمًّا تحت السحابة، فذلك قوله ﷿: <span class="qpc-hafs">﴿إنه كان عذاب يوم عظيم﴾</span> لشدته{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٨<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج-: لما أنزل الله عليهم أول العذاب أخذهم منه حر شديد، فرفع الله لهم غمامة، فخرج إليها طائفة منهم ليستظلُّوا بها، فأصابهم منها رَوح وبرد وريح طيبة، فصبَّ الله عليهم من فوقهم من تلك الغمامة عذابًا، فذلك قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة، إنه كان عذاب يوم عظيم﴾</span>، قال: بعث الله إليهم ظُلَّة مِن سحاب، وبعث إلى الشمس، فأحرقت ما على وجه الأرض، فخرجوا كلهم إلى تلك الظُّلَّة، حتى إذا اجتمعوا كلُّهم كشف الله عنهم الظلة، وأحمى عليهم الشمس، فاحترقوا كما يحترق الجراد في المقلى{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٠<span class="dash">-</span></span> عن أبي نضرة العبدي، قال: حدَّثنا رجلٌ من الصدر الأول، قال: كان قوم شعيب يقتلون على الكِذْبَة فما فوقها، فكانوا إذ يصنعون ذلك عيشُهم فيه شِدَّة. قال: حتى أصاب بعضُ ملوكهم ذنبًا، فعُطِّل الحد. قال: حتى أباحوا [الخمر] نهارًا جهارًا في المجالس. قال: فبسط الله لهم الرزق عند ذلك، حتى قال قائل: لو سعرناه كنا قد عطلناها منذ زمان. قال: فلما أراد الله عقوبتهم بعث عليهم حرًّا شديدًا. قال: فلم ينفعهم بيتٌ، ولا ظِلٌّ، ولا شيء. قال: فانطلقوا يرتادون الرَّوْح والبَرْد. قال: فدخل داخل منهم الظُّلَّة، فوجدها باردة، فأذَّن في الناس: البردَ البردَ. فلما تَتامُّوا تحتها قذفها الله عليهم، فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</span>{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>: يعني: تلك السحابة{31}. (ز)</p></p><p></div></p></div>",footnotes:1:المِسَلَّة: الإبرة العظيمة. مختار الصحاح (سلل).أخرجه ابن أبي حاتم ٩/٢٨١٥.أخرجه ابن جرير ١٧/٦٣٩، وابن أبي حاتم ٩/٢٨١٥، والحاكم ٢/٥٦٩.الوَمَد والوَمَدَة: ندًى يجيء في صميم الحر مِن قِبَل البحر مع سكون ريح، وهو ما يُعَبَّر عنه اليوم بالرطوبة. اللسان والمعجم الوسيط (ومد).أخرجه ابن جرير ١٧/٦٣٨، وابن أبي حاتم ٩/٢٨١٤-٢٨١٥، والحاكم ٢/٥٦٨-٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧ (١٨٧)-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٦٣٧، وإسحاق البستي في تفسيره ص٥٤١. وعزاه السيوطي إلى الفريابي بلفظ: فأنشئت لهم سحابة، فأتوها، فصيح بهم فيها.الأسراب: جمع سَرَب، وهو حفير تحت الأرض، وقيل: بيت تحت الأرض. لسان العرب (سرب).أخرجه ابن أبي حاتم ٩/٢٨١٦.أخرج الفريابي -كما في فتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦٣٨-٦٣٩، وابن أبي حاتم ٩/٢٨١٦، والحاكم ٢/٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وفي تفسير مجاهد ص٥١٣ بلفظ: يعني: ظل العذاب الذي أتاهم.أخرجه ابن جرير ١٧/٦٤٠، وإسحاق البستي في تفسيره ص٥٤٢.يوضح هذه العبارةَ قولُ ابن عباس من طريق الضحاك: فحميت بيوتهم، وغلت مياههم.أخرجه ابن عساكر ٢٣/٧٤.ائتفكت: انقلبت. النهاية (أفك).الأفكة: العذاب. النهاية (أفك).أخرجه ابن أبي حاتم ٩/٢٨١٦.أخرجه ابن أبي حاتم ٩/٢٨١٦، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧-٤٧٨ (١٨٨)-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨١٥. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد. وتقدم أنّ ابن أبي حاتم ٩/٢٨١٥ أخرجه من قول عبد الله بن عمرو.أخرجه ابن جرير ١٧/٦٣٧ واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٣)-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨١٥، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٤)-.أخرجه ابن عساكر في تاريخ دمشق ٢٣/٧٨.أخرجه الحاكم ٢/٥٦٩.أخرجه ابن جرير ١٧/٦٣٧.تفسير مقاتل بن سليمان ٣/٢٧٩.أخرجه ابن جرير ١٧/٦٣٩.أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٧ مختصرًا من طريق أصبغ.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧ (١٨٦)-، وابن أبي حاتم ٩/٢٨١٦، وأخرج نحوه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦٣٩، وابن أبي حاتم ٩/٢٨١٧ عن معمر بن راشد، عن رجل من أصحابه، عن بعض العلماء.تفسير يحيى بن سلّام ٢/٥٢٣.
  26,190,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٩٠ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> إنّ في هلاكهم بالحر والغم لعبرة لمن بعدهم، يُحَذِّر كُفّار مكة أمة محمد ﷺ، ثم قال ﷿: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> يعني: لو كان أكثرهم مؤمنين ما عذبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته من أعدائه، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إن في ذلك لآية وما كان أكثرهم مؤمنين (١٩٠) وإن ربك لهو العزيز الرحيم (١٩١)﴾</span> وهي مثل الأولى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.تفسير يحيى بن سلّام ٢/٥٢٣.
