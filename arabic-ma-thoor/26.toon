  26,200,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ سَلَكۡنَـٰهُ فِی قُلُوبِ ٱلۡمُجۡرِمِینَ ۝٢٠٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> قال: أدخلنا الشرك والتكذيب <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿المجرمين﴾</span>: الكُفّار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٤<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق حميد الطويل- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span>، قال: الشِّرْك، سلكه في قلوب المشركين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> قال: أدخلنا الشرك والتكذيب <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span>، قال: القَسْوَة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق حماد بن سلمة، عن حُمَيد- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span>، قال: الشرك، جعلناه في قلوب المجرمين{6}. (١١/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان، عن حُمَيد- في هذه الآية: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span>، قال: خَلَقْناه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق همام- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span>، قال: جعلناه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> قال: الكفر <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> يعني: هكذا جعلنا الكفر بالقرآن <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span> [قال: الشرك]{11}<span class=comment-ref>٤٨٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٥</span> لم يذكر <u>ابنُ جرير</u> (١٧/٦٤٨-٦٤٩) في معنى: <span class="qpc-hafs">﴿كَذَلِكَ سَلَكْناهُ فِي قُلُوبِ المُجْرِمِينَ﴾</span> سوى قول الحسن، وابن جريج، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> جعلناه <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span> المشركين، التكذيب{12}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/١٢٩.أخرجه ابن أبي حاتم ٩/٢٨٢٢.أخرجه ابن أبي حاتم ٩/٢٨٢١-٢٨٢٢.تفسير البغوي ٦/١٢٩.أخرجه ابن أبي حاتم ٩/٢٨٢٩.أخرجه ابن جرير ١٧/٦٤٩ بلفظ: الشرك سلكه في قلوبهم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٦٤٩.أخرجه ابن أبي حاتم ٩/٢٨٢١.أخرجه ابن جرير ١٧/٦٤٩.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن جرير ١٧/٦٤٩. وعلَّقه ابن أبي حاتم ٩/٢٨٢١. وما بين المعقوفين ساقط من نسخة ابن جرير، ويدل عليه ما علَّقه ابن أبي حاتم.تفسير يحيى بن سلّام ٢/٥٢٥.
  26,201,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یُؤۡمِنُونَ بِهِۦ حَتَّىٰ یَرَوُا۟ ٱلۡعَذَابَ ٱلۡأَلِیمَ ۝٢٠١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لا يؤمنون به﴾</span>، قال: إذا كذَّبوا سَلَك الله في قلوبهم ألّا يؤمنوا به{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿لا يؤمنون به﴾</span>، يقول: لا يؤمنون بما جاء به محمدٌ ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يؤمنون به﴾</span> يعني: بالقرآن <span class="qpc-hafs">﴿حتى يروا العذاب الأليم﴾</span> يعني: الوجيع{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٧<span class="dash">-</span></span> عن أصبغ، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قول الله تعالى: <span class="qpc-hafs">﴿سلكناه في قلوب المجرمين لا يؤمنون به﴾</span>، قال: هي كما قال: هو أضلَّهم، ومنعهم الإيمان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿لا يؤمنون به﴾</span> بالقرآن <span class="qpc-hafs">﴿حتى يروا العذاب الأليم﴾</span> المُوجِع، يعني: قيام الساعة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٢.أخرجه ابن أبي حاتم ٩/٢٨٢٢.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن أبي حاتم ٩/٢٨٢٢.تفسير يحيى بن سلّام ٢/٥٢٥.
  26,202,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَأۡتِیَهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٢٠٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسام- أنّه قرأ: (فَتَأْتِيهِم بَغْتَةً) بالتاء. فقال له رجل: يا أبا سعيد، إنما يأتيهم العذاب بغتة. فانتهره الحسن، وقال: إنما هي الساعة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَأۡتِیَهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٢٠٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فيأتيهم﴾</span> العذاب <span class="qpc-hafs">﴿بغتة﴾</span> يعني: فجأة، <span class="qpc-hafs">﴿وهم لا يشعرون﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فيأتيهم بغتة﴾</span> فجأة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي ٧/١٨١.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/١٣٧.تفسير مقاتل بن سليمان ٣/٢٨٠.تفسير يحيى بن سلّام ٢/٥٢٥.
  26,203,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَقُولُوا۟ هَلۡ نَحۡنُ مُنظَرُونَ ۝٢٠٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فيتَمَنَّوْن الرجعة والنظرة، فذلك قوله سبحانه: <span class="qpc-hafs">﴿فيقولوا﴾</span> يعني: كفار مكة: <span class="qpc-hafs">﴿هل نحن منظرون﴾</span> فنعتب ونراجع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فيقولوا﴾</span> يومئذ عند ذلك: <span class="qpc-hafs">﴿هل نحن منظرون﴾</span> مُؤَخَّرون، مردودون إلى الدنيا؛ فنُؤْمِن{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٨٠.تفسير يحيى بن سلّام ٢/٥٢٥.
  26,204,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا أوعدهم النبيُّ ﷺ العذابَ قالوا: فمتى هذا العذاب؟ تكذيبًا به. يقول الله ﷿: <span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span> على الاستفهام، أي: قد استعجلوا به لقولهم: <span class="qpc-hafs">﴿ائتنا بعذاب الله﴾</span> [العنكبوت:٢٩]، وذلك منهم استهزاء وتكذيب بأنّه لا يأتيهم العذاب{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٦<span class="dash">-</span></span> عن أنس بن مالك: أنّ رسول الله ﷺ عادَ رجلًا مِن المسلمين قد خفت فصارَ مِثل الفَرْخ، فقال له رسول الله ﷺ: «<b>هل كنت تدعو بشيء، أو تسأله إيّاه</b>؟». قال: نعم، كنت أقول: اللهم، ما كنت معاقبي به في الآخرة فعجِّله لي في الدنيا. فقال رسول الله ﷺ: «<b>سبحان الله! لا تُطِيقه</b> –أو: <b>لا تستطيعه</b>-، <b>أفلا قلتَ: اللهم، آتِنا في الدنيا حسنة، وفي الآخرة حسنة، وقنا عذاب النار؟!</b>». قال: فدعا اللهَ له، فشفاه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٨٠. وفي تفسير الثعلبي ٧/١٨١، وتفسير البغوي ٦/١٣٠ مثله منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلّام ٢/٥٢٥.أخرجه مسلم ٤/٢٠٦٨ (٢٦٨٨)، وابن جرير ٣/٥٤٥، وابن أبي حاتم ٩/٢٨٢٢ (١٥٩٩٦)، والبغوي في تفسيره ١/٢٣٣. وأورده الثعلبي ٢/١١٦.
  26,205,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٧<span class="dash">-</span></span> عن <span class="name-2">أبي جَهْضَمٍ</span>، قال: رُئي النبيُّ ﷺ كأنّه مُتَحَيِّر، فسألوه عن ذلك، فقال: «<b>ولِمَ؟! ورأيت عَدُوِّي يَلُونَ أمر أمتي من بعدي</b>». فنزلت: <span class="qpc-hafs">﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</span> فطابت نفسُه{1}. (١١/٣٠١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</span> - تفسير الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span>، قال: مثل عمر الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٩٩<span class="dash">-</span></span> عن أبي زيد فيض بن إسحاق، قال: سألتُ <span class="name-3">الفُضَيل بن عياض</span> عن قول الله ﷿: <span class="qpc-hafs">﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</span>، قال: قراءتها تفسيرُها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span> في الدنيا، <span class="qpc-hafs">﴿ثم جآءهم﴾</span> بعد ذلك العذاب <span class="qpc-hafs">﴿ما كانوا يوعدون * مآ أغنى عنهم﴾</span> مِن العذاب <span class="qpc-hafs">﴿ما كانوا يمتعون﴾</span> في الدنيا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span> إلى قوله: <span class="qpc-hafs">﴿ما أغنى عنهم ما كانوا يمتعون﴾</span>، قال: هؤلاء أهل الكفر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ثم جاءهم ما كانوا يوعدون﴾</span> العذاب{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٦٠٣<span class="dash">-</span></span> عن <span class="name-3">سليمان بن عبد الملك</span> -من طريق يزيد بن حازم- أنّه كان لا يَدَعُ أن يقول في خطبته كل جمعة: إنما أهل الدنيا فيها على وجَل، لم تمضِ بهم نِيَّة، ولم تَطْمَئِنَّ لهم دارٌ، حتى يأتي أمرُ الله وهم على ذلك، لا يدوم نعيمها، ولا تؤمن فجعاتها، ولا يبقى فيها شيء. ثم يتلو: <span class="qpc-hafs">﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</span>{7}. (١١/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠٤<span class="dash">-</span></span> عن عبيد الله بن موسى، قال: سمعت <span class="name-3">الحسن بن صالح</span> يقول: لقد دخل الترابَ مِن هذا المِصْرَ قومٌ قطعوا عنهم الدنيا بالصبر على طاعة الله، وبيَّن لهم هذا القرآنُ غِيَر{8} الدنيا، قال: <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين ثم جاءهم ما كانوا يوعدون ما أغنى عنهم ما كانوا يمتعون﴾</span>. ثم بكى حسن، ثم قال: إذا جاء الموتُ وسَكَراتُه لم يُغْنِ عن الفتى ما كان فيه مِن النعيم واللذة. ثم مال مَغْشِيًّا عليه{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٣ (١٥٩٩٧) مرسلًا.أخرجه يحيى بن سلّام ٢/٥٢٥.أخرجه ابن أبي حاتم ٩/٢٨٢٣.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن جرير ١٧/٦٥١، وابن أبي حاتم ٩/٢٨٢٣ مختصرًا من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٢٥.أخرجه ابن أبي الدنيا في كتاب ذم الدنيا -موسوعة الإمام ابن أبي الدنيا ٥/١٣٠-١٣١ (٢٧١)-، وابن أبي حاتم ٩/٢٨٢٢ (١٥٩٩٦). وعزاه السيوطي إلى عبد بن حميد.غِيَر الدنيا: تغيُّر حالها، وانتقالها عن الصلاح إلى الفساد. النهاية (غير).أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢٣٣ (٦١)-.
