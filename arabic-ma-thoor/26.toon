  26,100,""
  26,101,""
  26,102,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَوۡ أَنَّ لَنَا كَرَّةࣰ فَنَكُونَ مِنَ ٱلۡمُؤۡمِنِینَ ۝١٠٢ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٠٣ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٠٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فلو أن لنا كرة﴾</span> قال: رجعة إلى الدنيا، <span class="qpc-hafs">﴿فنكون من المؤمنين﴾</span> قال: حتى تحل لنا الشفاعة كما حلَّت لهؤلاء{1}. (١١/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿فلو أن لنا كرة﴾</span> يعني: رجعة إلى الدنيا؛ <span class="qpc-hafs">﴿فنكون من المؤمنين﴾</span> يعني: من المصدقين بالتوحيد، <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يعني: إن في هلاك قوم إبراهيم لعبرة لمن بعدهم، <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> يقول: لو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين. هلك قوم إبراهيم بالصيحة، تفسيره في سورة العنكبوت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فلو أن لنا كرة﴾</span> رجعة إلى الدنيا؛ <span class="qpc-hafs">﴿فنكون من المؤمنين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٨٧.تفسير مقاتل بن سليمان ٣/٢٧١.تفسير يحيى بن سلام ٢/٥١١.
  26,103,""
  26,103,""
  26,104,""
  26,105,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ قَوۡمُ نُوحٍ ٱلۡمُرۡسَلِینَ ۝١٠٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل- أنه سُئل: يا أبا سعيد، أرأيت قوله: <span class="qpc-hafs">﴿كذبت قوم نوح المرسلين﴾</span>، و<span class="qpc-hafs">﴿كذبت عاد المرسلين﴾</span>، و<span class="qpc-hafs">﴿كذبت ثمود المرسلين﴾</span>، وإنما أرسل إليهم رسول واحد؟ قال: إنّ الآخر جاء بما جاء الأول، فإذا كذبوا واحدًا فقد كذبوا الرسل أجمعين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذبت قوم نوح المرسلين﴾</span>، يعني: كذبوا نوحًا وحده. نظيرها في <span class="qpc-hafs">﴿اقتربت الساعة﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿كذبت قوم نوح المرسلين﴾</span>، يعني: نوحًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي ٧/١٧٣، وينظر: تفسير البغوي ٦/١٢٠.تفسير مقاتل بن سليمان ٣/٢٧١. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍ فَكَذَّبُوا عَبْدَنا وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</span> [القمر:٩].تفسير يحيى بن سلام ٢/٥١٢.
  26,106,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ نُوحٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ قال لهم أخوهم نوح﴾</span>، ليس بأخيهم في الدين، ولكن أخوهم في النسب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٢٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إذ قال لهم أخوهم نوح﴾</span>، أخوهم في النسب، وليس بأخيهم في الدين{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَا تَتَّقُونَ ۝١٠٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٢٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ألا تتقون﴾</span>، يقول: ألا تخشون الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا تتقون﴾</span>، يعني: ألا تخشون الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يأمرهم أن يتقوا الله{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧١.تفسير يحيى بن سلام ٢/٥١٢.علَّقه يحيى بن سلام ٢/٥١٢.تفسير مقاتل بن سليمان ٣/٢٧١.تفسير يحيى بن سلام ٢/٥١٢.
  26,107,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٠٧ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٠٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span> فيما بينكم وبين ربكم، <span class="qpc-hafs">﴿فاتقوا الله﴾</span> يعني: فاعبدوا الله، <span class="qpc-hafs">﴿وأطيعون﴾</span> فيما آمركم به من النصيحة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span> على ما جئتكم به{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٢.تفسير يحيى بن سلام ٢/٥١٢.
  26,108,""
  26,106,""
  26,107,""
  26,108,""
  26,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٠٩ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿وما اسالكم عليه من اجر﴾</span>، يقول: عَرَضًا مِن عَرَض الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿إن أجري إلا على الله﴾</span>، قال: جزائي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أسألكم عليه من أجر﴾</span> يعني: جُعْلًا، وذلك أنهم قالوا للأنبياء: إنما تريدون أن تملكوا علينا في أموالنا. فردت عليهم الأنبياء، فقالوا: لا نسألكم عليه من أجر. يعني: على الإيمان جُعلًا، <span class="qpc-hafs">﴿إن أجري﴾</span> يعني: جزائي <span class="qpc-hafs">﴿إلا على رب العالمين، فاتقوا الله﴾</span> يعني: فاعبدوا الله، <span class="qpc-hafs">﴿وأطيعون﴾</span> فيما آمركم به مِن النصيحة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣٧<span class="dash">-</span></span> عن أصبغ بن الفرج، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> يقول في قول الله: <span class="qpc-hafs">﴿وما أسالكم عليه من أجر﴾</span>، يقول: لا أسالكم على القرآن أجرًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أسألكم عليه﴾</span> على ما جئتكم به مِن الهدى <span class="qpc-hafs">﴿من أجر إن أجري﴾</span> إن ثوابي <span class="qpc-hafs">﴿إلا على رب العالمين﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٨٨.أخرجه ابن أبي حاتم ٨/٢٧٨٨.تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن أبي حاتم ٨/٢٧٨٨ في تفسير هذه الآية. كما أخرجه في تفسير قوله تعالى: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ قُلْ لا أسْأَلُكُمْ عَلَيْهِ أجْرًا إنْ هُوَ إلّا ذِكْرى لِلْعالَمِينَ﴾</span> [الأنعام:٩٠]، وقوله تعالى: <span class="qpc-hafs">﴿قُلْ ما أسْأَلُكُمْ عَلَيْهِ مِن أجْرٍ إلّا مَن شاءَ أنْ يَتَّخِذَ إلى رَبِّهِ سَبِيلًا﴾</span> [الفرقان:٥٧]، ولعل مراده: أن تفسير هذه الآية نظير تفسير آيتي الأنعام والفرقان، أي: أن نوحًا قال لقومه نحو ما قاله الأنبياء لما قالت لهم أقوامهم ذلك، ولذلك قال مقاتل بن سليمان في تفسير هذه الآية: وذلك أنهم قالوا للأنبياء ... فردت عليهم الأنبياء ...تفسير يحيى بن سلام ٢/٥١٢. وقد تقدم بسط قصة نوح ﵇ مع قومه في سورتي الأعراف وهود.
  26,110,""
  26,110,""
  26,111,""
  26,112,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ وَمَا عِلۡمِی بِمَا كَانُوا۟ یَعۡمَلُونَ ۝١١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> نوح ﵇: <span class="qpc-hafs">﴿وما علمي بما كانوا يعملون﴾</span> يقول: لم أكن أعلم أنّ الله يهديهم للإيمان مِن بينكم، ويَدَعُكُم!{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٥٠<span class="dash">-</span></span> عن أصبغ، قال: سمعتُ <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> في قول الله: <span class="qpc-hafs">﴿يعملون﴾</span>، قال: يعملون ويصنعون واحد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما علمي بما كانوا يعملون﴾</span>، أي: بما يعملون، إنّما أقبل منهم الظاهر، وليس لي بباطن أمرهم عِلْمٌ{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن أبي حاتم ٨/٢٧٨٨.تفسير يحيى بن سلّام ٢/٥١٢.
  26,113,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنۡ حِسَابُهُمۡ إِلَّا عَلَىٰ رَبِّیۖ لَوۡ تَشۡعُرُونَ ۝١١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٥٢<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إن حسابهم﴾</span>، يعني: ما جزاؤهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿إن حسابهم إلا على ربي﴾</span>، قال: هو أعلم بما في أنفسهم{2}. (١١/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال نوح ﵇: <span class="qpc-hafs">﴿إن حسابهم﴾</span> يعني: ما جزا[ؤهم] <span class="qpc-hafs">﴿إلا على ربي لو تشعرون﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنۡ حِسَابُهُمۡ إِلَّا عَلَىٰ رَبِّیۖ لَوۡ تَشۡعُرُونَ ۝١١٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦١٥٥<span class="dash">-</span></span> عن زِرّ بن حُبَيْشٍ، قال: شهدتُ صاحبَنا <span class="name-1">وابصةَ بن معبد</span>، وسمع رجلين يتنازعان في أهل العراق وأهل الشام، يعيب أحدُهما هؤلاء، ويعيب الآخرُ هؤلاء. قال وابصة: فهلّا يقولون غير ذلك! قال: وما نقول؟ قال: يقولان: <span class="qpc-hafs">﴿إن حسابهم إلا على ربي لو تشعرون﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ٢/٥١٢.أخرجه ابن جرير ١٧/٦٠٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن أبي حاتم ٨/٢٧٨٩.
  26,114,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنَا۠ بِطَارِدِ ٱلۡمُؤۡمِنِینَ ۝١١٤ إِنۡ أَنَا۠ إِلَّا نَذِیرࣱ مُّبِینࣱ ۝١١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿نذير﴾</span>، قال: نذير مِن النار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنا بطارد المؤمنين﴾</span> يقول: وما أنا بالذي لا يقبل الإيمان مِن الذين تزعمون أنهم الأرذلون عندكم، <span class="qpc-hafs">﴿إن أنا﴾</span> يعني: ما أنا <span class="qpc-hafs">﴿إلا نذير مبين﴾</span> يعني: رسول بَيِّن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أنا بطارد المؤمنين (١١٤)﴾</span> يعنيهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٨٩.تفسير مقاتل بن سليمان ٣/٢٧٢.تفسير يحيى بن سلّام ٢/٥١٢.
  26,115,""
  26,113,""
  26,114,""
  26,115,""
  26,116,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَىِٕن لَّمۡ تَنتَهِ یَـٰنُوحُ لَتَكُونَنَّ مِنَ ٱلۡمَرۡجُومِینَ ۝١١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span>، قال: مِن المقتولين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span>، قال: مِن المشتومين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق النضر أبي محمد- <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span>، قال: تواعدوه بالقتل{3}. (١١/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span>، قال: بالحجارة{5}. (١١/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span>، قال: بالشتيمة{3}. (١١/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٥<span class="dash">-</span></span> <span class="name-2">قال [أبو حمزة]</span> <span class="name-2">الثمالي</span>: كل شيء في القرآن مِن ذكر المرجومين فإنّه يعني بذلك: القتل؛ إلا التي في سورة مريم [٤٦]: <span class="qpc-hafs">﴿لئن لم تنته لأرجمنك﴾</span>، فإنّه يعني: لأشتمنَّك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: مِن المقتولين بالحجارة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا لئن لم تنته﴾</span> يعني: لئن لم تسكت <span class="qpc-hafs">﴿يا نوح﴾</span> عنّا؛ <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span> يعني: مِن المقتولين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالوا لئن لم تنته يا نوح﴾</span> عما تدعونا إليه، وعن ذمِّ آلهتنا وشتمها. <span class="qpc-hafs">﴿لتكونن من المرجومين﴾</span> قال <span class="name-2">قتادة</span>: بالحجارة، فلنقتلنَّك بها{10}<span class=comment-ref>٤٨١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٤٩٦) أن قولهم: <span class="qpc-hafs">﴿مِنَ المَرْجُومِينَ﴾</span> <b>يحتمل</b> أن يريدوا: بالحجارة، و<b>يحتمل</b> أن يريدوا: بالقول والشتم ونحوه، ثم <span class="comment-type-4">علَّق</span> على الاحتمال الثاني بقوله: «وهو شبيه برجم الحجارة، وهو من الرجم بالغيب والظن ونحو ذلك».</div></p></div>",footnotes:1:تفسير الثعلبي ٧/١٧٣.تفسير البغوي ٦/١٢١. وتصحَّفت في تفسير الثعلبي ٧/١٧٣ إلى: المشؤومين.أخرجه ابن أبي حاتم ٨/٢٧٨٩.علَّقه ابن أبي حاتم ٨/٢٧٨٩.أخرجه ابن أبي حاتم ٨/٢٧٨٩. وعلَّقه يحيى بن سلّام ٢/٥١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٨٩.تفسير الثعلبي ٧/١٧٣.تفسير البغوي ٦/١٢١.تفسير مقاتل بن سليمان ٣/٢٧٢. وآخره في تفسير الثعلبي ٧/١٧٣، وتفسير البغوي ٦/١٢١ منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلّام ٢/٥١٢.
  26,117,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ إِنَّ قَوۡمِی كَذَّبُونِ ۝١١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> نوح: <span class="qpc-hafs">﴿رب إن قومي كذبون﴾</span> البعث{1}. (ز)</p></p><p></div></p></div>",footnotes:1:هكذا في تفسير مقاتل بن سليمان ٣/٢٧٢.
  26,118,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱفۡتَحۡ بَیۡنِی وَبَیۡنَهُمۡ فَتۡحࣰا وَنَجِّنِی وَمَن مَّعِیَ مِنَ ٱلۡمُؤۡمِنِینَ ۝١١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- قال: ما كنتُ أدري ما قوله: <span class="qpc-hafs">﴿افتح بيننا وبين قومنا بالحق﴾</span> [الأعراف:٨٩]، حتى سمعت ابن ذي يزن يقول: تعالي أُفاتحك. يعني: تعال أُخاصمك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فافتح بيني وبينهم فتحا﴾</span>، قال: اقضِ بيني وبينهم قضاءً{2}. (١١/ ٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، مثله{3}. (١١/ ٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، نحوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فافتح بيني وبينهم فتحا﴾</span> يقول: اقض بيني وبينهم قضاءً، يعني: العذاب، <span class="qpc-hafs">﴿ونجني ومن معي من المؤمنين﴾</span> مِن الغرق، فنجّاه الله ﷿{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فافتح بيني وبينهم فتحا﴾</span>، قال: اقضِ بيني وبينهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ونجني ومن معي من المؤمنين﴾</span>، والفتح: القضاء. وإذا قضى الله بين النبيِّ وقومه هلكوا، وهذا حيثُ أمر بالدعاء عليهم، فاستجيب له، فأهلكهم الله، ونجّاه ومَن معه من المؤمنين{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٩٠.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦٠٤، وابن أبي حاتم ٨/٢٧٩٠ من طريق سعيد. وعلَّقه يحيى بن سلّام ٢/٥١٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٨/٢٧٩٠.تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن جرير ١٧/٦٠٤. وعلَّقه ابن أبي حاتم ٨/٢٧٩٠.تفسير يحيى بن سلّام ٢/٥١٣.
  26,119,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَنجَیۡنَـٰهُ وَمَن مَّعَهُۥ فِی ٱلۡفُلۡكِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٧٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السُّدِّيّ- <span class="qpc-hafs">﴿في الفلك المشحون﴾</span>، قال: سفينة حمل فيها مِن كل زوجين اثنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، <span class="qpc-hafs">﴿في الفلك المشحون﴾</span>، قال: سفينة نوح{2}. (١١/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٧٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، نحو ذلك{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡمَشۡحُونِ ۝١١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿الفلك المشحون﴾</span>. قال: السفينة المُوقَرة{4} الممتلئة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عبيد بن الأبرص:</p><p>شَحَنّا أرضهم بالخيل حتى تركناهم أذلَّ من الصِّراطِ؟{5}. (١١/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿الفلك المشحون﴾</span>، قال: المُمْتَلِئ{6}. (١١/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- أنّه قال: تدرون ما المشحون؟ قلنا: لا. قال: هو المُوقَر{7}. (١١/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: المُثْقَل{8}. (١١/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿الفلك المشحون﴾</span>، قال: المملوء المفروغ منه تحميلًا{9}. (١١/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، <span class="qpc-hafs">﴿في الفلك المشحون﴾</span>، قال: المُثْقَل{10}. (١١/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي مودود- في قوله: <span class="qpc-hafs">﴿الفلك المشحون﴾</span>، قال: المستدير{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٨<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، في قوله: <span class="qpc-hafs">﴿المشحون﴾</span>، قال: المثقل{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿في الفلك المشحون﴾</span>، قال: المحمَّل{13}. (١١/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿في الفلك المشحون﴾</span>، كُنّا نُحَدَّث: أنّه الموقر{2}. (١١/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأنجيناه ومن معه في الفلك المشحون﴾</span>، يعني: الموقر مِن الناس والطير والحيوان كلها، من كل صنف ذكر وأنثى{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأنجيناه ومن معه في الفلك المشحون﴾</span>، والمشحون: الموقر بحمله مما حمل نوح في السفينة من كل زوجين اثنين، ومَن معه من المؤمنين، كان معه امرأته وثلاثة بنين له: سام، وحام، ويافث، ونساؤهم، فجميعهم ثمانية{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٩١.علَّقه ابن أبي حاتم ٨/٢٧٩١. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٨/٢٧٩١.المُوقَرة: المثْقَلة، من الوِقر -بكسر الواو-: الحِمْل. النهاية (وقر).أخرجه الطستي -كما في الإتقان ٢/٨٠-.أخرجه ابن جرير ١٩/٤٤٢، وابن أبي حاتم -كما في الإتقان ٢/٣٩-.أخرجه ابن جرير ١٧/٦٠٤-٦٠٥، وابن أبي حاتم ٨/٢٧٩١ من طريق سعيد بن جبير. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٩/٤٤٢.أخرجه ابن جرير ١٧/٦٠٥، وابن أبي حاتم ٨/٢٧٩٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الثوري في تفسيره ص٢٢٩.تفسير الثعلبي ٧/١٧٣.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦٠٥. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٨/٢٧٩١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٧٣.تفسير يحيى بن سلّام ٢/٥١٣.
  26,120,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ أَغۡرَقۡنَا بَعۡدُ ٱلۡبَاقِینَ ۝١٢٠ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٢١ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم أغرقنا بعد﴾</span> أهل السفينة <span class="qpc-hafs">﴿الباقين﴾</span> يعني: مَن بقي منهم مِمَّن لم يركب السفينة، <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يقول: إنّ في هلاك قوم نوح لعبرة لِمَن بعدهم مِن هذه الأمة، ليحذروا مثل عقوبتهم. ثم قال تعالى: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> يعني: مُصَدِّقين بتوحيد الله ﷿. يقول: كان أكثرهم كافرين بالتوحيد، ولو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا. ثم قال سبحانه: <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نِقْمَته منهم بالغرق، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين إذ نَجّاهم من الغرق، إنّما ذكر الله تعالى تكذيب الأمم الخالية رسلهم لَمّا كذَّب كُفّار قريش النبيَّ ﷺ بالرسالة، أخبر الله ﷿ النبيَّ ﷺ أنه أرسله كما أرسل نوحًا وهودًا وصالحًا ولوطًا وشعيبًا، فكذبهم قومهم، فكذلك أنت، يا محمد. وذكر عقوبة الذين كذبوا رسلهم لئلا يُكَذِّب كفار قريش محمدًا ﷺ، فحذَّرهم مثلَ عذاب الأمم الخالية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦١٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ثم أغرقنا بعد﴾</span> من أنجينا في السفينة <span class="qpc-hafs">﴿الباقين﴾</span> وهم قوم نوح، وفيها تقديم، ثم أغرقنا الباقين بعد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٣.تفسير يحيى بن سلّام ٢/٥١٣.
