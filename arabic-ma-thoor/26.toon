  26,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبُّ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ وَمَا بَیۡنَهُمَاۤۖ إِن كُنتُمۡ تَعۡقِلُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿رب المشرق والمغرب﴾</span>، قال: عدد أيام السنة لها كل يوم مطلع ومغرب، لا ترجع إلى مطلعها ذلك إلى يوم القيامة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٩<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق أبي إسرائيل- في قوله: <span class="qpc-hafs">﴿رب المشرقين ورب المغربين﴾</span> [الرحمن:١٧]، قال: الشمس تطلع في الشتاء وتغرب، لها مغرب في الصيف ومطلع. وفي قوله: <span class="qpc-hafs">﴿رب المشرق والمغرب﴾</span>، قال: لها كل يوم مطلع ومغرب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: هو <span class="qpc-hafs">﴿رب المشرق والمغرب﴾</span> يعني: مشرق ومغرب يومٍ، يستوي الليل والنهار في السنة يومين، ويسمى البرج: الميزان. ثم قال: <span class="qpc-hafs">﴿وما بينهما﴾</span> يعني: ما بين المشرق والمغرب من جبل، أو بناء، أو شجر، أو شيء؛ <span class="qpc-hafs">﴿إن كنتم تعقلون﴾</span> توحيد الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿قال رب المشرق والمغرب﴾</span> أي: خالق المشرق والمغرب، <span class="qpc-hafs">﴿وما بينهما﴾</span> أي: خالق ما بينهما مِن الخَلْق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٢<span class="dash">-</span></span> عن أصبغ بن الفرج، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> في قوله: <span class="qpc-hafs">﴿تعقلون﴾</span>: يتفكرون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿رب المشرق والمغرب وما بينهما إن كنتم تعقلون﴾</span>. وهذا تبع للكلام الأول: <span class="qpc-hafs">﴿وما رب العالمين﴾</span>{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو الشيخ في العظمة ٤/١١٩٩ (٦٧٠).أخرجه أبو الشيخ في العظمة ٤/١١٩٨ (٦٦٧).تفسير مقاتل بن سليمان ٣/٢٦١.أخرجه ابن أبي حاتم ٨/٢٧٥٦-٢٧٥٧.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير يحيى بن سلام ٢/٥٠٠.
  26,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَىِٕنِ ٱتَّخَذۡتَ إِلَـٰهًا غَیۡرِی لَأَجۡعَلَنَّكَ مِنَ ٱلۡمَسۡجُونِینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٣٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان سجنُه أشدَّ مِن القتل؛ لأنّه كان يأخذ الرجل فيطرحه في مكان وحده فردًا، لا يسمع ولا يُبْصِر فيه شيئًا، يهوي به في الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿لئن اتخذت إلها غيري﴾</span> يعني: ربًّا <span class="qpc-hafs">﴿لأجعلنك من المسجونين﴾</span> يعني: مِن المحبوسين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿قال لئن اتخذت الها غيري لأجعلنك من المسجونين﴾</span>: أي: إن أقمت على هذا أن تعبد غيري، وتترك عبادتي؛ لأجعلنك من المسجونين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿لئن اتخذت إلها غيري لأجعلنك من المسجونين﴾</span> لأخلدنك في السجن{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/١٦٢، وتفسير البغوي ٦/١١١.تفسير مقاتل بن سليمان ٣/٢٦١.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير يحيى بن سلام ٢/٥٠٠.
  26,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَوَلَوۡ جِئۡتُكَ بِشَیۡءࣲ مُّبِینࣲ ۝٣٠ قَالَ فَأۡتِ بِهِۦۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- قال: لقد دخل موسى على فرعون وعليه زُرْمانِقةٌ{1} مِن صوفٍ، ما تجاوِزُ مِرْفَقَه، فاستُؤْذِن على فرعون، فقال: أدْخِلوه. فدخل، فقال: إنّ إلهي أرسلني إليك. فقال للقوم حوله: ما علمتُ لكم من إله غيري، خذوه. قال: إنِّي قد جئتُك بآية. قال: <span class="qpc-hafs">﴿فائت به إن كنتَ من الصادقين﴾</span>{2}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين قال﴾</span> فرعون: <span class="qpc-hafs">﴿فأت به إن كنت من الصادقين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثم قال له فرعون: <span class="qpc-hafs">﴿إنْ كُنْتَ جِئْتَ بِآيَةٍ فَأْتِ بِها إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span> [الأعراف:١٠٦]. وذلك بعدما قال الله مِن الكلام ما ذكر الله، قال له موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين﴾</span> يعني: بأمر بيِّن، يعني: اليد والعصا، يستبين لك أمري فتصدقني. <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿فأت به إن كنت من الصادقين﴾</span> بأنّك رسول رب العالمين إلينا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿قال أولو جئتك بشيء مبين﴾</span>: أي: بأمر تعرف به صِدْقي وكَذِبك، وحَقِّي وباطلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال له موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين﴾</span> بيِّن، <span class="qpc-hafs">﴿قال فأت به إن كنت من الصادقين﴾</span>{7}. (ز)</p></p><p></div></p></div>",footnotes:1:الزُّرْمانقة: جُبَّة من صوف، أعجمي معرب. المعرب ص٢١٩، واللسان (زرمق).أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٥٣، ٢٧٥٧.أخرجه ابن أبي حاتم ٨/٢٧٥٧.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير مقاتل بن سليمان ٣/٢٦١.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير يحيى بن سلام ٢/٥٠٠.
