  26,149,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتࣰا فَـٰرِهِینَ ۝١٤٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٣١٣<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿وتَنْحِتُونَ﴾</span> بكسر الحاء، <span class="qpc-hafs">﴿مِنَ الجِبالِ بُيُوتًا فارِهِينَ﴾</span> بالألف{1}. (١١/٢٨٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قوله: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا﴾</span>، قال: كانوا يَنقُبُون في الجبال البيوت{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَـٰرِهِینَ ۝١٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذقين{3}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: ‹فَرِهِينَ›، قال: أشِرِين. ويقال: كيِّسِين{4}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٧<span class="dash">-</span></span> عن إسماعيل بن أبي خالد، قال: سألتُ <span class="name-2">عبد الله بن شداد بن الهاد</span> عن قول الله -جلَّ ذِكْرُه-: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فارهين﴾</span>. قال: تتخَيَّرون بيوتًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد</span> -من طريق إسماعيل بن أبي خالد، وإسماعيل السُّدِّيّ- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: يتجبرون{6}<span class=comment-ref>٤٨١٧</span>. (١١/٢٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥٠٠) على قول ابن شداد بقوله: «وذهب عبد الله بن شداد إلى أنّه بمعنى: مستفرهين، أي: مبالغين في استحازة الفارِهِ مِن كل ما يصنعونه ويشتهونه».</div></p><p><div></p><p><p><span class="item-no">٥٦٣١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول: ‹فَرِهِينَ›، قال: شَرِهِين{7}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٠<span class="dash">-</span></span> عن <span class="name-2">شهر بن حوشب</span>، نحو ذلك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق طلحة اليامي-: أشِرِين، بَطِرين، مَرِحين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذِقين، كيِّسين{10}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: ناعمين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٤<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: مُتَجَبِّرين{12}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٥<span class="dash">-</span></span> قال <span class="name-2">عطية العوفي</span>: مُتَخَيِّرين لمواضع نحتِها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذِقين بنحتها{14}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٧<span class="dash">-</span></span> عن <span class="name-2">معاوية بن قرة</span>، <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذقين{12}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- ‹فَرِهِينَ›: تفسيرها: آمنين{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: ‹فَرِهِينَ›، قال: مُعجَبين بصُنْعِكم{17}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق الوليد، عن سعيد- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: آمنين{18}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣١<span class="dash">-</span></span> عن <span class="name-2">خُصَيْف بن عبد الرحمن</span>، قال: مُعجَبين{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: مُتجبرين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٣<span class="dash">-</span></span> عن هارون الأعور، قال: وزعم آخرُ عن <span class="name-2">منصور بن المعتمر</span>: <span class="qpc-hafs">﴿فارهين﴾</span> حاذقين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٤<span class="dash">-</span></span> قال <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق هارون الأعور-: مِن قِبَل الفراهة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: مُعجَبين بصنعكم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٦<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>: حَذِقِين بصنعتها{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فارهين﴾</span>، يعني: حاذقين بنَحْتِها{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فرهين﴾</span>، قال: الفَرِهُ: القويّ{26}<span class=comment-ref>٤٨١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٨</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿فارهين﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿فارهين﴾</span>، <b>وقرأ آخرون</b>: ‹فَرِهِينَ›. و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٦٢٣) صحة كلتا القراءتين <span class="mustanad">مستندًا لشهرتهما واستفاضتهما</span>، فقال: «والصواب من القول في ذلك أن يُقال: إن قراءة مَن قرأها: <span class="qpc-hafs">﴿فارهين﴾</span> وقراءة مَن قرأ: ‹فَرِهِينَ› قراءتان معروفتان، مستفيضة القراءة بكل واحدة منهما في علماء القراء، فبأيتهما قرأ القارئ فمصيب». ثم <span class="comment-type-4">علَّق</span> (١٧/٦٢٤) بقوله: «ومعنى قراءة مَن قرأ: <span class="qpc-hafs">﴿فارهين﴾</span>: حاذقين بنحتها، متخيرين لمواضع نحتها، كيسين، مِن الفراهة. ومعنى قراءة من قرأ: ‹فَرِهِينَ›: مرِحين، أشرين. وقد يجوز أن يكون معنى فاره وفره واحدًا».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٠/٣٦٣) قول مَن قال: معناه: حاذقين. ومَن قال: معناه: شرهين أشرين. ثم بيَّن أنه لا منافاة بينهما، فقال: «ولا منافاة بينهما؛ فإنهم كانوا يتخذون تلك البيوت المنحوتة في الجبال أشرًا وبطرًا وعبثًا، مِن غير حاجة إلى سكناها، وكانوا حاذقين متقنين لنحتها ونقشها، كما هو المشاهد من حالهم لِمَن رأى منازلهم؛ ولهذا قال: <span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span> أي: أقبِلوا على عمل ما يعود نفعه عليكم في الدنيا والآخرة، من عبادة ربكم الذي خلقكم ورزقكم؛ لِتُوَحِّدوه، وتعبدوه، وتسبحوه بكرة وأصيلًا».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>و<span class="qpc-hafs">﴿فارِهِينَ﴾</span> بالألف قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وابن عامر، وقرأ بقية العشرة: ‹فَرِهِينَ› بإسقاط الألف. انظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٣.أخرجه ابن أبي حاتم ٩/٢٨٠٢.أخرجه ابن جرير ١٧/٦٢١، وابن أبي حاتم ٩/٢٨٠٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٦٢٢، وابن أبي حاتم ٩/٢٨٠٣.أخرجه إسحاق البستي في تفسيره ص٥٣٦. وفي تفسير الثعلبي ٧/١٧٦ بلفظ: متخيرين لمواضع نحتها.أخرجه ابن جرير ١٧/٦٢٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ١٧/٦٢٣، وابن أبي حاتم ٩/٢٨٠٢. وعلَّقه يحيى بن سلّام ٢/٥١٧ وعقّب عليه بقوله: من قِبَل شَرَه النفس. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.علَّقه ابن أبي حاتم ٩/٢٨٠٢.أخرجه إسحاق البستي في تفسيره ص٥٣٨.أخرجه ابن جرير ١٧/٦٢٠، وإسحاق البستي في تفسيره ص٥٣٧، وابن أبي حاتم ٩/٢٨٠٣ من طريق جويبر. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/١٧٦.أخرجه ابن جرير ١٧/٦٢١، وابن أبي حاتم ٩/٢٨٠٢. وعزاه السيوطي إلى الفريابي.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٥٣٦. وعلقه يحيى بن سلّام ٢/٥١٧.أخرجه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦٢٣، وإسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٨٠٣ من طريق سعيد. وعلَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٠٣. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٩/٢٨٠٣.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.أخرجه إسحاق البستي في تفسيره ص٥٣٨.أخرجه إسحاق البستي في تفسيره ص٥٣٨.أخرجه عبد الرزاق ٢/٧٥.علَّقه يحيى بن سلّام ٢/٥١٧.تفسير مقاتل بن سليمان ٣/٢٧٥.أخرجه ابن جرير ١٧/٦٢٣.
  26,150,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٥٠ وَلَا تُطِیعُوۤا۟ أَمۡرَ ٱلۡمُسۡرِفِینَ ۝١٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span>، قال: المشركين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span>، قال: هم المشركون{2}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span> فيما آمركم به مِن النصيحة، <span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span> يعني: التسعة الذين عقروا الناقة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/١٢٥.أخرجه عبد الرزاق ٢/٧٥، وابن أبي حاتم ٩/٢٨٠٣. وعلَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٥. وآخره في تفسير البغوي ٦/١٢٥ عن مقاتل منسوبًا إليه دون تعيينه.
