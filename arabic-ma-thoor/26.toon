  26,223,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُلۡقُونَ ٱلسَّمۡعَ وَأَكۡثَرُهُمۡ كَـٰذِبُونَ ۝٢٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٧٠٩<span class="dash">-</span></span> عن عائشة، في قوله: <span class="qpc-hafs">﴿وأكثرهم كاذبون﴾</span>، قال: قالت: قلت: يا رسول الله، إنّ الكُهّان كانوا يُحَدِّثوننا بالشيء فيكون حقًّا. قال: «<b>تلك الكلمة مِن الحقِّ، يخطفها الجني، فيقذفها في أذن ولِيِّه</b>». وقال: «<b>فيزيد فيها أكثر مِن مائة كذبة</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿يلقون السمع﴾</span>، قال: القول{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يلقون السمع﴾</span>، قال: ما سمعه الشيطانُ ألقاه على كل أفاك كذّاب مِن الناس{3}. (١١/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٢<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span> في قوله: <span class="qpc-hafs">﴿وأكثرهم كاذبون﴾</span>: أي: وجماعتهم كاذبون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يلقون السمع وأكثرهم كاذبون﴾</span>، قال: كانت الشياطين تصعد إلى السماء فتسَّمَّع، ثم تنزل إلى الكهنة فتخبرهم، فتحدِّث الكهنةُ بما أنزلت به الشياطينُ مِن السمع، وتخلط الكهنة كَذِبًا كثيرًا، فيُحَدِّثون به الناس، فأمّا ما كان مِن سمع السماء فيكون حقًّا، وأمّا ما خلطوا به من الكذب فيكون كذبًا{5}. (١١/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يلقون السمع﴾</span> يقول: تُلقِي الشياطين بآذانهم إلى السمع في السماء لكلام الملائكة، وذلك أنّ الله ﷿ إذا أراد أمرًا في أهل الأرض أعلمَ به أهل السموات مِن الملائكة، فتكلَّموا به، فتسمع الشياطينُ لكلام الملائكة، وترميهم بالشُّهُب، فيخطفون الخطفة، ثم قال ﷿: <span class="qpc-hafs">﴿وأكثرهم كاذبون﴾</span> يعني: الشياطين حين يخبرون الكهنة أنّه يكون في الأرض كذا وكذا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يلقون السمع وأكثرهم كاذبون﴾</span> كانت الشياطين تصعد إلى السماء تستمع، ثم تنزل إلى الكهنة، فتخبرهم، فتُحَدِّث الكهنة بما نزلت به الشياطين مِن السمع، وتخلط به الكهنة كذبًا كثيرًا فيُحَدِّثون به الناس، فأمّا ما كان مِن سمع السماء فيكون حقًّا، وما خلطوا به مِن الكذب يكون كذِبًا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُلۡقُونَ ٱلسَّمۡعَ وَأَكۡثَرُهُمۡ كَـٰذِبُونَ ۝٢٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٧١٦<span class="dash">-</span></span> عن عائشة، قالت: سأل أناسٌ النبيَّ ﷺ عن الكُهّان؟ فقال: «<b>إنهم ليسوا بشيء</b>». فقالوا: يا رسول الله، إنّهم يُحَدِّثوننا أحيانًا بالشيء يكون حقًّا. قال: «<b>تلك الكلمة مِن الحق يخطفها الجنيُّ، فيقذفها في أذن ولِيِّه، فيخلطون فيها أكثر مِن مائة كذبة</b>»{8}. (١١/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٧<span class="dash">-</span></span> عن عائشة، عن النبي ﷺ، قال: «<b>الملائكة تُحَدَّث في العنان</b> -<b>والعنان: الغمام</b>- <b>بالأمر في الأرض، فيسمع الشيطان الكَلِم، فيًقُرُّها في أذن الكاهن كما تُقَرُّ القارورة، فيزيدون معها مائة كذبة</b>»{9}. (١١/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧١٨<span class="dash">-</span></span> عن عمر بن عبد الله مولى غفرة، قال: سمعتُ <span class="name-2">محمد بن كعب القرظي</span>، يقول: واللهِ، ما لأحد مِن أهل الأرض في السماء نجمٌ، ولكنهم يتبعون ويتخذون النجوم عِلَّة، فهو كما أخبرنا الله: <span class="qpc-hafs">﴿إلا من خطف الخطفة فأتبعه شهاب ثاقب﴾</span> [الصافات:١٠]. قال: <span class="qpc-hafs">﴿على من تنزل الشياطين﴾</span> إلى قوله: <span class="qpc-hafs">﴿وأكثرهم كاذبون﴾</span>{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٣/٧٨، كما أخرجه البخاري ٧/١٣٦ (٥٧٦٢)، ٨/٤٧ (٦٢١٣)، ٩/١٦٢ (٧٥٦١)، ومسلم ٤/١٧٥٠ (٢٢٢٨) كلاهما دون ذكر الآية.أخرجه ابن جرير ١٧/٦٧٢، وابن أبي حاتم ٩/٢٨٣٠.أخرجه ابن جرير ١٧/٦٧٢، وابن أبي حاتم ٩/٢٨٣٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلّام ٢/٥٣٠.أخرجه ابن أبي حاتم ٩/٢٨٣٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير.تفسير مقاتل بن سليمان ٣/٢٨٢.تفسير يحيى بن سلّام ٢/٥٣٠.أخرجه البخاري ٧/١٣٦ (٥٧٦٢)، ٨/٤٧ (٦٢١٣)، ٩/١٦٢ (٧٥٦١)، ومسلم ٤/١٧٥٠ (٢٢٢٨).أخرجه البخاري ٤/١١١ (٣٢١٠)، ٤/١٢٥ (٣٢٨٨)، وابن جرير ١٩/٥٠٤.أخرجه ابن أبي حاتم ٩/٢٨٣١.
  26,224,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلشُّعَرَاۤءُ یَتَّبِعُهُمُ ٱلۡغَاوُۥنَ ۝٢٢٤ أَلَمۡ تَرَ أَنَّهُمۡ فِی كُلِّ وَادࣲ یَهِیمُونَ ۝٢٢٥ وَأَنَّهُمۡ یَقُولُونَ مَا لَا یَفۡعَلُونَ ۝٢٢٦﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٦٧١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: تهاجى رجلان على عهد رسول الله ﷺ، أحدُهما من الأنصار، والآخرُ مِن قوم آخرين، وكان مع كل واحد منهما غُواة من قومه، وهم السفهاء؛ فأنزل الله: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span> الآيات{1}. (١١/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد-، مثله{2}. (١١/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عبد الكريم الجزري- قال: تهاجى شاعران في الجاهلية، وكان مع كل واحد منهما فِئامٌ مِن الناس؛ فأنزل الله: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، فهم ذانِك الشاعران{3}. (١١/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿والشعرآء يتبعهم الغاوون﴾</span>، منهم عبد الله بن الزِّبَعْرى السَّهْمِي، وأبو سفيان بن عبد المطلب، وهبيرة بن أبي وهب المخزومي، ومشافع بن عبد مناف عمير الجمحي، وأبو عزة اسمه عمرو بن عبد الله، كلهم من قريش، وأمية بن أبي الصلت الثقفي، تكلَّموا بالكذب والباطل، وقالوا: نحن نقول مثلَ قول محمد ﷺ؛ قالوا الشعر، واجتمع إليهم غُواة مِن قومهم يستمعون مِن أشعارهم، ويَرْوُون عنهم، حتى يهجون. فذلك قوله ﷿: <span class="qpc-hafs">﴿ألم تر أنهم في كل واد يهيمون﴾</span> ... فاستأذن شعراء المسلمين أن يَقْتَصُّوا مِن المشركين منهم عبد الله بن رواحة، وحسان بن ثابت، وكعب بن مالك من بني سلمة بن خثم، كلهم من الأنصار، فأذِن لهم النبيُّ ﷺ، فهَجَوُا المشركين، ومدحوا النبيَّ ﷺ؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span> إلى آيتين{4}<span class=comment-ref>٤٨٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٣٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥١٢) على هذا القول بقوله: «الأوَّلان مِمَّن تاب وآمن ﵄، ويدخل في الآية كل شاعر مخلط يهجو أو يمدح شهوة، ويقذف المحصنات، ويقول الزور».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلشُّعَرَاۤءُ یَتَّبِعُهُمُ ٱلۡغَاوُۥنَ ۝٢٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٧٢٣<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال ذات يوم: «<b>يا أبا هريرة، إنّك لن تزال سالمًا ما لم تأتِ ثلاثًا: العرس، والرهان، وصيحة السوق</b>». قال: «<b>إنك إذا أتيت العرس غفلت وأغفلت، وإذا أتيت الرهان حلفت وماريت</b>». قال: وما صيحة السوق؟ قال: «<b>الشاعر يُسمِع القومَ الشعرَ، فإن خطوتَ إليه ثلاث خطوات إلى عشر كنت من الغاوين</b>». ثم تلا هذه الآية: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿يتبعهم الغاوون﴾</span>، قال: هم الكُفّار، يتَّبعون ضُلاَّل الجن والإنس{6}. (١١/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿والشعراء﴾</span> قال: المشركون منهم الذين كانوا يَهْجُون النبيَّ ﷺ <span class="qpc-hafs">﴿يتبعهم الغاوون﴾</span> غُواة الجن{7}. (١١/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: هم الرُّواة{8}. (١١/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق بريدة- في هذه الآية: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: هم الشياطين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: الشياطين{10}. (١١/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٢٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيْف- في قوله: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: كان الشاعران يتقاولان؛ ليكون لهذا تبع، ولهذا تبع{11}. (١١/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سلمة بن كهيل- <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: هم عُصاة الجِنِّ{12}. (١١/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: الشياطين{13}. (١١/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٢<span class="dash">-</span></span> قال عبد الرحمن بن <span class="name-2">زيد بن أسلم</span>: قال رجل لأبي: يا أبا أسامة، أرأيتَ قول الله -جلَّ ثناؤه-: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون. ألم تر أنهم في كل واد يهيمون. وأنهم يقولون ما لا يفعلون﴾</span>؟ فقال له <span class="name-2">أبي</span>: إنّما هذا لشعراء المشركين، وليس شعراء المؤمنين، ألا ترى أنه يقول: <span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات﴾</span> إلى آخره؟ فقال: فرَّجْتَ عنِّي، يا أبا أسامة، فرَّج الله عنك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، قال: الغاوون: المشركون{15}<span class=comment-ref>٤٨٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٣١</span> اختُلِف في الذين وُصِفوا بالغيِّ في قوله تعالى: <span class="qpc-hafs">﴿والشُّعَراءُ يَتَّبِعُهُمُ الغاوُونَ﴾</span> على أربعة أقوال: <b>الأول:</b> هم رواة الشعر. <b>الثاني:</b> هم الشياطين. <b>الثالث:</b> هم السفهاء. وقالوا: نزل ذلك في رجلين تهاجيا على عهد رسول الله ﷺ. <b>الرابع:</b> هم ضلال الجن والإنس.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٦٧٦) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول المعنى لجميع الأقوال، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال فيه ما قال الله -جلَّ ثناؤه-: إنّ شعراء المشركين يتَّبعهم غواة الناس، ومَرَدة الشياطين، وعُصاة الجِنِّ، وذلك أن الله عمَّ بقوله: <span class="qpc-hafs">﴿والشُّعَراءُ يَتَّبِعُهُمُ الغاوُونَ﴾</span> فلم يَخْصُصْ بذلك بعض الغواة دون بعض، فذلك على جميع أصناف الغواة التي دخلت في عموم الآية».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٦/٥١٢) قول عكرمة من طريق خصيف، فقال: «وهذا أرجح الأقوال». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿أَلَمۡ تَرَ أَنَّهُمۡ فِی كُلِّ وَادࣲ یَهِیمُونَ ۝٢٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٧٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿يتبعهم الغاوون﴾</span> قال: هم الكفار، يتَّبعون ضُلاَّل الجن والإنس، <span class="qpc-hafs">﴿في كل واد يهيمون﴾</span> في كل لغوٍ يخوضون، <span class="qpc-hafs">﴿وأنهم يقولون ما لا يفعلون﴾</span> أكثر قولهم يكذبون{16}. (١١/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿في كل واد يهيمون﴾</span>: في كل فنٍّ مِن الكلام يأخذون{17}. (١١/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ألم تر أنهم في كل واد يهيمون﴾</span>، قال: في كل فنٍّ يفْتَنُّون{18}. (١١/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿ألم تر أنهم في كل واد﴾</span> قال: فنٍّ <span class="qpc-hafs">﴿يهيمون﴾</span> قال: يقولون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٨<span class="dash">-</span></span> عن ليث بن كيسان العبدي، قال: سمعتُ <span class="name-2">الحسن البصري</span> يقرأ هذه الآية: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون، ألم تر أنهم في كل واد يهيمون﴾</span>. قال: قد -واللهِ- رأينا أوديتَهم التي يهيمون فيها؛ مرةً في شتيمة فلان، ومرَّةً في مديحة فلان{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ألم تر أنهم في كل واد يهيمون﴾</span>، قال: يمدحون قومًا بباطل، ويشتمون قومًا بباطل{21}. (١١/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألم تر أنهم في كل واد يهيمون﴾</span>، يعني: في كل طريق، يعني: في كل فنٍّ مِن الكلام يأخذون{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٤١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله تعالى: <span class="qpc-hafs">﴿ألم تر أنهم في كل واد يهيمون﴾</span>، يذهبون في كل وادٍ مِن أودية الكلام{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَّهُمۡ یَقُولُونَ مَا لَا یَفۡعَلُونَ ۝٢٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٧٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وأنهم يقولون ما لا يفعلون﴾</span>: أكثر قولهم يكذبون{24}<span class=comment-ref>٤٨٣٢</span>. (١١/٣٢١)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٣٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٠/٣٨٥) على قول ابن عباس بقوله: «وهذا الذي قاله ابن عباس هو الواقع في نَفْس الأمر؛ فإن الشعراء يتبجَّحون بأقوال وأفعال لم تصدر منهم، ولا عنهم، فيتكثَّرون بما ليس لهم».</div></p><p><div></p><p><p><span class="item-no">٥٦٧٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنهم يقولون ما لا يفعلون﴾</span> فعلنا وفعلنا، وهم كَذَبة{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَّهُمۡ یَقُولُونَ مَا لَا یَفۡعَلُونَ ۝٢٢٦﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٧٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span>، فنسخ من ذلك واستثنى، فقال: <span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات وذكروا الله كثيرا﴾</span>{26}. (١١/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٤٦<span class="dash">-</span></span> و<span class="name-2">طاووس بن كيسان</span> -من طريق يزيد- قالا: قال: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون. ألم تر أنهم في كل واد يهيمون. وأنهم يقولون ما لا يفعلون﴾</span>، فنسخ من ذلك واستثنى، قال: <span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات﴾</span> الآية{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٧٤٧<span class="dash">-</span></span> قال <span class="name-2">محمد ابن شهاب الزهري</span>: وفي الشعراء قوله تعالى: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span> إلى قوله: <span class="qpc-hafs">﴿يفعلون﴾</span>، نسختها هذه الآية؛ قوله تعالى: <span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات وذكروا الله كثيرا﴾</span> إلى آخر السورة{28}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦٧٤-٦٧٥، وابن أبي حاتم ٩/٢٨٣٣ (١٦٠٦٤)، وأورده البغوي في تفسيره ٦/١٣٥.</p><p>الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ١٧/٦٧٥، وإسحاق البستي في تفسيره ص٥٤٦ مرسلًا.أخرجه إسحاق البستي في تفسيره ص٥٤٥، وابن أبي حاتم ٩/٢٨٣٢ مرسلًا.تفسير مقاتل بن سليمان ٣/٢٨٣. ونحوه في تفسير البغوي ٦/١٣٥ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن وهب في التفسير من الجامع ١/٤٢ (٨٧).</p><p>إسناده ضعيف جدًّا؛ فيه أبان وهو ابن أبي عياش، قال عنه ابن حجر في التقريب (١٤٢): «متروك». والراوي عنه شبيب بن سعيد التميمي، قال ابن حجر في التقريب (٢٧٣٩): «لا بأس بحديثه من رواية ابنه عنه، لا من رواية ابن وهب». وهذا الحديث من رواية ابن وهب عنه.أخرجه ابن جرير ١٧/٦٧٥، وابن أبي حاتم ٩/٢٨٣١. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٩/٢٨٣١، وابن مردويه -كما في تخريج الكشاف ٢/٤٨٠-.أخرجه ابن جرير ١٧/٦٧٣، وابن أبي حاتم ٩/٢٨٣١-٢٨٣٢. وعزاه السيوطي إلى الفريابي.أخرجه الثعلبي ٧/١٨٤.أخرجه ابن جرير ١٧/٦٧٤، وأخرجه إسحاق البستي في تفسيره ص٥٤٥ من طريق ابن جريج، ومثله ابن أبي حاتم ٩/٢٨٣٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر. وعلَّقه يحيى بن سلّام ٢/٥٣٠ بلفظ: الغاوون: الشياطين الذين يلقون الشعر على الشعراء الذي لا يجوز في الدين.أخرجه ابن أبي حاتم ٩/٢٨٣٢. وعزاه السيوطي إلى الفريابي، وابن المنذر.أخرجه ابن أبي شيبة ٨/٥١٩، وابن جرير ١٧/٦٧٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه عبد الرزاق ٢/٧٨، وابن جرير ١٧/٦٧٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وعلَّقه يحيى بن سلّام ٢/٥٣٠ بلفظ: الغاوون: الشياطين الذين يلقون الشعر على الشعراء الذي لا يجوز في الدين.أخرجه ابن جرير ١٧/٦٧٧، وابن أبي حاتم ٩/٢٨٣٤.أخرجه ابن جرير ١٧/٦٧٥، وابن أبي حاتم ٩/٢٨٣٢ من طريق أصبغ.أخرجه ابن جرير ١٧/٦٧٦، وابن أبي حاتم ٩/٢٨٣٢. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٩/٢٨٣٢، وابن مردويه -كما في تخريج الكشاف ٢/٤٨٠-.أخرجه ابن جرير ١٧/٦٧٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٦٧٧، وابن أبي حاتم ٩/٢٨٣٣.أخرجه ابن أبي حاتم ٩/٢٨٣٣.أخرجه عبد الرزاق ٢/٧٨، وابن جرير ١٧/٦٧٧، وابن أبي حاتم ٩/٢٨٣٣ من طريق سعيد. وعلَّقه يحيى بن سلّام ٢/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٨٣.تفسير يحيى بن سلّام ٢/٥٣٠.أخرجه ابن جرير ١٧/٦٧٧، وابن أبي حاتم ٩/٢٨٣٣. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.تفسير مقاتل بن سليمان ٣/٢٨٣.أخرجه البخاري في الأدب (٨٧١). وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه ابن جرير ١٧/٦٧٩.الناسخ والمنسوخ للزهري ص٣٢.
