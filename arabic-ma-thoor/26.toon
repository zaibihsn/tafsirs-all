  26,146,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَتُتۡرَكُونَ فِی مَا هَـٰهُنَاۤ ءَامِنِینَ ۝١٤٦ فِی جَنَّـٰتࣲ وَعُیُونࣲ ۝١٤٧ وَزُرُوعࣲ وَنَخۡلࣲ طَلۡعُهَا هَضِیمࣱ ۝١٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: معشب{1}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: أينع وبلغ، فهو هضيم{2}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن أبي عمرو- في قوله: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: إذا رطب واسترخى{3}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿طلعها هضيم﴾</span>. قال: مُنضَمٌّ بعضُه إلى بعض. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول امرئ القيس:</p><p>دارٌ لبيضاء العوارضِ{5} طَفْلةٍ{6} مهضومة{7} الكَشْحَين{8} رَيّا المعصمِ؟{9}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿هضيم﴾</span>، قال: لطيف مادام في كُفُرّاه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٢<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرياحي</span>، في قوله: <span class="qpc-hafs">﴿هضيم﴾</span>: يتهشهش في الفم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: يَتَهَشَّم تَهَشُّمًا{12}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مسلم بن خالد، عن ابن أبي نجيح- <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: الطلعة إذا مَسِسْتَها تناثرت{13}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٥<span class="dash">-</span></span> عن ابن جريج، قال: سمعتُ عبد الكريم يقول: سمعتُ <span class="name-2">مجاهدًا</span> يقول في قوله: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: حين تَطْلُعُ؛ يَقْبِض عليه فيَهْضِمُه. قال ابن جريج: قال <span class="name-2">مجاهد</span>: إذا مُسَّ تهشَّم وتفتَّت. قال: هو مِن الرُّطب هضيم؛ تقبض عليه فتهضمه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحم</span>، قال: الهضيم إذا بلغ البُسر في عذوقه، فعظُم، فذلك الهضم{15}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: {16} الطلع حين يتفرق ويخضر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- قال: الهضيم: الرَّطب اللين{18}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: هو الرَّخْوُ{19}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: ليس فيه نوى{20}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: لَيِّن{21}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٢<span class="dash">-</span></span> عن أبي العلاء -من طريق أبي إسحاق- قال: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: الهضيم: المذنب الرطب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٣<span class="dash">-</span></span> عن <span class="name-2">أبي ميسرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٤<span class="dash">-</span></span> ويزيد بن راشد= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٥<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٦<span class="dash">-</span></span> عن عمر بن إسماعيل الهمداني، قال: حدثني أبي، قال: سألتُ <span class="name-2">عاصم بن بهدلة</span> عن قول الله -جلَّ وعزَّ-: <span class="qpc-hafs">﴿نخل طلعها هضيم﴾</span>. قال: اللّين، ألا ترى قول الشاعر:</p><p>هضيم الحشا لَيِّنُهُ ...؟{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٧<span class="dash">-</span></span> قال <span class="name-2">محمد ابن شهاب الزهري</span>، <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: الهضيم: طلعها{25} اللطيف حين يطلع{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٨<span class="dash">-</span></span> عن <span class="name-3">يزيد بن أبي زياد</span>، <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: هو الرطب. وفي لفظ قال: المذَنَّبُ الذي قد رطب بعضه{27}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مسلم الزنجي- قال: الهضيم: لطيف{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال صالح ﵇: <span class="qpc-hafs">﴿أتتركون في ما هاهنا﴾</span> من الخير <span class="qpc-hafs">﴿آمنين﴾</span> من الموت. ثم أخبر عن الخير، فقال سبحانه: <span class="qpc-hafs">﴿في جنات وعيون * وزروع ونخل طلعها هضيم﴾</span> يعني: طلعها متراكب بعضها على بعض مِن الكثرة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١١<span class="dash">-</span></span> عن <span class="name-3">أبي صخر [حميد بن زياد الخراط]</span> -من طريق مفضل- <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: ما رأيت طلع النخل حين ينشقُّ عنه الكُمّ، فترى الطَّلع قد لصق بعضُه ببعض؛ فهو الهضيم!{3}<span class=comment-ref>٤٨١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٦</span> اختُلِف في معنى قوله <span class="qpc-hafs">﴿هضيم﴾</span> على أقوال: <b>الأول</b>: معناه: اليانع النضيج. <b>الثاني</b>: بل هو المتهشم المتفتت. <b>الثالث</b>: هو الرطب اللين. <b>الرابع</b>: هو الراكب بعضه بعضًا.</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (١٧/٦٢٠) بين الأقوال <span class="mustanad">مستندًا للغة</span>، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: الهضيم: هو المنكسر من لينه ورطوبته، وذلك من قولهم: هضم فلان حقه: إذا انتقصه وتحيّفه، فكذلك الهضم في الطلع، إنما هو التنقُّص منه مِن رطوبته ولينه؛ إما بمسِّ الأيدي، وإما بركوب بعضه بعضًا، وأصله»مفعول«صُرِف إلى»فعيل«».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٤٩٩-٥٠٠) القول الأخير الذي قاله الضحاك بقوله: «وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٥٦٣١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أتتركون في ما ههنا آمنين﴾</span> على الاستفهام، أي: لا تُتْرَكون فيه{31}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠١ بلفظ: معشبة. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم -كما في الإتقان ٢/٣٤-.أخرجه ابن أبي حاتم ٩/٢٨٠١.علَّقه ابن أبي حاتم ٩/٢٨٠١.العوارض: الثنايا سُميت عَوارِضَ؛ لأَنها فِي عُرْضِ الفَم. اللسان (عرض).طَفْلة: لينة ناعمة. اللسان (طفل).مهضومة: خميصة البطن. التاج (هضم).الكَشْح: ما بين الخاصِرة إلى الضِّلع الخلفي. اللسان (كشح).أخرجه الطستي -كما في الإتقان ٢/٨٨-.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٤ مختصرًا. والكُفُرّى: -بالضم وتشديد الراء وفتح الفاء وضمها مقصور-: هو وعاء الطلع وقشره الأعلى. النهاية (كفر).تفسير الثعلبي ٧/١٧٦.أخرجه يحيى بن سلّام ٢/٥١٦ من طريق أبي يحيى وابن مجاهد، والفريابي -كما في التغليق ٤/٢٧٢، وفتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم ٩/٢٨٠١ واللفظ له. وعلَّقه يحيى بن سلّام ٢/٥١٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم ٩/٢٨٠٢. وعلَّقه البخاري ٤/١٧٨٦ بلفظ: يتفتت إذا مُسَّ. وينظر: فتح الباري لابن حجر ٨/٤٩٧، وتغليق التعليق ٤/٢٧٢.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٧/٦٢٠ من طريق عبيد ولفظه: إذا كثر حمل النخلة، فركب بعضها بعضًا، حتى نقص بعضها بعضًا، فهو حينئذ هضيم، وكذا أخرجه إسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٨٠٢ من طريقه بنحوه. وعزاه السيوطي إلى عبد بن حميد.أثبت في المصدر هنا: «بطلع» بالباء الموحدة التحتانية، ولعلها: يَطْلُع.أخرجه ابن أبي حاتم ٩/٢٨٠١.أخرجه ابن جرير ١٧/٦٢٠، وابن أبي حاتم ٩/٢٨٠١. وعزاه السيوطي إلى سعيد بن منصور.علَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٩/٢٨٠١. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٠١.علَّقه ابن أبي حاتم ٩/٢٨٠١.أخرجه ابن أبي الدنيا في كتاب الأشراف -موسوعة الإمام ابن أبي الدنيا ٨/٣١٣ (٤٥١)-.أثبت في المصدر هنا: «الرحمن»، ولعلها: الرخو.أخرجه ابن وهب في الجامع- تفسير القرآن ٢/١٠١ (١٩٨).عزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه أبو جعفر الرملي في جزئه ص٥٧ (تفسير مسلم الزنجي). وعلَّقه يحيى بن سلّام ٢/٥١٧ وزاد: وهو الطلع ما لم ينشق.تفسير مقاتل بن سليمان ٣/٢٧٥. وآخره في تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٤ عن مقاتل منسوبًا إليه دون تعيينه، بلفظ: قد ركب بعضه بعضًا حتى هضم بعضه بعضًا.أخرجه ابن أبي حاتم ٩/٢٨٠١.تفسير يحيى بن سلّام ٢/٥١٦.
