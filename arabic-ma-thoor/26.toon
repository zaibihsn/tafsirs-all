  26,164,""
  26,165,""
  26,166,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَذَرُونَ مَا خَلَقَ لَكُمۡ رَبُّكُم مِّنۡ أَزۡوَ ٰ⁠جِكُمۚ بَلۡ أَنتُمۡ قَوۡمٌ عَادُونَ ۝١٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span>، قال: تركتم أقبال النساء إلى أدبار الرجال وأدبار النساء!{1}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن مهاجر- <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span>، قال: ما أصْلَحَ لكم، يعني: القُبُل{2}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span>، يقول: ترك أقبال النساء إلى أدبار الرجال{3}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق محمد بن يزيد بن المهاجر-: أنّه كان لا يرى بأسًا بإتيان النساء في أدبارهن، ويحتج في ذلك بقوله ﷿: <span class="qpc-hafs">﴿أتأتون الذكران من العالمين * وتذرون ما خلق لكم ربكم من أزواجكم بل أنتم قومٌ عادون﴾</span>، أي: من أزواجكم مثل ذلك، إن كنتم تشتهون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ما خلق لكم ربكم من أزواجكم﴾</span> ما جعل لكم ربكم مِن فروج نسائكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span>، قال: مُتَعَدُّون{6}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span> يعني بالأزواج: فروج نسائكم، <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span> يعني: مُعْتَدين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهذا على الاستفهام، أي: قد فعلتم، <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span> مُجاوِزون لأمر الله{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ٢/٥٢٠ من طريق ابن مجاهد دون ذكر أدبار النساء، وابن جرير ١٧/٦٣٠، وإسحاق البستي في تفسيره ص٥٤٠ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨٠٨. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه الدارمي في سننه ١/٧٢٧ (١١٦٣) بلفظ: هو -واللهِ- القُبُل، وابن أبي حاتم ٩/٢٨٠٨، ويحيى بن سلّام ٢/٥٢٠ من طريق عاصم بن حكيم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الطحاوي في شرح معاني الآثار ٣/٤٥. وتقدمت الأحاديث والآثار الدالة على فساد هذا القول عند تفسير قوله تعالى: <span class="qpc-hafs">﴿نِساؤُكُمْ حَرْثٌ لَكُمْ فَأْتُوا حَرْثَكُمْ أنّى شِئْتُمْ﴾</span> [البقرة:٢٢٣].علقه يحيى بن سلّام ٢/٥٢٠.أخرجه ابن جرير ١٧/٦٣٠. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٧.تفسير يحيى بن سلّام ٢/٥٢٠.
  26,167,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَىِٕن لَّمۡ تَنتَهِ یَـٰلُوطُ لَتَكُونَنَّ مِنَ ٱلۡمُخۡرَجِینَ ۝١٦٧ قَالَ إِنِّی لِعَمَلِكُم مِّنَ ٱلۡقَالِینَ ۝١٦٨ رَبِّ نَجِّنِی وَأَهۡلِی مِمَّا یَعۡمَلُونَ ۝١٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿مما يعملون﴾</span>، يقول: ينكحون الرجال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا لئن لم تنته﴾</span> يعني: لئن لم تسكت عنّا <span class="qpc-hafs">﴿يا لوط لتكونن من المخرجين﴾</span> من القرية، <span class="qpc-hafs">﴿قال﴾</span> لوط: <span class="qpc-hafs">﴿إني لعملكم﴾</span> يعني: إتيان الرجال <span class="qpc-hafs">﴿من القالين﴾</span> يعني: الماقتين، <span class="qpc-hafs">﴿رب نجني وأهلي مما يعملون﴾</span> مِن الخبائث{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span> مُجاوِزون لأمر الله، <span class="qpc-hafs">﴿قالوا لئن لم تنته يا لوط لتكونن من المخرجين﴾</span> مِن قريتنا، أي: نقتلك، فنخرجك منها قتيلًا، <span class="qpc-hafs">﴿قال إني لعملكم من القالين﴾</span> مِن المُبْغِضين. ثم قال: <span class="qpc-hafs">﴿رب نجني وأهلي مما يعملون﴾</span> وأهله: أُمَّته المؤمنون، <span class="qpc-hafs">﴿فنجيناه وأهله أجمعين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٨.تفسير مقاتل بن سليمان ٣/٢٧٧.تفسير يحيى بن سلّام ٢/٥٢٠.
  26,168,""
  26,167,""
  26,168,""
  26,169,""
  26,170,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥۤ أَجۡمَعِینَ ۝١٧٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٦<span class="dash">-</span></span> عن مجاهد، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وواعَدْناهُ أن نُّوَفِّيَهُ أجْمَعِينَ إلّا عَجُوزًا فِي الغابِرِينَ){1}. (١١/٢٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥۤ أَجۡمَعِینَ ۝١٧٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فنجيناه وأهله أجمعين﴾</span> ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.</p><p>والظاهر أن المراد من هذه القراءة التفسير، وإن ثبتت قراءة فهي شاذة.تفسير مقاتل بن سليمان ٣/٢٧٧.
  26,171,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا عَجُوزࣰا فِی ٱلۡغَـٰبِرِینَ ۝١٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله <span class="qpc-hafs">﴿في الغابرين﴾</span>. قال: في الباقين. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عَبِيد بن الأبرص وهو يقول:</p><p>ذهبوا وخَلَّفَني المُخَلِّف فيهم فكأنني في الغابرين غريبُ؟{1}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span> قال: هي امرأة لوط، غبرت في عذاب الله{2}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿في الغابرين﴾</span>، قال: الباقين في عذاب الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span>، يعني: الباقين في العذاب، يعني: امرأته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٢<span class="dash">-</span></span> عن أصبغ، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> في قول الله: <span class="qpc-hafs">﴿إلا عجوزا﴾</span>: امرأة لوط المُغْبَرة الشقية <span class="qpc-hafs">﴿في الغابرين﴾</span> الباقين الذين غبروا وأبقوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span>، غَبَرَتْ: بقيت في عذاب الله، لم ينجها{6}<span class=comment-ref>٤٨٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٠٢) أن قوله: <span class="qpc-hafs">﴿فِي الغابِرِينَ﴾</span> معناه: في الباقين. ثم قال: «فإما أن يريد: في الباقين من لِداتها وأهل سنتها. وهذا تأويل أبي عبيدة. وإما أن يريد: في الباقين في العذاب النازل بهم. وهذا تأويل قتادة. والمشهور أنها بمعنى: بقي. وغابر الزمان: مستقبله، ولكن الأعشى قد استعمل»غابر الزمان«بمعنى ماضيه في شعر المنافرة المشهور، وقال الزهراوي: يقال للذاهب: غابر، وللباقي: غابر».</div></p></div>",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٨٣-٨٤-.أخرجه ابن أبي حاتم ٩/٢٨٠٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٠٩.تفسير مقاتل بن سليمان ٣/٢٧٧.أخرجه ابن أبي حاتم ٩/٢٨٠٩.تفسير يحيى بن سلّام ٢/٥٢٠.
  26,172,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ دَمَّرۡنَا ٱلۡـَٔاخَرِینَ ۝١٧٢ وَأَمۡطَرۡنَا عَلَیۡهِم مَّطَرࣰاۖ فَسَاۤءَ مَطَرُ ٱلۡمُنذَرِینَ ۝١٧٣ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٧٤ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: ... فلمّا كان في جوف الليل إذ أدخل جبريل جناحَه تحت القرية، فرفعها، حتى إذا كانت في جو السماء -حتى إنهم ليسمعون أصوات الطير- قَلَبَها، ثم تَتَبَّع الشُّذّاذ ومَن خرج منهم بالحجارة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح– <span class="qpc-hafs">﴿وامطرنا عليهم مطرا﴾</span>، قال: على أهل بواديهم، وعلى رُعاتهم، وعلى مُسافريهم، فلم ينفلِت منهم أحدٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله ﷿: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span>: أمطر الله على قرية قوم لوط حجارة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿ثم دمرنا الآخرين﴾</span> قوم لوط وامرأته معهم، وكانت مُنافِقة، تظهر للوط الإيمان، وهي على الشرك.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٨<span class="dash">-</span></span> قوله ﷿: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span> قال <span class="name-2">قتادة</span>: أمطر الله على قرية قوم لوط حجارة، <span class="qpc-hafs">﴿فساء مطر المنذرين﴾</span> أي: فبئس مطر المنذرين، أنذرهم لوط فلم يقبلوا. أصاب قريتهم الخسف، وأصابت الحجارة مَن كان خارجًا من القرية، وأهل السَّفر منهم، وأصاب العجوزَ حجرٌ فقتلها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٩<span class="dash">-</span></span> عن الحكم بن أبان، في قوله: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span>، قال: سمعت <span class="name-2">وهبًا</span> يقول: الكبريت، والنار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم دمرنا﴾</span> يعني: أهلكنا <span class="qpc-hafs">﴿الآخرين﴾</span> بالخسف والحصب، فذلك قوله تعالى: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span> يعني: الحجارة، <span class="qpc-hafs">﴿فساء﴾</span> يعني: فبئس <span class="qpc-hafs">﴿مطر المنذرين﴾</span> يعني: الذين أُنذروا بالعذاب، خسف الله بقرى قوم لوط، وأرسل الحجارة على مَن كان خارجًا من القرية، <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يعني: إن في هلاكهم بالخسف والحصب لَعِبرة لهذه الأمة، ثم قال تعالى: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> لو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين. وذلك قوله تعالى: <span class="qpc-hafs">﴿ولقد أنذرهم بطشتنا﴾</span> [القمر:٣٦]، يعني: عذابنا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٩.أخرجه ابن أبي حاتم ٩/٢٨٠٩.علَّقه يحيى بن سلّام ٢/٥٢١.تفسير يحيى بن سلّام ٢/٥٢٠.أخرجه ابن أبي حاتم ٩/٢٨١٠.تفسير مقاتل بن سليمان ٣/٢٧٧.
