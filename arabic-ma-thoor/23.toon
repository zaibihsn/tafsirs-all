  23,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَقَدۡ وُعِدۡنَا نَحۡنُ وَءَابَاۤؤُنَا هَـٰذَا مِن قَبۡلُ إِنۡ هَـٰذَاۤ إِلَّاۤ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لقد وعدنا نحن وآبآؤنا هذا من قبل﴾</span> يعني: البعث، <span class="qpc-hafs">﴿إن هذا﴾</span> الذي يقول محمدٌ ﷺ <span class="qpc-hafs">﴿إلا أساطير الأولين﴾</span> يعني: أحاديثَ الأولين، وكذبهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لقد وعدنا نحن وآباؤنا هذا من قبل﴾</span> أي: وُعِدنا أن نُبْعَث نحن وآباؤنا فلم نُبْعَث. كقوله: <span class="qpc-hafs">﴿فأتوا بآبائنا إن كنتم صادقين﴾</span> [الدخان:٣٦]. قوله: <span class="qpc-hafs">﴿إن هذا إلا أساطير الأولين﴾</span> كذب الأولين وباطلهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٣.
  23,84,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل لِّمَنِ ٱلۡأَرۡضُ وَمَن فِیهَاۤ إِن كُنتُمۡ تَعۡلَمُونَ ۝٨٤ سَیَقُولُونَ لِلَّهِۚ قُلۡ أَفَلَا تَذَكَّرُونَ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لكفار مكة: <span class="qpc-hafs">﴿لمن الأرض ومن فيها﴾</span> مِن الخلق، حين كفروا بتوحيد الله ﷿: <span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span> خلقهما، <span class="qpc-hafs">﴿سيقولون لله قل أفلا تذكرون﴾</span> في توحيد الله ﷿، فتُوَحِّدونه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: فأمر الله نبيَّه أن يقول لهم: <span class="qpc-hafs">﴿قل لمن الأرض ومن فيها إن كنتم تعلمون(٨٤)سيقولون لله﴾</span> أي: فإذا قالوا ذلك فـ<span class="qpc-hafs">﴿قل أفلا تذكرون﴾</span> فتُؤْمِنوا وأنتم تُقِرُّون أنّ الأرض ومَن فيها لله{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٣.
  23,85,""
  23,84,""
  23,85,""
  23,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ مَن رَّبُّ ٱلسَّمَـٰوَ ٰ⁠تِ ٱلسَّبۡعِ وَرَبُّ ٱلۡعَرۡشِ ٱلۡعَظِیمِ ۝٨٦ سَیَقُولُونَ لِلَّهِۚ قُلۡ أَفَلَا تَتَّقُونَ ۝٨٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥١٩٨٥<span class="dash">-</span></span> عن هارون، قال: في مُصحف <span class="name-1">أُبَيّ بن كعب</span>: <span class="qpc-hafs">﴿سَيَقُولُونَ لِلَّهِ﴾</span> كلهن بغير ألف{1}. (١٠/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨٦<span class="dash">-</span></span> عن عاصم الجَحْدري، قال: في الإمام؛ مصحف <span class="name-1">عثمان بن عفان</span> الذي كُتِب للناس: <span class="qpc-hafs">﴿لله﴾</span> <span class="qpc-hafs">﴿لله﴾</span> كلهن بغير ألف{2}. (١٠/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨٧<span class="dash">-</span></span> عن أسيد بن يزيد، قال: في مصحف <span class="name-1">عثمان بن عفان</span>: <span class="qpc-hafs">﴿سَيَقُولُونَ لِلَّهِ﴾</span> ثلاثتهن بغير ألف{3}. (١٠/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨٨<span class="dash">-</span></span> عن عمرو، عن <span class="name-2">الحسن</span>، قال: <span class="qpc-hafs">﴿لمن الأرض ومن فيها﴾</span>، <span class="qpc-hafs">﴿سَيَقُولُونَ لِلَّهِ﴾</span>، ثلاثتهن: <span class="qpc-hafs">﴿لله﴾</span>، <span class="qpc-hafs">﴿لله﴾</span>، <span class="qpc-hafs">﴿لله﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨٩<span class="dash">-</span></span> عن عاصم الجحدري، عن <span class="name-2">نصر بن عاصم</span>: أنّه أول مَن أحدث فيها الألفين= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩٠<span class="dash">-</span></span> عن هارون، قال: وفي قراءة <span class="name-1">ابن مسعود</span> مثل قول نصر بن عاصم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩١<span class="dash">-</span></span> عن يحيى بن عتيق، قال: رأيتُ في مصحف <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لله﴾</span> <span class="qpc-hafs">﴿لله﴾</span> في ثلاثة مواضع{5}. (١٠/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩٢<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنّه قرأ: <span class="qpc-hafs">﴿لِلَّهِ﴾</span> بغير ألف كلهن{6}<span class=comment-ref>٤٥٧١</span>. (١٠/٦١٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧١</span> اختلف القراءُ في قراءة قوله تعالى: <span class="qpc-hafs">﴿سيقولون لله﴾</span> في الآيتين [٨٧، ٨٩]، فبعضهم أثبت الألف في اسم الجلالة، هكذا (اللهُ)، وبعضهم لم يثبتها. وقال <u>ابنُ عطية</u> (٦/٣١٦) <span class="comment-type-1">مُوَجِّهًا</span> القراءتين: «قرأ الجميع في الأول <span class="qpc-hafs">﴿لله﴾</span> بلا خلاف، واختُلِفَ في الثاني، والثالث، فقرأ أبو عمرو وحده (الله) جوابًا على اللفظ. وقرأ باقي السبعة: <span class="qpc-hafs">﴿لله﴾</span> جوابًا على المعنى، كأنه قال في السؤال: لمن ملك السموات السبع؟. إذ قولك: لمن هذه الدار؟، وقولك: مَن مالك هذه الدار؟ واحد في المعنى».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ جرير</u> (١٧/٩٨)، ثم بيَّنَ أنَ كلتا القراءتين صواب، ثم <span class="comment-type-3">اختار</span> (١٧/٩٩) القراءة بغير الألف، فقال: «الصواب مِن القراءة في ذلك أنهما قراءتان قد قرأ بهما علماء مِن القرأة، متقاربتا المعنى؛ فبأيتهما قرأ القارئ فمصيب، غير أنِّي مع ذلك أختار قراءة جميع ذلك بغير ألف؛ لإجماع خطوط مصاحف الأمصار على ذلك، سوى خط مصحف أهل البصرة».</div></p><p><h3><span class="qpc-hafs">﴿قُلۡ مَن رَّبُّ ٱلسَّمَـٰوَ ٰ⁠تِ ٱلسَّبۡعِ وَرَبُّ ٱلۡعَرۡشِ ٱلۡعَظِیمِ ۝٨٦ سَیَقُولُونَ لِلَّهِۚ قُلۡ أَفَلَا تَتَّقُونَ ۝٨٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥١٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لهم: <span class="qpc-hafs">﴿من رب السماوات السبع ورب العرش العظيم* سيقولون لله قل أفلا تتقون﴾</span> يعني: أفلا تعبدون اللهَ ﷿{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قل من رب السموات السبع ورب العرش العظيم(٨٦)سيقولون لله﴾</span>، فإذا قالوا ذلك فـ<span class="qpc-hafs">﴿قل أفلا تتقون﴾</span> وأنتم تُقِرُّون أنّ الله خالق هذه الأشياء وربها. وقد كان مُشْرِكو العربِ يُقِرُّون بهذا{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائل القرآن ص١٧٧، وإسحاق البستي في تفسيره ص٤٠٤-٤٠٥. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة العشرة ما عدا أبا عمرو، ويعقوب في الأخيرين؛ فإنهما قرآ فيهما: ‹سَيَقُولُونَ اللهُ› بإثبات همزة الوصل. انظر: النشر ٢/٣٢٩، والإتحاف ص٤٠٥.أخرجه أبو عبيد في فضائل القرآن ص١٧٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي داود في المصاحف ص٣٨.أخرجه إسحاق البستي في تفسيره ص٤٠٤-٤٠٥.أخرجه إسحاق البستي في تفسيره ص٤٠٤ من طريق عمرو. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٣.
  23,87,""
  23,87,""
  23,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ مَنۢ بِیَدِهِۦ مَلَكُوتُ كُلِّ شَیۡءࣲ وَهُوَ یُجِیرُ وَلَا یُجَارُ عَلَیۡهِ إِن كُنتُمۡ تَعۡلَمُونَ ۝٨٨ سَیَقُولُونَ لِلَّهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيج- في قوله: <span class="qpc-hafs">﴿قل بيده ملكوت كل شيء﴾</span>، قال: خزائن كلِّ شيء{1}<span class=comment-ref>٤٥٧٢</span>. (١٠/٦١٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٢</span> <span class="comment-type-3">اختار</span> <u>ابنُ جرير</u> (١٧/١٠٠) هذا القول <span class="mustanad">مستندًا إلى أقوال السلف</span>.</div></p><p><div></p><p><p><span class="item-no">٥١٩٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل من بيده ملكوت﴾</span> يعني: خَلْق <span class="qpc-hafs">﴿كل شيء وهو يجير ولا يجار عليه﴾</span> يقول: يُؤَمِّن ولا يُؤمَّن عليه أحد؛ <span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قل من بيده ملكوت كل شيء﴾</span> أي: ملك كل شيء، <span class="qpc-hafs">﴿وهو يجير﴾</span> مَن يشاء فيمنعه فلا يُوصَل إليه، <span class="qpc-hafs">﴿ولا يجار عليه﴾</span> أي: مُن أراد أن يُعَذِّبه لم يستطع أحدٌ منعَه؛ <span class="qpc-hafs">﴿إن كنتم تعلمون(٨٤) سيقولون لله﴾</span>، فإذا قالوا ذلك فـ<span class="qpc-hafs">﴿قل فأنى تسحرون﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ فَأَنَّىٰ تُسۡحَرُونَ ۝٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿فأنى تسحرون﴾</span>، يقول: تُكَذِّبون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سيقولون لله قل فأنى تسحرون﴾</span>، قُل: فمِن أين سُحِرتم فأنكرتم أنّ الله تعالى واحِدٌ لا شريك له، وأنتم مُقِرُّون بأنّه خَلَق الأشياء كلها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قل فأنى تسحرون﴾</span> عقولكم. فشَبَّههم بقوم مسحورين، ذاهبة عقولهم{6}<span class=comment-ref>٤٥٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٣</span> <span class="comment-type-1">ذكر</span> <u>ابنُ عطية</u> (٤/٣١٦) هذا القول، ثم <span class="comment-type-1">ذكر</span> أنّ قومًا قالوا: <span class="qpc-hafs">﴿تسحرون﴾</span> معناه: تمنعون، ثم <span class="comment-type-4">علَّق</span> بقوله: «<span class="mustanad">وحكى بعضُهم ذلك لغةً</span>».</div></p><p><h3><span class="qpc-hafs">﴿قُلۡ فَأَنَّىٰ تُسۡحَرُونَ ۝٨٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عبد الله بن دينار- قال: كان رسول الله ﷺ كثيرًا ما يُحَدِّث عن امرأة كانت في الجاهلية على رأس جبل، معها ابنٌ لها يرعى غنمًا، فقال لها ابنها: يا أماه، مَن خلقكِ؟ قالت: الله. قال: فمَن خلق أبي؟ قالت: الله. قال: فمَن خلقني؟ قالت: الله. قال: فمَن خلق السماء؟ قالت: الله. قال: فمَن خلق الأرض؟ قالت: الله. قال: فمَن خلق الجبل؟ قالت: الله. قال: فمَن خلق هذه الغنم؟ قالت: الله. قال: فإنِّي أسمع لله شأنًا. ثُمَّ ألقى نفسه مِن الجبل، فتَقَطَّع. قال ابن عمر: كان رسول الله ﷺ كثيرًا ما يُحَدِّثنا هذا الحديث. قال عبد الله بن دينار: كان ابنُ عمر كثيرًا ما يُحَدِّثنا بهذا الحديث{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٤١٣ من طريق ابن مجاهد، وابن جرير ١٧/١٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٣.أخرجه ابن جرير ١٧/١٠١.تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٤.أخرجه ابن أبي الدنيا في كتاب التفكر والاعتبار -كما في تفسير ابن كثير ٥/٤٩٠-، والأصبهاني في الترغيب والترهيب ١/٣٩٢ (٦٧٦)، والعقيلي في الضعفاء الكبير ٢/٢٣٩.</p><p>قال العقيلي: «وليس لهذا الحديث أصل». وقال ابن عدي في الكامل ٥/٢٩٣: «غير محفوظ، لا يحدّث به عن ابن دينار غير عبد الله بن جعفر، وعبد الله بن جعفر المديني ضعيف عند الأئمة». وقال ابن كثير: «في إسناده عبد الله بن جعفر المديني، والد الإمام علي بن المديني، وقد تكلّموا فيه». وقال في موضع آخر ٨/٣٨٨: «في إسناده ضعف، وعبد الله بن جعفر هذا هو المديني، ضعّفه ولدُه الإمام علي بن المديني وغيره». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٧٦٢-١٧٦٣ (٤٠٠١): «رواه عبد الله بن جعفر بن نجيح عن عبد الله بن دينار عن ابن عمر، وعبد الله ليس بثقة». وقال الألباني في الضعيفة ١٤/٥ (٦٥٠١): «منكر جدًّا».
  23,89,""
  23,89,""
  23,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ أَتَیۡنَـٰهُم بِٱلۡحَقِّ وَإِنَّهُمۡ لَكَـٰذِبُونَ ۝٩٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تُقْرَأ على وجه آخر: (بَلْ أتَيْتَهُمْ){1}<span class=comment-ref>٤٥٧٤</span> يا محمد بالحق؛ بالقرآن{2}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٣١٧): «قرأ ابن أبي إسحاق: (أتَيتَهم) على الخطاب لمحمد ﷺ».</div></p><p><h3><span class="qpc-hafs">﴿بَلۡ أَتَیۡنَـٰهُم بِٱلۡحَقِّ وَإِنَّهُمۡ لَكَـٰذِبُونَ ۝٩٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأَكْذَبَهم اللهُ ﷿ حين أشركوا به، فقال سبحانه: <span class="qpc-hafs">﴿بل أتيناهم بالحق﴾</span> يقول: بل جئناهم بالتوحيد، <span class="qpc-hafs">﴿وإنهم لكاذبون﴾</span> في قولهم: إنّ الملائكة بنات الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل أتيناهم بالحق﴾</span>: القرآن، أنزله الله على النبي{2}. (ز)</p></p><p></div></p></div>",footnotes:1:قال المحقق: وفي ابن أبي زمنين ورقة ٢٢٨: أتيتَهم. تفسير يحيى بن سلّام ١/٤١٤.</p><p>وهي قراءة شاذة، تروى أيضًا عن قتادة، وأبي حيوة، وغيرهما. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٨.تفسير يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٤.
  23,91,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا ٱتَّخَذَ ٱللَّهُ مِن وَلَدࣲ وَمَا كَانَ مَعَهُۥ مِنۡ إِلَـٰهٍۚ إِذࣰا لَّذَهَبَ كُلُّ إِلَـٰهِۭ بِمَا خَلَقَ وَلَعَلَا بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲۚ سُبۡحَـٰنَ ٱللَّهِ عَمَّا یَصِفُونَ ۝٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿ما اتخذ الله من ولد﴾</span> يعني: الملائكة، <span class="qpc-hafs">﴿وما كان معه من إله﴾</span> يعني: مِن شريك، فلو كان معه إله <span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق ولعلا بعضهم على بعض﴾</span> كفِعْل ملوك الدنيا، يلتمس بعضُهم قهرَ بعض، ثم نزَّه الربُّ نفسَه جل جلاله عن مقالتهم، فقال تعالى: <span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span> يعني: عمّا يقولون بأنّ الملائكة بنات الرحمن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ما اتخذ الله من ولد﴾</span> وذلك لقول المشركين: إن الملائكة بنات الله، <span class="qpc-hafs">﴿وما كان معه من إله﴾</span> وذلك لِما عبدوا مِن الأوثان، اتخذوا مع الله آلهة. قال: <span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق﴾</span> يقول: لو كان معه آلهة <span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق ولعلا بعضهم على بعض﴾</span> لَطَلَب بعضُهم مُلْكَ بعضٍ حتى يعلو عليه، كما يفعل ملوك الدنيا، <span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span> يُنَزِّه نفسه عما يكذبون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
  23,92,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَـٰلِمِ ٱلۡغَیۡبِ وَٱلشَّهَـٰدَةِ فَتَعَـٰلَىٰ عَمَّا یُشۡرِكُونَ ۝٩٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿عالم الغيب﴾</span>، الغيب هاهنا: ما لم يجِئْ مِن غيب الآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عالم الغيب والشهادة﴾</span> يعني: غيب ما كان، وما يكون، والشهادة، <span class="qpc-hafs">﴿فتعالى﴾</span> يعني: فارتفع <span class="qpc-hafs">﴿عما يشركون﴾</span> لقولهم: الملائكة بنات الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والشهادة﴾</span> ما أعلمَ العبادَ، <span class="qpc-hafs">﴿فتعالى﴾</span> ارتفع اللهُ <span class="qpc-hafs">﴿عما يشركون﴾</span> يرفع نفسه عما قالوا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
  23,93,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل رَّبِّ إِمَّا تُرِیَنِّی مَا یُوعَدُونَ ۝٩٣ رَبِّ فَلَا تَجۡعَلۡنِی فِی ٱلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٩٤ وَإِنَّا عَلَىٰۤ أَن نُّرِیَكَ مَا نَعِدُهُمۡ لَقَـٰدِرُونَ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل رب إما تريني ما يوعدون﴾</span> مِن العذاب، يعني: القتل ببدر، وذلك أنّ النبي ﷺ أراد أن يدعو على كفار مكة، ثم قال: <span class="qpc-hafs">﴿رب فلا تجعلني في القوم الظالمين*وإنا على أن نريك ما نعدهم﴾</span> مِن العذاب <span class="qpc-hafs">﴿لقادرون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿قل﴾</span> يا محمد: <span class="qpc-hafs">﴿رب إما تريني ما يوعدون﴾</span> من العذاب، <span class="qpc-hafs">﴿رب فلا تجعلني في القوم الظالمين﴾</span> لا تُهْلِكْني معهم إن أريتني ما يوعدون. قوله: <span class="qpc-hafs">﴿وإنا على أن نريك ما نعدهم﴾</span> مِن العذاب <span class="qpc-hafs">﴿لقادرون﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
