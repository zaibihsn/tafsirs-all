  74,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَرۡنِی وَمَنۡ خَلَقۡتُ وَحِیدࣰا ۝١١﴾</span> الآيات - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: أنّ الوليد بن المُغيرة جاء إلى النبيِّ ﷺ، فقَرأ عليه القرآن، فكأنه رَقَّ له، فبَلغ ذلك أبا جهل، فأتاه، فقال: يا عمّ، إنّ قومك يريدون أن يجمعوا لك مالًا ليُعطوكه، فإنك أتيتَ محمدًا لتَعرَّض لِما قِبلَه. قال: قد عَلمتْ قريش أني مِن أكثرها مالًا. قال: فقُلْ فيه قولًا يَبلغ قومك أنّك مُنكِرٌ له، أو أنك كارهٌ له. قال: وماذا أقول؟ فواللهِ، ما فيكم رجل أعلم بالشِّعر مني، ولا برَجَزِهِ ولا بقِصِيده مني، ولا بأشعار الجنّ، واللهِ، ما يُشبه الذي يقول شيئًا من هذا، وواللهِ، إنّ لِقَوْله الذي يقول حلاوة، وإنّ عليه لَطُلاوة{1}، وإنه لَمُثمِرٌ أعلاه، مُغدِقٌ أسفله، وإنّه لَيَعلو وما يُعلى، وإنه ليَحْطِم ما تحته. قال: لا يرضى عنك قومك حتى تقول فيه. قال: فدعني حتى أُفكّر. فلما فَكّر قال: هذا سحرٌ يُؤثر؛ يَأْثُره عن غيره. فنَزلت: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>{2}. (١٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق معمر، عن رجل-، مثله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أيوب- في قول الوليد بن المُغيرة: إنّه يأمر بالعدل، والإحسان{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: دَخل الوليدُ بن المُغيرة على أبي بكر، فسأله عن القرآن، فلمّا أخبَره خرج على قريش، فقال: يا عجبًا لِما يقول ابنُ أبي كَبْشَة، فواللهِ، ما هو بشعرٍ، ولا بسحرٍ، ولا بهَذْي من الجنون، وإنّ قوله لَمِن كلام الله. فلمّا سمع النّفرُ مِن قريش ائتمروا، وقالوا: واللهِ، لَئِن صَبأ الوليدُ لَتَصْبأنّ قريشٌ. فلما سمع بذلك أبو جهل قال: واللهِ، أنا أكفيكم شأنَه. فانطَلق حتى دَخل عليه بيتَه، فقال للوليد: ألم ترَ قومك قد جَمعوا لك الصدقة؟ فقال: ألستُ أكثرهم مالًا وولدًا؟! فقال له أبو جهل: يَتحدَّثون أنك إنما تَدخل على ابن أبي قُحافة لِتُصيب من طعامه. فقال الوليد: لقد تَحدّث بهذا عشيرتي! فواللهِ، لا أقرب ابنَ أبي قُحافة، ولا عمر، ولا ابن أبي كَبْشَة، وما قوله إلا سحرٌ يُؤثر. فأَنزل الله: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span>{5}. (١٥/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- قال: أنزل الله في الوليد بن المُغيرة قوله: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، وقوله: <span class="qpc-hafs">﴿فَوَرَبِّكَ لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾</span> [الحجر:٩٢] إلى آخرها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، قال: نزلت في الوليد بن المُغيرة{7}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١١<span class="dash">-</span></span> عن <span class="name-3">قتادة بن دعامة</span> -من طريق معمر- أنه قال: خَرج مِن بطن أمه وحيدًا. قال: نزلت فيه هذه الآيات حتى بلغ: <span class="qpc-hafs">﴿عليها تسعة عشر﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، يعني: الوليد بن المُغيرة المخزومي، كان يُسمّى: الوحيد في قومه، وذلك أنّ الله ﷿ أنزل على النبي ﷺ: <span class="qpc-hafs">﴿حم، تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ. غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</span> [غافر:١-٣، فلما نزلت هذه الآية قام النبيُّ ﷺ في المسجد الحرام، فقرأها، والوليد بن المُغيرة قريبًا منه يستمع إلى قراءته، فلمّا فَطِن ﷺ أنّ الوليد بن المُغيرة يَستمع إلى قراءته أعاد النبيُّ ﷺ يقرأ هذه الآية: <span class="qpc-hafs">﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿لا إلهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</span> ... فلمّا سمعها الوليد انطلَق حتى أتى مجلس بني مخزوم، فقال: واللهِ، لَقد سمعتُ مِن محمد كلامًا آنفًا ما هو مِن كلام الإنس، ولا مِن كلام الجنّ، وإنّ أسفله لَمُغدِق، وإنّ أعلاه لَمُونقٌ، وإنّ له لَحلاوة، وإنّ عليه لَطُلاوة، وإنه لَيَعلو وما يُعلى. ثم انصرف إلى منزله، فقالت قريش: لقد صَبأ الوليد، واللهِ، لئن صَبأ لتَصبونّ قريش كلّها. وكان يقال للوليد: ريحانة قريش، فقال أبو جهل: أنا أكفيكموه. فانطلَق أبو جهل حتى دَخل على الوليد، فقعد إليه كَشَبَه الحزين، فقال له الوليد: ما لي أراك -يا ابن أخي- حزينًا؟ فقال أبو جهل: ما يمنعني أن لا أحزن وهذه قريش يَجمعون لك نفقةً لِيُعينوك على كِبَرك، ويزعمون أنك إنما زَيّنتَ قول محمد لِتُصيب مِن فضل طعامه. فغضب الوليدُ عند ذلك، وقال: أوَليس قد عَلمتْ قريشٌ أني مِن أكثرهم مالًا وولدًا، وهل يَشبع محمدٌ وأصحابُه مِن الطعام فيكون لهم فضل؟ فقال أبو جهل: فإنهم يزعمون أنك إنما زَيّنتَ قول محمد من أجل ذلك. فقام الوليد، فانطلَق مع أبي جهل، حتى أتى مجلس قومه بني مخزوم، فقال: تزعمون أنّ محمدًا كاهن، فهل سمعتموه يُخبر بما يكون في غد؟ قالوا: اللهم، لا. قال: وتزعمون أنّ محمدًا شاعر، فهل رأيتموه يَنطق فيكم بشعرٍ قطّ؟ قالوا: اللهم، لا. قال: وتزعمون أنّ محمدًا كذّاب، فهل رأيتموه يَكذب فيكم قطّ؟ قالوا: اللهم، لا. وكان يُسمّى محمد ﷺ قبل النبوة: الأمين، فبَرّأه من هذه المقالة كلّها، فقالت قريش: وما هو، يا أبا المُغيرة؟ فتفَكّر في نفسه ما يقول عن محمد ﷺ: <span class="qpc-hafs">﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</span> فقَدَّر له السحر، <span class="qpc-hafs">﴿فَقُتِلَ﴾</span> يعني: لُعِن <span class="qpc-hafs">﴿كَيْفَ قَدَّرَ﴾</span> لمحمد ﷺ السحر، <span class="qpc-hafs">﴿ثُمَّ نَظَرَ ثُمَّ عَبَسَ﴾</span> يقول: ثم كَلَح، <span class="qpc-hafs">﴿وبَسَرَ﴾</span> يعني: وتَغيّر لونه، [<span class="qpc-hafs">﴿ثم أدبر﴾</span>]{9} يعني: أعرَض عن الإيمان، <span class="qpc-hafs">﴿واسْتَكْبَرَ﴾</span> عنه، فقال الوليد لقومه: <span class="qpc-hafs">﴿إنْ هذا﴾</span> الذي يقول محمد <span class="qpc-hafs">﴿إلّا سِحْرٌ يُؤْثَرُ﴾</span>. فقال له قومه: وما السِّحر، يا أبا المُغيرة؟ وفرحوا، فقال: شيء يكون ببابل، إذا تعلّمه الإنسان يُفرِّق بين الاثنين، ومحمد يَأْثُره ولمّا يحذقه بعدُ، وايمُ الله، لقد أصاب فيه حاجته، أما رأيتموه فَرّق بين فلان وبين أهله، وبين فلان وبين أبيه، وبين فلان وبين أخيه، وبين فلان وبين مولاه، فهذا الذي يقول محمد سحرٌ يُؤثر عن مُسَيلمة بن حبيب -الحنفي الكذّاب-. يقول: يرويه عنه، فذلك قوله: <span class="qpc-hafs">﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ إنْ هَذا إلّا قَوْلُ البَشَرِ﴾</span> يقول: إنْ هذا الذي يقول محمد إلا قول البشر. قال الوليد بن المُغيرة: عن يَسار أبي فكيهة، هو الذي يأتيه به من مُسَيلمة –الكذّاب-، فجَعل الله له سَقر، وهو الباب الخامس مِن جهنم، فلمّا قال ذلك الوليد شَقّ ذلك على النبي ﷺ ما لم يشقّ عليه فيما قُذف بغيره من الكذب؛ فأَنزل الله تعالى على نبيّه ﷺ يعزيه ليَصبِر على تكذيبهم، فقال: يا محمد <span class="qpc-hafs">﴿كَذلِكَ ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلّا قالُوا ساحِرٌ أوْ مَجْنُونٌ﴾</span> [الذاريات:٥٢]، وأَنزل في الوليد بن المُغيرة: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٣<span class="dash">-</span></span> تفسير <span class="name-3">الكلبي</span>: <span class="qpc-hafs">﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿إنْ هَذا إلّا قَوْلُ البَشَرِ﴾</span> أنّ الوليد بن المُغيرة قال: يا قوم، إنّ أمْر هذا الرجل -يعني: النبي ﷺ- قد فشا، وقد حضَر الموسم، وإنّ الناس سيسألونكم عنه، ... بنحو ما سبق مختصرًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</span> حتى بلَغ: <span class="qpc-hafs">﴿سَأُصْلِيهِ سَقَرَ﴾</span>، قال: هذه الآيات أُنزِلَتْ في الوليد بن المُغيرة{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَرۡنِی وَمَنۡ خَلَقۡتُ وَحِیدࣰا ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، قال: الوليد بن المُغيرة{13}. (١٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: وكان يُسمّى: الوحيد في قومه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span> الآيات، قال: هو الوليد بن المُغيرة بن هشام المَخزوميّ، وكان له ثلاثة عشر ولدًا، كلّهم ربّ بيت، فلما نزلت: <span class="qpc-hafs">﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span> لم يَزل في إدبار مِن الدنيا في نفسه وماله وولده حتى أخرجه الله من الدنيا{15}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وحِيدًا﴾</span>، قال: خَلَقتُه وحده، ليس له مال ولا ولد{7}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧١٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، يعني: الوليد بن المُغيرة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق حُصَين- في قوله ﷿: <span class="qpc-hafs">﴿ذرني ومن خلقت وحيدًا﴾</span>، قال: هو الوليد بن المُغيرة المَخزوميّ{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، قال: هو الوليد بن المُغيرة، أخرجه الله مِن بطن أمه وحيدًا، لا مال له ولا ولد، فرَزقه الله المال والولد والثّروة والنّماء{19}. (١٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٢<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، قال: الوليد بن المُغيرة{20}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span>، يعني: الوليد بن المُغيرة المَخزوميّ، كان يُسمّى: الوحيد في قومه ...{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span> يقول: خَلِّ بيني -يا محمد- وبين مَن خَلقتُ وحيدًا. يقول: حين لم يكن له مال ولا بنون، يعني: خَلِّ بيني وبينه، فأنا أتفرّد بهلاكه، وأمّا الوليد يعني: خَلَقتُه وحده ليس له شيء{22}<span class=comment-ref>٦٨٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٣</span> أفادت الآثار أنّ وصف الوليد بالوحيد لأنه وُلد بلا مال ولا ولد، ثم رزقه الله المال والولد. وقد <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٥٥) هذا القول، وزاد عليه <b>قولًا</b> آخر، فقال: «وقيل: المعنى: خَلَقتُه وحدي، لم يشركني فيه أحد». و<span class="comment-type-4">علّق</span> عليه قائلًا: «فـ<span class="qpc-hafs">﴿وحيدا﴾</span> حال من التاء في <span class="qpc-hafs">﴿خَلَقْتُ﴾</span>».</div></p></div>",footnotes:1:أي: رونقًا وحُسنًا، وقد تفتح الطاء. النهاية (طلا).أخرجه الحاكم ٢/٥٥٠ (٣٨٧٢)، والبيهقي في دلائل النبوة ٢/١٩٨، وفي الشعب ١/٢٨٨ (١٣٣)، والواحدي في أسباب النزول ص٤٤٧، من طريق عبد الرزاق، عن معمر، عن أيوب السّختياني، عن عكرمة، عن ابن عباس به، وأخرجه أيضًا ابن جرير ٢٣/٤٢٩ من طريق معمر، عن عباد بن منصور، عن عكرمة به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، على شرط البخاري، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال البيهقي: «رواه حماد بن زيد، عن أيوب، عن عكرمة مُرسلًا».أخرجه عبد الرزاق ٢/٣٢٨-٣٢٩.أخرجه عبد الرزاق ٢/٣٢٩. وذكر محققه أنّ المراد هو: «أنّ ثناء الوليد السابق على القرآن كان بعد سماعه قوله تعالى: <span class="qpc-hafs">﴿إنَّ اللَّهَ يَأْمُرُ بِالعَدْلِ والإحْسانِ﴾</span> الآية [النحل:٩٠]».أخرجه أبو نعيم في دلائل النبوة ص٢٣٣ (١٨٤) دون ذكر الآية، وابن جرير ٢٣/٤٢٩-٤٣٠، من طريق عطية العَوفيّ، عن ابن عباس به.</p><p>الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ٢٣/٤٢١، من طريق محمد بن إسحاق، عن محمد بن أبي محمد، عن سعيد بن جُبَير، أو عكرمة، عن ابن عباس به.</p><p>إسناده جيد. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ٢٣/٤٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٢٩، وابن جرير ٢٣/٤٢٩.سقطت من المطبوع.تفسير مقاتل بن سليمان ٤/٤٩١-٤٩٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٦-٥٧-.أخرجه ابن جرير ٢٣/٤٢٢.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ١٠/٧١.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٢٢.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٩٧ (٢٣٢٩).أخرجه ابن جرير ٢٣/٤٢١. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩١-٤٩٣.تفسير مقاتل بن سليمان ٤/٤٩٤.
  74,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡتُ لَهُۥ مَالࣰا مَّمۡدُودࣰا ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٢٥<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عطاء- أنه سُئل عن قوله: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>. قال: غَلة شهر بشهر{1}<span class=comment-ref>٦٨٧٤</span>. (١٥/٧٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٤</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٤٥٥) على قول عمر، فقال: «فهو مَدٌّ في الزمان لا ينقطع».</div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>، قال: ألف دينار{2}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span> تسعة آلاف مثقال فِضّة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span> كان له بين مكة والطائف إبل وخيل ونَعم وغنم، وكان له عِير كثيرة، وعبيدٌ، وجوار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٢٩<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span> -من طريق محمد بن سوقة- <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>: ألف دينار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>، قال: ألف دينار{6}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣١<span class="dash">-</span></span> عن <span class="name-2">النعمان بن سالم</span> -من طريق شعبة- في قوله: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>، قال: الأرض{7}. (١٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم بن المهاجر</span> -من طريق قيس بن الربيع- قال: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>، قال: ألف دينار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span> أربعة آلاف دينار{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول ﷿: فأَعطيتُه المالَ والولد، فذلك قوله: <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span> يعني بالمال: بُستانه الذي له بالطائف، والممدود: الذي لا يَنْقطع خيره شتًاء ولا صيفًا، كقوله: <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span> [الواقعة:٣٠]، يعني: لا يَنقطع{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٥<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>، قال: بلَغني: أنه أربعة آلاف دينار{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٦<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، <span class="qpc-hafs">﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</span>، قال: ألف ألف{12}<span class=comment-ref>٦٨٧٥</span>. (١٥/٧٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٥</span> <span class="comment-type-4">علّق</span> <u>ابن عطية</u> (٨/٤٥٥) على قول مَن حدّ المال الممدود بعدد معين بقوله: «فهذا مَدّ في العدد».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٣/٤٢٤) <span class="mustanad">العموم</span>، وأنّ المال الممدود هو الكثير، الممدود عدده أو مساحته، دون تعيين لحدّه أو مقداره، فقال: «والصواب من القول في ذلك أن يُقال كما قال الله: <span class="qpc-hafs">﴿وجعلت له مالا ممدودًا﴾</span>، وهو الكثير الممدود عدده أو مساحته».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٢٣. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه، والدينوري في المجالسة.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٧١، وفيه تصحفت إلى: سبعة آلاف، وتفسير البغوي ٨/٢٦٦.تفسير البغوي ٨/٢٦٦.أخرجه ابن جرير ٢٣/٤٢٢.أخرجه عبد الرزاق ٢/٣٢٩، وابن جرير ٢٣/٤٢٢، ومن طريق إبراهيم أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٢٣. وعزاه السيوطي إلى ابن مردويه.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٣ (٢٥٧).تفسير الثعلبي ١٠/٧١، وتفسير البغوي ٨/٢٦٦.تفسير مقاتل بن سليمان ٤/٤٩٤.أخرجه ابن جرير ٢٣/٤٢٣.عزاه السيوطي إلى عبد بن حميد. وفي تفسير الثعلبي ١٠/ ٧١ عن سفيان الثوري.
  74,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبَنِینَ شُهُودࣰا ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٣٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿وبَنِينَ شُهُودًا﴾</span> كانوا ثلاثة عشر ولدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم- <span class="qpc-hafs">﴿وبَنِينَ﴾</span> قال: كانوا عشرة، <span class="qpc-hafs">﴿شُهُودًا﴾</span> قال: لا يَغيبون{2}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٣٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿وبَنِينَ شُهُودًا﴾</span>، قال: كانوا ثلاثة عشر{3}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وبَنِينَ شُهُودًا﴾</span> حُضورًا بمكة، لا يَغيبون عنه، وكانوا عشرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبَنِينَ شُهُودًا﴾</span> يعني: حُضورًا، لا يَغيبون أبدًا عنه في تجارة ولا غيرها؛ لكثرة أموالهم بمكة، وكلّهم رجال، منهم الوليد بن الوليد، وخالد بن الوليد -وهو سيف الله أسلم بعد ذلك-، وعمارة بن الوليد، وهشام بن الوليد، والعاص بن الوليد، وقيس بن الوليد، وعبد شمس بن الوليد{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٧٢.أخرجه ابن جرير ٢٣/٤٢٤ دون شطره الثاني. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير البغوي ٨/٢٦٧.تفسير مقاتل بن سليمان ٤/٤٩٤.
  74,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَهَّدتُّ لَهُۥ تَمۡهِیدࣰا ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٤٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</span>، يعني: المال بعضه على بعض، كما تُمهد الفُرش{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</span>، قال: بَسطتُ له من المال والولد{2}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</span>، يعني: المال بعضه على بعض، كما يُمهد الفُرش{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</span>، يقول: بَسطتُ له في المال والولد والخير بَسطًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</span>، قال: بُسِط له{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٧٢.أخرجه ابن جرير ٢٣/٤٢٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٨/٢٦٧.تفسير مقاتل بن سليمان ٤/٤٩٤.أخرجه ابن جرير ٢٣/٤٢٥.
  74,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ یَطۡمَعُ أَنۡ أَزِیدَ ۝١٥ كَلَّاۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> <span class="qpc-hafs">﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ * كَلّا﴾</span>، قال: فما زال يَرى النقصان في ماله وولده حتى هَلك{1}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ * كَلّا﴾</span>، قال: فلم يُولَد له بعد يومئذ، ولم يَزدد له من المال إلا ما كان{2}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٤٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ﴾</span> ثم يطمع أنْ أُدخله الجنة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ﴾</span> يقول: ثم يرجو أنْ أزيده في ماله وولده، <span class="qpc-hafs">﴿كَلّا﴾</span> لا أزيده، بل أقطع ذلك عنه وأُهلكه، ثم مَنعه الله المال، فلم يُعطه شيئًا حتى افتقر وسأل الناس، فأَهلكه الله تعالى، ومات فقيرًا في المُستهزئين، ثم نَعتَ عمله الخبيث، فقال: <span class="qpc-hafs">﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَلَّاۤۖ إِنَّهُۥ كَانَ لِـَٔایَـٰتِنَا عَنِیدࣰا ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿عَنِيدًا﴾</span>، قال: جَحودًا{5}. (١٥/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span>، قال: مُعانِدًا عنها، مُجانِبًا لها{6}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٥٣<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span>، قال: مُشاقًّا{2}. (١٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كَلّا إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span>، قال: كفورًا بآيات الله، جَحودًا بها{8}. (١٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</span> يعني: كان عن آيات القرآن مُعرِضًا مُجانبًا له، لا يُؤمن بالقرآن. ثم أخبر الله تعالى ما يَصنع به في الآخرة، فقال: <span class="qpc-hafs">﴿سَأُرْهِقُهُ صَعُودًا﴾</span>{9}<span class=comment-ref>٦٨٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٦</span> ذكر <u>ابنُ عطية</u> (٨/٤٥٥-٤٥٦) أنّ قوله: <span class="qpc-hafs">﴿لآياتنا﴾</span> هي العِبر، ثم ذكر القول بأنها آيات القرآن، كما في قول مقاتل، و<span class="comment-type-3">رجّحه</span> <span class="mustanad">مستندًا إلى السياق</span>، فقال: «ويحتمل أن يريد بالآيات: آيات القرآن، وهو الأصح في التأويل؛ بسبب كلام الوليد في القرآن بأنه سحرٌ».</div></p><p><div></p><p><p><span class="item-no">٧٩٧٥٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿لِآياتِنا عَنِيدًا﴾</span>، قال: مُشاقًّا{10}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٦-، وذكر عقبه: لقول المشرك: <span class="qpc-hafs">﴿ولَئِنْ رُجِعْتُ إلى رَبِّي﴾</span> [فصلت:٥٠] كما يقولون: <span class="qpc-hafs">﴿إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</span> [فصلت:٥٠] للجنة إن كانت جنة".تفسير مقاتل بن سليمان ٤/٤٩٤-٤٩٥.أخرجه ابن جرير ٢٣/٤٢٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٢٦، ومن طريق جابر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٢٦. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٩٥.أخرجه ابن جرير ٢٣/٤٢٦. وعقبه مباشرة في نفس السطر: «وقيل: عنيدًا، وهو مِن عاند معاندة فهو مُعانِد، كما قيل: عام قابل، وإنما هو مُقبل». ويظهر من صنيع الطبعة أنه من كلام سفيان، والأشبه أنه من كلام ابن جرير.
