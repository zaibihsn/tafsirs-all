  74,46,""
  74,47,""
  74,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩١٢<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>لَيَخرُجنّ بشفاعتي من أهل الإيمان من النار، حتى لا يبقى فيها أحدٌ إلا أهل هذه الآية: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿شَفاعَةُ الشّافِعِينَ﴾</span></b>»{1}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٣<span class="dash">-</span></span> عن أنس، عن النبيِّ ﷺ، قال: «<b>يُؤتى بأدنى أهل النار منزلة يوم القيامة، فيقول اللهُ له: تَفتدي بملء الأرض ذهبًا وفِضّة؟ فيقول: نعم، إن قَدَرتُ عليه. فيقول: كَذبتَ، قد كنتُ أسألك ما هو أيسرُ عليك مِن أن تسألني فأُعطيك، وتَستغفرني فأغفر لك، وتدعوني فأستجيب لك، فلم تَخفني ساعة قطّ من ليل ونهار، ولم تَرجُ ما عندي قطّ، ولم تَخشَ عقابي ساعة قطّ. وليس وراءه أحد إلا وهو شرٌّ منه، فيقال له: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿حَتّى أتانا اليَقِينُ﴾</span>، يقول الله: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span></b>»{2}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٤<span class="dash">-</span></span> عن حبيبة -أو أُمّ حبيبة- قالت: كُنّا في بيت عائشة، فدخل رسول الله ﷺ، فقال: «<b>ما مِن مُسلِمَيْن يموت لهما ثلاثة من الولد أطفال لم يَبلغوا الحِنث إلا جيء بهم حتى يُوقفوا على باب الجنة، فيقال لهم: ادخلوا الجنة أنتم وآباؤكم</b>». قال: فذلك قوله: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>. فعقّب، قال: نَفعت الآباء شفاعة أبنائهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الزّعراء- قال: يُعذِّب الله قومًا مِن أهل الإيمان، ثم يُخرجهم بشفاعة محمد ﷺ، حتى لا يَبقى إلا مَن ذَكر الله: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿شَفاعَةُ الشّافِعِينَ﴾</span>{4}. (١٥/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله [بن مسعود]</span> -من طريق أبي الزّعراء- في حديث طويل عن آخر الزمان ومبدأ البعث، قال: ... ثم يَشفع الملائكة، والنَّبيّون، والشهداء، والصالحون، والمؤمنون، فيُشفِّعهم الله، قال: ثم يقول: أنا أرحم الراحمين. قال: فيُخرج من النار أكثرَ مما أُخرج مِن جميع الخَلْق برحمته، حتى ما يَترك فيها أحدًا فيه خير. ثم قرأ <span class="name-1">عبد الله</span>: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> قال: وجعل يعقِد حتى عدَّ أربعًا: <span class="qpc-hafs">﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span> ثم قال <span class="name-1">عبد الله</span>: أترون في هؤلاء خيرًا؟! ما تُرك فيها أحد فيه خير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٧<span class="dash">-</span></span> قال <span class="name-1">عمران بن الحُصَين</span>: الشفاعة نافعةٌ لكلّ واحد، دون هؤلاء الذين تَسمعون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٨<span class="dash">-</span></span> عن عبد الرحمن بن ميمون الأَودي: أنّ <span class="name-2">كعب [الأحبار]</span> دخل يومًا على عمر بن الخطاب، فقال له عمر: حَدِّثني إلى ما تنتهي شفاعة محمد ﷺ يوم القيامة؟ فقال كعب: قد أخبَرك الله في القرآن؛ إنّ الله يقول: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿اليَقِينُ﴾</span>. قال كعب: فيَشفع يومئذ حتى يَبلغ مَن لم يُصلِّ صلاة قطّ، ولم يُطعم مسكينًا قطّ، ولم يُؤمن ببعثٍ قطّ، فإذا بَلغت هؤلاء لم يبق أحد فيه خير{7}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، قال: لا تنالهم شفاعة مَن يَشفع{8}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، قال: تعلَّموا أن الله يُشَفِّع المؤمنين يوم القيامة بعضهم في بعض. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «<b>إنّ في أمتي لَرجلًا ليُدخِلنّ الله الجنةَ بشفاعته أكثر من بني تميم</b>». وقال الحسن البصري: أكثر من ربيعة ومُضر. قال: وكُنّا نُحدَّث أنّ الشهيد يَشفع في سبعين من أهل بيته{9}. (١٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سفيان- <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، قال: لا تَنالهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، يعني: لا يَنالهم يومئذ شفاعة الملائكة والنَّبيّين{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٣<span class="dash">-</span></span> عن أنس، يقول: قال النبي ﷺ: «<b>إنّ الرجل ليشفع للرجلين، والثلاثة، والرجل للرجال</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٤<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ يَصِف أهلَ النار: «<b>فيَمُرّ فيهم الرجل من أهل الجنة، فيقول الرجل منهم: يا فلان. قال: فيقول: ما تريد؟ فيقول: أما تذكر رجلًا سَقاك شربة يوم كذا وكذا؟ قال فيقول: وإنّك لَأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه. قال: ثم يَمُرّ بهم الرجل من أهل الجنة، فيقول: يا فلان، فيقول: ما تريد؟ فيقول: أما تَذكر رجلًا وهب لك وضوءًا يوم كذا وكذا؟ فيقول: إنك لأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه</b>»{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٥<span class="dash">-</span></span> عن يزيد بن صُهيب الفقير، قال: كُنّا بمكة ومعي طَلق بن حبيب، وكنا نرى رأي الخوارج، فبَلغنا أنّ <span class="name-1">جابر بن عبد الله</span> يقول في الشفاعة، فأتيناه، فقلنا له: بلغنا عنك في الشفاعة قولٌ، اللهُ مخالفٌ لك فيها في كتابه. فنَظر في وجوهنا، فقال: مِن أهل العراق أنتم؟ قلنا: نعم. فتبَسّم، وقال: وأين تجدون في كتاب الله؟ قلت: حيث يقول: <span class="qpc-hafs">﴿رَبَّنا إنَّكَ مَن تُدْخِلِ النّارَ فَقَدْ أخْزَيْتَهُ﴾</span> [آل عمران:١٩٢]، و<span class="qpc-hafs">﴿يُرِيدُونَ أنْ يَخْرُجُوا مِنَ النّارِ وما هُمْ بِخارِجِينَ مِنها﴾</span> [المائدة:٣٧]، و<span class="qpc-hafs">﴿كُلَّما أرادُوا أنْ يَخْرُجُوا مِنها أُعِيدُوا فِيها﴾</span> [السجدة:٢٠]، وأشباه هذا من القرآن. فقال: أنتم أعلم بكتاب الله أم أنا؟ قلنا: بل أنتَ أعلم به منّا. قال: فواللهِ، لقد شهدتُ تنزيل هذا على عهد رسول الله ﷺ وشفاعة الشافعين، ولقد سمعتُ تأويله من رسول الله ﷺ، وإنّ الشفاعة لنبيّه في كتاب الله؛ قال في السورة التي يذكر فيها المُدَّثِّر: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</span> الآية، ألا تَرون أنها حلّتْ لِمن لا يُشرك بالله شيئًا؟ سمعتُ رسول الله ﷺ يقول: «<b>إنّ الله خَلَق خَلْقًا، ولم يَستعن على ذلك، ولم يُشاور فيه أحدًا، فأَدخلَ مَن شاء الجنة برحمته، وأَدخلَ مَن شاء النار، ثم إنّ الله تحنّن على المُوحِّدين، فبَعث ملَكًا مِن قِبَله بماء ونور، فدَخل النار، فنَضح، فلم يُصب إلا مَن شاء، ولم يُصب إلا مَن خَرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم رجع إلى ربّه، فأمدّه بماء ونور، ثم دَخل فنَضح، فلم يُصب إلا مَن شاء الله، ثم لم يُصب إلا مَن خرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم أذِن الله للشفعاء، فشَفعوا لهم، فأَدخلهم الله الجنة برحمته وشفاعة الشافعين</b>»{14}. (١٥/٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن خسرو في مسند أبي حنيفة ١/٤٥١ (٤٨٩)، والحارثي في مسند أبي حنيفة ٢/٨٤٢ (١٤٩٧-١٥١٢)، من طريق أبي حنيفة، عن سلمة بن كُهيل، عن أبي الزّعراء، عن عبد الله بن مسعود به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال ابن خسرو: «روى الجماعة هذا الحديث موقوفًا على عبد الله بن مسعود».أخرجه الواحدي في التفسير الوسيط ٤/٣٨٦-٣٨٧ (١٢٥٧)، من طريق ليث، عن بشر، عن أنس بن مالك به. وعزاه السيوطي إلى ابن مردويه.</p><p>وسنده ضعيف؛ فيه بشر، قال عنه ابن حجر في التقريب (٧١٠): «هو ابن دينار، مجهول». وفيه ليث بن أبي سليم، قال عنه ابن حجر في التقريب (٥٦٨٥): «صدوق، اختلط جدًّا، ولم يتميّز حديثه؛ فتُرك».أخرجه إسحاق بن راهويه في مسنده ٤/٢٥١ (٢٠٧٤)، والطبراني في الكبير ٢٤/٢٢٤ (٥٧٠)، بنحوه دون ذكر الآية، من طريق محمد بن سيرين، عن حبيبة به. ووقع عند إسحاق: حبيبة أو أُمّ حبيبة.</p><p>وأخرجه الطبراني في الكبير ٢٤/٢٢٥ (٥٧١) بنحوه دون ذكر الآية، من طريق محمد بن سيرين، عن يزيد بن أبي بكرة، عن حبيبة به.</p><p>وقال المنذري في الترغيب والترهيب ٣/٥٥-٥٦ (٣٠٥٧): «رواه الطبراني في الكبير، بإسناد حسن جيد». وقال الهيثمي في المجمع ٣/٧ (٣٩٧٧): «رواه الطبراني في الكبير، ورجاله رجال الصحيح، خلا يزيد بن أبي بكرة، وقد وثّقه ابن حبان، وأعاده بإسناد آخر، ورجاله ثقات، وليس فيه يزيد بن أبي بكرة». وأورده الألباني في الصحيحة ٧/١٢٢٨ (٣٤١٦).أخرجه البيهقي في البعث (٨٦).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٢١/٢٨١-٢٨٥ (٣٨٧٩٢)، وابن جرير ٢٣/٤٥٣ بنحوه مختصرًا.تفسير البغوي ٨/٢٧٣.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٥٣، وعبد الرزاق ٢/٣٣٠-٣٣١ من طريق معمر مختصرًا، ومثله ابن جرير ٢٣/٤٥٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.كتاب صفة النار-موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٣)-.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه عبد الرزاق ٣/٣٦٤ (٣٣٩٣) واللفظ له، وابن خزيمة في التوحيد ٢/٧٤٥، والبزار ١٣/٣١٩ (٦٩٢١) مختصرًا، من طريق معمر، عن ثابت، عن أنس بن مالك به.</p><p>قال المنذري في الترغيب والترهيب ٤/٢٤١ (٥٥١٤): «رواته رواة الصحيح». وقال الهيثمي في المجمع ١٠/٣٨٢ (١٨٥٤٨): «رجاله رجال الصحيح».أخرجه ابن ماجه ٤/٦٤٤ (٣٦٨٥)، والبغوي في تفسيره ٨/٢٧٣-٢٧٤، واللفظ له، من طريق يزيد الرّقاشي، عن أنس بن مالك به.</p><p>وقال البوصيري في مصباح الزجاجة ٤/١٠٥ (٧٨٢١): «إسناد ضعيف؛ لضعف يزيد بن أبان الرّقاشي». وقال الألباني في الضعيفة ١/٢١٠ (٩٣): «ضعيف».أخرجه ابن أبي حاتم، وابن مردويه -كما في تفسير ابن كثير ٣/٩٩-. وأصله في صحيح مسلم ١/٧٧ (١٩١)، وليس فيه ذكر آية سورة المدثر.
  74,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾</span> نزلت هذه الآية في كفار قريش حين أعرَضوا ولم يؤمنوا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾</span>، قال: عن القرآن{2}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ﴾</span> يعني: عن القرآن <span class="qpc-hafs">﴿مُعرِضين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٩-٥٠٠.أخرجه ابن جرير ٢٣/٤٥٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه مقاتل بن سليمان ٤/٤٩٩-٥٠٠.
  74,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٠<span class="dash">-</span></span> و<span class="name-2">أبي رجاء</span> أنهما قرآ: ‹مُّسْتَنفَرَةٌ›، يعني: بنصب الفاء{1}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣١<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿كَأَنَّهُمْ حُمُرٌ﴾</span> مُثقّلة، <span class="qpc-hafs">﴿مُسْتَنْفِرَةٌ﴾</span> بخفض الفاء{2}<span class=comment-ref>٦٨٩٠</span>. (١٥/٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٠</span> ذكر <u>ابنُ جرير</u> (٢٣/٤٥٥) هذه القراءة، وقراءة مَن قرأ ذلك: ‹مُّسْتَنفَرَةٌ›، ثم قال <span class="comment-type-4">معلقًا</span>: «والصواب من القول في ذلك عندنا أنهما قراءتان <span class="mustanad">معروفتان، صحيحتا المعنى</span>، فبأيّتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: شبّههم بالحُمُر الوحشية المذْعُورة، فقال: <span class="qpc-hafs">﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ﴾</span> بترْكهم القرآن، إذا سمعوه فرُّوا منه مثل الحُمر{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها نافع، وأبو جعفر، وابن عامر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مُّسْتَنْفِرَةٌ﴾</span> بكسر الفاء. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٢.عزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٥٠٠.
  74,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرَّتۡ مِن قَسۡوَرَةِۭ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٣٣<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span> -من طريق أبي ظَبْيان- في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: هم الرُّماة؛ رجال القَنص{1}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق زيد بن أسلم- في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: الأسد{2}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القَسْورة: الرّجال الرُّماة؛ رجال القَنص{3}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿مِن قَسْوَرَةٍ﴾</span>، قال: هو بلسان العرب: الأسد، وبلسان الحبشة: قَسْورة{4}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي حمزة- أنه سأله: القَسْورة الأسد؟ فقال: ما أعلمه بلغة أحد من العرب الأسد، هم عُصْبة الرجال{5}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يوسف بن مهران- أنه سئل عن قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>. قال: هو بالعربية: الأسد، وبالفارسية: شار، وبالنّبَطِيّة: أريا، وبالحبشية: قَسْورة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿مِن قَسْوَرَةٍ﴾</span>، قال: مِن حبال الصيادين{7}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿مِن قَسْوَرَةٍ﴾</span>، قال: هو رِكْزُ الناس. يعني: أصواتهم{8}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبّاد بن عبد الرحمن مولى بني هاشم- أنه سئل عن القَسْورة. قال: جمْع الرجال، ألم تسمع ما قالتْ فلانة في الجاهلية:</p><p>يا بنتي كوني خيْرةً لخَيِّره</p><p>أخوالها في الحي مثل القَسْورهْ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي بشر- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القُنّاص{10}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: الرُّماة{11}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: هم الرُّماة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٥<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿قَسْوَرَةٍ﴾</span>، القَسْورة: هي مِن ظُلمة الليل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: وحشيّة فرّتْ من رُماتها{14}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القَسْورة: الرُّماة. فقال رجل لعكرمة: هو الأسد بلسان الحبشة. فقال عكرمة: اسم الأسد بلسان الحبشة: عَنبَسة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، قال: القَسْورة: الرُّماة{14}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span>، مثله{17}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي المُتوكِّل [الناجي]</span> -من طريق إسماعيل بن مسلم العبدي - قال: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span> هي لغَط القوم، وأصواتهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: القَسْورة: النَّبْل{19}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>: وهم الرُّماة القُنّاص{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٣<span class="dash">-</span></span> عن ابن لَهِيعة: أنّ <span class="name-2">يزيد بن أبي حبيب</span> سُئل عن قول الله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>. فزعم أنه يقال: هم الرُّماة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٤<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: أي: من رجال أقوياء، وكلّ ضخم شديد عند العرب: قَسْوَر، وقَسْوَرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق داود بن قيس- في قول الله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: هو الأسد{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، يعني: الرُّماة، وقالوا: الأسد{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القَسْورة: الأسد{6}<span class=comment-ref>٦٨٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩١</span> قال <u>ابنُ تيمية</u> (٦/٤٢٨): «و<span class="qpc-hafs">﴿قسورة﴾</span> يُراد به: الرامي، ويُراد به: الأسد».</div></p></div>",footnotes:1:أخرجه سعيد بن منصور وابن أبي حاتم -كما في فتح الباري ٨/٦٧٦-، وابن جرير ٢٣/٤٥٥، والحاكم ٢/٥٠٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٢-، والبزار (٢٢٧٧-كشف)، وابن جرير ٢٣/٤٥٩-٤٦٠، من طريق زيد، عن ابن سيلان. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٠ (١٦) من طريق عطاء، وابن جرير ٢٣/٤٥٥، ٤٥٧ من طريق سليم، وعطاء أيضًا بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٦٠ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٧٦-، وابن جرير ٢٣/٤٥٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٦٠.عزاه السيوطي إلى ابن المنذر.أخرجه سفيان بن عُيينة -كما في فتح الباري ٨/٦٧٦-، وعبد الرزاق ٢/٣٣٢، وابن جرير ٢٣/٤٥٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٥٨.أخرجه ابن جرير ٢٣/٤٥٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٥٥-٤٥٦، وبنحوه من طريق ابن أبي نجيح. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ١٠/٧٨، وتفسير البغوي ٨/٢٧٤.تفسير الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٥٦، وبنحوه من طريق أبي رجاء.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه الخطيب في تاريخه ٩/١٨٦.أخرجه الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.أخرجه عبد الرزاق ٢/٣٣٢، وابن جرير ٢٣/٤٥٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٥٧.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٣-١١٤ (٢٦٠).تفسير الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.أخرجه ابن جرير ٢٣/٤٥٩-٤٦٠، ومن طريق هشام أيضًا.تفسير مقاتل بن سليمان ٤/٥٠٠.أخرجه ابن جرير ٢٣/٤٦٠.
  74,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ یُرِیدُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُؤۡتَىٰ صُحُفࣰا مُّنَشَّرَةࣰ ۝٥٢﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق زاذان- يقول: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>، كان المشركون يقولون: لو كان محمد صادقًا فليُصبح عند كلِّ رأس رجل منّا صحيفةٌ فيها براءته وأَمْنه مِن النار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>، قال: إلى فلان بن فلان مِن ربّ العالمين؛ يُصبح عند رأس كلّ رجل صحيفة موضوعة يقرؤها{2}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- قال: قالوا: إن كان محمد صادقًا فليُصبح تحت رأس كلّ رجل منّا صحيفة فيها براءةٌ وأمَنَةٌ من النار. فنَزلت: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>{3}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>، قال: قد قال قائلون من الناس: يا محمد، إن سرَّك أن نتّبعك فأتِنا بكتاب خاصة إلى فلان وفلان، نُؤمر فيه باتّباعك. قال <span class="name-2">قتادة</span>: يريدون أن يُؤتوا براءة بغير عمل{4}<span class=comment-ref>٦٨٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٢</span> لم يذكر <u>ابنُ جرير</u> (٢٣/٤٦١) غير قول قتادة، ومجاهد.</div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٢<span class="dash">-</span></span> قال <span class="name-2">مطر الوراق</span>: كانوا يريدون أن يؤتوا براءة من غير عمل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: إنّ المشركين قالوا: يا محمد، بلَغنا أنّ الرجل من بني إسرائيل يُصبح مكتوب عند رأسه ذَنبه وكفّارته؛ فأتِنا بمثل ذلك. فكَرهه رسول الله ﷺ، وأنزل الله سبحانه هذه الآية: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى﴾</span> يقول: يُعطى <span class="qpc-hafs">﴿صُحُفًا مُنَشَّرَةً﴾</span> فيها كتاب من الله تعالى. وذلك أنّ كفار مكة قالوا للنبي ﷺ: كان الرجل مِن بني إسرائيل ذَنبه وكفّارة ذَنبه يُصبح مكتوبًا عند رأسه، فهلا تُرينا مثل هؤلاء الآيات إن كنت رسولًا كما تزعم. فقال جبريل: إن شئتَ فعلنا بهم كفِعْلنا ببني إسرائيل، وأَخذناهم بما أخذنا به بني إسرائيل. فكَره النبي ﷺ، وقالوا: ليُصبح عند رأس كلّ رجل منّا كتابٌ منشور مِن الله بأنّ آلهتنا باطل، وأنّ الإله الذي في السماء حقٌّ، وأنك رسول، وأنّ الذي جئت به حقٌّ، وتجيء معك بملائكة يَشهدون بذلك كقول ابن أبي أُمَيّة في سورة بني إسرائيل{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٧٩.أخرجه ابن جرير ٢٣/٤٦١ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٣/٤٦١.تفسير الثعلبي ١٠/٧٩.تفسير الثعلبي ١٠/٧٩. وبنحوه في تفسير البغوي ٨/٢٧٥ دون ذكر النزول.تفسير مقاتل بن سليمان ٤/٥٠٠. وآخره يشير إلى الآيات ٩٠-٩٣ من سورة الإسراء وهي: <span class="qpc-hafs">﴿وقالُوا لَنْ نُؤْمِنَ لَكَ حَتّى تَفْجُرَ لَنا مِنَ الأَرْضِ يَنْبُوعًا، أوْ تَكُونَ لَكَ جَنَّةٌ مِن نَخِيلٍ وعِنَبٍ فَتُفَجِّرَ الأَنْهارَ خِلالَها تَفْجِيرًا، أوْ تُسْقِطَ السَّماءَ كَما زَعَمْتَ عَلَيْنا كِسَفًا أوْ تَأْتِيَ بِاللَّهِ والمَلائِكَةِ قَبِيلًا، أوْ يَكُونَ لَكَ بَيْتٌ مِن زُخْرُفٍ أوْ تَرْقى فِي السَّماءِ ولَنْ نُؤْمِنَ لِرُقِيِّكَ حَتّى تُنَزِّلَ عَلَيْنا كِتابًا نَقْرَؤُهُ قُلْ سُبْحانَ رَبِّي هَلْ كُنْتُ إلّا بَشرًا رَسُولًا﴾</span> [الإسراء:٩٠-٩٣].
  74,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّاۖ بَل لَّا یَخَافُونَ ٱلۡـَٔاخِرَةَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- <span class="qpc-hafs">﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾</span>، قال: هذا الذي فَضحهم{1}. (١٥/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾</span>، قال: ذلك الذي تَضَحَّك بالقوم وأَفسدهم؛ أنهم كانوا لا يَخافون الآخرة، ولا يُصدِّقون بها{2}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا﴾</span> لا يؤمنون بالصُّحف التي أرادوها، ثم استأنف فقال: <span class="qpc-hafs">﴿بَلْ﴾</span> لكن <span class="qpc-hafs">﴿لا يَخافُونَ﴾</span> عذاب <span class="qpc-hafs">﴿الآخِرَةَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٤/٣٣.أخرجه ابن جرير ٢٣/٤٦٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٠٠-٥٠١.
  74,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّاۤ إِنَّهُۥ تَذۡكِرَةࣱ ۝٥٤ فَمَن شَاۤءَ ذَكَرَهُۥ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله <span class="qpc-hafs">﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾</span>، قال: هذا القرآن{1}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿فَمَن شاءَ ذَكَرَهُ﴾</span> يعني: فَهِمَهُ، يعني: القرآن{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٦٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٠١.
