  56,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَحۡنُ قَدَّرۡنَا بَیۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِینَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span> في المتعجّل والمتأخّر، <span class="qpc-hafs">﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</span>{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span>، قال: المتأخّر والمتعجّل{2}<span class=comment-ref>٦٤٤٤</span>. (١٤/٢١٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٤</span> ذكر <u>ابنُ عطية</u> (٨/٢٠٤) أنّ الآية تحتمل أن تكون بمعنى: «سوَّيْنا وعدَّلْنا التَّقدُّم والتَّأخُّر». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «أي: جعلنا الموت رُتَبًا، ليس يموت العالمَ دفعة واحدة، بل بترتيبٍ لا يعدوه أحد».</div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span>، قال: تقديره أن جعل أهل الأرض وأهل السماء فيه سواء؛ شريفهم وضعيفهم{3}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span> فمنكم مَن يموت صغيرًا، ومنكم مَن يموت كبيرًا، أو يموت شابًّا، أو شيخًا، أو يبلغ أرذَل العمر. ثم خوّفهم، فقال: <span class="qpc-hafs">﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</span> يعني: بمُعجَزين إنْ أردنا ذلك{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٦-٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو الشيخ في العظمة (١٨٠).تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَىٰۤ أَن نُّبَدِّلَ أَمۡثَـٰلَكُمۡ وَنُنشِئَكُمۡ فِی مَا لَا تَعۡلَمُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</span> فيقول: نذهب بكم، ونجيء بغيركم، <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> يقول: نخلقكم فيما لا تعلمون؛ إن نشأ خلقناكم قِردة، وإن نشأ خلقناكم خنازير{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> يعني: في حواصل طير، تكون بِبَرَهُوت، كأنها الخطاطيف. وبَرَهُوت: وادٍ باليمن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span>، قال: في أي خلْقٍ شئنا{3}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> أي: نبدّل صفاتكم، ونجعلكم قِردة وخنازير كما فعلنا بمن كان قبلكم{2}<span class=comment-ref>٦٤٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٢٠٤) قول الحسن بقوله: «تأوَّل الحسن هذا؛ لأنّ الآية تنحو إلى الوعيد».</div></p><p><div></p><p><p><span class="item-no">٧٥٢١٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> نخلُقكم في سوء خلقكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</span> على أن نخلُق مثلكم أو أمثل منكم، <span class="qpc-hafs">﴿ونُنْشِئَكُمْ﴾</span> يعني: ونخلقكم سوى خلْقكم <span class="qpc-hafs">﴿فِي ما لا تَعْلَمُونَ﴾</span> من الصورة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢١٥، وتفسير البغوي ٨/٢٠.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٢١٥، وتفسير البغوي ٨/٢٠.تفسير الثعلبي ٩/٢١٥.تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشۡأَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَكَّرُونَ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى فَلَوْلا تَذَكَّرُونَ﴾</span>، يقول: فهلّا تذكَّرون{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span>: إذ لم تكونوا شيئًا{2}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span>، قال: خلْق آدم ﵇{3}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٥<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجَوْني</span> -من طريق جعفر بن سليمان- يقرأ هذه الآية: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span>، قال: هو خلْق آدم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>{5} -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span> قال: خلْق آدم وخلْقكم، <span class="qpc-hafs">﴿فَلَوْلا تَذَكَّرُونَ﴾</span> فهلّا تصدّقون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span> يعني: الخلْق الأول حين خُلقتم من نطفة، ثم من علقة، ثم من مُضغة، ولم تكونوا شيئًا، <span class="qpc-hafs">﴿فَلَوْلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تَذَكَّرُونَ﴾</span> في البعث أنّه قادر على أن يبعثكم، كما خلقكم أول مرّة ولم تكونوا شيئًا{7}<span class=comment-ref>٦٤٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٦</span> نقل <u>ابنُ عطية</u> (٨/٢٠٥) عن أكثر المفسرين قولهم: «أشار إلى خلْق آدم ﵇، ووقف عليه؛ لأنك لا تجد أحدًا ينكر أنه من ولد آدم ﵇، وأنه من طين». ونقل عن بعضهم قولهم: «أراد تعالى بالنَّشأة الأولى: نشأة إنسان في طفولته، فيَعلم المرء نشأته كيف كانت بما يَرى من نشأة غيره».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٤٧.جاء في طبعة الكتاب بتحقيق: د. رضاء الله المباركفوري ص١٤٣ (٩٥) طمس مكان القائل، وقال المحقق: لعل المطموس: عن الضَّحّاك. وفي طبعة الكتاب بتحقيق: أبي بكر سعداوي ٣/٢٧١ (٢٠٩) روى الأثر عن الضَّحّاك دون إسناد.أخرجه ابن أبي الدنيا في الأهوال ٦/١٧٥ (٩٤).تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تَحۡرُثُونَ ۝٦٣ ءَأَنتُمۡ تَزۡرَعُونَهُۥۤ أَمۡ نَحۡنُ ٱلزَّ ٰ⁠رِعُونَ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢١٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>لا يقولنّ أحدكم: زرعتُ. ولكن ليقُلْ: حرثتُ</b>». قال <span class="name-1">أبو هريرة</span>: ألم تسمعوا الله يقول: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span>{1}. (١٤/٢١٥)= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٩<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السلمي</span> -من طريق عطاء- بمثله من قوله غير مرفوع{2}. (١٤/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ﴾</span> يقول: ما تزرعون، <span class="qpc-hafs">﴿أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span> يقول: أليس نحن الذي نُنبِته، أم أنتم المُنبِتون؟{3}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿أأَنْتُمْ تَزْرَعُونَهُ﴾</span>، قال: تُنبِتونه{4}. (١٤/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span> يعني: نحن الحافظون، يقول: أنتم تنبتونه أم نحن المنبتون له؟{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تَحۡرُثُونَ ۝٦٣ ءَأَنتُمۡ تَزۡرَعُونَهُۥۤ أَمۡ نَحۡنُ ٱلزَّ ٰ⁠رِعُونَ ۝٦٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- لا تقُلْ: زرعتُ. ولكن قل: حرثتُ. إنّ الله هو الزارع{6}. (١٤/٢١٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن حبان ١٣/٣٠ (٥٧٢٣)، وابن جرير ٢٢/٣٤٨، والثعلبي ٩/٢١٥، وفيه مسلم الجرمي.</p><p>قال الطبراني في المعجم الأوسط ٨/٨٠ (٨٠٢٤): «لم يرو هذا الحديث عن هشام إلا مخلد، تفرّد به مسلم الجرمي». وقال البيهقي في الكبرى ٦/٢٢٨ (١١٧٥١) بعد أن ذكره من قول مجاهد: «وقد روي فيه حديث مرفوع غير قوي». وقال الزيلعي في تخريج أحاديث الكشاف ٣/٤٠٩ (١٢٩٠): «ذكره عبد الحق في أحكامه في باب إحياء الموات من جهة البزار، وسكت عنه، فهو صحيح عنده، وأقرّه ابن القطان على ذلك». وقال الهيثمي في المجمع ٤/١٢٠ (٦٥٩٣): «رواه الطبراني في الأوسط، والبزار، وفيه مسلم بن أبي مسلم الجرمي، ولم أجد من ترجمه، وبقية رجاله ثقات». قال ابن حجر في الفتح ٥/٤ عن رواية ابن أبي حاتم: «ورجاله ثقات، إلا أن مسلم بن أبي مسلم الجرمي قال فيه ابن حبان: ربما أخطأ». وقال الألباني في الصحيحة ٦/٧١٥ (٢٨٠١): «وهذا إسناد جيد، رجاله ثقات رجال مسلم، غير مسلم بن أبي مسلم الجرمي».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٧-، وعبد بن حميد -كما في الفتح ٥/٤-. وعزاه السيوطي إلى عبد بن حميد بلفظ: عن أبي عبد الرحمن أنه كره أن يقول: زرعتُ، ويقول: حرثتُ.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه البيهقي في سننه ٦/١٣٨.
