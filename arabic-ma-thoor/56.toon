  56,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ إِنَّكُمۡ أَیُّهَا ٱلضَّاۤلُّونَ ٱلۡمُكَذِّبُونَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ أيُّها الضّالُّونَ المُكَذِّبُونَ﴾</span>، قال: المشركون المُكذِّبون{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر طعامهم وشرابهم في الآخرة، فقال: <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿أيُّها الضّالُّونَ﴾</span> عن الهدى، يعني: المشركين، ثم قال: <span class="qpc-hafs">﴿المُكَذِّبُونَ﴾</span> بالبعث؛ لقولهم: أوَ يَبعث آباءنا الأوّلين؟!{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَـَٔاكِلُونَ مِن شَجَرࣲ مِّن زَقُّومࣲ ۝٥٢ فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ﴾</span>، قال: والزَّقوم إذا أكلوا منه غَصُّوا، والزَّقوم شجرة{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَمالِئُونَ مِنها البُطُونَ﴾</span>، قال: يملؤون من الزَّقوم بطونهم{1}. (١٤/٢٥٠-٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ فَمالِئُونَ مِنها﴾</span> يعني: مِن طلْعها وثمرها <span class="qpc-hafs">﴿البُطُونَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
