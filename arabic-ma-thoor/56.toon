  56,53,""
  56,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَشَـٰرِبُونَ عَلَیۡهِ مِنَ ٱلۡحَمِیمِ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَشارِبُونَ عَلَيْهِ مِنَ الحَمِيمِ﴾</span>، يقول: على الزّقوم الحميم{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَشارِبُونَ عَلَيْهِ﴾</span> يعني: على الأكل <span class="qpc-hafs">﴿مِنَ الحَمِيمِ﴾</span> يعني: الشراب الحار الذي قد انتهى حرُّه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَشَـٰرِبُونَ شُرۡبَ ٱلۡهِیمِ ۝٥٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٥١٧٢<span class="dash">-</span></span> عن عبد الله بن عمر: أنّ رسول الله ﷺ قرأ في الواقعة: ‹فَشارِبُونَ شَرْبَ الهِيمِ› بفتح الشين من <span class="qpc-hafs">﴿شُرب﴾</span>{1}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٣<span class="dash">-</span></span> عن أنس بن مالك، قال: كان النبيُّ ﷺ يقرأ: ‹شَرْبَ الهِيمِ›{2}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٤<span class="dash">-</span></span> قرأ <span class="name-2">عاصم</span>: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span> برفع الشين{3}<span class=comment-ref>٦٤٤٢</span>. (١٤/٢١١)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٢</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿شُرْبَ الهيم﴾</span> بضم الشين. <b>الثانية:</b> ‹شَرْبَ الهِيمِ› بفتح الشين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٤٢) «أنهما قراءتان، قد قرأ بكلِّ واحدةٍ منهما علماءُ من القرأة، مع تقارب معنيَيْهما، فبأيَّتِهما قرأ القارئ فمصيبٌ في قراءته؛ لأن ذلك في فتحه وضمِّه نظير فتح قولهم: الضَّعف، والضُّعف وضمِّه».</div></p><p><h3><span class="qpc-hafs">﴿فَشَـٰرِبُونَ شُرۡبَ ٱلۡهِیمِ ۝٥٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٥١٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سفيان- في قوله: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل العِطاش{4}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>. قال: الإبل يأخذها داء يُقال له: الهِيم، فلا تَروى مِن الماء، فشبّه الله تعالى شُرب أهل النار مِن الحميم بمنزلة الإبل الهِيم. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ لَبيد بن ربيعة وهو يقول:</p><p>أجَزتُ إلى مَعارِفها بِشُعْثٍ وأطْلاحٍ{5} من العِيديِّ{6} هِيمِ؟!{7}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: هُيام الأرض، يعني: الرّمال{8}<span class=comment-ref>٦٤٤٣</span>. (١٤/٢١٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٣</span> ذكر <u>ابنُ عطية</u> (٨/٢٠٣) قول ابن عباس، وسفيان الثوري: أنّ «الهيم هنا: الرمال التي لا تُرْوى بالماء». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وذلك أن الهَيام -بفتح الهاء-: هو الرّمل الدِّق الغَمْر المتراكم».</div></p><p><div></p><p><p><span class="item-no">٧٥١٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>: هي الرّمال، لو مطرت عليها السماء أبدًا لم يُرَ فيها مستنقع{2}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل{10}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل الهُيَّم{11}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل الظّماء{12}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>: هو داء يكون في الإبل تشرب فلا تَروى{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الهيم: الإبل العِطاش، تشرب فلا تَروى، يأخذها داء يقال له: الهُيام{14}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿الهِيمِ﴾</span> الأرض السّهلة ذات الرّمل{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران- <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: الإبل المِراض تمصّ الماء مصًّا، ولا تَروى{16}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: الإبل يأخذها العِطاش، فلا تزال تشرب حتى تهلك{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي مجلز [لاحق بن حميد]</span>، <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: كان المِراض تمصّ الماء مصًّا، ولا تَروى{18}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿الهِيمِ﴾</span> الإبل العِطاش{10}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: ضوالّ الإبل، دوابّ لا تَروى{10}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل العِطاش{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: داءٌ بالإبل لا تَروى معه{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، يعني: الإبل العِطاش{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span> يعني بالهِيم: الإبل، يأخذها داء يُقال له: الهِيم، فلا تَروى من الشراب، وذلك أنه يُلقى على أهل النار العطش كلّ يوم مرتين حتى يشربوا الشراب الهِيم{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٤<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿الهِيمِ﴾</span>، قال: السّهلة{25}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الأوسط ٩/١٤٥ (٩٣٧١)، وتمام في فوائده ١/٢١٦ (٥١١)، وابن عساكر في تاريخ دمشق ٦٤/٢٢٩-٢٣٠. وأخرجه الحاكم ٢/٢٧٤ (٢٩٨٧) بضم الشين، وفي إسناده سلام بن سليمان المدايني.</p><p>قال ابن حبان في المجروحين ١/٣٤٢ (٤٣٣): «سلام بن سليمان شيخ يروي عن أبي عمرو بن العلاء أشياء لا يُتابع عليها، لا يجوز الاحتجاج به إذا انفرد، روى عن أبي عمرو بن العلاء، عن نافع، عن ابن عمر، أنّ رسول الله ﷺ قرأ: ‹فَشارِبُونَ شَرْبَ الهِيمِ›، في أشياء يروي مثل هذا لا توافق حديث الثقات، بل يباين حديث الأثبات». وقال ابن عدي في الكامل ٤/٣٢٣ (٧٧٢): «سلام بن سليمان بن سوار الثقفي المدائني الضرير ...، وهو عندي منكر الحديث». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «سلام ضعيف».</p><p>و‹شَرْبَ الهِيمٍ› بفتح الشين قراءة العشرة ما عدا نافعًا، وأبا جعفر، وعاصمًا، وحمزة؛ فإنهم قرؤوا: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span> بضم الشين. انظر: النشر ٢/٣٨٣، والإتحاف ص٥٢٧.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن حميد.أخرجه ابن جرير ٢٢/٣٤٣-٣٤٤ بنحوه من طريق علي، والعَوفيّ. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.يقال: ناقة طَلِيحُ أسفار إذا جَهَدَها السير وهَزَلها. لسان العرب (طلح).العِيديّة: إبل منسوبة إلى العيد، والعيد: قبيلة من مَهْرة، وإبل مَهْرة موصوفة بالنجابة. لسان العرب (رهن، عود).عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٢٥٧).عزاه السيوطي إلى سفيان بن عيينة في جامعه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٤٤.تفسير مجاهد ص٦٤٤.أخرجه ابن جرير ٢٢/٣٤٤. وعزا السيوطي إلى عبد بن حميد نحوه.تفسير الثعلبي ٩/٢١٤، وتفسير البغوي ٨/١٩.أخرجه ابن جرير ٢٢/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٣، وبنحوه من طريق خُصَيف.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢.أخرجه ابن جرير ٢٢/٣٤٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٤١-.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.أخرجه ابن جرير ٢٢/٣٤٤. وفي تفسير الثعلبي ٩/٢١٤، وتفسير البغوي ٨/١٩ عن سفيان: <span class="qpc-hafs">﴿الهِيمِ﴾</span>: الأرض السّهلة ذات الرّمل.
  56,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا نُزُلُهُمۡ یَوۡمَ ٱلدِّینِ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿هَذا نُزُلُهُمْ يَوْمَ الدِّينِ﴾</span>: كرامة يوم الحساب{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا﴾</span> الذي ذُكر مِن الزّقوم والشراب <span class="qpc-hafs">﴿نُزُلُهُمْ يَوْمَ الدِّينِ﴾</span> يعني: يوم الحساب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَحۡنُ خَلَقۡنَـٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿نَحْنُ خَلَقْناكُمْ فَلَوْلا تُصَدِّقُونَ﴾</span>، يقول: أفلا تُصدِّقون{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَحْنُ خَلَقْناكُمْ﴾</span> ولم تكونوا شيئًا وأنتم تعلمون <span class="qpc-hafs">﴿فَلَوْلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تُصَدِّقُونَ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تُمۡنُونَ ۝٥٨ ءَأَنتُمۡ تَخۡلُقُونَهُۥۤ أَمۡ نَحۡنُ ٱلۡخَـٰلِقُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</span>، يقول: هذا ماء الرجل{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</span> يعني: النُّطفة؛ الماء الدّافق، <span class="qpc-hafs">﴿أأَنْتُمْ تَخْلُقُونَهُ﴾</span> بشرًا، <span class="qpc-hafs">﴿أمْ نَحْنُ الخالِقُونَ﴾</span> له؟ بل نحن نخلقه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تُمۡنُونَ ۝٥٨ ءَأَنتُمۡ تَخۡلُقُونَهُۥۤ أَمۡ نَحۡنُ ٱلۡخَـٰلِقُونَ ۝٥٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٠١<span class="dash">-</span></span> عن حُجْر المَدَريّ، قال: بتُّ عند <span class="name-1">علِيٍّ</span>، فسمعتُه وهو يُصلّي بالليل يقرأ، فمرّ بهذه الآية: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ أأَنْتُمْ تَخْلُقُونَهُ أمْ نَحْنُ الخالِقُونَ﴾</span>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿أأنتم تزرعونه﴾</span>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</span>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿أأَنْتُمْ أنْشَأْتُمْ شَجَرَتَها﴾</span>. قال: بل أنت، يا ربّ. ثلاثًا{3}. (١٤/٢١٣)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه عبد الرزاق في مصنفه (٤٠٥٣)، والحاكم ٢/٤٧٧، والبيهقي في سننه ٢/٣١١.
  56,59,""
