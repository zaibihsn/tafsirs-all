  56,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَطُوفُ عَلَیۡهِمۡ وِلۡدَ ٰ⁠نࣱ مُّخَلَّدُونَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٦٨<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span> هم أولاد أهل الدنيا، لم يكن لهم حسنات فيُثابوا عليها، ولا سيئات فيُعاقبوا عليها؛ لأنّ الجنة لا وِلادة فيها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span>، قال: خَلَقهم الله في الجنة كما خَلَق الحُور العِين؛ لا يموتون، لا يَشِيبون، ولا يَهْرمون{2}. (١٤/٢٤٨-٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>: مُقَرَّطون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span>، قال: لا يموتون{4}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span> مُنعّمون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span>، قال: لم يكن لهم حسنات يُجْزَون بها، ولا سيئات يُعاقبون عليها، فوُضعوا في هذه المواضع{6}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span> لا يَهْرمون، ولا يَكبُرون، ولا ينقصون، ولا يتغيّرون، وليس كخَدَم الدنيا يتغيّرون مِن حال إلى حال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>:<span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ﴾</span> يعني: غِلمانٌ لا يَكبُرون <span class="qpc-hafs">﴿مُخَلَّدُونَ﴾</span> لا يموتون{8}<span class=comment-ref>٦٤٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٥</span> اختُلف في معنى: <b><span class="qpc-hafs">﴿مُخَلَّدُونَ﴾</span></b> في هذه الآية على قولين: <b>الأول:</b> أنهم وِلدان على سنٍّ واحدة، لا يتغيَّرون ولا يموتون. <b>الثاني:</b> مُقَرَّطون مُسَوَّرون. <b>الثالث:</b> مُنَعَّمون.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٢٩٥) القول الأول <span class="mustanad">مستندًا إلى اللغة</span>، وهو قول مجاهد، ومحمد بن السّائِب، ومقاتل، وعلَّل ذلك بقوله: «لأن ذلك أظهر معنييه، والعرب تقول للرجل إذا كبر ولم يَشْمَط: إنه لَمُخَلَّدٌ».</p><p>و<span class="comment-type-4">نحوه</span> قال <u>ابنُ عطية</u> (٨/١٩٤).</div></p></div>",footnotes:1:تفسير الثعلبي ٩/٢٠٤.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢٠٤، وتفسير البغوي ٨/١٠ وعقّب عليه بقوله: يقال: خلَّد جاريته إذا حلاها بالخِلْد، وهو القِرْط.تفسير مجاهد ص٦٤١، وأخرجه ابن جرير ٢٢/٢٩٥، وابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٢٠٤.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤١-. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢٠٤.تفسير مقاتل بن سليمان ٤/٢١٧.
  56,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بِأَكۡوَابࣲ وَأَبَارِیقَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿بِأَكْوابٍ﴾</span>، قال: الأكواب: الجِرار من الفِضّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿بِأَكْوابٍ وأَبارِيقَ﴾</span>: والأكواب: التي ليس لها آذان مثل الصّواع. والأباريق: التي لها الخراطيم والأعناق{2}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿بِأَكْوابٍ وأَبارِيقَ﴾</span>، قال: الأكواب: ليس لها آذان. والأباريق: التي لها آذان{3}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٧٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول: الأكواب: جِرار ليست لها عُرًى، وهي بالنَّبَطية: كوبا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الأكواب: الأقداح{5}. (١٤/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨١<span class="dash">-</span></span> عن أبي رجاء، قال: سألتُ <span class="name-2">الحسن [البصري]</span> عن الأكواب، فقال: هي الأباريق التي يُصبّ منها{6}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٢<span class="dash">-</span></span> عن ابن إدريس، قال: سمعت أبي، قال: مرَّ <span class="name-2">أبو صالح</span> صاحب الكلبي، قال: فقال أبي: قال لي الحسن وأنا جالس: سَلْه. فقلتُ: ما الأكواب؟ قال: جرار الفِضّة المستديرة أفواهها. والأباريق: ذوات الخراطيم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بِأَكْوابٍ وأَبارِيقَ﴾</span>، قال: الأكواب التي دون الأباريق ليس لها عُرًى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بِأَكْوابٍ وأَبارِيقَ﴾</span> أكواب يعني: الأكواب العظام من فِضّة، المُدوّرة الرؤوس ليس لها عُرًى ولا خراطيم، وأباريق من فِضّة في صفاء القوارير، فذلك قوله في <span class="qpc-hafs">﴿هَلْ أتى عَلى الإنْسانِ﴾</span>: <span class="qpc-hafs">﴿كانَتْ قَوارِيرا قَوارِيرَ مِن فِضَّةٍ﴾</span> [الإنسان:١٥-١٦]{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَأۡسࣲ مِّن مَّعِینࣲ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span>، قال: الخمر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span>، قال: الكأس من الخمر بعينها، ولا يكون كأسٌ حتى يكون فيها الخمر، فإذا لم يكن فيها خمر فإنما هو إناء، والمَعِين يقول: من خمرٍ جارٍ{2}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span>، قال: خمر بيضاء{12}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span>: الكأس: الخمر الجارية{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٨٩<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سفيان، وسلمة-: كلّ كأس في القرآن فهو خمر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span>، قال: يعني: الخمر، وهي هناك جارية؛ المَعين الجاري{15}. (١٤/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span> يعني: من خمر جارٍ، وكلّ مَعينٍ في القرآن فهو: جارٍ، غير الذي في <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span> يعني به: زمزم؛ <span class="qpc-hafs">﴿إنْ أصْبَحَ ماؤُكُمْ غَوْرًا فَمَن يَأْتِيكُمْ بِماءٍ مَعِينٍ﴾</span> [الملك:٣٠] يعني: ظاهرًا تَناله الدِّلاء، وكلّ شيء في القرآن كأس فهو الخمر{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٩٥.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٩٦، وابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٩٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٩٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٩٦.أخرجه عبد الرزاق ٢/٢٧٠، وابن جرير ٢٢/٢٩٦-٢٩٧، وبنحوه من طريق سعيد، وعبد بن حميد -كما في الفتح ٦/٣٢٢-.تفسير مقاتل بن سليمان ٤/٢١٧.أخرجه ابن جرير ٢٢/٢٩٧.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣)، وابن جرير ٢٢/٢٩٩-٣٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٩٨.أخرجه ابن جرير ٢٢/٢٩٨.أخرجه ابن جرير ٢٢/٢٩٧ بلفظ: من خمر جارية، ٢٢/٢٩٨ من طريق أبي هلال. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢١٧-٢١٨.
  56,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا یُصَدَّعُونَ عَنۡهَا وَلَا یُنزِفُونَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها﴾</span> عن الخمر، <span class="qpc-hafs">﴿ولا يُنْزِفُونَ﴾</span> لا تذهب بعقولهم{1}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- في قوله: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</span>، قال: لا تُصدّع رؤوسهم، ولا تُنزَف عقولهم{2}. (١٤/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٤<span class="dash">-</span></span> عن <span class="name-2">سعيد</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿ولا يُنْزِفُونَ﴾</span>، قال: لا يُغلَب أحدٌ على عقله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</span>، قال: لا تُصدّع رؤوسهم، ولا يقيئونها. وفي لفظ: ولا تُنزَف عقولهم{4}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</span>، قال: لا تُصدّع رؤوسهم، ولا تذهب عقولهم{5}. (١٤/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</span>، قال: أهل الجنة يأكلون ويشربون، ولا يُنزَفون كما يُنزَف أهل الدنيا إذا أكثروا الطعام والشراب. يقول: لا يَملّوا{6}. (١٤/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- يقول: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</span>، قال: لا تُصدّع رؤوسهم، ولا تُنزَف عقولهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</span>، قال: ليس فيها وجع الرأس، ولا يُغلَب أحدٌ على عقله{8}. (١٤/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها﴾</span> فتوجع رؤوسهم، <span class="qpc-hafs">﴿ولا يُنْزِفُونَ﴾</span> بها{9}<span class=comment-ref>٦٤٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٦</span> نقل <u>ابنُ عطية</u> (٨/١٩٤) في معنى: <b><span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها﴾</span></b> عن قوم أنّ المعنى: «لا يتفرقون عنها». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «بمعنى: لا تُقطَع عنهم لذتهم بسبب من الأسباب، كما يفرق أهل خمر الدنيا بأنواع من التفريق، وهذا كما قال: «<b>يتصدَّعُ السحاب عن المدينة</b> ...» الحديث».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٩٨-٣٠٠، وابن أبي شيبة ١٣/١٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٠٠.أخرجه ابن جرير ٢٢/٣٠٠، وابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٩٩-٣٠٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥١ (٣٠٧).أخرجه ابن جرير ٢٢/٢٩٧، ٢٩٩، ٣٠١، وبنحوه من طريق أبي هلال. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢١٨.
  56,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفَـٰكِهَةࣲ مِّمَّا یَتَخَیَّرُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وفاكِهَةٍ مِمّا يَتَخَيَّرُونَ﴾</span>، يقول: مما يشتهون{1}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفاكِهَةٍ مِمّا يَتَخَيَّرُونَ﴾</span>، يعني: يختارون مِن ألوان الفاكهة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢١٨.
  56,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَحۡمِ طَیۡرࣲ مِّمَّا یَشۡتَهُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٠٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</span> يخْطر على قلبه لحمُ الطير، فيصير مُمثّلًا بين يديه على ما اشتهى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</span>، يقول: يجيئهم الطير حتى يقع فيبسط جناحه، فيأكلون منه ما اشتَهوا نضيجًا لم تُنضجه النار، حتى إذا شبعوا منه طار، فذهب كما كان{2}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</span>، قال: لا يشتهي منها شيئًا إلا صار بين يديه، فيصيب منه حاجته، ثم يطير فيذهب{3}. (١٤/١٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</span>، يعني: من لحم الطير؛ إن شاؤوا شواء، وإن شاؤوا قديدًا، كلّ طير يَنعت نفسه لوليّ الله تعالى{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَحۡمِ طَیۡرࣲ مِّمَّا یَشۡتَهُونَ ۝٢١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٠٧<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>إنّك لَتنظر إلى الطير في الجنة، فتشتهيه، فيَخِرُّ بين يديك مشوِيًّا</b>»{5}. (١٤/١٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٨<span class="dash">-</span></span> عن ميمونة، أنّ النبيَّ ﷺ قال: «<b>إنّ الرجل لَيشتهي الطيرَ في الجنة، فيجيء مثل البُخْتيّ</b>{6} <b>حتى يقع على خِوانه، لم يُصبه دُخان، ولم تمسّه نار، فيأكل منه حتى يشبع، ثم يطير</b>»{7}. (١٤/١٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٠٩<span class="dash">-</span></span> عن أبي سعيد الخُدري، قال: قال رسول الله ﷺ: «<b>إنّ في الجنة لَطيرًا فيه سبعون ألف ريشة، فيجيء، فيقع على صَحْفة الرجل مِن أهل الجنة، فيَخرُج مِن كلّ ريشة لون أبيض مِن الثّلج، وأليَن مِن الزُّبْد، وأعذب مِن الشّهد، ليس فيه لون يشبه صاحبه، ثم يطير فيذهب</b>»{8}. (١٤/١٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٠<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>إنّ طير الجنة كأمثال البُخْت، ترعى في شجر الجنة</b>». فقال أبو بكر: يا رسول الله ﷺ، إنّ هذه الطير لَناعمة. فقال: «<b>آكِلُها أنعمُ منها، وإني لأرجو أن تكون ممن يأكل منها</b>»{9}. (١٤/١٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١١<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، قال: إنّ الرجل مِن أهل الجنة لَيشتهي الطيرَ مِن طيور الجنة، فيقع في يده مقليًّا نضيجًا{10}. (١٤/١٨٧)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/١٠.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢١٨.أخرجه ابن أبي الدنيا في صفة الجنة ص١٠٢-١٠٣ (١٠٠)، والبزار ٥/٤٠١-٤٠٢ (٢٠٣٢)، وسعيد بن منصور في سننه - التفسير ٥/٤٣٧-٤٣٨ (١١٧١).</p><p>قال العراقي في تخريج أحاديث الإحياء ص١٩٢٩: «أخرجه البزار بإسناد صحيح». وقال الهيثمي في المجمع ١٠/٤١٤ (١٨٧٣٤): «رواه البزار، وفيه حميد بن عطاء الأعرج، وهو ضعيف». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢٣٥ (٧٨٦٣): «رواه أبو يعلى الموصلي، والبزار، وابن أبي الدنيا، والبيهقي، ومدار أسانيدهم على حميد الأعرج، وهو ضعيف». وقال الألباني في الضعيفة ١٤/٦٤٠-٦٤١ (٦٧٨٤): «ضعيف جدًّا ... ووقع في تخريج الإحياء: أخرجه البزار بإسناد صحيح، فالظاهر أنه خطأ مطبعي».البُخْتي: إبل خُراسانيّة طوال الأعناق. تاج العروس (بخت).أخرجه ابن أبي الدنيا في صفة الجنة ص١١٣ (١١٩).</p><p>إسناده ضعيف؛ فيه رجل مجهول.أخرجه ابن أبي الدنيا في صفة الجنة ص١٠٤ (١٠٣)، وأبو نعيم الأصبهاني في صفة الجنة ٢/١٨١-١٨٢ (٣٤٠)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٢٣-٥٢٤-، والثعلبي ٩/٢٠٤.</p><p>قال ابن كثير: «هذا الحديث من رواية ابن أبي حاتم بسنده عن أبيه، عن علي بن محمد الطنافسي، عن أبي معاوية، عن عبيد الله بن الوليد الوصافي، عن عطية العَوفيّ، عن أبي سعيد الخدري ﵄ مرفوعًا، وهذا حديث غريب جدًّا، والوصافي وشيخه ضعيفان». وقال الألباني ١١/٤٥ (٥٠٢٦): «ضعيف».أخرجه أحمد ٢١/٣٤-٣٥ (١٣٣١١).</p><p>قال المنذري في الترغيب والترهيب ٤/٢٩٢ (٥٦٩٠): «بإسناد جيد». وقال العراقي في تخريج أحاديث الإحياء ص١٩٢٩: «بإسناد صحيح».أخرجه ابن أبي الدنيا في صفة الجنة (١١٢).
  56,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَحُورٌ عِینࣱ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩١٢<span class="dash">-</span></span> عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿حُورٌ عِينٌ﴾</span>. قال: «<b>حُور: بِيض، عِين: ضخام العيون، شَفْر الحوراء بمنزلة جَناح النّسور</b>». وفي لفظ ابن مردويه: «<b>شَفر الجُفون بمنزلة جَناح النّسر</b>»{1}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: الحُور: سُود الحَدَق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وحُورٌ عِينٌ﴾</span>، قال: الحُور: البِيض. والعين: العظام الأعين، حِسان{3}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- في قوله: <span class="qpc-hafs">﴿وحُورٌ عِينٌ﴾</span>، قال: يَحارُ فيهنّ البصرُ{4}. (١٤/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سفيان، عن رجل- <span class="qpc-hafs">﴿وحُورٌ﴾</span> قال: بِيض، <span class="qpc-hafs">﴿عِينٌ﴾</span> قال: عِظام الأعين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبادة بن منصور الناجي- يقول: الحُور: صوالح نساء بني آدم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- <span class="qpc-hafs">﴿وحُورٌ عِينٌ﴾</span>، قال: شديدة السّواد؛ سواد العين، شديدة البياض؛ بياض العين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحُورٌ﴾</span> يعني: البيضاء <span class="qpc-hafs">﴿عِينٌ﴾</span> العيناء، حِسان الأعين{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥. وعزاه السيوطي إلى ابن مردويه. وتقدم مطولًا مع تخريجه عند تفسير قوله تعالى: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> [الرحمن:٧٠].أخرجه ابن جرير ٢٢/٣٠٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٠٤، وابن أبي شيبة ١٣/٥٦٩.أخرجه ابن جرير ٢٢/٣٠٣.أخرجه ابن جرير ٢٢/٣٠٣.أخرجه ابن جرير ٢٢/٣٠٢.تفسير مقاتل بن سليمان ٤/٢١٨.
  56,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَمۡثَـٰلِ ٱللُّؤۡلُوِٕ ٱلۡمَكۡنُونِ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٢٠<span class="dash">-</span></span> عن أُمّ سلمة، قالت: قلتُ: يارسول الله، أخبِرني عن قول الله: <span class="qpc-hafs">﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</span>. قال: «<b>صفاؤهنّ كصفاء الدُّر الذي في الأصداف الذي لا تمسّه الأيدي</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</span>، قال: الذي في الصّدف لم يُجوّز على الأيدي{2}. (١٤/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿كَأَمْثالِ اللُّؤْلُؤِ﴾</span> قال: كبياض اللؤلؤ التي لم تمسّهن الأيدي ولا الدهر، <span class="qpc-hafs">﴿المَكْنُونِ﴾</span> الذي في الأصداف{3}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</span>، قال: اللؤلؤ العِظام الذي قد أُكِنّ مِن أن يمسّه شيءٌ{4}. (١٤/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</span> فشبّههم في الكنّ كأمثال اللؤلؤ المكنون في الصّدف المُطبق عليه، لم تمسّه الأيدي، ولم تَره الأعين، ولم يخْطُر على قلب بشر، كأحسن ما يكون{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠) مطولًا، وابن جرير ٢٢/٣٠٤.</p><p>قال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «رواه الطبراني، وفيه سليمان بن أبي كريمة، ضعَّفه أبو حاتم، وابن عدي».عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه هناد بن السري (٢٠).تفسير مقاتل بن سليمان ٤/٢١٨.
  56,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿جَزَاۤءَۢ بِمَا كَانُوا۟ یَعۡمَلُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَزاءً بِما كانُوا يَعْمَلُونَ﴾</span> في الدنيا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٢١٨.
  56,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَسۡمَعُونَ فِیهَا لَغۡوࣰا وَلَا تَأۡثِیمًا ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</span> قال: باطلًا. وفي قوله: <span class="qpc-hafs">﴿ولا تَأْثِيمًا﴾</span> قال:كذبًا{1}. (١٤/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</span> قال: اللغو: الحلف؛ لا والله، وبلى والله. <span class="qpc-hafs">﴿ولا تَأْثِيمًا﴾</span> قال: لا يأثمون{2}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</span>: لا يَسْتَبُّون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لغوا﴾</span> باطلًا، <span class="qpc-hafs">﴿تأثيما﴾</span> كذبًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٣٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</span>، قال: الهذْرُ من القول، والتأثيم الكذب{5}. (١٤/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَسْمَعُونَ فِيها﴾</span> يعني: في الجنة، يقول: لا يسمع في الجنة بعضهم من بعض <span class="qpc-hafs">﴿لَغْوًا﴾</span> يعني: الحلف، <span class="qpc-hafs">﴿ولا تَأْثِيمًا﴾</span> يعني: كذِبًا عند الشّراب؛ كفعل أهل الدنيا إذا شربوا الخمر{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤١.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٤-٥٠٥-.أخرجه هناد (٦).تفسير مقاتل بن سليمان ٤/٢١٨.
  56,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا قِیلࣰا سَلَـٰمࣰا سَلَـٰمࣰا ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿إلّا قِيلًا سَلامًا سَلامًا﴾</span>، يقول: التسليم منهم وعليهم، بعضهم على بعض، قال: هؤلاء المُقرّبون{1}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٣٣<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿إلّا قِيلًا سَلامًا سَلامًا﴾</span> يُحيي بعضهم بعضًا بالسلام{2}<span class=comment-ref>٦٤٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٧</span> ذكر <u>ابنُ عطية</u> (٨/١٩٧) أنّ الاستثناء في قوله تعالى: <span class="qpc-hafs">﴿إلّا قِيلًا سَلامًا سَلامًا﴾</span> استثناء متصل، ثم نقل <b>عن قوم</b>: أنه منقطع، و<span class="qpc-hafs">﴿سَلامًا﴾</span> نعت للقيل. ثم <span class="comment-type-1">وجَّهه</span> بقوله: «كأنه تعالى قال: إلا قيلًا سالمًا مِن هذه العيوب وغيرها». <b>ونقل عن الزّجّاج</b>: أنّ <span class="qpc-hafs">﴿سَلامًا﴾</span> مصدر، وناصبه <b><span class="qpc-hafs">﴿قِيلًا﴾</span></b>. ثم <span class="comment-type-1">وجَّهه</span> بقوله: «كأنه تعالى ذكر أنهم يقول بعضهم لبعض: سَلامًا سَلامًا».</div></p><p><div></p><p><p><span class="item-no">٧٤٩٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا قِيلًا سَلامًا سَلامًا﴾</span>، يعني: كثرة السلام من الملائكة. نظيرها في الرعد [٢٣-٢٤]: <span class="qpc-hafs">﴿والمَلائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِن كُلِّ بابٍ * سَلامٌ عَلَيْكُمْ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٨/١١.تفسير مقاتل بن سليمان ٤/٢١٨.
  56,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ ٱلۡیَمِینِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٣٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق زاذان- يقول: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</span>، قال: أصحاب اليمين: أطفال المؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٣٦<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن الحُبُليِّ</span> -من طريق عمرو بن لبيد- يقول: إن <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ﴾</span> هم الوِلدان{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَاۤ أَصۡحَـٰبُ ٱلۡیَمِینِ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</span> وما أعدّ لهم!{3}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</span>: أي: ماذا لهم، وماذا أعدّ لهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</span>، يقول: ما لأصحاب اليمين من الخير، ثم ذكر ما أعدّ الله لهم مِن الخير في الآخرة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَاۤ أَصۡحَـٰبُ ٱلۡیَمِینِ ۝٢٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٤٠<span class="dash">-</span></span> عن معاذ بن جبل: أنّ رسول الله ﷺ تلا هذه الآية: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</span>، <span class="qpc-hafs">﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</span>، فقبض بيديه قبضتين، فقال: «<b>هذه في الجنة ولا أبالي، وهذه في النار ولا أبالي</b>»{6}. (١٤/١٩٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٣٠٦، وعبد الرزاق ٢/٢٧٠ بلفظ: أطفال المسلمين.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٩٨ (٢٢٢).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٠٦.تفسير مقاتل بن سليمان ٤/٢١٨.أخرجه أحمد ٣٦/٣٩٥ (٢٢٠٧٧).</p><p>قال الهيثمي في المجمع ٧/١٢٠ (١١٣٩٨): «وفيه البراء بن عبد الله الغنوي، قال ابن عدي: وهو أقرب عندي إلى الصدق منه إلى الضعف، وبقية رجاله رجال الصحيح، إلا أنّ الحسن لم يسمع من معاذ».
  56,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِی سِدۡرࣲ مَّخۡضُودࣲ ۝٢٨ وَطَلۡحࣲ مَّنضُودࣲ ۝٢٩ وَظِلࣲّ مَّمۡدُودࣲ ۝٣٠﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٤١<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٢<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>: نظر المسلمون إلى وجّ -وهو وادٍ مُخصب بالطائف-، فأعجبهم سِدْرها، وقالوا: يا ليت لنا مثل هذا. فأنزل الله تعالى هذه الآية: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: كانوا يُعجبون بوَجٍّ وظِلاله؛ مِن طَلْحِه وسِدْرِه؛ فأنزل الله: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ فِي سِدْرٍ مَخْضُودٍ وطَلْحٍ مَنضُودٍ وظِلٍّ مَمْدُودٍ﴾</span>{2}. (١٤/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٤<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٥<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- قالا: لَمّا سأل أهلُ الطائف الوادي يُحمى لهم، وفيه عسل، ففعل، وهو واد مُعجِب، فسمعوا الناس يقولون: في الجنة كذا وكذا. قالوا: يا ليت لنا في الجنة مثل هذا الوادي. فأنزل الله: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ فِي سِدْرٍ مَخْضُودٍ﴾</span>{3}. (١٤/١٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی سِدۡرࣲ مَّخۡضُودࣲ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٤٦<span class="dash">-</span></span> عن أبي أُمامة، قال: كان أصحاب رسول الله ﷺ يقولون: إنّ الله ينفعنا بالأعراب ومسائلهم. أقبل أعرابيٌّ يومًا، فقال: يا رسول الله، لقد ذكر الله في القرآن شجرةً مُؤذية، وما كنتُ أرى أنّ في الجنة شجرة تؤذي صاحبها! فقال رسول الله ﷺ: «<b>وما هي؟</b>». قال: السِّدر؛ فإنّ لها شوكًا. فقال رسول الله ﷺ: «<b>أليس يقول: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>؟! يُخَضِّد الله شوكه، فيجعل مكان كلّ شوكة ثمرة، فإنها تُنبتُ ثمرًا، تُفْتقُ الثمرة منها عن اثنين وسبعين لونًا من الطعام، ما منها لون يشبه الآخر</b>»{4}. (١٤/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٧<span class="dash">-</span></span> عن عُتبة بن عبد الله السّلميّ، قال: كنتُ جالسًا مع النبيِّ ﷺ، فجاء أعرابيٌّ، فقال: يا رسول الله، أسْمَعُكَ تذكرُ في الجنة شجرةً لا أعلم شجرةً أكثر شوكًا منها. يعني: الطّلح، فقال رسول الله ﷺ: «<b>إنّ الله يجعل مكان كلّ شوكة منها ثمرة مثل خُصْية التَّيْس المَلْبُود</b>{5}» يعني: الخصِيّ منها «<b>فيها سبعون لونًا من الطعام لا يشبه لون الآخر</b>»{6}. (١٤/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: خَضَده وِقرُه من الحَمْل{7}. (١٤/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: المخضود؛ الذي لا شوك فيه{8}. (١٤/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: المخضود: المُوقر الذي لا شوك فيه{9}. (١٤/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>. قال: الذي ليس له شوك. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول أُميّة بن أبي الصّلت:</p><p>إنّ الحدائق في الجنان ظَليلة فيها الكواعب سِدرها مخضود؟{10}. (١٤/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>: والمخضود: المُوقر الذي لا شوك فيه{11}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٣<span class="dash">-</span></span> عن <span class="name-2">أبي الأَحْوص [عوف بن مالك بن نضلة الأشجعي]</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: لا شوك له{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٤<span class="dash">-</span></span> عن <span class="name-2">قَسامة بن زهير</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: خُضِد من الشوك، فلا شوك فيه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء بن السّائِب- <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: ثمرها أعظم من القِلال{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سدر مخضود﴾</span>، قال: المُوقَر حملًا{15}. (١٤/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿سِدْرٍ مَخْضُودٍ﴾</span>، يقول: مُوقَر{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿وسدر مخضود﴾</span>، قال: المواقير؛ لا شوك فيه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٥٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حبيب بن أبي ثابت، ومهران- قوله: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: لا شوك فيه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span> لا يعقر الأيدي{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿سِدْرٍ مَخْضُودٍ﴾</span>، قال: كثير الحمل، ليس له شوك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٢<span class="dash">-</span></span> عن <span class="name-2">يزيد الرّقاشي</span>، <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: نبْقها أعظم من القِلال{21}. (١٤/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿سدر مخضود﴾</span>، قال: ليس فيه شوك{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٤<span class="dash">-</span></span> عن <span class="name-3">السَّفْر بن نُسَير</span> -من طريق عمر بن عمرو بن عبد الأحموسيّ- في قول الله ﷿: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، قال: خُضِد شوكه؛ فلا شوك فيه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span>، يعني: الذي لا شوك له كسِدر أهل الدنيا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span> هو المُوقَر حملًا{25}<span class=comment-ref>٦٤٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٨</span> اختُلف في معنى «السدر المخضود» على قولين: <b>الأول:</b> هو الذي لا شوك فيه. <b>الثاني:</b> هو الموقَر حَمْلًا.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/١٩٧) القول الأول، وهو قول ابن عباس من طريق علي بن أبي طلحة وما في معناه، فقال: «وهو الصواب». و<span class="comment-type-4">لم يذكر مستندًا</span>.</p><p>وذكر <u>ابنُ القيم</u> (٣/١٠٩) أنّ أصحاب القول الأول احتجوا بحجتين: «<b>أحدهما</b>: أنّ الخَضد في اللغة: القطع، وكلّ رطب قضبته فقد خَضدته، وخضدت الشجر إذا قطعت شوكه، فهو خضيد ومخضود، ومنه الخضد على مثال الثمر، وهو كلّ ما قطع من عود رطب خضد بمعنى: مخضود كقبض وسلب، والخضاد شجر رخو لا شوك له». و<b>الثانية</b>: استشهادهم بحديث أبي أمامة، وعتبة بن عبد الله السلمي الواردين في تفسير الآيات، ثم ذكر بأنّ أصحاب القول الثاني أُنكِر عليهم قولهم بأنه «لا يُعرف في اللغة الخضد بمعنى: الحمل». ثم <span class="comment-type-2">استدرك</span> على إنكارهم بقوله: «ولم يُصب هؤلاء الذين أنكروا هذا القول، بل هو قول صحيح وأربابه ذهبوا إلى أنّ الله لما خضد شوكه وأذهبه، وجعل مكان كلّ شوكة ثمرة أُوقرت بالحمل، والحديثان المذكوران يجمعان القولين. وكذلك قول من قال المخضود: الذي لا يعقر اليد، ولا يرد اليد عنه شوك ولا أذًى فيه. فسّره بلازم المعنى، وهكذا غالب المفسرين يذكرون لازم المعنى المقصود تارة، وفردًا مِن أفراده تارة، ومثالًا من أمثلته، فيحكيها الجمّاعون للغثّ والسمين أقوالًا مختلفة، ولا اختلاف بينها».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٣٦٣) على القولين بقوله: «والظاهر أن المراد هذا وهذا، فإنّ سِدر الدنيا كثير الشوك قليل الثمر، وفي الآخرة على العكس من هذا لا شوك فيه، وفيه الثمر الكثير الذي قد أثقل أصله».</div></p><p><h3><span class="qpc-hafs">﴿وَطَلۡحࣲ مَّنضُودࣲ ۝٢٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٦٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق سعد- أنه قرأ: (وطَلْعٍ مَّنضُودٍ){26}<span class=comment-ref>٦٤٢٩</span>. (١٤/١٩٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٩</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ كثير</u> (١٣/٣٦٤) قراءة علي بن أبي طالب ﵄ بقوله: «فعلى هذا يكون هذا من صفة السدر، فكأنه وصفه بأنه مخضود، وهو الذي لا شوك له، وأنّ طلعه منضود، وهو كثرة ثمره».</div></p><p><div></p><p><p><span class="item-no">٧٤٩٦٨<span class="dash">-</span></span> عن قيس بن عباد، قال: قرأتُ على <span class="name-1">علي</span>: <span class="qpc-hafs">﴿وطَلْحٍ مَّنضُودٍ﴾</span>. فقال علي: ما بال الطّلح؟! أما تقرأ: (وطَلْعٍ)؟! ثم قال: <span class="qpc-hafs">﴿لَها طَلْعٌ نَّضِيدٌ﴾</span> [ق:١٠]. فقيل له: يا أمير المؤمنين، أنحكّها من المصحف؟ فقال: لا يُهاج القرآن اليوم{27}. (١٤/١٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَطَلۡحࣲ مَّنضُودࣲ ۝٢٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٦٩<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الحسن بن سعد- في قوله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: هو المَوْز{28}<span class=comment-ref>٦٤٣٠</span>. (١٤/١٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (٣/١١٠) على قول علي بن أبي طالب ﵄ وما في معناه بقوله: «والظاهر أنّ مَن فسّر الطّلح المنضود بالموز إنما أراد التمثيل به؛ لحُسن نضده، وإلا فالطّلح في اللغة: هو الشجر العظام من شجر البوادي».</div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٠<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: هو المَوْز{29}. (١٤/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي سعيد الرّقاشي- <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: المَوْز{30}. (١٤/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿منضود﴾</span>، قال: بعضه على بعض{31}. (١٤/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٣<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span>، <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: المَوْز{32}. (١٤/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٤<span class="dash">-</span></span> عن <span class="name-2">قسامة [بن زهير]</span> -من طريق عوف- قال: الطلح المنضود: هو المَوْز{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>: يعني: المَوْز المتراكم{34}. (١٤/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: مَوزكم؛ لأنهم كانوا يُعجبون بوجّ؛ وظِلاله مِن طَلْحه وسِدره{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: المَوْز {9}. (١٤/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span> ليس هو مَوزًا، ولكنه شجر له ظِل بارد طيّب{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٧٩<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: المَوْز{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: المَوْز{39}.(١٤/١٩٢) (١٤/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، يعني: المتراكب بعضه فوق بعض. نظيرها: <span class="qpc-hafs">﴿لَها طَلْعٌ نَضِيدٌ﴾</span> [ق:١٠] يعني: المنضود{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٢<span class="dash">-</span></span> عن ابن وهب، قال: قال لي <span class="name-3">مالك [بن أنس]</span>، في قول الله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: سمعتُ أنه المَوْز. قال مالك: وأنا أرى أن بعض العرب تُسمّيه: الطّلح{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ﴾</span>، قال: الله أعلم، إلا أنّ أهل اليمن يُسمّون المَوْز: الطّلح{31}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَظِلࣲّ مَّمۡدُودࣲ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٨٤<span class="dash">-</span></span> عن أبي هريرة، عن النبيّ ﷺ، قال: «<b>إنّ في الجنة شجرة يسير الراكب في ظِلّها مائة عام لا يقطعها، اقرءوا إن شئتم: <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span></b>»{43}. (١٤/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٥<span class="dash">-</span></span> عن أبي سعيد الخُدري، قال: قال رسول الله ﷺ: «<b>في الجنة شجرة يسير الراكب في ظِلّها مائة عام لا يقطعها، وذاك الظّل الممدود</b>»{44}. (١٤/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٦<span class="dash">-</span></span> عن أنس بن مالك، أنّ النبيَّ ﷺ، قال: «<b>إنّ في الجنة لَشجرة يسير الراكب في ظِلها مائة عام لا يقطعها، وإن شئتم فاقرءوا: <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ*وماءٍ مَسْكُوبٍ﴾</span></b>»{45}. (١٤/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٧<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق زياد مولى بني مخزوم- قال: إنّ في الجنة لَشجرةً يسيرُ الراكبُ في ظلِّها مائة عامٍ لا يقطعها، واقرءوا إن شئتُم: <span class="qpc-hafs">﴿وظلٍ مَّمدود﴾</span>. فبلغ ذلك <span class="name-2">كعبًا</span>، فقال: صدق، والذي أنزل التوراة على موسى والفرقان على محمدٍ، لو أنّ رجلًا ركب حقَّةً أو جذعةً ثم دار بأصل تلك الشجرة ما بلغها حتى يسقط هَرِمًا، إن الله ﷿ غرسها بيده، ونفخ فيها من روحه، وإنّ أفنانها مِن وراء سُور الجنة، وما في الجنة نهرٌ إلا يخرُجُ من أصل تلك الشجرة{46}. (٨/٤٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الظِلّ الممدود: شجرة في الجنة على ساق، ظِلّها قدر ما يسير الراكب في كلّ نواحيها مائة عام، فيخرج إليها أهل الجنة؛ أهل الغُرف وغيرهم، فيتحدّثون في ظِلّها، فيشتهي بعضهم، ويذكر لهو الدنيا، فيُرسل الله ريحًا من الجنة، فتحرَّك تلك الشجرة بكلّ لهو في الدنيا{47}. (١٤/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span>، يقول: ظِلّ الجنة لا ينقطع، ممدود عليهم أبدًا{11}. (١٤/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٠<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون الأَودي</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span>، قال: مسيرة سبعين ألف سنة{49}. (١٤/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩١<span class="dash">-</span></span> عن شعيب بن الحَبْحاب، قال: خرجتُ أنا و<span class="name-2">أبو العالية الرِّياحيّ</span>، فلما كُنّا بالجبال، وذلك قبل طلوع الشمس، قال: نبّئتُ أنّ الجنة هكذا. ثم تلا: <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span>{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٢<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span>، يعني: ظِلّ العرش{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وظِلٍّ مَمْدُودٍ﴾</span> دائم لا يزول، لا شمس فيه كمثل ما يزول الظِّل في الدنيا{52}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَظِلࣲّ مَّمۡدُودࣲ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٩٤<span class="dash">-</span></span> عن أبي هريرة، عن النبيِّ ﷺ، قال: «<b>إنّ حائط الجنة لَبِنة من ذهب، ولَبِنة من فِضّة، وقاع الجنة ذهب، ورَضْراضُها</b>{53} <b>اللؤلؤ، وطينها مسك، وتُرابها الزّعفران، وخلال ذلك سِدر مخضود، وطلح منضود، وظِلٍّ ممدود، وماء مسكوب</b>»{11}. (١٤/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٥<span class="dash">-</span></span> عن أبي هريرة، يقول: قال رسول الله ﷺ: «<b>إنّ في الجنة لَشجرة يسير الراكب في ظِلّها مائة عام لا يقطعها؛ شجرة الخُلد</b>»{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: في الجنة شجر لا يَحمل يُستظلّ به{56}. (١٤/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٧<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق قتادة- قال: إنّ في الجنة لَشجرة يسير الراكب في ظِلّها مائة عام لا يقطعها{57}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/٢٠٦، وتفسير البغوي ٨/١١. وعلقه الواحدي في أسباب النزول (ت: الفحل) ص٦٣٧.أخرجه ابن جرير ٢٢/٣١١-٣١٣، والبيهقي (٣٠٤). وعزاه السيوطي إلى عبد بن حميد.أخرجه البيهقي في البعث (٣٠٣). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه الحاكم ٢/٥١٨ (٣٧٧٨)، من طريق صفوان بن عمرو، عن سليم بن عامر، عن أبي أمامة.</p><p>قال الحاكم: «صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي.</p><p>وأخرجه ابن أبي الدنيا في صفة الجنة ٦/٣٤٣ (١٠٨) من مرسل سليم بن عامر.المَلْبُود: المُكْتَنِز اللحم، الذي لزم بعضه بعضًا فتلبّد. النهاية (لبد).أخرجه الطبراني في الكبير ١٧/١٣٠ (٣١٨)، وأبو نعيم الأصبهاني في صفة الجنة ٢/١٨٨-١٨٩ (٣٤٧).</p><p>قال الهيثمي في المجمع ١٠/٤١٤ (١٨٧٣٠): «رواه الطبراني، ورجاله رجال الصحيح». وأورده الألباني في الصحيحة ٦/٥٢٥ (٢٧٣٤).أخرجه ابن جرير ٢٢/٣٠٧. ونخلة مُوقَرة: إذا كثر حملها، والحمل: ثمر الشجرة. اللسان (وقر، حمل).أخرجه ابن جرير ٢٢/٣٠٧-٣١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه الطستي -كما في الإتقان ٢/٨٨-.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٠٨.أخرجه ابن جرير ٢٢/٣٠٧.أخرجه ابن جرير ٢٢/٣٠٩.تفسير مجاهد ص٦٤١، وأخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٣-، وهناد (١٠٨)، وابن جرير ٢٢/٣٠٨، والبيهقي في البعث (٣٠٤). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٠٩.أخرجه هناد في الزهد ١/٩٣.أخرجه ابن جرير ٢٢/٣٠٧-٣٠٨.تفسير الثعلبي ٩/٢٠٦، وتفسير البغوي ٨/١١.أخرجه عبد الرزاق ٢/٢٧٠، وابن جرير ٢٢/٣٠٨، بنحوه من طريق سعيد، وأبي هلال.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٠.أخرجه ابن جرير ٢٢/٣٠٧.تفسير مقاتل بن سليمان ٤/٢١٨.تفسير الثعلبي ٩/٢٠٦.أخرجه ابن جرير ٢٢/٣٠٩، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤-. وعزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة، وقراءة العشرة: <span class="qpc-hafs">﴿وطَلْحٍ مَّنضُودٍ﴾</span>. انظر: مختصر ابن خالويه ص١٥١.أخرجه ابن جرير ٢٢/٣٠٩-٣١٠، وابن الأنباري في المصاحف -كما في تفسير القرطبي ١٧/٢٠٨-٢٠٩-. وقال ابن الأنباري: «ومعنى هذا أنه رجع إلى ما في المصحف وعلم أنه الصواب، وأبطل الذي كان فرط من قوله». تفسير القرطبي ١٧/٢٠٩.أخرجه عبد الرزاق ٢/٢٧٠، وهناد (١١٢)، وابن جرير ٢٢/٣١١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه هناد (١١١)، والحربي في غريب الحديث ٢/٦٣١، وابن جرير ٢٢/٣١٠-٣١١، ومن طريق أبي بشر أيضًا. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣١٢.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٣١١.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٣-، وهناد (١٠٨)، وابن جرير ٢٢/٣١٣، والبيهقي في البعث (٣٠٤). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٢، وأخرجه ابن جرير ٢٢/٣١١-٣١٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٩-.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢٠٦، وتفسير البغوي ٨/١٢.أخرجه ابن جرير ٢٢/٣١١.أخرجه عبد الرزاق ٢/٢٧٠، وابن جرير ٢٢/٣١٢، وبمثله من طريق سعيد، وأبي هلال. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢١٨.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٣٣ (٢٦٢).أخرجه ابن جرير ٢٢/٣١٢.أخرجه البخاري ٤/١١٩ (٣٢٥٢)، ٦/١٤٦ (٤٨٨١) واللفظ له، ومسلم ٤/٢١٧٥ (٢٨٢٦)، وابن جرير ٢٢/٣١٣.أخرجه الترمذي ٤/٤٩٥ (٢٦٩٣).</p><p>قال الترمذي: «هذا حديث حسن غريب من حديث أبي سعيد».أخرجه البخاري ٤/١١٩ (٣٢٥١)، والترمذي ٥/٤٨٦-٤٨٧ (٣٥٧٧)، واللفظ له.</p><p>قال الترمذي: «هذا حديث حسن صحيح».أخرجه ابن جرير ٢٢/٣١٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٦-. وعزاه السيوطي إلى ابن مردويه.</p><p>قال ابن كثير: «هذا أثر غريب، وإسناده جيد قوي حسن».عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣١٤، وابن أبي الدنيا في صفة الجنة ٦/٣٣٣ (٦٤). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٢-.تفسير الثعلبي ٩/٢٠٧.تفسير مقاتل بن سليمان ٤/٢١٩.الرَّضْراض: الحصى الصغار. النهاية (رَضْرَضَ).عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ١٦/٣٤ (٩٩٥٠)، والدارمي في سننه ٢/٤٣٦ (٢٨٣٩)، وابن جرير ٧/١٦٨، ٢٢/٣١٤-٣١٥.</p><p>في إسناده أبو الضَّحّاك الراوي عن أبي هريرة، قال أبو حاتم كما في الجرح والتعديل ٩/٣٩٥ (١٨٧٧): «أبو الضَّحّاك هذا لا أعلم روى عنه غير شعبة». قال أحمد شاكر في عمدة التفسير ١/٥٢٦: «أصل الحديث ثابت من أوجه كثيرة دون زيادة شجرة الخلد».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٧-.أخرجه ابن جرير ٢٢/٣١٧.
