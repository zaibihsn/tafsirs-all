  35,44,""
  35,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ یُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِمَا كَسَبُوا۟ مَا تَرَكَ عَلَىٰ ظَهۡرِهَا مِن دَاۤبَّةࣲ وَلَـٰكِن یُؤَخِّرُهُمۡ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّىۖ فَإِذَا جَاۤءَ أَجَلُهُمۡ فَإِنَّ ٱللَّهَ كَانَ بِعِبَادِهِۦ بَصِیرَۢا ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٢٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: إن كان الجُعَلُ لَيُعَذَّبُ في جحره من ذنب ابن آدم. ثم قرأ: <span class="qpc-hafs">﴿ولَوْ يُؤاخِذُ اللَّهُ النّاسَ بِما كَسَبُوا ما تَرَكَ عَلى ظَهْرِها مِن دابَّةٍ ولَكِنْ يُؤَخِّرُهُمْ﴾</span> الآية{1}. (١٢/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَكِنْ يُؤَخِّرُهُمْ إلى أجَلٍ مُسَمًّى فَإذا جاءَ أجَلُهُمْ فَإنَّ اللَّهَ كانَ بِعِبادِهِ بَصِيرًا﴾</span>، يريد: أهل طاعته، وأهل معصيته{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَوْ يُؤاخِذُ اللَّهُ النّاسَ بِما كَسَبُوا ما تَرَكَ عَلى ظَهْرِها مِن دابَّةٍ﴾</span>، قال: قد فعل ذلك بهم في زمان نوح؛ فأهلك ما على ظهرها مِن دابة، إلا ما حمل نوح في السفينة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٣<span class="dash">-</span></span> قال <span class="name-2">أبو حمزة الثمالي</span>، في هذه الآية: يحبس المطر، فيهلك كل شيء{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوْ يُؤاخِذُ اللَّهُ النّاسَ﴾</span> كفار مكة <span class="qpc-hafs">﴿بِما كَسَبُوا﴾</span> من الذنوب، وهو الشرك <span class="qpc-hafs">﴿ما تَرَكَ عَلى ظَهْرِها مِن دابَّةٍ﴾</span> لعجل لهم العقوبة <span class="qpc-hafs">﴿ما تَرَكَ عَلى ظَهْرِها مِن دابَّةٍ﴾</span> فوق الأرض من دابة، لهلكت الدواب من قحط المطر، <span class="qpc-hafs">﴿ولَكِنْ يُؤَخِّرُهُمْ إلى أجَلٍ مُسَمًّى﴾</span> إلى الوقت الذي في اللوح المحفوظ، <span class="qpc-hafs">﴿فَإذا جاءَ أجَلُهُمْ﴾</span> وقت نزول العذاب بهم في الدنيا <span class="qpc-hafs">﴿فَإنَّ اللَّهَ كانَ بِعِبادِهِ بَصِيرًا﴾</span> لم يزل الله ﷿ بعباده بصيرًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَوْ يُؤاخِذُ اللَّهُ النّاسَ بِما كَسَبُوا﴾</span> بما عملوا <span class="qpc-hafs">﴿ما تَرَكَ عَلى ظَهْرِها مِن دابَّةٍ﴾</span> لحبس عنهم القطر، فهلك ما في الأرض من دابة، <span class="qpc-hafs">﴿ولَكِنْ يُؤَخِّرُهُمْ﴾</span> يعني: المشركين <span class="qpc-hafs">﴿إلى أجَلٍ مُسَمًّى﴾</span> الساعة؛ بها يكون هلاك كفار آخر هذه الأمة، <span class="qpc-hafs">﴿فَإذا جاءَ أجَلُهُمْ﴾</span> الساعة <span class="qpc-hafs">﴿فَإنَّ اللَّهَ كانَ بِعِبادِهِ بَصِيرًا﴾</span>{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٤٢٨، والطبراني (٩٠٤٠)، وأخرجه عبد الرزاق ٢/١٣٧ بنحوه من طريق معمر. وعزاه السيوطي إلى الفريابي، وابن المنذر.تفسير البغوي ٧/٤٢٧.أخرجه ابن جرير ١٩/٣٩٧، وأخرجه عبد الرزاق ٢/١٣٧ من طريق معمر مختصرًا.تفسير الثعلبي ٨/١١٧.تفسير مقاتل بن سليمان ٣/٥٦٢.تفسير يحيى بن سلام ٢/٧٩٧-٧٩٨.
  36,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٦٤٢٧٦<span class="dash">-</span></span> عن عائشة، قالت: نزلت سورة يس بمكة{1}. (١٢/٣١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة يس بمكة{2}. (١٢/٣١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، وذكرها باسم «يس والقرآن»، وأنها نزلت بعد <span class="qpc-hafs">﴿قل أوحي﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٧٩<span class="dash">-</span></span> عن عكرمة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٠<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨١<span class="dash">-</span></span> عن قتادة -من طرق-: مكية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٢<span class="dash">-</span></span> عن محمد بن مسلم الزهري: مكية، ونزلت بعد سورة الجن{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٤<span class="dash">-</span></span> قال مقاتل بن سليمان: مكية، عدد آياتها ثلاث وثمانون آية كوفية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٥<span class="dash">-</span></span> قال يحيى بن سلّام: سورة يس مكية كلها{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه النحاس (٦٣٧) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في الدلائل ٧/١٤٢-١٤٤ من طريق خصيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل ٣/٥٧١.تفسير يحيى بن سلام ٢/٧٩٩.
  36,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یسۤ ۝١ وَٱلۡقُرۡءَانِ ٱلۡحَكِیمِ ۝٢﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٦٤٢٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كان النبيُّ ﷺ يقرأ في المسجد، فيجهر بالقراءة، حتى تأذّى به ناسٌ مِن قريش، حتى قاموا ليأخذوه، وإذا أيديهم مجموعةٌ إلى أعناقهم، وإذا هم عُمْيٌ لا يبصرون، فجاءوا إلى النبي ﷺ، فقالوا: ننشدك اللهَ والرحمَ، يا محمد. قال: ولم يكن بطنٌ مِن بطون قريش إلا وللنبيِّ ﷺ فيهم قرابة، فدعا النبيُّ ﷺ حتى ذهب ذلك عنهم؛ فنزلت: <span class="qpc-hafs">﴿يس * والقُرْآنِ الحَكِيمِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿أمْ لَمْ تُنْذِرْهُمْ لا يُؤْمِنُونَ﴾</span>. قال: فلم يؤمن مِن ذلك النفر أحدٌ{1}. (١٢/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والقُرْآنِ الحَكِيمِ﴾</span> وذلك أن أُبَيَّ بن خلف الجمحي قال للنبي ﷺ: ما أرسل الله إلينا رسولًا، وما أنت برسول. وتابعه كفار مكة على ذلك؛ فأقسم الله ﷿ بالقرآن الحكيم، يعني: المحكم من الباطل: <span class="qpc-hafs">﴿إنَّكَ﴾</span> يا محمد <span class="qpc-hafs">﴿لَمِنَ المُرْسَلِينَ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یسۤ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٢٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: يا محمد{3}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿يس﴾</span> محمد ﷺ. وفي لفظ، قال: يا محمد{3}. (١٢/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: فإنّه قسم أقسمه الله، وهو من أسماء الله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: يا إنسان، بالحَبَشِيَّة{6}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: يا إنسان{7}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، في قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: هذا قَسَمٌ أقسم به ربُّك، قال: يا محمد، <span class="qpc-hafs">﴿إنك لمن المرسلين﴾</span> قبل أن أخلقَ الخلقَ بألفي عام{3}. (١٢/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن الحنفية</span>، في قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: محمد ﷺ{9}<span class=comment-ref>٥٣٩١</span>. (١٢/٣١٩-٣٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٩١</span> <span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٢/٣٥٦): «الصحيح أن <span class="qpc-hafs">﴿يس﴾</span> بمنزلة <span class="qpc-hafs">﴿حم﴾</span> و<span class="qpc-hafs">﴿ألم﴾</span>، وليست اسمًا من أسماء النبي ﷺ».</div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٥<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرياحي</span>: <span class="qpc-hafs">﴿يس﴾</span> يا رجل{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: يا رجل، بلغة الحبشة{11}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: <span class="qpc-hafs">﴿يس﴾</span> يا محمد{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿يس﴾</span>: مفتاح كلام، افتتح الله به كلامه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٢٩٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿يس﴾</span>: يا محمد{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق شرقي- <span class="qpc-hafs">﴿يس﴾</span>، قال: يا إنسان{15}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٢<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، مثله{16}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله <span class="qpc-hafs">﴿يس﴾</span>، قال: يا إنسان، بالحبشية{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يس﴾</span>، قال: كل هجاء في القرآن اسمٌ مِن أسماء القرآن{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عثمان- قال: <span class="qpc-hafs">﴿يس﴾</span> يا إنسان، والسين حرف من اسم الإنسان، يقول النبي ﷺ: يا إنسان{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يس﴾</span>، يعني ﷿: النبيَّ ﷺ، يقول: يا إنسان، بلغة طيئ{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٧<span class="dash">-</span></span> عن أشهب، قال: سألتُ <span class="name-3">مالك بن أنس</span>: أينبغي لأحدٍ أن يَتَسَمّى بـ<span class="qpc-hafs">﴿يس﴾</span>؟ فقال: ما أراه ينبغي؛ يقول الله: <span class="qpc-hafs">﴿يس * والقُرْآنِ الحَكِيمِ﴾</span>. يقول: هذا اسمي، تسمَّيتُ به{11}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣٠٨<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- قوله: <span class="qpc-hafs">﴿يس﴾</span> يا إنسان{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو نعيم في دلائل النبوة ١/١٩٩-٢٠٠ (١٥٣)، من طريق النضر بن عبد الرحمن أبي عمرو الخزاز، عن عكرمة، عن ابن عباس به.</p><p>إسناده ضعيف جدًّا؛ فيه النضر بن عبدالرحمن الخزاز، قال عنه ابن حجر في التقريب (٧١٤٤): «متروك».تفسير مقاتل بن سليمان ٣/٥٧٣.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/٣٩٨.أخرجه ابن جرير ١٩/٣٩٨. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/٣٩٨ بنحوه. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في الدلائل ١/١٥٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير الثعلبي ٨/١٢٠، وتفسير البغوي ٧/٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٨/١٢٠.أخرجه سفيان الثوري (٢٤٨)، وإسحاق البستي ص١٧٨، وابن جرير ١٩/٣٩٩.أخرجه سفيان الثوري (٢٤٨).أخرجه ابن جرير ١٩/٣٩٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص١٧٩.أخرجه ابن جرير ١٩/٣٩٩، كما أخرجه عبد الرزاق ٢/١٣٩ من طريق معمر بنحوه.أخرجه يحيى بن سلام ٢/٧٩٩.تفسير مقاتل بن سليمان ٣/٥٧٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي ص١٧٨.
  36,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡقُرۡءَانِ ٱلۡحَكِیمِ ۝٢ إِنَّكَ لَمِنَ ٱلۡمُرۡسَلِینَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٣٠٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿يس * والقُرْآنِ الحَكِيمِ﴾</span>، قال: يُقسم اللهُ بما يشاء. ثم نزع بهذه الآية: <span class="qpc-hafs">﴿سَلامٌ عَلى إلْ ياسِينَ﴾</span> [الصافات:١٣٠]، كأنّه يرى أنّه سلَّم على رسوله{1}. (١٢/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يس * والقُرْآنِ الحَكِيمِ * إنَّكَ لَمِنَ المُرْسَلِينَ﴾</span>، قال: قَسَمٌ، كما تسمعون{2}. (١٢/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣١١<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي كثير</span>، في قوله: <span class="qpc-hafs">﴿يس * والقُرْآنِ الحَكِيمِ﴾</span> قال: يُقْسِمُ بألفِ عالم، <span class="qpc-hafs">﴿إنَّكَ لَمِنَ المُرْسَلِينَ﴾</span>{1}. (١٢/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والقُرْآنِ الحَكِيمِ﴾</span>... فأقسم الله ﷿ بالقرآن الحكيم، يعني: المحكم مِن الباطل، <span class="qpc-hafs">﴿إنَّكَ﴾</span> يا محمد <span class="qpc-hafs">﴿لَمِنَ المُرْسَلِينَ﴾</span>{4}<span class=comment-ref>٥٣٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٩٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٣٣): «و<span class="qpc-hafs">﴿الحَكِيمِ﴾</span>: المحكم، فيكون بمعنى مفعول، أي: أُحكم في مواعظه وأوامره ونواهيه، ويحتمل أن يكون <span class="qpc-hafs">﴿الحَكِيمِ﴾</span> بناء فاعل، أي: ذو الحكمة».</div></p><p><div></p><p><p><span class="item-no">٦٤٣١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والقُرْآنِ الحَكِيمِ﴾</span>: المُحكَم، <span class="qpc-hafs">﴿إنَّكَ لَمِنَ المُرْسَلِينَ﴾</span> أقسم للنبي ﵇{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٣٩٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٧٣.تفسير يحيى بن سلام ٢/٧٩٩.
  36,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٤ تَنزِیلَ ٱلۡعَزِیزِ ٱلرَّحِیمِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٣١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لَمِنَ المُرْسَلِينَ * عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> أي: على الإسلام، <span class="qpc-hafs">﴿تَنْزِيلَ العَزِيزِ الرَّحِيمِ﴾</span> قال: هو القرآن{1}. (١٢/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلى صِراطٍ﴾</span> على طريق <span class="qpc-hafs">﴿مُسْتَقِيمٍ﴾</span> دين الإسلام؛ لأنّ غير دين الإسلام ليس بمستقيم. ثم قال: هذا القرآن هو <span class="qpc-hafs">﴿تَنْزِيلَ﴾</span> من <span class="qpc-hafs">﴿العَزِيزِ﴾</span> في مُلكه، <span class="qpc-hafs">﴿الرَّحِيمِ﴾</span> بخلْقه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٣١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> على دين مستقيم، والصراط: الطريق المستقيم إلى الجنة، <span class="qpc-hafs">﴿تَنْزِيلَ العَزِيزِ الرَّحِيمِ﴾</span> يعني: القرآن هو تنزيل العزيز الرحيم، نزل مع جبريل على محمد ﷺ{3}<span class=comment-ref>٥٣٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٩٣</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٩/٤٠٠): «وفي قوله: <span class="qpc-hafs">﴿على صراط مستقيم﴾</span> وجهان: <b>أحدهما</b>: أن يكون معناه: إنك لمن المرسلين على استقامة من الحق. فيكون حينئذ <span class="qpc-hafs">﴿على﴾</span> من قوله: <span class="qpc-hafs">﴿على صراط مستقيم﴾</span> من صلة الإرسال. <b>والآخر</b>: أن يكون خبرًا مبتدأ، كأنه قيل: إنك لمن المرسلين، إنك على صراط مستقيم».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٠٠ مقتصرًا على شطره الأول. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٥٧٣.تفسير يحيى بن سلام ٢/٧٩٩.
  36,5,""
