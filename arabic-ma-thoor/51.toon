  51,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ مَاۤ أَتَى ٱلَّذِینَ مِن قَبۡلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوۡ مَجۡنُونٌ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿ما أتى الَّذِينَ مِن قَبْلِهِمْ﴾</span> يعني: الأمم الخالية <span class="qpc-hafs">﴿مِن رَسُولٍ إلّا قالُوا﴾</span> لرسولهم: هو <span class="qpc-hafs">﴿ساحِرٌ أوْ مَجْنُونٌ﴾</span> كقول كُفّار مكة لمحمد ﷺ{1}<span class=comment-ref>٦٢١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٩</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٨١): «وقوله تعالى: <span class="qpc-hafs">﴿كذلك﴾</span> تقديره: سيرة الأمم كذلك، أو الأمر في القديم كذلك. وقوله: <span class="qpc-hafs">﴿إلا قالوا ساحر أو مجنون﴾</span> معناه: إلا قال بعض هذا، وبعض الجميع، ألا ترى أنّ قوم نوح لم يقولوا قط: ساحر. وإنما قالوا: <span class="qpc-hafs">﴿به جنة﴾</span> [سبأ:٨]! فلما اختلف الفرق جعل الخبر عن ذلك بإدخال <span class="qpc-hafs">﴿أو﴾</span> بين الصفتين، وليس المعنى أنّ كلّ أمة قالت عن نبيها: إنه ساحر أو هو مجنون، فليست هذه كالمتقدمة في فرعون، بل هذه كأنه قال: إلا قالوا: هو ساحر، وهو مجنون».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣٣.
  51,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَتَوَاصَوۡا۟ بِهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أتَواصَوْا بِهِ﴾</span>، قال: هل أوصى الأوّلُ الآخرَ منهم بالتكذيب؟!{1}. (١٣/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أتَواصَوْا بِهِ﴾</span> يقول: أوصى الأولُ الآخرَ أن يقولوا ذلك لرسلهم؟! ثم قال: <span class="qpc-hafs">﴿بَلْ هُمْ قَوْمٌ طاغُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلۡ هُمۡ قَوۡمࣱ طَاغُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٥١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿بَلْ هُمْ قَوْمٌ طاغُونَ﴾</span> حمَلهم الطغيانُ فيما أعطَيتهم ووسّعتُ عليهم على تكذيبك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ هُمْ قَوْمٌ طاغُونَ﴾</span>، يعني: عاصين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٥٠، ومن طريق سعيد بنحوه. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/١٣٣.تفسير البغوي ٧/٣٨٠.تفسير مقاتل بن سليمان ٤/١٣٣.
  51,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤ وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾</span> - نزول الآيتين</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٥٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، قال: لَمّا نَزَلَتْ: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> لم يَبقَ مِنّا أحدٌ إلا أيقن بالهَلكة؛ إذ أُمر النبيُّ ﷺ أن يتولّى عنّا؛ فنَزَلَتْ: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فطابتْ أنفسُنا{1}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: ما نَزَلَتْ علينا آيةٌ كانت أشدّ علينا منها، ولا أعظم علينا منها، فقلنا: ما هذا إلا مِن سَخْطةٍ أو مقْتٍ. حتى نَزَلَتْ: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{2}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٥<span class="dash">-</span></span> عن <span class="name-3">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: ذُكِر لنا: أنها لما نَزَلَتْ اشتدَّ على أصحاب رسول الله ﷺ، ورأوا أنّ الوحي قد انقطع، وأنّ العذاب قد حضر، فأنزل الله بعد ذلك: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{3}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> يعني: فأعْرِض عنهم، فقد بلَّغتَ وأعذَرتَ، <span class="qpc-hafs">﴿فَما أنْتَ﴾</span> يا محمد <span class="qpc-hafs">﴿بِمَلُومٍ﴾</span> يقول: فلا تُلام، فحزن النبيُّ ﷺ مخافة أن ينزل بهم العذاب؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤ وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾</span> - تفسير الآيتين، والنسخ فيهما</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٥٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>، قال: ذَكِّر بالقرآن{5}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: أمره الله أن يتولّى عنهم ليعذّبهم، وعذر محمدًا ﷺ، ثم قال: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فنَسَختْها{6}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: محمد ﷺ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> قال: فأَعرَض عنهم، فقيل له: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فوَعَظهم{8}. (١٣/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> أنّ التولي عنهم منسوخ؛ بأنّه قد أُمِر بالإقبال عليهم بالموعظة، قال تعالى: <span class="qpc-hafs">﴿يا أيُّها الرَّسُولُ بَلِّغْ ما أُنْزِلَ إلَيْكَ مِن رَبِّكَ وإنْ لَمْ تَفْعَلْ فَما بَلَّغْتَ رِسالَتَهُ﴾</span> [المائدة:٦٧]{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن شهاب الزُّهريّ</span>: وقال تعالى في سورة الذّاريات: <span class="qpc-hafs">﴿فتول عنهم فما أنت بملوم﴾</span>، نُسِختْ بقوله: <span class="qpc-hafs">﴿وذكر فإن الذكرى تنفع المؤمنين﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق القاسم بن عبد الله- أنه قال: ويقول في الذّاريات: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> أمره أن يتولى عنهم ليعذّبهم، وعذر محمدًا النبي محمد ﷺ، ثم قال: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> عِظ بالقرآن مَن آمن مِن قومك؛ فإنّ الذكرى تنفعهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> يعني: فأعْرِض عنهم، فقد بلَّغتَ وأعذَرتَ، <span class="qpc-hafs">﴿فَما أنْتَ﴾</span> يا محمد <span class="qpc-hafs">﴿بِمَلُومٍ﴾</span> يقول: فلا تلام، فحزن النبيُّ ﷺ مخافةَ أن ينزل بهم العذاب؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فوعظ كفارَ مكة بوعيد القرآن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> معناه: عِظ بالقرآن كفار مكة؛ فإنّ الذكرى تنفع مَن سبق في عِلم الله أن يؤمن منهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: قد بلَّغتَ ما أرسلناك به، فلستَ بملوم. قال: وكيف يلومه، وقد أدّى ما أُمر به؟!{3}<span class=comment-ref>٦٢٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨١) في معنى الآية <b>احتمالين</b>، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فتول عنهم﴾</span> أي: عن الحرص المُفرط عليهم، وذهاب النفس حسرات. و<b>يحتمل</b> أن يراد: فتولّ عن التعب المفرط في دعائهم وضمهم إلى الإسلام، فلست بمصيطر عليهم، ولست بملوم إذ قد بلغت، فنحّ نفسك عن الحزن عليهم، وذكِّر فقط، فإن الذكرى نافعة للمؤمنين، ولمن قضي له أن يكون منهم في ثاني حال». ثم <span class="comment-type-4">علّق</span> على الاحتمال الثاني، فقال: «وعلى هذا التأويل فلا نسخ في الآية، إلا في معنى الموادعة التي فيها، فإن آية السيف نسخَتْ جميع الموادعات».</div></p><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤ وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٦٨<span class="dash">-</span></span> عن سليمان بن حبيب المحاربي، قال: مَن وجد للذكرى في قلبه موقعًا فليعلم أنّه مؤمن؛ قال الله: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{16}. (١٣/٦٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق بن راهويه -كما في المطالب (٤١١٦)-، وأحمد بن منيع -كما في المطالب (٤١١٧)-، والهيثم بن كليب -كما في المطالب ٩/٤٣-، والبيهقي في شعب الإيمان (١٧٥٠)، والضياء في المختارة (٧١٤). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه إسحاق بن راهويه -كما في المطالب (٤١١٥)-، وابن جرير ٢١/٥٥٢. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢١/٥٥٢.تفسير مقاتل بن سليمان ٤/١٣٣.أخرجه إسحاق بن راهويه -كما في المطالب (٤١١٥)-. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى أبي داود في ناسخه، وابن المنذر.تفسير مجاهد ص٦٢١، وأخرجه ابن جرير ٢١/٥٥٢.أخرجه ابن جرير ٢١/٥٥١، ٥٥٣. وعزاه السيوطي إلى ابن المنذر.علقه النحاس في الناسخ والمنسوخ (ت: اللاحم) ٣/٢٨.الناسخ والمنسوخ للزهري ص٣٥.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٨٣ (١٨٠).تفسير البغوي ٧/٣٨٠.تفسير مقاتل بن سليمان ٤/١٣٣.تفسير البغوي ٧/٣٨٠.أخرجه ابن جرير ٢١/٥٥٢.عزاه السيوطي إلى ابن المنذر.
