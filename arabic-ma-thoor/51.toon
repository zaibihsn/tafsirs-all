  51,6,""
  51,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّمَاۤءِ ذَاتِ ٱلۡحُبُكِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٣٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عمرو البَكالي- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: هي السماء السابعة{1}<span class=comment-ref>٦١٧٧</span>. (١٣/٦٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧٧</span> <span class="comment-type-1">وجّه</span> <u>ابنُ كثير</u> (١٣/٢٠٩) قول عبد الله، فقال: «وكأنه -والله أعلم- أراد بذلك: السماء التي فيها الكواكب الثابتة، وهي عند كثير من علماء الهيئة في الفلك الثامن الذي فوق السابع».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٦٢): «ظاهر لفظة السماء أنها لجميع السماوات».</div></p><p><h3><span class="qpc-hafs">﴿ذَاتِ ٱلۡحُبُكِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٣٩٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> أنه سُئل عن قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>. قال: ذات الخَلْق الحَسن{2}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: حُسنها، واستواؤها{3}. (١٣/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات البهاء والجمال، وإنّ بنيانها كالبُرْد المُسلسل{4}. (١٣/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات الخَلْق الحَسن{5}<span class=comment-ref>٦١٧٨</span>. (١٣/٦٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧٨</span> نقل <u>ابنُ عطية</u> (٨/٦٣) عن منذر بن سعيد قوله: «إنّ السماء في تألّف جِرمها هي هكذا لها حُبُك، وذلك لجودة خِلْقتها وإتقان صَنعتها». و<span class="comment-type-4">علَّق</span> عليه بقوله: «ولذلك عبّر ابن عباس ﵄ في تفسير قوله تعالى: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span> بأن قال: حُبُكها: حُسْن خِلقَتها ...».</div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>. قال: ذات الطرائق، والخَلْق الحَسن. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعتَ زهير بن أبي سُلْمى يقول:</p><p>هم يضربون حَبِيك البَيْض إذ لَحِقوا لا ينكُصُون إذا ما استُلحموا وحَمُوا؟{6}. (١٣/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿ <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، ما الحُبك؟ قال: ذات الطرائق. قال: فهل كانت العرب تعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: نعم، أما سمعت قول زهير بن أبي سُلْمى:</p><p>مُكلّل بأصول النجم تنسجه ريح الشمال لضاحي مائح حُبُك؟{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: حُبُكها: حُسْنها، واستواؤها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: ذات الزينة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: المُتقن البُنيان{10}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، يقول: ذات الزينة، ويُقال أيضًا: حُبُكها مثل حُبُك الرّمل، ومثل حُبُك الدّرع، ومثل حُبُك الماء إذا ضربتْه الريح، فنسجته طرائق{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿الحُبُكِ﴾</span>: الطريق التي تُرى في السماء من آثار الغيم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران بن حدير- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات الخَلْق الحَسن، ألم تر إلى النساج إذا نسج الثوب قيل: ما أحسن ما حبَكه{13}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿ذاتِ الحُبُك﴾</span>، قال: حُبكت بالخَلْق الحَسن؛ حُبكت بالنجوم{14}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات الخَلْق الشديد{15}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ذاتِ الحُبُكِ﴾</span>، قال: ذات الخَلْق الحَسن{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: حُبُكها: نجومها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق علي بن جعفر- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: ذات الخَلْق الحَسن{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span> ذات الطرائق، كحُبُك الماء إذا ضربتْه الريح، وحُبُك الرمل والشَّعر الجَعد، ولكنها لا تُرى لبُعدها من الناس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، يعني: مثل الطرائق التي تكون في الرّمل من الريح، ومثل الماء تصيبه الريح فيركب بعضه بعضًا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١١<span class="dash">-</span></span> عن <span class="name-3">سفيان بن حسين</span> -من طريق الحصين بن نمير- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: طرائق كطرائق الرمل والماء. وأنشد:</p><p>مكلّل بأصول النجم تنسجه ريح خَريْق لضاحي مائه حبُك{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذاتِ الحُبُكِ﴾</span>، قال: الشدة، حُبِكت: شُدّت. وقرأ قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وبَنَيْنا فَوْقَكُمْ سَبْعًا شِدادًا﴾</span> [النبأ:١٢]{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٣<span class="dash">-</span></span> عن <span class="name-3">الهُذيل بن حبيب</span>: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span> الخَلْق الحَسن{23}<span class=comment-ref>٦١٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧٩</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/٤٨٦ بتصرف): «قوله تعالى: <span class="qpc-hafs">﴿والسماء ذات الحبك﴾</span> يقول -تعالى ذِكْرُه-: والسماء ذات الخَلْق الحَسن، وعنى بقوله: <span class="qpc-hafs">﴿ذات الحبك﴾</span>: ذات الطرائق ... <span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span>، وإن اختلفت ألفاظ قائليه فيه».</p><p>وذكر <u>ابنُ كثير</u> (١٣/٢٠٩) عبارات السلف في معنى الحُبك، ثم <span class="comment-type-4">علّق</span> قائلًا: «وكل هذه الأقوال ترجع إلى شيء واحد، وهو الحُسْن والبهاء، <span class="mustanad">كما قال ابن عباس</span> ﵄، فإنها مِن حُسنها مرتفعة شفّافة صفيقة، شديدة البناء، متسعة الأرجاء، أنيقة البهاء، مكلّلة بالنجوم الثوابت والسيارات، موشحة بالشمس والقمر والكواكب الزاهرات».</p><p>ونقل <u>ابنُ عطية</u> (٨/٦٣) عن ابن جني قوله: «الحُبُك: طرائق الغَيْم ونحو هذا».</div></p><p><h3><span class="qpc-hafs">﴿ذَاتِ ٱلۡحُبُكِ ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٤١٤<span class="dash">-</span></span> عن أبي قِلابة، عن رجل مِن أصحاب النبي ﷺ، عن النبي ﷺ، قال: «<b>إنّ مِن بعدكم الكذّاب المُضِل، وإنّ رأسه مِن بعده حُبُك حُبُك حُبُك</b>» ثلاث مرات{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٨٩ من طريقي عمرو والقاسم، وأبو الشيخ (٥٦٥). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه أحمد بن منيع -كما في المطالب العالية (٤١٢٠)-.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦١٧-، والفريابي -كما في تغليق التعليق ٤/٣١٩-، وابن جرير ٢١/٤٨٧، وابن أبي حاتم -كما في تغليق التعليق ٤/٣١٩-، وأبو الشيخ في العظمة (٥٥٦). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٣- بنحوه. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن أبي حاتم -كما في الفتح ٦/٢٩٤-، وأبو الشيخ في العظمة (٥٥٦).أخرجه ابن جرير ٢١/٤٨٦، ٤٨٨، ٤٨٩ من طريق عكرمة وقتادة، ومن طريق علي أيضًا بزيادة: ويقال: ذات الزينة. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطستي في مسائله -كما في الإتقان ٢/٩٤-.أخرجه الطبراني مطولًا في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).أخرجه ابن جرير ٢١/٤٨٧.أخرجه ابن جرير ٢١/٤٨٧.تفسير مجاهد ص٦١٧، وأخرجه ابن جرير ٢١/٤٨٩.أخرجه ابن جرير ٢١/٤٨٩، وإسحاق البستي ص٢٢٠.أخرجه ابن جرير -كما في الفتح ٦/٢٩٤-.أخرجه ابن جرير ٢١/٤٨٧، وأبو الشيخ (٥٥٥).أخرجه ابن جرير ٢١/٤٨٧-٤٨٨، وبنحوه من طريق قتادة، وأبو الشيخ (٥٤٨).أخرجه إسحاق البستي ص٢٢٠، وأبو الشيخ (٥٤٦).أخرجه عبد الرزاق ٢/٢٤٢، وابن جرير ٢١/٤٨٨، وبنحوه من طريق سعيد.أخرجه ابن جرير ٢١/٤٨٨.أخرجه ابن جرير ٢١/٤٨٨.تفسير البغوي ٧/٣٧١.تفسير مقاتل بن سليمان ٤/١٢٧. وفي تفسير البغوي ٧/٣٧١ عن مقاتل دون تعيينه.أخرجه إسحاق البستي ص٤٢١.أخرجه ابن جرير ٢١/٤٨٩.تفسير مقاتل بن سليمان ٤/١٢٧.أخرجه أحمد ٣٨/٢٢٩ (٢٣١٥٩)، ٣٨/٤٧٢ (٢٣٤٨٧)، وابن جرير ٢١/٤٨٨ وقال عقبه: يعني بالحبُك الجُعُودة.</p><p>قال الهيثمي في المجمع ٧/٣٤٣ (١٢٥٢٢): «رواه أحمد، ورجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٨/١٢١ (٧٦٢٨): «رواه أحمد بن منيع، ورواته ثقات». وقال ابن حجر في الإصابة ٣/٣٧١: «وقال الدارقطني في الأفراد: ... غريب تفرد به ابن أبي سبرة. قلت: وهو ضعيف، والراوي عنه أضعف منه». وقال الألباني في الصحيحة ٦/٧٢٧ (٢٨٠٨): «وهذا إسناد صحيح، غاية رجاله ثقات رجال الشيخين، وجهالة الصحابي لا تضر».
  51,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّكُمۡ لَفِی قَوۡلࣲ مُّخۡتَلِفࣲ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إنَّكُمْ لَفِي قَوْلٍ مُخْتَلِف﴾</span>، قال: مصدِّق بهذا القرآن ومُكَذِّب{1}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّكُمْ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿لَفِي قَوْلٍ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿مُخْتَلِفٍ﴾</span> شكّ، يؤمن به بعضكم ويكفر به بعضكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿إنَّكُمْ لَفِي قَوْلٍ مُخْتَلِف﴾</span>، قال: أهل الشرك يختلف عليهم الباطل{3}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّكُمْ لَفِي قَوْلٍ مُخْتَلِفٍ﴾</span>، قال: يتخرّصون؛ يقولون: هذا سحر، ويقولون: هذا أساطير، فبأي قولهم يؤخذ؟! قُتل الخرّاصون، هذا الرجل لا بدّ له من أن يكون فيه أحد هؤلاء، فما لكم لا تأخذون أحد هؤلاء، وقد رميتموه بأقاويل شتى، فبأي هذا القول تأخذون هذا الرجل الآن؟! فهو قول مختلف. قال: فذكر أنه تَخرّصٌ منهم، ليس لهم بذلك علم. قالوا: فما منع هذا القرآن أن ينزل باللسان الذي نَزَلَتْ به الكتب من قبلك، فقال الله: <span class="qpc-hafs">﴿أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</span> [فصلت:٤٤]؟ لو جعلنا هذا القرآن أعجميًّا لقلتم نحن عَرَبٌ وهذا القرآن أعجمي، فكيف يجتمعان؟!{4}<span class=comment-ref>٦١٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٠</span> ذكر <u>ابنُ عطية</u> (٨/٦٤) في المخاطب بقوله: <span class="qpc-hafs">﴿إنكم﴾</span> احتمالين، و<span class="comment-type-1">وجّههما</span>، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿إنكم لفي قول مختلف﴾</span> <b>يحتمل</b> أن يكون خطابًا لجميع الناس مؤمن وكافر، أي: اختلفتم بأن قال فريق منكم: آمنّا بمحمد وكتابه، وقال فريق آخر: كفرنا، وهذا قول قتادة. <b>ويحتمل</b> أن يكون خطابًا للكفرة فقط، أي: أنتم في جنس من الأقوال مختلف في نفسه، قوم منكم يقولون: ساحر، وقوم: كاهن، وقوم: شاعر، وقوم: مجنون إلى غير ذلك، وهذا قول ابن زيد».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٤٢، وابن جرير ٢١/٤٩٠. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/١٢٧.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤٩٠.
  51,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُؤۡفَكُ عَنۡهُ مَنۡ أُفِكَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِك﴾</span>، قال: يُضَلُّ عنه مَن ضَلّ{1}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِك﴾</span>: يُؤفن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة، ومعمر- في قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِك﴾</span>، قال: يُصرف عنه مَن صُرِف{3}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِكَ﴾</span>: فالمأفوك عنه اليوم، يعني: كتاب الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِكَ﴾</span> يعني: عن الإيمان بالقرآن، يعني: يُصرف عن القرآن مَن كذّب به، يعني: الخرّاصين، يقول: الكذّابون الذين يخرصون الكذب{5}<span class=comment-ref>٦١٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨١</span> ذكر <u>ابنُ عطية</u> (٨/٦٤-٦٥) في عود الضمير في قوله: <span class="qpc-hafs">﴿عنه﴾</span> عدة احتمالات، فقال: «والضمير في: <span class="qpc-hafs">﴿عنه﴾</span> قال الحسن وقتادة: <b>هو عائد على</b> محمد <b>أو</b> كتابه وشرعه، و<span class="qpc-hafs">﴿يُؤْفَكُ﴾</span> معناه: يُصرف، فالمعنى: يُصرف عن كتاب الله مَن صُرف ممن غلبت شقاوته، وكان قتادة يقول: المأفوك منا اليوم عن كتاب الله كثيرًا. <b>ويحتمل</b> أن يعود الضمير على القول، أي: يُصرف بسببه مَن أراد الإسلام، بأن يقال له: هو سحر، هو كهانة. وهذا حكاه الزهراوي. <b>ويحتمل</b> أن يعود الضمير في <span class="qpc-hafs">﴿عنه﴾</span> على القول، أي: يُصرف عنه بتوفيق الله إلى الإسلام مَن غَلبت سعادته، وهذا على أن يكون قوله: <span class="qpc-hafs">﴿إنكم لفي قول مختلف﴾</span> للكفار فقط». ثم <span class="comment-type-4">علّق</span> على الاحتمال الأخير، فقال: «وهذا وجه حسن لا يخل به، إلا أنّ <span class="mustanad">عُرف الاستعمال</span> في»أفك«إنما هو في الصرف من خير إلى شر، وتأمل ذلك تجدها أبدًا في المصروفين المذمومين».</p><p>وذكر <u>ابنُ القيم</u> (٣/٣٣) القول بعود الضمير على محمد ﷺ، و<span class="comment-type-1">وجّهه</span>، فقال: «والمعنى: يُصرف عنه مَن صُرف حتى يكذّب به».</div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِكَ﴾</span>، قال: يُؤفك عنه المشركون{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٦١٧، وأخرجه ابن جرير ٢١/٤٩١، وقال: «قال ابن عمرو في حديثه: يوفى، أو يؤفن، أو كلمة تشبهها. وقال الحارث: يؤفن، بغير شكّ». وأخرجه إسحاق البستي ص٤٢٢ من طريق ابن جريج، ووقع في النسخة: يوفق دون إعجام الفاء ولعله تحريف من «يؤفن» كما ذكر محققه.أخرجه عبد الرزاق ٢/٢٤٣، وابن جرير ٢١/٤٩١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤٩١. وعلقه إسحاق البستي ص٤٢٢ بلفظ: أفك عنه اليوم كثير، يعني كتاب الله.تفسير مقاتل بن سليمان ٤/١٢٧-١٢٨.أخرجه ابن جرير ٢١/٤٩٢.
  51,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُتِلَ ٱلۡخَرَّ ٰ⁠صُونَ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: ما كان في القرآن «قُتّل» بالتشديد فهو عذاب، وما كان <span class="qpc-hafs">﴿قُتل﴾</span> بالتخفيف فهو رحمة{1}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: لُعِن المرتابون{2}<span class=comment-ref>٦١٨٢</span>. (١٣/٦٦٨)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٢</span> <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٨/٦٥) أن قوله: <span class="qpc-hafs">﴿قتل﴾</span> دعاء عليهم، <span class="mustanad">كقول القائل</span>: قاتلك الله. ثم <span class="comment-type-2">انتقد</span> <span class="mustanad">-مستندًا إلى ظاهر اللفظ</span>- ما جاء في قول ابن عباس، فقال: «وقال بعض المفسرين معناه: لُعن الخراصون. وهذا تفسير لا تعطيه اللفظة».</div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: الكَهَنة{3}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span> هم الكَهَنة الذين يتخرصون على علم الغيب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: الذين يَخْرُصون الكذب، كقوله في «عبس» [١٧]: <span class="qpc-hafs">﴿قُتِلَ الإنْسانُ﴾</span>{5}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: الذين يقولون: لا نُبعث، ولا يوقنون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: الكذّابون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: الكذّابون{8}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: أهل الغِرّة والظنون{9}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: هي مثل التي في «عبس» [١٧]: <span class="qpc-hafs">﴿قُتِلَ الأِنْسانُ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... يقول: الكذّابون الذين يخرصون الكذب، <span class="qpc-hafs">﴿قُتِلَ﴾</span> يعني: لُعن <span class="qpc-hafs">﴿الخَرّاصُونَ﴾</span> نظيرها في النحل{11}، وكانوا سبعة عشر رجلًا، فقال لهم الوليد بن المُغيرة المخزومي: لينطَلِق كلُّ أربعة منكم أيام الموسم فليجلسوا على طريق ليصدّوا الناس عن النبي ﷺ. وتخرّصهم أنهم قالوا للناس: إنه ساحر، ومجنون، وشاعر، وكاهن، وكذاب. وبقي الوليد بمكة يصدّقهم بما يقولون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: القوم الذين كانوا يتخرَّصون الكذبَ على رسول الله ﷺ، قالت طائفة: إنما هو ساحر، والذي جاء به سحر. وقالت طائفة: إنما هو شاعر، والذي جاء به شعر. وقالت طائفة: إنما هو كاهن، والذي جاء به كهانة. وقالت طائفة: <span class="qpc-hafs">﴿أساطِيرُ الأَوَّلِينَ اكْتَتَبَها فَهِيَ تُمْلى عَلَيْهِ بُكْرَةً وأَصِيلًا﴾</span> [الفرقان:٥]. يتخرّصون على رسول الله ﷺ{6}<span class=comment-ref>٦١٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٣</span> اختُلف في تفسير قوله: <span class="qpc-hafs">﴿الخراصون﴾</span> على قولين: <b>الأول</b>: أنهم الكهنة الذين يتخرصون الكذب والباطل. <b>الثاني</b>: أنهم المرتابون.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u>(٢١/٤٩٢) القول الأول <span class="mustanad">مستندًا إلى أقوال السلف</span>، فقال: «قوله تعالى: <span class="qpc-hafs">﴿قتل الخراصون﴾</span> يقول -تعالى ذكره-: لُعن المتكهنون الذين يتخرّصون الكذب والباطل فيتطيبونه».</div></p></div>",footnotes:1:أخرجه الطبراني (١١١٧٥).أخرجه ابن جرير ٢١/٤٩٢، وابن أبي حاتم -كما في الإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر. وعزا ابن حجر في الفتح ٨/٥٩٩ إلى ابن جرير عن ابن عباس -من طريق علي- في الآية قال: لُعن الكذابون.أخرجه ابن جرير ٢١/٤٩٢. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٩/١١١.أخرجه ابن جرير ٢١/٤٩٢. وهو في تفسير مجاهد ص٦١٨ دون آخره. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢١/٤٩٣.أخرجه عبد الرزاق ٢/٢٤٢.أخرجه عبد الرزاق -كما في الفتح ٨/٥٩٩-.أخرجه ابن جرير ٢١/٤٩٣ دون لفظ: الغرة. وعلقه إسحاق البستي ص٤٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن المنذر -كما في الفتح ٨/٦٠١-.لعله يقصد قوله تعالى: <span class="qpc-hafs">﴿وإنْ هُمْ إلّا يَخْرُصُونَ﴾</span> [الأنعام:١١٦، يونس:٦٦] ولكنها ليست في النحل.تفسير مقاتل بن سليمان ٤/١٢٨.أخرجه ابن جرير ٢١/٤٩٣.
  51,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ هُمۡ فِی غَمۡرَةࣲ سَاهُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُونَ﴾</span>، قال: في غفلة لاهون{1}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ﴾</span>: يعني: الكفر والشكّ{2}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُون﴾</span>، قال: في ضلالتهم يتمادَوْن{3}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُونَ﴾</span>، قال: قلبه في كنانة{4}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُون﴾</span>، قال: في عمًى وشُبهة{5}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُونَ﴾</span>، يعني: في غفلة لاهون عن أمر الله تعالى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿غَمْرَةٍ ساهُونَ﴾</span>، قال: في غفلة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فِي غَمْرَةٍ ساهُونَ﴾</span>، قال: ساهون عمّا أتاهم، وعمّا نزل عليهم، وعمّا أمرهم الله -تبارك وتعالى-. وقرأ قول الله -جلّ ثناؤه-: <span class="qpc-hafs">﴿بَلْ قُلُوبُهُمْ فِي غَمْرَةٍ مِن هَذا﴾</span> الآية [المؤمنون:٦٣]، وقال: ألا ترى الشيء إذا أخذْتَه ثم غمَرْتَه في الماء؟{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٩٤. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢١/٤٩٤، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٠، والإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وذكر محققو الدر أنه في نسخة منه بلفظ: كآبة.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن جرير ٢١/٤٩٤ بلفظ: غمرة وشبهة. وكذلك علقه إسحاق البستي ص٤٢٢.تفسير مقاتل بن سليمان ٤/١٢٨.أخرجه ابن جرير ٢١/٤٩٤.أخرجه ابن جرير ٢١/٤٩٤.
  51,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَسۡـَٔلُونَ أَیَّانَ یَوۡمُ ٱلدِّینِ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يَسْأَلُونَ أيّانَ يَوْمُ الدِّينِ يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span> قال: فِتنتهم أنهم سألوا عن يوم الدِّين وهم موقوفون على النار، <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ هَذا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span> فقالوا حين وُقفوا: <span class="qpc-hafs">﴿يا ويْلَنا هَذا يَوْمُ الدِّينِ﴾</span> [الصافات:٢٠]. وقال الله -تبارك وتعالى-: <span class="qpc-hafs">﴿هَذا يَوْمُ الفَصْلِ الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span> [الصافات:٢١]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَسْأَلُونَ أيّانَ يَوْمُ الدِّين﴾</span>، قال: يقولون: متى يوم الدِّين؟ أوَ يكون يوم الدِّين؟{2}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَسْئَلُونَ﴾</span> النبي ﷺ <span class="qpc-hafs">﴿أيّانَ﴾</span> يقول: متى <span class="qpc-hafs">﴿يَوْمُ الدِّينِ﴾</span> يعني: يوم الحساب، فقالوا: يا محمد -وهم الخرّاصون-، متى يكون الذي تعِدنا به؟! تكذيبًا به، من أمر الحساب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أيّانَ يَوْمُ الدِّينِ﴾</span>، قال: الذين كانوا يجحدون أنهم يُدانون، أو يُبعثون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٩٦.تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٥-٤٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٢٨.أخرجه ابن جرير ٢١/٤٩٥.
  51,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ هُمۡ عَلَى ٱلنَّارِ یُفۡتَنُونَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُون﴾</span>، قال: يُعذّبون{1}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق حماد بن زيد، عن عمرو بن مالك- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُعذّبون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥١<span class="dash">-</span></span> عن <span class="name-2">أبي الجوزاء</span> -من طريق جعفر بن سليمان، عن عمرو بن مالك- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: المناقشة في الأعمال{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُون﴾</span>، قال: يُعَذَّبون عليها ويُحرقون، كما يُفتن الذّهب في النار{4}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، يقول: يُنضَجون بالنار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span> يقول: يُطبخون. ويُقال أيضًا <span class="qpc-hafs">﴿يُفْتَنُونَ﴾</span>: يُكذِّبون، كل هذا يقال{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حُصين- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُعذّبون في النار، يُحرقون فيها، ألم ترَ أنّ الذَّهب إذا أُلقي في النار قيل: فُتِن؟{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس، ومبارك- <span class="qpc-hafs">﴿يفتنون﴾</span>: يُعذَّبون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٧<span class="dash">-</span></span> عن قرة: سمعت <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿يفتنون﴾</span> يُقَرَّرون بذنوبهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٨<span class="dash">-</span></span> قال إسحاق البستي: وجدت في كتاب أبي في تفسير <span class="name-2">قتادة</span>: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُنضَجون بالنار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span> يعني: يُعذّبون، يُحرقون، كقوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ فَتَنُوا المُؤْمِنِينَ والمُؤْمِناتِ﴾</span> [البروج:١٠]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، يقول: يُحرَقون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُحرقون بالنار{12}<span class=comment-ref>٦١٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٤</span> في قوله: <span class="qpc-hafs">﴿يوم هم على النار يفتنون﴾</span> قولان: <b>الأول</b>: أنهم يُحرقون ويُعذّبون بالنار. <b>الثاني</b>: أنهم يُكذّبون.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٤٩٨) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، وعلَّل ذلك بقوله: «لأن الفتنة أصلها: الاختبار، وإنما يقال: فتنت الذهب بالنار: إذا طبختها بها لتعرف جودتها؛ فكذلك قوله: <span class="qpc-hafs">﴿يوم هم على النار يفتنون﴾</span> يُحرقون بها كما يُحرق الذهب بها».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٦٥-٦٦): «و<span class="qpc-hafs">﴿يفتنون﴾</span> معناه: يُحرقون ويُعذّبون في النار. قاله ابن عباس، ومجاهد، وعكرمة، <span class="mustanad">والجميع</span>».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ القيم</u> (٣/٣٣-٣٤ بتصرف) على القول الأول، فقال: «والمشهور في تفسير هذا الحرف أنه بمعنى: يُحرقون، ولكن لفظة <span class="qpc-hafs">﴿على﴾</span> تعطي معنًى زائدًا على ما ذكروه، ولو كان المراد نفس الحرق لقيل: يوم هم في النار يفتنون. ولهذا لَمّا علم هؤلاء ذلك قال كثير منهم <span class="qpc-hafs">﴿على﴾</span> بمعنى: في، كما تكون»في«بمعنى: على. ومَن جعل الفتنة ههنا مِن الحريق <span class="mustanad">أخذه من قوله تعالى</span> <span class="qpc-hafs">﴿إنَّ الَّذِينَ فَتَنُوا المُؤْمِنِينَ والمُؤْمِناتِ ثُمَّ لَمْ يَتُوبُوا﴾</span> [البروج:١٠]، واستشهد على ذلك أيضًا بهذه اللفظة التي في الذّاريات». ثم قال: «والظاهر أنّ فتنتهم على النار قبل فتنتهم فيها، لهم عند عرضهم عليها ووقوفهم عليها فتنة، وعند دخولهم والتعذيب بها فتنة أشد منها. وحقيقة الأمر أنّ الفتنة تُطلق على: العذاب وسببه، ولهذا سمى الله الكفر: فتنة، فهم لما أتَوا بالفتنة التي هي أسباب العذاب في الدنيا سمّى جزاءهم: فتنة، ولهذا قال: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span> وكان وقوفهم على النار وعرضهم عليها مِن أعظم فتنتهم، وآخر هذه الفتنة دخول النار والتعذيب بها، ففُتنوا أولًا بأسباب الدنيا وزينتها، ثم فُتنوا بإرسال الرسل إليهم، ثم فُتنوا بمخالفتهم وتكذيبهم، ثم فُتنوا بعذاب الدنيا، ثم فُتنوا بعذاب الموت، ثم يُفتنون في موقف القيامة، ثم إذا حُشروا إلى النار وُقِفوا عليها وعُرضوا عليها وذلك من أعظم فتنتهم، ثم الفتنة الكبرى التي أنسَتهم جميع الفتن قبلها».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٩٥، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٠، والإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٨٧ (٣٦٨٠٣)، وابن أبي الدنيا في صفة النار ٦/٤٤٢ (١٩٤)، والحربي في غريب الحديث ٣/٩٣٦.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٨٧ (٣٦٨٠٤).تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٦، مقتصرًا على شطره الثاني ٢١/٤٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢١/٤٩٦.أخرجه ابن جرير ٢١/٤٩٧ وإسحاق البستي ص٤٢٢.أخرجه ابن جرير ٢١/٤٩٦. وهو عند سفيان الثوري ص٢٨١، وإسحاق البستي ص٤٢٢ بالاقتصار على لفظ: يُحرقون.أخرجه الحربي في غريب الحديث ٣/٩٣٦.أخرجه الحربي في غريب الحديث ٣/٩٣٦، وإسحاق البستي ص٤٢٣ وقال فيه: أحسبه قال: يعيرون بذنوبهم. قال محقّقه: كلمة «يعيرون» عليها ضبة.تفسير إسحاق البستي ص٤٢٣.تفسير مقاتل بن سليمان ٤/١٢٨.أخرجه ابن جرير ٢١/٤٩٧.أخرجه ابن جرير ٢١/٤٩٧.
  51,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذُوقُوا۟ فِتۡنَتَكُمۡ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span>، يقول: تكذيبكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٣<span class="dash">-</span></span> عن <span class="name-2">أبي الجوزاء</span>، <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُم﴾</span>، قال: عذابكم{2}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فِتْنَتَكُمْ﴾</span>، قال: حريقكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُم﴾</span>، يقول: حريقكم، ويقال: كذبكم{1}<span class=comment-ref>٦١٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٥</span> في قوله: <span class="qpc-hafs">﴿ذوقوا فتنتكم﴾</span> قولان: <b>الأول</b>: ذوقوا تكذيبكم. <b>الثاني</b>: ذوقوا حريقكم وعذابكم.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٤٩٩) القول الأول <span class="mustanad">مستندًا إلى أقوال السلف</span>.</div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ هَذا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span>، قال: تكذيبكم، به تُكذِّبون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ ذُوقُوا فِتْنَتَكُم﴾</span>، قال: يوم يُعذّبون، فيقول: ذوقوا عذابكم{6}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span> يعني: عذابكم، <span class="qpc-hafs">﴿هذا﴾</span> العذاب <span class="qpc-hafs">﴿الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span> في الدنيا استهزاءً به وتكذيبًا بأنّه غير نازل بنا، لقولهم في الدنيا للنبي ﷺ: متى هذا الوعد الذي تعِدنا به؟!{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُم﴾</span>، قال: حريقكم{2}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span>، يقول: احتراقكم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span>، قال: ذوقوا عذابكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ هَذا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span>. فقال: هذا الذي فُتنتم به، ألم تر إلى الدينار إذا أُدخل النار قيل: قد اختُبر وفُتن؟!{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٠٠.عزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٩.أخرجه ابن جرير ٢١/٥٠٠.أخرجه إسحاق البستي ص٤٢٣.أخرجه عبد الرزاق ٢/٢٤٢، وابن جرير ٢١/٤٩٩، وبنحوه من طريق سعيد. وعلقه إسحاق البستي ص٤٢٣.تفسير مقاتل بن سليمان ٤/١٢٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤٩٩.أخرجه ابن جرير ٢١/٥٠٠.أخرجه إسحاق البستي في تفسيره ص٤٢٣.
  51,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَعُیُونٍ ۝١٥ ءَاخِذِینَ مَاۤ ءَاتَىٰهُمۡ رَبُّهُمۡۚ إِنَّهُمۡ كَانُوا۟ قَبۡلَ ذَ ٰ⁠لِكَ مُحۡسِنِینَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُسْلِم البَطِين- في قوله: <span class="qpc-hafs">﴿آخِذِينَ ما آتاهُمْ رَبُّهُمْ﴾</span> قال: الفرائض، <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُحْسِنِين﴾</span> قال: قبل أن تنزل الفرائض يعملون{1}<span class=comment-ref>٦١٨٦</span>. (١٣/٦٧١)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٦</span> لم يذكر <u>ابنُ جرير</u> (٢١/٥٠٠) غير قول ابن عباس.</p><p>ونقل <u>ابنُ عطية</u> (٨/٦٦) عن ابن عباس قوله: «المعنى: <span class="qpc-hafs">﴿آخِذِينَ﴾</span> في دنياهم <span class="qpc-hafs">﴿ما آتاهُمْ رَبُّهُمْ﴾</span> من أوامره ونواهيه وفرائضه وشرعه». و<span class="comment-type-1">وجَّهه</span> بقوله: «فالحال على هذا محكية، وهي متقدمة في الزمان على كونهم في جنات وعيون»، ونقل <u>ابنُ عطية</u> (٥/١٧٤ ط.دار الكتب العلمية) عن جماعة من المفسرين: أن «معنى قوله: <span class="qpc-hafs">﴿آخذين ما آتاهم ربهم﴾</span> أي: مُحصّلين لنعم الله التي أعطاهم من جنته ورضوانه». و<span class="comment-type-1">وجَّهه</span> بقوله: «وهذه حال متصلة في المعنى بكونهم في الجنات». ثم <span class="comment-type-3">رجَّحه</span> قائلًا: «وهذا التأويل أرجح عندي؛ <span class="mustanad">لاستقامة الكلام به</span>».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٣/٢١١) أثر ابن عباس، فقال: «وهذا الإسناد ضعيف، ولا يصح عن ابن عباس. وقد رواه عثمان بن أبي شيبة، عن معاوية بن هشام، عن سفيان، عن أبي عمر البزار، عن مُسْلِم البَطِين، عن سعيد بن جُبَير، عن ابن عباس، فذكره». ثم <span class="comment-type-2">انتقد</span> -<span class="mustanad">مستندًا إلى اللغة</span>- تفسير <u>ابن جرير</u> الآية على ما جاء في قول ابن عباس، فقال: «والذي فسّر به ابن جرير فيه نظر؛ لأن قوله: <span class="qpc-hafs">﴿آخذين﴾</span> حال من قوله: <span class="qpc-hafs">﴿في جنات وعيون﴾</span>، فالمتقون في حال كونهم في الجنات والعيون آخذون ما آتاهم ربهم، أي: من النعيم والسرور والغبطة».</div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٤<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿آخِذِينَ ما آتاهُمْ رَبُّهُمْ﴾</span> آخذين بما أمرهم ربُهم، عاملين بالفرائض التي أوجبها عليهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ وعُيُونٍ﴾</span> يعني: بساتين وأنهار جارية، <span class="qpc-hafs">﴿آخِذِينَ﴾</span> في الآخرة <span class="qpc-hafs">﴿ما آتاهُمْ رَبُّهُمْ﴾</span> يعني: ما أعطاهم ربهم مِن الخير والكرامة في الجنة؛ <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذلِكَ﴾</span> الثواب في الدنيا <span class="qpc-hafs">﴿مُحْسِنِينَ﴾</span> في أعمالهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٦<span class="dash">-</span></span> عن محمد بن حُمَيد، قال:حدّثني <span class="name-3">سفيان الثوري</span> في قوله تعالى: <span class="qpc-hafs">﴿إن المتقين في جنات وعيون آخذين ما آتاهم ربهم﴾</span> قال: من ثواب الفرائض؛ <span class="qpc-hafs">﴿إنهم كانوا قبل ذلك محسنين﴾</span> قال: كانوا متطوّعين{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٠١. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٩/١١١.تفسير مقاتل بن سليمان ٤/١٢٨.أخرجه أبو نعيم في حلية الأولياء ٧/٧٧.
