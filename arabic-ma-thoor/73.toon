  73,19,""
  73,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ یَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَیِ ٱلَّیۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَاۤىِٕفَةࣱ مِّنَ ٱلَّذِینَ مَعَكَۚ﴾</span> - نزول الآية، والنسخ فيها{1}</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي عمرو بن العلاء، عن مجاهد-: أنها [أي: سورة المزمل] نزلت بمكة، فهي مكّيّة، إلا آيتين منها، فإنهما نَزَلَتا بالمدينة؛ وهما قوله تعالى: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ﴾</span> إلى آخرها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: لَمّا نزل أول المزمل كانوا يقومون نحوًا مِن قيامهم في شهر رمضان، وكان بين أولها وآخرها نحو من سنة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿يا أيُّها المزمل قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</span>: فلمّا قدم النبي ﷺ المدينة نَسَخَتْها هذه الآية: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ونِصْفَهُ وثُلُثَهُ وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ﴾</span> إلى آخرها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٥<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأَجْدع الهَمداني</span> -من طريق الشعبي-: هذه الآية: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ونِصْفَهُ وثُلُثَهُ وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ﴾</span> نَسَخَتْ: <span class="qpc-hafs">﴿قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿يا أيُّها المزمل قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</span> الآية، قال: لَبِثوا بذلك سنة، فشَقّ عليهم، وتوَرّمتْ أقدامهم، ثم نَسخَها آخر السورة: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</span>{6}. (١٥/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: لما نزلت على النبيِّ ﷺ: <span class="qpc-hafs">﴿يا أيُّها المزمل قُمِ اللَّيْلَ﴾</span> قام رسول الله ﷺ وقام المسلمون معه حَوْلًا كاملًا حتى تَورّمتْ أقدامهم، فأنزل الله بعد الحَوْل: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ﴾</span> إلى قوله: <span class="qpc-hafs">﴿ما تَيَسَّرَ مِنهُ﴾</span>. قال الحسن: فالحمد لله الذي جَعله تَطوّعًا بعد فريضة، ولابد من قيام الليل{6}. (١٥/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: فَرض الله قيام الليل في أول هذه السورة، فقام أصحاب النبيِّ ﷺ حتى انتَفختْ أقدامهم، وأَمسَك الله خاتمتها حَوْلًا، ثم أنزل الله التّخفيف في آخرها فقال: <span class="qpc-hafs">﴿عَلِمَ أنْ سَيَكُونُ مِنكُمْ مَرْضى﴾</span> إلى قوله: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</span>، فنَسَخ ما كان قبلها، فقال: <span class="qpc-hafs">﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</span> فريضتان واجبتان، ليس فيهما رخصة{8}. (١٥/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ﴾</span> إلى الصلاة <span class="qpc-hafs">﴿أدْنى﴾</span> يعني: أقل <span class="qpc-hafs">﴿مِن ثُلُثَيِ اللَّيْلِ﴾</span> وذلك أنّ النبي ﷺ والمؤمنين كانوا يقومون في أول الإسلام من الليل نصفه وثُلثه، وهذا قبل أن تُفرض الصلوات الخمس، فقاموا سنة، فشقّ ذلك عليهم، فنَزَلَت الرّخصة بعد ذلك عند السنة، فذلك قوله: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ... وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</span> يعني: وأَتِمُّوا الصلوات الخمس، وأَعطُوا الزكاة المفروضة من أموالكم، فنُسِخَ قيام الليل على المؤمنين، وثَبتَ قيام الليل على النبي ﷺ، وكان بين أول هذه السورة وآخرها سنة، حتى فُرضت الصلوات الخمس، والزكاة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ یَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَیِ ٱلَّیۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَاۤىِٕفَةࣱ مِّنَ ٱلَّذِینَ مَعَكَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٥٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥١<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق عباد- <span class="qpc-hafs">﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</span>، قالا: لن تُطيقوه{10}. (١٥/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</span> قال: أنْ خَفّف عنهم في القيام، <span class="qpc-hafs">﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</span> قال: علم أن لن تُطيقوا قيام الليل، <span class="qpc-hafs">﴿فَتابَ عَلَيْكُمْ﴾</span> قال: ثم أنبأنا الله تعالى بخصال المؤمنين، فقال: <span class="qpc-hafs">﴿عَلِمَ أنْ سَيَكُونُ مِنكُمْ مَّرْضى﴾</span> إلى آخر الآية{11}. (١٥/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ﴾</span> الآية، قال: أدنى من ثُلثي الليل، وأدنى من نصفه، وأدنى من ثُلثه{11}. (١٥/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</span> قيام الليل كُتب عليكم، <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥٥<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ﴾</span>، يريد: لا يَفوته عِلْمُ ما تَفعلون، أي: أنه يَعلم مقادير الليل والنهار، فيَعلم القَدْر الذي تقومون من الليل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ﴾</span> إلى الصلاة <span class="qpc-hafs">﴿أدْنى﴾</span> يعني: أقل <span class="qpc-hafs">﴿مِن ثُلُثَيِ اللَّيْلِ﴾</span> ... <span class="qpc-hafs">﴿وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ﴾</span> من المؤمنين يقومون نصفه وثلثه، ويقومون وينامون، <span class="qpc-hafs">﴿واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</span> يعني: قيام ثُلثي الليل الأول، ولا نصف الليل، ولا ثُلث الليل، <span class="qpc-hafs">﴿فَتابَ عَلَيْكُمْ﴾</span> يعني: فتَجاوز عنكم في التّخفيف بعد قوله: <span class="qpc-hafs">﴿قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٥٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</span>: أن لن تُطيقوه{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ یَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَیِ ٱلَّیۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَاۤىِٕفَةࣱ مِّنَ ٱلَّذِینَ مَعَكَۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٥٨<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «<b>خَلّتان لا يُحصيهما رجل مسلم إلا أدخلتاه الجنة، وهما يسير، ومَن يعمل بهما قليل: يُسبّح الله في دُبُر كلّ صلاة عشرًا، ويَحمده عشرًا، ويُكبّره عشرًا</b>». قال: فأنا رأيتُ رسول الله ﷺ يَعقدها بيده، قال: «<b>فتلك خمسون ومائة باللسان، وألف وخمسمائة في الميزان. وإذا أوى إلى فراشه سبّح وحمد وكبّر مائة، قال: فتلك مائة باللسان، وألف في الميزان، فأيّكم يعمل في اليوم الواحد ألفين وخمسمائة سيئة؟!</b>». قالوا: فكيف لا نُحصيهما؟ قال: «<b>ويأتي أحدكم الشيطان وهو في صلاته، فيقول: اذكر كذا، اذكر كذا. حتى يَنفَتل، ولعله لا يَعقل، ويأتيه وهو في مَضجعه فلا يزال ينوّمه حتى ينام</b>»{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنَ ٱلۡقُرۡءَانِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٥٩<span class="dash">-</span></span> عن ابن عباس، عن النبي ﷺ: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</span>، قال: «<b>مائة آية</b>»{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٠<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: خمسون آية{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق ربيع-: مَن قرأ مائة آية في ليلة لم يُحاجّه القرآن{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٢<span class="dash">-</span></span> عن أبي رجاء محمد، قال: قلتُ <span class="name-2">للحسن</span>: يا أبا سعيد، ما تقول في رجلٍ قد استَظهر القرآنَ كلّه عن ظهر قلبه، فلا يقوم به، إنما يُصلّي المكتوبة؟ قال: يَتوسّد القرآن، لعن الله ذاك؛ قال الله للعبد الصالح: <span class="qpc-hafs">﴿وإنَّهُ لَذُو عِلْمٍ لِما عَلَّمْناهُ﴾</span> [يوسف:٦٨]، <span class="qpc-hafs">﴿وعُلِّمْتُمْ ما لَمْ تَعْلَمُوا أنْتُمْ ولا آباؤُكُمْ﴾</span> [الأنعام:٩١]. قلت: يا أبا سعيد، قال الله: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</span>! قال: نعم، ولو خمسين آية{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق عثمان-: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</span> مائة آية{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</span> عليكم في الصلاة{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنَ ٱلۡقُرۡءَانِۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٦٥<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span> -من طريق أبي صالح-: مَن قرأ في ليلة مائة آية كُتب من القانتين{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٦<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأَجْدع الهَمداني</span> -من طريق الشعبي- قال: هذه الآية خيرٌ لأمة محمد ﷺ مِن أن يُعطى كلّ رجل مثل الدنيا <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَلِمَ أَن سَیَكُونُ مِنكُم مَّرۡضَىٰ وَءَاخَرُونَ یَضۡرِبُونَ فِی ٱلۡأَرۡضِ یَبۡتَغُونَ مِن فَضۡلِ ٱللَّهِ وَءَاخَرُونَ یُقَـٰتِلُونَ فِی سَبِیلِ ٱللَّهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٦٧<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>ما مِن جالبٍ يَجلب طعامًا إلى بلد من بلدان المسلمين، فيَبيعه بسعر يومه، إلا كانت منَزِلَتُه عند الله منزلة الشهيد</b>». ثم قرأ رسول الله ﷺ: <span class="qpc-hafs">﴿وآخَرُونَ يَضْرِبُونَ فِي الأَرْضِ يَبْتَغُونَ مِن فَضْلِ اللَّهِ وآخَرُونَ يُقاتِلُونَ فِي سَبِيلِ اللَّهِ﴾</span>{26}. (١٥/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عبيد الله- قال: ما من حالٍ يأتيني عليه الموت بعد الجهاد في سبيل الله أحبّ إلي من أن يأتيني وأنا بين شُعْبَتَيْ رَحْلي، ألتمس من فضل الله. ثم تلا هذه الآية: <span class="qpc-hafs">﴿وآخَرُونَ يَضْرِبُونَ فِي الأَرْضِ يَبْتَغُونَ مِن فَضْلِ اللَّهِ وآخَرُونَ يُقاتِلُونَ فِي سَبِيلِ اللَّهِ﴾</span>{27}. (١٥/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلِمَ أنْ سَيَكُونُ مِنكُمْ مَرْضى﴾</span> فلا يُطيقون قيام [الليل]، <span class="qpc-hafs">﴿وآخَرُونَ يَضْرِبُونَ فِي الأَرْضِ﴾</span> تجارًا <span class="qpc-hafs">﴿يَبْتَغُونَ مِن فَضْلِ اللَّهِ﴾</span> يعني: يَطلبون من فضل الله الرزق، <span class="qpc-hafs">﴿وآخَرُونَ يُقاتِلُونَ فِي سَبِيلِ اللَّهِ﴾</span> ولا يطيقون قيام الليل، فهذه رخصة من الله ﷿ لهم بعد التشديد{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنۡهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٧٠<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبيِّ ﷺ: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</span>، قال: «<b>مائة آية</b>»{29}. (١٥/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٧١<span class="dash">-</span></span> عن قيس بن أبي حازم، قال: صَلَّيتُ خلف <span class="name-1">عبد الله بن عباس</span>، فقرأ في أول ركعة بـ<span class="qpc-hafs">﴿الحَمْدُ لِلَّهِ﴾</span>، وأول آية من البقرة، ثم ركع، فلما انصرف أقبَل علينا، فقال: إنّ الله يقول: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</span>{30}. (١٥/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الربيع بن زيد- <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</span>، قال: يعني: في صلاة المغرب والعشاء{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٧٣<span class="dash">-</span></span> عن <span class="name-3">جعفر بن محمد</span> -من طريق ابنه موسى- في هذه الآية، قال: ما تَيَسَّرَ لكم فيه خشوع القلب، وصفاء السِّر{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ﴾</span> عليكم <span class="qpc-hafs">﴿مِنهُ﴾</span> يعني: من القرآن، فلم يُوقِّت شيئًا في صلواتكم الخمس منه{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنۡهُۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٧٥<span class="dash">-</span></span> عن أبي سعيد الخدري، قال: أمرنا رسول الله ﷺ أن نقرأ بفاتحة الكتاب، وما تيسّر{34}. (١٥/٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقِیمُوا۟ ٱلصَّلَوٰةَ وَءَاتُوا۟ ٱلزَّكَوٰةَ وَأَقۡرِضُوا۟ ٱللَّهَ قَرۡضًا حَسَنࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٧٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾</span>، يريد: ما سوى الزكاة؛ من صِلة الرَّحِم، وقِرى الضيف{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٧٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾</span> هذا في التَّطوّع{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</span>: فهما فريضتان واجبتان، لا رخصة لأحد فيهما، فأدّوهما إلى الله -تعالى ذِكْره-{37}<span class=comment-ref>٦٨٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٤٤٨): «والصلاة والزكاة هنا المفروضتان، <b>ومَن قال</b>: إنّ القيام بالليل غير واجب قال: معنى الآية: خُذوا من هذا الثِّقل بما تيسّر وحافِظوا على فرائضكم. <b>ومَن قال</b>: إنّ شيئًا من القيام واجب قال: قرنه الله بالفرائض لأنه فرض».</div></p><p><div></p><p><p><span class="item-no">٧٩٥٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</span> يعني: وأَتِمُّوا الصلوات الخمس، وأَعطوا الزكاة المفروضة من أموالكم، فنُسِخَ قيام الليل على المؤمنين، وثَبتَ قيام الليل على النبي ﷺ، وكان بين أول هذه السورة وآخرها سنة، حتى فُرضت الصلوات الخمس والزكاة، فهما واجبتان، فذلك قوله: <span class="qpc-hafs">﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</span> يقول: وأَعطوا الزكاة من أموالكم، <span class="qpc-hafs">﴿وأَقْرِضُوا اللَّهَ﴾</span> يعني: التَّطوّع <span class="qpc-hafs">﴿قَرْضًا حَسَنًا﴾</span> يعني بالحسن: طيِّبة بها نفسه، يَحتسبها تَطوّعًا بعد الفريضة، <span class="qpc-hafs">﴿وما تُقَدِّمُوا لِأَنْفُسِكُمْ مِن خَيْرٍ﴾</span> يعني: مِن صدقة؛ فريضة كانت أو تَطوّعًا؛ يقول: <span class="qpc-hafs">﴿تَجِدُوهُ عِنْدَ اللَّهِ هُوَ خَيْرًا﴾</span> ثوابًا عند الله في التقديم <span class="qpc-hafs">﴿هُوَ خَيْرًا وأَعْظَمَ أجْرًا﴾</span> يقول: أفضل مما أعطيتم من أموالكم وأعظم أجرًا، يعني: وأكثر خيرًا وأفضل خيرًا في الآخرة، <span class="qpc-hafs">﴿واسْتَغْفِرُوا اللَّهَ﴾</span> من الذّنوب؛ <span class="qpc-hafs">﴿إنَّ اللَّهَ غَفُورٌ﴾</span> لكم عند الاستغفار إذا استغفرتموه، <span class="qpc-hafs">﴿رَحِيمٌ﴾</span> حين رخّص لكم بالتوبة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾</span>، قال: القرض: النوافل، سوى الزكاة{37}. (ز)</p></p><p></div></p></div>",footnotes:1:تقدم في أول السورة آثار في ذلك.أخرجه النحاس في الناسخ والمنسوخ ص٧٥١، من طريق يموت بن المُزَرِّع، عن أبي حاتم سهل بن محمد السِّجستاني، عن أبي عبيدة معمر بن المثنى، عن يونس بن حبيب، عن أبي عمرو بن العلاء، عن مجاهد، عن ابن عباس به.</p><p>وسنده صحيح.أخرجه ابن جرير ٢٣/٣٦٢، من طريق سِماك، عن عكرمة، عن ابن عباس به.</p><p>وسنده ضعيف؛ من أجل رواية سِماك بن حرب عن عكرمة، قال ابن حجر في التقريب (٢٦٢٤): «روايته عن عكرمة خاصة مضطربة».أخرجه القاسم بن سلام في الناسخ والمنسوخ ص٢٥٦ (٤٦٧)، والنحاس في الناسخ والمنسوخ ص٧٥٣، من طريق عطاء الخُراسانيّ، عن ابن عباس به.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٠-.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن نصر في مختصر قيام الليل ص٣، وابن جرير ٢٣/٣٩٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٢-. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٧٨-٤٧٩.أخرجه ابن جرير ٢٣/٣٩٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٣٩٥.تفسير البغوي ٨/٢٥٧.تفسير مقاتل بن سليمان ٤/٤٧٨، ٤٧٩.أخرجه ابن جرير ٢٣/٣٩٤.أخرجه أحمد ١١/٤٠-٤١ (٦٤٩٨)، ١١/٥٠٩-٥١١ (٦٩١٠)، وابن ماجه ٢/٨٦ (٩٢٦)، وأبو داود ٧/٤٠١-٤٠٢ (٥٠٦٥)، والترمذي ٦/٣٣-٣٤ (٣٧٠٩)، والنسائي ٣/٧٤ (١٣٤٨)، وابن حبان ٥/٣٥٤ (٢٠١٢)، ٥/٣٦١-٣٦٢ (٢٠١٨)، وابن جرير ٢٣/٣٩٤-٣٩٥، من طريق عطاء بن السّائِب، عن أبيه، عن عبد الله بن عمرو به.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال النووي في الأذكار ص١٥٢-١٥٣ (٤١١): «إسناده صحيح، إلا أنّ فيه عطاء بن السّائِب، وفيه اختلاف بسب اختلاطه؛ وقد أشار أيوب السّختياني إلى صحة حديثه هذا». وقال المناوي في التيسير ١/٥١٦: «إسناد صحيح».أخرجه الطبراني في الكبير ١١/٢٩ (١٠٩٤٠). وأورده الديلمي في الفردوس ٣/١٥١ (٤٤٠٩).</p><p>قال ابن كثير في تفسيره ٨/٢٥٩: «وهذا حديث غريب جدًّا». وقال الهيثمي في المجمع ٧/١٣٠ (١١٤٤٧): «فيه عبد الرحمن بن طاووس، ولم أعرفه، وبقية رجاله وُثِّقوا».تفسير الثعلبي ١٠/٦٥.أخرجه ابن جرير ٢٣/٣٩٦.أخرجه ابن جرير ٢٣/٣٩٦.أخرجه ابن جرير ٢٣/٣٩٦.تفسير مقاتل بن سليمان ٤/٤٧٩.أخرجه ابن جرير ٢٣/٣٩٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٠-.أخرجه ابن مردويه -كما في تخريج الكشاف ٤/١١٢-، وفي إسناده فرقد السبخي.</p><p>قال العراقي في تخريج أحاديث الإحياء ص٥١٦: «سند ضعيف». وقال ابن حجر في الكافِ الشاف ص١٧٩ (٢٤٣): «فرقد ضعيف».أخرجه البيهقي في شعب الإيمان (١٢٥٦). وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٧٩.تقدم تخريجه برقم (٢٣٨).أخرجه الدارقطني ١/٣٣٨، والبيهقي في سننه ٢/٤٠.تفسير الثعلبي ١٠/٦٥، وتفسير البغوي ٨/٢٥٧.أخرجه الثعلبي ١٠/٦٦.تفسير مقاتل بن سليمان ٤/٤٧٨-٤٧٩.أخرجه أحمد ١٧/٣٠ (١٠٩٩٨)، ١٨/١٣ (١١٤١٥)، ١٨/٤١٢ (١١٩٢٢)، وأبو داود ٢/١١١-١١٢ (٨١٨)، وابن حبان ٥/٩٢ (١٧٩٠)، من طريق قتادة، عن أبي نضرة، عن أبي سعيد به.</p><p>قال ابن حجر في الفتح ٢/٢٤٣: «سند قوي». وقال في التلخيص الحبير ١/٥٦٧: «إسناده صحيح». وقال القاري في مرقاة المفاتيح ٢/٦٨٣: «صحّ عن أبي سعيد». وقال الشوكاني في نيل الأوطار ٢/٢٤٨: «قال ابن سيد الناس: وإسناده صحيح، ورجاله ثقات». وقال الألباني في صحيح أبي داود ٣/٤٠١ (٧٧٧): «إسناده صحيح، على شرط مسلم».تفسير البغوي ٨/٢٥٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٢-.أخرجه ابن جرير ٢٣/٣٩٨.تفسير مقاتل بن سليمان ٤/٤٧٨-٤٧٩.أخرجه ابن جرير ٢٣/٣٩٨.
  74,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٨١<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة المُدَّثِّر بمكة{1}. (١٥/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٢<span class="dash">-</span></span> عن عبد الله بن الزُّبير، مثله{2}. (١٥/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكّيّة، ونزلت بعد: <span class="qpc-hafs">﴿يا أيُّها المُزَّمِّل﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٤<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٥<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٦<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٧<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة،، وذكرها بمسمّى: <span class="qpc-hafs">﴿يا أيها المُدَّثِّر﴾</span>، وأنها نزلت بعد: <span class="qpc-hafs">﴿يا أيُّها المُزَّمِّل﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٨<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٨٩<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة المُدَّثِّر مكّيّة، عددها ست وخمسون آية كوفي{8}<span class=comment-ref>٦٨٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٣</span> قال <u>ابن عطية</u> (٨/٤٥٠): «وهي مكّيّة <span class="mustanad">بإجماع من أهل التأويل</span>».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٥٧) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤، من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٨٧.
  74,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١ قُمۡ فَأَنذِرۡ ۝٢﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٩٠<span class="dash">-</span></span> عن يحيى بن أبي كَثِير، قال: سألتُ <span class="name-1">أبا سَلمة بن عبد الرحمن</span> عن أول ما نَزَل من القرآن. فقال: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>. قلتُ: يقولون: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</span>. فقال أبو سَلمة: سألتُ جابر بن عبد الله عن ذلك، قلتُ له مثل ما قلتَ، قال جابر: لا أُحدِّثك إلا ما حَدَّثنا رسول الله ﷺ، قال: «<b>جاورتُ بحِراء، فلمّا قَضيتُ جواري هبَطتُ، فنُوديتُ، فنَظرتُ عن يميني، فلم أرَ شيئًا، ونظرتُ عن شمالي، فلم أرَ شيئًا، ونظرتُ خلفي، فلم أرَ شيئًا، فرفعتُ رأسي فإذا المَلَك الذي جاءني بحِراء جالس على كرسي بين السماء والأرض، فجُئِثْتُ</b>{1} <b>منه رُعبًا، فرجعتُ فقلتُ: دَثِّروني، فدَثَّروني</b>»، فنزلت: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر قُمْ فَأَنْذِرْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>{2}<span class=comment-ref>٦٨٦٤</span>. (١٥/٦١)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٤</span> <span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٤/١٧٦) <span class="mustanad">بهذا الأثر</span> أنّ الآيات الأولى من سورة اقرأ هي أول آيات القرآن نزولًا، حيث قال <span class="comment-type-4">معلقًا</span> على هذا الأثر: «هذا السياق هو المحفوظ، وهو يقتضي أنه قد نَزل الوحي قبل هذا؛ لقوله: «<b>فإذا المَلَك الذي جاءني بحِراء</b>». وهو جبريل حين أتاه بقوله: <span class="qpc-hafs">﴿اقرأ باسم ربك الذي خلق ...﴾</span>، ثم إنه حَصل بعد هذا فترة، ثم نزل الملك بعد هذا». ثم <span class="comment-type-1">وجّه</span> ما جاء في بعض الروايات عن جابر وتفيد أنّ آيات المُدَّثِّر هي أول آيات القرآن نزولًا بقوله: «ووجه الجمع: أنّ أول شيء نَزل بعد فترة الوحي هذه السورة».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ تيمية</u> (٦/٤١٩).</div></p><p><div></p><p><p><span class="item-no">٧٩٥٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مُلَيْكَة-: أنّ الوليد بن المُغيرة صَنع لقريش طعامًا، فلمّا أكلوا قال: ما تقولون في هذا الرجل؟ فقال بعضهم: ساحر. وقال بعضهم: ليس بساحر. وقال بعضهم: كاهن. وقال بعضهم: ليس بكاهن. وقال بعضهم: شاعر. وقال بعضهم: ليس بشاعر. وقال بعضهم: سحرٌ يُؤثر. فاجتمع رأيهم على أنه سحرٌ يُؤثر، فبَلغ ذلك النبيَّ ﷺ، فحَزن، وقنَّع رأسه، وتَدثّر؛ فأنزل الله: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span> إلى قوله: <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span>{3}. (١٥/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span> -من طريق المُغيرة- <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، قال: كان مُتَدَثِّرًا في قَطيفة، وذُكر أنّ هذه الآية أول شيء نَزل من القرآن على رسول الله ﷺ، وأنه قيل له: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٣<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزُّهريّ</span> -من طريق معمر- قال: فَتَر الوحيُ عن رسول الله ﷺ فَتْرةً، فحَزِن حُزنًا، فجعل يعدو إلى شواهق رؤوس الجبال ليَتَردّى منها، فكلّما أوفى بذُروة جبل تبَدّى له جبريل ﵇، فيقول: إنّك نبي الله. فيَسكن لذلك جأْشه، وتَرجع إليه نفسه؛ فكان النبي ﷺ يُحدِّث عن ذلك، قال: «<b>فبينما أنا أمشي يومًا إذ رأيتُ المَلَك الذي كان يأتيني بحِراء على كرسي بين السماء والأرض، فجُثِثْتُ</b>{5} <b>منه رُعبًا، فرَجعتُ إلى خديجة، فقلتُ: زَمِّلُوني</b>». فزَمَّلناه، أي: فدَثَّرناه؛ فأنزل الله: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر قُمْ فَأَنْذِرْ ورَبَّكَ فَكَبِّرْ وثِيابَكَ فَطَهِّرْ﴾</span>. قال الزُّهريّ: فكان أول شيء أُنزل عليه: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</span> حتى بلغ: <span class="qpc-hafs">﴿ما لَمْ يَعْلَمْ﴾</span>{6}<span class=comment-ref>٦٨٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٥</span> لم يذكر <u>ابن جرير</u> (٢٣/٤٠٠-٤٠٣) غير قول الزُّهريّ، وإبراهيم النَّخَعي.</div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزُّهريّ</span> أنه قال: ... ويزعم ناسٌ أنّ <span class="qpc-hafs">﴿يا أيها المُدَّثِّر﴾</span> أول سورة أُنزِلَتْ عليه، والله أعلم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، يعني: النبي ﷺ، وذلك أنّ كفار مكة آذَوه، فانطَلق إلى جبل حِراء ليتوارى عنهم، فبينما هو يمشي إذ سمع مناديًا يقول: يا محمد. فنظر يمينًا وشمالًا وإلى السماء، فلم يرَ شيئًا، فمَضى على وجهه، فنُودي الثانية: يا محمد. فنظر يمينًا وشمالًا ومن خلفه، فلم يرَ شيئًا إلا السماء، ففَزع، وقال: لعلّ هذا شيطان يدعوني. فمَضى على وجهه، فنودي في قفاه: يا محمد، يا محمد. فنظر خلفه وعن يمينه وعن شماله، ثم نظر إلى السماء، فرأى مثل السرير بين السماء والأرض، وعليه دَرْبوكة{8} قد غَطَّت الأُفُق، وعليه جبريل ﵇ مثل النور المتوقِّد يتلألأ، حتى كاد أن يَغشى البصر، ففَزع فزعًا شديدًا، ثم وقَع مغشيًّا عليه، ولبث ساعة، ثم أفاق، فقام يمشي -وبه رِعْدة شديدة، ورِجلاه تَصطكّان- راجعًا حتى دخل على خديجة، فدعا بماء، فصَبّه عليه، فقال: دثِّروني. فدَثَّروه بقَطيفة حتى استدفأ، فلمّا أفاق قال: لقد أشفقتُ على نفسي. قالت له خديجة: أبشِر، فواللهِ، لا يسوءُك الله أبدًا؛ لأنك تَصدق الحديث، وتَصِل الرَّحِم، وتَحمل الكَلّ، وتَقري الضيف، وتُعين على نوائب الخير. فأتاه جبريل ﵇ وهو مُتَقنِّع بالقَطيفة، فقال: يا أيها المُتَدَثِّر بقَطيفته، المُتَقَنِّع فيها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال جابر بن عبد الله: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span> هذه أول آية نزلت على النبي، والعامّة على أنّ أول ما نَزل: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</span>{10}<span class=comment-ref>٦٨٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٦</span> في أول آيات القرآن نزولًا قولان، كما في قول يحيى بن سلام.</p><p>وقد <span class="comment-type-3">رجح</span> <u>ابنُ عطية</u> (٨/٤٥١) -<span class="mustanad">مستندًا إلى السنة</span>- أن الآيات الأولى من سورة اقرأ هي أول القرآن نزولًا، فقال: «واختلف الناس في أول ما نزل من كتاب الله تعالى؛ فقال جابر بن عبد الله، وأبو سلمة، والنَّخَعي، ومجاهد هو: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span> الآيات. وقال الزُّهريّ، والجمهور هو: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</span>، وهذا هو الأصح، وحديث صدر كتاب البخاري نص في ذلك».</div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٧<span class="dash">-</span></span> قال ابن هشام: حَدَّثني بعض أهل العلم: أنّ أشدّ ما لقي رسول الله ﷺ من قريش أنه خرج يومًا فلم يَلقه أحد من الناس إلا كَذَّبه وآذاه، لا حرٌّ ولا عبدٌ، فرجع رسول الله ﷺ إلى منزله، فتَدثَّر من شدّة ما أصابه؛ فأَنزل الله تعالى عليه: <span class="qpc-hafs">﴿يا أيها المُدَّثِّر قم فأنذر﴾</span>{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٥٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، قال: دُثِّرْتَ هذا الأمرَ، فقُم به{12}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٥٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، قال: النائم{13}. (١٥/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span>-من طريق المغيرة- <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، قال: كان مُتَدَثِّرًا في قَطيفة، يعني: شَملة صغيرة الخَمْلِ{14}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، أنه قال: دُثِّرْتَ هذا الأمر فقُم به{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span>، قال: المُتَدَثِّر في ثيابه{16}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها المُدَّثِّر﴾</span> يعني: النبي ﷺ ... أتاه جبريل ﵇ وهو مُتَقنِّع بالقَطيفة، فقال: يا أيها المُتَدَثِّر بقَطيفته، المُتَقَنِّع فيها{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُمۡ فَأَنذِرۡ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قُمْ فَأَنْذِرْ﴾</span>، قال: أنذِر عذابَ ربك، ووقائعَه في الأمم، وشدّة نِقمته إذا انتقم{16}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُمْ فَأَنْذِرْ﴾</span> كفارَ مكةَ العذابَ إن لم يُوحِّدوا الله تعالى{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أي: ذُعرتُ وخِفتُ. يُقال: جُئِث الرجل: إذا فزع. النهاية (جأث).أخرجه البخاري ٦/١٦١-١٦٢ (٤٩٢٢- ٤٩٢٤)، ومسلم ١/١٤٤ (١٦١)، وابن جرير ٢٣/٤٠٠-٤٠٣، وابن مردويه -كما في التغليق ٤/٣٥٤-، والثعلبي ١٠/٦٧-٦٨.أخرجه الطبراني في الكبير ١١/١٢٥ (١١٢٥٠).</p><p>قال الهيثمي في المجمع ٧/١٣١ (١١٤٤٨): «وفيه إبراهيم بن يزيد الخوزي، وهو متروك». وقال السيوطي: «سند ضعيف».أخرجه ابن جرير ٢٣/٤٠٠.أي: فزعت منه وخفت. وقيل معناه: قلعت من مكاني، من قوله تعالى: <span class="qpc-hafs">﴿اجتثت من فوق الأرض﴾</span> [إبراهيم:٢٦]، وقال الحربي: أراد جُئِثت، فجعل مكان الهمزة ثاء. النهاية (جثث).أخرجه عبد الرزاق ٢/٣٢٧، وابن جرير ٢٣/٤٠٣.أخرجه البيهقي في دلائل النبوة ٢/١٤٢.دَرْبوكة: في كتاب «تكملة المعاجم العربية» لرينهارت بيتر ٤/٣١٤: دَرْبوكة: محفَّة، مَحْمَل ... دربوكة بالكاف الفارسية، وهي شبه قفص من الخشب تنقل فيه العروس الشابة يوم الزفاف من بيت أهلها إلى بيت الزوجية.تفسير مقاتل بن سليمان ٤/٤٨٩-٤٩٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٤-.سيرة ابن هشام ١/٢٧٤-٢٧٥.أخرجه الحاكم ٢/٥٠٦.أخرجه ابن جرير ٢٣/٤٠٤ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٣/٤٠٠، وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٠٤.أخرجه ابن جرير ٢٣/٤٠٤. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨٩-٤٩٠.أخرجه ابن جرير ٢٣/٤٠٤. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨٩-٤٩٠.
  74,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَرَبَّكَ فَكَبِّرۡ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿ورَبَّكَ فَكَبِّرْ﴾</span>، قال: عَظِّم{1}. (١٥/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورَبَّكَ فَكَبِّرْ﴾</span> يعني: فعَظِّم، ولا تعظمن كفار مكة في نفسك. فقام من مضجعه ذلك، فقال: «<b>الله أكبر كبيرًا</b>». فكبّرتْ خديجة، وخَرجتْ، وعَلمتْ أنه قد أُوحي إليه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٠.
  74,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَثِیَابَكَ فَطَهِّرۡ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٠٨<span class="dash">-</span></span> قال <span class="name-1">أُبيّ بن كعب</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span> لا تلبسها على غَدرٍ، ولا على ظُلمٍ، ولا إثم، البسْها وأنت بَرٌّ جواد طاهر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: لا تَكُن ثيابُك التي تلبِس من مَكْسِبة{2} باطل{3}. (١٥/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: من الإثم. قال: وهي في كلام العرب: نقيُّ الثياب{4}. (١٥/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: مِن الغدر، لا تَكُن غدّارًا{5}. (١٥/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: لستَ بساحر، ولا كاهن{5}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٣<span class="dash">-</span></span> عن عكرمة: أنّ <span class="name-1">عبد الله بن عباس</span> سُئل عن قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>. قال: لا تَلبسها على غَدْرةٍ، ولا فَجْرةٍ. ثم قال: ألا تسمعون قول غَيلان بن سَلمة:</p><p>وإني بحمد الله لا ثوبَ فاجرٍ لَبِستُ ولا من غَدْرةٍ أتقنّع{7}. (١٥/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٤<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق منصور- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: عمَلك أصلِحْهُ، كان أهل الجاهلية إذا كان الرجل حسنَ العمل قالوا: فلانٌ طاهر الثياب{8}. (١٥/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: كان الرجل في الجاهلية إذا كان غدّارًا قالوا: فلانٌ دَنِسُ الثياب{9}. (١٥/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٦<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span> وقلبك ونيَّتك فطهِّر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span>، <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: مِن الإثم{11}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: وعمَلَك فأصلِح{12}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: لستَ بكاهن، ولا ساحر؛ فأَعرِض عما قالوا{13}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: ليس ثيابه الذي يَلبس{14}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، يقول: لا تَلبس ثيابك على معصية{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>-من طريق أبي روق- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>: وعمَلك فأصلِح{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الأَجْلَح- قال: لا تَلبس ثيابك على معصية{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: عَنى نفسه{14}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٥<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٦<span class="dash">-</span></span> و<span class="name-2">عطاء</span> -من طريق جابر- قالا: من الخطايا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٧<span class="dash">-</span></span> قال <span class="name-2">طاووس بن كيسان</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span> وثيابك فقصِّر؛ لأنّ تقصير الثياب طُهرةٌ لها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: خُلُقك فحَسِّنه{21}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٢٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق ابن عون- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: اغسلها بالماء{22}. (١٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، يقول: طهِّرها من المعاصي، وهي كلمة عربية، كانت العرب إذا نَكث الرجل ولم يُوفِ بعهده قالوا: إنّ فلانًا لَدَنِسُ الثياب. وإذا وفى وأَصلَح قالوا: إنّ فلانًا لَطاهرُ الثياب{23}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣١<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span> وخُلقك فحسِّن{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٢<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزُّهريّ</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span> نفسك فطهِّر عن الذّنب{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span> يقال للرجل إذا كان صالحًا: إنّه لَطاهرُ الثياب، وإذا كان فاجرًا: إنّه لَخبيث الثياب{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٤<span class="dash">-</span></span> عن <span class="name-2">يزيد بن مَرثَد</span>، في قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>: أنه أُلقي على رسول الله ﷺ سلا{27} شاة{21}. (١٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، يقول: طهِّر بالتوبة من المعاصي. وكانت العرب تقول للرجل إذا أذنب: إنّه دَنِس الثياب، وإذا تَوقّى قالوا: إنّه لَطاهرُ الثياب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وثِيابَكَ فَطَهِّرْ﴾</span>، قال: كان المشركون لا يَتطهَّرون، فأمره أن يَتطهَّر، ويُطهِّر ثيابه{30}<span class=comment-ref>٦٨٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٧</span> اختُلف في قوله: <span class="qpc-hafs">﴿وثيابك فطهر﴾</span> على أقوال: <b>الأول</b>: لا تَلبس ثيابك على معصية، ولا على غَدْرة. <b>الثاني</b>: لا تَلبس ثيابك من مَكسبٍ غير طيّب. <b>الثالث</b>: أصلِح عملك. <b>الرابع</b>: اغسلها بالماء، وطهِّرها من النجاسة. <b>الخامس</b>: حَسِّن خُلقك. <b>السادس</b>: طهِّر قلبك ونيّتك.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٤٥٢) على القول الأول والثاني بقوله: «وهذا كلّه معنًى قريب بعضه من بعض».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٣/٤٠٩-٤١٠) <span class="mustanad">-مستندًا إلى أنه الأظهر</span>- القول الرابع، فقال: «وهذا القول الذي قاله ابن سيرين، وابن زيد في ذلك أظهر معانيه». ثم قال <span class="comment-type-4">معلقًا</span>: «والذي قاله ابن عباس، وعكرمة، ومَن ذكرنا قوله عليه أكثر السلف من أنه عني به: جسمك فطَهِّر من الذّنوب. والله أعلم بمراده من ذلك».</p><p>ولم يذكر <u>ابنُ تيمية</u> (٦/٤٢٠-٤٢٢) غير القول الثالث والرابع، و<span class="comment-type-3">رجّح</span> أنّ الآية <span class="mustanad">تعمّهما</span>، فقال: «والأشبه -والله أعلم- أنّ الآية تعمُّ نوعي الطهارة، وتشمل هذا كلَّه، فيكون مأمورًا بتطهير الثياب المتضمّنة تطهير البدن والنفس مِن كلّ ما يُستقذر شرعًا مِن الأعيان والأخلاق والأعمال؛ لأنّ تطهيرها أن تُجعل طاهرة، ومتى اتصل بها وبصاحبها شيءٌ مِن النجاسة لم تكن مُطهّرة على الإطلاق؛ فإنها متى أُزيل عنها نَجسٌ دون نَجس لم تكن قد طَهرتْ حتى يزال عنها كلّ نَجس، بل كلّ ما أمر الله باجتنابه من الأرجاس وجَب التطهير منه، وهو داخل في عموم هذا الخطاب».</div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٦٨، وتفسير البغوي ٨/٢٦٤.المَكْسِبة والكسب والكِسبة بمعنًى. التاج (كسب).أخرجه ابن جرير ٢٣/٤٠٨ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٣/٤٠٦، وفي لفظ عنده: من الذنوب، والحاكم ٢/٥٠٦. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٤٠٥. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن الأنباري في الوقف والابتداء، وابن مردويه.أخرجه ابن جرير ٢٣/٤٠٩، وابن أبي شيبة ١٣/٤١٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٥.عزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر. وأخرجه ابن جرير ٢٣/٤٠٦ من طريق مغيرة بلفظ: من الذّنوب.أخرجه ابن جرير ٢٣/٤٠٨. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٠٧.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٤.أخرجه ابن جرير ٢٣/٤٠٨.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٠٨.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٠٧، وعبد الرزاق ٢/٣٢٧-٣٢٨ من طريق معمر بنحوه، وكذا ابن جرير. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٤- بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٥.تفسير الثعلبي ١٠/٦٨، وتفسير البغوي ٨/٢٦٤، وجاء عقبه: فكنى عن النفس بالثوب.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٤.السلا: الجلد الرقيق الذي يخرج فيه الولد مِن بطن أمه ملفوفًا فيه، وقيل في الماشية: السلا، وفي الناس: المشيمة. والأول أشبه؛ لأنّ المشيمة تخرج بعد الولد، ولا يكون فيها حين يخرج. النهاية ٢/٣٩٦.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤٠٩.
  74,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ ۝٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٣٧<span class="dash">-</span></span> عن جابر بن عبد الله، قال: سمعتُ رسول الله ﷺ يقرأ: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span> برفع الراء ...{1}. (١٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٨<span class="dash">-</span></span> عن عبد الله بن مسعود، أنه قرأ على رسول الله ﷺ: ‹والرِّجْزَ فاهْجُرْ› بالكسر{2}. (١٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٣٩<span class="dash">-</span></span> عن أبي محمد يحيى بن زكريا الكوفي -ويُعرف بابن أبي الحواجب-، قال: كنت آخِذًا بيد الأعمش أقوده، فقلت له: كيف تقرأ: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span> أو ‹والرِّجْزَ فاهْجُرْ›؟ فقال: أوَهمَّك ذلك؟ قرأتُ القرآن على يحيى بن وثّاب ثلاثين مرة كلّه يقرأ كذلك، وكذلك قرأ يحيى على عَلقمة، وكذلك قرأ عَلقمة على ابن مسعود، وابن مسعود على رسول الله ﷺ، يعني: <span class="qpc-hafs">﴿الرُّجْزَ﴾</span> بالضم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أنه كان يقرؤها: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span> بالرفع ...{4}<span class=comment-ref>٦٨٦٨</span>. (١٥/٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٨</span> ذكر <u>ابن جرير</u> (٢٣/٤١٠) قراءة الرفع والكسر، و<span class="comment-type-1">وجّههما</span>، فقال: «فمَن ضَم الراء وجّهه إلى الأوثان، وقال: معنى الكلام: والأوثان فاهجُر عبادتها، واترك خدمتها. ومَن كسر الراء وجّهه إلى العذاب، وقال: معناه: والعذاب فاهجُر. أي: ما أوجب لك العذاب من الأعمال فاهجُر». و<span class="comment-type-4">علّق</span> عليهما قائلًا: «والصواب من القول في ذلك أنهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب، والضم والكسر في ذلك لغتان بمعنًى واحد، ولم نجد أحدًا من متقدمي أهل التأويل فَرّق بين تأويل ذلك، وإنما فَرّق بين ذلك فيما بلغنا الكسائي».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٥/٣٩٣ ط: دار الكتب العلمية بتصرف) على القراءتين بقوله: «قيل: هما بمعنًى، يراد بهما: الأصنام والأوثان، وقيل: هما لمعنيين: الكسر للنّتن والنقائص وفُجور الكفار، والضم لصنمين إساف ونائلة».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ ۝٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٤١<span class="dash">-</span></span> عن جابر بن عبد الله، قال: سمعتُ رسول الله ﷺ يقرأ: <span class="qpc-hafs">﴿والرُّجْز فاهْجُرْ﴾</span> برفع الراء، وقال: «<b>هي الأوثان</b>»{5}. (١٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: الأصنام{6}. (١٥/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>: معناه: اترك المآثم{7}<span class=comment-ref>٦٨٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٦٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٥٢) <b>قولًا</b> آخر عن ابن عباس، فقال: «وقال ابن عباس: الرُّجز: السخط». ثم <span class="comment-type-1">وجّهه</span> بقوله: «فالمعنى: اهجر ما يؤدي إليه، ويُوجبه».</div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٤<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٥<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿الرُّجز﴾</span> -بضم الراء-: الصنم. -وبالكسر-: النجاسة والمعصية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span> -من طريق مغيرة- <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: الإثم{9}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: الأوثان{10}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، يقول: اهجر المعصية{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٤٩<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، يعني: الشّرك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: الشيطان، والأوثان{13}. (١٥/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: الأوثان{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه كان يقرؤها: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span> بالرفع، وقال: هي الأوثان{4}. (١٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: هما صنمان كانا عند البيت؛ إساف ونائلة، يَمسح وجوههما مَن أتى عليهما من المشركين، فأمر الله نبيَّه ﷺ أن يَهجرهما ويُجانبهما{16}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزُّهريّ</span> -من طريق معمر- <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: هي الأوثان{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿والرجز فاهجر﴾</span>، قال: الأوثان{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، يعني: العذاب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span> يعني: الأوثان؛ يساف ونائلة، وهما صنمان عند البيت، يَمسح وجوهَهما مَن مَرّ بهما مِن كفار مكة، فأمَر الله -تبارك وتعالى- النبيَّ ﷺ أن يجتنبهما. يعني بالرجز: أوثانًا لا تَتحرّك، بمنزلة الإبل، يعني: داء يأخذها ذلك الداء فلا تَتحرّك مِن وجع الرّجز، فشبّه الآلهة بها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿والرُّجْزَ فاهْجُرْ﴾</span>، قال: الرُّجز: آلهتهم التي كانوا يَعبدون، أمَره أن يَهجرها، فلا يأتيها، ولا يَقربها{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٢٧٥ (٢٩٩٢)، من طريق محمد بن كثير المصيصي، عن معمر، عن الزُّهريّ، عن أبي سَلمة بن عبد الرحمن، عن جابر بن عبد الله به.</p><p>قال ابن عدي في الكامل ٧/٥٠٠-٥٠١ (١٧٣٢) في ترجمة محمد بن كثير أبي يوسف المصيصي: «حدثنا ابن حماد، حدثني عبد الله بن أحمد، سمعت أبي، وذكر محمد بن كثير المصيصي فضعّفه جدًّا، وقال: سمع من معمر، ثم بَعَث إلى اليمن بعد، فأخذها، فرواها. يعني: أحاديث معمر. وقال: هو منكر الحديث. أو قال: هو يروي أشياء مُنكرة». ثم ذكر الحديث، وقال عقبه: «ومحمد بن كثير له روايات عن معمر، والأوزاعي خاصة، أحاديث عداد مما لا يُتابعه أحد عليه».</p><p>والقراءة متواترة، قرأ بها يعقوب، وأبو جعفر، وحفص، وقرأ بقية العشرة: ‹والرِّجْزَ› بكسر الراء. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٧١.أخرجه الطبراني (١٠٠٧٠)، والحاكم ٢/٢٥١. وعزاه السيوطي إلى ابن مردويه.</p><p>وصححه الحاكم.ذكره في الإيماء ٤/٥١٤ (٤٠٧٠)، وعزاه إلى الأفراد لابن شاهين (٤٩).عزاه السيوطي إلى عَبد بن حُمَيد.تقدم تخريجه في قراءات الآية.أخرجه ابن جرير ٢٣/٤١٠ بنحوه، ومن طريق علي بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.تفسير البغوي ٨/٢٦٥.أخرجه ابن جرير ٢٣/٤١١. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١١، كذلك من طريق جابر أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٢.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١١.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤١١. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٢٨، وابن جرير ٢٣/٤١١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٥.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤١١.
  74,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٥٩<span class="dash">-</span></span> عن حمّاد بن أبي سليمان، قال: قرأتُ في مصحف <span class="name-1">أُبيّ [بن كعب]</span>: (ولا تَمْنُنْ أن تَستَكْثِر){1}. (١٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٠<span class="dash">-</span></span> قال يحيى بن سلام: وكان <span class="name-2">الحسن البصري</span> يقرؤها: (تَسْتَكْثِرْ) موقوفة{2}<span class=comment-ref>٦٨٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٠</span> <span class="comment-type-4">علق</span> <u>ابنُ عطية</u> (٨/٣٩٣ ط: دار الكتب العلمية) على هذه القراءة، فقال: «وقرأ الحسن بن أبي الحسن: (تَسْتَكْثِرْ) بجزم الراء، وذلك كأنه قال: لا تَسْتَكْثِرْ».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ الرجل عطاءً رجاءَ أن يُعطيك أكثر منه{3}. (١٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span> قال: لا تَقُلْ: قد دَعوتُهم فلم يُقبل مني. عُد، فادْعُهم، <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span> على ذلك{4}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ شيئًا تَطلب أكثر منه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٤<span class="dash">-</span></span> عن <span class="name-2">أبي الأَحْوَص</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٥<span class="dash">-</span></span> و<span class="name-2">ضَمْرة بن حبيب</span> -من طريق أرطاة- في قوله: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ شيئًا لِتُعطى أكثر منه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span> -من طريق مُغيرة- <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ شيئًا لِتُعطى أكثرَ منه{7}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span> كان هذا للنبيِّ ﷺ خاصة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ مُصانعةً؛ رجاء أفضل منه من الثواب{9}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تَضْعُف أن تَستَكْثِر من الخير. قال: <span class="qpc-hafs">﴿تَمْنُن﴾</span> في كلام العرب: تَضْعُف{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعَظِّم عملَك في عينك أن تَستَكْثِر من الخير{11}. (١٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧١<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي حُجَيرة-: هما رِبَوان؛ حلال وحرام، فأمّا الحلال فالهدايا، وأمّا الحرام فالربا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ شيئًا لتُعطى أكثر منه، وهي للنبي ﷺ خاصة، والناس مُوَسَّع عليهم{13}. (١٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، يقول: ولا تُعطِ شيئًا لتُعطى أكثر منه، وإنما نزل هذا في النبيِّ ﷺ{14}. (١٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٤<span class="dash">-</span></span> قال <span class="name-2">طاووس بن كيسان</span> -من طريق ابنه-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٥<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر - <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ شيئًا لتُثاب أفضل منه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، (ولا تَمْنُن تَسْتَكْثِرْ)، قال: لا تَستَكْثِر عملك{16}. (١٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تُعطِ شيئًا لمثابة الدنيا، ولا لِمُجازاة الناس{17}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٨<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span> لا تُعطِ مالَك مُصانعة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٧٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا يَكثُر عملك في عينك، فإنه فيما أنعم الله عليك وأعطاك قليل{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، يقول: ولا تُعطِ عطيةً لِتُعطى أكثر من عَطِيّتك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</span>، قال: لا تَمْنُن بالنبوة والقرآن الذي أرسلناك به تَسْتَكْثِرهم به، تأخذ عليه عِوضًا من الدنيا{10}<span class=comment-ref>٦٨٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧١</span> اختُلف في قوله: <span class="qpc-hafs">﴿ولا تمنن تستكثر﴾</span> على أقوال: <b>الأول</b>: ولا تُعطِ -يا محمد- عَطِيّة لِتُعطى أكثر منها. <b>الثاني</b>: ولا تَمْنُن عملك على ربّك تَسْتَكْثِر. <b>الثالث</b>: لا تَضْعُف أن تَسْتَكْثِر من الخير. <b>الرابع</b>: لا تَمْنُن بالنبوة على الناس، تأخذ عليه منهم أجرًا.</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٨/٤٥٣) القول الأول، فقال: «فكأنه من قولهم: مَنَّ إذا أعطى، وقال الضَّحّاك: وهذا خاصٌّ بالنبي ﵇، ومباح لأُمّته، لكن لا أجر لهم فيه. قال مكي: وهذا معنى قوله تعالى: <span class="qpc-hafs">﴿وما آتَيْتُمْ مِن رِبًا لِيَرْبُوا فِي أمْوالِ النّاسِ فَلا يَرْبُوا عِنْدَ اللَّهِ﴾</span> [الروم:٣٩]». و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للسياق</span>، فقال: «وهذا معنًى أجنبي مِن معنى هذه السورة». و<span class="comment-type-4">علّق</span> على القول الثاني بقوله: «ففي هذا التأويل تحريض على الجد، وتخويف». و<span class="comment-type-4">علّق</span> على القول الثالث، فقال: «وقال مجاهد: معناه: ولا تَضْعُف تَسْتَكْثِر ما حمّلناك من أعباء الرسالة وتَسْتَكْثِر من الخير. فهذه من قولهم: حبل منين، أي: ضعيف».</p><p>وقد <span class="comment-type-3">رجح</span> <u>ابنُ جرير</u> (٢٣/٤١٧) -<span class="mustanad">مستندًا إلى السياق، والقراءات-</span> القول الثاني، فقال: «وإنما قلتُ ذلك أولى بالصواب؛ لأن ذلك في سياق آيات تَقدّم فيهنّ أمْر الله نبيّه ﷺ بالجد في الدعاء إليه، والصبر على ما يَلقى من الأذى فيه، فهذه بأن تكون من أنواع تلك أشبه منها بأن تكون من غيرها. وذكر عن عبد الله بن مسعود أنّ ذلك في قراءته: (ولا تَمْنُنْ أن تَسْتَكْثِر)».</div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٥-. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن عبد الله بن مسعود. انظر: مختصر ابن خالويه ص١٦٤.تفسير ابن أبي زمنين ٥/٥٥.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٢٣٧.أخرجه ابن جرير ٢٣/٤١٢، والطبراني (١٢٦٧٢)، والبيهقي ٧/٥١ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢٢ (٢٣١١٦).أخرجه ابن جرير ٢٣/٤١٢.أخرجه ابن جرير ٢٣/٤١٣، كذلك من طريق منصور بنحوه، وبه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢١ (٢٣١١١). وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.أخرجه ابن جرير ٢٣/٤١٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٦.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٤.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرج شطره الأول ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢١ (٢٣١١٣)، وابن جرير ٢٣/٤١٣ من طريق سلمة بن نُبيط. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٥- بنحوه. وأخرج شطره الثاني ابن جرير ٢٣/٤١٤- ٤١٥ من طريق سفيان عن رجل.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وأخرج شطره الأول ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢١ (٢٣١١٢)، وابن جرير ٢٣/٤١٣ من طريق شعبة، عمن سمع عكرمة.أخرجه عبد الرزاق ٢/٣٢٨، وابن جرير ٢٣/٤١٤.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرج تفسيره ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢٢ (٢٣١١٥)، وابن جرير ٢٣/٤١٥، من طريق سفيان بن حسين، بلفظ: لا تمنن عملك تَسْتَكْثِره على ربك. وعند ابن جرير أيضًا من طريق عوف، وأبي سهل أيضًا. كذلك عند عبد الرزاق في تفسيره ٢/٣٢٨ بلفظ: لا تمنن عملك ولا تَسْتَكْثِر.أخرجه ابن جرير ٢٣/٤١٤. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٧٠.أخرجه ابن جرير ٢٣/٤١٥.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤١٦.
  74,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِرَبِّكَ فَٱصۡبِرۡ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٨٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span> -من طريق مُغيرة- <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span>، قال: إذا أعطيتَ عَطِيّةً فأَعطِها لربّك، واصبر حتى يكون هو الذي يُثيبُك{1}. (١٥/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span>، قال: على ما أُوذيتَ{2}. (١٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٤<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span> إذا أعطيتَ عَطِيّة فأَعطِها لربّك، واصبر حتى يكون هو الذي يُثيبُك عليها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span> يُعزِّي نبيَّه ﷺ ليَصبر على الأذى والتكذيب من كفار مكة{4}<span class=comment-ref>٦٨٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٢</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٣/٤١٧): «وقوله: <span class="qpc-hafs">﴿ولربك فاصبر﴾</span> يقول -تعالى ذِكْره-: ولربك فاصبر على ما لَقِيتَ فيه من المكروه. <span class="mustanad">وبنحو الذي قلنا في ذلك قال جماعة من أهل التأويل</span> على اختلاف فيه بين أهل التأويل». ثم ذكر قول مجاهد، وابن زيد، وإبراهيم النَّخَعي.</div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولِرَبِّكَ فاصْبِرْ﴾</span>، قال: حُمِّل أمرًا عظيمًا؛ محاربة العرب، ثم العَجَم من بعد العرب في الله{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤١٨. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٧٠.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤١٧.
  74,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٦٨٧<span class="dash">-</span></span> عن عبد الله بن عباس، قال: لَمّا نزلت: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span> قال رسول الله ﷺ: «<b>كيف أنعَم وصاحبُ الصُّور قد التَقم القَرن، وحَنى جَبهته، يَستمع متى يُؤمر؟!</b>». قالوا: كيف نقول، يا رسول الله؟ قال: «<b>قولوا: حَسْبنا الله ونِعْم والوكيل، على الله توكَّلنا</b>»{1}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قوله: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، قال: هو يوم يُنفخ في الصُّور الذي يُنفخ فيه. قال ابن عباس: إنّ نبي الله ﷺ خرج إلى أصحابه، فقال: «<b>كيف أنعَم وصاحب القَرن قد التَقم القَرن، وحَنى جَبهته، ثم أقبل بأُذُنه يَستمع متى يُؤمر بالصيحة</b>». فاشتدّ ذلك على أصحابه، فأمَرهم أن يقولوا: «<b>حَسْبنا الله ونِعْم والوكيل، على الله توكَّلنا</b>»{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، قال: الصُّور{3}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿النّاقور﴾</span> الصُّور؛ كهيئة البُوق{4}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، يعني: الصُّور{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي رجاء-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٣<span class="dash">-</span></span> و<span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٤<span class="dash">-</span></span> و<span class="name-2">أبي مالك غَزْوان الغفاري</span>، مثله{6}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، قال: إذا نُفخ في الصُّور{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، قال: فإذا نُفخ في الصُّور{8}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فإذا نقر في الناقور﴾</span>: والنّاقور: الصُّور، والصُّور: الخَلْق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، قال: النّاقور: الصُّور{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٦٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، يعني: نُفخ في الصُّور، والنّاقور: القَرن الذي يَنفخ فيه إسرافيل، وهو الصُّور{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span>، قال: الصُّور{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٠١<span class="dash">-</span></span> عن بَهْز بن حكيم، قال: أمَّنا <span class="name-2">زُرارة بن أوْفى</span>، فقرأ المدثِّر، فلما بلغ: <span class="qpc-hafs">﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</span> خرّ مَيِّتًا، فكنتُ في مَن حَمله{13}. (١٥/٧٠)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه. كما عزاه إلى ابن أبي شيبة والطبراني، وليس عندهما قوله: لما نزلت، كما في الأثر التالي.أخرجه أحمد ٥/١٤٤-١٤٥ (٣٠٠٨)، والحاكم ٤/٦٠٣ (٨٦٧٧)، وابن جرير ٢٣/٤١٨-٤١٩، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٦٤-، والثعلبي ١٠/٧١.</p><p>قال ابن كثير في تفسيره ٢/١٧١: «حديث جيد». وقال الذهبي في التلخيص: «عطية -العَوفيّ- ضعيف». وقال الهيثمي في المجمع ١٠/٣٣١ (١٨٣٠٨): «فيه عطية العَوفيّ، وهو ضعيف، وفيه توثيق ليّن». وأورده الألباني في الصحيحة ٣/٦٦ (١٠٧٩).أخرجه ابن جرير ٢٣/٤٢٠-٤٢١. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٣/٤١٩، وبنحوه من طريق جابر. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٢٠.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه عن عكرمة آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٣-، وابن جرير ٢٣/٤١٩.أخرجه ابن جرير ٢٣/٤٢٠.أخرجه عبد الرزاق ٢/٣٢٨، وابن جرير ٢٣/٤٢٠. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٢٠.أخرجه ابن جرير ٢٣/٤٢٠.تفسير مقاتل بن سليمان ٤/٤٩٠-٤٩١.أخرجه ابن جرير ٢٣/٤٢٠.أخرجه ابن سعد ٧/١٥٠، والحاكم ٢/٥٠٦.
  74,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَذَ ٰ⁠لِكَ یَوۡمَىِٕذࣲ یَوۡمٌ عَسِیرٌ ۝٩ عَلَى ٱلۡكَـٰفِرِینَ غَیۡرُ یَسِیرࣲ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمٌ عَسِيرٌ﴾</span>، قال: شديد{1}. (١٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَذَلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ﴾</span> قال: شديد، ثم بَيَّن على مَن مَشقَّتُه وعُسْرُه، فقال: <span class="qpc-hafs">﴿عَلى الكافِرِينَ غَيْرُ يَسِيرٍ﴾</span>{2}. (١٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَذلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ﴾</span> يعني: مَشقَّتَه وشدّته، <span class="qpc-hafs">﴿عَلى الكافِرِينَ غَيْرُ يَسِيرٍ﴾</span> يعني: غير هيّن، ويَهُونُ ذلك على المؤمن كأدنى صلاته{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٢٠-٤٢١. وعلقه البخاري في صحيحه ٤/١٨٧٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرج أوله ابن جرير ٢٣/٤٢٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٩١.
  74,10,""
