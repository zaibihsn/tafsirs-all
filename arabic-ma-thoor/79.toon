  79,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَحَشَرَ فَنَادَىٰ ۝٢٣ فَقَالَ أَنَا۠ رَبُّكُمُ ٱلۡأَعۡلَىٰ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٠٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>كلمتان قالهما فرعون:</b> <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨]، <b>وقوله:</b> <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span>». قال: «<b>كان بينهما أربعون عامًا، <span class="qpc-hafs">﴿فأخذه الله نكال الآخرة والأولى﴾</span></b>»{1}. (١١/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، قال: كان بين كلمتيه أربعون سنة{2}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: لَمّا قال فرعون: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨]؛ قال جبريل: يا ربِّ، طغى عبدُك، فأْذَن لي في هلاكه. قال: يا جبريل، هو عبدي، ولن يسبقني، له أجلٌ قد أجَّلته حتى يجيء ذلك الأجل. فلما قال: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span>؛ قال: يا جبريل، سبقت دعوتُك في عبدي، وقد جاء أوانُ هلاكه{3}. (١١/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٩<span class="dash">-</span></span> عن <span class="name-2">خَيْثمة الجُعْفيّ</span> -من طريق الأعمش- قال: كان بين قول فرعون: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨] وقوله: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span> أربعون سنة{4}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق معمر- يقول: كان بين قول فرعون: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> وبين قوله: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span> أربعون سنة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق هارون بن موسى- قال: لَمّا قال فرعون لقومه: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨] نَشَر جبريلُ أجنحةَ العذاب غضبًا لله ﷿، فأوحى الله ﷿ إليه: أن يا جبريل، إنّما يُعجِّل بالعقوبة مَن يخاف الفَوْت. قال: فأَمهله ﷿ بعد هذه المقالة أربعين عامًا، حتى قال: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: قال موسى: يا فرعون، هل لك في أنْ أُعطيك شبابك لا تَهرَم، ومُلكك لا يُنزَع منك، وتُرَدّ إليك لذة المناكح والمشارب والمركوب، وإذا مِتّ دخَلتَ الجنة، وتؤمن بي. فوقعتْ في نفسه هذه الكلمات، وهي الليِّنات. قال: كما أنتَ حتى يأتي هامان. فلمّا جاء هامان أخبره، فعجَّزه هامان، وقال: تصير تَعبُد بعد إذ كنتَ ربًّا تُعبد؟! فذلك حين خَرج عليهم، فقال لقومه وجَمْعهم: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>{7}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَحَشَرَ فَنادى﴾</span> يقول: حَشر القِبط، <span class="qpc-hafs">﴿فَقالَ أنا رَبُّكُمُ الأَعْلى﴾</span> وذلك أنّ موسى ﷺ قال لفرعون: لك مُلكك فلا يزول، ولك شبابك فلا تَهرَم، ولك الجنة إذا مِتّ، على أن يقول: ربي الله وأنا أعبده. فقال فرعون: إنك لعاجز، بينا يكون الرجل ربًّا يُعبَد حتى يكون له ربّ. فقال فرعون: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>. يقول: ليس لي ربٌّ فوقي، فذلك الأعلى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَحَشَرَ فَنادى﴾</span>، قال: صَرخ وحَشَر قومه، فنادى فيهم، فلمّا اجتمعوا قال: أنا ربّكم الأعلى، <span class="qpc-hafs">﴿فأخذه الله نكال الآخرة والأولى﴾</span> [النازعات:٢٥]{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه تمام في فوائده ١/٣٤٦ (٨٨٨)، وابن عساكر في تاريخه ٥٢/٢٤٧-٢٤٨.</p><p>قال الألباني في الضعيفة ٩/١١٧ (٤١١٧): «ضعيف».عزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.أخرجه ابن أبي حاتم ٩/٢٩٧٩، ٣٠٦١.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٨٥-٨٦.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٩٥ (٢٤٤)-.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٧٧.أخرجه ابن جرير ٢٤/٨٣.
  79,24,""
  79,24,""
  79,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلۡـَٔاخِرَةِ وَٱلۡأُولَىٰۤ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الضُّحى- يقول: أخذه الله بكلمتيه كلتيهما، أمّا كلمته الأولى قوله: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span>، وأما الآخرة: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>{1}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثله{2}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٧<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق إسماعيل بن سُمَيع- <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: الأولى: تكذيبه وعصيانه، والآخرة: قوله: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>. ثم قرأ: <span class="qpc-hafs">﴿فَكَذَّبَ وعَصى ثُمَّ أدْبَرَ يَسْعى فَحَشَرَ فَنادى فَقالَ أنا رَبُّكُمُ الأَعْلى﴾</span> فهي الكلمة الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: الأولى: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨]، والآخرة: قوله: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>{4}. (١٥/٢٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: أول عَمَلِه وآخره{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿نَكالَ الآخِرَةِ والأُولى﴾</span> أما الأولى فحين قال فرعون: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span>، وأما الآخرة فحين قال: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>، فأخذه الله بكلمتيه كلتيهما، فأغرقه في اليم{6}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢١<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل الأسدي- <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: هما كلمتاه؛ الأولى: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨]، والأخرى: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span> وكان بينهما أربعون سنة{7}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: عقوبة الدنيا، والآخرة{8}. (١٥/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- قال: لَمّا قال فرعون لقومه: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨]؛ نشر جبريلُ أجنحةَ العذاب غضبًا لله ﷿، فأوحى الله ﷿ إليه: أن يا جبريل، إنما يعجِّل بالعقوبة مَن يخاف الفَوْت. قال: فأمهله ﷿ بعد هذه المقالة أربعين عامًا، حتى قال: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span>، فذلك قوله ﷿: <span class="qpc-hafs">﴿فأخذه الله نكال الآخرة والأولى﴾</span>: قوله الأول، وقوله الآخر. ثم أغرقه الله ﷿ وجنوده{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: أصابته عقوبة الدنيا والآخرة{10}. (١٥/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: نكال الآخرة من المعصية والأولى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ﴾</span> بعقوبة قوله: <span class="qpc-hafs">﴿نَكالَ الآخِرَةِ والأُولى﴾</span>، وكان بينهما أربعين سنة؛ الأولى قوله: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span> [القصص:٣٨]، والآخرة قوله: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</span>، قال: اختلفوا فيها، فمِنهم مَن قال: نكال الآخرة من كلمتيه، والأولى قوله: <span class="qpc-hafs">﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</span>، وقوله: <span class="qpc-hafs">﴿أنا رَبُّكُمُ الأَعْلى﴾</span>. وقال آخرون: عذاب الدنيا، وعذاب الآخرة، عجَّل الله له الغرق، مع ما أعدّ له من العذاب في الآخرة{13}<span class=comment-ref>٧٠٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٦</span> اختُلف في قوله: <span class="qpc-hafs">﴿نكال الآخرة والأولى﴾</span> على أقوال: <b>الأول</b>: عقوبة كلمتيه: قوله: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span> وقوله: <span class="qpc-hafs">﴿ما علمت لكم من إله غيري﴾</span> [القصص:٣٨]. <b>الثاني</b>: عذاب الدنيا وعذاب الآخرة. <b>الثالث</b>: فأخذه الله نكال الدنيا والآخرة. <b>الرابع</b>: أنّ الأولى هي عصيانه ربّه وكفره به، والآخرة قوله: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span>. <b>الخامس</b>: أخذه بأول عَمَلِه وآخره.</p><p>و<span class="comment-type-3">اختار</span> <u>ابنُ جرير</u> (٢٤/٨٤) -<span class="mustanad">مستندًا إلى القرآن، وأقوال السلف</span>- أنّ المراد عقوبة كلمتيه كما في القول الأول، فقال: «يعني -تعالى ذِكْره- بقوله: <span class="qpc-hafs">﴿فأخذه الله﴾</span> فعاقبه الله <span class="qpc-hafs">﴿نكال الآخرة والأولى﴾</span> يقول: عقوبة الآخرة من كلمتيه، وهي قوله: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span>، والأولى قوله: <span class="qpc-hafs">﴿ما علمت لكم من إله غيري﴾</span> [القصص:٣٨]، وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على هذا، ثم ذكر بقية الأقوال، ولم يعلّق عليها.</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٤/٢٤٢) -<span class="mustanad">مستندًا إلى القرآن</span>- القول الثاني، وقال: «كَما قال تعالى: <span class="qpc-hafs">﴿وجَعَلْناهُمْ أئِمَّةً يَدْعُونَ إلى النّارِ ويَوْمَ القِيامَةِ لا يُنْصَرُونَ﴾</span> [القصص:٤١]، هذا هو الصحيح في معنى الآية؛ أنّ المراد بقوله: <span class="qpc-hafs">﴿نَكالَ الآخِرَةِ والأولى﴾</span> أي: الدنيا والآخرة، وقيل: المراد بذلك: كَلِمَتاه الأولى والثانية. وقيل: كفْره وعصيانه. والصحيح الذي لا شكَّ فيه الأول».</div></p></div>",footnotes:1:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٧٠٣-، وابن جرير ٢٤/٨٤ وزاد: كان بينهما أربعون سنة. كما أخرجه بنحوه من طريق عطية.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٨٧.تفسير مجاهد ص٧٠٣، وأَخرَجه ابن جرير ٢٤/٨٥، ومن طريق عبد الكريم أيضًا، والفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٨٧.أخرجه ابن جرير ٢٤/٨٥-٨٦. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٨٥، ومن طريق زكريا أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٨٦-٨٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب العقوبات- موسوعة الإمام ابن أبي الدنيا ٤/٤٩٥ (٢٤٤).أخرجه عبد الرزاق ٢/٣٤٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٨٨ واللفظ له.تفسير مقاتل بن سليمان ٤/٥٧٧.أخرجه ابن جرير ٢٤/٨٦.
  79,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّمَن یَخۡشَىٰۤ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٢٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إنَّ فِي ذَلِكَ لَعِبْرَةً لِمَن يَخْشى﴾</span> لِمَن يَخشى أن يُفعل به ما فُعل بفرعون وقومه فيُؤمن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنَّ فِي ذلِكَ﴾</span> يقول: إنّ في هلاك فرعون وقومه <span class="qpc-hafs">﴿لَعِبْرَةً لِمَن يَخْشى﴾</span> يعني: لِمَن يَذكر الله تعالى، يقول: لِمَن يَخشى عقوبة الله تعالى، مثل ما فُعل بآل فرعون فلا يُشرك، يخوِّف كفار مكة لِئَلّا يُكذّبوا محمدًا ﷺ فيُجازيهم مثل ما حَلّ بقوم فرعون من العذاب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٠-.تفسير مقاتل بن سليمان ٤/٥٧٧.
  79,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ءَأَنتُمۡ أَشَدُّ خَلۡقًا أَمِ ٱلسَّمَاۤءُۚ بَنَىٰهَا ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: يا معشر العرب، <span class="qpc-hafs">﴿أأَنْتُمْ أشَدُّ خَلْقًا أمِ السَّماءُ بَناها﴾</span>؟ يقول: أنتم أشد قوة من السماء؟ لأنه قال: <span class="qpc-hafs">﴿إذا السَّماءُ انْفَطَرَتْ﴾</span>، <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، يقول: فما حالكم أنتم -يا بني آدم- وأنتم أضعف من السماء؟{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٧-٥٧٨.
  79,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿رَفَعَ سَمۡكَهَا فَسَوَّىٰهَا ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي، وعطية- في قوله: <span class="qpc-hafs">﴿رَفَعَ سَمْكَها﴾</span>، قال: بناها{1}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿رَفَعَ سَمْكَها﴾</span>، قال: رفع بنيانها بغير عمد{2}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿رَفَعَ سَمْكَها﴾</span>، قال: رفع بنيانها{3}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿بَناها رَفَعَ سَمْكَها﴾</span> يعني: طولها مسيرة خمسمائة عام، <span class="qpc-hafs">﴿فَسَوّاها﴾</span> ليس فيها خَلَل{4}<span class=comment-ref>٧٠٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٧</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٨٩) غير قول قتادة، ومجاهد، وابن عباس.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥٣٢) في قوله: <span class="qpc-hafs">﴿فسواها﴾</span> احتمالين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فَسَوّاها﴾</span> <b>يحتمل</b> أن يريد: جعلها ملساء مستوية ليس فيها مرتفع ومنخفض، <b>ويحتمل</b> أن يكون عبارة عن إتقان خَلْقها، ولا يقصد معنى إملاس سطحها، والله تعالى أعلم كيف هي».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٨٩ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٧٠٤، وأخرجه ابن جرير ٢٤/٨٩. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٢٤/٨٩ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٨.
  79,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَغۡطَشَ لَیۡلَهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: أظلم ليلها{1}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: العشاء{2}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: أظلم ليلها{3}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: أظلم ليلها{4}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، يقول: أظلم ليلها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم- <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: أظلم ليلها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: أظلم ليلها{7}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٢<span class="dash">-</span></span> عن <span class="name-2">شرحبيل بن سعد</span> -من طريق أبي معشر- في قوله: <span class="qpc-hafs">﴿وأغطش ليلها﴾</span>، قال: أظلم ليلها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿أغطش ليلها﴾</span>: أظلم ليلها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وأَغْطَشَ﴾</span> يقول: وأَظلم <span class="qpc-hafs">﴿لَيْلَها﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَغْطَشَ لَيْلَها﴾</span>، قال: الظُّلمة{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَخۡرَجَ ضُحَىٰهَا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: الشمس{2}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، يقول: أخرج نهارها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: أخرج نهارها{3}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: أبرزه{15}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: نَوَّرها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: نهارها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: نور ضوئها{18}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: أنار ضحاها{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span> يعني: وأَبرز، يقول: وأَخرج شمسها، وإنما صارت مُؤنّثة لأنّ ظُلمة الليل في السموات، وظُلمة الليل من السماء تجيء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَخْرَجَ ضُحاها﴾</span>، قال: ضوء النهار{21}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٩٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٩٠ بلفظ: «أظلم» فقط. وعزاه السيوطي إلى أبي الشيخ، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٩٠-٩١.أخرجه ابن جرير ٢٤/٩١.أخرجه عبد الرزاق ٢/٣٤٧، وابن جرير ٢٤/٩٠، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٥٥ (٢٣٩٣).أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٩.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩٠.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٤-.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر، وأبي الشيخ.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٤-، وابن جرير ٢٤/٩١.أخرجه ابن جرير ٢٤/٩١.أخرجه ابن جرير ٢٤/٩١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٧.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩١-٩٢.
  79,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨١٣٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- أنه قرأ: (والأَرْضَ عِندَ ذَلِكَ دَحاها){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨١٣٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق مجاهد- قال: خَلَق الله البيت قبل الأرض بألفي سنة، ومنه دُحِيت الأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</span>، قال: مع ذلك{3}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- أنّ رجلًا قال له: آيتان في كتاب الله تُخالف إحداهما الأخرى؟ فقال: إنما أُتيتَ من قِبَل رأيك، اقرأ. قال: <span class="qpc-hafs">﴿قُلْ أئِنَّكُمْ لَتَكْفُرُونَ بِالَّذِي خَلَقَ الأَرْضَ فِي يَوْمَيْن﴾</span> حتى بلغ: <span class="qpc-hafs">﴿ثُمَّ اسْتَوى إلى السَّماءِ وهِيَ دُخانٌ﴾</span> [فصلت:٩-١١]، وقوله: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</span>. قال: خَلَق الله الأرض قبل أن يَخلُق السماء، ثم خَلَق السماء، ثم دحا بعدما خَلَق السماء، وإنما قوله: دحاها: بسطها{4}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿دَحاها﴾</span>، قال: دَحيُها: أنْ أخرج منها الماء والمرعى، وشَقَّق فيها الأنهار، وجعل فيها الجبال والرّمال والسُّبل والآكام وما بينهما في يومين{5}. (١٥/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي-: حيث ذَكر خَلْق الأرض قبل السماء، ثم ذَكر السماء قبل الأرض، وذلك أنّ الله خَلَق الأرض بأقواتها من غير أن يَدْحُوها قبل السماء، ثم استوى إلى السماء فسوّاهنّ سبع سموات، ثم دحا الأرض بعد ذلك، فذلك قوله: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: وُضع البيت على الماء على أربعة أركان قبل أن يَخلق الدنيا بألفي عام، ثم دُحِيت الأرض من تحت البيت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>، <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</span>، قال: دُحِيتْ من مكة{8}. (١٥/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ﴾</span> قال: مع ذلك <span class="qpc-hafs">﴿دَحاها﴾</span> قال: بَسَطها{9}. (١٥/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٥<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، قال: بلَغني: أنّ الأرض دُحِيتْ دَحيًا من تحت الكعبة{10}. (١٥/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</span>، قال: بَسَطها{11}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أبي حمزة- في قوله: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</span>، قال: مع ذلك دحاها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذلِكَ دَحاها﴾</span>، يقول: بعد بناء السماء، بَسَطها مِن تحت الكعبة مسيرة خمسمائة عام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٦٩<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق عبد الرحمن- <span class="qpc-hafs">﴿دَحاها﴾</span>: بَسَطها{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿دَحاها﴾</span>، قال: حَرَثها، شَقَّها. وقال: <span class="qpc-hafs">﴿أخْرَجَ مِنها ماءَها﴾</span>، وقرأ: <span class="qpc-hafs">﴿ثُمَّ شَقَقْنا الأَرْضَ شَقًّا﴾</span> حتى بلغ <span class="qpc-hafs">﴿وفاكِهَةً وأَبًّا﴾</span> [عبس:٢٦-٣١]. وقال: حين شَقَّها أنبتَ هذا منها. وقرأ: <span class="qpc-hafs">﴿والأَرْضِ ذاتِ الصَّدْعِ﴾</span> [الطارق:١٢]{15}<span class=comment-ref>٧٠٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٨</span> اختُلف في قوله: <span class="qpc-hafs">﴿بعد ذلك﴾</span> على قولين: <b>الأول</b>: أنّ الأرض دُحِيتْ من بعد خَلْق السماء. <b>الثاني</b>: أنّ معناه: مع ذلك، وقالوا: الأرض خُلِقتْ ودُحِيتْ قبل السماء.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/٩٤) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، فقال: «والقول الذي ذكرناه عن ابن عباس من أنّ الله تعالى خَلَق الأرض، وقَدّر فيها أقواتها، ولم يَدْحُها، ثم استوى إلى السماء فسوّاهنّ سبع سموات، ثم دحا الأرض بعد ذلك، فأَخرج منها ماءها ومرعاها، وأرسى جبالها؛ أشبه لما دلّ عليه ظاهر التنزيل؛ لأنه -جلّ ثناؤه- قال: <span class="qpc-hafs">﴿والأرض بعد ذلك دحاها﴾</span> والمعروف من معنى»بعد«أنه خلاف معنى»قبل«، وليس في دَحْو الله الأرض بعد تسويته السماوات السبع، وإغطاشه ليلها، وإخراجه ضحاها، ما يوجب أن تكون الأرض خُلِقتْ بعد خَلْق السماوات؛ لأنّ الدَّحْو إنما هو البَسط في كلام العرب، والمدّ يقال منه: دحا يدحُو دَحْوًا، ودحيت أدحي دحيًا لغتان».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٥٣٢): «وقوله تعالى: <span class="qpc-hafs">﴿والأَرْضَ بَعْدَ ذلِكَ دَحاها﴾</span> متوجّه على أنّ الله تعالى خَلَق الأرض ولم يَدْحُها، ثم استوى إلى السماء وهي دُخان فخَلَقها وبناها، ثم دحا الأرض بعد ذلك». ثم ذكر اختلاف السلف، و<span class="comment-type-4">علّق</span> قائلًا: «والذي قلناه تترتب عليه آيات القرآن كلّها».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (٨/٣١٦).</div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨١٣٧١<span class="dash">-</span></span> عن علي، قال: صَلّى بنا رسول الله ﷺ صلاة الصبح، فلمّا قضى صلاته رفع رأسه إلى السماء، فقال: «<b>تبارك رافعها ومُدبِّرها</b>». ثم رمى ببصره إلى الأرض، فقال: «<b>تبارك داحيها وخالقها</b>»{16}. (١٥/٢٣٤)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٩٤.</p><p>وهي قراءة شاذة.أخرجه ابن جرير ٢٤/٩٣.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البخاري في صحيحه مطولًا ٤/١٨١٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣٩-.أخرجه ابن جرير ٢٤/٩٢، ومن طريق عطية بنحوه أيضًا.أخرجه ابن جرير ٢٤/٩٣.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٨٩-٩٤، ومن طريق الأعمش أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٩٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٩٤.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩٥.أخرجه ابن جرير ٢٤/٩٥-٩٦.أخرجه البزار ٢/١٤٥-١٤٦ (٥٠٧) مطولًا، وأبو الشيخ في العظمة ٣/١٠٤٢ (٥٦٠) واللفظ له، من طريق يونس بن أرقم، عن إبراهيم بن عبد الله بن حسن بن حسن، عن زيد بن علي بن الحسين، عن أبيه، عن جده، عن علي بن أبي طالب به.</p><p>وقال البزار: «وهذا الحديث لا نعلمه يُروى عن النبي ﷺ بهذا اللفظ إلا من هذا الوجه بهذا الإسناد، ويونس بن أرقم كان صدوقًا روى عنه أهل العلم، واحتملوا حديثَه على أنّ فيه شيعية شديدة». وقال الهيثمي في المجمع ٧/٣٢٨ (١٢٤٥٦): «فيه مَن لم أعرفهم». وقال المتقي الهندي في كنز العمال ١٤/٥٥٧ (٣٩٥٩٠): «سنده حسن».
  79,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَخۡرَجَ مِنۡهَا مَاۤءَهَا وَمَرۡعَىٰهَا ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٧٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ومَرْعاها﴾</span> ما خَلَق الله فيها من النبات، <span class="qpc-hafs">﴿ماءَها﴾</span> ما فَجّر فيها من الأنهار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿أخْرَجَ مِنها ماءَها ومَرْعاها﴾</span>، يقول: بحورها ونباتها؛ لأنّ النبات والماء يكونان من الأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٧٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿أخْرَجَ مِنها ماءَها﴾</span> قال: فَجّر منها الأنهار، <span class="qpc-hafs">﴿ومَرْعاها﴾</span> قال: ما خَلَق الله مِن نبات أو شيء{3}. (١٥/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٧٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وكان بدء خَلْق الأرض -فيما بلَغنا- أنها كانت طينة في موضع بيت المقدس، ثم خَلَق السموات، ثم دحا الأرض، فقال لها: اذهبي أنتِ كذا، واذهبي أنتِ كذا، ومن مكة بُسطت الأرض، ثم جعل فيها جبالها وأنهارها وأشجارها. قال: <span class="qpc-hafs">﴿أخْرَجَ مِنها ماءَها ومَرْعاها﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٩٦.تفسير مقاتل بن سليمان ٤/٥٧٨.عزاه السيوطي إلى ابن المنذر.تفسير ابن أبي زمنين ٥/٩١.
  79,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡجِبَالَ أَرۡسَىٰهَا ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والجِبالَ أرْساها﴾</span>، قال: أثبتها أن تَميد بأهلها{1}. (١٥/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والجِبالَ أرْساها﴾</span>، يقول: أوْتَدها في الأرض لئلا تزول، فاستقرّتْ بأهلها{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡجِبَالَ أَرۡسَىٰهَا ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨١٣٧٨<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق أبي عبد الرحمن السُّلميّ- قال: لَمّا خَلَق اللهُ الأرضَ قَمَصتْ، وقالتْ: تَخْلُق عَلَيَّ آدم وذُرِّيته يُلقون عَلَيَّ نَتنهم، ويَعملون عَلَيَّ بالخطايا. فأرساها الله، فمنها ما تَرون، ومنها ما لا تَرون، فكان أول قرار الأرض كلحم الجَزور إذا نُحر يَختَلج لحمها{3}<span class=comment-ref>٧٠٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٩</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١٤/٢٤٤) على هذا الأثر بقوله: «غريب».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٩٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩٦-٩٧.
  79,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَتَـٰعࣰا لَّكُمۡ وَلِأَنۡعَـٰمِكُمۡ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿مَتاعًا لَكُمْ﴾</span>، قال: منفعة{1}. (١٥/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى <span class="qpc-hafs">﴿مَرْعاها﴾</span>، فقال فيها: <span class="qpc-hafs">﴿مَتاعًا لَكُمْ ولِأَنْعامِكُمْ﴾</span> يقول: معيشة لكم ولمواشيكم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٧٨.
  79,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا جَاۤءَتِ ٱلطَّاۤمَّةُ ٱلۡكُبۡرَىٰ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span>، قال: الطّامَّة مِن أسماء يوم القيامة{1}. (١٥/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span>، قال: إذا دُفعوا إلى مالك خازن النار{2}. (١٥/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٨٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن قيس الكندي</span> -من طريق موسى بن قيس- <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span>، قال: إذا قيل: اذهبوا به إلى النار{3}. (١٥/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٨٤<span class="dash">-</span></span> عن <span class="name-3">القاسم بن الوليد الهَمذاني</span> -من طريق مالك بن مِغْول- في قوله: <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span>، قال: إذا سيق أهل الجنة إلى الجنة، وأهل النار إلى النار{4}<span class=comment-ref>٧٠٣٠</span>. (١٥/٢٣٥)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٣٠</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٩٧) غير قول القاسم، وابن عباس.</div></p><p><div></p><p><p><span class="item-no">٨١٣٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span> يعني: العُظمى، وهي النفخة الآخرة من بيت المقدس، فذلك الطّامَّة الكبرى، وهي يوم القيامة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٨٦<span class="dash">-</span></span> عن <span class="name-3">نعيم النحوي</span> -من طريق يحيى بن يحيى- قال: سمعتُ في قوله: <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span>، قال: إذا قيل لهم: قوموا إلى النار{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٩٧. وعزاه السيوطي إلى ابن المنذر، وابن حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ١٣/٥١٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٥٥٨، وابن جرير ٢٤/٩٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤٤ (٢٠٦)-.
  79,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ یَتَذَكَّرُ ٱلۡإِنسَـٰنُ مَا سَعَىٰ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتَ الطّامَّة، فقال: <span class="qpc-hafs">﴿يَوْمَ يَتَذَكَّرُ الإنْسانُ ما سَعى﴾</span>، يعني: يَتذكر ما عمل في الدنيا مِن الشَّرِّ، يجزى به في ذلك اليوم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٩.
  79,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبُرِّزَتِ ٱلۡجَحِیمُ لِمَن یَرَىٰ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبُرِّزَتِ الجَحِيمُ لِمَن يَرى﴾</span> لأنّ الخَلْق يومئذ يُبصرونها؛ فمن كان منها أعمى في الدنيا فهو يومئذ يُبصِر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وبُرِّزَتِ الجَحِيمُ لِمَن يَرى﴾</span>، قال: لِمَن ينظر{2}. (١٥/٢٣٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٩.عزاه السيوطي إلى ابن المنذر.
  79,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا مَن طَغَىٰ ۝٣٧ وَءَاثَرَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝٣٨ فَإِنَّ ٱلۡجَحِیمَ هِیَ ٱلۡمَأۡوَىٰ ۝٣٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨١٣٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿فَأَمّا مَن طَغى وآثَرَ الحَياةَ الدُّنْيا﴾</span> نزلت هذه الآية في النَّضر بن الحارث بن عَلقمة بن كلدة، وفي حبيب بن عبد ياليل، وأُمَيّة بن خلف الجُمحيّ، وعُتْبة وعُتيبة ابني أبي لهب، فهؤلاء كفار، ومنهم مُصعب وأبو [الروم] ابنا عمير، وذلك أنهم وجدوا جزورًا في البَريّة، ضلَّتْ مِن الأعراب، فنَحروها، وجعلوا يَقتسِمونها بينهم، فأصاب مُصعب وأبو [الروم] سهمين، ثم إنّ مُصعب ذكر مَقامه بين يدي ربّ العالمين، فخاف أن يُحاسبه الله تعالى يوم القيامة، فقال: إنّ سهمي وسهم أخي هو لكم. فقال له عند ذلك أُمَيّة بن خلف: ولِمَ؟ قال: إني أخاف أن يُحاسبني الله به. فقال له أُمَيّة بن خلف: هاته، وأنا أحمل عنك هذا الوزر عند إلهك في الآخرة، وفشَتْ تلك المقالة في قريش في أمْر مُصعب؛ فأَنزَل الله تعالى: <span class="qpc-hafs">﴿فَأَمّا مَن طَغى﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَمَّا مَن طَغَىٰ ۝٣٧ وَءَاثَرَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝٣٨ فَإِنَّ ٱلۡجَحِیمَ هِیَ ٱلۡمَأۡوَىٰ ۝٣٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨١٣٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَأَمّا مَن طَغى﴾</span>، قال: عصى{2}<span class=comment-ref>٧٠٣١</span>. (١٥/٢٣٥)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٣١</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٩٨) غير قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٨١٣٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَمّا مَن طَغى﴾</span> الثابت على الشّرك، <span class="qpc-hafs">﴿وآثَرَ الحَياةَ الدُّنْيا﴾</span> على الآخرة، ولم يَخفِ الله ولا حسابه؛ فأكل الحرام، <span class="qpc-hafs">﴿فَإنَّ الجَحِيمَ هِيَ المَأْوى﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٩-٥٨٠.تفسير مجاهد ص٧٠٤، وأخرجه ابن جرير ٢٤/٩٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٩-٥٨٠.
