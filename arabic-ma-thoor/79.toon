  79,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٢٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿اذْهَبْ إلى فِرْعَوْنَ إنَّهُ طَغى﴾</span>، قال: عصى{1}. (١٥/٢٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يا موسى، <span class="qpc-hafs">﴿اذْهَبْ إلى فِرْعَوْنَ إنَّهُ طَغى﴾</span>. يقول: إنه قد بلغ من طغيانه أنه عُبِد. [وفي قراءة ابن مسعود]{2}: <span class="qpc-hafs">﴿طَغى﴾</span> لأنه لم يَعبد صنمًا قط، ولكنه دعا الناس إلى عبادته، فذلك قوله: <span class="qpc-hafs">﴿إنَّهُ طَغى﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٨٩<span class="dash">-</span></span> عن <span class="name-3">صخر بن جُويرية</span> -من طريق عبيد الله بن أبي نصر- قال: لَمّا بَعث اللهُ موسى إلى فرعون قال: <span class="qpc-hafs">﴿اذْهَبْ إلى فِرْعَوْنَ إنَّهُ طَغى﴾</span> إلى قوله: <span class="qpc-hafs">﴿وأَهْدِيَكَ إلى رَبِّكَ فَتَخْشى﴾</span>، ولن يَفعله. فقال موسى: يا ربِّ، كيف أذهب إليه وقد عَلِمتَ أنه لا يفعل؟! فأوحى الله إليه: أنِ امضِ إلى ما أُمِرتَ به؛ فإنّ في السماء اثني عشر ألف مَلَكٍ يطلبون عِلم القَدَر، فلم يَبلغوه، ولم يُدركوه{4}. (١٥/٢٣٠)</p></p><p></div></p></div>",footnotes:1:أخرجه الفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.كذا أثبتها المحقق من إحدى النسخ! وأورد أنها جاءت في نسخة أخرى: وفي قوله.تفسير مقاتل بن سليمان ٤/٥٧٦.أخرجه عبد الرزاق ٢/٣٤٦. وعزاه السيوطي إلى ابن المنذر.
  79,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقُلۡ هَل لَّكَ إِلَىٰۤ أَن تَزَكَّىٰ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</span>، قال: إلى أن تقول: لا إله إلا الله{1}. (١٥/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- في قوله: <span class="qpc-hafs">﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</span>، قال: هل لك إلى أن تقول: لا إله إلا الله{2}. (١٥/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقُلْ هَلْ لَكَ إلى أنْ تَزَكّى﴾</span>، يقول: هل لك أن تُصلِح ما قد أفسدتَ. يقول: وأدعوك لتوحيد الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</span>، قال: إلى أن تُخلِص{4}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</span>: إلى أن تُسلِم. قال: والتزكي في القرآن كلّه: الإسلام. وقرأ قول الله: <span class="qpc-hafs">﴿وذَلِكَ جَزاءُ مَن تَزَكّى﴾</span> [طه:٧٦]، قال: مَن أسلم. وقرأ: <span class="qpc-hafs">﴿وما يُدْرِيكَ لَعَلَّهُ يَزَّكّى﴾</span> [عبس:٣]، قال: يُسلِم. وقرأ: <span class="qpc-hafs">﴿وما عَلَيْكَ ألّا يَزَّكّى﴾</span> [عبس:٧]: أن لا يُسلِم{5}<span class=comment-ref>٧٠٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٣</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٨٠-٨١) غير قول عبد الرحمن بن زيد، وعكرمة من طريق الحكم.</p><p><span class="comment-type-3">ورجّح</span> <u>ابن عطية</u> (٨/٥٣٠) -<span class="mustanad">مستندًا للعموم</span>- أنّ التزكي هو التّطهّر من النقائص والتلبُّس بالفضائل، ثم <span class="comment-type-4">علّق</span> على قول مَن فسّر ذلك بـ: تُسلِم، ومَن فسّره بـ لا إله إلا الله، فقال: «والتزكي هو التّطهّر من النقائص، والتلبُّس بالفضائل، وفسّر بعضهم: <span class="qpc-hafs">﴿تَزَكّى﴾</span> بتُسلِم وفسّرها بقول: لا إله إلا الله، وهذا تخصيص وما ذكرناه يعمّ جميع هذا».</div></p></div>",footnotes:1:أخرجه البيهقي في الأسماء والصفات (٢٠٥).أخرجه ابن جرير ٢٤/٨١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٦.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٨٠.
  79,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَهۡدِیَكَ إِلَىٰ رَبِّكَ فَتَخۡشَىٰ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٢٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَهْدِيَكَ إلى رَبِّكَ﴾</span> إلى عَظمته، <span class="qpc-hafs">﴿فَتَخْشى﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٦.
  79,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَرَىٰهُ ٱلۡـَٔایَةَ ٱلۡكُبۡرَىٰ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٢٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَأَراهُ الآيَةَ الكُبْرى﴾</span>، قال: عصاه، ويده{1}. (١٥/٢٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَأَراهُ الآيَةَ الكُبْرى﴾</span>، قال: عصاه، ويده{2}. (١٥/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سلّام بن مِسْكين- أنه سأله عن قوله: <span class="qpc-hafs">﴿فَأَراهُ الآيَةَ الكُبْرى﴾</span>. قال: عصاه، ويده{3}. (١٥/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٢٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يُخبِر اللَّه ﷿ محمدًا ﷺ بخَبَره، قال له فرعون: وما هي؟ قال: <span class="qpc-hafs">﴿فَأَراهُ الآيَةَ الكُبْرى﴾</span>، وهي اليد والعصا؛ أخرج يده بيضاء لها شعاع كشُعاع الشمس يُغشي البصر، فكانت اليد أعظم وأعجب من العصا، من غير سوء، يعني: مِن غير بَرَص{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَراهُ الآيَةَ الكُبْرى﴾</span>، قال: العصا، والحيّة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٧٠٣، وأَخرَجه ابن جرير ٢٤/٨٢، والفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٨٢، ومن طريق سعيد أيضًا بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٣-، وابن جرير ٢٤/٨٢ بنحوه من طريق محمد بن سيف. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٦-٥٧٧.أخرجه ابن جرير ٢٤/٨٢.
  79,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَذَّبَ وَعَصَىٰ ۝٢١ ثُمَّ أَدۡبَرَ یَسۡعَىٰ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨١٣٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثُمَّ أدْبَرَ يَسْعى﴾</span>، قال: يَعمل بالفساد{1}<span class=comment-ref>٧٠٢٤</span>. (١٥/٢٢٩)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٤</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٨٣) غير قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٨١٣٠٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿ثُمَّ أدْبَرَ يَسْعى﴾</span>، قال: أدبَر عن الحق، وسعى يَجمع{2}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿فَكَذَّبَ وعَصى﴾</span> وزعم أنه ليس مِن الله ﷿، <span class="qpc-hafs">﴿وعَصى﴾</span> فقال: إنه سِحرٌ، وعصى أيضًا، يعني: استعصى عن الإيمان، ثم قال: <span class="qpc-hafs">﴿ثُمَّ أدْبَرَ﴾</span> عن الحقّ، <span class="qpc-hafs">﴿يَسْعى﴾</span> يعني: في جمْع السّحرة، فهو قوله: <span class="qpc-hafs">﴿فَجَمَعَ كَيْدَهُ ثم أتى﴾</span> [طه:٦٠] به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ثُمَّ أدْبَرَ يَسْعى﴾</span>، قال: ليس بالشدّ، يَعمل بالفساد والمعاصي{2}. (١٥/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨١٣٠٥<span class="dash">-</span></span> قال <span class="name-3">مالك بن أنس</span>: وإنما السعي في كتاب الله العمل والفعل، <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نُودِيَ لِلصَّلاةِ مِن يَوْمِ الجُمُعَةِ فاسْعَوْا إلى ذِكْرِ اللَّهِ وذَرُوا البَيْعَ ذَلِكُمْ خَيْرٌ لَكُمْ إنْ كُنْتُمْ تَعْلَمُونَ﴾</span> [الجمعة:٩]، يقول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وإذا تَوَلّى سَعى فِي الأَرْضِ﴾</span> [البقرة:٢٠٥]، وقال تعالى: <span class="qpc-hafs">﴿وأَمّا مَن جاءَكَ يَسْعى وهُوَ يَخْشى﴾</span> [عبس:٨-٩]، وقال: <span class="qpc-hafs">﴿ثُمَّ أدْبَرَ يَسْعى﴾</span>، وقال: <span class="qpc-hafs">﴿إنَّ سَعْيَكُمْ لَشَتّى﴾</span> [الليل:٤]. قال <span class="name-3">مالك</span>: فليس السعي الذي ذَكر الله في كتابه بالسعي على الأقدام، ولا الاشتداد، وإنما عَنى: العمل، والفعل{5}<span class=comment-ref>٧٠٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٢٥</span> أفادت آثار السلف أنّ قوله: <span class="qpc-hafs">﴿أدبر يسعى﴾</span> مراد به: الإعراض عن الحق والإيمان. وقد ذكر هذا <u>ابنُ عطية</u> (٨/٥٣١)، وزاد <b>قولًا</b> آخر، فقال: «وقال بعض المفسرين: <span class="qpc-hafs">﴿أدبر يسعى﴾</span> حقيقةً؛ قام من موضعه موليًا فارًّا بنفسه عن مجالسة موسى ﵇».</div></p></div>",footnotes:1:تفسير مجاهد ص٧٠٣ بنحوه، وأخرجه ابن جرير ٢٤/٨٣، والفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٧.عزاه السيوطي إلى ابن المنذر.موطأ مالك (ت: د. بشار عواد) ١/١٦٣ (٢٨٦). وتقدم ذكره في سورتي البقرة والجمعة.
