  42,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ أَوۡحَیۡنَاۤ إِلَیۡكَ رُوحࣰا مِّنۡ أَمۡرِنَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span>، قال: القرآن{1}. (١٣/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٢٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span> نبوة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿رُوحًا مِن أمْرِنا﴾</span>، قال: رحمة مِن أمرنا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿رُوحًا مِن أمْرِنا﴾</span>، قال: رحمة من عندنا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span>، قال: وحيًا مِن أمرنا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٣<span class="dash">-</span></span> قال <span class="name-2">مالك بن دينار</span>: <span class="qpc-hafs">﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span>، يعني: القرآن. وكان يقول: يا أصحاب القرآن، ماذا زرع القرآنُ في قلوبكم، فإنّ القرآنَ ربيع القلوب كما أن الغيث ربيع الأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٤<span class="dash">-</span></span> قال <span class="name-2">الربيع [بن أنس]</span>: <span class="qpc-hafs">﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span> جبريل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span> كتابًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله تعالى: <span class="qpc-hafs">﴿وكَذَلِكَ﴾</span> يعني: وهكذا <span class="qpc-hafs">﴿أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</span> يعني: الوحي بأمرنا، كما أوحينا إلى الأنبياء مِن قبلك حين ذكر الأنبياء من قبله، فقال: <span class="qpc-hafs">﴿وما كانَ لِبَشَرٍ أنْ يُكَلِّمَهُ اللَّهُ إلّا وحْيًا أوْ مِن وراءِ حِجابٍ أوْ يُرْسِلَ رَسُولًا فَيُوحِيَ بِإذْنِهِ ما يَشاءُ إنَّهُ عَلِيٌّ حَكِيمٌ﴾</span>{9}<span class=comment-ref>٥٨٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٣١) أن قوله: <span class="qpc-hafs">﴿من أمرنا﴾</span> <b>يعني</b>: «واحد من أمورنا». ثم ذكر <b>احتمالًا آخر</b>، فقال: «ويحتمل أن يكون الأمر بمعنى الكلام».</div></p><p><h3><span class="qpc-hafs">﴿مَا كُنتَ تَدۡرِی مَا ٱلۡكِتَـٰبُ وَلَا ٱلۡإِیمَـٰنُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٣٧<span class="dash">-</span></span> عن علي بن أبي طالب، قال: قيل للنبي ﷺ: هل عبدتَ وثنًا قطّ؟ قال: «<b>لا</b>». قالوا: فهل شربتَ خمرًا قط؟ قال: «<b>لا، وما زلتُ أعرف الذي هم عليه كفرٌ، وما كنتُ أدري ما الكتاب ولا الإيمان</b>». وبذلك نزل القرآن: <span class="qpc-hafs">﴿ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمانُ﴾</span>{10}. (١٣/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٨<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحي</span>: <span class="qpc-hafs">﴿ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمانُ﴾</span>، يعني: الدعوة إلى الإيمان{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمانُ﴾</span>: يعني: محمدًا ﷺ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ما كُنْتَ تَدْرِي ما الكِتابُ﴾</span> يا محمد قبل الوحي ما الكتاب، <span class="qpc-hafs">﴿ولا الإيمانُ﴾</span>{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِن جَعَلۡنَـٰهُ نُورࣰا نَّهۡدِی بِهِۦ مَن نَّشَاۤءُ مِنۡ عِبَادِنَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٤١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَكِنْ جَعَلْناهُ﴾</span>، يعني: الإيمان{2}<span class=comment-ref>٥٨٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٢/٤٣٤) في عود الضمير في قوله: <span class="qpc-hafs">﴿جعلناه﴾</span> قولين: <b>الأول</b>: أنه عائد على الكتاب. <b>الثاني</b>: أنه عائد على الإيمان.</p><p>ثم <span class="comment-type-3">رجح</span> أنّه عائد على الروح، ولم يذكر مستندًا، فقال: «والصحيح أنه يعود على الروح في قوله: <span class="qpc-hafs">﴿روحا من أمرنا﴾</span>».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ تيمية</u> (٥/٥١٣-٥١٤)، و<span class="comment-type-4">بيّن</span> أنه يتناولهما؛ فالروح شامل الإيمان والقرآن.</div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولَكِنْ جَعَلْناهُ نُورًا نَهْدِي بِهِ مَن نَشاءُ مِن عِبادِنا﴾</span>: يعني: بالقرآن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَكِنْ جَعَلْناهُ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿نُورًا﴾</span> يعني: ضياء مِن العمى <span class="qpc-hafs">﴿نَهْدِي بِهِ﴾</span> يعني: بالقرآن من الضَّلالة إلى الهُدى <span class="qpc-hafs">﴿مَن نَشاءُ مِن عِبادِنا﴾</span>{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّكَ لَتَهۡدِیۤ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى- <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</span>، قال: تدعو{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</span>، قال: قال الله: <span class="qpc-hafs">﴿ولِكُلِّ قَوْمٍ هادٍ﴾</span> [الرعد:٧]، قال: داعٍ يدعو إلى الله تعالى{18}. (١٣/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</span>: لكلّ قومٍ هادٍ{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</span>، قال: تدعو إلى دين مستقيم{20}. (١٣/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيم﴾</span>، يقول: تدعو إلى دين مستقيم{12}<span class=comment-ref>٥٨٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٤</span> لم يذكر <u>ابنُ جرير</u> (٢٠/٥٤٣-٥٤٤) غير قول السُّدّي، وقول قتادة من طريق معمر.</div></p><p><div></p><p><p><span class="item-no">٦٩٢٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</span>، يعني: إنك لتدعو إلى دين مستقيم، يعني: الإسلام{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿وإنَّكَ لَتَهْدِي﴾</span>، قال: لتدعو{23}. (١٣/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإنك لتهدي إلى صراط مستقيم﴾</span>، أي: إلى الجنة {24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في التغليق ٤/٣٠٤-. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٧/٢٠١.أخرجه ابن جرير٢٠/٥٤٢.أخرجه عبد الرزاق ٢/١٩٣.أخرجه ابن جرير٢٠/٥٤٢.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٧/٢٠١.تفسير البغوي ٧/٢٠١.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٦/٢٠١.تفسير مقاتل بن سليمان ٣/٧٧٦.أخرجه الواحدي في التفسير الوسيط ٤/٦٢ (٨٢٣)، من طريق إسماعيل بن يحيى بن عبيد الله التميمي، عن أبي سيار، عن الضحاك، عن النزال بن سبرة، عن علي بن أبي طالب به.</p><p>وسنده ضعيف جدًّا؛ فيه إسماعيل بن يحيى بن عبيد الله، وهو متروك. كما في ميزان الاعتدال ١/٢٥٣.تفسير الثعلبي ٨/٣٢٦.أخرجه ابن جرير٢٠/٥٤٤.تفسير مقاتل بن سليمان ٣/٧٧٦.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٧/٢٠١.أخرجه ابن جرير٢٠/٥٤٢.تفسير مقاتل بن سليمان ٣/٧٧٦.أخرجه سفيان الثوري ص٢٦٩.أخرجه ابن جرير ٢٠/٥٤٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٣، وابن جرير٢٠/٥٤٤.عزاه السيوطي إلى ابن جرير، وفي المطبوع منه مثله عن السُّدّي.أخرجه ابن جرير٢٠/٥٤٤.تفسير مقاتل بن سليمان ٣/٧٧٦.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٣٦١.
  42,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿صِرَ ٰ⁠طِ ٱللَّهِ ٱلَّذِی لَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ أَلَاۤ إِلَى ٱللَّهِ تَصِیرُ ٱلۡأُمُورُ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿صِراطِ اللَّهِ﴾</span> يقول: دين الله <span class="qpc-hafs">﴿الَّذِي لَهُ ما فِي السَّماواتِ وما فِي الأَرْضِ﴾</span> خلْقه وعبيده، وفي قبضته، <span class="qpc-hafs">﴿ألا إلى اللَّهِ تَصِيرُ الأُمُورُ﴾</span> يعني: أمور الخلائق في الآخرة تصير إليه، فيجزيهم بأعمالهم، والله غفور لذنوب العباد، رحيم بهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿صراط الله﴾</span> طريق الله الذي هدى له عبادَه المؤمنين إلى الجنة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٧٦-٧٧٧.تفسير يحيى بن سلام ١/٣٦١.
  43,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٥٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت بمكة سورة «حم الزخرف»{2}. (١٣/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراساني-: مكية، ونزلت بعد «حم عسق»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية، وسمّياها: «حم الزخرف»{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٥٩<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٠<span class="dash">-</span></span> عن محمد بن شهاب الزّهري: مكية، وسمّاها: «حم الزخرف»، ونزلت بعد «حم عسق»{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦١<span class="dash">-</span></span> عن محمد بن شهاب الزهري -من طريق موسى بن عقبة- قال: بعث رسولُ الله ﷺ مصعبَ بن عمير، فنزل في بني غنم على أسعد بن زرارة، فجعل يدعو الناس، فجاء سعد بن معاذ، فتوعّده، فقال له أسعد بن زرارة: استمع مِن قوله، فإن سمعتَ منكرًا فاردُدْه بأهدى منه، وإن سمعتَ حقًّا فأجِبْ إليه. فقال: ماذا تقول؟ فقرأ عليه مصعب: <span class="qpc-hafs">﴿حم * والكِتابِ المُبِينِ * إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا لَعَلَّكُمْ تَعْقِلُونَ﴾</span>. قال سعد بن معاذ: ما أسمع إلا ما أعرف. فرجع وقد هداه الله{7}. (١٣/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٢<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٣<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الزخرف مكية، عددها تسع وثمانون آية كوفية{9}<span class=comment-ref>٥٨٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٣٢) أن هذه السورة مكية <span class="mustanad">بإجماع من أهل العلم</span>.</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه البيهقي في الدلائل ٢/٤٣١-٤٣٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٧٨٧.
  43,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حمۤ ۝١ وَٱلۡكِتَـٰبِ ٱلۡمُبِینِ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿حم والكِتابِ المُبِينِ﴾</span>، قال: مُبين -واللهِ- بركته، وهُداه، ورُشده{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿حم والكِتابِ المُبِينِ﴾</span>: هو هذا الكتاب المبين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حم والكِتابِ المُبِينِ﴾</span>، يعني: البيِّنُ ما فيه{3}<span class=comment-ref>٥٨٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٣٢) أن قوله: <span class="qpc-hafs">﴿المُبِين﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يكون مِن: أبان، الذي هو بمعنى: بان، أي: ظهر، فلا يحتاج إلى مفعول. <b>الثاني</b>: ويحتمل أن يكون مُعدًّى من: بان، فهذا لا بد له من مفعول، تقديره: المبين الهدى والشرع ونحوه.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٥٤٦.أخرجه ابن جرير ٢٠/٥٤٦.تفسير مقاتل بن سليمان ٣/٧٨٩.
  43,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا جَعَلۡنَـٰهُ قُرۡءَ ٰ⁠ نًا عَرَبِیࣰّا لَّعَلَّكُمۡ تَعۡقِلُونَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٦٧<span class="dash">-</span></span> عن طاووس، قال: جاء رجلٌ إلى <span class="name-1">ابن عباس</span> مِن حَضرمَوْت، فقال له: يا ابن عباس، أخبِرني عن القرآن، أكلامٌ مِن كلام الله، أمْ خلْق مِن خلْق الله؟ قال: بل كلام مِن كلام الله، أوَما سمعت الله يقول: <span class="qpc-hafs">﴿وإنْ أحَدٌ مِنَ المُشْرِكِينَ اسْتَجارَكَ فَأَجِرْهُ حَتّى يَسْمَعَ كَلامَ اللَّهِ﴾</span> [التوبة:٦]؟ فقال له الرجل: أفرأيت قوله: <span class="qpc-hafs">﴿إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا﴾</span>؟ قال: كتبه الله في اللوح المحفوظ بالعربية، أما سمعت الله يقول: <span class="qpc-hafs">﴿بَلْ هُوَ قُرْآنٌ مَجِيدٌ فِي لَوْحٍ مَحْفُوظٍ﴾</span> [البروج:٢١-٢٢]؟ المجيد: هو العزيز، أي: كتبه الله في اللوح المحفوظ{1}. (١٣/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا﴾</span> ليفقهوا ما فيه، ولو كان غير عربيٍّ ما عقلوه، <span class="qpc-hafs">﴿لَعَلَّكُمْ تَعْقِلُونَ﴾</span> يقول: لكي تعقلون ما فيه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٦٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span>، قال: كلام أهل السماء العربية. ثم قرأ: <span class="qpc-hafs">﴿حم والكِتابِ المُبِين إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا﴾</span> الآيتين{3}. (١٣/١٨٤)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٧٨٩.أخرجه ابن أبي شيبة ١٠/٤٥٩.
  43,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ فِیۤ أُمِّ ٱلۡكِتَـٰبِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٧٠<span class="dash">-</span></span> عن أنس، أنّ رسول الله ﷺ قال: «<b>إنّ الله كتب كتابًا قبل أن يخلق السماوات والأرض، وهو عنده فوق العرش، الخلْق منتهون إلى ما في ذلك الكتاب، وتصديقُ ذلك في كتاب الله: <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</span></b>»{1}. (١٣/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عروة بن عامر- قال: إنّ أول ما خلق الله من شيء القلم، فأمره أن يكتب ما هو كائِن إلى يوم القيامة، والكتاب عنده. ثم قرأ: <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</span>{2}. (١٣/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران- <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا﴾</span>، قال: أُمّ الكتاب: القرآن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</span>، قال: القرآن عند الله في أُمِّ الكتاب{4}. (١٣/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٤<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد [العوفي]</span> -من طريق إدريس- في قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</span>: يعني: القرآن في أُمّ الكتاب الذي عند الله، منه نُسِخ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٥<span class="dash">-</span></span> عن أبي صخر، قال: سمعت <span class="name-2">محمد بن كعب القُرظي</span> يقول: أرأيتَ هؤلاء القدريين يؤمنون سورة: <span class="qpc-hafs">﴿حم والكتاب المبين إنا جعلناه قرءانًا عربيًا لعلكم تعقلون وإنه في أم الكتاب لدينا لعليّ حكيم﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</span>، قال: في أصل الكتاب، وجملته{7}. (١٣/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٧<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن عبد الله بن سابِط الجُمَحي</span>، في قوله:<span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</span>، قال: في أُمّ الكتاب ما هو كائن إلى يوم القيامة، وُكِّل ثلاثة مِن الملائكة يحفظون، فوُكِّل جبريل بالوحي ينزل به إلى الرسل، وبالهلاك إذا أراد أن يُهلِك قومًا كان صاحب ذلك، ووُكِّل أيضًا بالنصر في الحروب إذا أراد الله أن ينصر، ووُكِّل ميكائيل بالقطر أن يحفظه، ووُكِّل بنبات الأرض أن يحفظه، ووُكِّل مَلك الموت بقبْض الأنفس، فإذا ذهبت الدنيا جُمِع بين حفظهم وحِفْظ أُمِّ الكتاب فوجدوه سواءً{8}. (١٣/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</span>، يقول: في الكتاب الذي عند الله في الأصل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</span> يقول لأهل مكة: إن كذَّبتم بهذا القرآن فإنّ نُسختَه في أصل الكتاب، يعني: اللوح المحفوظ <span class="qpc-hafs">﴿لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا﴾</span>، قال: الذّكر الحكيم فيه كلّ شيء كان، وكلّ شيء يكون، وما نزل من كتاب فمنه{4}. (١٣/١٨٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَدَیۡنَا لَعَلِیٌّ حَكِیمٌ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿لَدَيْنا﴾</span> أي: عندنا <span class="qpc-hafs">﴿لَعَلِيٌّ حَكِيمٌ﴾</span> يخبر عن منزلته، وفضله، وشرفه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لدينا لَعَلِيٌّ﴾</span> يقول: عندنا مرفوع، <span class="qpc-hafs">﴿حَكِيمٌ﴾</span> يعني: مُحكَم مِن الباطل{10}<span class=comment-ref>٥٨٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٧</span> <span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٢/٤٣٦): «قوله: <span class="qpc-hafs">﴿لدينا﴾</span> <b>يجوز</b> فيه أن تكون من صلة <span class="qpc-hafs">﴿أُمّ الكتاب﴾</span>، أي: أنه في الكتاب الذي عندنا. وهذا اختيار ابن عباس. و<b>يجوز</b> أن يكون من صلة الخبر؛ أنه عليّ حكيم عندنا ليس هو كما عند المكذبين به، أي: وإن كذبتم به وكفرتم فهو عندنا في غاية الارتفاع والشرف».</div></p></div>",footnotes:1:أخرجه أبو نعيم في تاريخ أصبهان ١/٣٨٣، من طريق سعيد بن عيسى الكريزي أبي عثمان، ثنا أبو داود، ثنا همام بن يحيى، عن سعيد بن أبي عروبة، عن قتادة، عن أنس به.</p><p>إسناده ضعيف؛ فيه سعيد بن عيسى الكريزي، قال عنه الدارقطني: «ضعيف». كما في لسان الميزان لابن حجر ٤/٧٠.أخرجه ابن جرير ٢٠/٥٤٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/٥٤٧.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٤٧.أخرجه إسحاق البستي ص٣١١. ولفظ الأثر كذا ورد في المصدر.أخرجه عبد الرزاق ٢/١٩٤، وابن جرير ٢٠/٥٤٧ بنحوه، كذلك من طريق سعيد بنحوه.أخرجه ابن أبي شيبة ١٣/٤٣٠ مختصرًا، وأبو الشيخ في العظمة (٤٩٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٤٧.تفسير مقاتل بن سليمان ٣/٧٨٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٤٧.تفسير مقاتل بن سليمان ٣/٧٨٩.
  43,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ صَفۡحًا أَن كُنتُمۡ قَوۡمࣰا مُّسۡرِفِینَ ۝٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٨٣<span class="dash">-</span></span> عن <span class="name-2">عاصم</span>، أنّه قرأ: <span class="qpc-hafs">﴿أنْ كُنتُمْ﴾</span> بنصب الألف{1}<span class=comment-ref>٥٨٣٨</span>. (١٣/١٨٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٨</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿أن كنتم﴾</span>؛ فقرأ قوم بفتح الهمزة، وقرأ غيرهم بكسرها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٥٥٠) أن قراءة الفتح بمعنى: لأن كنتم، وقراءة الكسر بمعنى: أفنضرب عنكم الذكر صفحًا إذ كنتم قومًا مسرفين.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٧/٥٣٤).</p><p>ثم <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٥١) صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، وصحة معناهما، وإلى لغة العرب</span>، فقال: «والصواب مِن القول في ذلك عندنا: أنّ الكسر والفتح في الألف في هذا الموضع قراءتان مشهورتان في قرأة الأمصار صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب، وذلك أن العرب إذا تقدّم»أن«-وهي بمعنى الجزاء- فعلٌ مستقبِل كسروا ألفها أحيانًا، فمحّضوا لها الجزاء، فقالوا: أقوم إن قمت. وفتحوها أحيانًا، وهم ينوون ذلك المعنى، فقالوا: أقوم أن قمت. بتأويل: لأن قمت، فإذا كان الذي تقدمها من الفعل ماضيًا لم يتكلموا إلا بفتح الألف من»أن«فقالوا: قمتُ أَنْ قمتَ، وبذلك جاء التنزيل، وتتابع شعر الشعراء».</div></p><p><h3><span class="qpc-hafs">﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ صَفۡحًا أَن كُنتُمۡ قَوۡمࣰا مُّسۡرِفِینَ ۝٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span>، قال: أحسبتم أنْ نصفح عنكم ولم تفعلوا ما أُمِرتُم به{2}. (١٣/١٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span>، قال: تُكَذِّبون بالقرآن، ثم لا تُعاقَبون عليه{3}. (١٣/١٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: لم يبعث اللهُ رسولًا إلا أن أنزل عليه كتابًا، فإنْ قَبِله قومُه وإلّا رُفِع، فذلك قوله: <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا أنْ كُنْتُمْ قَوْمًا مُسْرِفِينَ﴾</span> لا تقبلونه، فتلقّته قلوب نقِيَّةٌ، قالوا: قَبِلناه، ربَّنا، قَبِلناه، ربَّنا. ولو لم يفعلوا لرُفِع، ولم يُترك منه شيء على ظهر الأرض{4}. (١٣/١٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span>، قال: العذاب{5}. (١٣/١٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span>، قال: لو أنّ هذه الأمة لم يؤمنوا لضُرِب عنهم الذِّكر صفحًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أفنضرب عنكم الذّكر صفحًا ان كنتم قومًا مسرفين﴾</span>: أي: مشركين. واللهِ، لو أنّ هذا القرآن رُفِع حين ردَّه أوائلُ هذه الأمة لهلكوا، ولكنَّ الله عاد بعائدته ورحمته، كرّره عليهم، ودعاهم إليه عشرين سنة، أو ما شاء الله مِن ذلك{7}<span class=comment-ref>٥٨٣٩</span>. (١٣/١٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٣٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٢/٣٠٠) على هذا القول الذي قاله قتادة، وابن زيد، والحسن، فقال: «وقول قتادة لطيف المعنى جدًّا، وحاصله أنه يقول في معناه: إنّه تعالى من لطفه ورحمته بخلْقه لا يترك دعاءهم إلى الخير والذّكر الحكيم -وهو القرآن-، وإن كانوا مسرفين معرضين عنه، بل يأمر به ليهتدي مَن قَدّر هدايته، وتقوم الحجة على مَن كَتب شقاوته».</div></p><p><div></p><p><p><span class="item-no">٦٩٢٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span>، قال: أفنضرب عنكم العذاب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٩١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿صَفْحًا﴾</span> أنَذَرُ الذِّكرَ مِن أجلكم؟!{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٩٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span> أفنترككم سُدًى؛ لا نأمركم، ولا ننهاكم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span> يقول لأهل مكة: أفنُذهِب عنكم هذا القرآن سُدًى؛ لا تُسألون عن تكذيبٍ به <span class="qpc-hafs">﴿أنْ كُنْتُمْ قَوْمًا مُسْرِفِينَ﴾</span> يعني: مشركين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٢٩٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</span> قال: الذِّكر ما أُنزل عليهم مما أمرهم الله به ونهاهم <span class="qpc-hafs">﴿صَفْحًا﴾</span> لا نذكر لكم منه شيئًا{12}<span class=comment-ref>٥٨٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٠</span> اختُلف في المراد بالذِّكْر على قولين: <b>الأول</b>: أنّه ذِكْر العذاب، فالمعنى: أفنُمْسِكُ عن عذابكم ونترُكُكم على كفركم؟!. <b>الثاني</b>: أنه القرآن، فالمعنى: أفنُمْسِكُ عن إنزال القرآن من أجل أنكم لا تؤمِنون به؟!</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٥٠) -<span class="mustanad">مستندًا إلى السياق</span>- القولَ الأول الذي قاله ابن عباس، والسُّدّيّ، ومجاهد، وأبو صالح، ومقاتل، فقال: «لأنّ الله -تبارك وتعالى- أتْبَع ذلك خبرَه عن الأمم السالفة قبل الأُمَّة التي توعّدها بهذه الآية في تكذيبها رسلها، وما أحلّ بها مِن نقمته، ففي ذلك دليلٌ على أنّ قوله: <span class="qpc-hafs">﴿أفنضرب عنكم الذكر صفحا﴾</span> وعيدٌ منه للمخاطبين به مِن أهل الشِّرك؛ إذ سلكوا في التكذيب بما جاءهم عن الله رسولهم مسلك الماضين قبلهم».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٥٣٣-٥٣٤): "قوله تعالى: <span class="qpc-hafs">﴿صَفْحًا﴾</span> انتصابه كانتصاب <span class="qpc-hafs">﴿صُنْعَ اللَّهِ﴾</span> [النمل:٨٨]، فيحتمل أن يكون بمعنى: العفو والغفر للذنب، فكأنه يقول: أفنترك تذكيركم وتخويفكم عفوًا عنكم وغفرًا لإجرامكم أن كنتم، أو من أجل أن كنتم قومًا مسرفين، هذا لا يصلح، وهذا قول ابن عباس ومجاهد، ويحتمل قوله: <span class="qpc-hafs">﴿صَفْحًا﴾</span> أن يكون بمعنى: مغفولًا عنه، أي: نتركه يمرُّ لا تؤخذون بقوله ولا بتدبُّره ولا تُنَبهون عليه، وهذا المعنى نظير قول الشاعر:</p><p>تمر الصبا صفحًا بساكن ذي الغضا ويصدع قلبي إن يهب هبوبها</p><p>أي: تمر مغفولًا عنها، فكأن هذا المعنى: أفنترككم سدًى، وهذا هو منحى قتادة وغيره، ومن اللفظة قول كثير:</p><p>صفوحًا فما تلقاك إلا بخيلة فمَن ملّ منها ذلك الوصل ملّت".</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة، ماعدا نافعًا، وأبا جعفر، وحمزة، والكسائي، وخلفًا العاشر؛ فإنهم قرؤوا: ‹إن كُنتُمْ› بكسر الهمزة. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٤.أخرجه ابن جرير ٢٠/٥٤٩.تفسير مجاهد ص٥٩٢، وأخرجه الفريابي -كما في التغليق ٤/٣٠٦، والفتح ٨/٥٦٦-، وابن جرير ٢٠/٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى محمد بن نصر في كتاب الصلاة.أخرجه ابن جرير ٢٠/٥٤٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/٥٤٩.أخرجه ابن جرير ٢٠/٥٤٩، وإسحاق البستي ص٣١٣، وابن أبي حاتم -كما في الفتح ٨/٥٦٩-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٥٤٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٥-.تفسير الثعلبي ٨/٣٢٨، وتفسير البغوي ٧/٢٠٦.تفسير مقاتل بن سليمان ٣/٧٨٩.أخرجه ابن جرير ٢٠/٥٤٩-٥٥٠.
  43,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَمۡ أَرۡسَلۡنَا مِن نَّبِیࣲّ فِی ٱلۡأَوَّلِینَ ۝٦ وَمَا یَأۡتِیهِم مِّن نَّبِیٍّ إِلَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٢٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يَأْتِيهِمْ مِن نَبِيٍّ﴾</span> ينذرهم العذاب <span class="qpc-hafs">﴿إلّا كانُوا بِهِ﴾</span> يعني: بالعذاب <span class="qpc-hafs">﴿يسْتَهْزِئُونَ﴾</span> بأنّه غيرُ نازِل بهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨٩.
  43,7,""
  42,53,""
