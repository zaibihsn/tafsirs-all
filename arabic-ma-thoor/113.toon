quran[5]{c,v,t}:
  113,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٠١<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، قالت: كان لرسول الله ﷺ غلام يهودي يخدمه، يقال له: لَبِيد بن أعصم. فلم تَزل به يهود حتى سَحر النبيَّ ﷺ، وكان رسول الله ﷺ يذوب ولا يدري ما وجَعه، فبينا رسول الله ﷺ ذات ليلة نائم إذ أتاه مَلكان، فجلس أحدهما عند رأسه، والآخر عند رجليه، فقال الذي عند رأسه للذي عند رجليه: ما وجَعه؟ قال: مطبوب. قال: مَن طبّه؟ قال: لَبِيد بن أعصم. قال: بم طبّه؟ قال: بمُشط ومُشاطة{1} وجُفِّ طلْعة{2} ذَكر، بذي أرْوان{3}، وهي تحت راعُوفة البئر{4}. فلما أصبح رسول الله ﷺ غدا ومعه أصحابه إلى البئر، فنزل رجل، فاستخرج جُفّ طَلْعةٍ مِن تحت الراعُوفة، فإذا فيها مُشط رسول الله ﷺ ومِن مُشاطة رأسه، وإذا تمثالٌ مِن شمعٍ تمثال رسول الله ﷺ، وإذا فيها إبَرٌ مغروزة، وإذا وتَرٌ فيه إحدى عشرة عُقدة، فأتاه جبريل بالمُعوّذتين، فقال: يا محمد، <span class="qpc-hafs">﴿قل أعُوذُ بِرَبِّ الفَلَقِ﴾</span> وحلّ عُقدة، <span class="qpc-hafs">﴿مِن شَرِّ ما خَلَقَ﴾</span> وحلّ عُقدة، حتى فرغ منها وحلّ العُقَد كلّها، وجعل لا ينزع إبرة إلا وجد لها ألَمًا، ثم يجد بعد ذلك راحة، فقيل: يا رسول الله، لو قتلتَ اليهودي. فقال: «<b>قد عافاني الله، وما وراءه من عذاب الله أشد</b>». فأخرجه{5}. (١٥/٧٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: أنّ لَبِيد بن الأعصم اليهودي سَحر النبيَّ ﷺ، وجعل تمثالًا فيه إحدى عشرة عُقدة، فأصابه مِن ذلك وجع شديد، فأتاه جبريل وميكائيل يعودانه، فقال ميكائيل: يا جبريل، إنّ صاحبك شاكٍ. قال: أجل، أصابه لَبِيد بن الأعصم اليهودي، وهو في بئر ميمونة، في كَرَبة{6} تحت صخرة في الماء. قال: فما دواء ذلك؟ قال: تُنزح البئر، ثم تُقلب الصخرة، فتوجد الكَرَبة فيها تمثالٌ فيه إحدى عشرة عُقدة، فتُحرق، فإنّه يبرأ بإذن الله. فأرسل إلى رهطٍ منهم عمّار بن ياسر، فنزح الماء، فوجدوه قد صار كأنه ماء الحناء، ثم قُلبت الصخرة، فإذا كَربة فيها صخرة فيها تمثالٌ فيه إحدى عشرة عُقدة، فأنزل الله: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد: <span class="qpc-hafs">﴿أعُوذُ بِرَبِّ الفَلَقِ﴾</span> الصبح. فانحلّتْ عُقدة، <span class="qpc-hafs">﴿مِن شَرِّ ما خَلَقَ﴾</span> من الجنّ والإنس. فانحلّتْ عُقدة، <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span> الليل وما يجيء به النهار، <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span> السحّارات المؤذيات. فانحلّتْ عُقدة، <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>{7}. (١٥/٧٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٣<span class="dash">-</span></span> قال <span class="name-1">ابن عباس</span>، و<span class="name-1">عائشة</span> –دخل حديث بعضهما في بعض-: كان غلام من اليهود يخدم رسول الله ﷺ، فدبَّت إليه اليهود، فلم يزالوا به حتى أخذ مشاطة رأس النبي ﷺ وعدة أسنان مِن مشطه، فأعطاها اليهود، فسحروه فيها، وكان الذي تولى ذلك رجل منهم يقال له: لبيد بن أعصم، ثم دسها في بئر بني زريق، يقال لها: ذَروان، فمرض رسول الله ﷺ، وانتثر شعر رأسه، ولبث ستة أشهر يرى أنه يأتي النساء ولا يأتيهن، وجعل يذوب ولا يدري ما عراه، فبينما هو نائم إذ أتاه ملكان، فقعد أحدهما عند رأسه، والآخر عند رجليه، فقال الذي عند رجليه للذي عند رأسه: ما بال الرجل؟ قال: طُبَّ. قال: وما طُبَّ؟ قال: سُحِر. قال: ومن سَحَره؟ قال: لبيد بن أعصم اليهودي. قال: وبم طَبَّه؟ قال: بمشط ومشاطة. قال: وأين هو؟ قال: في جُفِّ طلعةٍ تحت راعوفة في بئر ذروان -والجف: قشر الطلع، والراعوفة: حجر في أسفل البئر كان يقوم عليه المائح-. فانتبه رسول الله ﷺ مذعورًا، وقال: «<b>يا عائشة، أما شعرت أن الله تعالى أخبرني بدائي</b>». ثم بعث رسول الله ﷺ عليًّا والزبير وعمار بن ياسر، فنَزحوا ماء البئر كأنه نُقاعة الحِنّاء{8}، ثم رفعوا الصخرة، وأخرجوا الجُفّ، فإذا فيه مُشاطة رأسه، وأسنانٌ من مشطه، وإذا وتر معقود فيه إحدى عشرة عقدة، مغروزة بالإبَر. فأنزل الله تعالى السورتين، فجعل كلما قرأ آية انحلَّت عقدة، ووجد رسول الله ﷺ خِفَّة، حتى انحلت العقدة الأخيرة، فقام كأنما أُنشِط من عِقال{9}، وجعل جبريل ﵇ يقول: باسم الله أرقيك، من كل شيء يؤذيك، من حاسد وعين، والله يشفيك. فقالوا: يا رسول الله، أفلا نأخذ الخبيث نقتله؟ فقال رسول الله ﷺ: «<b>أما أنا فقد شفاني الله، وأكره أن يثير على الناس شرًّا</b>»{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٤<span class="dash">-</span></span> عن <span class="name-1">زيد بن أرقم</span>، قال: سَحَر النبيَّ ﷺ رجلٌ من اليهود، فاشتكى، فأتاه جبريل فنزل عليه بالمُعوّذتين، وقال: إنّ رجلًا من اليهود سَحرك، والسِّحر في بئر فلان. فأرسل عليًّا، فجاء به، فأمره أن يحُلّ العُقد، ويقرأ آية، فجعل يقرأ ويحُلّ، حتى قام النَّبِيّ ﷺ كأنما نشِط من عِقال{11}. (١٥/٧٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span> وذلك أنّ لَبِيد بن عاصم بن مالك، ويقال: ابن أعصم اليهودي، سَحر النبي ﷺ في إحدى عشرة عُقدة في وتَرٍ، فجعله في بئر لها سبع موانى في جُفّ طَلْعةٍ كان النبي ﷺ يستند إليها، فَدَبّ فيه السِّحر، واشتدّ عليه ثلاث ليالٍ، حتى مرض مرضًا شديدًا، وجزعت النساء، فنَزَلَت المعوّذات، فبينما رسول الله ﷺ نائم إذ رأى كأن مَلَكين قد أتياه، فقعد أحدهما عند رأسه، والآخر عند رجليه، ثم قال أحدهما لصاحبه: ما شكواه؟ قال: أصابه طِبّ -يقول: سِحر-. قال: فمَن طبَّه؟ قال: لَبِيد بن أعصم اليهودي. قال: في أي شيء؟ قال: في قِشر طَلْعة. قال: فأين هو؟ قال: في بئر فلان. قال: فما دواؤه؟ قال: تُنزف البئر، ثم يُخرج قِشر الطَّلعة، فيحرقه، ثم يحِل العُقد، كلّ عُقدة بآية من المُعوّذتين، فذلك شفاؤه. فلما استيقظ النبي ﷺ وجّه علي بن أبي طالب إلى البئر، فاستخرج السِّحر، وجاء به، فأَحرق ذلك القِشر. ويقال: إنّ جبريل أخبر النبي ﷺ بمكان السِّحر، وقال جبريل للنبي ﷺ: حُلّ عُقدة، واقرأ آية. ففعل النبي ﷺ ذلك، فجعل يذهب عنه ما كان يجد حتى برأ وانتشر للنساء{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٦<span class="dash">-</span></span> عن عبد الله بن مسعود، أنّ النبيَّ ﷺ سُئل عن هاتين السورتين. فقال: «<b>قيل لي فقلتُ، فقولوا كما قلتُ</b>»{13}. (١٥/٧٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٧<span class="dash">-</span></span> عن زِرّ بن حُبَيش، قال: أتيتُ المدينة، فلقيتُ أُبيّ بن كعب، فقلت: يا أبا المنذر، إني رأيتُ ابن مسعود لا يكتب المُعوّذتين في مُصحفه، فقال: أما -والذي بعث محمدًا بالحقّ- قد سألتُ رسول الله ﷺ عنهما، وما سألني عنهما أحدٌ منذ سألته غيرُك، قال: «<b>قيل لي: قُل. فقلتُ، فقولوا</b>». فنحن نقول كما قال رسول الله ﷺ{14}. (١٥/٧٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٨<span class="dash">-</span></span> عن عُقبة بن عامر، قال: بينا أنا أسير مع رسول الله ﷺ فيما بين الجُحفة والأبواء إذ غشينا ريح وظُلمة شديدة، فجعل رسول الله ﷺ يتعوّذ بـ<span class="qpc-hafs">﴿أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، و<span class="qpc-hafs">﴿أعُوذُ بِرَبِّ النّاسِ﴾</span>، ويقول: «<b>يا عُقبة، تعوّذ بهما، فما تعوّذ متعوّذ بمثلهما</b>». قال: وسمعتُه يؤُمّنا بهما في الصلاة{15}. (١٥/٧٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٠٩<span class="dash">-</span></span> عن عُقبة بن عامر، قال: لقيتُ رسول الله ﷺ ... فقال: «<b>يا عُقبة بن عامر، ألا أعلّمك خير ثلاث سور أُنزِلَتْ في التوراة والإنجيل والزّبور والفرقان العظيم!</b>». قال: قلتُ: بلى، جعلني الله فِداك. قال: فأقرأني: <span class="qpc-hafs">﴿قُلْ هُوَ اللَّهُ أحَدٌ﴾</span> و<span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span> و<span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span>. ثم قال: «<b>يا عُقبة، لا تنساهنّ، ولا تَبِتْ ليلة حتى تقرأهنّ</b>»{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٠<span class="dash">-</span></span> عن أبي سعيد الخدريّ، قال: كان رسول الله ﷺ يتعوّذ من عين الجانّ، ومن عين الإنس، فلما نزلت سورة المُعوّذتين أخذهما، وترك ما سوى ذلك{17}. (١٥/٧٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١١<span class="dash">-</span></span> عن أنس بن مالك، قال: صنعت اليهود بالنبي ﷺ شيئًا، فأصابه منه وجعٌ شديد، فدخل عليه أصحابه، فخرجوا من عنده وهم يرون أنه لُمَّ به{18}، فأتاه جبريل بالمُعوّذتين، فعوّذه بهما ثم قال: باسم الله أرقيك، من كلّ شيء يؤذيك، ومن كلّ عين ونفس حاسد يشفيك، باسم الله أرقيك{19}. (١٥/٧٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٢<span class="dash">-</span></span> عن أبي العلاء يزيد بن عبد الله بن الشَّخِّير، قال: قال رجل: كُنّا مع رسول الله ﷺ في سَفرٍ والناس يعتقبون{20} وفي الظَّهر قِلّة، فجاءت نَزْلة رسول الله ﷺ ونَزْلَتي، فلحقني، فضرب مَنكِبيّ، فقال: <b><span class="qpc-hafs">﴿قُل أعُوذُ بِرَبِّ الفَلَقِ﴾</span></b>. فقلتُ: أعوذ برب الفلق. فقرأها رسول الله ﷺ وقرأتُها معه، ثم قال: <b><span class="qpc-hafs">﴿قُل أعُوذُ بِرَبِّ النّاسِ﴾</span></b>. فقرأها رسول الله ﷺ وقرأتُها معه. قال: «<b>إذا أنت صَلَّيتَ فاقرأ بهما</b>»{21}. (١٥/٧٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٣<span class="dash">-</span></span> عن أبي عابس الجُهنيّ، أنّ رسول الله ﷺ قال له: «<b>يا ابن عابس، ألا أُخبرك بأفضل ما تعوّذ به المُتعوّذون</b>!». قال: بلى، يا رسول الله. قال: «<b><span class="qpc-hafs">﴿أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، و<span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span>، هما المُعوّذتان</b>»{22}. (١٥/٧٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٤<span class="dash">-</span></span> عن أنس بن مالك: أنّ النبيَّ ﷺ ركب بغلة، فحادت به، فحبسها، وأمر رجلًا أن يقرأ عليها: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ مِن شَرِّ ما خَلَقَ﴾</span>، فسكنت ومضت{23}. (١٥/٧٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٥<span class="dash">-</span></span> عن أبي هريرة، قال: أهدى النّجاشي إلى رسول الله ﷺ بغلة شهباء، فكان فيها صعوبة، فقال للزُّبير: «<b>اركبها، وذلِّلها</b>». فكأن الزُّبير اتقى، فقال له: «<b>اركبها، واقرأ القرآن</b>». قال: ما أقرأ؟ قال: «<b>اقرأ: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، فوالذي نفسي بيده، ما قمتَ تُصلِّي بمثلها</b>»{24}. (١٥/٧٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عبد الرحمن بن يزيد-: أنه كان يحكّ المُعوّذتين من المصحف، ويقول: لا تخلطوا القرآن بما ليس منه، إنهما ليستا من كتاب الله، إنّما أُمِر النبيُّ ﷺ أن يُتعوّذ بهما. وكان ابن مسعود لا يقرأ بهما. قال البزار: لم يتابع ابنَ مسعود أحدٌ من الصحابة، وقد صح عن النبيِّ ﷺ أنه قرأ بهما في الصلاة، وأُثبتتا في المصحف{25}<span class=comment-ref>٧٣٣٩</span>. (١٥/٧٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٧٣٣٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/٥١٧) على قول ابن مسعود بقوله: «وهذا مشهور عند كثير من القراء والفقهاء، أنّ ابن مسعود كان لا يكتب المُعوّذتين في مصحفه، فلعله لم يسمعهما من النبي، ولم يتواتر عنده، ثم لعلّه قد رجع عن قوله ذلك إلى قول الجماعة، فإنّ الصحابة كتبوهما في المصاحف الأئمة، ونفذوها إلى سائر الآفاق كذلك».</div></p><p><div></p><p><p><span class="item-no">٨٥٦١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: إذا قرأتَ: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span> فقُل: أعوذ برب الفلق. وإذا قرأتَ: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span> فقُل: أعوذ برب الناس{26}. (١٥/٧٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مدنية{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦١٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيف، عن مجاهد-: مكّيّة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٠<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمّى: <span class="qpc-hafs">﴿قل أعوذ برب الفلق﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿ألم تر كيف فعل ربك﴾</span>{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢١<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٢<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٣<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٤<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة الفيل{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٥<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٦<span class="dash">-</span></span> عن مقاتل بن سليمان: مكّيّة، عددها خمس آيات{34}. (ز)</p></p><p></div></p></div>",footnotes:1:المشاطة: هي الشعر الذي يسقط من الرأس واللحية عند التسريح بالمشط. النهاية (مشط).جف الطلعة: وعاء الطلعة، وهو الغشاء الذي يكون فوقه. النهاية (جفف).ذو أروان: هي بئر لبني زريق بالمدينة. تاج العروس (أرى، ذرو).راعوفة البئر: هي صخرة تُترك في أسفل البئر، إذا حفرت تكون ناتئة هناك، فإذا أرادوا تنقية البئر جلس المنقي عليها. النهاية (رعف).أخرجه المستغفري في فضائل القرآن ٢/٧٣١-٧٣٢ (١٠٩٧)، والبيهقي في الدلائل ٧/٩٢-٩٤. والحديث بلفظ آخر عند البخاري ٤/١٢٢ (٣٢٦٨)، ٧/١٣٦-١٣٨ (٥٧٦٣، ٥٧٦٥، ٥٧٦٦)، ٨/١٨-١٩ (٦٠٦٣)، ٨/٨٣ (٦٣٩١)، ومسلم ٤/١٧١٩-١٧٢٠ (٢١٨٩) دون ذكر المعوذتين.</p><p>قال الألباني في الصحيحة ٦/٦١٨: «هذا إسناد ضعيف جدًّا».كربة: أصل السعف. وقيل: ما يبقى من أصوله في النخلة بعد القطع. اللسان (كرب).عزاه السيوطي إلى ابن مردويه.نُقاعة الحِنّاء: قال الداودي: المراد: الماء الذي يكون من غُسالة الإناء الذي تُعجن فيه الحِنّاء. فتح الباري لابن حجر ١٠/٢٣٠.أُنشِط من عقال: حَلَّ. النهاية (نشط).أورده الثعلبي ١٠/٣٣٨، والبغوي ٨/٥٩١ مختصرًا.</p><p>قال ابن كثير ٨/٥٣٨ بعد إيراد سياق الثعلبي للحديث معزوًّا إليه: «هكذا أورده بلا إسناد، وفيه غرابة، وفي بعضه نكارة شديدة، ولبعضه شواهد مما تقدم».أخرجه عبد بن حميد في المنتخب من مسنده ١/٢٢٨ (٢٧١)، والطحاوي في شرح مشكل الآثار ١٥/١٨٠ (٥٩٣٥).</p><p>وأخرجه بنحوه أحمد ٣٢/١٤ (١٩٢٦٧)، والنسائي ٧/١١٢ (٤٠٨٠).</p><p>وذكره الألباني في السلسلة الصحيحة (٢٧٦١).تفسير مقاتل بن سليمان ٤/٩٣٣-٩٣٤.أخرجه الطبراني في الكبير ١٠/١٣٢ (١٠٢١١)، وفي الأوسط ٤/١٣ (٣٤٨٨).</p><p>قال الهيثمي في المجمع ٧/١٥٠ (١١٥٦٤): «فيه إسماعيل بن مسلم المكي، وهو ضعيف».أخرجه عبد الرزاق ٢/٤١١، وأحمد ٣٥/١١٦ (٢١١٨٦)، والبخاري (٤٩٧٦، ٤٩٧٧)، والنسائي -كما في تحفة الأشراف (١٩)-، وابن الضريس (٢٩١)، وابن حبان (٧٩٧). وعزاه السيوطي إلى ابن الأنباري، وابن مردويه.أخرجه أبو داود ٢/٥٩١ (١٤٦٣).</p><p>قال ابن القطان في بيان الوهم والإيهام ٤/٦٢١ (٢١٧٧): «وسكت عنه -أبو داود-، ولم يبين أنه من رواية ابن إسحاق». وقال الألباني في صحيح أبي داود ٥/٢٠٤ (١٣١٦): «حديث صحيح».أخرجه أحمد ٢٨/٥٦٩-٥٧٠ (١٧٣٣٤)، ٢٨/٦٥٤-٦٥٥ (١٧٤٥٢).</p><p>قال الهيثمي في المجمع ٧/١٤٨-١٤٩ (١١٥٥٧): «رجاله ثقات». وقال الشوكاني في تحفة الذاكرين ص٤١٤: «رجال ثقات». وقال الألباني في الصحيحة ٦/٨٥٩ (٢٨٦١): «هذا إسناد صحيح».أخرجه الترمذي ٤/١٤٥ (٢١٨٥)، والنسائي ٨/٢٧١ (٥٤٩٤)، وابن ماجه ٤/٥٤٤ (٣٥١١).</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال السيوطي في الشمائل الشريفة ص٢٨٠ (٥٠٤): «صَحَّ».اللمم: طرف من الجنون يلم بالإنسان، أي: يقترب منه ويعتريه. النهاية (لمم).أخرجه الطبراني في الدعاء ص٣٣٥ (١٠٩٥) بنحوه. وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ليّن؛ فيه أبو جعفر الرازي، وهو عيسى بن أبي عيسى التميمي، قال عنه ابن حجر في التقريب (٨٠١٩): «صدوق سيئ الحفظ».يعتقبون: يتعاقبون البعير الواحد في الركوب واحدًا بعد واحد. النهاية (عقب).أخرجه أحمد ٣٣/٤٠٦، ٣٤/٢٤٨ (٢٠٢٨٤، ٢٠٧٤٤، ٢٠٧٤٥)، وابن الضريس (٢٩٤) مختصرًا.</p><p>قال محقّقو المسند: «إسناده صحيح».أخرجه أحمد ٢٤/١٨٣ (١٥٤٤٨)، ٢٨/٥٣٠ (١٧٢٩٧)، ٢٨/٦١٢ (١٧٣٨٩)، والنسائي ٨/٢٥١ (٥٤٣٢).</p><p>قال الألباني في الصحيحة ٣/٩٤ (١١٠٤): «وهذا إسناد رجاله ثقات رجال الشيخين، غير أبي عبد الله هذا؛ قال الذهبي: لا يُعرف. وأما ابن حبّان فذكره في الثقات، لكن الحديث صحيح، فإنّ له طرقًا كثيرة عن عُقبة بن عامر الجُهنيّ، عند النسائي وغيره».أخرجه ابن عدي في الكامل ٣/٤٣٦.</p><p>قال ابن عدي: «يرويه خالد بن يزيد، عن الثوري، وهو منكر». وقال الذهبي في ميزان الاعتدال ١/٦٤٦ (٢٤٧٦): «خالد بن يزيد أبو الهيثم العمري المكي، عن ابن أبي ذئب، والثوري. كذّبه أبو حاتم، ويحيى. وقال ابن حبان: يروي الموضوعات عن الأثبات».أخرجه ابن بشران في أماليه ١/٣٥٥ (٨١٧).</p><p>إسناده ضعيف؛ فيه سيف بن مسكين السلمي، قال ابن حبان في المجروحين ١/٣٤٧: «شيخ من أهل البصرة ... يأتي بالمقلوبات والأشياء الموضوعات، لا يحلّ الاحتجاج به لمخالفته الأثبات في الروايات على قِلّتها».أخرجه أحمد ٣٥/١١٧ (٢١١٨٨)، والبزار (١٥٨٦)، والطبراني (٩١٤٨، ٩١٥٢)، وابن مردويه -كما في فتح الباري ٨/٧٤٢-.</p><p>قال محققو المسند: «إسناده صحيح».عزاه السيوطي إلى ابن الأنباري.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٣/١٥٣.</p><p>قال السيوطي في الإتقان ١/٥٠: «... إسناده جيد، رجاله كلّهم ثقات من علماء العربية المشهورين».أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل ٤/٩٢١.
  113,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَعُوذُ بِرَبِّ ٱلۡفَلَقِ ۝١ مِن شَرِّ مَا خَلَقَ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٢٧<span class="dash">-</span></span> عن عمرو بن عَبسة، قال: صَلّى بنا رسول الله ﷺ، فقرأ: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، فقال: «<b>يا ابن عَبسة، أتدري ما الفلق؟</b>». قلت: الله ورسوله أعلم. قال: «<b>بئر في جهنم، فإذا سُعِّرت البئر ففيها سَعْر جهنم، وإنّ جهنم لتتأذّى منها كما يتأذّى بنو آدم من جهنم</b>»{1}. (١٥/٧٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٨<span class="dash">-</span></span> عن عُقبة بن عامر، قال: قال لي رسول الله ﷺ: «<b>اقرأ: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، هل تدري ما الفلق؟ باب في النار، إذا فُتح سُعِّرت جهنم</b>»{2}. (١٥/٧٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٢٩<span class="dash">-</span></span> عن عبد الله بن عمرو بن العاصي، قال: سألتُ رسول الله ﷺ عن قول الله: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>. قال: «<b>هو سجن في جهنم، يُحبس فيه الجبّارون والمُتكبِّرون، وإنّ جهنم لتَعَوَّذُ بالله منه</b>»{3}. (١٥/٧٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٠<span class="dash">-</span></span> عن أبي هريرة، عن النبيِّ ﷺ، قال: «<b>الفَلق: جُبٌّ في جهنم مُغطّى</b>»{4}. (١٥/٧٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣١<span class="dash">-</span></span> عن <span class="name-1">عمرو بن عَبسة</span> -من طريق أيوب بن يزيد- قال: الفَلق: بئر في جهنم، إذا سُعِّرتْ جهنم فمنه تُسعّر، وإنها لتتأذّى بها كما يتأذّى بنو آدم من جهنم{5}. (١٥/٧٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عمرو</span>: <span class="qpc-hafs">﴿الفَلَقِ﴾</span>: شجرة في النار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق إسحاق بن عبد الله، عمن حدّثه- قال: الفَلق: سجن في جهنم{7}. (١٥/٧٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قال: <span class="qpc-hafs">﴿الفَلَقِ﴾</span> الصُّبح{8}. (١٥/٧٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد: <span class="qpc-hafs">﴿أعُوذُ بِرَبِّ الفَلَقِ﴾</span> الصُّبح، ... <span class="qpc-hafs">﴿مِن شَرِّ ما خَلَقَ﴾</span> من الجن والإنس{9}<span class=comment-ref>٧٣٤٠</span>. (١٥/٧٩٤)</p></p><p></div></p><p><div><span class=comment-ref>٧٣٤٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٧١٤) على قول ابن عباس وما في معناه بقوله: «<span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿فالِقُ الإصْباحِ﴾</span> [الأنعام:٩٦]».</div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك بن مُزاحِم- أنّ نافع بن الأزرق قال له: أخبِرني عن قوله تعالى: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>. قال: أعوذ بربّ الصُّبح إذا انفلق عن ظُلمة الليل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتُ زُهير بن أبي سُلمى وهو يقول:</p><p>الفارجُ الهمَّ مسدولًا عساكرُه كما يُفرِّج غَمَّ الظلمة الفلقُ؟{10}. (١٥/٧٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: <span class="qpc-hafs">﴿الفَلَق﴾</span> الخَلْق{11}. (١٥/٧٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٨<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span> -من طريق عبد الله بن محمد بن عقيل- قال: الفلَق: الصُّبح{12}. (١٥/٧٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٣٩<span class="dash">-</span></span> عن عبد الجبّار الخولاني، قال: قدم <span class="name-1">رجل من أصحاب رسول الله ﷺ</span> الشام، قال: فنظر إلى دُور أهل الذِّمّة، وما هم فيه من العيش والنضارة، وما وسّع عليهم في دنياهم، قال: فقال: لا أبالي، أليس مِن ورائهم الفَلَق؟ قال: قيل: وما الفَلَق؟ قال: بيت في جهنم، إذا فُتح هرَّ أهل النار{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٠<span class="dash">-</span></span> عن زيد بن علي بن الحسين، عن آبائه، قال: الفَلَق: جُبّ في قعر جهنم، عليه غطاء، فإذا كُشف عنه خرجتْ مِنه نار تضجّ منه جهنم؛ مِن شدّة حرّ ما يخرج منه{14}. (١٥/٧٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق أبي عبيد- قال: الفَلَق: بيتٌ في جهنم، إذا فُتح صاح أهل النار من شدّة حرّه{15}. (١٥/٧٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم الأفطس- قال: الفَلَق: الصُّبح{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٣<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن الحُبُليّ</span> -من طريق خثيم بن عبد الله- قال: الفَلَق: جهنم{17}. (١٥/٧٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، قال: الصُّبح{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>: معنى الفلَق: الخَلْق{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في هذه الآية: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، قال: الفَلَق: الصُّبح{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٧<span class="dash">-</span></span> قال <span class="name-2">وهْب بن مُنَبِّه</span>: <span class="qpc-hafs">﴿الفَلَقِ﴾</span> هو جُبٌّ في جهنم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- أنه كان يقول في هذه الآية: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، يقول: فالق الحبّ والنّوى، قال: <span class="qpc-hafs">﴿فالِقُ الإصْباحِ﴾</span> [الأنعام:٩٦]{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿الفَلَقِ﴾</span>، قال: هو فَلَق الصُّبح{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سفيان- يقول: <span class="qpc-hafs">﴿الفَلَقِ﴾</span> جُبّ في جهنم{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿الفَلَقِ﴾</span> هو وادٍ في جهنم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span> يعني: بربّ الخَلْق، <span class="qpc-hafs">﴿مِن شَرِّ ما خَلَقَ﴾</span> من الجن والإنس{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، قيل له: فَلَق الصُّبح؟ قال: نعم. وقرأ: ‹فالِقُ الإصْباحِ وجاعِلُ اللَّيْلِ سَكَنًا›{27}<span class=comment-ref>٧٣٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٣٤١</span> اختُلف في معنى: «الفلق» في هذه الآية على أقوال: <b>الأول:</b> سجنٌ في جهنم. <b>الثاني:</b> اسم من أسماء جهنم. <b>الثالث:</b> الصُّبح. <b>الرابع:</b> الخَلْق.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٧٤٥) القول الثالث -<span class="mustanad">مستندًا إلى اللغة</span>- وهو قول ابن عباس من طريق العَوفيّ، وما في معناه، فقال: «والصواب من القول في ذلك أن يقال: إنّ الله -جلَّ ثناؤه- أمر نبيَّه محمدًا أن يقول: <span class="qpc-hafs">﴿أعُوذُ بِرَبِّ الفَلَقِ﴾</span>، والفَلَق في كلام العرب: فَلَقُ الصُّبح، تقول العرب: هو أبْيَنُ من فَلَقِ الصُّبح، ومن فَرَقِ الصُّبح». ثم <span class="comment-type-4">بيَّن</span> جواز الأقوال الأخرى وغيرها مما يندرج تحت معنى الفَلَق، فقال: «وجائزٌ أن يكون في جهنم سجنٌ اسمه: فَلَقٌ، وإذا كان ذلك كذلك ولم يكن -جلَّ ثناؤه- وضع دلالةً على أنه عنى بقوله: <span class="qpc-hafs">﴿بِرَبِّ الفَلَقِ﴾</span> بعض ما يُدْعى الفَلَق دون بعض، وكان الله -تعالى ذِكْره- ربَّ كلِّ ما خلق من شيء، وجب أن يكون معنيًّا به كل ما اسْمُه الفلق؛ إذ كان رب جميع ذلك».</p><p>وكذا <span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٤/٥٢٣) أنه الصبح قائلًا: «وهو الصحيح، وهو اختيار البخاري: في صحيحه». ولم يذكر مستندًا.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ تيمية</u> (٧/٣٨٧) -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- القول الأول والثاني قائلًا: «وأمّا مَن قال: إنه واد في جهنم، أو شجرة في جهنم، أو أنه اسم من أسماء جهنم، فهذا أمر لا تُعرف صحته، لا بدلالة الاسم عليه، ولا بنقل عن النبي، ولا في تخصيص ربوبيته بذلك حكمه، بخلاف ما إذا قال: ربّ الخَلْق، أو ربّ كلّ ما انفلق، أو ربّ النور الذي يُظهره على العباد بالنهار، فإنّ في تخصيص هذا بالذِّكر ما يظهر به عظمة الرّبّ المستعاذ به».</div></p></div>",footnotes:1:أخرجه أبو يعلى -كما في إتحاف الخيرة المهرة ٢/١٨٣ (١٣٠٠)- بنحوه مختصرًا. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أورده الديلمي في الفردوس ٣/٢١٧ (٤٦٢٧). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٧٤- مختصرًا.أخرجه ابن جرير ٢٤/١٩٦، ٧٤٢، والثعلبي ١٠/١٥٢.</p><p>قال ابن كثير في تفسيره ٨/٥٣٥: «منكر ... إسناده غريب، ولا يصحّ رفعه». وقال الألباني في الضعيفة ٩/٣١ (٤٠٢٩): «منكر».أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٠٨-٤٠٩ (٤٤)-، وابن أبي حاتم -كما في التخويف من النار ص١٢١-.تفسير الثعلبي ١٠/٣٣٩.أخرجه ابن جرير ٢٤/٧٤١.أخرجه ابن جرير ٢٤/٧٤٣.تقدم تخريجه في نزول السورة.أخرجه الطستي في مسائل نافع (٣١)، والطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).أخرجه ابن جرير ٢٤/٧٤٥، وابن أبي حاتم -كما في الإتقان ٢/٥٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٧٤٤، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٥٥٣-.أخرجه ابن جرير ٢٤/٧٤٢. وفي النهاية: الهرار صوت الكلب ونباحه، وقيل: صوته دون نباحه (هرر).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٥٥٤، والتخويف من النار ص١٢١-.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٢٨ (٦١)-، وابن أبي الدنيا مختصرًا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٠٨ (٤٠)-، وابن جرير ٢٤/٧٤٢-٧٤٣، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٥٥٤-.أخرجه ابن جرير ٢٤/٧٤٣.أخرجه ابن جرير ٢٤/٧٤٣، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٥٥٤-.تفسير مجاهد ص٧٦١، وأخرجه ابن جرير ٢٤/٧٤٤.تفسير الثعلبي ١٠/٣٣٩.أخرجه ابن جرير ٢٤/٧٤٣.تفسير الثعلبي ١٠/٣٣٩.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٧٧ (١٤٨)، وابن جرير ٢٤/٧٤٤.أخرجه عبد الرزاق ٢/٤٠٨، وابن جرير ٢٤/٧٤٤، وبنحوه من طريق سعيد.أخرجه ابن جرير ٢٤/٧٤٢، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٠٨ (٤١)-.تفسير الثعلبي ١٠/٣٣٩، وتفسير البغوي ٨/٥٩٥.تفسير مقاتل بن سليمان ٤/٩٣٣-٩٣٤.أخرجه ابن جرير ٢٤/٧٤٤.</p><p>والقراءة لجمهور القراء، ما عدا عاصمًا، وحمزة، والكسائي، وخلَف الذين يقرؤون: <span class="qpc-hafs">﴿وجَعَل﴾</span>. ينظر: النشر ٢/١٩٦.
  113,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٥٤<span class="dash">-</span></span> عن عائشة، قالت: نظر رسول الله ﷺ يومًا إلى القمر لما طلع، فقال: «<b>يا عائشة، استعيذي بالله مِن شرّ هذا، فإنّ هذا الغاسق إذا وقب</b>». وفي لفظ عند ابن جرير: «<b>تعوّذي بالله من شرّ غاسقٍ إذا وقب، وهذا غاسقٌ إذا وقب</b>»{1}. (١٥/٧٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٥<span class="dash">-</span></span> عن أبي هريرة، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: «<b>النجم هو الغاسق، وهو الثُّريّا</b>»{2}. (١٥/٧٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٦<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي المهزم- في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: الغاسق: الكوكب{3}. (١٥/٧٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>: الليل، وما يجيء به النهار{4}. (١٥/٧٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: الليل إذا أقبل{5}. (١٥/٨٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>. قال: الغاسق: الظُّلمة، والوَقب: شدة سواده إذا دخل في كلّ شيء. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ زهيرًا وهو يقول:</p><p>ظلّتْ تجوبُ يداها وهي لاهيةٌ حتى إذا جنَح الإظلامُ والغسَق؟</p><p>وقال في الوَقب:</p><p>وقَب العذاب عليهم فكأنهم لحقتهم نارُ السماء فأُخمدوا{6}. (١٥/٨٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿غاسِقٍ إذا وقَبَ﴾</span> قال: الغاسق هو الليل <span class="qpc-hafs">﴿إذا وقَبَ﴾</span> يعني: إذا دخل، يعني: غروب الشمس{7}. (١٥/٨٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: الليل إذا أقبل؛ إذا دخل على الناس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: أول الليل إذا أظلم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٣<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span>، <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: الليل إذا ذهب{10}. (١٥/٧٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- <span class="qpc-hafs">﴿غاسِقٍ إذا وقَبَ﴾</span>، يقول: النهار إذا دخل في الليل{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿غاسِقٍ إذا وقَبَ﴾</span>، قال: إذا ذهب{12}<span class=comment-ref>٧٣٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٣٤٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٢٤/٧٤٩) على قول قتادة بقوله: «ولست أعرف ما قال قتادة في ذلك في كلام العرب، بل <span class="mustanad">المعروف من كلامها</span> من معنى: <span class="qpc-hafs">﴿وقَبَ﴾</span>: دخل».</div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق عقيل بن خالد- أنه قال: الغاسق إذا وقب: الشمس إذا غربتْ{13}. (١٥/٧٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، يعني: الليل إذا أطبق الأُفُق بظُلمته{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ﴾</span> يعني: ظُلمة الليل <span class="qpc-hafs">﴿إذا وقَبَ﴾</span> يعني: إذا دَخلتْ ظُلمة الليل في ضوء النهار؛ إذا غابت الشمس فاختلط الظلام{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ غاسِقٍ إذا وقَبَ﴾</span>، قال: كانت العرب تقول: الغاسق: سقوط الثُّريّا. وكانت الأسقام والطواعين تكثر عند وقوعها، وترتفع عند طلوعها{16}<span class=comment-ref>٧٣٤٣</span>. (١٥/٧٩٩)</p></p><p></div></p><p><div><span class=comment-ref>٧٣٤٣</span> اختُلف في معنى: «الغاسق إذا وقب» على أقوال: <b>الأول:</b> الليل إذا أظلم. <b>الثاني:</b> النهار إذا دخل في الليل. <b>الثالث:</b> الكوكب، وهو الثُّريّا إذا سقطتْ، وكانت الأسقام والطواعين تكثر عند وقوعها، وترتفع عن طلوعها. <b>الرابع:</b> هو القمر.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٧/٣٩١) على القول الثالث بقوله: «ويشبه -والله أعلم- أن يكون من الحكمة في ذلك: أنّ النور هو جنس الخير، والظُّلمة جنس الشّرّ، وفي الليل يقع من الشرور النفسانية ما لا يقع في النهار، والقمر له تأثير في الأرض لا سيما حال كسوفه؛ فإنّ <span class="mustanad">النبي قال</span>: «<b>إنهما آيتان يخوّف الله بهما عباده</b>». والتخويف إنما يكون بانعقاد سبب الخوف، ولا يكون ذلك إلا عند سبب العذاب أو مظنّته، فعُلم أنّ الكسوف مظنّة حدوث عذاب بأهل الأرض، ولهذا شُرع عند الكسوف الصلاة الطويلة والصدقة والعتاقة والدعاء لدفْع العذاب، وكذلك عند سائر الآيات التي هي إنشاء العذاب كالزلزلة، وظهور الكواكب وغير ذلك، وهو أقرب الكواكب التي لها تأثير في الأرض بالترطيب واليبس وغير ذلك».</p><p>و<span class="comment-type-1">وجَّهه</span> <u>ابنُ القيم</u> (٣/٤٠٨) بقوله: «إنْ أراد صاحب هذا القول اختصاص الغاسق بالنجم إذا غرب فباطل، وإنْ أراد: أنّ اسم الغاسق يتناول ذلك بوجه ما؛ فهذا يحتمل أن يدل اللفظ عليه بفحواه ومقصوده وتنبيهه، وأمّا أن يختص اللفظ به فباطل».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/٥٢٤) على القول الرابع بقوله: «وعمدة أصحاب هذا القول ما رواه الإمام أحمد ...». ثم ذكر حديث عائشة الوارد في أول تفسير الآية.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٧٤٩) <span class="mustanad">العموم</span>، فقال: «وأولى الأقوال في ذلك عندي بالصواب أن يُقال: إنّ الله أمر نبيَّه أن يستعيذ من شرِّ <span class="qpc-hafs">﴿غاسِقٍ﴾</span> وهو الذي يُظْلِم، يقال: قد غَسَقَ الليل يَغْسِق غُسوقًا: إذا أظلم، <span class="qpc-hafs">﴿إذا وقَبَ﴾</span> يعني: إذا دخل في ظلامه؛ والليل إذا دَخَل في ظلامه غاسق، والنجم إذا أفَل غاسق، والقمر غاسقٌ إذا وقب، ولم يَخْصُص بعض ذلك بل عمَّ الأمر بذلك، فكلُّ غاسق فإنه كان يُؤْمَرُ بالاستعاذة من شرِّه إذا وقب».</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/٧١٥) عن القتبي وغيره أنّ «الغاسق إذا وقب»: «هو البدر إذا دخل في ساهوره فخسف». واستدل أصحاب القول الثالث <span class="mustanad">بحديث أبي هريرة</span> الوارد في تفسير الآية وفيه: «<b>النجم: الغاسق</b>». واستدل أصحاب القول الرابع <span class="mustanad">بحديث عائشة</span> الوارد في أول تفسير الآية.</p><p>و<span class="comment-type-4">علَّق</span> عليهما <u>ابنُ تيمية</u> (٧/٣٨٨) بقوله: «وهذا المرفوع قد ظنّ بعض الناس منافاته لمن فسّره بالليل؛ فجعلوه قولًا آخر، ثم فسّروا وقوبه بسكونه. قال ابن قتيبة: ويقال الغاسق: القمر إذا كسف واسوَدّ. ومعنى وقب: دخل في الكسوف، وهذا ضعيف، فإنّ ما قال رسول الله لا يُعارض بقول غيره، وهو لا يقول إلا الحقّ، وهو لم يأمر عائشة بالاستعاذة منه عند كسوفه، بل مع ظهوره، وقد قال الله تعالى: <span class="qpc-hafs">﴿وجَعَلْنا اللَّيْلَ والنَّهارَ آيَتَيْنِ فَمَحَوْنا آيَةَ اللَّيْلِ وجَعَلْنا آيَةَ النَّهارِ مُبْصِرَةً﴾</span> [الإسراء:١٢]. فالقمر آية الليل، وكذلك النجوم إنما تطلع فتُرى بالليل، فأمره بالاستعاذة من ذلك أمر بالاستعاذة من آية الليل ودليله وعلامته، والدليل مستلزم للمدلول، فإذا كان شرّ القمر موجودًا فشَرّ الليل موجود، وللقمر من التأثير ما ليس لغيره، فتكون الاستعاذة من الشّرّ الحاصل عنه أقوى، ويكون هذا <span class="mustanad">كقوله</span> عن المسجد المؤسس على التقوى: «<b>هو مسجدي هذا</b>». مع أنّ الآية تتناول مسجد قباء قطعًا. <span class="mustanad">وكذلك قوله</span> عن أهل الكساء: «<b>هؤلاء أهل بيتي</b>». مع أنّ القرآن يتناول نساءه، فالتخصيص لكون المخصوص أولى بالوصف، فالقمر أحقّ ما يكون بالليل بالاستعاذة».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ القيم</u> (٣/٤٠٦، ٤٠٧).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٥٢٥) نحو هذا مختصرًا.</div></p></div>",footnotes:1:أخرجه أحمد ٤٠/٣٧٨-٣٧٩ (٢٤٣٢٣)، ٤٢/٤٦٨ (٢٥٧١١)، ٤٣/٨ (٢٥٨٠٢)، ٤٣/١٣٨ (٢٦٠٠٠)، ٤٣/٢٣٩ (٢٦١٤٦)، والترمذي ٥/٥٥٠ (٣٦٦١)، والحاكم ٢/٥٨٩ (٣٩٨٩)، وابن جرير ٢٤/٧٤٨، ٧٤٩، والثعلبي ١٠/٣٣٩.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال الزركشي في التذكرة ص٢٢٠: «قال النووي: هو حديث ضعيف. وهذا عجيب منه؛ فإنّ الحديث رواه الترمذي وصححه». وقال ابن حجر في الفتح ٨/٧٤١ عن إسناد الحاكم والترمذي: «إسناده حسن». وقال الألباني في الصحيحة ١/٧١٤ (٣٧٢): «رجاله ثقات رجال الشيخين، غير الحارث بن عبد الرحمن هذا، وهو القرشي العامري، وهو صدوق».أخرجه أبو الشيخ في العظمة ٤/١٢١٨، وابن جرير ٢٤/٧٤٨، والثعلبي ١٠/٣٤٠. وأورده الديلمي في الفردوس ٤/٤١٩ (٧٢١٩) جميعهم بنحوه. وعزاه السيوطي إلى ابن مردويه.</p><p>قال ابن كثير في تفسيره ٨/٥٣٦ عن رواية ابن جربر: «وهذا الحديث لا يصحّ رفعه إلى النبي ﷺ».أخرجه ابن جرير ٢٤/٧٤٧. وعزاه السيوطي إلى ابن أبي حاتم.تقدم تخريجه في نزول السورة.عزاه السيوطي إلى ابن المنذر. وأخرج شطره الأول ابن جرير ٢٤/٧٤٦ من طريق عطية، وشطره الثاني ٢٤/٧٤٧ بنحوه من طريق علي.أخرجه الطستي في مسائل نافع (٢٧١).تفسير مجاهد ص٧٦١، وأخرج ابن جرير ٢٤/٧٤٦ نحوه. وعلقه البخاري في صحيحه ٤/١٩٠٤.أخرجه عبد الرزاق ٢/٤٠٨، وابن جرير ٢٤/٧٤٦، ٧٤٧، وبنحوه من طريق قتادة.أخرجه ابن جرير ٢٤/٧٤٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٧٧ (١٤٨)، وابن جرير ٢٤/٧٤٦، وفي رواية عنده من طريق رجل من أهل المدينة بلفظ: هو غروب الشمس إذا جاء الليل، إذا وجب.أخرجه عبد الرزاق ٢/٤٠٨ بنحوه، وابن جرير ٢٤/٧٤٩.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٥ (٢٧). وعزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٧٤-.تفسير مقاتل بن سليمان ٤/٩٣٤.أخرجه ابن جرير ٢٤/٧٤٧-٧٤٨، وأبو الشيخ (٦٩٨).
  113,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِی ٱلۡعُقَدِ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ﴾</span>، قال: الساحرات{1}. (١٥/٨٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span>: السحّارات المؤذيات{2}. (١٥/٧٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- <span class="qpc-hafs">﴿النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: ما خالط السحر من الرُّقى{3}. (١٥/٨٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- <span class="qpc-hafs">﴿النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: الرُّقى في عُقَد الخيط{4}. (١٥/٨٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٥<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: الأخْذ في عُقد الخيط{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿النَّفّاثاتِ﴾</span>، قال: السّواحر{6}. (١٥/٨٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: السّواحر والسَّحرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٨<span class="dash">-</span></span> عن قتادة -من طريق سعيد- قال: كان <span class="name-2">الحسن [البصري]</span> يقول إذا جاز: <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: إياكم وما خالط السِّحر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: إياكم وما خالط السِّحر مِن هذه الرُّقى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span>، يعني: السِّحر وآلاته، يعني: الرُقية التي هي لله معصية، يعني به: ما تَنفُثْنَ مِن الرُّقى في العُقدة، والآخذة يعني به: السّحر، فهنّ السّاحرات المهيّجات الأخّاذات{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ﴾</span>، قال: <span class="qpc-hafs">﴿النَّفاثات﴾</span> السَّواحر <span class="qpc-hafs">﴿في العُقد﴾</span>{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِی ٱلۡعُقَدِ ۝٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٨٢<span class="dash">-</span></span> عن أبي هريرة، أن النَّبيَّ ﷺ قال: «<b>مَن عَقَد عُقْدةً ثم نَفَث فيها فقد سَحَر، ومن سَحَر فقد أشرك، ومن تعلَّق شيئًا وُكل إليه</b>»{12}. (١٥/٨٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٣<span class="dash">-</span></span> عن أبي هريرة، قال: جاء النبيُّ ﷺ يعودني، فقال: «<b>ألا أرقيك برُقية رقاني بها جبريل؟</b>». فقلت: بلى، بأبي وأمي. قال: «<b>باسم الله أرقيك، والله يشفيك من كلّ داء فيك، <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span></b>». فرَقى بها ثلاث مرات{13}. (١٥/٨٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٤<span class="dash">-</span></span> عن ابن عمر: أنّ النبيَّ ﷺ وجد وجعًا في رأسه، فأبطأ على أصحابه، ثم خرج إلى أصحابه، فقال له عمر: ما الذي بطأ بك عنّا؟ فقال: «<b>وجعٌ وجدتُه في رأسي، فهبط عليّ جبريل، فوضع يده على رأسي، ثم قال: باسم الله أرقيك، من كلّ شيء يؤذيك -أو يصيبك-، ومن شرّ كلّ ذي شرٍّ مُعلن أو مُسرّ، ومن شرّ الجنّ والإنس، <span class="qpc-hafs">﴿ومِن شَرِّ النَّفّاثاتِ فِي العُقَدِ ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span></b>». قال: «<b>فبَرأتُ</b>»{14}. (١٥/٨٠٢)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.تقدم تخريجه في نزول السورة.أخرجه ابن جرير ٢٤/٧٥٠.أخرجه ابن جرير ٢٤/٧٥٠-٧٥١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٧٥٠.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٧٥٠.أخرجه ابن جرير ٢٤/٧٥٠.أخرجه عبد الرزاق ٢/٤٠٨، وابن جرير ٢٤/٧٥٠.تفسير مقاتل بن سليمان ٤/٩٣٤-٩٣٥.أخرجه ابن جرير ٢٤/٧٥١.أخرجه النسائي ٧/١١٢ (٤٠٧٩).</p><p>قال الطبراني في الأوسط ٢/١٢٨ (١٤٦٩): «لم يرو هذا الحديث عن عباد إلا أبو داود». وقال ابن القيسراني في ذخيرة الحفاظ ٤/٢٣٣٨ (٥٤٣٠): «رواه عباد بن ميسرة المنقري، عن الحسن، عن أبي هريرة، وعبّاد ليس بالقوي». وقال المنذري في الترغيب والترهيب ٤/١٦ (٤٦٠٤): «من رواية الحسن عن أبي هريرة، ولم يسمع منه عند الجمهور». وقال الذهبي في ميزان الاعتدال ٢/٣٧٨ (٤١٤٧) في ترجمة عبّاد بن ميسرة: «عبّاد بن ميسرة المنقرى المعلم، عن الحسن: ضعّفه أحمد، ويحيى. وقال يحيى مرة: ليس به بأس. وقال أبو داود: ليس بالقوي، وكان من العُبّاد». ثم ذكر هذا الحديث، فقال عقبه: «هذا الحديث لا يصحّ؛ للين عبّاد وانقطاعه».أخرجه أحمد ١٥/٤٧٠-٤٧١ (٩٧٥٧)، وابن ماجه ٤/٥٥١ (٣٥٢٤)، والحاكم ٢/٥٩٠ (٣٩٩٠).</p><p>قال البوصيري في مصباح الزجاجة ٤/٧٣ (٩٢٢١): «هذا إسناد فيه عاصم بن عبيد الله، وهو ضعيف».عزاه السيوطي إلى ابن مردويه.
  113,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، قال: نفس ابن آدم، وعَيْنُه{1}. (١٥/٨٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، قال: هو أوَّل ذنبٍ كان في السماء{2}. (١٥/٨٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، يعني: اليهود، هم حَسَدة الإسلام{3}. (١٥/٨٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، قال: مِن شرِّ عينه، ونفسه{4}. (١٥/٨٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٨٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق معمر- <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، قال: من شرّ عينه، ونفسه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، يعني: اليهود حين حسدوا النبي ﷺ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span>، قال: يهود، لم يمنعهم أن يؤمنوا به إلا حسدهم{7}<span class=comment-ref>٧٣٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٣٤٤</span> اختُلف في معنى: «الحاسد» على قولين: <b>الأول:</b> أنه كلّ حاسد أُمِرَ النبي أن يستعيذ من شرّ عينه ونفسه. <b>الثاني:</b> أنهم اليهود الذين حسدوا النبي، فأُمِر أن يستعيذ من شرّهم.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٧١٦) القول الأول -وهو قول قتادة وما في معناه- بقوله: «يريد: السعي الخبيث والإذاية كيف قدر؛ لأنه عدوٌّ مجدٌّ ممتحن».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٧٥٢) <span class="mustanad">العموم</span>، فقال: «وأولى القولين بالصواب في ذلك قول مَن قال: أُمِر النبي أن يستعيذ من شرِّ كلِّ حاسدٍ إذا حسد، فعابه أو سحره، أو بغاه سوءًا». ثم علَّل ذلك بقوله: «لأنّ الله ﷿ لم يَخْصُص من قوله: <span class="qpc-hafs">﴿ومِن شَرِّ حاسِدٍ إذا حَسَدَ﴾</span> حاسدًا دون حاسد، بل عمَّ أمْرَه إيّاه بالاستعاذة من شرِّ كلِّ حاسد، فدل ذلك على عمومه».</div></p><p><h3><span class="qpc-hafs">﴿وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ ۝٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٩٢<span class="dash">-</span></span> عن عبادة بن الصّامت، عن رسول الله ﷺ: أنّ جبريل أتاه وهو يُوعَك، فقال: باسم الله أرقيك، مِن كلّ شيء يؤذيك، من حسد حاسد وكلّ عين، اسم الله يشفيك{8}. (١٥/٨٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٣<span class="dash">-</span></span> عن جابر بن عبد الله، أو عن أبي سعيد الخدريّ: أنّ النبيَّ ﷺ اشتكى، فأتاه جبريل، فقال: باسم الله أرقيك، من كلّ شيء يؤذيك، من كلّ كاهن وحاسد، والله يشفيك{9}. (١٥/٨٠٣)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن عدي في الكامل ٢/٧١١، والبيهقي في شعب الإيمان (٦٦٣٢، ٦٦٣٣).عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٠٨، وابن جرير ٢٤/٧٥١. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٤٠٨، وابن جرير ٢٤/٧٥١.تفسير مقاتل بن سليمان ٤/٩٣٥.أخرجه ابن جرير ٢٤/٧٥٢.أخرجه أحمد ٣٧/٤١٩-٤٢٠، ٤٢١ (٢٢٧٥٩، ٢٢٧٦٠، ٢٢٧٦١)، وابن ماجه ٤/٥٥٣ (٣٥٢٧)، وابن حبان ٣/٢٣٤ (٩٥٣)، ٧/٢٣٣-٢٣٤ (٢٩٦٨).</p><p>قال البزار ٧/١٣٢ (٢٦٨٤): «وهذا الحديث لا نعلمه يروى عن عبادة بأحسن مِن هذا الإسناد». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال الهيثمي في المجمع ٥/١١٠ (٨٤٣٩): «رواه أحمد، وفيه سليمان رجل من أهل الشام، ولم يضعفه أحد، وبقية رجاله رجال الصحيح». وقال البوصيري في مصباح الزجاجة ٤/٧٥ (٣٢١): «هذا إسناد حسن».عزاه السيوطي إلى ابن مردويه. وهو عند مسلم ٤/١٧١٨ (٢١٨٦) بنحوه عن أبي سعيد.
  114,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٥٦٩٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مدنية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيف، عن مجاهد-: مكّيّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمّى: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿قل أعوذ برب الفلق﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٧<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أُنزل بمكة <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span>{4}. (١٥/٨٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٨<span class="dash">-</span></span> عن عبد الله بن الزُّبير، قال: أُنزل بالمدينة <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span>{4}. (١٥/٨٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٦٩٩<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٧٠٠<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: أنها مكّيّة، وذكراها بمسمّى: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٧٠١<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٧٠٢<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: أنها مكّيّة، ونزلت بعد سورة الفلق{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٧٠٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة {9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٥٧٠٤<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الناس مكّيّة، عددها ست آيات{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٣/١٥٣، وقال السيوطي في الإتقان ١/٥٠: «... إسناده جيد، رجاله كلّهم ثقات، مِن علماء العربية المشهورين».أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٩٤١.
  114,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ ۝١ مَلِكِ ٱلنَّاسِ ۝٢ إِلَـٰهِ ٱلنَّاسِ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٥٧٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾</span> أمَر الله ﷿ النبيَّ ﷺ أن يتعوّذ برب الناس، الذي هو <span class="qpc-hafs">﴿مَلِكِ النّاسِ﴾</span> بِمَلِكهم في برِّهم وبحرهم، وفاجرهم وصالحهم وطالحهم، وهو <span class="qpc-hafs">﴿إلهِ النّاسِ﴾</span> كلّهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٩٤٣.
