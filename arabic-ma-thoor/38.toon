  38,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ مَا لَنَا لَا نَرَىٰ رِجَالࣰا كُنَّا نَعُدُّهُم مِّنَ ٱلۡأَشۡرَارِ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿وقالُوا ما لَنا لا نَرى رِجالًا كُنّا نَعُدُّهُمْ مِنَ الأَشْرارِ﴾</span>، قال: ذلك قول أبي جهل بن هشام في النار: ما لي لا أرى بلالًا، وعمّارًا، وصهيبًا، وخبّابًا، وفلانًا، وفلانًا؟{1}. (١٢/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وقالُوا ما لَنا لا نَرى رِجالًا كُنّا نَعُدُّهُمْ مِنَ الأَشْرارِ﴾</span>، قال: عبد الله بن مسعود، ومَن معه{2}. (١٢/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وقالُوا ما لَنا لا نَرى رِجالًا كُنّا نَعُدُّهُمْ مِنَ الأَشْرارِ﴾</span>، قال: هم قوم كانوا يسخرون مِن محمد وأصحابه، فانطُلق به وبأصحابه إلى الجنة، وذُهِب بهم إلى النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقالُوا ما لَنا لا نَرى رِجالًا كُنّا نَعُدُّهُمْ مِنَ الأَشْرارِ﴾</span>، قال: فَقَدوا أهلَ الجنة{4}. (١٢/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٣<span class="dash">-</span></span> عن <span class="name-3">شِمْر بن عطية</span>، <span class="qpc-hafs">﴿وقالُوا ما لَنا لا نَرى رِجالًا كُنّا نَعُدُّهُمْ مِنَ الأَشْرارِ﴾</span>، قال: قال أبو جهل في النار: أين خبّاب؟ أين صهيب؟ أين بلال؟ أين عمّار؟{5}. (١٢/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا ما لَنا لا نَرى رِجالًا كُنّا نَعُدُّهُمْ مِنَ الأَشْرارِ﴾</span>، يعنون: فقراء المؤمنين؛ عمار، وخبّاب، وصهيب، وبلال، وسالم، ونحوهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٥<span class="dash">-</span></span> عن عثمان بن المبارك الأنباري، قال: سمعتُ <span class="name-3">سفيانَ بن عيينة</span> يقول: <span class="qpc-hafs">﴿ما لنا لا نرى رجالا كنا نعدهم من الأشرار﴾</span>، قال: يقول أبو جهل: أين بلال؟ أين عمار؟ أين صهيب؟{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٣٦ بنحوه، وابن عساكر ١٠/٤٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٨.أخرجه ابن جرير ٢٠/١٣٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٥٢.أخرجه ابن عساكر في تاريخ دمشق ٢٤/٢٢٦.
  38,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَتَّخَذۡنَـٰهُمۡ سِخۡرِیًّا أَمۡ زَاغَتۡ عَنۡهُمُ ٱلۡأَبۡصَـٰرُ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٠٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿أتَّخَذْناهُمْ سِخْرِيًّا﴾</span> قال: أتخذناهم سخريًا، وليسوا كذلك؟ <span class="qpc-hafs">﴿أمْ زاغَتْ عَنْهُمُ الأَبْصارُ﴾</span> أم هم في النار ولا نراهم؟{1}. (١٢/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق طلحة اليامي-: <span class="qpc-hafs">﴿أتخذناهم سخريًا﴾</span> استفهام، <span class="qpc-hafs">﴿أمْ زاغَتْ عَنْهُمُ الأَبْصارُ﴾</span> أم هم في النار فلا نراهم؟!{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أتَّخَذْناهُمْ سِخْرِيًّا﴾</span> قال: أخطأناهم؟ <span class="qpc-hafs">﴿أمْ زاغَتْ عَنْهُمُ الأَبْصارُ﴾</span> قال: ولا نراهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠٠٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر-: <span class="qpc-hafs">﴿أتَّخَذْناهُمْ سُخْرِيًّا أمْ زاغَتْ عَنْهُمُ الأَبْصارُ﴾</span>، يقولون: أزاغت أبصارنا عنهم فلا ندري أين هم؟{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿أتَّخَذْناهُمْ سُخْرِيًّا﴾</span> في الدنيا؟ <span class="qpc-hafs">﴿أمْ زاغَتْ عَنْهُمُ الأَبْصارُ﴾</span> وهم معنا في النار؟{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿أتَّخَذْناهُمْ سِخْرِيًّا أمْ زاغَتْ عَنْهُمُ الأَبْصارُ﴾</span>، قال: أم هم معنا في النار ولا نراهم؟ زاغت أبصارنا عنهم، فلم نراهم حين أُدخِلوا النار؟{6}. (١٢/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أتَّخَذْناهُمْ سِخْرِيًّا﴾</span> في الدنيا، نظيرها في «قد أفلَحَ»: <span class="qpc-hafs">﴿فاتَّخَذْتُمُوهُمْ سِخْرِيًّا﴾</span> [المؤمنون:١١٠]{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٣٨ بنحوه، وابن عساكر ١٠/٤٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه إسحاق البستي ص٢٥٤.تفسير مجاهد (٥٧٦)، وأخرجه ابن جرير ٢٠/١٣٨، وابن أبي حاتم -كما في فتح الباري ٨/٥٤٦- وفي آخره: أم هم في النار لا نعلم مكانهم. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٨-.أخرجه ابن جرير ٢٠/١٣٨.أخرجه ابن جرير ٢٠/١٣٨.أخرجه عبد الرزاق ٢/١٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٥٢.
  38,64,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ذَ ٰ⁠لِكَ لَحَقࣱّ تَخَاصُمُ أَهۡلِ ٱلنَّارِ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٠١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ ذَلِكَ لَحَقٌّ تَخاصُمُ أهْلِ النّارِ﴾</span> يعني: خصومة القادة والأتباع في هذه الآية، ما قال بعضُهم لبعض في الخصومة، نظيرها في الأعراف، وفي «حم المؤمن» حين <span class="qpc-hafs">﴿قالَتْ أُخْراهُمْ لِأُولاهُمْ رَبَّنا هَؤُلاءِ أضَلُّونا﴾</span> [الأعراف:٣٨] عن الهدى، ثم ردت أولاهم دخول النار على أخراهم دخول النار وهم الأتباع، وقوله: <span class="qpc-hafs">﴿وإذْ يَتَحاجُّونَ فِي النّارِ﴾</span> إلى آخر الآية [غافر:٤٧]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٠١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّ ذَلِكَ لَحَقٌّ تَخاصُمُ أهْلِ النّارِ﴾</span>، فقرأ: <span class="qpc-hafs">﴿تاللَّهِ إنْ كُنّا لَفِي ضَلالٍ مُبِينٍ * إذْ نُسَوِّيكُمْ بِرَبِّ العالَمِينَ﴾</span> [الشعراء:٩٧-٩٨]. وقرأ: <span class="qpc-hafs">﴿ويَوْمَ نَحْشُرُهُمْ جَمِيعًا﴾</span> حتى بلغ: <span class="qpc-hafs">﴿إنْ كُنّا عَنْ عِبادَتِكُمْ لَغافِلِينَ﴾</span> [يونس:٢٨-٢٩]. قال: إن كنتم تعبدوننا كما تقولون. <span class="qpc-hafs">﴿إنْ كُنّا عَنْ عِبادَتِكُمْ لَغافِلِينَ﴾</span> ما كنا نسمع ولا نبصر، قال: وهذه الأصنام، قال: هذه خصومة أهل النار. وقرأ: <span class="qpc-hafs">﴿وضَلَّ عَنْهُمْ ما كانُوا يَفْتَرُونَ﴾</span> [يونس:٣٠]. قال: وضل عنهم يوم القيامة ما كانوا يفترون في الدنيا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥٢.أخرجه ابن جرير ٢٠/١٣٩.
  38,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ إِنَّمَاۤ أَنَا۠ مُنذِرࣱۖ وَمَا مِنۡ إِلَـٰهٍ إِلَّا ٱللَّهُ ٱلۡوَ ٰ⁠حِدُ ٱلۡقَهَّارُ ۝٦٥ رَبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا ٱلۡعَزِیزُ ٱلۡغَفَّـٰرُ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٠١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> لكفار مكة: <span class="qpc-hafs">﴿إنَّما أنا مُنْذِرٌ﴾</span> يعني: رسول، <span class="qpc-hafs">﴿وما مِن إلَهٍ إلّا اللَّهُ الواحِدُ﴾</span> لا شريك له، <span class="qpc-hafs">﴿القَهّارُ﴾</span> لخلقه، ثم عظَّم نفسه عن شركهم، فقال سبحانه: <span class="qpc-hafs">﴿رَبُّ السَّماواتِ والأَرْضِ وما بَيْنَهُما﴾</span> فإن مَن يعبد فيهما فأنا ربهما وربُّ من فيهما، <span class="qpc-hafs">﴿العَزِيزُ﴾</span> في ملكه، <span class="qpc-hafs">﴿الغَفّارُ﴾</span> لمن تاب{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ إِنَّمَاۤ أَنَا۠ مُنذِرࣱۖ وَمَا مِنۡ إِلَـٰهٍ إِلَّا ٱللَّهُ ٱلۡوَ ٰ⁠حِدُ ٱلۡقَهَّارُ ۝٦٥ رَبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا ٱلۡعَزِیزُ ٱلۡغَفَّـٰرُ ۝٦٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٠١٦<span class="dash">-</span></span> عن عائشة، قالت: كان رسول الله ﷺ إذا تضوَّر{2} مِن الليل قال: «<b>لا إله إلا الله الواحد القهار، رب السموات والأرض وما بينهما العزيز الغفار</b>»{3}. (١٢/٦١٦)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥٢.تضور: تلوى وتقلب. النهاية (ضور).أخرجه ابن حبان ١٢/٣٤٠ (٥٥٣٠)، والحاكم ١/٧٢٤ (١٩٨٠).</p><p>قال ابن أبي حاتم في العلل ٥/٣٧٣ (٢٠٥٤): «قال أبو زرعة: ... حديث منكر، وسمعت أبي أيضًا يقول: هذا حديث منكر». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن حجر في إتحاف المهرة ١٧/٣٢٠ (٢٢٣٢٠): «هو معلول». وقال المناوي في فيض القدير ٥/١١٢ (٦٦١٥): «قال الحاكم: على شرطهما. وأقرّه الذهبي، وقال الحافظ العراقي في أماليه: حديث صحيح». وأورده الألباني في الصحيحة ٥/٩٨ (٢٠٦٦).
