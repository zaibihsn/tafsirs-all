quran[77]{c,v,t}:
  25,1,""
  25,2,""
  25,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱتَّخَذُوا۟ مِن دُونِهِۦۤ ءَالِهَةࣰ لَّا یَخۡلُقُونَ شَیۡـࣰٔا وَهُمۡ یُخۡلَقُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿واتخذوا من دونه آلهة﴾</span> قال: هي هذه الأوثان التي تُعبَد مِن دون الله، <span class="qpc-hafs">﴿لا يخلقون شيئًا وهم يخلقون﴾</span> وهو الله الخالق الرازق، وهذه الأوثان تُخلَق ولا تَخلق شيئًا، ولا تضرُّ ولا تنفع، ولا تملِك موتًا ولا حياة{1}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٣٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وهم يخلقون﴾</span>، يعني: وهم يُصَوَّرون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتخذوا﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿من دونه آلهة﴾</span> يعني: اللات والعزى يعبدونهم، <span class="qpc-hafs">﴿لا يخلقون شيئًا﴾</span> ذبابًا ولا غيره، <span class="qpc-hafs">﴿وهم يخلقون﴾</span> يعني: الآلهة لا تَخلق شيئًا وهي تُخلق، ينحتونها بأيديهم ثم يعبدونها، نظيرها في مريم، وفي يس، وفي الأحقاف{3}<span class=comment-ref>٤٧٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٠٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٤١٧) على قول مقاتل بقوله: «وهذا التأويل أشدُّ إبداءً لخساسة الأصنام ...».</div></p><p><div></p><p><p><span class="item-no">٥٤٣٣٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: قوله: <span class="qpc-hafs">﴿واتخذوا من دونه﴾</span> من دون الله <span class="qpc-hafs">﴿آلهة﴾</span> يعني: الأوثان، <span class="qpc-hafs">﴿لا يخلقون شيئًا وهم يخلقون﴾</span> يصنعونها بأيديهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَمۡلِكُونَ لِأَنفُسِهِمۡ ضَرࣰّا وَلَا نَفۡعࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ضرًا﴾</span>، قال: ضلالة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن الآلهة، فقال تعالى: <span class="qpc-hafs">﴿ولا يملكون لأنفسهم ضرا﴾</span> يقول: لا تقدر الآلهة أن تمتنع مِمَّن أراد بها سوءًا، <span class="qpc-hafs">﴿ولا نفعا﴾</span> يقول: ولا تسوق الآلهة إلى أنفسها نفعًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: قوله: <span class="qpc-hafs">﴿ولا يملكون لأنفسهم﴾</span> يعني: الأوثان <span class="qpc-hafs">﴿ضرا ولا نفعا﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَمۡلِكُونَ مَوۡتࣰا وَلَا حَیَوٰةࣰ وَلَا نُشُورࣰا ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا يملكون موتا ولا حياة﴾</span> وهي هذه الأوثان التي تعبد من دون الله، لا تضر ولا تنفع ولا تملك موتًا ولا حياة، وفي قوله: <span class="qpc-hafs">﴿ولا نشورا﴾</span> يعني: بعثًا{8}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال تعالى: <span class="qpc-hafs">﴿ولا يملكون﴾</span> يعني: الآلهة <span class="qpc-hafs">﴿موتا﴾</span> يعني: أن تُمِيت أحدًا، ثم قال ﷿: <span class="qpc-hafs">﴿ولا حياة﴾</span> يعني: ولا يُحْيُون أحدًا، يعني: الآلهة، <span class="qpc-hafs">﴿ولا نشورا﴾</span> أن تبعث الأموات، فكيف تعبدون مَن لا يقدِر على شيء مِن هذا، وتتركون عبادة ربكم الذي يملك ذلك كله؟!{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: قوله: <span class="qpc-hafs">﴿ولا يملكون موتا﴾</span> أي: لا يميتون أحدًا، <span class="qpc-hafs">﴿ولا حياة﴾</span> أي: ولا يُحْيُون أحدًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤٦<span class="dash">-</span></span> <span class="qpc-hafs">﴿ولا نشورا﴾</span>، قال <span class="name-2">قتادة</span>: أي: ولا بعثًا. لا يملكون شيئًا من ذلك{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ١/٤٦٩.تفسير مقاتل بن سليمان ٣/٢٢٥. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِيَكُونُوا لَهُمْ عِزًّا (٨١) كَلّا سَيَكْفُرُونَ بِعِبادَتِهِمْ ويَكُونُونَ عَلَيْهِمْ ضِدًّا﴾</span> [مريم:٨١-٨٢]، وقوله تعالى: <span class="qpc-hafs">﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لَعَلَّهُمْ يُنْصَرُونَ (٧٤) لا يَسْتَطِيعُونَ نَصْرَهُمْ وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span> [يس:٧٤-٧٥]، وقوله تعالى: <span class="qpc-hafs">﴿قُلْ أرَأَيْتُمْ ما تَدْعُونَ مِن دُونِ اللَّهِ أرُونِي ماذا خَلَقُوا مِنَ الأَرْضِ أمْ لَهُمْ شِرْكٌ فِي السَّماواتِ ائْتُونِي بِكِتابٍ مِن قَبْلِ هَذا أوْ أثارَةٍ مِن عِلْمٍ إنْ كُنْتُمْ صادِقِينَ (٤) ومَن أضَلُّ مِمَّنْ يَدْعُو مِن دُونِ اللَّهِ مَن لا يَسْتَجِيبُ لَهُ إلى يَوْمِ القِيامَةِ وهُمْ عَنْ دُعائِهِمْ غافِلُونَ﴾</span> [الأحقاف:٤-٥].تفسير يحيى بن سلام ١/٤٦٨.أخرجه ابن أبي حاتم ٨/٢٦٦٢.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٦٩.أخرجه ابن أبي حاتم ٨/٢٦٦٢. وعلَّق يحيى بن سلام ١/٤٦٩ آخره. وعزا السيوطي آخره إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٦٩.
  25,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ إِنۡ هَـٰذَاۤ إِلَّاۤ إِفۡكٌ ٱفۡتَرَىٰهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قال: كل شيء في القرآن <span class="qpc-hafs">﴿إفك﴾</span> فهو كذب{1}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طرق- في قوله: <span class="qpc-hafs">﴿وقال الذين كفروا إن هذا﴾</span>: هذا قول مشركي العرب، <span class="qpc-hafs">﴿إلا أفك﴾</span> هو الكذب{2}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الذين كفروا إن هذا إلا إفك افتراه﴾</span>، قال النضر بن الحارث من بني عبد الدار: ما هذا القرآنُ إلا كَذِب اخْتَلَقَه محمدٌ ﷺ مِن تِلقاء نفسه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: قوله: <span class="qpc-hafs">﴿وقال الذين كفروا إن هذا﴾</span>، يعنون: القرآن.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥١<span class="dash">-</span></span> <span class="qpc-hafs">﴿إلا إفك﴾</span> قال <span class="name-2">قتادة</span>: إلا كذب. قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿افتراه﴾</span> يعنون: محمدًا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعَانَهُۥ عَلَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأعانه عليه﴾</span>: أي: على حديثه هذا، وأمره{5}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿وأعانه عليه﴾</span> على القرآن{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَوۡمٌ ءَاخَرُونَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأعانه عليه قوم آخرون﴾</span>، قال: يهود{7}<span class=comment-ref>٤٧٠٥</span>. (١١/١٣٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٠٥</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٩٨) سوى قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعنون: عَبْدَ ابنِ الحضرمي{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: هو عبيد بن الخضر الحبشي الكاهن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأعانه عليه﴾</span> أي: على حديثه هذا وأمره <span class="qpc-hafs">﴿قوم آخرون﴾</span>{5}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: عبدُ ابنِ الحضرمي، وعدّاسُ غلامُ عتبةَ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأعانه عليه قوم آخرون﴾</span> يقول النضر: عاون محمدًا ﷺ عداسٌ مولى حُوَيْطِب بن عبد العُزّى، ويسارٌ غلامٌ لعامر ابن الحضرمي، وجبرٌ مولى عامر بن الحضرمي كان يهوديًّا فأسلم، وكان هؤلاء الثلاثة مِن أهل الكتاب{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَدۡ جَاۤءُو ظُلۡمࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فقد جاؤا﴾</span> فقد أتَوْا <span class="qpc-hafs">﴿ظلما وزورا﴾</span>{13}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقد جاءوا ظلما﴾</span> قالوا شِرْكًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿ظلما﴾</span> إثمًا وشركًا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزُورࣰا ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿فقد جاؤا ظلما وزورا﴾</span>، قال: كَذِبًا{16}. (١١/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزورا﴾</span> وكذبًا؛ حين يزعمون أن الملائكة بنات الله ﷿، وحين قالوا: إن القرآن ليس من الله ﷿، إنما اختلقه محمد ﷺ من تلقاء نفسه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿وزورا﴾</span> كذبًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٦٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٦٢-٢٦٦٣ أوله من طريق سعيد بن بشير، وآخره من طريق سعيد ابن أبي عروبة. وعلَّقه يحيى بن سلام ١/٤٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٦٩.أخرجه ابن أبي حاتم ٨/٢٦٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير يحيى بن سلام ١/٤٦٩.أخرجه ابن جرير ١٧/٣٩٨، ومن طريق ابن جريج أيضًا، وإسحاق البستي في تفسيره ص٤٩٩ من طريق ابن جريج، وابن أبي حاتم ٨/٢٦٦٣. وعلَّقه يحيى بن سلام ١/٤٦٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ١/٤٦٩.تفسير الثعلبي ٧/١٢٣، وتفسير البغوي ٦/٧٢.أخرجه ابن أبي حاتم ٨/٢٦٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ١/٤٦٩.تفسير مقاتل بن سليمان ٣/٢٢٦.أخرجه ابن أبي حاتم ٨/٢٦٦٤. وعلَّقه يحيى بن سلام ١/٤٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٦٩.أخرجه ابن جرير ١٧/٣٩٩، وإسحاق البستي في تفسيره ص٤٩٩ من طريق ابن جريج، وابن أبي حاتم ٨/٢٦٦٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٦٩.
  25,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوۤا۟ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ٱكۡتَتَبَهَا﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن إسحاق، عن شيخ له، عن عكرمة- قال: كان النضرُ بنُ الحارث بن كلدة بن علقمة بن عبد مناف بن عبد الدار بن قصي مِن شياطين قريش، وكان يؤذي رسولَ الله ﷺ، وينصِب له العداوةَ، وكان قد قدم الحِيرة، تعلَّم بها أحاديثَ ملوك فارس، وأحاديثَ رستم وإسفندياز، فكان رسولُ الله ﷺ إذا جلس مجلسًا فذكَّر بالله، وحذَّر قومه ما أصاب مَن قبلهم مِن الأمم مِن نقمة الله؛ خَلَفَه في مجلسه إذا قام، ثم يقول: أنا -واللهِ- يا معشر قريش أحسنُ حديثًا منه، فهلموا، فأنا أُحَدِّثكم أحسنَ مِن حديثه. ثم يحدثهم عن ملوك فارس ورستم وإسفندياز، ثم يقول: ما محمد أحسن حديثًا مِنِّي. قال: فأنزل الله -تبارك وتعالى- في النَّضر ثماني آيات من القرآن؛ قول الله: <span class="qpc-hafs">﴿إذا تتلى عليه آياتنا قال أساطير الأولين﴾</span> [القلم:١٥،والمطففين:١٣]، وكلُّ ما ذكر فيه الأساطير في القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٦٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق محمد بن إسحاق بسنده- نحوه، إلا أنّه جعل قوله: في النضر ثماني آيات. عن ابن إسحاق، عن الكلبي، عن أبي صالح، عن ابن عباس{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوۤا۟ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ٱكۡتَتَبَهَا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقالوا أساطير الاولين﴾</span>، قال: كَذِبُ الأولين وأحاديثُهم{3}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿أساطير الأولين﴾</span>: أشعارهم وكهانتهم، وقالها النضر بن الحارث{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالوا أساطير الأولين﴾</span> وقال النضر: هذا القرآن حديث الأولين؛ أحاديث رستم وإسفنديار، <span class="qpc-hafs">﴿اكتتبها﴾</span> محمد ﷺ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿وقالوا أساطير الأولين﴾</span> أي: كَذِب الأولين وباطلُهم، <span class="qpc-hafs">﴿اكتتبها﴾</span> يقول: اكتتبها محمدٌ، كَتَب الأساطيرَ مِن عبد ابنِ الحضرمي. وقال <span class="name-3">الكلبي</span>: وعدّاسٌ غُلام عُتبة{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهِیَ تُمۡلَىٰ عَلَیۡهِ بُكۡرَةࣰ وَأَصِیلࣰا ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فهي تملى عليه بكرة وأصيلا﴾</span>، يقول: هؤلاء النفر الثلاثة يُعَلِّمون محمدًا ﷺ طَرَفَيِ النهار بالغداة والعشي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٧٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿فهي تملى عليه﴾</span> على محمد <span class="qpc-hafs">﴿بكرة وأصيلا﴾</span> والأصيل: العَشِيّ{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن إسحاق في السيرة ص٢٥٦، ومن طريقه ابن جرير ١٧/٣٩٩.</p><p>سنده ضعيف لجهالة شيخ ابن إسحاق.أخرجه ابن إسحاق في السيرة ص٢٥٧، وابن جرير ١٧/٤٠٠.</p><p>السند الأول جيد، أما السند الثاني فهو ضعيف جدًّا. ينظر: مقدمة الموسوعة.أخرجه ابن أبي حاتم ٨/٢٦٦٣. وعلَّقه يحيى بن سلام ١/٤٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٤٠٠.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٦٩.تفسير مقاتل بن سليمان ٣/٢٢٦.تفسير يحيى بن سلام ١/٤٧٠.
  25,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَنزَلَهُ ٱلَّذِی یَعۡلَمُ ٱلسِّرَّ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لهم، يا محمد: <span class="qpc-hafs">﴿أنزله الذي يعلم السر﴾</span>، وذلك أنهم قالوا بمكة سرًّا: <span class="qpc-hafs">﴿هَلْ هَذا إلّا بَشَرٌ مِثْلُكُمْ﴾</span> [الأنبياء:٣]؛ لأنه إنسيٌّ مثلكم، بل هو ساحر، <span class="qpc-hafs">﴿أفَتَأْتُونَ السِّحْرَ وأَنْتُمْ تُبْصِرُونَ﴾</span> [الأنبياء:٣] إلى آيتين. فأنزل الله ﷿: <span class="qpc-hafs">﴿قُلْ أنْزَلَهُ الَّذِي يَعْلَمُ السِّرَّ فِي السَّماواتِ والأَرْضِ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ أَنزَلَهُ ٱلَّذِی یَعۡلَمُ ٱلسِّرَّ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿يعلم السر﴾</span>، قال: السِرُّ: ما أسرَّ ابنُ آدم في نفسه{2}. (١٠/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٧٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق أبي رَوْق- قال: السِّرُّ: ما حَدَّثْتَ به نفسَك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿قل أنزله الذي يعلم السر في السموات والأرض﴾</span>، قال: ما يُسِرُّ أهلُ الأرض، وأهلُ السماء{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿قل أنزله﴾</span> أنزل القرآن{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ كَانَ غَفُورࣰا رَّحِیمࣰا ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿غفورا﴾</span>: يعني: لِما كان منهم في الشرك، <span class="qpc-hafs">﴿رحيما﴾</span> بهم في الإسلام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه كان غفورا﴾</span> في تأخير العذاب عنهم، <span class="qpc-hafs">﴿رحيما﴾</span> حين لا يعجل عليهم بالعقوبة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٢٧.أخرجه ابن جرير ١٦/١٣، وابن أبي حاتم ٨/٢٦٦٤، والبيهقي في الأسماء والصفات (٧٣). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٦٤.أخرجه ابن جرير ١٧/٤٠٢.تفسير يحيى بن سلام ١/٤٧٠.أخرجه ابن أبي حاتم ٨/٢٦٦٤.تفسير مقاتل بن سليمان ٣/٢٢٧.
  25,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ مَالِ هَـٰذَا ٱلرَّسُولِ یَأۡكُلُ ٱلطَّعَامَ وَیَمۡشِی فِی ٱلۡأَسۡوَاقِ لَوۡلَاۤ أُنزِلَ إِلَیۡهِ مَلَكࣱ فَیَكُونَ مَعَهُۥ نَذِیرًا ۝٧ أَوۡ یُلۡقَىٰۤ إِلَیۡهِ كَنزٌ أَوۡ تَكُونُ لَهُۥ جَنَّةࣱ یَأۡكُلُ مِنۡهَاۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿أوْ تَكُونُ لَهُ جَنَّةٌ يَأْكُلُ مِنها﴾</span>، وبعض الكوفيين يقرأها: ‹نَأْكُلُ مِنها›{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ مَالِ هَـٰذَا ٱلرَّسُولِ یَأۡكُلُ ٱلطَّعَامَ وَیَمۡشِی فِی ٱلۡأَسۡوَاقِ لَوۡلَاۤ أُنزِلَ إِلَیۡهِ مَلَكࣱ فَیَكُونَ مَعَهُۥ نَذِیرًا ۝٧ أَوۡ یُلۡقَىٰۤ إِلَیۡهِ كَنزٌ أَوۡ تَكُونُ لَهُۥ جَنَّةࣱ یَأۡكُلُ مِنۡهَاۚ﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن إسحاق، عن شيخ له، عن عكرمة-: أنّ عتبة وشيبة ابني ربيعة، وأبا سفيان بن حرب، والنضرَ بن الحارث، وأبا البختري، والأسود بن المطلب، وزمعة بن الأسود، والوليد بن المغيرة، وأبا جهل بن هشام، وعبد الله بن أبي أمية، وأمية بن خلف، والعاصي بن وائل، ونبيه بن الحجاج؛ اجتمعوا، فقال بعضُهم لبعض: ابعثوا إلى محمد، فكلِّموه، وخاصموه، حتى تعذروا منه. فبعثوا إليه: إنّ أشراف قومك قد اجتمعوا لك ليكلموك. قال: فجاءهم رسولُ الله ﷺ، فقالوا له: يا محمد، إنّا بعثنا إليك لِنعذر منك، فإن كنتَ إنّما جئتَ بهذا الحديث تطلب به مالًا جمعنا لك مِن أموالنا، وإن كنت تطلب الشرفَ فنحن نُسَوِّدك، وإن كنتَ تريد به مُلْكًا مَلَّكناك. فقال رسول الله ﷺ: «<b>ما بي مِمّا تقولون، ما جئتكم بما جئتكم به أطلبُ أموالَكم، ولا الشرفَ فيكم، ولا المُلْكَ عليكم، ولكنَّ الله بعثني إليكم رسولًا، وأنزل عَلَيَّ كتابًا، وأمرني أن أكون لكم بشيرًا ونذيرًا؛ فبلَّغْتُكم رسالةَ ربي، ونصحت لكم، فإن تقبلوا مِنِّي ما جئتكم به فهو حظُّكم في الدنيا والآخرة، وإن تردُّوه عَلَيَّ أصبرْ لأمر الله حتى يحكم الله بيني وبينكم</b>». قالوا: يا محمد، فإن كنت غير قابل مِنّا شيئًا مِمّا عرضنا عليك -أو قالوا: فإذا لم تقبل هذا- فسَل لنفسك، وسل ربَّك أن يبعث معك ملَكًا يُصَدِّقك بما تقول، ويراجعنا عنك، وسله أن يجعل لك جنانًا وقصورًا مِن ذهب وفضة؛ تُغنيك عمّا تبتغي، فإنّك تقوم بالأسواق، وتلتمس المعاشَ كما نلتمسه، حتى نعرف فضلَك ومنزلتك مِن ربِّك إن كنت رسولًا كما تزعم. فقال لهم رسول الله ﷺ: «<b>ما أنا بفاعل، ما أنا بالذي يسأل ربَّه هذا، وما بُعِثتُ إليكم بهذا، ولكنَّ الله بعثني بشيرًا ونذيرًا</b>». فأنزل الله في قولهم ذلك: <span class="qpc-hafs">﴿وقالوا مال هذا الرسول يأكل الطعام﴾</span> إلى قوله: <span class="qpc-hafs">﴿وجعلنا بعضكم لبعض فتنة أتصبرون وكان ربك بصيرًا﴾</span>. أي: جعلتُ بعضكم لبعض بلاءً لتصبروا، ولو شئتُ أن أجعل الدنيا مع رسولي فلا تخالفوه لَفَعَلْتُ{2}. (١١/١٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ مَالِ هَـٰذَا ٱلرَّسُولِ یَأۡكُلُ ٱلطَّعَامَ وَیَمۡشِی فِی ٱلۡأَسۡوَاقِ لَوۡلَاۤ أُنزِلَ إِلَیۡهِ مَلَكࣱ فَیَكُونَ مَعَهُۥ نَذِیرًا ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقالوا ما لهذا الرسول﴾</span> قال: عَجِب الكفارُ مِن ذلك أن يكون رسولٌ يأكل الطعام، ويمشي في الأسواق، <span class="qpc-hafs">﴿لولا أنزل إليه ملك فيكون معه نذيرا أو يلقي إليه كنز أو تكون له جنة يأكل منها﴾</span>{3}. (١١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿يأكل الطعام ويمشي في الأسواق﴾</span>، قال: هي الطريق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالوا مال هذا الرسول﴾</span> يعني: النبي ﷺ <span class="qpc-hafs">﴿يأكل الطعام ويمشي في الأسواق لولا أنزل إليه ملك فيكون معه نذيرا﴾</span> يعني: رسولًا يُصَدِّق محمدًا ﷺ بما جاء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: قوله: <span class="qpc-hafs">﴿وقالوا مال هذا الرسول﴾</span> فيما يدَّعي أنه رسول <span class="qpc-hafs">﴿يأكل الطعام ويمشي في الأسواق لولا﴾</span> هلّا <span class="qpc-hafs">﴿أنزل إليه ملك فيكون معه نذيرا﴾</span> فيُصَدِّقه بِمَقالَتِه{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ یُلۡقَىٰۤ إِلَیۡهِ كَنزٌ أَوۡ تَكُونُ لَهُۥ جَنَّةࣱ یَأۡكُلُ مِنۡهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو يلقى إليه كنز﴾</span> يعني: أو ينزل إليه مالٌ مِن السماء فيقسمه بيننا، <span class="qpc-hafs">﴿أو تكون له جنة﴾</span> يعني: بُستانًا <span class="qpc-hafs">﴿يأكل منها﴾</span>، هذا قول النضر بن الحارث، وعبد الله بن أمية، ونوفل بن خويلد، كلهم من قريش{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿أو يلقى إليه كنز﴾</span> فإنه فقير، <span class="qpc-hafs">﴿أو تكون له جنة يأكل منها﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلظَّـٰلِمُونَ إِن تَتَّبِعُونَ إِلَّا رَجُلࣰا مَّسۡحُورًا ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٣٨٩<span class="dash">-</span></span> عن <span class="name-1">البراء</span> -من طريق عبد الله بن مرة- قوله: <span class="qpc-hafs">﴿الظالمون﴾</span>، قال: اليهود{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٩٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿إن تتبعون إلا رجلا مسحورا﴾</span>، قال: بلغني: أنّ أبا سفيان بن حرب، وأبا جهل بن هشام، وعتبة بن ربيعة في رهط من قريش؛ قاموا من المسجد إلى دارٍ في أصل الصفا فيها نبيُّ الله يصلي، فاستمعوا، فلمّا فرغ نبيُّ الله مِن صلاته، قال أبو سفيان: يا أبا الوليد -لعتبة-، أنشدك بالله، أتعرف شيئًا مما يقول؟ فقال عتبة: اللهم، أعْرِفُ بعضًا، وأُنكِر بعضًا. فقال أبو جهل: فأنت، يا أبا سفيان، هل تعرف شيئًا مما يقول؟ فقال: اللهم، نعم. فقال أبو سفيان لأبي جهل: يا أبا الحكم، هل تعرف مِمّا يقول شيئًا؟ فقال أبو جهل: لا، والذي جعلها بنية -يعني: الكعبة-، ما أعرف مما يقول قليلًا ولا كثيرًا، و<span class="qpc-hafs">﴿إن تتبعون إلا رجلا مسحورا﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٩١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿وقال الظالمون إن تتبعون﴾</span>، قال: الوليد بن المغيرة وأصحابُه يومَ دار الندوة{11}. (١١/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الظالمون﴾</span> يعني: هؤلاء <span class="qpc-hafs">﴿إن﴾</span> يعني: ما <span class="qpc-hafs">﴿تتبعون إلا رجلا مسحورا﴾</span> يعني: أنّه مغلوب على عَقْلِه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٣٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلَّام</span>: <span class="qpc-hafs">﴿وقال الظالمون﴾</span> المشركون، يعنيهم{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ١/٤٧٠.</p><p>و‹نَأْكُلُ› بالنون قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة بالياء. انظر: النشر ٢/٣٣٣، والإتحاف ص٤١٥.أخرجه ابن إسحاق في السيرة ص١٩٧-٢٠٠، ومن طريقه ابن جرير ١٥/٨٧-٩٠. وأورده الواحدي في أسباب النزول ص٢٩٢-٢٩٤.</p><p>إسناده ضعيف؛ لجهالة شيخ ابن إسحاق.أخرجه ابن أبي حاتم ٨/٢٦٦٠، ٢٦٦٢-٢٦٦٤، ٢٦٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٦٥.تفسير مقاتل بن سليمان ٣/٢٢٧.تفسير يحيى بن سلام ١/٤٧٠.تفسير مقاتل بن سليمان ٣/٢٢٧.تفسير يحيى بن سلام ١/٤٧٠.أخرجه ابن أبي حاتم ٨/٢٦٦٥، وأخرجه ابن أبي حاتم أيضًا ٤/١١٤٦ في تفسير قوله تعالى: <span class="qpc-hafs">﴿ومَن لَمْ يَحْكُمْ بِما أنْزَلَ اللَّهُ فَأُولَئِكَ هُمُ الظّالِمُونَ﴾</span> [المائدة:٤٥].علَّقه يحيى بن سلام ١/٤٧٠.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٧.تفسير يحيى بن سلام ١/٤٧٠.
