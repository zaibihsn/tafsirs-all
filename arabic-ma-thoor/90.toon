quran[20]{c,v,t}:
  90,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٢٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (١٥/٤٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٢٧<span class="dash">-</span></span> عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمُسمّى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿ق والقرآن المجيد﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٢٨<span class="dash">-</span></span> عن عبد الله بن الزُّبير: نزلت سورة <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span> بمكة{3}. (١٥/٤٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٢٩<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٠<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسمّياها: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣١<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٢<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، وذكرها بمُسمّى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، وأنها نزلت بعد <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٤<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة البلد مكّيّة، عددها عشرون آية كوفي{8}<span class=comment-ref>٧١٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٧٤</span> <span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/٦١٨) عن قوم: «أنّ سورة البلد مدنية».</div></p><p><h3><span class="qpc-hafs">﴿لَاۤ أُقۡسِمُ بِهَـٰذَا ٱلۡبَلَدِ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله تعالى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، قال: مكة{9}. (١٥/٤٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، قال: مكة{10}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لا أُقْسِمُ﴾</span>، قال: <span class="qpc-hafs">﴿لا﴾</span> ردًّا عليهم، <span class="qpc-hafs">﴿أُقْسِمُ بِهَذا البَلَدِ﴾</span>{11}<span class=comment-ref>٧١٧٥</span>. (١٥/٤٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٧١٧٥</span> <span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/٦١٨) في معنى: <span class="qpc-hafs">﴿لا أقسم﴾</span> قولين آخرين: <b>الأول</b> عن الزَّجّاج وغيره: أن «<span class="qpc-hafs">﴿لا﴾</span> صلة زائدة مؤكدة، واستأنف قوله تعالى: <span class="qpc-hafs">﴿أُقْسِمُ﴾</span>». <b>والثاني</b> عن بعض المتأولين: أنّ «<span class="qpc-hafs">﴿لا﴾</span>» نفيٌ للقَسم بالبلد، أخبر الله تعالى أنه لا يُقسِم به".</div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>: يعني: مكة{12}. (١٥/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٣٩<span class="dash">-</span></span> عن منصور بن المعتمر، قال: سأل رجل <span class="name-2">مجاهدًا</span> عن هذه الآية: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>. قال: لا أدري. ثم فسّرها لي، فقال: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span> الحرام{13}. (١٥/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٠<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق عبد الملك- في قوله: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>: يعني: مكة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، قال: مكة{13}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، قال: مكة{16}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، يعني: مكة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قول الله: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ﴾</span>، قال: مكة{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٦٩٩.أخرجه ابن جرير ٢٤/٤٠١، وابن مردويه -كما في فتح الباري ٨/٧٠٣-٧٠٤-، والطبراني (١٢٤١٢). وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٤٠١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٤٠٢.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٧٣، وابن جرير ٢٤/٤٠٢ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٧٠١.أخرجه ابن جرير ٢٤/٤٠٢.
  90,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنتَ حِلُّۢ بِهَـٰذَا ٱلۡبَلَدِ ۝٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٤٥<span class="dash">-</span></span> عن <span class="name-1">أبي بَرزة الأسلمي</span>، قال: فِيّ نزلت هذه الآية: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>؛ خرجتُ، فوجدت عبد الله بن خَطَل مُتعلّقًا بأستار الكعبة، فضربتُ عُنُقه بين الرُّكن والمقام{1}. (١٥/٤٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: لَمّا فتح النبيُّ ﷺ الكعبةَ أخذ أبو بَرزة الأسلمي هو وسعيدُ بن حُريث عبدَ الله بن خَطَل -وهو الذي كانت قريش تُسمّيه: ذا القَلْبَين؛ فأنزل الله: <span class="qpc-hafs">﴿ما جَعَلَ اللَّهُ لِرَجُلٍ مِن قَلْبَيْنِ فِي جَوْفِهِ﴾</span>-، فقدَّمه أبو بَرزة، فضَرب عُنُقه وهو مُتعلّق بأستار الكعبة؛ فأنزل الله فيه: <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، وإنما كان ذلك لأنه قال لقريش: أنا أعلم لكم علم محمد. فأتى النبيَّ ﷺ، فقال: يا رسول الله، إني أحبّ أن تَسْتَكتبني. قال: «<b>فاكتب</b>». فكان إذا أملى عليه من القرآن: <span class="qpc-hafs">﴿وكانَ اللَّهُ عَلِيمًا حَكِيمًا﴾</span> [النساء:١٧] كتب: وكان الله حكيمًا عليمًا. وإذا أملى عليه: <span class="qpc-hafs">﴿وكانَ اللَّهُ غَفُورًا رَحِيمًا﴾</span> [النساء:٩٦] كتب: وكان الله رحيمًا غفورًا. ثم يقول: يا رسول الله، أقرأ عليك ما كتبتُ؟ فيقول: «<b>نعم</b>». فإذا قرأ عليه: وكان الله حكيمًا عليمًا. أو: رحيمًا غفورًا. قال له النبيُّ ﷺ: «<b>ما هكذا أمليتُ عليك، وإنّ الله لكذلك؛ إنه لغفور رحيم، وإنه لرحيم غفور</b>». فرجع إلى قريش فقال: ليس آمره بشيء كنتُ آخذ به فيتصرف. فلم يُؤمِّنه، فكان أحد الأربعة الذين لم يُؤمِّنهم النبيُّ ﷺ{2}. (١٥/٤٣٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنتَ حِلُّۢ بِهَـٰذَا ٱلۡبَلَدِ ۝٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: أنتَ -يا محمد- يحلّ لك أن تقاتل به، وأمّا غيرك فلا{3}<span class=comment-ref>٧١٧٦</span>. (١٥/٤٣٢)</p></p><p></div></p><p><div><span class=comment-ref>٧١٧٦</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ كثير</u> (١٤/٣٥٣) قول ابن عباس، وأبي صالح، والضَّحّاك، والحسن، وعطية، وقتادة، وابن زيد بقوله: «وهذا المعنى الذي قالوه <span class="mustanad">قد ورد به الحديث المتفق على صحته</span>: «<b>إنّ هذا البلد حرّمه الله يوم خلق السموات والأرض، فهو حرام بحرمة الله إلى يوم القيامة، لا يُعضَد شجره، ولا يُختلى خلاه، وإنما أُحِلّتْ لي ساعة من نهار، وقد عادتْ حُرمتها اليوم كحُرمتها بالأمس، ألا فليبلغ الشاهد الغائب</b>». وفي لفظ: «<b>فإنْ أحدٌ ترخَّص بقتال رسول الله فقولوا: إنّ الله أذن لرسوله، ولم يأذن لكم</b>»».</div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله تعالى: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>: يعني بذلك: النبيَّ ﷺ؛ أحلّ الله له يوم دخل مكة أن يقتل مَن شاء، ويستحيي مَن شاء، فقَتل يومئذ ابن خَطَل صَبْرًا وهو آخِذٌ بأستار الكعبة، فلم يحلّ لأحد مِن الناس بعد رسول الله ﷺ أن يقتل فيها حرامًا حرّمه الله، فأحلّ الله له ما صنع بأهل مكة، ألم تسمع أنّ الله قال في تحريم الحَرم: <span class="qpc-hafs">﴿ولِلَّهِ عَلى النّاسِ حِجُّ البَيْتِ مَنِ اسْتَطاعَ إلَيْهِ سَبِيلًا﴾</span> [آل عمران:٩٧]؟ يعني بالناس: أهل القِبلة{4}. (١٥/٤٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: أحلّ له أن يصنع فيه ما شاء{5}. (١٥/٤٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: مكة{6}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور-: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، يعني: رسول الله ﷺ، يقول: أنتَ في حِلٍّ مما صنعتَ فيه{7}. (١٥/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، يقول: لا تُؤاخذ بما عملتَ فيه، وليس عليك فيه ما على الناس{8}. (١٥/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٣<span class="dash">-</span></span> عن منصور بن المعتمر، قال: سأل رجلٌ <span class="name-2">مجاهدًا</span> عن هذه الآية: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>. قال: لا أدري. ثم فسّرها لي، فقال: الحرام، أحلّ الله له ساعة من النهار؛ قيل له: ما صنعتَ فيه من شيء فأنت في حِلٍّ{9}. (١٥/٤٣٤-٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: أُحلّتْ له ساعة من نهار{9}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، مثله{9}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد-: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، يعني: محمدًا ﷺ، يقول: أنتَ حِلٌّ بالحرم؛ فاقتل إن شئتَ، أو دَعْ{12}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: أحلّها الله لمحمد ﷺ ساعةً مِن نهار يوم الفتح{13}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٨<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span>، <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: أُحلّتْ مكةُ للنبي ﷺ ساعةً مِن نهار، ثم أُطبقتْ إلى يوم القيامة{9}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٥٩<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق عبد الملك- <span class="qpc-hafs">﴿لا أُقْسِمُ بِهَذا البَلَدِ وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: إنّ الله حرّم مكة يوم خلق السموات والأرض، فهي حرام إلى أن تقوم الساعة، لم تحلّ لبشر إلا لرسول الله ﷺ ساعةً مِن نهار، لا يُختلى خلاها{15}، ولا يُعضَد عِضاهها{16}، ولا يُنفَّر صيدها، ولا تَحلّ لُقَطتها إلا لمعرّف{17}. (١٥/٤٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: أنتَ به غير حَرِجٍ، ولا آثم{18}. (١٥/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦١<span class="dash">-</span></span> عن <span class="name-2">شرحبيل بن سعد</span> -من طريق أبي مَعشر- <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: يُحرِّمون أن يقتلوا بها الصيد، ويعضدوا بها شجرة، ويستحلُّون إخراجك وقتلك!{19}. (١٥/٤٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، يعني: لم أُحلّها لأحد مِن قبلك ولا مِن بعدك، وإنما أحللتها لك ساعة مِن النهار، وذلك أنّ الله ﷿ لم يفتح مكة على أحد غيره، ولم يحلّ بها القتلُ لأحد، غير ما قتل النبيُّ ﷺ مقيس بن [صبابة] الكناني وغيره حين فتح مكة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span>، قال: لم يكن بها أحدٌ حِلًّا غير النبيِّ ﷺ، كلّ مَن كان بها حرامٌ لم يحلّ لهم أن يُقاتلوا فيها، ولا يستحلُّوا فيها حُرمة، فأحلّه الله لرسوله، فقاتل المشركين فيه{21}<span class=comment-ref>٧١٧٧</span>. (١٥/٤٣٦)</p></p><p></div></p><p><div><span class=comment-ref>٧١٧٧</span> اختُلف في معنى: <span class="qpc-hafs">﴿وأَنْتَ حِلٌّ بِهَذا البَلَدِ﴾</span> على قولين: <b>الأول:</b> أنت حلال بهذا البلد يحلّ لك فيه قتْل مَن شئتَ. <b>الثاني:</b> أنت مُحِلٌّ بهذا البلد غير محرم في دخوله.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٦١٨) القول الأول بقوله: «وكان هذا يوم فتح مكة، وعلى هذا يتركب قول مَن قال: السورة مدنية نزلت عام الفتح. ويتركب على هذا التأويل قول مَن قال: <span class="qpc-hafs">﴿لا﴾</span> نافية، أي: إنّ هذا البلد لا يُقسِم الله به، وقد جاء أهله بأعمال توجب إحلال حُرمته. ويتَّجه أيضًا أن تكون <span class="qpc-hafs">﴿لا﴾</span> غير نافية».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٣/٣٠٣) القول الثاني بأنه «حلال ساكن البلد، بخلاف المحرم الذي يحج ويعتمر ويرجع، ولأنّ أمْنه إنما تظهر به النعمة عند الحِلّ من الإحرام، وإلا ففي حال الإحرام هو في أمان، والحرمة هناك للفعل لا للمكان، والمقصود هو ذِكْر حرمة المكان، وهي إنما تظهر بحال الحلال الذي لم يتلبس بما يقتضي أمْنه، ولكن على هذا ففيه تنبيه، فإنه إذا أقسم به وفيه الحلال فإذا كان فيه الحرام فهو أولى بالتعظيم والأمن».</p><p>ونقل <u>ابنُ عطية</u> عن بعض المتأولين أنّ المعنى: «وأنت ساكنٌ بهذا البلد». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وعلى هذا يجيء قول مَن قال: هي مكّيّة. والمعنى على إيجاب القسم بيِّن، وعلى نفيه أيضًا يتَّجه على معنى: لا أُقسِم ببلد أنت ساكنه على أذى هؤلاء القوم وكفرهم».</p><p>و<span class="comment-type-1">وجَّهه</span> <u>ابنُ القيم</u> (٣/٣٠٤) بأنه «متضمن لهذا التعظيم، مع تضمّنه أمرًا آخر، وهو الإقسام ببلده المشتمل على رسوله وعبده، فهو خير البقاع وقد اشتمل على خير العباد، فجعل بيته هدًى للناس، ونبيّه إمامًا وهاديًا لهم، وذلك من أعظم نِعمه وإحسانه إلى خَلْقه، كما هو مِن أعظم آياته ودلائل وحدانيته وربوبيته، فمن اعتبر حال بيته وحال نبيّه وجد ذلك من أظهر أدلة التوحيد والربوبية». ثم <b>نقل</b> عن شرحبيل بن سعد -حكاية عن الثعلبي- أنّ المعنى: «قد جعلوك حلالًا مُستَحل الأذى والإخراج والقتل لك لو قدروا».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن عبد البر في التمهيد ٦/١٧٠-١٧١ مختصرًا.عزاه السيوطي إلى ابن أبي حاتم، وابن جرير. وأخرجه ابن مردويه بنحوه -كما في فتح الباري ٨/٧٠٣-٧٠٤-.أخرجه ابن جرير ٢٤/٤٠٣. وعزاه السيوطي إلى ابن مردويه.أخرجه الحاكم ٢/٥٢٣.أخرجه ابن جرير ٢٤/٤٠١، والطبراني (١٢٤١٢).أخرجه ابن جرير ٢٤/٤٠٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.تفسير مجاهد ص٥٠٥ بنحوه، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٨، وفتح الباري ٨/٧٠٣-، وابن جرير ٢٤/٤٠٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٣٣-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٤٠٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.الخلا -مقصور-: النبات الرطب الرقيق ما دام رطبًا، واختلاؤه: قطعه، وأخلت الأرض: كثر خلاها، فإذا يبس فهو حشيش. النهاية (خلا).العضاة: شجر أم غيلان، وكلّ شجر عظيم له شوك. النهاية (عضه).أخرجه ابن جرير ٢٤/٤٠٥ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٧٣، وابن جرير ٢٤/٤٠٤، وكذلك من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور في سننه -التفسير ٨/٣٤٣ (٢٤٦١). وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٧٠١.أخرجه ابن جرير ٢٤/٤٠٥، وزاده: فأحله الله لرسوله، فقاتل المشركين فيه.
  90,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَالِدࣲ وَمَا وَلَدَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد-: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span> يعني بالوالد: آدم، <span class="qpc-hafs">﴿وما ولَدَ﴾</span> ولده{1}. (١٥/٤٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: هو الوالد، وولده{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span> قال: الوالد الذي يلد، <span class="qpc-hafs">﴿وما ولَدَ﴾</span>: العاقِر الذي لا يلد من الرجال والنساء{3}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: آدم، وما ولد{4}. (١٥/٤٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span> قال: الوالد: آدم، <span class="qpc-hafs">﴿وما ولَدَ﴾</span> ولده{5}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٦٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: الوالد: آدم، وما ولد: ولده{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النضر بن عربي- <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: العاقر، والتي تلد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل ابن أبي خالد- في قوله: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: آدم، وما ولد{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: آدم، وما ولد{9}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٣<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجوني</span> -من طريق جعفر بن سليمان- <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: إبراهيم، وما ولد{10}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، يعني: آدم، وذُرّيته ﵇ إلى أن تقوم الساعة، فأقسم الله ﷿ بمكة، وبآدم، وذُرّيته{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٥<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- في قوله: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span>، قال: آدم، وما ولد{6}<span class=comment-ref>٧١٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٧٨</span> اختُلف في معنى: <span class="qpc-hafs">﴿ووالِدٍ وما ولَدَ﴾</span> على أقوال: <b>الأول:</b> عُنِيَ بالوالد: كلّ والد، وما ولد: كلّ عاقر لم يلد. <b>الثاني:</b> عني بذلك: آدم، وولده. <b>الثالث:</b> إبراهيم، وما ولد.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٤٠٨) <span class="mustanad">العموم</span>، فقال: «إنّ الله أقسم بكلّ والدٍ وولده». وعلَّل ذلك بقوله: «لأنّ الله عمَّ كلَّ والدٍ وما ولد، وغير جائزٍ أن يُخَصَّ ذلك إلا بحجّةٍ يجب التسليم لها من خبر، أو عقل، ولا خبر بخصوص ذلك، ولا برهان يجب التسليم له بخصوصه، فهو على عمومه كما عمَّه».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٤/٣٥٤) القول الثاني، وهو قول مجاهد وما في معناه <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وهذا الذي ذهب إليه مجاهد وأصحابه حسنٌ قوي؛ لأنه تعالى لما أقسم بأُمّ القُرى وهي المساكن أقسم بعده بالساكن، وهو آدم أبو البشر وولده». ثم ذكر أنّ اختيار <u>ابن جرير</u> محتمل أيضًا.</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/٦١٩) عن بعض رواة التفسير أنّ معنى الآية: «نوح، وجميع ولده». و<span class="comment-type-4">نقل</span> عن ابن عباس ما معناه: «أنّ الوالد والولد هنا على العموم؛ فهي أسماء جنس يدخل فيها جميع الحيوان».</div></p></div>",footnotes:1:أخرجه الحاكم ٢/٥٢٣.أخرجه ابن جرير ٢٤/٤٠٦.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٥٠٥-، وأخرجه ابن جرير ٢٤/٤٠٦، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٢٥-. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.تفسير مجاهد ص٥٠٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٨-، وابن جرير ٢٤/٤٠٦-٤٠٧. وعلقه البخاري في صحيحه ٤/١٨٨٨ مقتصرًا على أوله. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٤٠٧.أخرجه ابن جرير ٢٤/٤٠٦.أخرجه ابن جرير ٢٤/٤٠٧.أخرجه عبد الرزاق ٢/٣٧٣، وابن جرير ٢٤/٤٠٧، ومن طريق سعيد أيضًا.أخرجه ابن جرير ٢٤/٤٠٨، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٢٥-.تفسير مقاتل بن سليمان ٤/٧٠١.أخرجه ابن جرير ٢٤/٤٠٧.
  90,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَقَدۡ خَلَقۡنَا ٱلۡإِنسَـٰنَ فِی كَبَدٍ ۝٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span> نزلت هذه الآية في الحارث بن عمرو بن نوفل بن عبد مناف القرشي؛ وذلك أنه أصاب ذنبًا وهو بالمدينة، فأتى رسول الله ﷺ، فقال: ما كفّارته؟ فقال رسول الله ﷺ: «<b>اذهب فأعتق رقبة، أو أطعِم ستين مسكينًا</b>». قال: ليس غير هذا؟ قال رسول الله ﷺ: «<b>هو الذي أخبرتُك</b>». فرجع من عند رسول الله ﷺ وهو مهموم مغموم حتى أتى أصحابَه، فقال: واللهِ، ما أعلم إلا أني لَئِن دخلتُ في دين محمد إنّ مالي لَفي نقصان مِن الكفارات والنفقة في سبيل الله، ما يظن محمد إلا أنّا وجدنا هذا المال في الطريق! لقد أنفقتُ مالًا لبدًا. يعني: مالًا كثيرًا؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>{1}<span class=comment-ref>٧١٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٧٩</span> نقل <u>ابنُ عطية</u> (٨/٦٢٠) <b>قولين</b> آخرين في نزول الآية، فقال: «وروي أن سبب هذه الآية وما بعدها هو أبو الأشَدَّين، رجل من قريش شديد القوة، اسمه: أسيد بن كلدة الجمحي، كان يحسب أن أحدًا لا يقدر عليه. ويقال: بل نزلتْ في عمرو بن عبد ودّ. ذكره النَّقّاش». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهو الذي اقتحم الخندق بالمدينة، وقتله علي بن أبي طالب ﵁ خلف الخندق».</div></p><p><h3><span class="qpc-hafs">﴿لَقَدۡ خَلَقۡنَا ٱلۡإِنسَـٰنَ فِی كَبَدٍ ۝٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٢٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: في انتصاب. ويُقال: في شِدّة{2}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: في نصب{3}. (١٥/٤٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: في شِدّة{4}. (١٥/٤٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: في شدة معيشته، وحمله وحياته، ونبات أسنانه{5}. (١٥/٤٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: خَلَق اللهُ كلَّ شيء يمشى على أربعة، إلا الإنسان فإنه خُلِق مُنتَصِبًا{6}. (١٥/٤٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: مُنتَصِبًا في بطن أُمّه{7}. (١٥/٤٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: مُنتصبًا في بطن أُمّه؛ إنه قد وُكِّل به مَلَكٌ إذا نامت الأُمّ أو اضطجعتْ رفع رأسه، لولا ذلك لغرق في الدم{8}. (١٥/٤٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله ﷿: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>. قال: في اعتدال واستقامة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول لبَيد بن ربيعة:</p><p>يا عينُ هلا بكيتِ أربدَ إذ قمنا وقام الخصوم في كَبد؟{9}. (١٥/٤٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٥<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شدّاد بن الهاد</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: معتدلًا بالقامة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عمرو بن ثابت، عن أبيه- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>: في انتصاب{11}. (١٥/٤٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- أحسبه عن عبد الله، <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span>، قال: مُنتصبًا{12}. (١٥/٤٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن أبي الحسن</span> -من طريق علي بن رفاعة- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: يُكابد مضايق الدنيا، وشدائد الآخرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٨٩<span class="dash">-</span></span> قال حُميد: أرسل <span class="name-2">عمر بن عبد العزيز</span> إلى مجاهد، قال: فخرجتُ معه، فلما كان يوم الجمعة خرج عمر، فصعد المنبر، فقال: ألا إنّ الله خَلَقكم مِن أكباد، فقال: <span class="qpc-hafs">﴿لقد خلقنا الإنسان في كبد﴾</span> ...{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: في شدة{15}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- <span class="qpc-hafs">﴿الإنْسانَ فِي كَبَدٍ﴾</span>، قال: شدة خروج أسنانه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مغيرة- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: صَعَد{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span>: خُلِق مُنتصبًا على رجلين، لم تُخلق دابة على خَلْقه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النضر- <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span>، قال: شدة وطول{19}. (١٥/٤٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمارة- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: في انتصاب، يعني: القامة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق علي بن رفاعة- أنه قرأ هذه الآية: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>. قال: لا أعلم خليقة يُكابد مِن الأمر ما يُكابِد هذا الإنسان{21}. (١٥/٤٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي مودود- <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: يُكابد أمور الدنيا، وأمور الآخرة{22}. (١٥/٤٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، قال: معتدلًا في القامة. وفي لفظ: قائمًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٢٩٩<span class="dash">-</span></span> عن عبد الحميد بن جعفر، سمعتُ <span class="name-2">محمد بن علي أبا جعفر الباقر</span> سأل رجلًا مِن الأنصار عن قول الله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>. قال: في قيامه واعتداله. فلم يُنكر عليه أبو جعفر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ﴾</span> قال: وقع هاهنا القسم، <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span> قال: في مشقّة؛ يُكابد أمر الدنيا وأمر الآخرة{25}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠١<span class="dash">-</span></span> قال <span class="name-2">عمرو بن دينار</span>: <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span> نبات أسنانه{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٢<span class="dash">-</span></span> قال <span class="name-2">خُصَيف بن عبد الرحمن</span>: <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span> مقاساة وانتقال أحوال، نُطفة ثم عَلقة إلى آخر تمام الخَلْق{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span> في قوة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span> مُنتصبًا قائمًا، وذلك أنّ الله -تبارك وتعالى- خَلَق كلّ شيء على أربع قوائم غير ابن آدم يمشي على رجلين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٥<span class="dash">-</span></span> عن <span class="name-3">معمر بن راشد</span> -من طريق عبد الرزاق- <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span>، قال: شيء من خلق، لم يُخلق خَلْقه شيء{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span>، قال: في السماء خُلِق آدم{31}<span class=comment-ref>٧١٨٠</span>. (١٥/٤٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٧١٨٠</span> اختُلف في معنى: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span> على أقوال: <b>الأول:</b> لقد خلقنا ابن آدم في شدة وعناء ونصب. <b>الثاني:</b> خُلِقَ مُنتَصبًا مُعتَدِل القامة. <b>الثالث:</b> أنه خُلِق في السماء.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ كثير</u> (١٤/٣٥٤) القول الثاني بقوله: «ومعنى هذا القول: لقد خلقنا الإنسان سويًّا مستقيمًا كقوله: <span class="qpc-hafs">﴿يا أيُّها الإنْسانُ ما غَرَّكَ بِرَبِّكَ الكَرِيمِ الَّذِي خَلَقَكَ فَسَوّاكَ فَعَدَلَكَ﴾</span> [الانفطار:٦-٧]، وكقوله: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي أحْسَنِ تَقْوِيمٍ﴾</span> [التين:٤]».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٤/٤١٢) -<span class="mustanad">مستندًا إلى لغة العرب</span>- القول الأول، وهو قول ابن عباس من طريق علي بن أبي طلحة وسعيد بن جُبَير، وما في معناه، وعلَّل ذلك بقوله: «لأنّ ذلك هو المعروف من كلام العرب من معاني الكَبَد».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٨/٦٢٠) ولم يذكر مستندًا، و<span class="comment-type-2">انتقد</span> القول الثاني والثالث قائلًا: «وهذان القولان قد ضُعِّفا».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٧٠١-٧٠٢.أخرجه ابن جرير ٢٤/٤١٠، والطبراني (١٢٤١٢) من طريق سعيد بن جُبَير بلفظ: في اعتدال وانتصاب.أخرجه ابن جرير ٢٤/٤٠٨.أخرجه ابن جرير ٢٤/٤١٠.أخرجه ابن جرير ٢٤/٤١٠، والحاكم ٢/٥٢٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم بلفظ: في شدة خَلْق؛ في ولادته، ونبْت أسنانه، وسَرره، ومعيشته، وختانه.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو الشيخ في العظمة (١٠٩١).أخرجه نافع في مسائله (٤٩). وعزاه السيوطي إلى الطستي في مسائله.أخرجه ابن جرير ٢٤/٤١١.أخرجه سعيد بن منصور في سننه -التفسير ٨/٣٤٤ (٢٤٦٢). وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٢٩-، وابن جرير ٢٤/٤١١. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن المبارك في الزهد (٢٣١)، وابن جرير ٢٤/٤٠٩. وأخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٢٦- عن أخيه الحسن. وكذا نسبه السيوطي إليه كما سيأتي.أخرجه ابن عساكر في تاريخ دمشق ١٥/٢٩٣.تفسير مجاهد ص٥٠٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٨-، وابن جرير ٢٤/٤١٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٤١٠.أخرجه ابن جرير ٢٤/٤١١.أخرجه ابن جرير ٢٤/٤١١.أخرجه ابن جرير ٢٤/٤٠٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٤١١.أخرجه ابن المبارك (٢٣٠)، وابن جرير ٢٤/٤٠٩، وبنحوه من طريق منصور.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٢٦-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٤١١.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٠٣-.أخرجه عبد الرزاق ٢/٣٧٣، وابن جرير ٢٤/٤٠٨-٤٠٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٣٣- بنحوه.تفسير البغوي ٨/٤٣٠. وفي تفسير الثعلبي ١٠/٢٠٧ عن عمرو بن دينار عن ابن عباس، وتقدم نحو ذلك عنه.تفسير الثعلبي ١٠/٢٠٧.تفسير الثعلبي ١٠/٢٠٧، وتفسير البغوي ٨/٤٣٠.تفسير مقاتل بن سليمان ٤/٧٠١-٧٠٢.أخرجه عبد الرزاق ٢/٣٧٣.أخرجه ابن جرير ٢٤/٤١٢. وعزاه السيوطي إلى ابن أبي حاتم.
  90,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَیَحۡسَبُ أَن لَّن یَقۡدِرَ عَلَیۡهِ أَحَدࣱ ۝٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٣٣٠٧<span class="dash">-</span></span> عن رجل من بني عامر، قال: صَلّيتُ خلف النبيِّ ﷺ، فسمعتُه يقرأ: <span class="qpc-hafs">﴿أيَحْسَبُ أن لَّن يَقْدِرَ عَلَيْهِ أحَدٌ﴾</span>، <span class="qpc-hafs">﴿أيَحْسَبُ أن لَّـمْ يَرَهُ أحَدٌ﴾</span> [البلد:٧]، يعني: بفتح السين مِن «يحسَب»{1}. (١٥/٤٤٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَیَحۡسَبُ أَن لَّن یَقۡدِرَ عَلَیۡهِ أَحَدࣱ ۝٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٣٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَنْ يَقْدِرَ عَلَيْهِ أحَدٌ﴾</span> الآية، قال: الكافر يحسب أن لن يقدر الله عليه، ولم يره{2}. (١٥/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَنْ يَقْدِرَ عَلَيْهِ أحَدٌ﴾</span> يعني بالأحد: الله ﷿، يعني نفسه، أيحسب هذا الإنسان أن لن يقدر الله ﷿ على أن يذهب بماله وإنْ أحرزه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:الحديث عند أبي يعلى -كما في المطالب العالية (٤١٧٩)، وإتحاف السادة المهرة (٦٦٠٧)-. وعزاه السيوطي إلى أبي يعلى، والبغوي، وابن مردويه.</p><p>قال البوصيرى: «سند ضعيف لجهالة بعض رواته».</p><p>وهي قراءة متواترة، قرأ بها ابن عامر، وعاصم، وحمزة، وأبو جعفر، وقرأ بقية العشرة: ‹أيَحْسِبُ› بكسر السين. انظر: الإتحاف ص٥٨٥.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٧٠٢.
  90,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَقُولُ أَهۡلَكۡتُ مَالࣰا لُّبَدًا ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿مالًا لُبَدًا﴾</span>، قال: كثيرًا{1}. (١٥/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يَقُولُ أهْلَكْتُ مالًا لُبَدًا﴾</span>، قال: كثيرًا{2}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿أهْلَكْتُ مالًا لُبَدًا﴾</span>، قال: أنفقتُ مالًا في الصّدِّ عن سبيل الله{3}. (١٥/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يَقُولُ أهْلَكْتُ مالًا لُبَدًا﴾</span>، قال: كثيرًا{4}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٤<span class="dash">-</span></span> عن <span class="name-2">شرحبيل بن سعد</span> -من طريق أبي مَعشر- في قوله: <span class="qpc-hafs">﴿أهلكت مالا لبدا﴾</span>، قال: كثير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعني: مالًا كثيرًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿يَقُولُ أهْلَكْتُ مالًا لُبَدًا﴾</span>، قال: أيمُنّ علينا؟! فما فضّلناه أفضل، <span class="qpc-hafs">﴿ألَمْ نَجْعَلْ لَهُ عَيْنَيْنِ﴾</span> وكذا وكذا؟!{7}. (١٥/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿مالًا لُبَدًا﴾</span>، قال: اللبد: الكثير{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٤١٣.تفسير مجاهد ص٥٠٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٨-، وابن جرير ٢٤/٤١٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٣٣-. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٧٣، وابن جرير ٢٤/٤١٣-٤١٤، ومن طريق سعيد أيضًا.أخرجه سعيد بن منصور في سننه -التفسير ٨/٣٤٧ (٢٤٦٦).تقدم في نزول قوله تعالى: <span class="qpc-hafs">﴿لَقَدْ خَلَقْنا الإنْسانَ فِي كَبَدٍ﴾</span>، أما هذه الآية فقد ذكر المحقق أنها ساقطة مع تفسيرها. تفسير مقاتل بن سليمان ٤/٧٠٢.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٤١٤.
  90,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَیَحۡسَبُ أَن لَّمۡ یَرَهُۥۤ أَحَدٌ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٣٣١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَمْ يَرَهُ أحَدٌ﴾</span>، قال: لم يقدر عليه أحد{1}. (١٥/٤٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣١٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَمْ يَرَهُ أحَدٌ﴾</span>، قال: الأحد: الله ﷿{2}. (١٥/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَمْ يَرَهُ أحَدٌ﴾</span>، قال: ابن آدم، إنك مسؤول عن هذا المال؛ من أين اكتسبتَه، وأين أنفقتَه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٢١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَمْ يَرَهُ أحَدٌ﴾</span> إنه كان كاذبًا في قوله أنفقتُ كذا وكذا، ولم يكن أنفق جميع ما قال، يقول: أيظنّ أنّ الله ﷿ لم يرَ ذلك منه فيعلم مقدار نفقته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال الله تعالى وهو يَعِده الخير: <span class="qpc-hafs">﴿أيَحْسَبُ أنْ لَمْ يَرَهُ أحَدٌ﴾</span>، أوَيحسب هذا الإنسان أنّ الله تعالى ليس يرى ما يُنفق وليس يُحصيه، وهو يُخلفه عليه؟!{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٨-. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٧٣، وابن جرير ٢٤/٤١٤، ومن طريق سعيد أيضًا.تفسير البغوي ٨/٤٣١.تفسير مقاتل بن سليمان ٤/٧٠٢.
  90,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ نَجۡعَل لَّهُۥ عَیۡنَیۡنِ ۝٨ وَلِسَانࣰا وَشَفَتَیۡنِ ۝٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٣٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ألَمْ نَجْعَلْ لَهُ عَيْنَيْنِ﴾</span> الآية، قال: نِعَمٌ مِن الله مِتظاهرة يقرّرك بها كيما تشكر{1}. (١٥/٤٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَمۡ نَجۡعَل لَّهُۥ عَیۡنَیۡنِ ۝٨ وَلِسَانࣰا وَشَفَتَیۡنِ ۝٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٣٣٢٤<span class="dash">-</span></span> عن مكحول، قال: قال النبيُّ ﷺ: «<b>يقول الله: يا ابن آدم، قد أنعمتُ عليك نِعَمًا عِظامًا لا تُحصي عدّها، ولا تُطيق شُكْرها، وإنّ مما أنعمتُ عليك أن جعلتُ لك عينين تنظر بهما، وجعلتُ لهما غطاء، فانظر بعينيك إلى ما أحللتُ لك، فإن رأيتَ ما حرّمتُ عليك فأطبِق عليهما غطاءهما، وجعلتُ لك لسانًا، وجعلتُ له غلافًا، فانطقْ بما أمرتُك، وأحللتُ لك، فإنْ عرض لك ما حرّمتُ عليك فأغلِق عليك لسانك، وجعلتُ لك فرَجًا، وجعلتُ لك سِتْرًا، فأصِب بفرجِك ما أحللتُ لك، فإنْ عرض لك ما حرّمتُ عليك فأرخِ عليك سترك، ابن آدم، إنك لا تحمل سخطي، ولا تستطيع انتقامي</b>»{2}. (١٥/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٣٣٢٥<span class="dash">-</span></span> عن أبي حازم، قال: قال رسول الله ﷺ: «<b>إن الله تعالى يقول: ابن آدم إن نازعك لسانك فيما حرّمتُ عليك فقد أعنتُك عليه بطبقتين فأطبِق، وإن نازعك بصرك إلى بعض ما حرّمتُ عليك فقد أعنتُك عليه بطبقتين فأطبِق، وإنْ نازعك فرجك إلى ما حرّمتُ عليك فقد أعنتُك عليه بطبقتين فأطبِق</b>»{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٤١٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن عساكر ٦٦/٢٢٩ مرسلًا.أخرجه الثعلبي ١٠/٢٠٩ مرسلًا.
