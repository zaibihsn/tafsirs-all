  69,38,""
  69,39,""
  69,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾</span> الآيات - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال الوليد بن المُغيرة: إنّ محمدًا ساحر. فقال أبو جهل بن هشام: بل هو مجنون. فقال عُقبة بن أبي مُعَيْط: بل هو شاعر. وقال النّضر: كاهن. وقال أُبَيّ: كذّاب. فبرّأه الله من قولهم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فأَقسم الله بالخَلْق <span class="qpc-hafs">﴿إنَّهُ﴾</span> إنّ هذا القرآن <span class="qpc-hafs">﴿لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span> على الله، يعني: جبريل ﵇ عن قول الله تعالى{1}<span class=comment-ref>٦٧٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٦) هذا القول، و<span class="comment-type-4">ذكر</span> قولًا آخر بأنّ «الرسول» هو محمد ﷺ، وأنه أُضيف القول إليه من حيث تلاه وبلغه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٦/٣٩١-٣٩٢) -<span class="mustanad">مستندًا إلى السياق</span>- أنّ «الرسول» هو محمد ﷺ، فقال: «فهذا محمد كما يدلّ عليه الكلام كلّه، وهذا قول عامة العلماء».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا هُوَ بِقَوۡلِ شَاعِرࣲۚ قَلِیلࣰا مَّا تُؤۡمِنُونَ ۝٤١ وَلَا بِقَوۡلِ كَاهِنࣲۚ قَلِیلࣰا مَّا تَذَكَّرُونَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما هُوَ بِقَوْلِ شاعِرٍ﴾</span> قال: طهّره الله وعَصمه، <span class="qpc-hafs">﴿ولا بِقَوْلِ كاهِنٍ﴾</span> قال: طهّره مِن الكهانة وعَصمه منها{1}. (١٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما هُوَ بِقَوْلِ شاعِرٍ﴾</span> لقول عُتبة، وقول أبي جهل، <span class="qpc-hafs">﴿قَلِيلًا ما تُؤْمِنُونَ﴾</span> يعني: قليلًا ما تُصدِّقون بالقرآن، يعني بالقليل: أنهم لا يؤمنون، ثم قال: <span class="qpc-hafs">﴿ولا﴾</span> هو، يعني: القرآن <span class="qpc-hafs">﴿بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ﴾</span> فتَعتبرون{2}<span class=comment-ref>٦٧٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٧) أنّ <span class="qpc-hafs">﴿ما﴾</span> في قوله: <span class="qpc-hafs">﴿قليلا ما تؤمنون﴾</span> <b>يحتمل</b> أن تكون نافية فينتفي إيمانهم البتة، و<b>يحتمل</b> أن تكون مصدرية ويَتصف بالقلة إمّا الإيمان وإمّا العدد الذي يؤمنون، ثم قال: «فعلى اتصاف إيمانهم بالقلّة فهو الإيمان اللغوي؛ لأنهم قد صَدّقوا بأشياء يسيرة لا تُغني عنهم شيئًا؛ إذ كانوا يُصدِّقون أنّ الخير والصلة والعفاف الذي كان يأمر به رسول الله ﷺ هو حقٌّ صواب».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,42,""
  69,41,""
  69,42,""
  69,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَنزِیلࣱ مِّن رَّبِّ ٱلۡعَـٰلَمِینَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأَكذبهم الله، فقال: بل القرآن <span class="qpc-hafs">﴿تَنْزِيلٌ مِن رَبِّ العالَمِينَ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ تَقَوَّلَ عَلَیۡنَا بَعۡضَ ٱلۡأَقَاوِیلِ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٨<span class="dash">-</span></span> عن يزيد بن عامر السّوائي: أنهم بينما هم يطوفون بالطّاغية إذ سمعوا مُتكلّمًا وهو يقول: <span class="qpc-hafs">﴿ولَوْ تَقَوَّلَ عَلَيْنا بَعْضَ الأَقاوِيلِ لَأَخَذْنا مِنهُ بِاليَمِينِ ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span> [الحاقة:٤٤-٤٦]، ففَزعنا لذلك، وقلنا: ما هذا الكلام الذي لا نَعرفه؟! فنَظرنا، فإذا النبي ﷺ مُنطلقًا{1}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ تَقَوَّلَ عَلَيْنا﴾</span> محمدٌ شيئًا منه <span class="qpc-hafs">﴿بَعْضَ الأَقاوِيلِ﴾</span> يعني: مِن تلقاء نفسه ما لم نَقُل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الأوسط (٨٩٢٢).تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَأَخَذۡنَا مِنۡهُ بِٱلۡیَمِینِ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span>، قال: بقدرة{1}<span class=comment-ref>٦٧٧٧</span>. (١٤/٦٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٧</span> ساق <u>ابنُ عطية</u> (٨/٣٩٧) قول ابن عباس، ثم <span class="comment-type-4">علَّق</span> بقوله: «ومعناه: لَنِلنا منه عقابه بقوة منا، أو يكون المعنى: لنَزعنا قوته». ثم <span class="comment-type-4">ذكر</span> قولًا آخر وهو أنها عبارة عن الهوان، كما يقال لمن يُسجن أو يقام لعقوبة: قد أُخذ بيده وبيمينه.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٣/١٩٢).</div></p><p><div></p><p><p><span class="item-no">٧٨٦٣١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span> لقَطعنا يده اليمنى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٢<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span>، في قوله: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span>، قال: بالحق{3}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span> يقول: لانتقمنا منه بالحق، كقوله: <span class="qpc-hafs">﴿تَأْتُونَنا عَنِ اليَمِينِ﴾</span> [الصافات:٢٨] يعني: مِن قِبَل الحق، بأنكم على الحق{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٣-.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الوتين: عِرْقُ القلب{1}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>، قال: نِياط القلب{2}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿الوَتِينَ﴾</span>، قال: هو حَبل القلب الذي في الظهر{3}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء بن السّائِب- في قوله: <span class="qpc-hafs">﴿ثم لقطعنا منه الوتين﴾</span>، قال: نِياطُ القلب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: الوَتِين: الحَبل الذي في الظهر{5}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>: وتِين القلب؛ وهو عِرق يكون في القلب، فإذا قُطع مات الإنسان{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الوَتِين: نِياط القلب{7}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: إذا انقطع الوَتِين، لا إن جاع عِرق، ولا إن شَبع عِرق{8}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>، قال: كُنّا نُحدَّث أنه حَبل القلب{9}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله: <span class="qpc-hafs">﴿لقطعنا منه الوتين﴾</span>، قال: نِياط القلب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span> يعني: عِرق يكون في القلب، وهو نِياط القلب، وإذا انقطع مات صاحبه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>، قال: الوَتِين: نِياط القلب، الذي القلب مُتعلّق به{6}<span class=comment-ref>٦٧٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/١٩٢) أنّ هذا القول قول جميع أهل اللغة.</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٤٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق حُصين-: إذا احتُضر الإنسان أتاه مَلَك الموت، فغَمز وتِينه، فإذا انقطع الوَتِين خرج روحُه، فهناك حين يَشخَص بصرُه، وتَتبعه روحه{13}. (١٤/٦٨٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٤. وعزاه السيوطي إلى ابن المنذر.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٤٧، والفتح ٨/٦٦٤-، وابن جرير ٢٣/٢٤٤، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٤٧، والفتح ٨/٦٦٤-، والحاكم ٢/٥٠١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الحاكم ٢/٥٠١، وابن جرير ٢٣/٢٤٤ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٣ (٢٢٩١).أخرجه ابن جرير ٢٣/٢٤٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٤٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٤٢٥.أخرجه ابن جرير ٢٣/٢٤٥.عزاه السيوطي إلى ابن أبي حاتم.
  69,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا مِنكُم مِّنۡ أَحَدٍ عَنۡهُ حَـٰجِزِینَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما مِنكُمْ مِن أحَدٍ عَنْهُ حاجِزِينَ﴾</span> ليس أحد منكم يَحجز الرّبّ عن ذلك{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَتَذۡكِرَةࣱ لِّلۡمُتَّقِینَ ۝٤٨ وَإِنَّا لَنَعۡلَمُ أَنَّ مِنكُم مُّكَذِّبِینَ ۝٤٩ وَإِنَّهُۥ لَحَسۡرَةٌ عَلَى ٱلۡكَـٰفِرِینَ ۝٥٠ وَإِنَّهُۥ لَحَقُّ ٱلۡیَقِینِ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإنَّهُ لَتَذْكِرَةٌ لِلْمُتَّقِينَ﴾</span> يعني: هذا القرآن، <span class="qpc-hafs">﴿وإنَّهُ لَحَسْرَةٌ عَلى الكافِرِينَ﴾</span> قال: ذاكم يوم القيامة{1}<span class=comment-ref>٦٧٧٩</span>. (١٤/٦٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٩</span> على قول قتادة فالضمير في قوله: <span class="qpc-hafs">﴿وإنه لحسرة﴾</span> عائد على التكذيب.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١٢٣) <b>احتمالًا آخر</b> بعوْد الضمير على القرآن، أي: وإنّ القرآن والإيمان به لحسرة في نفس الأمر على الكافرين. ثم قال: «<span class="mustanad">كما قال</span>: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين لا يؤمنون به﴾</span> [الشعراء:٢٠٠-٢٠١]».</div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّهُ﴾</span> وإنّ هذا القرآن <span class="qpc-hafs">﴿لَتَذْكِرَةٌ لِلْمُتَّقِينَ وإنّا لَنَعْلَمُ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿أنَّ مِنكُمْ مُكَذِّبِينَ وإنَّهُ لَحَسْرَةٌ عَلى الكافِرِينَ﴾</span> يوم القيامة، <span class="qpc-hafs">﴿وإنَّهُ﴾</span> وإنّ هذا القرآن <span class="qpc-hafs">﴿لَحَقُّ اليَقِينِ﴾</span> أنّه مِن الله تعالى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وإنَّهُ لَتَذْكِرَةٌ﴾</span>، <span class="qpc-hafs">﴿وإنَّهُ لَحَسْرَةٌ﴾</span>، <span class="qpc-hafs">﴿وإنَّهُ لَحَقُّ اليَقِينِ﴾</span>، قال: القرآن{3}<span class=comment-ref>٦٧٨٠</span>. (١٤/٦٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٨) أنّ الضمير في قوله: <span class="qpc-hafs">﴿وإنه لتذكرة﴾</span> <b>قيل</b> بعوْده على القرآن، و<b>قيل</b> بعوْده على النبي محمد ﷺ.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢٥-٤٢٦.عزاه السيوطي إلى ابن المنذر.
