  37,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٤٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، أنه كان يقرأ: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>{1}. (١٢/٤٠٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٤٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٢٢<span class="dash">-</span></span> عن شدّاد بن أوس، قال: قال النبي ﷺ: «<b>إذا جمع الله الأولين والآخرين ببقيع واحد؛ ينفذهم البصر، ويُسمعهم الداعي، قال: أنا خير شريك، كلُّ عملٍ كان عُمِل لي في دار الدنيا كان لي فيه شريك فأنا أدعه اليوم، ولا أقبل اليوم إلا خالصًا»</b>. ثم قرأ: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، <span class="qpc-hafs">﴿فَمَن كانَ يَرْجُو لِقاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلًا صالِحًا ولا يُشْرِكْ بِعِبادَةِ رَبِّهِ أحَدًا﴾</span> [الكهف:١١٠]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، قال: هذه ثنية الله{3}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى المؤمنين، فقال: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> بالتوحيد، لا يذوقون العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، استثنى المؤمنين، وهم مِن كل ألفٍ واحدٌ{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور.</p><p>و<span class="qpc-hafs">﴿المُخْلَصِينَ﴾</span> بفتح اللام قراءة متواترة، قرأ بها نافع، وعاصم، وحمزة، والكسائي، وأبو جعفر، وخلف، وقرأ بقية العشرة: ‹المُخْلِصِينَ› بكسر اللام. انظر: النشر ٢/٢٩٥، والإتحاف ص٤٧٣.أخرجه الطبراني في الكبير ٧/٢٩٠ (٧١٦٧)، والشجري في ترتيب الأمالي الخميسية ٢/٣٠٦ (٢٥٤٤)، من طريق حميد الشامي، عن محمود بن الربيع، عن شداد به.</p><p>إسناده ضعيف؛ لجهالة حميد الشامي، وهو ابن أبي حميد الحمصي، قال عنه ابن حجر في التقريب (١٥٦٧): «مجهول».أخرجه ابن جرير ١٩/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
  37,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ لَهُمۡ رِزۡقࣱ مَّعۡلُومࣱ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span>، قال: في الجنة{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span>، قال: في الجنة{2}. (١٢/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأخبر ما أعدَّ لهم، فقال -جلَّ وعز-: <span class="qpc-hafs">﴿أُولئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span>، يعني بالمعلوم: حين يشتهونه يُؤتون به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span> الجنة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٣٠.تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
  37,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَ ٰ⁠كِهُ وَهُم مُّكۡرَمُونَ ۝٤٢ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝٤٣ عَلَىٰ سُرُرࣲ مُّتَقَـٰبِلِینَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم بيَّن الرِّزق، فقال -تبارك وتعالى-: <span class="qpc-hafs">﴿فَواكِهُ وهُمْ مُكْرَمُونَ * فِي جَنّاتِ النَّعِيمِ * عَلى سُرُرٍ مُتَقابِلِينَ﴾</span> في الزِّيارة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَواكِهُ وهُمْ مُكْرَمُونَ * فِي جَنّاتِ النَّعِيمِ * عَلى سُرُرٍ مُتَقابِلِينَ﴾</span> والسرر مرمولة بالذهب، وبقضبان اللؤلؤ الرطب، <span class="qpc-hafs">﴿مُتَقابِلِينَ﴾</span> لا ينظر بعضهم إلى قفا بعض{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
