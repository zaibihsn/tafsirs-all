  37,154,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا لَكُمۡ كَیۡفَ تَحۡكُمُونَ ۝١٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٠٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ما لَكُمْ كَيْفَ تَحْكُمُونَ﴾</span>: إنّ هذا لَحُكمٌ جائِر{1}. (١٢/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٠٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما لَكُمْ كَيْفَ تَحْكُمُونَ﴾</span>، يعني: كيف تقضون الجَوْر؛ حين تزعمون أنّ لله ﷿ البنات ولكم البنون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٢.
  37,155,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَا تَذَكَّرُونَ ۝١٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٠٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَلا تَذَكَّرُون﴾</span> أنّه لا يختار البنات على البنين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٢٢.
  37,156,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ لَكُمۡ سُلۡطَـٰنࣱ مُّبِینࣱ ۝١٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٠٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أمْ لَكُمْ سُلْطانٌ مُبِينٌ﴾</span>: أي: عذر مبين{1}. (١٢/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٠٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿سُلْطانٌ مُبِينٌ﴾</span>، يقول: حجة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٠٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ لَكُمْ﴾</span> بما تقولون <span class="qpc-hafs">﴿سُلْطانٌ مُبِينٌ﴾</span> كتاب مِن الله ﷿ أن الملائكة بنات الله، <span class="qpc-hafs">﴿فَأْتُوا بِكِتابِكُمْ إنْ كُنْتُمْ صادِقِينَ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٠٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أمْ لَكُمْ سُلْطانٌ مُبِينٌ﴾</span> حجة بينة، على الاستفهام{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٤٣. وعلَّقه يحيى بن سلام ٢/٨٤٦ بلفظ: يعني: أم لكم حجة بينة بأنّ مع الله شريكًا، فإنه ليس لكم حجة.تفسير مقاتل بن سليمان ٣/٦٢٢.تفسير يحيى بن سلام ٢/٨٤٦.
  37,157,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأۡتُوا۟ بِكِتَـٰبِكُمۡ إِن كُنتُمۡ صَـٰدِقِینَ ۝١٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٠٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَأْتُوا بِكِتابِكُم﴾</span> أي: بعُذركم؛ <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span>{1}. (١٢/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٠٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فَأْتُوا بِكِتابِكُمْ﴾</span>: أنّ هذا كذا؛ بأن له البنات ولكم البنون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٠٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَأْتُوا بِكِتابِكُمْ﴾</span> الذي فيه حجتكم؛ <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> أن الملائكة بنات الله، أي: ليس لهم بذلك حجة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٤٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٤٤.تفسير يحيى بن سلام ٢/٨٤٦.
  37,158,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ بَیۡنَهُۥ وَبَیۡنَ ٱلۡجِنَّةِ نَسَبࣰاۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٠٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: أُنزِلَت هذه الآيةُ في ثلاثة أحياء مِن قُريش{1}: سُلَيم، وخُزاعة، وجُهينة، <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> الآية{2}. (١٢/٤٨٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ بَیۡنَهُۥ وَبَیۡنَ ٱلۡجِنَّةِ نَسَبࣰاۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٠٩٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> قالوا لحي مِن الملائكة يُقال لهم الجن -ومنهم إبليس-: بنات الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: زعم أعداءُ الله أنه -تبارك وتعالى- هو وإبليس أخَوان{4}. (١٢/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٢<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> فجعلوا الملائكةَ بنات الله، فسمي الملائكة: جنًّا؛ لاجتنانهم عن الأبصار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: قال كفار قريش: الملائكة بنات الله. فقال لهم أبو بكر الصديق: فمَن أمهاتهم؟! فقالوا: بنات سروات الجن{6}، يحسبون أنهم خلقوا مما خلق منه إبليس{7}. (١٢/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>: الملائكة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق قيس بن سعد- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: بنات سراة الجن. قال: هم بنات -يعنون- الله ﷿{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، قال: إنهم سُموا: الجن؛ لأنهم كانوا على الجنان، والملائكة كلهم أجنة{10}. (١٢/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: قالوا: الملائكة بنات الله{11}. (١٢/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> أشركوا الشيطانَ في عبادة الله، فهو النسب الذي جعلوه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٠٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، قال: <span class="qpc-hafs">﴿الجِنَّةِ﴾</span>: الملائكة{13}. (١٢/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٠<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: قالوا: صاهر إلى كرام الجن{14}. (١٢/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: قد قالت اليهود: إنّ الله صاهر الجنَّ، فخرجت بينهما الملائكة{15}. (١٢/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>: قالوا: صاهر إلى الجن، والملائكة في الجن، فلذلك قالوا: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> يقول: جعلوا الملائكة بنات الله من الجن. وكذبوا أعداء الله، سبحان الله عما يصفون{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: الجنة: الملائكة، قالوا: هنَّ بنات الله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: قالوا -لعنهم الله-: بل تزوَّج مِن الجن، فخرج منها الملائكة، تعالى الله عن ذلك علوًّا كبيرًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلُوا﴾</span> ووصفوا <span class="qpc-hafs">﴿بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> بين الرب تعالى والملائكة، حين زعموا أنهم بنات الله ﷿{19}<span class=comment-ref>٥٥٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٢٤</span> قال <u>ابنُ عطية</u> (٧/٣١٥ بتصرف): «<span class="qpc-hafs">﴿الجنة﴾</span> على هذا القول تقع على الملائكة، سميت بذلك لأنها مستجنة، أي: مستترة».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ تيمية</u> (٥/٣٥٦).</div></p><p><div></p><p><p><span class="item-no">٦٦١١٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: بين الله وبين الجنة نسبًا؛ افتروا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span> وقال بعضهم: قال مشركو العرب: إنه صاهر الجن، وقال: الجن صنف من الملائكة، فكانت له منهم بنات{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ عَلِمَتِ ٱلۡجِنَّةُ إِنَّهُمۡ لَمُحۡضَرُونَ ۝١٥٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦١١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق قيس بن سعد- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا بَيْنَهُ وبَيْنَ الجِنَّةِ نَسَبًا﴾</span>، قال: بنات سراة الجن. قال: هم بنات -يعنون- الله ﷿. فأنزل الله ﷿: <span class="qpc-hafs">﴿عَلِمَتِ الجِنَّةُ إنَّهُمْ لَمُحْضَرُونَ﴾</span>، قال: محضرون العذاب{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١١٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي مودود- قال: قال المسلمون: لو أنّ لنا أمرًا نَبْتَدِرُه{23}. قال: فنزل عنه: <span class="qpc-hafs">﴿ولَقَدْ عَلِمَتِ الجِنَّةُ إنَّهُمْ لَمُحْضَرُونَ﴾</span>{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ عَلِمَتِ ٱلۡجِنَّةُ إِنَّهُمۡ لَمُحۡضَرُونَ ۝١٥٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦١٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمَتِ الجِنَّةُ إنَّهُمْ لَمُحْضَرُونَ﴾</span>، يقول: إنها ستحضر الحساب. قال: والجنة الملائكة{25}. (١٢/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>-من طريق معمر-، في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمَتِ الجِنَّةُ إنَّهُمْ لَمُحْضَرُونَ﴾</span>، قال: في النار{26}. (١٢/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ لَمُحْضَرُونَ﴾</span>: إنّ هؤلاء الذين قالوا هذا لمحضرون؛ لَمُعَذَّبون{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ عَلِمَتِ الجِنَّةُ إنَّهُمْ لَمُحْضَرُونَ﴾</span> لقد علِم ذلك الحيُّ مِن الملائكة، ومن قال: إنهم بنات الله <span class="qpc-hafs">﴿إنهم لمحضرون﴾</span> النار{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَقَدْ عَلِمَتِ الجِنَّةُ﴾</span> الجن <span class="qpc-hafs">﴿إنَّهُمْ لَمُحْضَرُونَ﴾</span> مُدْخَلون في النار{21}<span class=comment-ref>٥٥٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٢٥</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿ولَقَدْ عَلِمَتِ الجِنَّةُ إنَّهُمْ لَمُحْضَرُونَ﴾</span> على أقوال: <b>الأول</b>: أن المعنى: ولقد علمت الجنة إنهم لمُشْهَدون الحساب. و<b>الثاني</b>: أن المعنى: ولقد علمت الجنة أنّ قائلي هذا القول سيحضرون العذاب في النار.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٧/٣١٥) على القولين، فقال: «مَن جعل <span class="qpc-hafs">﴿الجنة﴾</span>: الشياطين؛ جعل العلامة في <span class="qpc-hafs">﴿عَلِمَت﴾</span> لها، والضمير في <span class="qpc-hafs">﴿إنهم﴾</span> عائد عليهم، أي: جعلوا الشياطين بنسب من الله، والشياطين تعلم ضد ذلك مِن أنها ستحضر أمر الله وثوابه وعقابه. ومَن جعل <span class="qpc-hafs">﴿الجنة﴾</span>: الملائكة؛ جعل الضمير في <span class="qpc-hafs">﴿إنهم﴾</span> للقائلين هذه المقالة، أي: علمت الملائكة أن هؤلاء الكفرة سيحضرون ثواب الله وعقابه. وقد يتداخل هذان القولان».</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (١٩/٦٤٦) القولَ الثانيَ -وهو قول السديّ- <span class="mustanad">استنادًا إلى نظائرها في السورة</span>، فقال: «أولى القولين في ذلك بالصواب قول مَن قال: إنهم لمحضرون العذاب. لأن سائر الآيات التي ذكر فيها الإحضار في هذه السورة إنما عني به: الإحضار في العذاب، فكذلك في هذا الموضع».</p><p>وظاهر كلام <u>ابن كثير</u> (١٢/٦٢) أنه <span class="comment-type-4">ذهب</span> إلى هذا أيضًا.</div></p></div>",footnotes:1:كذا ورد في مطبوعة الدر.عزاه السيوطي إلى جويبر.تفسير الثعلبي ٨/١٧٢، وتفسير البغوي ٤/٤٩.أخرجه ابن جرير ١٩/٦٤٤.تفسير الثعلبي ٨/١٧١-١٧٢.سروات الجن: أشرافهم. اللسان (سرو)تفسير مجاهد (٥٧١)، وأخرجه ابن جرير ١٩/٦٤٥، والبيهقي في شعب الإيمان (١٤١). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٤٥.أخرجه سفيان الثوري (٢٥٥).عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٨/١٧٢، وتفسير البغوي ٤/٤٩.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر،.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٨٤٦، وابن جرير ١٩/٦٤٥ بلفظ: قالت اليهود: إن الله تبارك وتعالى تزوج إلى الجن، فخرج منهما الملائكة، قال: سبحانه سبح نفسه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٥٧.أخرجه ابن جرير ١٩/٦٤٥.تفسير الثعلبي ٨/١٧٢، وتفسير البغوي ٤/٤٩.تفسير مقاتل بن سليمان ٣/٦٢٢.أخرجه ابن جرير ١٩/٦٤٦.تفسير يحيى بن سلام ٢/٨٤٦.أخرجه سفيان الثوري ١/٢٥٥.بَدَرْتُ إلى الشيءِ: أسْرَعْت. اللسان (بدر).أخرجه سفيان الثوري ١/٢٥٥.تفسير مجاهد (٥٧١)، وأخرجه ابن جرير ١٩/٦٤٦ دون قوله: وقال: الجنة: الملائكة. وعلَّقه يحيى بن سلام ٢/٨٤٦. وعزاه السيوطي إلى آدم بن أبي إياس، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، والبيهقي في شعب الإيمان.أخرجه عبد الرزاق ٢/١٥٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وعبد بن حميد.أخرجه ابن جرير ١٩/٦٤٦.تفسير مقاتل بن سليمان ٣/٦٢٢.تفسير يحيى بن سلام ٢/٨٤٦.
  37,159,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَ ٱللَّهِ عَمَّا یَصِفُونَ ۝١٥٩ إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝١٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦١٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>-من طريق معمر- في قوله: <span class="qpc-hafs">﴿سُبْحانَ اللَّهِ عَمّا يصِفُونَ﴾</span> قال: عما يكذبون، <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> قال: هذه ثنيا الله من الجن والإنس{1}. (١٢/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سُبْحانَ اللَّهِ عَمّا يَصِفُونَ﴾</span> عمّا يقولون من الكذب، <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> الموحدين فإنهم لا يحضرون النار{2}<span class=comment-ref>٥٥٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٢٦</span> ذكر <u>ابنُ عطية</u> (٧/٣١٥) قولين في الاستثناء الواقع في الآية، فقال: «نزَّه تعالى نفسه عما يصفه الناس ولا يليق به، ومن هذا استثنى العباد المخلصين؛ لأنهم يصفونه بصفاته العلى، <b>وقالت فرقة</b>: استثناهم من قوله: <span class="qpc-hafs">﴿إنهم لمحضرون﴾</span>. وهذا يصح على قول من رأى الجنة: الملائكة».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (١٩/٦٤٧) إلى الثاني <span class="mustanad">مستندًا لأقوال السلف</span>.</p><p>و<span class="comment-type-4">ذهب</span> <u>ابنُ القيم</u> (٢/٣٧٥)، و<span class="comment-type-4">كذا</span> <u>ابنُ كثير</u> (١٢/٦٢) إلى الأول، وهو <span class="comment-type-3">الظاهر</span> من كلام <u>ابن عطية</u>، ولم يذكروا مستندًا.</p><p>و<span class="comment-type-2">عقَّبَ</span> <u>ابنُ كثير</u> (١٢/٦٢) على كلام <u>ابن جرير</u> بقوله: «جعل ابنُ جرير هذا الاستثناء من قوله تعالى: <span class="qpc-hafs">﴿إنهم لمحضرون... إلا عباد الله المخلصين﴾</span>، وفي هذا الذي قاله نظر».</div></p><p><div></p><p><p><span class="item-no">٦٦١٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿سُبْحانَ اللَّهِ﴾</span> يُنَزِّه نفسه <span class="qpc-hafs">﴿عَمّا يَصِفُونَ﴾</span> يكذبون، <span class="qpc-hafs">﴿سُبْحانَ اللَّهِ عَمّا يَصِفُونَ﴾</span> يعني: الذين جعلوا بينه وبين الجنة نسبًا <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> المؤمنين. وهذا من مقاديم الكلام{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٥٧ دون قوله: «عما يكذبون». وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٢.تفسير يحيى بن سلام ٢/٨٤٦-٨٤٧.
