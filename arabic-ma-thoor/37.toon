  37,112,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبَشَّرۡنَـٰهُ بِإِسۡحَـٰقَ نَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝١١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا مِنَ الصّالِحِينَ﴾</span>، قال: إنما بُشِّر به نبيًّا حين فداه الله مِن الذبح، ولم تكن البشارة بالنبوة حين مولده{1}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ﴾</span>، قال: بشرى نبوة، بُشِّر به مرتين: حين وُلد، وحين نُبِّئَ{2}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا مِنَ الصّالِحِينَ﴾</span>، قال: بُشِّر إبراهيم بإسحاق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الذبيح إسحاق. قال: وقوله: <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا مِنَ الصّالِحِينَ﴾</span>، قال: بُشِّر بنُبُوَّته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق داود- <span class="qpc-hafs">﴿وبشرناه بإسحاق﴾</span>، قال: بنبوة إسحاق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا﴾</span>، قال: بُشِّر به بعد ذلك نبيًّا، بعدما كان هذا مِن أمره، لَمّا جاد لله بنفسه{6}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا مِنَ الصّالِحِينَ﴾</span>، قال: بنبوته{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا مِنَ الصّالِحِينَ﴾</span>، يقول: وبشّرنا إبراهيم بنبوة إسحاق بعد العفو عنه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وبَشَّرْناهُ بِإسْحاقَ نَبِيًّا﴾</span>، أي: وبشرناه به نبيًّا، أي: بأنّه نبي{9}<span class=comment-ref>٥٥١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥١٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٣٠٥): «من قال: إن الذبيح هو إسماعيل. جعل هذه البشارة بولادة إسحاق، وهي البشارة المترددة في غير ما سورة. ومَن جعل الذبيح إسحاق جعل هذه البشارة بنفس النبوءة فقط».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٠٧ بنحوه.أخرجه ابن جرير ١٩/٦٠٧، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٠-، والحاكم ٢/٥٥٧. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٦٠٨.أخرجه ابن جرير ١٩/٦٠٧.أخرجه إسحاق البستي ص٢١٠.أخرجه عبد الرزاق ٢/١٥٤ من طريق معمر بنحوه، وابن جرير ١٩/٦٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٠٨.تفسير مقاتل بن سليمان ٣/٦١٦.تفسير يحيى بن سلام ٢/٨٣٩.
  37,113,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبَـٰرَكۡنَا عَلَیۡهِ وَعَلَىٰۤ إِسۡحَـٰقَۚ وَمِن ذُرِّیَّتِهِمَا مُحۡسِنࣱ وَظَالِمࣱ لِّنَفۡسِهِۦ مُبِینࣱ ۝١١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وبارَكْنا عَلَيْهِ وعَلى إسْحاقَ ومِن ذُرِّيَّتِهِما مُحْسِنٌ وظالِمٌ لِنَفْسِهِ مُبِينٌ﴾</span>، أي: مؤمن وكافر{1}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٢٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿مُحْسِنٌ وظالِمٌ لِنَفْسِهِ مُبِينٌ﴾</span>، قال: المحسن: المطيع لله. والظالم لنفسه: العاصي لله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبارَكْنا عَلَيْهِ﴾</span> على إبراهيم، <span class="qpc-hafs">﴿وعَلى إسْحاقَ ومِن ذُرِّيَّتِهِما﴾</span> إبراهيم وإسحاق <span class="qpc-hafs">﴿مُحْسِنٌ﴾</span> مؤمن، <span class="qpc-hafs">﴿وظالِمٌ لِنَفْسِهِ مُبِينٌ﴾</span> يعني: المُشْرِك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وبارَكْنا عَلَيْهِ وعَلى إسْحاقَ ومِن ذُرِّيَّتِهِما مُحْسِنٌ﴾</span> مؤمن، <span class="qpc-hafs">﴿وظالِمٌ لِنَفْسِهِ مُبِينٌ﴾</span> مُشْرِك{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٠٨.تفسير مقاتل بن سليمان ٣/٦١٦.تفسير يحيى بن سلام ٢/٨٤٠.
  37,114,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَـٰرُونَ ۝١١٤ وَنَجَّیۡنَـٰهُمَا وَقَوۡمَهُمَا مِنَ ٱلۡكَرۡبِ ٱلۡعَظِیمِ ۝١١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ونَجَّيْناهُما وقَوْمَهُما مِنَ الكَرْبِ العَظِيمِ﴾</span>: أي: مِن آل فرعون{1}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ونَجَّيْناهُما وقَوْمَهُما مِنَ الكَرْبِ العَظِيمِ﴾</span>، قال: مِن الغَرَق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ مَنَنّا﴾</span> أنعمنا <span class="qpc-hafs">﴿عَلى مُوسى وهارُونَ﴾</span> بالنبوة، وهلاك عدوهما، <span class="qpc-hafs">﴿ونَجَّيْناهُما وقَوْمَهُما﴾</span> بني إسرائيل <span class="qpc-hafs">﴿مِنَ الكَرْبِ العَظِيمِ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولَقَدْ مَنَنّا عَلى مُوسى وهارُونَ﴾</span> بالنبوة، <span class="qpc-hafs">﴿ونَجَّيْناهُما وقَوْمَهُما مِنَ الكَرْبِ العَظِيمِ﴾</span> مِن فرعون وقومه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٠٩.تفسير مقاتل بن سليمان ٣/٦١٦.تفسير يحيى بن سلام ٢/٨٤٠.
  37,115,""
  37,113,""
  37,114,""
  37,115,""
  37,116,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَصَرۡنَـٰهُمۡ فَكَانُوا۟ هُمُ ٱلۡغَـٰلِبِینَ ۝١١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونَصَرْناهُمْ﴾</span> على عدُوِّهم؛ <span class="qpc-hafs">﴿فَكانُوا هُمُ الغالِبِينَ﴾</span> لفرعون وقومه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ونَصَرْناهُمْ﴾</span> على آل فرعون؛ <span class="qpc-hafs">﴿فَكانُوا هُمُ الغالِبِينَ﴾</span> وكانا شريكين في الرسالة، وكان موسى أفضلهما{2}<span class=comment-ref>٥٥١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥١٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٣٠٦) أن الضمير في قوله: <span class="qpc-hafs">﴿نَصَرْناهُمْ﴾</span> عائد على الجماعة المتقدم ذكرها، وهم موسى وهارون وقومهما، ثم أورد <b>قولًا</b> آخر، فقال: «وقال قوم: أراد: موسى وهارون، ولكن أخرج ضميرهما مخرج الجمع تفخيمًا، <span class="mustanad">وهذا مما تفعله العرب</span>، تكني عمَّن تُعَظِّم بكناية الجمع».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦١٦.تفسير يحيى بن سلام ٢/٨٤٠.
  37,117,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَءَاتَیۡنَـٰهُمَا ٱلۡكِتَـٰبَ ٱلۡمُسۡتَبِینَ ۝١١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وآتَيْناهُما الكِتابَ المُسْتَبِينَ﴾</span>، قال: التوراة{1}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتَيْناهُما الكِتابَ﴾</span> يقول: أعطيناهما التوراة <span class="qpc-hafs">﴿المُسْتَبِينَ﴾</span> يعني: بَيّنٌ ما فيه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وآتَيْناهُما الكِتابَ المُسْتَبِينَ﴾</span> التوراة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٦.تفسير يحيى بن سلام ٢/٨٤٠.
  37,118,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهَدَیۡنَـٰهُمَا ٱلصِّرَ ٰ⁠طَ ٱلۡمُسۡتَقِیمَ ۝١١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وهَدَيْناهُما الصِّراطَ المُسْتَقِيمَ﴾</span>، قال: الإسلام{1}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهَدَيْناهُما الصِّراطَ المُسْتَقِيمَ﴾</span> دين الإسلام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهَدَيْناهُما الصِّراطَ المُسْتَقِيمَ﴾</span> الإسلام؛ الطريق إلى الجنة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٧.تفسير يحيى بن سلام ٢/٨٤٠.
  37,119,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَرَكۡنَا عَلَیۡهِمَا فِی ٱلۡـَٔاخِرِینَ ۝١١٩ سَلَـٰمٌ عَلَىٰ مُوسَىٰ وَهَـٰرُونَ ۝١٢٠ إِنَّا كَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡمُحۡسِنِینَ ۝١٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٨٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِما فِي الآخِرِينَ﴾</span>، قال: أبقى اللهُ عليهما الثناءَ الحسنَ في الآخرين{1}. (١٢/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِما فِي الآخِرِينَ﴾</span> أبقينا مِن بعدهما الثناءَ الحسن يُقال لهما بعدهما، وذلك قوله ﷿: <span class="qpc-hafs">﴿سَلامٌ عَلى مُوسى وهارُونَ﴾</span> يعني بالسلام: الثناء الحسن، <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾</span> هكذا نجزي كلَّ مَن أحسن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٨٤٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِما﴾</span> أي: وأبقينا عليهما <span class="qpc-hafs">﴿فِي الآخِرِينَ﴾</span> الثناء الحسن{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٧.تفسير يحيى بن سلام ٢/٨٤٠.
