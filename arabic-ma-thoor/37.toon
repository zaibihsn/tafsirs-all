  37,164,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا مِنَّاۤ إِلَّا لَهُۥ مَقَامࣱ مَّعۡلُومࣱ ۝١٦٤﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٦١٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، قال: الملائكة{1}. (١٢/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٤٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، قال: الملائكة؛ ما في السماء موضع إلا عليه مَلَكٌ إما ساجدًا أو قائمًا حتى تقوم الساعة{2}. (١٢/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-، مثله{3}. (١٢/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، قال: ذاك قول جبريل ﵇{4}. (١٢/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: كانوا يُصَلُّون الرجالُ والنساءُ جميعًا، حتى نزلت: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span> فتقدم الرجال وتأخَّر النساء{5}. (١٢/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>، قال: هذا قول الملائكة، يُنَزِّهون اللهَ عما قالت اليهودُ، حيث جعلوا بينه وبين الجنة نسبًا، ويخبرون بمكانهم في السموات في صفوفهم وتسبيحهم، وهو قوله في أول السورة: <span class="qpc-hafs">﴿والصّافّاتِ صَفًّا﴾</span>، ليس في السموات موضع شبر إلا وعليه ملك قائم، أو راكع، أو ساجد{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، قال: الملائكة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، يعني: في القربة والمشاهدة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، يعني: مكان معلوم يعبد الله فيه، وهم الملائكة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>، قال: هؤلاء الملائكة{7}<span class=comment-ref>٥٥٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٢٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٣١٦) عند قوله تعالى: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</span>: «هذا يؤيد أن <span class="qpc-hafs">﴿الجِنَّة﴾</span> أراد بها: الملائكة،كأنه قال: ولقد علمت كذا، وإن قولنا لكذا، وتقدير الكلام: وما منا ملك».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٥٨ عن قتادة، وأخرجه ابن جرير ١٩/٦٥٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو الشيخ في العظمة (٥٠٨).تفسير مجاهد (٥٧١) مختصرًا، وأخرجه ابن جرير ١٩/٦٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٨٤٧.أخرجه ابن جرير ١٩/٦٥١.تفسير الثعلبي ٨/١٧٢، وتفسير البغوي ٤/٥٠.علقه يحيى بن سلام ٢/٨٤٧.أخرجه ابن جرير ١٩/٦٥١.
  37,165,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَنَحۡنُ ٱلصَّاۤفُّونَ ۝١٦٥ وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ۝١٦٦﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦١٥٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن مالك</span>، قال: كان الناس يُصَلُّون مُتَبَدِّدين{1}؛ فأنزل الله: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span> فأمرهم أن يَصفُّوا{2}. (١٢/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٥٩<span class="dash">-</span></span> عن <span class="name-2">الوليد بن عبد الله بن أبي مغيث</span> -من طريق ابن جريج- قال: كانوا لا يصُفُّون في الصلاة حتى نزلت: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span>{2}. (١٢/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، قال: حُدِّثتُ: أنهم كانوا لا يصُفُّون حتى نزلت: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّون﴾</span>{4}. (١٢/٤٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَنَحۡنُ ٱلصَّاۤفُّونَ ۝١٦٥ وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ۝١٦٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦١٦١<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، قالت: قال رسول الله ﷺ: «<b>ما في السماء موضِعٌ قدمٍ إلا عليه مَلَك ساجد أو قائم</b>». وذلك قول الملائكة: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ﴾</span>{5}. (١٢/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٢<span class="dash">-</span></span> عن أنس، أنّ النبي ﷺ كان إذا قام إلى الصلاة قال: «<b>استووا وتراصُّوا، يريدُ الله بكم هَدْي الملائكة</b>». وقرأ رسول الله ﷺ: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>{6}. (١٢/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٣<span class="dash">-</span></span> عن العلاء بن سعد، أنّ رسول الله ﷺ قال يومًا لجلسائه: «<b>أطَّت</b>{7} <b>السماء، وحُقَّ لها أن تئط؛ ليس منها موضع قدم إلا عليه ملك راكع أو ساجد</b>». ثم قرأ: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>{8}. (١٢/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٤<span class="dash">-</span></span> عن الحسن البصري، قال: كانت أول صلاة صلاها رسول الله ﷺ الظهر، فأتاه جبريل، فقال: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>. فقام جبريل بين يديه، ورسول الله ﷺ خلفه، ثم صفَّ الناسُ خلفه، والنساءُ خلف الرجال، فصلى بهم الظهر أربعًا، حتى إذا كان عند العصر قام جبريل ففعل مثلها، ثم جاءه حين غربت الشمس فصلى بهم ثلاثًا، يقرأ في الركعتين الأوليين يجهر فيهما، ولم يُسمع في الثالثة، حتى إذا كان عند العشاء وغاب الشفق جاءه جبريل فصلى بالناس أربع ركعات، يجهر بالقراءة في ركعتين، حتى إذا أصبح ليلته أتاه فصلى ركعتين يجهر فيهما، ويطيل القراءة{9}. (١٢/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٥<span class="dash">-</span></span> عن أبي نضرة، قال: كان <span class="name-1">عمر بن الخطاب</span> إذا أقيمت الصلاة قال: استووا، تقدَّم يا فلان، تأخَّر يا فلان، أقيموا صفوفكم، يريد الله بكم هَدْيَ الملائكة. ثم يتلو: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>{10}. (١٢/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السُّدِّيّ- قال: إنّ مِن السماوات لَسماء ما فيها موضع شِبْر إلا وعليه جبهةُ ملَك أو قدماه قائمًا أو ساجدًا. ثم قرأ: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>{11}. (١٢/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span> قال: الملائكة، <span class="qpc-hafs">﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span> قال: الملائكة{12}. (١٢/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span> ما في السماوات موضع شبر إلا وعليه مَلَك مُصَلٍّ أو مُسَبِّح{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وإنا لنحن الصافون﴾</span>: الملائكة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span> قال: أطَّت السماء، وما تلام أن تئط؛ إن في السماء لسماء ما فيها موضع شبر إلا عليه جبهة ملك أو قدماه{15}. (١٢/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</span> [المزمل:٢٠]؛ قال جبريل: أشَقَّ ذلك عليكم؟ قال: «<b>نعم</b>». قال: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span>{16}. (١٢/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span>، قال: الملائكة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span> قال: صفوف في السماء، <span class="qpc-hafs">﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span> أي: المصلون، هذا قول الملائكة. قال: يُثنون بمكانهم من العبادة{18}. (١٢/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span>، قال: للصلاة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّون﴾</span> صفوف الملائكة في السماء للعبادة كصفوف الناس في الأرض{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ﴾</span> يعني: صفوف الملائكة في السموات في الصلاة، <span class="qpc-hafs">﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</span> يعني: المصلين. يخبر جبريلُ النبيَّ ﷺ بعبادتهم لربهم ﷿، فكيف يعبدهم كفار مكة؟!{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</span>، قال: الملائكة، هذا كله لهم{22}<span class=comment-ref>٥٥٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٢٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٣١٦) أن <span class="qpc-hafs">﴿المُسَبِّحُونَ﴾</span> <b>يحتمل</b> أن يريد به: الصلاة، و<b>يحتمل</b> أن يريد به: قول: سبحان الله.</div></p><p><div></p><p><p><span class="item-no">٦٦١٧٨<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وإنا لنحن الصافون﴾</span>، قال: الملائكة قالت: نحن الصافون؛ يعني: صُفَّةً{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَنَحۡنُ ٱلصَّاۤفُّونَ ۝١٦٥ وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ۝١٦٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٦١٧٩<span class="dash">-</span></span> عن أبي ذرٍّ، قال: قال رسول الله ﷺ: «<b>إنِّي أرى ما لا ترون، وأسمع ما لا تسمعون، إنّ السماء أطَّت، وحُقّ لها أن تئط؛ ما فيها موضع أربع أصابع إلا وملك واضِعٌ جبهتَه ساجدًا لله</b>»{24}. (١٢/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٠<span class="dash">-</span></span> عن جابر بن سمرة، قال: قال رسول الله ﷺ: «<b>ألا تَصُفُّونَ كَما تَصُفُّ الملائكةُ عند ربها</b>؟!». فقلنا: وكيف تَصُفُّ الملائكة عند ربها؟ قال: «<b>يُتِمُّون الصفوف الأُوَل، ويتراصُّون في الصف</b>»{25}. (١٢/٤٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨١<span class="dash">-</span></span> عن حذيفة، قال: قال رسول الله ﷺ: «<b>فُضِّلنا على الناس بثلاث: جُعلت صفوفنا كصفوف الملائكة، وجُعلت لنا الأرض كلها مسجدًا، وجُعلت تربتها لنا طهورًا إذا لم نجد الماء</b>»{26}. (١٢/٤٩١)</p></p><p></div></p></div>",footnotes:1:متبددين: متفرقين. التاج (بدد).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق في المصنف (٢٤٢٣). وعزاه السيوطي إلى ابن المنذر.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/٢٦٠ (٢٥٣)، وأبو الشيخ الأصبهاني في العظمة ٣/٩٨٤-٩٨٥ (٥٠٨)، وابن جرير ١٩/٦٥١-٦٥٢. وفيه أبو معاذ الفضل بن خالد النحوي.</p><p>قال ابن كثير في تفسيره ٨/٢٧١: «وهذا مرفوع غريب جدًّا». وقال الألباني في الصحيحة ٣/٤٩ (١٠٥٩): «هذا إسناد حسن في الشواهد، رجاله ثقات غير الفضل هذا، فقد ترجمه ابن أبي حاتم (٣/٢/٦١) من رواية ثقتين عنه، ولم يذكر فيه جرحًا ولا تعديلًا، ثم روى من طريق مسلم بن صبيح عن أبي الضحى عن مسروق عن عبد الله بن مسعود ﵁ قال: فذكره موقوفًا عليه باختصار، وهو في حكم المرفوع، وإسناده صحيح».عزاه السيوطي إلى ابن مردويه.أطَّت: الأطيط صوت الأقتاب، أي: أن كثرة ما فيها من الملائكة قد أثقلها حتى أطَّت. النهاية (أطط).أخرجه محمد بن نصر في كتاب تعظيم قدر الصلاة ١/٢٦١-٢٦٢ (٢٥٥)، وابن عساكر في تاريخه ٥٢/٣٨١.</p><p>قال ابن كثير ٨/٢٧١: «وهذا إسناد غريب جدًّا».أخرجه عبد الرزاق في المصنف (١٧٧١).أخرجه ابن جرير ١٩/٦٥٣ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٩-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٥٨ من طريق مسروق، وابن جرير ١٩/٦٥٤ بنحوه، والطبراني (٩٠٤٢)، والبيهقي في شعب الإيمان (١٥٩). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد بن حميد -كما في التغليق ٣/٤٩٤-، وأخرجه ابن جرير ١٩/٦٥٤ من طريق عطية العوفي بلفظ: الملائكة صافون تسبح لله ﷿.تفسير الثعلبي ٨/١٧٢.أخرجه إسحاق البستي ص٢٢٤.عزاه السيوطي إلى عبد بن حميد.أخرجه محمد بن نصر في مختصر قيام الليل (٥).أخرجه عبد الرزاق ٢/١٥٨، وابن جرير ١٩/٦٥٤ من طريق أبي هلال.أخرجه ابن جرير ١٩/٦٥٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٤.تفسير البغوي ٤/٥٠.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٥.أخرجه إسحاق البستي ص٢٢٤.أخرجه أحمد ٣٥/٤٠٥-٤٠٦ (٢١٥١٦)، والترمذي ٤/٣٥١-٣٥٢ (٢٤٦٥)، وابن ماجه ٥/٢٨٣ (٤١٩٠)، والحاكم ٤/٥٨٧ (٨٦٣٣)، ٤/٦٢٣ (٨٧٢٦).</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وأورده الألباني في الصحيحة ٤/٢٩٩ (١٧٢٢).أخرجه مسلم ١/٣٢٢ (٤٣٠).أخرجه مسلم ١/٣٧١ (٥٢٢). وأورده الثعلبي ٣/٣١٧.</p><p><b>وقد أورد السيوطي بعد تفسير الآيات ١٢/٤٩١-٤٩٣ آثارًا عن تسوية الصفوف في الصلاة وحكمها.</b>
  37,166,""
  37,165,""
  37,166,""
  37,167,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن كَانُوا۟ لَیَقُولُونَ ۝١٦٧ لَوۡ أَنَّ عِندَنَا ذِكۡرࣰا مِّنَ ٱلۡأَوَّلِینَ ۝١٦٨ لَكُنَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝١٦٩ فَكَفَرُوا۟ بِهِۦۖ فَسَوۡفَ یَعۡلَمُونَ ۝١٧٠﴾</span> - نزول الآيات، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٦١٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span> الآيات، قال: لما جاء المشركين من أهل مكة ذِكرُ الأولين وعِلْمُ الآخرين؛ كفروا بالكتاب، <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span>{1}. (١٢/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ * لَكُنّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>: هذا قول مشركي أهل مكة، فلمّا جاءهم ذِكر الأولين وعلم الآخرين كفروا به فسوف يعلمون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span>، قال: قول الناس، فلما جاءهم ما عرفوا كفروا به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ﴾</span>، قال: قالت هذه الأمة ذلك قبل أن يُبعث محمد ﷺ، فلما جاءهم محمد ﷺ كفروا به، <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span>{4}. (١٢/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٦<span class="dash">-</span></span> عن أبي هلال، أنّه بلغه: أنّ قريشًا كانت تقول: لو أنّ الله بعث مِنّا نبيًّا ما كانت أمة من الأمم أطوع لخالقها، ولا أسمع لنبيها، ولا أشد تمسُّكًا بكتابها مِنّا. فأنزل الله: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span>، <span class="qpc-hafs">﴿لَوْ أنّا أُنْزِلَ عَلَيْنا الكِتابُ لَكُنّا أهْدى مِنهُمْ﴾</span> [الأنعام:١٥٧]، <span class="qpc-hafs">﴿وأَقْسَمُوا بِاللَّهِ جَهْدَ أيْمانِهِمْ لَئِنْ جاءَهُمْ نَذِيرٌ لَيَكُونُنَّ أهْدى مِن إحْدى الأُمَمِ﴾</span> [فاطر:٤٢]، وكانت اليهود تستفتح به على الأنصار فيقولون: إنّا نجد نبيًّا يَخْرُج{5}. (١٢/ ٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ذِكْرًا مِنَ الأَوَّلِينَ﴾</span>، قال: هؤلاء ناس من مشركي العرب قالوا: لو أنّ عندنا كتابًا من كتب الأولين، أو جاءنا علم من علم الأولين. قال: قد جاءكم محمد بذلك، <span class="qpc-hafs">﴿فَكَفَرُوا بِهِ فَسَوْفَ يَعْلَمُونَ﴾</span> يقول: قد جاءكم محمد بذلك، فكفروا بالقرآن وبما جاء به محمد ﵇{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span>، قال: قول أهل الشرك من أهل مكة، فلما جاءهم ذِكر الأولين وعلم الآخرين كفروا به{7}. (١٢/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ﴾</span> كفار مكة: <span class="qpc-hafs">﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span> خبر الأمم الخالية كيف أهلكوا وما كان مِن أمرهم؛ <span class="qpc-hafs">﴿لَكُنّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> بالتوحيد. نزلت في الملأ من قريش، فقصَّ الله ﷿ عليهم خبر الأولين، وعلم الآخرين، <span class="qpc-hafs">﴿فَكَفَرُوا بِهِ﴾</span> بالقرآن، <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span> هذا وعيد، يعني: القتل ببدر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: رجع الحديثُ إلى الأولين أهل الشرك: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وإنْ كانُوا لَيَقُولُونَ﴾</span> يعني: قريشًا: <span class="qpc-hafs">﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</span> مثل كتاب موسى وعيسى؛ <span class="qpc-hafs">﴿لَكُنّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> المؤمنين. قال الله: <span class="qpc-hafs">﴿فَكَفَرُوا بِهِ﴾</span> بالقرآن{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٥٦ من طريق محمد بن سعد العوفي، عن أبيه، قال: حدثني عمي الحسين بن الحسن، عن أبيه، عن جده عطية العوفي، عن ابن عباس به. وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ١٩/٦٥٦.أخرجه عبد الرزاق ٢/١٥٩.أخرجه ابن جرير ١٩/٦٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٥، ٦٥٧. وعلَّقه يحيى بن سلام ٢/٨٤٧ بنحوه مختصرا.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٦.تفسير يحيى بن سلام ٢/٨٤٧.
  37,168,""
  37,168,""
  37,169,""
  37,170,""
  37,171,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ سَبَقَتۡ كَلِمَتُنَا لِعِبَادِنَا ٱلۡمُرۡسَلِینَ ۝١٧١ إِنَّهُمۡ لَهُمُ ٱلۡمَنصُورُونَ ۝١٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦١٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا﴾</span> الآية، قال: سبق هذا مِن الله أن ينصرهم{1}. (١٢/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا﴾</span> الآية، قال: كانت الأنبياء تُقتَل وهم منصورون، والمؤمنون يُقتلون وهم منصورون، نُصِروا بالحُجَج في الدنيا والآخرة، ولم يُقتل نبيٌّ قطُّ ولا قوم يدعون إلى الحق من المؤمنين، فتذهب تلك الأُمَّة والقرن، حتى يبعث الله قومًا ينتصر بهم منهم{2}. (١٢/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا﴾</span> بالنصر <span class="qpc-hafs">﴿لِعِبادِنا المُرْسَلِينَ﴾</span> يعني: الأنبياء ﵈، يعني بالكلمة: قوله ﷿: <span class="qpc-hafs">﴿كَتَبَ اللَّهُ لَأَغْلِبَنَّ أنا ورُسُلِي﴾</span> [المجادلة:٢١]، فهذه الكلمة التي سبقت للمرسلين، <span class="qpc-hafs">﴿إنَّهُمْ لَهُمُ المَنصُورُونَ﴾</span> على كفار قريش{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا لِعِبادِنا المُرْسَلِينَ * إنَّهُمْ لَهُمُ المَنصُورُونَ﴾</span> في الدنيا، وبالحُجَّة في الآخرة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٧ مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣.تفسير يحيى بن سلام ٢/٨٤٨.
  37,172,""
  37,172,""
  37,173,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ جُندَنَا لَهُمُ ٱلۡغَـٰلِبُونَ ۝١٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦١٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وإنَّ جُنْدَنا لَهُمُ الغالِبُونَ﴾</span>، قال: لم يُقتَل مِن الرسل أصحاب الشرائع أحدٌ قطُّ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خليد- في قوله: <span class="qpc-hafs">﴿وإن جندنا لهم الغالبون﴾</span>، قال: ولا أعلم أولئك إلا أهل الشام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦١٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّ جُنْدَنا﴾</span> حزبنا؛ يعني: المؤمنين <span class="qpc-hafs">﴿لَهُمُ الغالِبُونَ﴾</span> الذين نجوا مِن عذاب الدنيا والآخرة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٨٤٨.أخرجه الفسوي في المعرفة والتاريخ ٢/٣٠٣، وابن عساكر في تاريخ دمشق ١/٢٨٧.تفسير مقاتل بن سليمان ٣/٦٢٣.
  37,174,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦١٩٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، يعني: الموت{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٠<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، يعني: يوم بدر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، قال: إلى الموت{3}. (١٢/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، قال: يوم بدر{4}. (١٢/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span> قال: يوم القيامة{5}. (١٢/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، يقول الله ﷿ للنبي ﷺ: فأعرِض عن كُفّار مكة إلى العذاب؛ إلى القتل ببدر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، قال: يوم القيامة{7}<span class=comment-ref>٥٥٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٢٩</span> اختُلِف في الحين المذكور في الآية على ثلاثة أقوال: <b>الأول</b>: أن المراد: إلى الموت. وهو قول قتادة. و<b>الثاني</b>: أن المراد: إلى يوم بدر. وهو قول السديّ. و<b>الثالث</b>: أن المراد: إلى يوم القيامة. وهو قول ابن زيد.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (١٩/٦٥٩) إلى القول الثاني -وهو قول مجاهد، والسديّ- <span class="mustanad">استنادًا إلى السياق</span>، فقال: «هذا القول الذي قاله السدي أشبه بما دل عليه ظاهر التنزيل؛ وذلك أنّ الله توعدهم بالعذاب الذي كانوا يستعجلونه، فقال: <span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span>، وأمر نبيَّه ﷺ أن يُعرِض عنهم إلى مجيء حينه، فتأويل الكلام: فتول عنهم -يا محمد- إلى حين مجيء عذابنا ونزوله بهم».</div></p><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٤﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، قال: نسخها القتال في سورة براءة: <span class="qpc-hafs">﴿فاقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾</span> [التوبة:٥]{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span> نسختها آية القتال{1}<span class=comment-ref>٥٥٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٣٠</span> قال <u>ابنُ عطية</u> (٧/٣١٧ بتصرف): «وعد للنبي ﷺ، وأمر بالموادعة، وهذا مما نسخته آية السيف».</div></p></div>",footnotes:1:تفسير الثعلبي ٨/١٧٣، وتفسير البغوي ٤/٥٠.تفسير الثعلبي ٨/١٧٣، وتفسير البغوي ٤/٥٠.أخرجه ابن جرير ١٩/٦٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٨. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٩.أخرجه يحيى بن سلام ٢/٨٤٨.تفسير الثعلبي ٨/١٧٣، وتفسير البغوي ٤/٥٠.
  37,175,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَبۡصِرۡهُمۡ فَسَوۡفَ یُبۡصِرُونَ ۝١٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</span>، يعني: النفخة الأولى بها يهلك كفار آخر هذه الأمة الدّائنين بدِين أبي جهل وأصحابه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</span>، قال: أبصروا حين لم ينفعهم البصر{2}. (١٢/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَبْصِرْهُمْ﴾</span> إذا نزل بهم العذاب ببدر، <span class="qpc-hafs">﴿فَسَوْفَ يُبْصِرُونَ﴾</span> العذاب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢١١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</span>، يقول: أنظِرْهم فسوف يُبصرون ما لهم بعد اليوم. قال: يقول: يبصرون يوم القيامة ما ضيَّعوا مِن أمر الله، وكفرهم بالله ورسوله وكتابه. قال: فـ«أبصِرهم» و«أبصِر» واحد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</span>، أي: فسوف يرون العذاب{5}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٨٤٨.أخرجه ابن جرير ١٩/٦٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٩.تفسير يحيى بن سلام ٢/٨٤٨.
  37,176,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝١٧٦﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٦٢١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قالوا: يا محمد، أرِنا العذابَ الذي تُخَوِّفنا به، عجِّله لنا. فنزلت: <span class="qpc-hafs">﴿أفَبِعَذابِنا يَسْتَعْجِلُونَ﴾</span>{1}. (١٢/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسَوْفَ يُبْصِرُونَ﴾</span> العذابَ، فقالوا للنبي ﷺ: متى هذا الوعد؟ تكذيبًا به؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿أفَبِعَذابِنا يَسْتَعْجِلُونَ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى جويبر.</p><p>قال السيوطي في لباب النقول ص١٦٧: «صحيح على شرط الشيخين».تفسير مقاتل بن سليمان ٣/٦٢٣-٦٢٤.
  37,177,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا نَزَلَ بِسَاحَتِهِمۡ فَسَاۤءَ صَبَاحُ ٱلۡمُنذَرِینَ ۝١٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٢١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: في قوله: <span class="qpc-hafs">﴿فَإذا نَزَلَ بِساحَتِهِمْ﴾</span> قال: بدارهم <span class="qpc-hafs">﴿فَساءَ صَباحُ المُنْذَرِينَ﴾</span> قال: بئسما يُصبِحون{1}. (١٢/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا نَزَلَ بِساحَتِهِمْ﴾</span> بحضرتهم <span class="qpc-hafs">﴿فَساءَ صَباحُ﴾</span> فبئس صباح <span class="qpc-hafs">﴿المُنْذَرِينَ﴾</span> الذين أنذروا العذاب{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا نَزَلَ بِسَاحَتِهِمۡ فَسَاۤءَ صَبَاحُ ٱلۡمُنذَرِینَ ۝١٧٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٢١٧<span class="dash">-</span></span> عن أنس بن مالك: أنّ رسول الله ﷺ غزا خيبر، فصلَّينا عندها صلاة الغداة بغَلَس، فركب نبيُّ الله ﷺ وركب أبو طلحة، وأنا رديف أبي طلحة، فأجرى نبي الله ﷺ في زقاق خيبر، وإنّ ركبتي لَتَمَسُّ فَخِذ نبيِّ الله ﷺ، ثم حسر الإزارَ عن فخذه حتى إني أنظر إلى بياض فخذ نبي الله ﷺ، فلما دخل القرية قال: «<b>الله أكبر، خربت خيبر، إنا إذا نزلنا بساحة قوم <span class="qpc-hafs">﴿فساء صباح المنذرين﴾</span></b>» قالها ثلاثًا{3}. (١٢/٤٩٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٦٦٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣-٦٢٤.أخرجه البخاري ١/٨٣-٨٤ (٣٧١)، ١/١٢٥-١٢٦ (٦١٠)، ٤/٤٨ (٢٩٤٥)، ٤/٥٦-٥٧ (٢٩٩١)، ٤/٢٠٨ (٣٦٤٧)، ٥/١٣١-١٣٢ (٤١٩٧-٤١٩٩)، ٧/٩٥-٩٦ (٥٥٢٨)، وعبد الرزاق ٣/١٠٩ (٢٥٧٠) مختصرًا.
  37,178,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٢١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>، قال: قيل له: أعرِض عنهم{1}. (١٢/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢١٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span>: يعني: إلى حين آجالهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span> أعرِض عنهم إلى تلك المدة؛ القتل ببدر{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٨﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٢١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</span> نسخها القتال، هي مثل الأولى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٨٤٩.تفسير مقاتل بن سليمان ٣/٦٢٤.علقه يحيى بن سلام ٢/٨٤٩.
  37,179,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَبۡصِرۡ فَسَوۡفَ یُبۡصِرُونَ ۝١٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٢٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿وأَبْصِرْ فَسَوْفَ يُبْصِرُونَ﴾</span>، قال: يقول: يوم القيامة؛ ما صنعوا مِن أمر الله وكفرهم بالله ورسوله وكتابه. قال: أبصِر وأبصِرهم واحد{1}. (١٢/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَبْصِرْ﴾</span> وأبصر العذاب، <span class="qpc-hafs">﴿فَسَوْفَ يُبْصِرُونَ﴾</span> العذاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأَبْصِرْ﴾</span> انتظر، <span class="qpc-hafs">﴿فَسَوْفَ يُبْصِرُونَ﴾</span> فسوف يرون العذاب{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٤.تفسير يحيى بن سلام ٢/٨٤٩.
  37,180,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَ رَبِّكَ رَبِّ ٱلۡعِزَّةِ عَمَّا یَصِفُونَ ۝١٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ﴾</span> قال: سبَّح نفسه إذ كُذِب عليه وقيل عليه البهتان، <span class="qpc-hafs">﴿عَمّا يَصِفُونَ﴾</span> قال: عما يكذبون{1}. (١٢/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نزَّه نفسه عن قولهم، فقال ﷿: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ﴾</span> يعني: عزة مَن يَتَعَزَّز مِن ملوك الدنيا <span class="qpc-hafs">﴿عَمّا يَصِفُونَ﴾</span> عمّا يقولون من الكذب: إنّ الملائكة بنات الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ﴾</span> يُنَزِّه نفسه <span class="qpc-hafs">﴿رَبِّ العِزَّةِ عَمّا يَصِفُونَ﴾</span> عما يكذبون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٥٩ من طريق معمر، وابن جرير ١٩/٦٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٤.تفسير يحيى بن سلام ٢/٨٤٩.
  37,181,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَسَلَـٰمٌ عَلَى ٱلۡمُرۡسَلِینَ ۝١٨١ وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وسَلامٌ عَلى المُرْسَلِينَ﴾</span>، قال: قال رسول الله ﷺ: «<b>إذا سَلَّمْتُم عَلَيَّ فسلِّموا على المرسلين؛ فإنّما أنا رسولٌ مِن المرسلين</b>»{1}. (١٢/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٢٩<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>إذا سلَّمتُم عَلَيَّ فسَلِّموا على المرسلين؛ فإنما أنا رسول من المرسلين</b>». قال أبو العوام: كان <span class="name-2">قتادة</span> يذكر هذا الحديثَ إذا تلا هذه الآيات: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span> دبر الصلاة{2}. (١٢/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٣٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وسَلامٌ عَلى المُرْسَلِينَ﴾</span>، يعني: الثناء الحسن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وسَلامٌ عَلى المُرْسَلِينَ﴾</span> الذين بلَّغوا عن الله التوحيد، <span class="qpc-hafs">﴿والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span> على هلاك الآخرين الذين لم يُوَحِّدوا ربهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَلَـٰمٌ عَلَى ٱلۡمُرۡسَلِینَ ۝١٨١ وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٨٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٢٣٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: كُنّا نعرِف انصرافَ رسول الله ﷺ مِن الصلاة بقوله: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span>{5}. (١٢/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٣٣<span class="dash">-</span></span> عن أبي سعيد، عن رسول الله ﷺ: أنّه كان إذا أراد أن يُسلِّم من صلاته قال: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span>{6}. (١٢/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٣٤<span class="dash">-</span></span> عن زيد بن أرقم، عن رسول الله ﷺ، قال: «<b>من قال دبر كل صلاة: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span> ثلاث مرات؛ فقد اكتال بالمكيال الأوفى من الأجر</b>»{7}. (١٢/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٣٥<span class="dash">-</span></span> عن الشعبي، قال: قال رسول الله ﷺ: «<b>مَن سرَّه أن يكتال بالمكيال الأوفى مِن الأجر يوم القيامة فليَقُل آخرَ مجلسه حين يريد أن يقوم: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span></b>»{8}. (١٢/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٢٣٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الأصبغ بن نباتة- قال: مَن أحبَّ أن يكتال بالمكيال الأوفى مِن الأجر يوم القيامة فليكن آخرَ كلامه من مجلسه: <span class="qpc-hafs">﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span>{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/١٥٩، من طريق معمر مختصرًا، وابن جرير ١٩/٦٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ في طبقات المحدثين بأصبهان ٢/١٠-١١ المرفوع فقط، وأبو نعيم في أخبار أصبهان ١/١٤٩، ٢/٣١١، والثعلبي ٨/١٧٣.</p><p>قال الألباني في الصحيحة ٦/١١٢٧: «وهذا إسناد حسن، لولا أن إبراهيم هذا ذكره ابن أبي حاتم في الجرح، وقال: سألت أبي عنه؟ فقال: لا أعرفه. وذكر أنه روى عنه النضر بن هشام الأصبهاني وعبد الرزاق بن بكر الأصبهاني. قلت: فهو على شرط ابن حبان في الثقات».علقه يحيى بن سلام ٢/٨٤٩.تفسير مقاتل بن سليمان ٣/٦٢٤.أخرجه الطبراني في الكبير ١١/١١٥ (١١٢٢١).</p><p>قال الهيثمي المجمع ١٠/١٠٣ (١٦٩٢٧): «فيه محمد بن عبد الله بن عبيد بن عمير، وهو متروك». وقال الصالحي في سبل الهدى والرشاد ٨/١٦٩: «بسند ضعيف». وقال الألباني في الضعيفة ٩/٢١٦: «واهٍ، لا يفرح به».أخرجه الطيالسي في مسنده ٣/٦٥١-٦٥٢ (٢٣١٢)، وابن أبي شيبة في مصنفه ١/٢٦٩ (٣٠٩٧)، ومجاهد في تفسيره ص٥٧١.</p><p>قال المناوي في التيسير ٢/٢٥٢: «وإسناده حسن». وقال الألباني في الضعيفة ٩/٢١٥ (٤٢٠١): «ضعيف جدًّا».أخرجه الطبراني في الكبير ٥/٢١١ (٥١٢٤).</p><p>قال الهيثمي المجمع ١٠/١٠٢-١٠٣ (١٦٩٢٦): «فيه عبد المنعم بن بشير، وهو ضعيف جدًّا». وقال الألباني في الضعيفة ١٤/٦٩ (٦٥٢٩): «موضوع».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢، وتخريج أحاديث الكشاف ٣/١٨٢- مرسلًا.أخرجه يحيى بن سلام ٢/٨٤٩.
  37,182,""
