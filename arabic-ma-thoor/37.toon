  37,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَحَقَّ عَلَیۡنَا قَوۡلُ رَبِّنَاۤۖ إِنَّا لَذَاۤىِٕقُونَ ۝٣١ فَأَغۡوَیۡنَـٰكُمۡ إِنَّا كُنَّا غَـٰوِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span>: فوجب علينا قضاء ربنا؛ لأنا كنا أذلاء، وكنتم أعِزّاء{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span> قال: هذا قول الجن، <span class="qpc-hafs">﴿فَأَغْوَيْناكُمْ إنّا كُنّا غاوِينَ﴾</span> هذا قول الشياطين لضُلّال بني آدم{2}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فَأَغْوَيْناكُمْ﴾</span> قال: الشياطين تقول: أغويناكم في الدنيا <span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span>{3}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قالت الشياطين: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span> يومَ قال لإبليس: <span class="qpc-hafs">﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّنْ تَبِعَكَ مِنهُمْ أجْمَعِينَ﴾</span> [ص:٨٥] <span class="qpc-hafs">﴿إنّا لَذائِقُونَ فَأَغْوَيْناكُمْ﴾</span> يعني: أضللناكم عن الهدى، <span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span> ضالين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span> هذا قول الشياطين، والقول هاهنا هو قوله: <span class="qpc-hafs">﴿ولَكِنْ حَقَّ القَوْلُ مِنِّي﴾</span> صدق القول مِنِّي <span class="qpc-hafs">﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنَ الجِنَّةِ والنّاسِ أجْمَعِينَ﴾</span> [السجدة:١٣]. قال: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا إنّا لَذائِقُونَ﴾</span> أي: العذاب، <span class="qpc-hafs">﴿فَأَغْوَيْناكُمْ﴾</span> تقوله الشياطين للمشركين، أي: فأضللناكم، <span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span> ضالين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.أخرجه ابن جرير ١٩/٥٢٧ دون شطره الثاني. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٥-٦٠٦.تفسير يحيى بن سلام ٢/٨٢٩.
  37,32,""
  37,32,""
  37,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنَّهُمۡ یَوۡمَىِٕذࣲ فِی ٱلۡعَذَابِ مُشۡتَرِكُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</span> قال: كلهم <span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</span> ومَن أغْوَوا في الدنيا <span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>{2}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿مُشْتَرِكُونَ﴾</span> لا يمنعُ بعضُكم بعضًا من دخول النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</span> للكفار والشياطين <span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ فِي العَذابِ مُشْتَرِكُونَ﴾</span>، قال: هم والشياطين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ فِي العَذابِ مُشْتَرِكُونَ﴾</span> يُقرَن كلُّ واحد منهم هو وشيطانه في سلسلة واحدة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٨٢٨.تفسير مقاتل بن سليمان ٣/٦٠٥-٦٠٦.أخرجه ابن جرير ١٩/٥٢٧.تفسير يحيى بن سلام ٢/٨٢٩-٨٣٠.
  37,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا كَذَ ٰ⁠لِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِینَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span>، يقول: إنّا هكذا نصنع بالمشركين{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> الذين جعلوا لله شركاء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> بالمشركين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.تفسير البغوي ٧/٣٩.تفسير يحيى بن سلام ٢/٨٣٠.
  37,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> نزلت في الملأ مِن قريش الذين مشَوْا إلى أبي طالب، فقال لهم النبي ﷺ: «<b>قولوا: لا إله إلا الله. تملكون بها العرب، وتدين لكم العجم بها</b>»{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٠٥<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: قال رسول الله ﷺ: «<b>أُمِرْتُ أن أُقاتِل الناس حتى يقولوا: لا إله إلا الله. فمَن قال: لا إله إلا الله. فقد عصم مِنِّي مالَه ونفسَه إلا بِحَقِّه، وحسابه على الله</b>». وأنزل الله في كتابه، وذكر قومًا استكبروا فقال: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>. وقال: <span class="qpc-hafs">﴿إذْ جَعَلَ الَّذِينَ كَفَرُوا فِي قُلُوبِهِمُ الحَمِيَّةَ حَمِيَّةَ الجاهِلِيَّةِ فَأَنْزَلَ اللَّهُ سَكِينَتَهُ عَلى رَسُولِهِ وعَلى المُؤْمِنِينَ وأَلْزَمَهُمْ كَلِمَةَ التَّقْوى وكانُوا أحَقَّ بِها وأَهْلَها﴾</span> [الفتح:٢٦] وهي: لا إله إلا الله محمد رسول الله، استكبر عنها المشركون يوم الحديبية، يوم كاتَبهم رسول الله ﷺ على قضية المدة{2}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>، قال: كانوا إذا لم يُشرِك بالله يستنكفون{3}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>، قال: يعني: المشركين خاصَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> يَتَكَبَّرون عنِ الهُدى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> عنها{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٠<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>، قال: قال <span class="name-1">عمر بن الخطاب</span>: احضروا موتاكم، ولقِّنوهم لا إله إلا الله، فإنهم يرون ويسمعون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق سعيد بن رمانة- أنّه قيل له: أليس «لا إله إلا الله» مفتاح الجنة؟ قال: بلى. ولكن ليس مِن مفتاح إلا وله أسنان، فمَن جاء بأسنانه فُتِح له، ومن لا لم يُفتح له{8}. (١٢/٤٠٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.أخرجه البيهقي في الأسماء والصفات ١/٢٦٣-٢٦٤ (١٩٦)، وابن جرير ٢١/٣٠٨-٣٠٩ واللفظ له، وأخرجه البخاري ٤/٤٨ (٢٩٤٦)، ٩/١٥ (٦٩٢٤)، ٩/٩٣ (٧٢٨٤)، ومسلم ١/٥١ (٢٠)، ١/٥٢ (٢١) كلاهما دون قوله: وأنزل الله في كتابه.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٩/٥٢٨.تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.أخرجه ابن جرير ١٩/٥٢٨.أخرجه البخاري في تاريخه ١/٩٥، والبيهقى في الأسماء والصفات (٢٠٨).
  37,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ أَىِٕنَّا لَتَارِكُوۤا۟ ءَالِهَتِنَا لِشَاعِرࣲ مَّجۡنُونِۭ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ويَقُولُونَ أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span> لا يعقل. قال: فحكى الله صِدقَه، فقال: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ وصَدَّقَ المُرْسَلِينَ﴾</span>{1}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويَقُولُونَ أئِنّا لَتارِكُوا آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span>: يعنون: محمدًا ﷺ{2}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويَقُولُونَ﴾</span> يعني: المشركين، إذا دعاهم النبي ﷺ إلى الإيمان: <span class="qpc-hafs">﴿أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span> يعنون: النبي ﷺ، أي: لا نفعل{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٩/٥٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.
  37,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ جَاۤءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِینَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: قال: فحكى الله صِدْقَه، فقال: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ وصَدَّقَ المُرْسَلِينَ﴾</span>{1}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span> بالقرآن، <span class="qpc-hafs">﴿وصَدَّقَ المُرْسَلِينَ﴾</span> أي: صدّق مَن كان قبله مِن المرسلين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span>، يعني: بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُونَ أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span>. فقال -جل وعز-: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span> يعني: محمدًا ﷺ، جاء بالتوحيد، <span class="qpc-hafs">﴿وصَدَّقَ المُرْسَلِينَ﴾</span> قبله{4}<span class=comment-ref>٥٤٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٥</span> <span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٢/٣٦٧): «مجيئه تصديقٌ لهم من جهتين: مِن جهة إخبارهم بمجيئه ومبعثه، ومِن جهة إخباره بمثل ما أخبروا به، ومطابقة ما جاء به لما جاءوا به؛ فإن الرسول الأول إذا أتى بأمرٍ لا يعلم إلا بالوحي، ثم جاء نبي آخر لم يقارنه في الزمان ولا في المكان، ولا تلقى عنه ما جاء به، وأخبر بمثل ما أخبر به سواء؛ دلَّ ذلك على صدق الرسولين الأول والآخر، وكان ذلك بمنزلة رجلين أخبر أحدهما بخبر عن عيان، ثم جاء آخر من غير بلده وناحيته -بحيث يعلم أنه لم يجتمع به، ولا تلقى عنه، ولا عمن تلقى عنه-، فأخبر بمثل ما أخبر به الأول سواء؛ فإنه يضطر السامع إلى تصديق الأول والثاني. و<b>المعنى الثانى:</b> أنه لم يأتِ مُكَذِّبًا لِمَن قبله مِن الأنبياء، مُزْرِيًا عليهم، كما يفعل الملوك المتغلبون على الناس بمن تقدمهم من الملوك، بل جاء مصدقًا لهم، شاهدًا بنبوتهم، ولو كان كاذبًا متقولًا منشئًا من عنده سياسة لم يصدِّق من قبله، بل كان يُزْرِي بهم، ويطعن عليهم، كما يفعل أعداء الأنبياء».</p><p>وبنحو الكلام الأول <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١٢/١٥).</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٩/٥٢٩.علقه يحيى بن سلام ٢/٨٣٠.تفسير مقاتل بن سليمان ٣/٦٠٦.
  37,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّكُمۡ لَذَاۤىِٕقُوا۟ ٱلۡعَذَابِ ٱلۡأَلِیمِ ۝٣٨ وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّكُمْ لَذائِقُوا العَذابِ الأَلِيمِ﴾</span> يعني: الوجيع، <span class="qpc-hafs">﴿وما تُجْزَوْنَ﴾</span> في الآخرة <span class="qpc-hafs">﴿إلّا ما كُنْتُمْ تَعْمَلُونَ﴾</span> في الدنيا مِن الشرك، جزاءُ الشرك النارُ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إنَّكُمْ لَذائِقُو العَذابِ الأَلِيمِ﴾</span> المُوجِع، يقوله للمشركين، يعني: عذاب جهنم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.
