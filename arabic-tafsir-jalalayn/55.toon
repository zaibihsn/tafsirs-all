tafsir[78]{c,v,t}:
  55,1,"﴿ٱلرَّحۡمَـٰنُ ۝١﴾ الله تعالى"
  55,2,"﴿عَلَّمَ﴾ من شاء ﴿ٱلۡقُرۡءَانَ ۝٢﴾"
  55,3,"﴿خَلَقَ ٱلۡإِنسَـٰنَ ۝٣﴾ أَيْ الْجِنْس"
  55,4,"﴿عَلَّمَهُ ٱلۡبَیَانَ ۝٤﴾ النُّطْق"
  55,5,"﴿ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانࣲ ۝٥﴾ يَجْرِيَانِ"
  55,6,"﴿وَٱلنَّجۡمُ﴾ مَا لَا سَاقَ لَهُ مِنْ النَّبَات ﴿وَٱلشَّجَرُ﴾ مَا لَهُ سَاق ﴿یَسۡجُدَانِ ۝٦﴾ يَخْضَعَانِ لِمَا يُرَاد مِنْهُمَا"
  55,7,"﴿وَٱلسَّمَاۤءَ رَفَعَهَا وَوَضَعَ ٱلۡمِیزَانَ ۝٧﴾ أَثْبَت الْعَدْل"
  55,8,"﴿أَلَّا تَطۡغَوۡا۟﴾ أَيْ لِأَجْلِ أَنْ لَا تَجُورُوا ﴿فِی ٱلۡمِیزَانِ ۝٨﴾ مَا يُوزَن بِهِ"
  55,9,"﴿وَأَقِیمُوا۟ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ﴾ بِالْعَدْلِ ﴿وَلَا تُخۡسِرُوا۟ ٱلۡمِیزَانَ ۝٩﴾ تنقصوا الموزون"
  55,10,"﴿وَٱلۡأَرۡضَ وَضَعَهَا﴾ أَثْبَتَهَا ﴿لِلۡأَنَامِ ۝١٠﴾ لِلْخَلْقِ الْإِنْس وَالْجِنّ وغيرهم"
  55,11,"﴿فِیهَا فَـٰكِهَةࣱ وَٱلنَّخۡلُ﴾ الْمَعْهُود ﴿ذَاتُ ٱلۡأَكۡمَامِ ۝١١﴾ أَوْعِيَة طلعها"
  55,12,"﴿وَٱلۡحَبُّ﴾ كالحنطة والشعير ﴿ذُو ٱلۡعَصۡفِ﴾ التبن ﴿وَٱلرَّیۡحَانُ ۝١٢﴾ الْوَرَق الْمَشْمُوم"
  55,13,"﴿فَبِأَیِّ ءَالَاۤءِ﴾ نِعَم ﴿رَبِّكُمَا﴾ أَيّهَا الْإِنْس وَالْجِنّ ﴿تُكَذِّبَانِ ۝١٣﴾ ذُكِرَتْ إحْدَى وَثَلَاثِينَ مَرَّة وَالِاسْتِفْهَام فِيهَا لِلتَّقْرِيرِ لِمَا رَوَى الْحَاكِم عَنْ جَابِر قَالَ قَرَأَ عَلَيْنَا رَسُول اللَّه صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ سُورَة الرَّحْمَن حَتَّى خَتَمَهَا ثُمَّ قَالَ مَالِي أَرَاكُمْ سُكُوتًا لَلْجِنّ كَانُوا أَحْسَن مِنْكُمْ رَدًّا مَا قَرَأْت عَلَيْهِمْ هَذِهِ الْآيَة مِنْ مَرَّة {فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٣} إلَّا قَالُوا وَلَا بِشَيْءٍ مِنْ نِعَمك رَبّنَا نُكَذِّب فَلَك الحمد"
  55,14,"﴿خَلَقَ ٱلۡإِنسَـٰنَ﴾ آدَم ﴿مِن صَلۡصَـٰلࣲ﴾ طِين يَابِس يُسْمَع لَهُ صَلْصَلَة أَيْ صَوْت إذَا نُقِرَ ﴿كَٱلۡفَخَّارِ ۝١٤﴾ وهو ما طبخ من الطين"
  55,15,"﴿وَخَلَقَ ٱلۡجَاۤنَّ﴾ أَبَا الْجِنّ وَهُوَ إبْلِيس ﴿مِن مَّارِجࣲ مِّن نَّارࣲ ۝١٥﴾ هُوَ لَهَبهَا الْخَالِص مِنْ الدخان"
  55,16,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٦﴾"
  55,17,"﴿رَبُّ ٱلۡمَشۡرِقَیۡنِ﴾ مَشْرِق الشِّتَاء وَمَشْرِق الصَّيْف ﴿وَرَبُّ ٱلۡمَغۡرِبَیۡنِ ۝١٧﴾ كذلك"
  55,18,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٨﴾"
  55,19,"﴿مَرَجَ﴾ أَرْسَلَ ﴿ٱلۡبَحۡرَیۡنِ﴾ الْعَذْب وَالْمِلْح ﴿یَلۡتَقِیَانِ ۝١٩﴾ فِي رأي العين"
  55,20,"﴿بَیۡنَهُمَا بَرۡزَخࣱ﴾ حَاجِز مِنْ قُدْرَته تَعَالَى ﴿لَّا یَبۡغِیَانِ ۝٢٠﴾ لَا يَبْغِي وَاحِد مِنْهُمَا عَلَى الْآخَر فيختلط به"
  55,21,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٢١﴾"
  55,22,"﴿یُخۡرَجُ﴾ بِالْبِنَاءِ لِلْمَفْعُولِ وَالْفَاعِل ﴿مِنۡهُمَا﴾ مِنْ مَجْمُوعهمَا الصَّادِق بِأَحَدِهِمَا وَهُوَ الْمِلْح ﴿ٱللُّؤۡلُؤُ وَٱلۡمَرۡجَانُ ۝٢٢﴾ خَرَز أحمر أو صغار اللؤلؤ"
  55,23,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٢٣﴾"
  55,24,"﴿وَلَهُ ٱلۡجَوَارِ﴾ السُّفُن ﴿ٱلۡمُنشَـَٔاتُ﴾ الْمُحْدَثَات ﴿فِی ٱلۡبَحۡرِ كَٱلۡأَعۡلَـٰمِ ۝٢٤﴾ كالجبال عظما وارتفاعا"
  55,25,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٢٥﴾"
  55,26,"﴿كُلُّ مَنۡ عَلَیۡهَا﴾ أَيْ الْأَرْض مِنْ الْحَيَوَان ﴿فَانࣲ ۝٢٦﴾ هَالِك وَعَبَّرَ بِمَنْ تَغْلِيبًا لِلْعُقَلَاءِ"
  55,27,"﴿وَیَبۡقَىٰ وَجۡهُ رَبِّكَ﴾ ذَاته ﴿ذُو ٱلۡجَلَـٰلِ﴾ الْعَظَمَة ﴿وَٱلۡإِكۡرَامِ ۝٢٧﴾ للمؤمنين بأنعمه عليهم"
  55,28,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٢٨﴾"
  55,29,"﴿یَسۡـَٔلُهُۥ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾ بِنُطْقٍ أَوْ حَال مَا يَحْتَاجُونَ إلَيْهِ مِنْ الْقُوَّة عَلَى الْعِبَادَة وَالرِّزْق وَالْمَغْفِرَة وَغَيْر ذَلِكَ ﴿كُلَّ یَوۡمٍ﴾ وَقْت ﴿هُوَ فِی شَأۡنࣲ ۝٢٩﴾ أَمْر يُظْهِرهُ عَلَى وَفْق مَا قَدَّرَهُ فِي الْأَزَل مِنْ إحْيَاء وَإِمَاتَة وَإِعْزَاز وَإِذْلَال وَإِغْنَاء وَإِعْدَام وَإِجَابَة دَاعٍ وإعطاء سائل وغير ذلك"
  55,30,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٣٠﴾"
  55,31,"﴿سَنَفۡرُغُ لَكُمۡ﴾ سَنَقْصِدُ لِحِسَابِكُمْ ﴿أَیُّهَ ٱلثَّقَلَانِ ۝٣١﴾ الْإِنْس والجن"
  55,32,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٣٢﴾"
  55,33,"﴿یَـٰمَعۡشَرَ ٱلۡجِنِّ وَٱلۡإِنسِ إِنِ ٱسۡتَطَعۡتُمۡ أَن تَنفُذُوا۟﴾ تَخْرُجُوا ﴿مِنۡ أَقۡطَارِ﴾ نَوَاحِي ﴿ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ فَٱنفُذُوا۟ۚ﴾ أَمْر تَعْجِيز ﴿لَا تَنفُذُونَ إِلَّا بِسُلۡطَـٰنࣲ ۝٣٣﴾ بقوة ولا قوة لكم على ذلك"
  55,34,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٣٤﴾"
  55,35,"﴿یُرۡسَلُ عَلَیۡكُمَا شُوَاظࣱ مِّن نَّارࣲ﴾ هُوَ لَهَبهَا الْخَالِص مِنْ الدُّخَان أَوْ مَعَهُ ﴿وَنُحَاسࣱ﴾ أَيْ دُخَان لَا لَهَب فِيهِ ﴿فَلَا تَنتَصِرَانِ ۝٣٥﴾ تَمْتَنِعَانِ من ذلك بل يسوقكم إلى المحشر"
  55,36,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٣٦﴾"
  55,37,"﴿فَإِذَا ٱنشَقَّتِ ٱلسَّمَاۤءُ﴾ انْفَرَجَتْ أَبْوَابًا لِنُزُولِ الْمَلَائِكَة ﴿فَكَانَتۡ وَرۡدَةࣰ﴾ أَيْ مِثْلهَا مُحْمَرَّة ﴿كَٱلدِّهَانِ ۝٣٧﴾ كَالْأَدِيمِ الْأَحْمَر عَلَى خِلَاف الْعَهْد بِهَا وَجَوَاب إذَا فما أعظم الهول"
  55,38,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٣٨﴾"
  55,39,"﴿فَیَوۡمَىِٕذࣲ لَّا یُسۡـَٔلُ عَن ذَنۢبِهِۦۤ إِنسࣱ وَلَا جَاۤنࣱّ ۝٣٩﴾ عَنْ ذَنْبه وَيُسْأَلُونَ فِي وَقْت آخَر {فَوَرَبِّكَ لَنَسۡـَٔلَنَّهُمۡ أَجۡمَعِینَ} وَالْجَانّ هُنَا وَفِيمَا سَيَأْتِي بمعنى الجني والإنس فيهما بمعنى الإنسي"
  55,40,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٤٠﴾"
  55,41,"﴿یُعۡرَفُ ٱلۡمُجۡرِمُونَ بِسِیمَـٰهُمۡ﴾ سَوَاد الْوُجُوه وَزُرْقَة الْعُيُون ﴿فَیُؤۡخَذُ بِٱلنَّوَ ٰ⁠صِی وَٱلۡأَقۡدَامِ ۝٤١﴾"
  55,42,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٤٢﴾ تُضَمّ نَاصِيَة كُلّ مِنْهُمْ إلَى قَدَمَيْهِ مِنْ خَلْف أَوْ قُدَّام وَيُلْقَى فِي النَّار وَيُقَال لَهُمْ"
  55,43,"﴿هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِی یُكَذِّبُ بِهَا ٱلۡمُجۡرِمُونَ ۝٤٣﴾"
  55,44,"﴿یَطُوفُونَ﴾ يَسْعَوْنَ ﴿بَیۡنَهَا وَبَیۡنَ حَمِیمٍ﴾ مَاء حَارّ ﴿ءَانࣲ ۝٤٤﴾ شَدِيد الْحَرَارَة يُسْقَوْنَهُ إذَا اسْتَغَاثُوا مِنْ حر النار وهو منقوص كقاض"
  55,45,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٤٥﴾"
  55,46,"﴿وَلِمَنۡ خَافَ﴾ أَيْ لِكُلٍّ مِنْهُمْ أَوْ لِمَجْمُوعِهِمْ ﴿مَقَامَ رَبِّهِۦ﴾ قِيَامه بَيْن يَدَيْهِ لِلْحِسَابِ فَتَرَكَ معصيته ﴿جَنَّتَانِ ۝٤٦﴾"
  55,47,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٤٧﴾"
  55,48,"﴿ذَوَاتَاۤ﴾ تَثْنِيَة ذَوَات عَلَى الْأَصْل وَلَامهَا يَاء ﴿أَفۡنَانࣲ ۝٤٨﴾ أغصان جمع فنن كطلل"
  55,49,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٤٩﴾"
  55,50,"﴿فِیهِمَا عَیۡنَانِ تَجۡرِیَانِ ۝٥٠﴾"
  55,51,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٥١﴾"
  55,52,"﴿فِیهِمَا مِن كُلِّ فَـٰكِهَةࣲ﴾ فِي الدُّنْيَا أَوْ كُلّ مَا يُتَفَكَّه بِهِ ﴿زَوۡجَانِ ۝٥٢﴾ نَوْعَانِ رَطْب وَيَابِس وَالْمُرّ مِنْهُمَا فِي الدُّنْيَا كَالْحَنْظَلِ حُلْو"
  55,53,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٥٣﴾"
  55,54,"﴿مُتَّكِـِٔینَ﴾ حَال عَامِله مَحْذُوف أَيْ يَتَنَعَّمُونَ ﴿عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾ مَا غَلُظَ مِنْ الدِّيبَاج وَخَشُنَ وَالظَّهَائِر مِنْ السُّنْدُس ﴿وَجَنَى ٱلۡجَنَّتَیۡنِ﴾ ثَمَرهمَا ﴿دَانࣲ ۝٥٤﴾ قَرِيب يَنَالهُ الْقَائِم وَالْقَاعِد وَالْمُضْطَجِع"
  55,55,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٥٥﴾"
  55,56,"﴿فِیهِنَّ﴾ فِي الْجَنَّتَيْنِ وَمَا اشْتَمَلَتَا عَلَيْهِ مِنْ الْعَلَالِيّ وَالْقُصُور ﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾ الْعَيْن عَلَى أَزْوَاجهنَّ الْمُتَّكِئِينَ مِنْ الْإِنْس وَالْجِنّ ﴿لَمۡ یَطۡمِثۡهُنَّ﴾ يَفْتَضّهُنَّ وَهُنَّ مِنْ الْحُور أَوْ مِنْ نِسَاء الدُّنْيَا المنشآت ﴿إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾"
  55,57,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٥٧﴾"
  55,58,"﴿كَأَنَّهُنَّ ٱلۡیَاقُوتُ﴾ صفاء ﴿وَٱلۡمَرۡجَانُ ۝٥٨﴾ اللؤلؤ بياضا"
  55,59,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٥٩﴾"
  55,60,"﴿هَلۡ﴾ مَا ﴿جَزَاۤءُ ٱلۡإِحۡسَـٰنِ﴾ بِالطَّاعَةِ ﴿إِلَّا ٱلۡإِحۡسَـٰنُ ۝٦٠﴾ بالنعيم"
  55,61,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٦١﴾"
  55,62,"﴿وَمِن دُونِهِمَا﴾ الْجَنَّتَيْنِ الْمَذْكُورَتَيْنِ ﴿جَنَّتَانِ ۝٦٢﴾ أَيْضًا لِمَنْ خَافَ مَقَام ربه"
  55,63,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٦٣﴾"
  55,64,"﴿مُدۡهَاۤمَّتَانِ ۝٦٤﴾ سوداوان من شدة خضرتهما"
  55,65,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٦٥﴾"
  55,66,"﴿فِیهِمَا عَیۡنَانِ نَضَّاخَتَانِ ۝٦٦﴾ فوارتان بالماء"
  55,67,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٦٧﴾"
  55,68,"﴿فِیهِمَا فَـٰكِهَةࣱ وَنَخۡلࣱ وَرُمَّانࣱ ۝٦٨﴾ هُمَا مِنْهَا وَقِيلَ من غيرها"
  55,69,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٦٩﴾"
  55,70,"﴿فِیهِنَّ﴾ أي الجنتين وما فيهما ﴿خَیۡرَ ٰ⁠تٌ﴾ أخلاقا ﴿حِسَانࣱ ۝٧٠﴾ وجوها"
  55,71,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٧١﴾"
  55,72,"﴿حُورࣱ﴾ شَدِيدَات سَوَاد الْعُيُون وَبَيَاضهَا ﴿مَّقۡصُورَ ٰ⁠تࣱ﴾ مَسْتُورَات ﴿فِی ٱلۡخِیَامِ ۝٧٢﴾ مِنْ دُرّ مُجَوَّف مُضَافَة إلَى الْقُصُور شَبِيهَة بالخدور"
  55,73,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٧٣﴾"
  55,74,"﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ﴾ قبل أزواجهن ﴿وَلَا جَاۤنࣱّ ۝٧٤﴾"
  55,75,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٧٥﴾"
  55,76,"﴿مُتَّكِـِٔینَ﴾ أَيْ أَزْوَاجهمْ وَإِعْرَابه كَمَا تَقَدَّمَ ﴿عَلَىٰ رَفۡرَفٍ خُضۡرࣲ﴾ جَمْع رَفْرَفَة أَيْ بُسُط أَوْ وَسَائِد ﴿وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾ جَمْع عَبْقَرِيَّة أَيْ طَنَافِس"
  55,77,"﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝٧٧﴾"
  55,78,"﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾ تَقَّدَمَ ولفظ اسم زائد"
