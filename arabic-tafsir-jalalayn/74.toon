tafsir[56]{c,v,t}:
  74,1,"﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١﴾ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ وَأَصْله الْمُتَدَثِّر أُدْغِمَتْ التَّاء فِي الدَّال أَيْ الْمُتَلَفِّف بِثِيَابِهِ عِنْد نُزُول الْوَحْي عَلَيْهِ"
  74,2,"﴿قُمۡ فَأَنذِرۡ ۝٢﴾ خَوِّفْ أَهْل مَكَّة النَّار إنْ لَمْ يُؤْمِنُوا"
  74,3,"﴿وَرَبَّكَ فَكَبِّرۡ ۝٣﴾ عَظِّمْ عَنْ إشْرَاك الْمُشْرِكِينَ"
  74,4,"﴿وَثِیَابَكَ فَطَهِّرۡ ۝٤﴾ عَنْ النَّجَاسَة أَوْ قَصِّرْهَا خِلَاف جَرّ الْعَرَب ثِيَابهمْ خُيَلَاء فَرُبَّمَا أَصَابَتْهَا نَجَاسَة"
  74,5,"﴿وَٱلرُّجۡزَ﴾ فَسَّرَهُ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ بِالْأَوْثَانِ ﴿فَٱهۡجُرۡ ۝٥﴾ أَيْ دُمْ عَلَى هَجْره"
  74,6,"﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾ بِالرَّفْعِ حَال أَيْ لَا تُعْطِ شَيْئًا لِتَطْلُب أَكْثَر مِنْهُ وَهَذَا خَاصّ بِهِ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ لِأَنَّهُ مَأْمُور بِأَجْمَل الْأَخْلَاق وَأَشْرَف الْآدَاب"
  74,7,"﴿وَلِرَبِّكَ فَٱصۡبِرۡ ۝٧﴾ عَلَى الْأَوَامِر وَالنَّوَاهِي"
  74,8,"﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾ نُفِخَ فِي الصُّور وَهُوَ الْقَرْن النَّفْخَة الثَّانِيَة"
  74,9,"﴿فَذَ ٰ⁠لِكَ﴾ أَيْ وَقْت النَّقْر ﴿یَوۡمَىِٕذࣲ﴾ بَدَل مِمَّا قَبْله الْمُبْتَدَأ وَبُنِيَ لِإِضَافَتِهِ إلَى غَيْر مُتَمَكِّن وَخَبَر الْمُبْتَدَأ ﴿یَوۡمٌ عَسِیرٌ ۝٩﴾ وَالْعَامِل فِي إذَا مَا دَلَّتْ عَلَيْهِ الْجُمْلَة اشْتَدَّ الْأَمْر"
  74,10,"﴿عَلَى ٱلۡكَـٰفِرِینَ غَیۡرُ یَسِیرࣲ ۝١٠﴾ فِيهِ دَلَالَة عَلَى أَنَّهُ يَسِير عَلَى الْمُؤْمِنِينَ فِي عُسْره"
  74,11,"﴿ذَرۡنِی﴾ اُتْرُكْنِي ﴿وَمَنۡ خَلَقۡتُ﴾ عَطْف عَلَى الْمَفْعُول أَوْ مَفْعُول مَعَهُ ﴿وَحِیدࣰا ۝١١﴾ حَال مِنْ مَنْ أَوْ مِنْ ضَمِيره الْمَحْذُوف مِنْ خَلَقْت مُنْفَرِدًا بِلَا أَهْل وَلَا مَال هُوَ الْوَلِيد بْن المغيرة المخزومي"
  74,12,"﴿وَجَعَلۡتُ لَهُۥ مَالࣰا مَّمۡدُودࣰا ۝١٢﴾ وَاسِعًا مُتَّصِلًا مِنْ الزُّرُوع وَالضُّرُوع وَالتِّجَارَة"
  74,13,"﴿وَبَنِینَ﴾ عَشَرَة أَوْ أَكْثَر ﴿شُهُودࣰا ۝١٣﴾ يَشْهَدُونَ الْمَحَافِل وتسمع شهاداتهم"
  74,14,"﴿وَمَهَّدتُّ﴾ بَسَطْت ﴿لَهُۥ﴾ فِي الْعَيْش وَالْعُمُر وَالْوَلَد ﴿تَمۡهِیدࣰا ۝١٤﴾"
  74,15,"﴿ثُمَّ یَطۡمَعُ أَنۡ أَزِیدَ ۝١٥﴾"
  74,16,"﴿كَلَّاۤۖ﴾ لَا أَزِيدهُ عَلَى ذَلِكَ ﴿إِنَّهُۥ كَانَ لِـَٔایَـٰتِنَا﴾ الْقُرْآن ﴿عَنِیدࣰا ۝١٦﴾ مُعَانِدًا"
  74,17,"﴿سَأُرۡهِقُهُۥ﴾ أُكَلِّفهُ ﴿صَعُودًا ۝١٧﴾ مَشَقَّة مِنْ الْعَذَاب أَوْ جَبَلًا مِنْ نَار يَصْعَد فِيهِ ثُمَّ يَهْوِي أبدا"
  74,18,"﴿إِنَّهُۥ فَكَّرَ﴾ فِيمَا يَقُول فِي الْقُرْآن الَّذِي سَمِعَهُ مِنْ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿وَقَدَّرَ ۝١٨﴾ فِي نَفْسه ذَلِكَ"
  74,19,"﴿فَقُتِلَ﴾ لُعِنَ وَعُذِّبَ ﴿كَیۡفَ قَدَّرَ ۝١٩﴾ عَلَى أَيّ حال كان تقديره"
  74,20,"﴿ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾"
  74,21,"﴿ثُمَّ نَظَرَ ۝٢١﴾ فِي وُجُوه قَوْمه أَوْ فِيمَا يَقْدَح بِهِ فِيهِ"
  74,22,"﴿ثُمَّ عَبَسَ﴾ قَبَضَ وَجْهه وَكَلَّحَهُ ضِيقًا بِمَا يَقُول ﴿وَبَسَرَ ۝٢٢﴾ زَادَ فِي الْقَبْض وَالْكُلُوح"
  74,23,"﴿ثُمَّ أَدۡبَرَ﴾ عَنْ الْإِيمَان ﴿وَٱسۡتَكۡبَرَ ۝٢٣﴾ تَكَبَّرَ عَنْ اتِّبَاع النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ"
  74,24,"﴿فَقَالَ﴾ فِيمَا جَاءَ بِهِ ﴿إِنۡ﴾ مَا ﴿هَـٰذَاۤ إِلَّا سِحۡرࣱ یُؤۡثَرُ ۝٢٤﴾ يُنْقَل عَنْ السَّحَرَة"
  74,25,"﴿إِنۡ﴾ مَا ﴿هَـٰذَاۤ إِلَّا قَوۡلُ ٱلۡبَشَرِ ۝٢٥﴾ كَمَا قَالُوا إنَّمَا يُعَلِّمهُ بشر"
  74,26,"﴿سَأُصۡلِیهِ﴾ أُدْخِلهُ ﴿سَقَرَ ۝٢٦﴾ جَهَنَّم"
  74,27,"﴿وَمَاۤ أَدۡرَىٰكَ مَا سَقَرُ ۝٢٧﴾ تعظيم لشأنها"
  74,28,"﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾ شَيْئًا مِنْ لَحْم وَلَا عَصَب إلَّا أَهْلَكَتْهُ ثُمَّ يَعُود كما كان"
  74,29,"﴿لَوَّاحَةࣱ لِّلۡبَشَرِ ۝٢٩﴾ مُحَرِّقَة لِظَاهِرِ الْجِلْد"
  74,30,"﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾ مَلَكًا خَزَنَتهَا قَالَ بَعْض الْكُفَّار وَكَانَ قَوِيًّا شَدِيد الْبَأْس أَنَا أَكْفِيكُمْ سَبْعَة عَشَر وَاكْفُونِي أَنْتُمْ اثْنَيْنِ قَالَ تَعَالَى"
  74,31,"﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ﴾ أَيْ فَلَا يُطَاقُونَ كَمَا يَتَوَهَّمُونَ ﴿وَمَا جَعَلۡنَا عِدَّتَهُمۡ﴾ ذَلِكَ ﴿إِلَّا فِتۡنَةࣰ﴾ ضَلَالًا ﴿لِّلَّذِینَ كَفَرُوا۟﴾ بِأَنْ يَقُولُوا لِمَ كَانُوا تِسْعَة عَشَر ﴿لِیَسۡتَیۡقِنَ﴾ لِيَسْتَبِينَ ﴿ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ﴾ أَيْ الْيَهُود صِدْق النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ فِي كَوْنهمْ تِسْعَة عَشَر الْمُوَافِق لِمَا فِي كِتَابهمْ ﴿وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟﴾ مِنْ أَهْل الْكِتَاب ﴿إِیمَـٰنࣰا﴾ تَصْدِيقًا لِمُوَافَقَتِهِ مَا أَتَى بِهِ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ لِمَا فِي كِتَابهمْ ﴿وَلَا یَرۡتَابَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَٱلۡمُؤۡمِنُونَ﴾ مِنْ غَيْرهمْ فِي عَدَد الْمَلَائِكَة ﴿وَلِیَقُولَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ﴾ شَكّ بِالْمَدِينَةِ ﴿وَٱلۡكَـٰفِرُونَ﴾ بِمَكَّة ﴿مَاذَاۤ أَرَادَ ٱللَّهُ بِهَـٰذَا﴾ الْعَدَد ﴿مَثَلࣰاۚ﴾ سَمَّوْهُ لِغَرَابَتِهِ بِذَلِكَ وَأُعْرِبَ حَالًا ﴿كَذَ ٰ⁠لِكَ﴾ أَيْ مِثْل إضْلَال مُنْكِر هَذَا الْعَدَد وَهَدَى مُصَدِّقه ﴿یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ﴾ أَيْ الْمَلَائِكَة فِي قُوَّتهمْ وَأَعْوَانهمْ ﴿إِلَّا هُوَۚ وَمَا هِیَ﴾ أي سقر ﴿إِلَّا ذِكۡرَىٰ لِلۡبَشَرِ ۝٣١﴾"
  74,32,"﴿كَلَّا﴾ استفتاح بمعنى ألا ﴿وَٱلۡقَمَرِ ۝٣٢﴾"
  74,33,"﴿وَٱلَّیۡلِ إِذَا﴾ بفتح الذال ﴿دَبَرَ ۝٣٣﴾ جاء بعد النهار وفي قراءة {إِذۡ أَدۡبَرَ} بِسُكُونِ الذَّال بَعْدهَا هَمْزَة أَيْ مَضَى"
  74,34,"﴿وَٱلصُّبۡحِ إِذَاۤ أَسۡفَرَ ۝٣٤﴾ ظَهَرَ"
  74,35,"﴿إِنَّهَا﴾ أَيْ سَقَر ﴿لَإِحۡدَى ٱلۡكُبَرِ ۝٣٥﴾ الْبَلَايَا الْعِظَام"
  74,36,"﴿نَذِیرࣰا﴾ حَال مِنْ إحْدَى وَذُكِّرَ لِأَنَّهَا بِمَعْنَى العذاب ﴿لِّلۡبَشَرِ ۝٣٦﴾"
  74,37,"﴿لِمَن شَاۤءَ مِنكُمۡ﴾ بَدَل مِنْ الْبَشَر ﴿أَن یَتَقَدَّمَ﴾ إلَى الْخَيْر أَوْ الْجَنَّة بِالْإِيمَانِ ﴿أَوۡ یَتَأَخَّرَ ۝٣٧﴾ إلَى الشَّرّ أَوْ النَّار بِالْكُفْرِ"
  74,38,"﴿كُلُّ نَفۡسِۭ بِمَا كَسَبَتۡ رَهِینَةٌ ۝٣٨﴾ مَرْهُونَة مَأْخُوذَة بِعَمَلِهَا فِي النَّار"
  74,39,"﴿إِلَّاۤ أَصۡحَـٰبَ ٱلۡیَمِینِ ۝٣٩﴾ وَهُمْ الْمُؤْمِنُونَ فَنَاجُونَ مِنْهَا كائنون"
  74,40,"﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠﴾ بَيْنهمْ"
  74,41,"﴿عَنِ ٱلۡمُجۡرِمِینَ ۝٤١﴾ وَحَالهمْ وَيَقُولُونَ لَهُمْ بَعْد إخْرَاج الموحدين من النار"
  74,42,"﴿مَا سَلَكَكُمۡ﴾ أدخلكم ﴿فِی سَقَرَ ۝٤٢﴾"
  74,43,"﴿قَالُوا۟ لَمۡ نَكُ مِنَ ٱلۡمُصَلِّینَ ۝٤٣﴾"
  74,44,"﴿وَلَمۡ نَكُ نُطۡعِمُ ٱلۡمِسۡكِینَ ۝٤٤﴾"
  74,45,"﴿وَكُنَّا نَخُوضُ﴾ في الباطل ﴿مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥﴾"
  74,46,"﴿وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾ الْبَعْث وَالْجَزَاء"
  74,47,"﴿حَتَّىٰۤ أَتَىٰنَا ٱلۡیَقِینُ ۝٤٧﴾ الْمَوْت"
  74,48,"﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾ مِنْ الْمَلَائِكَة وَالْأَنْبِيَاء وَالصَّالِحِينَ وَالْمَعْنَى لَا شَفَاعَة لَهُمْ"
  74,49,"﴿فَمَا﴾ مُبْتَدَأ ﴿لَهُمۡ﴾ خَبَره مُتَعَلِّق بِمَحْذُوفٍ انْتَقَلَ ضَمِيره إلَيْهِ ﴿عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾ حَال مِنْ الضَّمِير وَالْمَعْنَى أَيّ شَيْء حَصَلَ لَهُمْ فِي إعْرَاضهمْ عَنْ الِاتِّعَاظ"
  74,50,"﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾ وَحْشِيَّة"
  74,51,"﴿فَرَّتۡ مِن قَسۡوَرَةِۭ ۝٥١﴾ أَسَد أَيْ هَرَبَتْ مِنْهُ أشد الهرب"
  74,52,"﴿بَلۡ یُرِیدُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُؤۡتَىٰ صُحُفࣰا مُّنَشَّرَةࣰ ۝٥٢﴾ أَيْ مِنْ اللَّه تَعَالَى بِاتِّبَاعِ النَّبِيّ كَمَا قَالُوا {وَلَن نُّؤۡمِنَ لِرُقِیِّكَ حَتَّىٰ تُنَزِّلَ عَلَیۡنَا كِتَـٰبࣰا نَّقۡرَؤُهُۥۗ}"
  74,53,"﴿كَلَّاۖ﴾ رَدْع عَمَّا أَرَادُوهُ ﴿بَل لَّا یَخَافُونَ ٱلۡـَٔاخِرَةَ ۝٥٣﴾ أَيْ عَذَابهَا"
  74,54,"﴿كَلَّاۤ﴾ اسْتِفْتَاح ﴿إِنَّهُۥ﴾ أَيْ الْقُرْآن ﴿تَذۡكِرَةࣱ ۝٥٤﴾ عِظَة"
  74,55,"﴿فَمَن شَاۤءَ ذَكَرَهُۥ ۝٥٥﴾ قَرَأَهُ فَاتَّعَظَ بِهِ"
  74,56,"﴿وَمَا یَذۡكُرُونَ﴾ بِالْيَاءِ وَالتَّاء ﴿إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ﴾ بِأَنْ يُتَّقَى ﴿وَأَهۡلُ ٱلۡمَغۡفِرَةِ ۝٥٦﴾ بأن يغفر لمن اتقاه"
