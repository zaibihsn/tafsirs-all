tafsir[49]{c,v,t}:
  52,1,"﴿وَٱلطُّورِ ۝١﴾ أَيْ الْجَبَل الَّذِي كَلَّمَ اللَّه عَلَيْهِ موسى"
  52,2,"﴿وَكِتَـٰبࣲ مَّسۡطُورࣲ ۝٢﴾"
  52,3,"﴿فِی رَقࣲّ مَّنشُورࣲ ۝٣﴾ أَيْ التَّوْرَاة أَوْ الْقُرْآن"
  52,4,"﴿وَٱلۡبَیۡتِ ٱلۡمَعۡمُورِ ۝٤﴾ هُوَ فِي السَّمَاء الثَّالِثَة أَوْ السَّادِسَة أَوْ السَّابِعَة بِحِيَالِ الْكَعْبَة يَزُورهُ كُلّ يَوْم سَبْعُونَ أَلْف مَلَك بِالطَّوَافِ وَالصَّلَاة لَا يَعُودُونَ إلَيْهِ أَبَدًا"
  52,5,"﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ ۝٥﴾ أَيْ السَّمَاء"
  52,6,"﴿وَٱلۡبَحۡرِ ٱلۡمَسۡجُورِ ۝٦﴾ أَيْ الْمَمْلُوء"
  52,7,"﴿إِنَّ عَذَابَ رَبِّكَ لَوَ ٰ⁠قِعࣱ ۝٧﴾ لَنَازِل بِمُسْتَحِقِّهِ"
  52,8,"﴿مَّا لَهُۥ مِن دَافِعࣲ ۝٨﴾ عَنْهُ"
  52,9,"﴿یَوۡمَ﴾ مَعْمُول لَوَاقِع ﴿تَمُورُ ٱلسَّمَاۤءُ مَوۡرࣰا ۝٩﴾ تَتَحَرَّك وتدور"
  52,10,"﴿وَتَسِیرُ ٱلۡجِبَالُ سَیۡرࣰا ۝١٠﴾ تَصِير هَبَاء مَنْثُورًا وَذَلِكَ فِي يَوْم الْقِيَامَة"
  52,11,"﴿فَوَیۡلࣱ﴾ شدة عذاب ﴿یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١١﴾ للرسل"
  52,12,"﴿ٱلَّذِینَ هُمۡ فِی خَوۡضࣲ﴾ بَاطِل ﴿یَلۡعَبُونَ ۝١٢﴾ أَيْ يَتَشَاغَلُونَ بِكُفْرِهِمْ"
  52,13,"﴿یَوۡمَ یُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا ۝١٣﴾ يُدْفَعُونَ بِعُنْفٍ بَدَل مِنْ يَوْم تَمُور وَيُقَال لَهُمْ تَبْكِيتًا"
  52,14,"﴿هَـٰذِهِ ٱلنَّارُ ٱلَّتِی كُنتُم بِهَا تُكَذِّبُونَ ۝١٤﴾"
  52,15,"﴿أَفَسِحۡرٌ هَـٰذَاۤ﴾ الْعَذَاب الَّذِي تَرَوْنَ كَمَا كُنْتُمْ تقولون في الوحي هذا سحر ﴿أَمۡ أَنتُمۡ لَا تُبۡصِرُونَ ۝١٥﴾"
  52,16,"﴿ٱصۡلَوۡهَا فَٱصۡبِرُوۤا۟﴾ عَلَيْهَا ﴿أَوۡ لَا تَصۡبِرُوا۟﴾ صَبْركُمْ وَجَزَعكُمْ ﴿سَوَاۤءٌ عَلَیۡكُمۡۖ﴾ لِأَنَّ صَبْركُمْ لَا يَنْفَعكُمْ ﴿إِنَّمَا تُجۡزَوۡنَ مَا كُنتُمۡ تَعۡمَلُونَ ۝١٦﴾ أَيْ جَزَاءَهُ"
  52,17,"﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَعِیمࣲ ۝١٧﴾"
  52,18,"﴿فَـٰكِهِینَ﴾ مُتَلَذِّذِينَ ﴿بِمَاۤ﴾ مَصْدَرِيَّة ﴿ءَاتَىٰهُمۡ﴾ أَعْطَاهُمْ ﴿رَبُّهُمۡ وَوَقَىٰهُمۡ رَبُّهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝١٨﴾ عَطْفًا عَلَى آتَاهُمْ أَيْ بِإِتْيَانِهِمْ وَوِقَايَتهمْ وَيُقَال لَهُمْ"
  52,19,"﴿كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا﴾ حَال أَيْ مُهَنَّئِينَ ﴿بِمَا﴾ الباء سببية ﴿كُنتُمۡ تَعۡمَلُونَ ۝١٩﴾"
  52,20,"﴿مُتَّكِـِٔینَ﴾ حَال مِنْ الضَّمِير الْمُسْتَكِن فِي قَوْله {فِی جَنَّـٰتࣲ} ﴿عَلَىٰ سُرُرࣲ مَّصۡفُوفَةࣲۖ﴾ بَعْضهَا إلَى جَنْب بَعْض ﴿وَزَوَّجۡنَـٰهُم﴾ عُطِفَ عَلَى جَنَّات أَيْ قَرَنَّاهُمْ ﴿بِحُورٍ عِینࣲ ۝٢٠﴾ عِظَام الْأَعْيُن حِسَانهَا"
  52,21,"﴿وَٱلَّذِینَ ءَامَنُوا۟﴾ مبتدأ ﴿وَأَتۡبَعۡنَـٰهُمۡ﴾ وَفِي قِرَاءَة {وَٱتَّبَعَتۡهُمۡ} مَعْطُوف عَلَى {ءَامَنُوا۟} ﴿ذُرِّیَّـٰتِهِم﴾ وَفِي قِرَاءَة {ذُرِّیَّتُهُم} الصِّغَار وَالْكِبَار ﴿بِإِیمَـٰنٍ﴾ مِنْ الكبار ومن أولادهم الصغار والخبر ﴿أَلۡحَقۡنَا بِهِمۡ ذُرِّیَّـٰتِهِمۡ﴾ الْمَذْكُورِينَ فِي الْجَنَّة فَيَكُونُونَ فِي دَرَجَتهمْ وَإِنْ لَمْ يَعْمَلُوا تَكْرِمَة لِلْآبَاءِ بِاجْتِمَاعِ الْأَوْلَاد إلَيْهِمْ ﴿وَمَاۤ أَلَتۡنَـٰهُم﴾ بِفَتْحِ اللَّام وَكَسْرهَا نَقَصْنَاهُمْ ﴿مِّنۡ عَمَلِهِم مِّن﴾ زَائِدَة ﴿شَیۡءࣲۚ﴾ يُزَاد فِي عَمَل الْأَوْلَاد ﴿كُلُّ ٱمۡرِىِٕۭ بِمَا كَسَبَ﴾ مِنْ عَمَلٍ خَيْر أَوْ شَرّ ﴿رَهِینࣱ ۝٢١﴾ مَرْهُون يُؤَاخَذ بِالشَّرِّ ويجازي بالخير"
  52,22,"﴿وَأَمۡدَدۡنَـٰهُم﴾ زِدْنَاهُمْ فِي وَقْت بَعْد وَقْت ﴿بِفَـٰكِهَةࣲ وَلَحۡمࣲ مِّمَّا یَشۡتَهُونَ ۝٢٢﴾ وَإِنْ لَمْ يُصَرِّحُوا بِطَلَبِهِ"
  52,23,"﴿یَتَنَـٰزَعُونَ﴾ يَتَعَاطَوْنَ بَيْنهمْ ﴿فِیهَا﴾ أَيْ الْجَنَّة ﴿كَأۡسࣰا﴾ خَمْرًا ﴿لَّا لَغۡوࣱ فِیهَا﴾ أَيْ بِسَبَبِ شُرْبهَا يَقَع بَيْنهمْ ﴿وَلَا تَأۡثِیمࣱ ۝٢٣﴾ بِهِ يَلْحَقهُمْ بِخِلَافِ خمر الدنيا"
  52,24,"﴿وَیَطُوفُ عَلَیۡهِمۡ﴾ لِلْخِدْمَةِ ﴿غِلۡمَانࣱ﴾ أَرِقَّاء ﴿لَّهُمۡ كَأَنَّهُمۡ﴾ حُسْنًا وَلَطَافَة ﴿لُؤۡلُؤࣱ مَّكۡنُونࣱ ۝٢٤﴾ مَصُون فِي الصَّدَف لِأَنَّهُ فِيهَا أَحْسَن مِنْهُ فِي غَيْرهَا"
  52,25,"﴿وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ ۝٢٥﴾ يَسْأَل بَعْضهمْ بَعْضًا عَمَّا كَانُوا عَلَيْهِ وَمَا وَصَلُوا إلَيْهِ تَلَذُّذًا وَاعْتِرَافًا بِالنِّعْمَةِ"
  52,26,"﴿قَالُوۤا۟﴾ إيمَاء إلَى عِلَّة الْوُصُول ﴿إِنَّا كُنَّا قَبۡلُ فِیۤ أَهۡلِنَا﴾ فِي الدُّنْيَا ﴿مُشۡفِقِینَ ۝٢٦﴾ خَائِفِينَ مِنْ عَذَاب اللَّه"
  52,27,"﴿فَمَنَّ ٱللَّهُ عَلَیۡنَا﴾ بِالْمَغْفِرَةِ ﴿وَوَقَىٰنَا عَذَابَ ٱلسَّمُومِ ۝٢٧﴾ النَّار لِدُخُولِهَا فِي الْمَسَامّ وَقَالُوا إيمَاء أَيْضًا"
  52,28,"﴿إِنَّا كُنَّا مِن قَبۡلُ﴾ أَيْ فِي الدُّنْيَا ﴿نَدۡعُوهُۖ﴾ نَعْبُدهُ مُوَحِّدِينَ ﴿إِنَّهُۥ﴾ بِالْكَسْرِ اسْتِئْنَافًا وَإِنْ كَانَ تَعْلِيلًا مَعْنَى وَبِالْفَتْحِ تَعْلِيلًا لَفْظًا ﴿هُوَ ٱلۡبَرُّ﴾ الْمُحْسِن الصَّادِق فِي وَعْده ﴿ٱلرَّحِیمُ ۝٢٨﴾ الْعَظِيم الرحمة"
  52,29,"﴿فَذَكِّرۡ﴾ دُمْ عَلَى تَذْكِير الْمُشْرِكِينَ وَلَا تَرْجِع عَنْهُ لِقَوْلِهِمْ لَك كَاهِن مَجْنُون ﴿فَمَاۤ أَنتَ بِنِعۡمَتِ رَبِّكَ﴾ بِإِنْعَامِهِ عَلَيْك ﴿بِكَاهِنࣲ﴾ خَبَر مَا ﴿وَلَا مَجۡنُونٍ ۝٢٩﴾ مَعْطُوف عَلَيْهِ"
  52,30,"﴿أَمۡ﴾ بَلْ ﴿یَقُولُونَ﴾ هُوَ ﴿شَاعِرࣱ نَّتَرَبَّصُ بِهِۦ رَیۡبَ ٱلۡمَنُونِ ۝٣٠﴾ حَوَادِث الدَّهْر فَيَهْلَك كَغَيْرِهِ مِنْ الشعراء"
  52,31,"﴿قُلۡ تَرَبَّصُوا۟﴾ هَلَاكِي ﴿فَإِنِّی مَعَكُم مِّنَ ٱلۡمُتَرَبِّصِینَ ۝٣١﴾ هَلَاككُمْ فَعُذِّبُوا بِالسَّيْفِ يَوْم بَدْر وَالتَّرَبُّص الِانْتِظَار"
  52,32,"﴿أَمۡ تَأۡمُرُهُمۡ أَحۡلَـٰمُهُم﴾ عُقُولهمْ ﴿بِهَـٰذَاۤۚ﴾ قَوْلهمْ لَهُ سَاحِر كَاهِن مَجْنُون أَيْ لَا تَأْمُرهُمْ بِذَلِكَ ﴿أَمۡ﴾ بَلْ ﴿هُمۡ قَوۡمࣱ طَاغُونَ ۝٣٢﴾ بِعِنَادِهِمْ"
  52,33,"﴿أَمۡ یَقُولُونَ تَقَوَّلَهُۥۚ﴾ اخْتَلَقَ الْقُرْآن لَمْ يَخْتَلِقهُ ﴿بَل لَّا یُؤۡمِنُونَ ۝٣٣﴾ اسْتِكْبَارًا فَإِنْ قَالُوا اخْتَلَقَهُ"
  52,34,"﴿فَلۡیَأۡتُوا۟ بِحَدِیثࣲ﴾ مُخْتَلَق ﴿مِّثۡلِهِۦۤ إِن كَانُوا۟ صَـٰدِقِینَ ۝٣٤﴾ في قولهم"
  52,35,"﴿أَمۡ خُلِقُوا۟ مِنۡ غَیۡرِ شَیۡءٍ﴾ مِنْ غَيْر خَالِق ﴿أَمۡ هُمُ ٱلۡخَـٰلِقُونَ ۝٣٥﴾ أَنْفُسهمْ وَلَا يُعْقَل مَخْلُوق بِغَيْرِ خَالِق وَلَا مَعْدُوم يَخْلُق فَلَا بُدّ لَهُمْ مِنْ خَالِق هُوَ اللَّه الْوَاحِد فَلِمَ لَا يُوَحِّدُونَهُ وَيُؤْمِنُونَ بِرَسُولِهِ وَكِتَابه"
  52,36,"﴿أَمۡ خَلَقُوا۟ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَۚ﴾ وَلَا يَقْدِر عَلَى خَلْقهمَا إلَّا اللَّه الْخَالِق فَلِمَ لَا يَعْبُدُونَهُ ﴿بَل لَّا یُوقِنُونَ ۝٣٦﴾ بِهِ وَإِلَّا لَآمَنُوا بِنَبِيِّهِ"
  52,37,"﴿أَمۡ عِندَهُمۡ خَزَاۤىِٕنُ رَبِّكَ﴾ مِنْ النُّبُوَّة وَالرِّزْق وَغَيْرهمَا فَيَخُصُّوا مَنْ شَاءُوا بِمَا شَاءُوا ﴿أَمۡ هُمُ ٱلۡمُصَۣیۡطِرُونَ﴾ الْمُتَسَلِّطُونَ الْجَبَّارُونَ وَفِعْله سَيْطَرَ وَمِثْله بيطر وبيقر"
  52,38,"﴿أَمۡ لَهُمۡ سُلَّمࣱ﴾ مَرْقَى إلَى السَّمَاء ﴿یَسۡتَمِعُونَ فِیهِۖ﴾ أَيْ عَلَيْهِ كَلَام الْمَلَائِكَة حَتَّى يُمْكِنهُمْ مُنَازَعَة النَّبِيّ بِزَعْمِهِمْ إِنِ ادَّعَوْا ذَلِكَ ﴿فَلۡیَأۡتِ مُسۡتَمِعُهُم﴾ مُدَّعِي الِاسْتِمَاع عَلَيْهِ ﴿بِسُلۡطَـٰنࣲ مُّبِینٍ ۝٣٨﴾ بِحُجَّةٍ بَيِّنَة وَاضِحَة وَلِشِبْهِ هَذَا الزَّعْم بِزَعْمِهِمْ أَنَّ الملائكة بنات الله"
  52,39,"قال تعالى ﴿أَمۡ لَهُ ٱلۡبَنَـٰتُ﴾ بِزَعْمِكُمْ ﴿وَلَكُمُ ٱلۡبَنُونَ ۝٣٩﴾ تَعَالَى اللَّه عَمَّا زَعَمْتُمُوهُ"
  52,40,"﴿أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا﴾ على ما جئتهم بِهِ مِنْ الدِّين ﴿فَهُم مِّن مَّغۡرَمࣲ﴾ غُرْم ذَلِكَ ﴿مُّثۡقَلُونَ ۝٤٠﴾ فَلَا يُسْلِمُونَ"
  52,41,"﴿أَمۡ عِندَهُمُ ٱلۡغَیۡبُ﴾ أَيْ عِلْمه ﴿فَهُمۡ یَكۡتُبُونَ ۝٤١﴾ ذَلِكَ حَتَّى يُمْكِنهُمْ مُنَازَعَة النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ فِي الْبَعْث وَأُمُور الْآخِرَة بِزَعْمِهِمْ"
  52,42,"﴿أَمۡ یُرِیدُونَ كَیۡدࣰاۖ﴾ بِك لِيُهْلِكُوك فِي دَار النَّدْوَة ﴿فَٱلَّذِینَ كَفَرُوا۟ هُمُ ٱلۡمَكِیدُونَ ۝٤٢﴾ الْمَغْلُوبُونَ الْمُهْلَكُونَ فَحَفِظَهُ اللَّه مِنْهُمْ ثُمَّ أَهْلَكَهُمْ بِبَدْرٍ"
  52,43,"﴿أَمۡ لَهُمۡ إِلَـٰهٌ غَیۡرُ ٱللَّهِۚ سُبۡحَـٰنَ ٱللَّهِ عَمَّا یُشۡرِكُونَ ۝٤٣﴾ بِهِ مِنْ الْآلِهَة وَالِاسْتِفْهَام بِأَمْ فِي مَوَاضِعهَا لِلتَّقْبِيحِ وَالتَّوْبِيخ"
  52,44,"﴿وَإِن یَرَوۡا۟ كِسۡفࣰا﴾ بَعْضًا ﴿مِّنَ ٱلسَّمَاۤءِ سَاقِطࣰا﴾ عَلَيْهِمْ كَمَا قَالُوا {فَأَسۡقِطۡ عَلَیۡنَا كِسۡفࣰا مِّنَ ٱلسَّمَاۤءِ} أَيْ تَعْذِيبًا لَهُمْ ﴿یَقُولُوا۟﴾ هَذَا ﴿سَحَابࣱ مَّرۡكُومࣱ ۝٤٤﴾ مُتَرَاكِب نُرْوَى بِهِ وَلَا يُؤْمِنُونَ"
  52,45,"﴿فَذَرۡهُمۡ حَتَّىٰ یُلَـٰقُوا۟ یَوۡمَهُمُ ٱلَّذِی فِیهِ یُصۡعَقُونَ ۝٤٥﴾ يموتون"
  52,46,"﴿یَوۡمَ لَا یُغۡنِی﴾ بَدَل مِنْ يَوْمَهُمُ ﴿عَنۡهُمۡ كَیۡدُهُمۡ شَیۡـࣰٔا وَلَا هُمۡ یُنصَرُونَ ۝٤٦﴾ يُمْنَعُونَ مِنْ الْعَذَاب فِي الْآخِرَة"
  52,47,"﴿وَإِنَّ لِلَّذِینَ ظَلَمُوا۟﴾ بِكُفْرِهِمْ ﴿عَذَابࣰا دُونَ ذَ ٰ⁠لِكَ﴾ فِي الدُّنْيَا قَبْل مَوْتهمْ فَعُذِّبُوا بِالْجُوعِ وَالْقَحْط سَبْع سِنِينَ وَبِالْقَتْلِ يَوْم بَدْر ﴿وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَعۡلَمُونَ ۝٤٧﴾ أَنَّ الْعَذَاب يَنْزِل بِهِمْ"
  52,48,"﴿وَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ﴾ بِإِمْهَالِهِمْ وَلَا يَضِقْ صَدْرك ﴿فَإِنَّكَ بِأَعۡیُنِنَاۖ﴾ بِمَرْأًى مِنَّا نَرَاك وَنَحْفَظك ﴿وَسَبِّحۡ﴾ مُتَلَبِّسًا ﴿بِحَمۡدِ رَبِّكَ﴾ أَيْ قُلْ سُبْحَان اللَّه وَبِحَمْدِهِ ﴿حِینَ تَقُومُ ۝٤٨﴾ مِنْ مَنَامك أَوْ مِنْ مجلسك"
  52,49,"﴿وَمِنَ ٱلَّیۡلِ فَسَبِّحۡهُ﴾ حَقِيقَة أَيْضًا ﴿وَإِدۡبَـٰرَ ٱلنُّجُومِ ۝٤٩﴾ مَصْدَر أَيْ عَقِب غُرُوبهَا سَبِّحْهُ أَيْضًا أَوْ صَلِّ فِي الْأَوَّل الْعِشَاءَيْنِ وَفِي الثَّانِي الْفَجْر وقيل الصبح"
