tafsir[60]{c,v,t}:
  51,1,"﴿وَٱلذَّ ٰ⁠رِیَـٰتِ﴾ الرِّيَاح تَذْرُو التُّرَاب وَغَيْره ﴿ذَرۡوࣰا ۝١﴾ مَصْدَر وَيُقَال تَذْرِيهِ ذَرْيًا تَهُبّ بِهِ"
  51,2,"﴿فَٱلۡحَـٰمِلَـٰتِ﴾ السُّحُب تَحْمِل الْمَاء ﴿وِقۡرࣰا ۝٢﴾ ثِقَلًا مَفْعُول الحاملات"
  51,3,"﴿فَٱلۡجَـٰرِیَـٰتِ﴾ السُّفُن تَجْرِي عَلَى وَجْه الْمَاء ﴿یُسۡرࣰا ۝٣﴾ بِسُهُولَةٍ مَصْدَر فِي مَوْضِع الْحَال أَيْ مُيَسَّرَة"
  51,4,"﴿فَٱلۡمُقَسِّمَـٰتِ أَمۡرًا ۝٤﴾ الْمَلَائِكَة تَقْسِم الْأَرْزَاق وَالْأَمْطَار وَغَيْرهَا بَيْن الْبِلَاد وَالْعِبَاد"
  51,5,"﴿إِنَّمَا تُوعَدُونَ﴾ مَا مَصْدَرِيَّة أَيْ وَعْدهمْ بِالْبَعْثِ وَغَيْره ﴿لَصَادِقࣱ ۝٥﴾ لَوَعْد صَادِق"
  51,6,"﴿وَإِنَّ ٱلدِّینَ﴾ الْجَزَاء بَعْد الْحِسَاب ﴿لَوَ ٰ⁠قِعࣱ ۝٦﴾ لَا محالة"
  51,7,"﴿وَٱلسَّمَاۤءِ ذَاتِ ٱلۡحُبُكِ ۝٧﴾ جَمْع حَبِيكَة كَطَرِيقَةٍ وَطَرِيق أَيْ صَاحِبَة الطُّرُق فِي الْخِلْقَة كَالطَّرِيقِ فِي الرمل"
  51,8,"﴿إِنَّكُمۡ﴾ يَا أَهْل مَكَّة فِي شَأْن النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ وَالْقُرْآن ﴿لَفِی قَوۡلࣲ مُّخۡتَلِفࣲ ۝٨﴾ قِيلَ شَاعِر سَاحِر كَاهِن شِعْر سِحْر كهانة"
  51,9,"﴿یُؤۡفَكُ﴾ يُصْرَف ﴿عَنۡهُ﴾ عَنْ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ وَالْقُرْآن أَيْ عَنْ الْإِيمَان بِهِ ﴿مَنۡ أُفِكَ ۝٩﴾ صُرِفَ عَنْ الْهِدَايَة فِي عِلْم الله تعالى"
  51,10,"﴿قُتِلَ ٱلۡخَرَّ ٰ⁠صُونَ ۝١٠﴾ لُعِنَ الْكَذَّابُونَ أَصْحَاب الْقَوْل الْمُخْتَلِف"
  51,11,"﴿ٱلَّذِینَ هُمۡ فِی غَمۡرَةࣲ﴾ جَهْل يَغْمُرهُمْ ﴿سَاهُونَ ۝١١﴾ غَافِلُونَ عَنْ أَمْر الْآخِرَة"
  51,12,"﴿یَسۡـَٔلُونَ﴾ النَّبِيّ اسْتِفْهَام اسْتِهْزَاء ﴿أَیَّانَ یَوۡمُ ٱلدِّینِ ۝١٢﴾ أَيْ مَتَى مَجِيئُهُ وَجَوَابهمْ يَجِيء"
  51,13,"﴿یَوۡمَ هُمۡ عَلَى ٱلنَّارِ یُفۡتَنُونَ ۝١٣﴾ أَيْ يُعَذَّبُونَ فِيهَا وَيُقَال لَهُمْ حِين التَّعْذِيب"
  51,14,"﴿ذُوقُوا۟ فِتۡنَتَكُمۡ﴾ تَعْذِيبكُمْ ﴿هَـٰذَا﴾ التَّعْذِيب ﴿ٱلَّذِی كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ ۝١٤﴾ فِي الدُّنْيَا اسْتِهْزَاء"
  51,15,"﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ﴾ بَسَاتِين ﴿وَعُیُونٍ ۝١٥﴾ تَجْرِي فيها"
  51,16,"﴿ءَاخِذِینَ﴾ حَال مِنْ الضَّمِير فِي خَبَر إنَّ ﴿مَاۤ ءَاتَىٰهُمۡ﴾ أَعْطَاهُمْ ﴿رَبُّهُمۡۚ﴾ مِنْ الثَّوَاب ﴿إِنَّهُمۡ كَانُوا۟ قَبۡلَ ذَ ٰ⁠لِكَ﴾ أي دخلوهم الْجَنَّة ﴿مُحۡسِنِینَ ۝١٦﴾ فِي الدُّنْيَا"
  51,17,"﴿كَانُوا۟ قَلِیلࣰا مِّنَ ٱلَّیۡلِ مَا یَهۡجَعُونَ ۝١٧﴾ يَنَامُونَ وَمَا زَائِدَة وَيَهْجَعُونَ خَبَر كَانَ وَقَلِيلًا ظَرْف أَيْ يَنَامُونَ فِي زَمَن يَسِير مِنْ اللَّيْل ويصلون أكثره"
  51,18,"﴿وَبِٱلۡأَسۡحَارِ هُمۡ یَسۡتَغۡفِرُونَ ۝١٨﴾ يَقُولُونَ اللَّهُمَّ اغْفِرْ لَنَا"
  51,19,"﴿وَفِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝١٩﴾ الَّذِي لَا يسأل لتعففه"
  51,20,"﴿وَفِی ٱلۡأَرۡضِ﴾ مِنْ الْجِبَال وَالْبِحَار وَالْأَشْجَار وَالثِّمَار وَالنَّبَات وَغَيْرهَا ﴿ءَایَـٰتࣱ﴾ دَلَالَات عَلَى قُدْرَة اللَّه سبحانه وتعالى ووحدانيته ﴿لِّلۡمُوقِنِینَ ۝٢٠﴾"
  51,21,"﴿وَفِیۤ أَنفُسِكُمۡۚ﴾ آيَات أَيْضًا مِنْ مَبْدَأ خَلْقكُمْ إلَى مُنْتَهَاهُ وَمَا فِي تَرْكِيب خَلْقكُمْ مِنْ الْعَجَائِب ﴿أَفَلَا تُبۡصِرُونَ ۝٢١﴾ ذَلِكَ فَتَسْتَدِلُّونَ بِهِ عَلَى صانعه وقدرته"
  51,22,"﴿وَفِی ٱلسَّمَاۤءِ رِزۡقُكُمۡ﴾ أَيْ الْمَطَر الْمُسَبَّب عَنْهُ النَّبَات الَّذِي هُوَ رِزْق ﴿وَمَا تُوعَدُونَ ۝٢٢﴾ مِنْ الْمَآب وَالثَّوَاب وَالْعِقَاب أَيْ مَكْتُوب ذَلِكَ فِي السماء"
  51,23,"﴿فَوَرَبِّ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِ إِنَّهُۥ﴾ أَيْ مَا تُوعَدُونَ ﴿لَحَقࣱّ مِّثۡلُ مَاۤ أَنَّكُمۡ تَنطِقُونَ ۝٢٣﴾ بِرَفْعِ مِثْل صِفَة وَمَا مَزِيدَة وَبِفَتْحِ اللَّام مُرَكَّبَة مَعَ مَا الْمَعْنَى مِثْل نُطْقكُمْ فِي حَقِيقَته أَيْ مَعْلُومِيَّته عِنْدكُمْ ضَرُورَة صُدُوره عَنْكُمْ"
  51,24,"﴿هَلۡ أَتَىٰكَ﴾ خِطَاب لِلنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿حَدِیثُ ضَیۡفِ إِبۡرَ ٰ⁠هِیمَ ٱلۡمُكۡرَمِینَ ۝٢٤﴾ وَهُمْ مَلَائِكَة اثْنَا عَشَر أَوْ عَشْرَة أَوْ ثَلَاثَة مِنْهُمْ جبريل"
  51,25,"﴿إِذۡ﴾ ظَرْف لِحَدِيثِ ضَيْف ﴿دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰاۖ﴾ أَيْ هَذَا اللَّفْظ ﴿قَالَ سَلَـٰمࣱ﴾ أَيْ هَذَا اللَّفْظ ﴿قَوۡمࣱ مُّنكَرُونَ ۝٢٥﴾ لَا نَعْرِفهُمْ قَالَ ذَلِكَ فِي نَفْسه وَهُوَ خَبَر مُبْتَدَأ مُقَدَّر أي هؤلاء"
  51,26,"﴿فَرَاغَ﴾ مَالَ ﴿إِلَىٰۤ أَهۡلِهِۦ﴾ سِرًّا ﴿فَجَاۤءَ بِعِجۡلࣲ سَمِینࣲ ۝٢٦﴾ وَفِي سُورَة هُود {بِعِجۡلٍ حَنِیذࣲ} أَيْ مشوي"
  51,27,"﴿فَقَرَّبَهُۥۤ إِلَیۡهِمۡ قَالَ أَلَا تَأۡكُلُونَ ۝٢٧﴾ عَرَضَ عَلَيْهِمْ الْأَكْل فَلَمْ يُجِيبُوا"
  51,28,"﴿فَأَوۡجَسَ﴾ أَضْمَرَ فِي نَفْسه ﴿مِنۡهُمۡ خِیفَةࣰۖ قَالُوا۟ لَا تَخَفۡۖ﴾ إنَّا رُسُل رَبّك ﴿وَبَشَّرُوهُ بِغُلَـٰمٍ عَلِیمࣲ ۝٢٨﴾ ذِي عِلْم كَثِير وَهُوَ إسْحَاق كَمَا ذُكِرَ فِي هُود"
  51,29,"﴿فَأَقۡبَلَتِ ٱمۡرَأَتُهُۥ﴾ سَارَّة ﴿فِی صَرَّةࣲ﴾ صَيْحَة حَال أَيْ جَاءَتْ صَائِحَة ﴿فَصَكَّتۡ وَجۡهَهَا﴾ لَطَمَتْهُ ﴿وَقَالَتۡ عَجُوزٌ عَقِیمࣱ ۝٢٩﴾ لَمْ تَلِد قَطُّ وَعُمْرهَا تِسْع وَتِسْعُونَ سَنَة وَعُمْر إبْرَاهِيم مِائَة سَنَة أَوْ عُمْره مِائَة وَعِشْرُونَ سَنَة وَعُمْرهَا تِسْعُونَ سَنَة"
  51,30,"﴿قَالُوا۟ كَذَ ٰ⁠لِكِ﴾ أَيْ مِثْل قَوْلنَا فِي الْبِشَارَة ﴿قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ ٱلۡحَكِیمُ﴾ فِي صُنْعه ﴿ٱلۡعَلِیمُ ۝٣٠﴾ بخلقه"
  51,31,"﴿قَالَ فَمَا خَطۡبُكُمۡ﴾ شأنكم ﴿أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٣١﴾"
  51,32,"﴿قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٣٢﴾ كَافِرِينَ هُمْ قَوْم لُوط"
  51,33,"﴿لِنُرۡسِلَ عَلَیۡهِمۡ حِجَارَةࣰ مِّن طِینࣲ ۝٣٣﴾ مَطْبُوخ بِالنَّارِ"
  51,34,"﴿مُّسَوَّمَةً﴾ مُعَلَّمَة عَلَيْهَا اسْم مَنْ يُرْمَى بِهَا ﴿عِندَ رَبِّكَ﴾ ظَرْف لَهَا ﴿لِلۡمُسۡرِفِینَ ۝٣٤﴾ بِإِتْيَانِهِمْ الذُّكُور مع كفرهم"
  51,35,"﴿فَأَخۡرَجۡنَا مَن كَانَ فِیهَا﴾ أَيْ قُرَى قَوْم لُوط ﴿مِنَ ٱلۡمُؤۡمِنِینَ ۝٣٥﴾ لِإِهْلَاكِ الْكَافِرِينَ"
  51,36,"﴿فَمَا وَجَدۡنَا فِیهَا غَیۡرَ بَیۡتࣲ مِّنَ ٱلۡمُسۡلِمِینَ ۝٣٦﴾ وَهُمْ لُوط وَابْنَتَاهُ وُصِفُوا بِالْإِيمَانِ وَالْإِسْلَام أَيْ هُمْ مُصَدِّقُونَ بِقُلُوبِهِمْ عَامِلُونَ بِجَوَارِحِهِمْ الطَّاعَات"
  51,37,"﴿وَتَرَكۡنَا فِیهَاۤ﴾ بَعْد إهْلَاك الْكَافِرِينَ ﴿ءَایَةࣰ﴾ عَلَامَة عَلَى إهْلَاكهمْ ﴿لِّلَّذِینَ یَخَافُونَ ٱلۡعَذَابَ ٱلۡأَلِیمَ ۝٣٧﴾ فَلَا يَفْعَلُونَ مِثْل فِعْلهمْ"
  51,38,"﴿وَفِی مُوسَىٰۤ﴾ مَعْطُوف عَلَى فِيهَا الْمَعْنَى وَجَعَلْنَا فِي قِصَّة مُوسَى آيَة ﴿إِذۡ أَرۡسَلۡنَـٰهُ إِلَىٰ فِرۡعَوۡنَ﴾ مُلْتَبِسًا ﴿بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٣٨﴾ بِحُجَّةٍ وَاضِحَة"
  51,39,"﴿فَتَوَلَّىٰ﴾ أَعْرَضَ عَنْ الْإِيمَان ﴿بِرُكۡنِهِۦ﴾ مَعَ جُنُوده لِأَنَّهُمْ لَهُ كَالرُّكْنِ ﴿وَقَالَ﴾ لِمُوسَى هُوَ ﴿سَـٰحِرٌ أَوۡ مَجۡنُونࣱ ۝٣٩﴾"
  51,40,"﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ﴾ طَرَحْنَاهُمْ ﴿فِی ٱلۡیَمِّ﴾ الْبَحْر فَغَرِقُوا ﴿وَهُوَ﴾ أَيْ فِرْعَوْن ﴿مُلِیمࣱ ۝٤٠﴾ آتٍ بِمَا يُلَام عَلَيْهِ مِنْ تَكْذِيب الرُّسُل وَدَعْوَى الرُّبُوبِيَّة"
  51,41,"﴿وَفِی﴾ إهْلَاك ﴿عَادٍ﴾ آيَة ﴿إِذۡ أَرۡسَلۡنَا عَلَیۡهِمُ ٱلرِّیحَ ٱلۡعَقِیمَ ۝٤١﴾ هِيَ الَّتِي لَا خَيْر فِيهَا لِأَنَّهَا لَا تَحْمِل الْمَطَر وَلَا تُلَقِّح الشَّجَر وهي الدبور"
  51,42,"﴿مَا تَذَرُ مِن شَیۡءٍ﴾ نَفْس أَوْ مَال ﴿أَتَتۡ عَلَیۡهِ إِلَّا جَعَلَتۡهُ كَٱلرَّمِیمِ ۝٤٢﴾ كَالْبَالِي الْمُتَفَتِّت"
  51,43,"﴿وَفِی﴾ إهْلَاك ﴿ثَمُودَ﴾ آيَة ﴿إِذۡ قِیلَ لَهُمۡ﴾ بَعْد عَقْر النَّاقَة ﴿تَمَتَّعُوا۟ حَتَّىٰ حِینࣲ ۝٤٣﴾ إلَى انقضاء آجالكم كما في آية {تَمَتَّعُوا۟ فِی دَارِكُمۡ ثَلَـٰثَةَ أَیَّامࣲۖ}"
  51,44,"﴿فَعَتَوۡا۟﴾ تَكَبَّرُوا ﴿عَنۡ أَمۡرِ رَبِّهِمۡ﴾ أَيْ عَنْ امْتِثَاله ﴿فَأَخَذَتۡهُمُ ٱلصَّـٰعِقَةُ﴾ بَعْد مُضِيّ الثَّلَاثَة أَيَّام أَيْ الصَّيْحَة الْمُهْلِكَة ﴿وَهُمۡ یَنظُرُونَ ۝٤٤﴾ أَيْ بالنهار"
  51,45,"﴿فَمَا ٱسۡتَطَـٰعُوا۟ مِن قِیَامࣲ﴾ أَيْ مَا قَدَرُوا عَلَى النُّهُوض حِين نُزُول الْعَذَاب ﴿وَمَا كَانُوا۟ مُنتَصِرِینَ ۝٤٥﴾ عَلَى مَنْ أَهْلَكَهُمْ"
  51,46,"﴿وَقَوۡمِ نُوحࣲ﴾ بِالْجَرِّ عُطِفَ عَلَى ثَمُود أَيْ وَفِي إهْلَاكهمْ بِمَا فِي السَّمَاء وَالْأَرْض آيَة وَبِالنَّصْبِ أَيْ وَأَهْلَكْنَا قَوْمَ نُوح ﴿مِّن قَبۡلُۖ﴾ أي قبل إهلاك هؤلاء المذكورين ﴿إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٤٦﴾"
  51,47,"﴿وَٱلسَّمَاۤءَ بَنَیۡنَـٰهَا بِأَیۡی۟دࣲ﴾ بِقُوَّةٍ ﴿وَإِنَّا لَمُوسِعُونَ ۝٤٧﴾ قَادِرُونَ يُقَال آدَ الرَّجُل يَئِيد قَوِيَ وَأَوْسَعَ الرَّجُل صَارَ ذَا سِعَة وَقُوَّة"
  51,48,"﴿وَٱلۡأَرۡضَ فَرَشۡنَـٰهَا﴾ مَهَّدْنَاهَا ﴿فَنِعۡمَ ٱلۡمَـٰهِدُونَ ۝٤٨﴾ نَحْنُ"
  51,49,"﴿وَمِن كُلِّ شَیۡءٍ﴾ مُتَعَلِّق بِقَوْلِهِ خَلَقْنَا ﴿خَلَقۡنَا زَوۡجَیۡنِ﴾ صِنْفَيْنِ كَالذَّكَرِ وَالْأُنْثَى وَالسَّمَاء وَالْأَرْض وَالشَّمْس وَالْقَمَر وَالسَّهْل وَالْجَبَل وَالصَّيْف وَالشِّتَاء وَالْحُلْو وَالْحَامِض وَالنُّور وَالظُّلْمَة ﴿لَعَلَّكُمۡ تَذَكَّرُونَ ۝٤٩﴾ بِحَذْفِ إحْدَى التَّاءَيْنِ مِنْ الْأَصْل فَتَعْلَمُونَ أَنَّ خَالِق الْأَزْوَاج فَرْد فَتَعْبُدُوهُ"
  51,50,"﴿فَفِرُّوۤا۟ إِلَى ٱللَّهِۖ﴾ أَيْ إلَى ثَوَابه مِنْ عِقَابه بِأَنْ تُطِيعُوهُ وَلَا تَعْصُوهُ ﴿إِنِّی لَكُم مِّنۡهُ نَذِیرࣱ مُّبِینࣱ ۝٥٠﴾ بَيِّن الْإِنْذَار"
  51,51,"﴿وَلَا تَجۡعَلُوا۟ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَۖ إِنِّی لَكُم مِّنۡهُ نَذِیرࣱ مُّبِینࣱ ۝٥١﴾ يُقَدَّر قَبْل فَفِرُّوا قل لهم"
  51,52,"﴿كَذَ ٰ⁠لِكَ مَاۤ أَتَى ٱلَّذِینَ مِن قَبۡلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟﴾ هُوَ ﴿سَاحِرٌ أَوۡ مَجۡنُونٌ ۝٥٢﴾ أَيْ مِثْل تَكْذِيبهمْ لَك بِقَوْلِهِمْ إنَّك سَاحِر أَوْ مَجْنُون تَكْذِيب الْأُمَم قَبْلهمْ رُسُلهمْ بِقَوْلِهِمْ ذلك"
  51,53,"﴿أَتَوَاصَوۡا۟﴾ كلهم ﴿بِهِۦۚ﴾ اسْتِفْهَام بِمَعْنَى النَّفْي ﴿بَلۡ هُمۡ قَوۡمࣱ طَاغُونَ ۝٥٣﴾ جَمَعَهُمْ عَلَى هَذَا الْقَوْل طُغْيَانهمْ"
  51,54,"﴿فَتَوَلَّ﴾ أَعْرِضْ ﴿عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤﴾ لِأَنَّك بلغتهم الرسالة"
  51,55,"﴿وَذَكِّرۡ﴾ عِظْ بِالْقُرْآنِ ﴿فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾ مَنْ عَلِمَ اللَّه تَعَالَى أَنَّهُ يُؤْمِن"
  51,56,"﴿وَمَا خَلَقۡتُ ٱلۡجِنَّ وَٱلۡإِنسَ إِلَّا لِیَعۡبُدُونِ ۝٥٦﴾ وَلَا يُنَافِي ذَلِكَ عَدَم عِبَادَة الْكَافِرِينَ لِأَنَّ الْغَايَة لَا يَلْزَم وُجُودهَا كَمَا فِي قَوْلك بَرَيْت هَذَا الْقَلَم لِأَكْتُب بِهِ فَإِنَّك قَدْ لَا تكتب به"
  51,57,"﴿مَاۤ أُرِیدُ مِنۡهُم مِّن رِّزۡقࣲ﴾ لِي وَلِأَنْفُسِهِمْ وَغَيْرهمْ ﴿وَمَاۤ أُرِیدُ أَن یُطۡعِمُونِ ۝٥٧﴾ وَلَا أَنْفُسهمْ ولا غيرهم"
  51,58,"﴿إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلۡقُوَّةِ ٱلۡمَتِینُ ۝٥٨﴾ الشديد"
  51,59,"﴿فَإِنَّ لِلَّذِینَ ظَلَمُوا۟﴾ أَنْفُسهمْ بِالْكُفْرِ مِنْ أَهْل مَكَّة وَغَيْرهمْ ﴿ذَنُوبࣰا﴾ نَصِيبًا مِنْ الْعَذَاب ﴿مِّثۡلَ ذَنُوبِ﴾ نَصِيب ﴿أَصۡحَـٰبِهِمۡ﴾ الْهَالِكِينَ قَبْلهمْ ﴿فَلَا یَسۡتَعۡجِلُونِ ۝٥٩﴾ بِالْعَذَابِ إنْ أَخَّرْتهمْ إلَى يَوْم الْقِيَامَة"
  51,60,"﴿فَوَیۡلࣱ﴾ شِدَّة عَذَاب ﴿لِّلَّذِینَ كَفَرُوا۟ مِن﴾ فِي ﴿یَوۡمِهِمُ ٱلَّذِی یُوعَدُونَ ۝٦٠﴾ أَيْ يَوْم الْقِيَامَة"
