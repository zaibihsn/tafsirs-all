tafsir[129]{c,v,t}:
  9,1,"هَذِهِ ﴿بَرَاۤءَةࣱ مِّنَ ٱللَّهِ وَرَسُولِهِۦۤ﴾ وَاصِلَة ﴿إِلَى ٱلَّذِینَ عَـٰهَدتُّم مِّنَ ٱلۡمُشۡرِكِینَ ۝١﴾ عَهْدًا مُطْلَقًا أَوْ دُون أَرْبَعَة أَشْهُر أَوْ فَوْقهَا وَنَصّ الْعَهْد بِمَا يُذْكَر فِي قَوْله"
  9,2,"﴿فَسِیحُوا۟﴾ سِيرُوا آمِنِينَ أَيّهَا الْمُشْرِكُونَ ﴿فِی ٱلۡأَرۡضِ أَرۡبَعَةَ أَشۡهُرࣲ﴾ أَوَّلهَا شَوَّال بِدَلِيلِ مَا سَيَأْتِي وَلَا أَمَان لَكُمْ بَعْدهَا ﴿وَٱعۡلَمُوۤا۟ أَنَّكُمۡ غَیۡرُ مُعۡجِزِی ٱللَّهِ﴾ أَيْ فَائِتِي عَذَابه ﴿وَأَنَّ ٱللَّهَ مُخۡزِی ٱلۡكَـٰفِرِینَ ۝٢﴾ مُذِلّهمْ فِي الدُّنْيَا بِالْقَتْلِ وَالْأُخْرَى بالنار"
  9,3,"﴿وَأَذَ ٰ⁠نࣱ﴾ إعْلَام ﴿مِّنَ ٱللَّهِ وَرَسُولِهِۦۤ إِلَى ٱلنَّاسِ یَوۡمَ ٱلۡحَجِّ ٱلۡأَكۡبَرِ﴾ يَوْم النَّحْر ﴿أَنَّ﴾ أَيْ بِأَنَّ ﴿ٱللَّهَ بَرِیۤءࣱ مِّنَ ٱلۡمُشۡرِكِینَ﴾ وَعُهُودهمْ ﴿وَرَسُولُهُۥۚ﴾ بَرِيء أَيْضًا وَقَدْ بَعَثَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ عَلِيًّا مِنْ السَّنَة وَهِيَ سَنَة تسع فأذن يوم النحربمنى بِهَذِهِ الْآيَات وَأَنْ لَا يَحُجّ بَعْد الْعَام مُشْرِك وَلَا يَطُوف بِالْبَيْتِ عُرْيَان رَوَاهُ الْبُخَارِيّ ﴿فَإِن تُبۡتُمۡ﴾ مِنْ الْكُفْر ﴿فَهُوَ خَیۡرࣱ لَّكُمۡۖ وَإِن تَوَلَّیۡتُمۡ﴾ عَنْ الْإِيمَان ﴿فَٱعۡلَمُوۤا۟ أَنَّكُمۡ غَیۡرُ مُعۡجِزِی ٱللَّهِۗ وَبَشِّرِ﴾ أَخْبِرْ ﴿ٱلَّذِینَ كَفَرُوا۟ بِعَذَابٍ أَلِیمٍ ۝٣﴾ مُؤْلِم وَهُوَ الْقَتْل وَالْأَسْر فِي الدُّنْيَا وَالنَّار فِي الْآخِرَة"
  9,4,"﴿إِلَّا ٱلَّذِینَ عَـٰهَدتُّم مِّنَ ٱلۡمُشۡرِكِینَ ثُمَّ لَمۡ یَنقُصُوكُمۡ شَیۡـࣰٔا﴾ مِنْ شُرُوط الْعَهْد ﴿وَلَمۡ یُظَـٰهِرُوا۟﴾ يُعَاوِنُوا ﴿عَلَیۡكُمۡ أَحَدࣰا﴾ مِنْ الْكُفَّار ﴿فَأَتِمُّوۤا۟ إِلَیۡهِمۡ عَهۡدَهُمۡ إِلَىٰ﴾ انْقِضَاء ﴿مُدَّتِهِمۡۚ﴾ الَّتِي عَاهَدْتُمْ عَلَيْهَا ﴿إِنَّ ٱللَّهَ یُحِبُّ ٱلۡمُتَّقِینَ ۝٤﴾ بِإِتْمَامِ الْعُهُود"
  9,5,"﴿فَإِذَا ٱنسَلَخَ﴾ خَرَجَ ﴿ٱلۡأَشۡهُرُ ٱلۡحُرُمُ﴾ وَهِيَ آخِر مُدَّة التَّأْجِيل ﴿فَٱقۡتُلُوا۟ ٱلۡمُشۡرِكِینَ حَیۡثُ وَجَدتُّمُوهُمۡ﴾ فِي حِلّ أَوْ حَرَم ﴿وَخُذُوهُمۡ﴾ بِالْأَسْرِ ﴿وَٱحۡصُرُوهُمۡ﴾ فِي الْقِلَاع وَالْحُصُون حَتَّى يُضْطَرُّوا إلَى الْقَتْل أَوْ الْإِسْلَام ﴿وَٱقۡعُدُوا۟ لَهُمۡ كُلَّ مَرۡصَدࣲۚ﴾ طَرِيق يَسْلُكُونَهُ ونصب كل على نزع الخافظ ﴿فَإِن تَابُوا۟﴾ مِنْ الْكُفْر ﴿وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ فَخَلُّوا۟ سَبِیلَهُمۡۚ﴾ وَلَا تَتَعَرَّضُوا لَهُمْ ﴿إِنَّ ٱللَّهَ غَفُورࣱ رَّحِیمࣱ ۝٥﴾ لِمَنْ تَابَ"
  9,6,"﴿وَإِنۡ أَحَدࣱ مِّنَ ٱلۡمُشۡرِكِینَ﴾ مَرْفُوع بِفِعْلٍ يُفَسِّرهُ ﴿ٱسۡتَجَارَكَ﴾ اسْتَأْمَنَك مِنْ الْقَتْل ﴿فَأَجِرۡهُ﴾ أَمِّنْهُ ﴿حَتَّىٰ یَسۡمَعَ كَلَـٰمَ ٱللَّهِ﴾ الْقُرْآن ﴿ثُمَّ أَبۡلِغۡهُ مَأۡمَنَهُۥۚ﴾ وَهُوَ دَار قَوْمه إنْ لَمْ يُؤْمِن لِيَنْظُر فِي أَمْره ﴿ذَ ٰ⁠لِكَ﴾ الْمَذْكُور ﴿بِأَنَّهُمۡ قَوۡمࣱ لَّا یَعۡلَمُونَ ۝٦﴾ دِين اللَّه فَلَا بُدّ لَهُمْ مِنْ سَمَاع الْقُرْآن لِيَعْلَمُوا"
  9,7,"﴿كَیۡفَ﴾ أَيْ لَا ﴿یَكُونُ لِلۡمُشۡرِكِینَ عَهۡدٌ عِندَ ٱللَّهِ وَعِندَ رَسُولِهِۦۤ﴾ وَهُمْ كَافِرُونَ بِاَللَّهِ وَرَسُوله غَادِرُونَ ﴿إِلَّا ٱلَّذِینَ عَـٰهَدتُّمۡ عِندَ ٱلۡمَسۡجِدِ ٱلۡحَرَامِۖ﴾ يَوْم الْحُدَيْبِيَة وَهُمْ قُرَيْش الْمُسْتَثْنَوْنَ مِنْ قَبْل ﴿فَمَا ٱسۡتَقَـٰمُوا۟ لَكُمۡ﴾ أَقَامُوا عَلَى الْعَهْد وَلَمْ ينقضوه ﴿فَٱسۡتَقِیمُوا۟ لَهُمۡۚ﴾ على الوفاء به وما شرطية ﴿إِنَّ ٱللَّهَ یُحِبُّ ٱلۡمُتَّقِینَ ۝٧﴾ وَقَدْ اسْتَقَامَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ عَلَى عَهْدهمْ حَتَّى نَقَضُوا بِإِعَانَةِ بَنِي بَكْر على خزاعة"
  9,8,"﴿كَیۡفَ﴾ يَكُون لَهُمْ عَهْد ﴿وَإِن یَظۡهَرُوا۟ عَلَیۡكُمۡ﴾ يظفروا بكم ﴿لَا یَرۡقُبُوا۟﴾ يُرَاعُوا ﴿فِیكُمۡ إِلࣰّا﴾ قَرَابَة ﴿وَلَا ذِمَّةࣰۚ﴾ عهدا بل يؤذوكم ما استطاعوا وجملة الشرط حال ﴿یُرۡضُونَكُم بِأَفۡوَ ٰ⁠هِهِمۡ﴾ بِكَلَامِهِمْ الْحَسَن ﴿وَتَأۡبَىٰ قُلُوبُهُمۡ﴾ الْوَفَاء بِهِ ﴿وَأَكۡثَرُهُمۡ فَـٰسِقُونَ ۝٨﴾ نَاقِضُونِ لِلْعَهْدِ"
  9,9,"﴿ٱشۡتَرَوۡا۟ بِـَٔایَـٰتِ ٱللَّهِ﴾ الْقُرْآن ﴿ثَمَنࣰا قَلِیلࣰا﴾ مِنْ الدُّنْيَا أَيْ تَرَكُوا اتِّبَاعهَا لِلشَّهَوَاتِ وَالْهَوَى ﴿فَصَدُّوا۟ عَن سَبِیلِهِۦۤۚ﴾ دِينه ﴿إِنَّهُمۡ سَاۤءَ﴾ بِئْسَ ﴿مَا كَانُوا۟ یَعۡمَلُونَ ۝٩﴾ هـ عملهم هذا"
  9,10,"﴿لَا یَرۡقُبُونَ فِی مُؤۡمِنٍ إِلࣰّا وَلَا ذِمَّةࣰۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُعۡتَدُونَ ۝١٠﴾"
  9,11,"﴿فَإِن تَابُوا۟ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ فَإِخۡوَ ٰ⁠نُكُمۡ﴾ أَيْ فَهُمْ إخْوَانكُمْ ﴿فِی ٱلدِّینِۗ وَنُفَصِّلُ﴾ نُبَيِّن ﴿ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝١١﴾ يَتَدَبَّرُونَ"
  9,12,"﴿وَإِن نَّكَثُوۤا۟﴾ نَقَضُوا ﴿أَیۡمَـٰنَهُم﴾ مَوَاثِيقهمْ ﴿مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ﴾ عَابُوهُ ﴿فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ﴾ رُؤَسَاءَهُ فِيهِ وَضْع الظَّاهِر مَوْضِع الْمُضْمَر ﴿إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ﴾ عُهُود ﴿لَهُمۡ﴾ وَفِي قِرَاءَة بِالْكَسْرِ ﴿لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾ عَنْ الْكُفْر"
  9,13,"﴿أَلَا﴾ لِلتَّحْضِيضِ ﴿تُقَـٰتِلُونَ قَوۡمࣰا نَّكَثُوۤا۟﴾ نَقَضُوا ﴿أَیۡمَـٰنَهُمۡ﴾ عُهُودهمْ ﴿وَهَمُّوا۟ بِإِخۡرَاجِ ٱلرَّسُولِ﴾ مِنْ مَكَّة لَمَّا تشاوروا فيه بدار الندوة ﴿وَهُم بَدَءُوكُمۡ﴾ بِالْقِتَالِ ﴿أَوَّلَ مَرَّةٍۚ﴾ حَيْثُ قَاتَلُوا خُزَاعَة حُلَفَاءَكُمْ مَعَ بَنِي بَكْر فَمَا يَمْنَعكُمْ أَنْ تُقَاتِلُوهُمْ ﴿أَتَخۡشَوۡنَهُمۡۚ﴾ أَتَخَافُونَهُمْ ﴿فَٱللَّهُ أَحَقُّ أَن تَخۡشَوۡهُ﴾ فِي ترك قتالهم ﴿إِن كُنتُم مُّؤۡمِنِینَ ۝١٣﴾"
  9,14,"﴿قَـٰتِلُوهُمۡ یُعَذِّبۡهُمُ ٱللَّهُ﴾ يَقْتُلهُمْ ﴿بِأَیۡدِیكُمۡ وَیُخۡزِهِمۡ﴾ يُذِلّهُمْ بِالْأَسْرِ وَالْقَهْر ﴿وَیَنصُرۡكُمۡ عَلَیۡهِمۡ وَیَشۡفِ صُدُورَ قَوۡمࣲ مُّؤۡمِنِینَ ۝١٤﴾ بِمَا فَعَلَ بِهِمْ هُمْ بَنُو خُزَاعَة"
  9,15,"﴿وَیُذۡهِبۡ غَیۡظَ قُلُوبِهِمۡۗ﴾ كَرْبهَا ﴿وَیَتُوبُ ٱللَّهُ عَلَىٰ مَن یَشَاۤءُۗ﴾ بِالرُّجُوعِ إلَى الْإِسْلَام كَأَبِي سُفْيَان ﴿وَٱللَّهُ عَلِیمٌ حَكِیمٌ ۝١٥﴾"
  9,16,"﴿أَمۡ﴾ بِمَعْنَى هَمْزَة الْإِنْكَار ﴿حَسِبۡتُمۡ أَن تُتۡرَكُوا۟ وَلَمَّا﴾ لَمْ ﴿یَعۡلَمِ ٱللَّهُ﴾ عِلْم ظُهُور ﴿ٱلَّذِینَ جَـٰهَدُوا۟ مِنكُمۡ﴾ بِإِخْلَاصٍ ﴿وَلَمۡ یَتَّخِذُوا۟ مِن دُونِ ٱللَّهِ وَلَا رَسُولِهِۦ وَلَا ٱلۡمُؤۡمِنِینَ وَلِیجَةࣰۚ﴾ بِطَانَة وَأَوْلِيَاء الْمَعْنَى وَلَمْ يَظْهَر الْمُخْلِصُونَ وَهُمْ الْمَوْصُوفُونَ بما ذكر من غيرهم ﴿وَٱللَّهُ خَبِیرُۢ بِمَا تَعۡمَلُونَ ۝١٦﴾"
  9,17,"﴿مَا كَانَ لِلۡمُشۡرِكِینَ أَن یَعۡمُرُوا۟ مَسۡجِدَ ٱللَّهِ﴾ بِالْإِفْرَادِ وَالْجَمْع بِدُخُولِهِ وَالْقُعُود فِيهِ ﴿شَـٰهِدِینَ عَلَىٰۤ أَنفُسِهِم بِٱلۡكُفۡرِۚ أُو۟لَـٰۤىِٕكَ حَبِطَتۡ﴾ بَطَلَتْ ﴿أَعۡمَـٰلُهُمۡ﴾ لِعَدَمِ شرطها ﴿وَفِی ٱلنَّارِ هُمۡ خَـٰلِدُونَ ۝١٧﴾"
  9,18,"﴿إِنَّمَا یَعۡمُرُ مَسَـٰجِدَ ٱللَّهِ مَنۡ ءَامَنَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ وَلَمۡ یَخۡشَ﴾ أحدا ﴿إِلَّا ٱللَّهَۖ فَعَسَىٰۤ أُو۟لَـٰۤىِٕكَ أَن یَكُونُوا۟ مِنَ ٱلۡمُهۡتَدِینَ ۝١٨﴾"
  9,19,"﴿أَجَعَلۡتُمۡ سِقَایَةَ ٱلۡحَاۤجِّ وَعِمَارَةَ ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾ أَيْ أَهْل ذَلِكَ ﴿كَمَنۡ ءَامَنَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَجَـٰهَدَ فِی سَبِیلِ ٱللَّهِۚ لَا یَسۡتَوُۥنَ عِندَ ٱللَّهِۗ﴾ فِي الْفَضْل ﴿وَٱللَّهُ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلظَّـٰلِمِینَ ۝١٩﴾ الْكَافِرِينَ نَزَلَتْ رَدًّا عَلَى مَنْ قَالَ ذَلِكَ وَهُوَ الْعَبَّاس أَوْ غَيْره"
  9,20,"﴿ٱلَّذِینَ ءَامَنُوا۟ وَهَاجَرُوا۟ وَجَـٰهَدُوا۟ فِی سَبِیلِ ٱللَّهِ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡ أَعۡظَمُ دَرَجَةً﴾ رُتْبَة ﴿عِندَ ٱللَّهِۚ﴾ مِنْ غَيْرهمْ ﴿وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡفَاۤىِٕزُونَ ۝٢٠﴾ الظَّافِرُونَ بِالْخَيْرِ"
  9,21,"﴿یُبَشِّرُهُمۡ رَبُّهُم بِرَحۡمَةࣲ مِّنۡهُ وَرِضۡوَ ٰ⁠نࣲ وَجَنَّـٰتࣲ لَّهُمۡ فِیهَا نَعِیمࣱ مُّقِیمٌ ۝٢١﴾ دَائِم"
  9,22,"﴿خَـٰلِدِینَ﴾ حال مقدرة ﴿فِیهَاۤ أَبَدًاۚ إِنَّ ٱللَّهَ عِندَهُۥۤ أَجۡرٌ عَظِیمࣱ ۝٢٢﴾"
  9,23,"وَنَزَلَ فِيمَنْ تَرَكَ الْهِجْرَة لِأَجْلِ أَهْله وَتِجَارَته ﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ لَا تَتَّخِذُوۤا۟ ءَابَاۤءَكُمۡ وَإِخۡوَ ٰ⁠نَكُمۡ أَوۡلِیَاۤءَ إِنِ ٱسۡتَحَبُّوا۟﴾ اختاروا ﴿ٱلۡكُفۡرَ عَلَى ٱلۡإِیمَـٰنِۚ وَمَن یَتَوَلَّهُم مِّنكُمۡ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلظَّـٰلِمُونَ ۝٢٣﴾"
  9,24,"﴿قُلۡ إِن كَانَ ءَابَاۤؤُكُمۡ وَأَبۡنَاۤؤُكُمۡ وَإِخۡوَ ٰ⁠نُكُمۡ وَأَزۡوَ ٰ⁠جُكُمۡ وَعَشِیرَتُكُمۡ﴾ أَقْرِبَاؤُكُمْ وَفِي قِرَاءَة {عَشِیرَ ٰ⁠تُكُمۡ} ﴿وَأَمۡوَ ٰ⁠لٌ ٱقۡتَرَفۡتُمُوهَا﴾ اكتسبتموها ﴿وَتِجَـٰرَةࣱ تَخۡشَوۡنَ كَسَادَهَا﴾ عدم نفاذها ﴿وَمَسَـٰكِنُ تَرۡضَوۡنَهَاۤ أَحَبَّ إِلَیۡكُم مِّنَ ٱللَّهِ وَرَسُولِهِۦ وَجِهَادࣲ فِی سَبِیلِهِۦ﴾ فَقَعَدْتُمْ لِأَجْلِهِ عَنْ الْهِجْرَة وَالْجِهَاد ﴿فَتَرَبَّصُوا۟﴾ انْتَظِرُوا ﴿حَتَّىٰ یَأۡتِیَ ٱللَّهُ بِأَمۡرِهِۦۗ﴾ تهديد لهم ﴿وَٱللَّهُ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلۡفَـٰسِقِینَ ۝٢٤﴾"
  9,25,"﴿لَقَدۡ نَصَرَكُمُ ٱللَّهُ فِی مَوَاطِنَ﴾ لِلْحَرْبِ ﴿كَثِیرَةࣲ﴾ كبدر وقريظة والنضير ﴿وَ﴾ اذكر ﴿یَوۡمَ حُنَیۡنٍ﴾ وَادٍ بَيْن مَكَّة وَالطَّائِف أَيْ يَوْم قِتَالكُمْ فِيهِ هَوَازِن وَذَلِك فِي شَوَّال سَنَة ثَمَان ﴿إِذۡ﴾ بَدَل مِنْ يَوْم ﴿أَعۡجَبَتۡكُمۡ كَثۡرَتُكُمۡ﴾ فَقُلْتُمْ لَنْ نُغْلَب الْيَوْم مِنْ قِلَّة وَكَانُوا اثْنَيْ عَشَرَ أَلْفًا وَالْكُفَّار أَرْبَعَة آلَاف ﴿فَلَمۡ تُغۡنِ عَنكُمۡ شَیۡـࣰٔا وَضَاقَتۡ عَلَیۡكُمُ ٱلۡأَرۡضُ بِمَا رَحُبَتۡ﴾ مَا مَصْدَرِيَّة أَيْ مَعَ رَحْبهَا أَيْ سِعَتهَا فَلَمْ تَجِدُوا مَكَانًا تَطْمَئِنُّونَ إلَيْهِ لِشِدَّةِ مَا لَحِقَكُمْ مِنْ الْخَوْف ﴿ثُمَّ وَلَّیۡتُم مُّدۡبِرِینَ ۝٢٥﴾ مُنْهَزِمِينَ وَثَبَتَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ عَلَى بَغْلَته الْبَيْضَاء وَلَيْسَ مَعَهُ غَيْر الْعَبَّاس وَأَبُو سُفْيَان آخِذ بِرِكَابِهِ"
  9,26,"﴿ثُمَّ أَنزَلَ ٱللَّهُ سَكِینَتَهُۥ﴾ طُمَأْنِينَته ﴿عَلَىٰ رَسُولِهِۦ وَعَلَى ٱلۡمُؤۡمِنِینَ﴾ فَرَدُّوا إلَى النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ لَمَّا نَادَاهُمْ الْعَبَّاس بِإِذْنِهِ وَقَاتَلُوا ﴿وَأَنزَلَ جُنُودࣰا لَّمۡ تَرَوۡهَا﴾ مَلَائِكَة ﴿وَعَذَّبَ ٱلَّذِینَ كَفَرُوا۟ۚ﴾ بالقتل والأسر ﴿وَذَ ٰ⁠لِكَ جَزَاۤءُ ٱلۡكَـٰفِرِینَ ۝٢٦﴾"
  9,27,"﴿ثُمَّ یَتُوبُ ٱللَّهُ مِنۢ بَعۡدِ ذَ ٰ⁠لِكَ عَلَىٰ مَن یَشَاۤءُۗ﴾ منهم بالإسلام ﴿وَٱللَّهُ غَفُورࣱ رَّحِیمࣱ ۝٢٧﴾"
  9,28,"﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِنَّمَا ٱلۡمُشۡرِكُونَ نَجَسࣱ﴾ قَذَر لِخُبْثِ بَاطِنهمْ ﴿فَلَا یَقۡرَبُوا۟ ٱلۡمَسۡجِدَ ٱلۡحَرَامَ﴾ أَيْ لَا يَدْخُلُوا الْحَرَم ﴿بَعۡدَ عَامِهِمۡ هَـٰذَاۚ﴾ عَام تِسْع مِنْ الْهِجْرَة ﴿وَإِنۡ خِفۡتُمۡ عَیۡلَةࣰ﴾ فَقْرًا بِانْقِطَاعِ تِجَارَتهمْ عَنْكُمْ ﴿فَسَوۡفَ یُغۡنِیكُمُ ٱللَّهُ مِن فَضۡلِهِۦۤ إِن شَاۤءَۚ﴾ وقد أغناهم بالفتوح والجزية ﴿إِنَّ ٱللَّهَ عَلِیمٌ حَكِیمࣱ ۝٢٨﴾"
  9,29,"﴿قَـٰتِلُوا۟ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱللَّهِ وَلَا بِٱلۡیَوۡمِ ٱلۡـَٔاخِرِ﴾ وَإِلَّا لَآمَنُوا بِالنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿وَلَا یُحَرِّمُونَ مَا حَرَّمَ ٱللَّهُ وَرَسُولُهُۥ﴾ كَالْخَمْرِ ﴿وَلَا یَدِینُونَ دِینَ ٱلۡحَقِّ﴾ الثَّابِت النَّاسِخ لِغَيْرِهِ مِنْ الْأَدْيَان وَهُوَ دِين الْإِسْلَام ﴿مِنَ﴾ بَيَان لِلَّذِينَ ﴿ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ﴾ أَيْ الْيَهُود وَالنَّصَارَى ﴿حَتَّىٰ یُعۡطُوا۟ ٱلۡجِزۡیَةَ﴾ الْخَرَاج الْمَضْرُوب عَلَيْهِمْ كُلّ عَام ﴿عَن یَدࣲ﴾ حَال أَيْ مُنْقَادِينَ أَوْ بِأَيْدِيهِمْ لَا يُوَكَّلُونَ بِهَا ﴿وَهُمۡ صَـٰغِرُونَ ۝٢٩﴾ أَذِلَّاء مُنْقَادُونَ لِحُكْمِ الْإِسْلَام"
  9,30,"﴿وَقَالَتِ ٱلۡیَهُودُ عُزَیۡرٌ ٱبۡنُ ٱللَّهِ وَقَالَتِ ٱلنَّصَـٰرَى ٱلۡمَسِیحُ﴾ عيسى ﴿ٱبۡنُ ٱللَّهِۖ ذَ ٰ⁠لِكَ قَوۡلُهُم بِأَفۡوَ ٰ⁠هِهِمۡۖ﴾ لَا مُسْتَنِد لَهُمْ عَلَيْهِ بَلْ ﴿یُضَـٰهِـُٔونَ﴾ يُشَابِهُونَ بِهِ ﴿قَوۡلَ ٱلَّذِینَ كَفَرُوا۟ مِن قَبۡلُۚ﴾ مِنْ آبَائِهِمْ تَقْلِيدًا لَهُمْ ﴿قَـٰتَلَهُمُ﴾ لَعَنَهُمْ ﴿ٱللَّهُۖ أَنَّىٰ﴾ كَيْفَ ﴿یُؤۡفَكُونَ ۝٣٠﴾ يُصْرَفُونَ عَنْ الْحَقّ مَعَ قِيَام الدَّلِيل"
  9,31,"﴿ٱتَّخَذُوۤا۟ أَحۡبَارَهُمۡ﴾ عُلَمَاء الْيَهُود ﴿وَرُهۡبَـٰنَهُمۡ﴾ عُبَّاد النَّصَارَى ﴿أَرۡبَابࣰا مِّن دُونِ ٱللَّهِ﴾ حَيْثُ اتَّبَعُوهُمْ فِي تَحْلِيل مَا حَرَّمَ اللَّه وَتَحْرِيم مَا أَحَلَّ الله ﴿وَٱلۡمَسِیحَ ٱبۡنَ مَرۡیَمَ وَمَاۤ أُمِرُوۤا۟﴾ فِي التَّوْرَاة وَالْإِنْجِيل ﴿إِلَّا لِیَعۡبُدُوۤا۟﴾ أَيْ بِأَنْ يَعْبُدُوا ﴿إِلَـٰهࣰا وَ ٰ⁠حِدࣰاۖ لَّاۤ إِلَـٰهَ إِلَّا هُوَۚ سُبۡحَـٰنَهُۥ﴾ تنزيها له ﴿عَمَّا یُشۡرِكُونَ ۝٣١﴾"
  9,32,"﴿یُرِیدُونَ أَن یُطۡفِـُٔوا۟ نُورَ ٱللَّهِ﴾ شَرْعه وَبَرَاهِينه ﴿بِأَفۡوَ ٰ⁠هِهِمۡ﴾ بِأَقْوَالِهِمْ فِيهِ ﴿وَیَأۡبَى ٱللَّهُ إِلَّاۤ أَن یُتِمَّ﴾ يُظْهِر ﴿نُورَهُۥ وَلَوۡ كَرِهَ ٱلۡكَـٰفِرُونَ ۝٣٢﴾ ذَلِكَ"
  9,33,"﴿هُوَ ٱلَّذِیۤ أَرۡسَلَ رَسُولَهُۥ﴾ مُحَمَّدًا صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿بِٱلۡهُدَىٰ وَدِینِ ٱلۡحَقِّ لِیُظۡهِرَهُۥ﴾ يُعْلِيه ﴿عَلَى ٱلدِّینِ كُلِّهِۦ﴾ جَمِيع الْأَدْيَان الْمُخَالِفَة لَهُ ﴿وَلَوۡ كَرِهَ ٱلۡمُشۡرِكُونَ ۝٣٣﴾ ذلك"
  9,34,"﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِنَّ كَثِیرࣰا مِّنَ ٱلۡأَحۡبَارِ وَٱلرُّهۡبَانِ لَیَأۡكُلُونَ﴾ يَأْخُذُونَ ﴿أَمۡوَ ٰ⁠لَ ٱلنَّاسِ بِٱلۡبَـٰطِلِ﴾ كَالرِّشَا فِي الْحُكْم ﴿وَیَصُدُّونَ﴾ النَّاس ﴿عَن سَبِیلِ ٱللَّهِۗ﴾ دِينه ﴿وَٱلَّذِینَ﴾ مُبْتَدَأ ﴿یَكۡنِزُونَ ٱلذَّهَبَ وَٱلۡفِضَّةَ وَلَا یُنفِقُونَهَا﴾ أَيْ الْكُنُوز ﴿فِی سَبِیلِ ٱللَّهِ﴾ أَيْ لَا يؤدون منها حقه من الزكاة والخير ﴿فَبَشِّرۡهُم﴾ أَخْبِرْهُمْ ﴿بِعَذَابٍ أَلِیمࣲ ۝٣٤﴾ مُؤْلِم"
  9,35,"﴿یَوۡمَ یُحۡمَىٰ عَلَیۡهَا فِی نَارِ جَهَنَّمَ فَتُكۡوَىٰ﴾ تُحْرَق ﴿بِهَا جِبَاهُهُمۡ وَجُنُوبُهُمۡ وَظُهُورُهُمۡۖ﴾ وَتُوَسِّع جُلُودهمْ حَتَّى تُوضَع عَلَيْهَا كُلّهَا وَيُقَال لَهُمْ ﴿هَـٰذَا مَا كَنَزۡتُمۡ لِأَنفُسِكُمۡ فَذُوقُوا۟ مَا كُنتُمۡ تَكۡنِزُونَ ۝٣٥﴾ أي جزاءه"
  9,36,"﴿إِنَّ عِدَّةَ ٱلشُّهُورِ﴾ الْمُعْتَدّ بِهَا لِلسَّنَةِ ﴿عِندَ ٱللَّهِ ٱثۡنَا عَشَرَ شَهۡرࣰا فِی كِتَـٰبِ ٱللَّهِ﴾ اللَّوْح الْمَحْفُوظ ﴿یَوۡمَ خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ مِنۡهَاۤ﴾ أَيْ الشُّهُور ﴿أَرۡبَعَةٌ حُرُمࣱۚ﴾ مُحَرَّمَة ذُو الْقَعْدَة وَذُو الْحِجَّة وَالْمُحَرَّم وَرَجَب ﴿ذَ ٰ⁠لِكَ﴾ أَيْ تَحْرِيمهَا ﴿ٱلدِّینُ ٱلۡقَیِّمُۚ﴾ الْمُسْتَقِيم ﴿فَلَا تَظۡلِمُوا۟ فِیهِنَّ﴾ أَيْ الْأَشْهُر الْحُرُم ﴿أَنفُسَكُمۡۚ﴾ بِالْمَعَاصِي فَإِنَّهَا فِيهَا أَعْظَم وِزْرًا وَقِيلَ فِي الْأَشْهُر كُلّهَا ﴿وَقَـٰتِلُوا۟ ٱلۡمُشۡرِكِینَ كَاۤفَّةࣰ﴾ جَمِيعًا فِي كُلّ الشُّهُور ﴿كَمَا یُقَـٰتِلُونَكُمۡ كَاۤفَّةࣰۚ وَٱعۡلَمُوۤا۟ أَنَّ ٱللَّهَ مَعَ ٱلۡمُتَّقِینَ ۝٣٦﴾ بِالْعَوْنِ وَالنَّصْر"
  9,37,"﴿إِنَّمَا ٱلنَّسِیۤءُ﴾ أَيْ التَّأْخِير لِحُرْمَةِ شَهْر إلَى آخَر كَمَا كَانَتْ الْجَاهِلِيَّة تَفْعَلهُ مِنْ تَأْخِير حُرْمَة الْمُحَرَّم إذَا هَلَّ وَهُمْ فِي الْقِتَال إلَى صَفَر ﴿زِیَادَةࣱ فِی ٱلۡكُفۡرِۖ﴾ لِكُفْرِهِمْ بِحُكْمِ اللَّه فِيهِ ﴿یُضَلُّ﴾ بِضَمِّ الْيَاء وَفَتْحهَا ﴿بِهِ ٱلَّذِینَ كَفَرُوا۟ یُحِلُّونَهُۥ﴾ أَيْ النَّسِيء ﴿عَامࣰا وَیُحَرِّمُونَهُۥ عَامࣰا لِّیُوَاطِـُٔوا۟﴾ يُوَافِقُوا بِتَحْلِيلِ شَهْر وَتَحْرِيم آخَر بَدَله ﴿عِدَّةَ﴾ عَدَد ﴿مَا حَرَّمَ ٱللَّهُ﴾ مِنْ الْأَشْهُر فَلَا يَزِيدُوا عَلَى تَحْرِيم أَرْبَعَة وَلَا يَنْقُصُوا وَلَا يَنْظُرُوا إلَى أَعْيَانهَا ﴿فَیُحِلُّوا۟ مَا حَرَّمَ ٱللَّهُۚ زُیِّنَ لَهُمۡ سُوۤءُ أَعۡمَـٰلِهِمۡۗ﴾ فَظَنُّوهُ حسنا ﴿وَٱللَّهُ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلۡكَـٰفِرِینَ ۝٣٧﴾"
  9,38,"وَنَزَلَ لَمَّا دَعَا النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ النَّاس إلَى غَزْوَة تَبُوك وَكَانُوا فِي عسرة وشدة حر فشق عليهم ﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ مَا لَكُمۡ إِذَا قِیلَ لَكُمُ ٱنفِرُوا۟ فِی سَبِیلِ ٱللَّهِ ٱثَّاقَلۡتُمۡ﴾ بِإِدْغَامِ التَّاء فِي الْأَصْل فِي الْمُثَلَّثَة وَاجْتِلَاب هَمْزَة الْوَصْل أَيْ تَبَاطَأْتُمْ وَمِلْتُمْ عَنْ الْجِهَاد ﴿إِلَى ٱلۡأَرۡضِۚ﴾ والقعود فيها والاستفهام للتوبيخ ﴿أَرَضِیتُم بِٱلۡحَیَوٰةِ ٱلدُّنۡیَا﴾ ولذاتها ﴿مِنَ ٱلۡـَٔاخِرَةِۚ﴾ أَيْ بَدَل نَعِيمهَا ﴿فَمَا مَتَـٰعُ ٱلۡحَیَوٰةِ ٱلدُّنۡیَا فِی﴾ جَنْب مَتَاع ﴿ٱلۡـَٔاخِرَةِ إِلَّا قَلِیلٌ ۝٣٨﴾ حقير"
  9,39,"﴿إِلَّا﴾ بِإِدْغَامِ لَا فِي نُون إنْ الشَّرْطِيَّة فِي الْمَوْضِعَيْنِ ﴿تَنفِرُوا۟﴾ تَخْرُجُوا مَعَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ لِلْجِهَادِ ﴿یُعَذِّبۡكُمۡ عَذَابًا أَلِیمࣰا﴾ مُؤْلِمًا ﴿وَیَسۡتَبۡدِلۡ قَوۡمًا غَیۡرَكُمۡ﴾ أَيْ يَأْتِ بِهِمْ بَدَلكُمْ ﴿وَلَا تَضُرُّوهُ﴾ أَيْ اللَّه أَوْ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿شَیۡـࣰٔاۗ﴾ بِتَرْكِ نَصْره فَإِنَّ اللَّه نَاصِر دِينه ﴿وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٣٩﴾ وَمِنْهُ نَصْر دِينه وَنَبِيّه"
  9,40,"﴿إِلَّا تَنصُرُوهُ﴾ أَيْ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿فَقَدۡ نَصَرَهُ ٱللَّهُ إِذۡ﴾ حِين ﴿أَخۡرَجَهُ ٱلَّذِینَ كَفَرُوا۟﴾ من مكة أي ألجؤوه إلَى الْخُرُوج لَمَّا أَرَادُوا قَتْله أَوْ حَبْسه أَوْ نَفْيه بِدَارِ النَّدْوَة ﴿ثَانِیَ ٱثۡنَیۡنِ﴾ حَال أَيْ أَحَد اثْنَيْنِ وَالْآخَر أَبُو بَكْر الْمَعْنَى نَصَرَهُ اللَّه فِي مِثْل تِلْكَ الْحَالَة فَلَا يَخْذُلهُ فِي غَيْرهَا ﴿إِذۡ﴾ بَدَل مِنْ إذْ قَبْله ﴿هُمَا فِی ٱلۡغَارِ﴾ نَقْب فِي جَبَل ثَوْر ﴿إِذۡ﴾ بَدَل ثَانٍ ﴿یَقُولُ لِصَـٰحِبِهِۦ﴾ أَبِي بَكْر وَقَدْ قَالَ لَهُ لَمَّا رَأَى أَقْدَام الْمُشْرِكِينَ لَوْ نَظَرَ أَحَدهمْ تَحْت قَدَمَيْهِ لَأَبْصَرَنَا ﴿لَا تَحۡزَنۡ إِنَّ ٱللَّهَ مَعَنَاۖ﴾ بِنَصْرِهِ ﴿فَأَنزَلَ ٱللَّهُ سَكِینَتَهُۥ﴾ طُمَأْنِينَته ﴿عَلَیۡهِ﴾ قِيلَ عَلَى النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ وَقِيلَ عَلَى أَبِي بَكْر ﴿وَأَیَّدَهُۥ﴾ أَيْ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿بِجُنُودࣲ لَّمۡ تَرَوۡهَا﴾ مَلَائِكَة فِي الْغَار وَمَوَاطِن قِتَاله ﴿وَجَعَلَ كَلِمَةَ ٱلَّذِینَ كَفَرُوا۟﴾ أَيْ دَعْوَة الشِّرْك ﴿ٱلسُّفۡلَىٰۗ﴾ الْمَغْلُوبَة ﴿وَكَلِمَةُ ٱللَّهِ﴾ أَيْ كَلِمَة الشَّهَادَة ﴿هِیَ ٱلۡعُلۡیَاۗ﴾ الظَّاهِرَة الْغَالِبَة ﴿وَٱللَّهُ عَزِیزٌ﴾ فِي مُلْكه ﴿حَكِیمٌ ۝٤٠﴾ فِي صُنْعه"
  9,41,"﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾ نَشَاطًا وَغَيْر نَشَاط وَقِيلَ أَقْوِيَاء وَضُعَفَاء أَوْ أَغْنِيَاء وَفُقَرَاء وَهِيَ مَنْسُوخَة بِآيَةِ {لَّیۡسَ عَلَى ٱلضُّعَفَاۤءِ} ﴿وَجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِكُمۡ وَأَنفُسِكُمۡ فِی سَبِیلِ ٱللَّهِۚ ذَ ٰ⁠لِكُمۡ خَیۡرࣱ لَّكُمۡ إِن كُنتُمۡ تَعۡلَمُونَ ۝٤١﴾ أَنَّهُ خَيْر لَكُمْ فَلَا تَثَّاقَلُوا"
  9,42,"ونزل في المنافقين الذين تخلفوا ﴿لَوۡ كَانَ﴾ ما دعوتهم إليه ﴿عَرَضࣰا﴾ مَتَاعًا مِنْ الدُّنْيَا ﴿قَرِیبࣰا﴾ سَهْل الْمَأْخَذ ﴿وَسَفَرࣰا قَاصِدࣰا﴾ وَسَطًا ﴿لَّٱتَّبَعُوكَ﴾ طَلَبًا لِلْغَنِيمَةِ ﴿وَلَـٰكِنۢ بَعُدَتۡ عَلَیۡهِمُ ٱلشُّقَّةُۚ﴾ الْمَسَافَة فَتَخَلَّفُوا ﴿وَسَیَحۡلِفُونَ بِٱللَّهِ﴾ إذَا رَجَعْتُمْ إلَيْهِمْ ﴿لَوِ ٱسۡتَطَعۡنَا﴾ الْخُرُوج ﴿لَخَرَجۡنَا مَعَكُمۡ یُهۡلِكُونَ أَنفُسَهُمۡ﴾ بِالْحَلِفِ الْكَاذِب ﴿وَٱللَّهُ یَعۡلَمُ إِنَّهُمۡ لَكَـٰذِبُونَ ۝٤٢﴾ فِي قَوْلهمْ ذَلِكَ"
  9,43,"وَكَانَ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ أَذَّنَ لِجَمَاعَةٍ فِي التَّخَلُّف بِاجْتِهَادٍ مِنْهُ فَنَزَلَ عِتَابًا لَهُ وَقَدَّمَ الْعَفْو تَطْمِينًا لِقَلْبِهِ ﴿عَفَا ٱللَّهُ عَنكَ لِمَ أَذِنتَ لَهُمۡ﴾ فِي التَّخَلُّف وَهَلَّا تَرَكْتهمْ ﴿حَتَّىٰ یَتَبَیَّنَ لَكَ ٱلَّذِینَ صَدَقُوا۟﴾ فِي الْعُذْر ﴿وَتَعۡلَمَ ٱلۡكَـٰذِبِینَ ۝٤٣﴾ فِيهِ"
  9,44,"﴿لَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ﴾ فِي التَّخَلُّف عَنْ ﴿أَن یُجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝٤٤﴾"
  9,45,"﴿إِنَّمَا یَسۡتَـٔۡذِنُكَ﴾ فِي التَّخَلُّف ﴿ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَٱرۡتَابَتۡ﴾ شَكَّتْ ﴿قُلُوبُهُمۡ﴾ فِي الدِّين ﴿فَهُمۡ فِی رَیۡبِهِمۡ یَتَرَدَّدُونَ ۝٤٥﴾ يَتَحَيَّرُونَ"
  9,46,"﴿وَلَوۡ أَرَادُوا۟ ٱلۡخُرُوجَ﴾ مَعَك ﴿لَأَعَدُّوا۟ لَهُۥ عُدَّةࣰ﴾ أُهْبَة مِنْ الْآلَة وَالزَّاد ﴿وَلَـٰكِن كَرِهَ ٱللَّهُ ٱنۢبِعَاثَهُمۡ﴾ أَيْ لَمْ يُرِدْ خُرُوجهمْ ﴿فَثَبَّطَهُمۡ﴾ كَسَّلَهُمْ ﴿وَقِیلَ﴾ لَهُمْ ﴿ٱقۡعُدُوا۟ مَعَ ٱلۡقَـٰعِدِینَ ۝٤٦﴾ الْمَرْضَى وَالنِّسَاء وَالصِّبْيَان أَيْ قَدَّرَ اللَّه تَعَالَى ذَلِكَ"
  9,47,"﴿لَوۡ خَرَجُوا۟ فِیكُم مَّا زَادُوكُمۡ إِلَّا خَبَالࣰا﴾ فسادا بِتَخْذِيلِ الْمُؤْمِنِينَ ﴿وَلَأَوۡضَعُوا۟ خِلَـٰلَكُمۡ﴾ أَيْ أَسْرَعُوا بَيْنكُمْ بِالْمَشْيِ بِالنَّمِيمَةِ ﴿یَبۡغُونَكُمُ﴾ يَطْلُبُونَ لَكُمْ ﴿ٱلۡفِتۡنَةَ﴾ بِإِلْقَاءِ الْعَدَاوَة ﴿وَفِیكُمۡ سَمَّـٰعُونَ لَهُمۡۗ﴾ مَا يَقُولُونَ سَمَاع قبول ﴿وَٱللَّهُ عَلِیمُۢ بِٱلظَّـٰلِمِینَ ۝٤٧﴾"
  9,48,"﴿لَقَدِ ٱبۡتَغَوُا۟﴾ لَك ﴿ٱلۡفِتۡنَةَ مِن قَبۡلُ﴾ أَوَّل مَا قَدِمْت الْمَدِينَة ﴿وَقَلَّبُوا۟ لَكَ ٱلۡأُمُورَ﴾ أَيْ أَجَالُوا الْفِكْر فِي كَيْدك وَإِبْطَال دِينك ﴿حَتَّىٰ جَاۤءَ ٱلۡحَقُّ﴾ النَّصْر ﴿وَظَهَرَ﴾ عَزَّ ﴿أَمۡرُ ٱللَّهِ﴾ دِينه ﴿وَهُمۡ كَـٰرِهُونَ ۝٤٨﴾ لَهُ فَدَخَلُوا فِيهِ ظَاهِرًا"
  9,49,"﴿وَمِنۡهُم مَّن یَقُولُ ٱئۡذَن لِّی﴾ فِي التَّخَلُّف ﴿وَلَا تَفۡتِنِّیۤۚ﴾ وَهُوَ الْجَدّ بْن قَيْس قَالَ لَهُ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ هَلْ لَك فِي جَلَّاد بَنِي الْأَصْفَر فَقَالَ إنِّي مُغْرَم بِالنِّسَاءِ وَأَخْشَى إنْ رَأَيْت نِسَاء بَنِي الأصفر أن لا أصبر عنهن فأفتتن قال تعالى ﴿أَلَا فِی ٱلۡفِتۡنَةِ سَقَطُوا۟ۗ﴾ بِالتَّخَلُّفِ وَقُرِئَ سَقَطَ ﴿وَإِنَّ جَهَنَّمَ لَمُحِیطَةُۢ بِٱلۡكَـٰفِرِینَ ۝٤٩﴾ لَا مَحِيص لَهُمْ عنها"
  9,50,"﴿إِن تُصِبۡكَ حَسَنَةࣱ﴾ كنصر وغنيمة ﴿تَسُؤۡهُمۡۖ وَإِن تُصِبۡكَ مُصِیبَةࣱ﴾ شِدَّة ﴿یَقُولُوا۟ قَدۡ أَخَذۡنَاۤ أَمۡرَنَا﴾ بِالْحَزْمِ حِين تَخَلَّفْنَا ﴿مِن قَبۡلُ﴾ قَبْل هَذِهِ الْمَعْصِيَة ﴿وَیَتَوَلَّوا۟ وَّهُمۡ فَرِحُونَ ۝٥٠﴾ بِمَا أَصَابَك"
  9,51,"﴿قُل﴾ لَهُمْ ﴿لَّن یُصِیبَنَاۤ إِلَّا مَا كَتَبَ ٱللَّهُ لَنَا﴾ إصَابَته ﴿هُوَ مَوۡلَىٰنَاۚ﴾ نَاصِرنَا وَمُتَوَلِّي أمورنا ﴿وَعَلَى ٱللَّهِ فَلۡیَتَوَكَّلِ ٱلۡمُؤۡمِنُونَ ۝٥١﴾"
  9,52,"﴿قُلۡ هَلۡ تَرَبَّصُونَ﴾ فِيهِ حَذْف إحْدَى التَّاءَيْنِ مِنْ الْأَصْل أَيْ تَنْتَظِرُونَ أَنْ يَقَع ﴿بِنَاۤ إِلَّاۤ إِحۡدَى﴾ الْعَاقِبَتَيْنِ ﴿ٱلۡحُسۡنَیَیۡنِۖ﴾ تَثْنِيَة حُسْنَى تَأْنِيث أَحْسَن النَّصْر أَوْ الشَّهَادَة ﴿وَنَحۡنُ نَتَرَبَّصُ﴾ نَنْتَظِر ﴿بِكُمۡ أَن یُصِیبَكُمُ ٱللَّهُ بِعَذَابࣲ مِّنۡ عِندِهِۦۤ﴾ بِقَارِعَةٍ مِنْ السَّمَاء ﴿أَوۡ بِأَیۡدِینَاۖ﴾ بِأَنْ يُؤْذِن لَنَا فِي قِتَالكُمْ ﴿فَتَرَبَّصُوۤا۟﴾ بِنَا ذَلِكَ ﴿إِنَّا مَعَكُم مُّتَرَبِّصُونَ ۝٥٢﴾ عَاقِبَتكُمْ"
  9,53,"﴿قُلۡ أَنفِقُوا۟﴾ فِي طَاعَة اللَّه ﴿طَوۡعًا أَوۡ كَرۡهࣰا لَّن یُتَقَبَّلَ مِنكُمۡ﴾ ما أنفقتموه ﴿إِنَّكُمۡ كُنتُمۡ قَوۡمࣰا فَـٰسِقِینَ ۝٥٣﴾ وَالْأَمْر هُنَا بِمَعْنَى الْخَبَر"
  9,54,"﴿وَمَا مَنَعَهُمۡ أَن یُقۡبَلَ﴾ بالياء والتاء ﴿مِنۡهُمۡ نَفَقَـٰتُهُمۡ إِلَّاۤ أَنَّهُمۡ﴾ فَاعِل و «أَن یُقۡبَلَ» مَفْعُول ﴿كَفَرُوا۟ بِٱللَّهِ وَبِرَسُولِهِۦ وَلَا یَأۡتُونَ ٱلصَّلَوٰةَ إِلَّا وَهُمۡ كُسَالَىٰ﴾ مُتَثَاقِلُونَ ﴿وَلَا یُنفِقُونَ إِلَّا وَهُمۡ كَـٰرِهُونَ ۝٥٤﴾ النَّفَقَة لِأَنَّهُمْ يعدونها مغرما"
  9,55,"﴿فَلَا تُعۡجِبۡكَ أَمۡوَ ٰ⁠لُهُمۡ وَلَاۤ أَوۡلَـٰدُهُمۡۚ﴾ أَيْ لَا تَسْتَحْسِن نِعَمنَا عَلَيْهِمْ فَهِيَ اسْتِدْرَاج ﴿إِنَّمَا یُرِیدُ ٱللَّهُ لِیُعَذِّبَهُم﴾ أَيْ أَنْ يُعَذِّبهُمْ ﴿بِهَا فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا﴾ بِمَا يَلْقَوْنَ فِي جَمْعهَا مِنْ الْمَشَقَّة وَفِيهَا مِنْ الْمَصَائِب ﴿وَتَزۡهَقَ﴾ تَخْرُج ﴿أَنفُسُهُمۡ وَهُمۡ كَـٰفِرُونَ ۝٥٥﴾ فَيُعَذِّبهُمْ فِي الْآخِرَة أَشَدّ الْعَذَاب"
  9,56,"﴿وَیَحۡلِفُونَ بِٱللَّهِ إِنَّهُمۡ لَمِنكُمۡ﴾ أَيْ مُؤْمِنُونَ ﴿وَمَا هُم مِّنكُمۡ وَلَـٰكِنَّهُمۡ قَوۡمࣱ یَفۡرَقُونَ ۝٥٦﴾ يَخَافُونَ أَنْ تَفْعَلُوا بِهِمْ كَالْمُشْرِكِينَ فَيَحْلِفُونَ تَقِيَّة"
  9,57,"﴿لَوۡ یَجِدُونَ مَلۡجَـًٔا﴾ يلجأون إلَيْهِ ﴿أَوۡ مَغَـٰرَ ٰ⁠تٍ﴾ سَرَادِيب ﴿أَوۡ مُدَّخَلࣰا﴾ مَوْضِعًا يَدْخُلُونَهُ ﴿لَّوَلَّوۡا۟ إِلَیۡهِ وَهُمۡ یَجۡمَحُونَ ۝٥٧﴾ يُسْرِعُونَ فِي دُخُوله وَالِانْصِرَاف عَنْكُمْ إسْرَاعًا لَا يَرُدّهُ شَيْء كالفرس الجموح"
  9,58,"﴿وَمِنۡهُم مَّن یَلۡمِزُكَ﴾ يعيبك ﴿فِی﴾ قسم ﴿ٱلصَّدَقَـٰتِ فَإِنۡ أُعۡطُوا۟ مِنۡهَا رَضُوا۟ وَإِن لَّمۡ یُعۡطَوۡا۟ مِنۡهَاۤ إِذَا هُمۡ یَسۡخَطُونَ ۝٥٨﴾"
  9,59,"﴿وَلَوۡ أَنَّهُمۡ رَضُوا۟ مَاۤ ءَاتَىٰهُمُ ٱللَّهُ وَرَسُولُهُۥ﴾ مِنْ الْغَنَائِم وَنَحْوهَا ﴿وَقَالُوا۟ حَسۡبُنَا﴾ كَافِينَا ﴿ٱللَّهُ سَیُؤۡتِینَا ٱللَّهُ مِن فَضۡلِهِۦ وَرَسُولُهُۥۤ﴾ مِنْ غَنِيمَة أُخْرَى مَا يَكْفِينَا ﴿إِنَّاۤ إِلَى ٱللَّهِ رَ ٰ⁠غِبُونَ ۝٥٩﴾ أَنْ يُغْنِينَا وَجَوَاب لَوْ لَكَانَ خَيْرًا لَهُمْ"
  9,60,"﴿إِنَّمَا ٱلصَّدَقَـٰتُ﴾ الزَّكَوَات مَصْرُوفَة ﴿لِلۡفُقَرَاۤءِ﴾ الَّذِينَ لَا يَجِدُونَ مَا يَقَع مَوْقِعًا مِنْ كِفَايَتهمْ ﴿وَٱلۡمَسَـٰكِینِ﴾ الَّذِينَ لَا يَجِدُونَ مَا يَكْفِيهِمْ ﴿وَٱلۡعَـٰمِلِینَ عَلَیۡهَا﴾ أَيْ الصَّدَقَات مِنْ جَابٍ وَقَاسِم وَكَاتِب وَحَاشِر ﴿وَٱلۡمُؤَلَّفَةِ قُلُوبُهُمۡ﴾ لِيُسْلِمُوا أَوْ يَثْبُت إسْلَامهمْ أَوْ يَسْلَم نُظَرَاؤُهُمْ أَوْ يَذُبُّوا عَنْ الْمُسْلِمِينَ أَقْسَام الْأَوَّل وَالْأَخِير لَا يُعْطِيَانِ الْيَوْم عِنْد الشَّافِعِيّ رَضِيَ اللَّه تَعَالَى عَنْهُ لِعَزِّ الْإِسْلَام بِخِلَافِ الْآخَرَيْنِ فَيُعْطِيَانِ عَلَى الْأَصَحّ ﴿وَفِی﴾ فَكّ ﴿ٱلرِّقَابِ﴾ أَيْ الْمُكَاتَبِينَ ﴿وَٱلۡغَـٰرِمِینَ﴾ أَهْل الدِّين إنْ اسْتَدَانُوا لِغَيْرِ مَعْصِيَة أَوْ تَابُوا وَلَيْسَ لَهُمْ وَفَاء أَوْ لِإِصْلَاحِ ذَات الْبَيْن وَلَوْ أَغْنِيَاء ﴿وَفِی سَبِیلِ ٱللَّهِ﴾ أَيْ الْقَائِمِينَ بِالْجِهَادِ مِمَّنْ لَا فيء لهم ولو أغنياء ﴿وَٱبۡنِ ٱلسَّبِیلِۖ﴾ الْمُنْقَطِع فِي سَفَره ﴿فَرِیضَةࣰ﴾ نُصِبَ بِفِعْلِهِ الْمُقَدَّر ﴿مِّنَ ٱللَّهِۗ وَٱللَّهُ عَلِیمٌ﴾ بِخَلْقِهِ ﴿حَكِیمࣱ ۝٦٠﴾ فِي صُنْعه فَلَا يَجُوز صَرْفهَا لِغَيْرِ هَؤُلَاءِ ولا مانع صِنْف مِنْهُمْ إذَا وُجِدَ فَيَقْسِمهَا الْإِمَام عَلَيْهِمْ عَلَى السَّوَاء وَلَهُ تَفْضِيل بَعْض آحَاد الصِّنْف عَلَى بَعْض وَأَفَادَتْ اللَّام وُجُوب اسْتِغْرَاق أَفْرَاده لَكِنْ لَا يَجِب عَلَى صَاحِب الْمَال إذَا قَسَمَ لِعُسْرِهِ بَلْ يَكْفِي إعْطَاء ثَلَاثَة مِنْ كُلّ صِنْف وَلَا يَكْفِي دُونهَا كَمَا أَفَادَتْهُ صِيغَة الْجَمْع وَبَيَّنَتْ السُّنَّة أَنَّ شَرْط الْمُعْطَى مِنْهَا الْإِسْلَام وَأَنْ لَا يَكُون هَاشِمِيًّا وَلَا مطلبيا"
  9,61,"﴿وَمِنۡهُمُ﴾ أَيْ الْمُنَافِقِينَ ﴿ٱلَّذِینَ یُؤۡذُونَ ٱلنَّبِیَّ﴾ بِعَيْبِهِ وَبِنَقْلِ حَدِيثه ﴿وَیَقُولُونَ﴾ إذَا نُهُوا عَنْ ذَلِكَ لِئَلَّا يُبَلِّغهُ ﴿هُوَ أُذُنࣱۚ﴾ أَيْ يَسْمَع كُلّ قَيْل وَيَقْبَلهُ فَإِذَا حَلَفْنَا لَهُ أَنَّا لَمْ نَقُلْ صَدَّقْنَا ﴿قُلۡ﴾ هُوَ ﴿أُذُنُ﴾ مُسْتَمِع ﴿خَیۡرࣲ لَّكُمۡ﴾ لَا مُسْتَمِع شَرّ ﴿یُؤۡمِنُ بِٱللَّهِ وَیُؤۡمِنُ﴾ يُصَدِّق ﴿لِلۡمُؤۡمِنِینَ﴾ فِيمَا أَخْبَرُوهُ بِهِ لَا لِغَيْرِهِمْ وَاللَّام زَائِدَة لِلْفَرَقِ بَيْن إيمَان التَّسْلِيم وَغَيْره ﴿وَرَحۡمَةࣱ﴾ بِالرَّفْعِ عَطْفًا عَلَى أُذُن وَالْجَرّ عَطْفًا على خير ﴿لِّلَّذِینَ ءَامَنُوا۟ مِنكُمۡۚ وَٱلَّذِینَ یُؤۡذُونَ رَسُولَ ٱللَّهِ لَهُمۡ عَذَابٌ أَلِیمࣱ ۝٦١﴾"
  9,62,"﴿یَحۡلِفُونَ بِٱللَّهِ لَكُمۡ﴾ أَيّهَا الْمُؤْمِنُونَ فِيمَا بَلَغَكُمْ عَنْهُمْ مِنْ أَذَى الرَّسُول أَنَّهُمْ مَا أَتَوْهُ ﴿لِیُرۡضُوكُمۡ وَٱللَّهُ وَرَسُولُهُۥۤ أَحَقُّ أَن یُرۡضُوهُ﴾ بِالطَّاعَةِ ﴿إِن كَانُوا۟ مُؤۡمِنِینَ ۝٦٢﴾ حقا وَتَوْحِيد الضَّمِير لِتَلَازُمِ الرِّضَاءَيْنِ أَوْ خَبَر اللَّه ورسوله محذوف"
  9,63,"﴿أَلَمۡ یَعۡلَمُوۤا۟﴾ بِ ﴿أَنَّهُۥ﴾ أَيْ الشَّأْن ﴿مَن یُحَادِدِ﴾ يُشَاقِقْ ﴿ٱللَّهَ وَرَسُولَهُۥ فَأَنَّ لَهُۥ نَارَ جَهَنَّمَ﴾ جزاء ﴿خَـٰلِدࣰا فِیهَاۚ ذَ ٰ⁠لِكَ ٱلۡخِزۡیُ ٱلۡعَظِیمُ ۝٦٣﴾"
  9,64,"﴿یَحۡذَرُ﴾ يخاق ﴿ٱلۡمُنَـٰفِقُونَ أَن تُنَزَّلَ عَلَیۡهِمۡ﴾ أَيْ الْمُؤْمِنِينَ ﴿سُورَةࣱ تُنَبِّئُهُم بِمَا فِی قُلُوبِهِمۡۚ﴾ مِنْ النِّفَاق وَهُمْ مَعَ ذَلِكَ يَسْتَهْزِئُونَ ﴿قُلِ ٱسۡتَهۡزِءُوۤا۟﴾ أَمْر تَهْدِيد ﴿إِنَّ ٱللَّهَ مُخۡرِجࣱ﴾ مُظْهِر ﴿مَّا تَحۡذَرُونَ ۝٦٤﴾ إخْرَاجه من نفاقكم"
  9,65,"﴿وَلَىِٕن﴾ لَام قَسَم ﴿سَأَلۡتَهُمۡ﴾ عَنْ اسْتِهْزَائِهِمْ بِك وَالْقُرْآن وَهُمْ سَائِرُونَ مَعَك إلَى تَبُوك ﴿لَیَقُولُنَّ﴾ مُعْتَذِرِينَ ﴿إِنَّمَا كُنَّا نَخُوضُ وَنَلۡعَبُۚ﴾ فِي الْحَدِيث لِنَقْطَع بِهِ الطَّرِيق وَلَمْ نَقْصِد ذَلِكَ ﴿قُلۡ﴾ لهم ﴿أَبِٱللَّهِ وَءَایَـٰتِهِۦ وَرَسُولِهِۦ كُنتُمۡ تَسۡتَهۡزِءُونَ ۝٦٥﴾"
  9,66,"﴿لَا تَعۡتَذِرُوا۟﴾ عَنْهُ ﴿قَدۡ كَفَرۡتُم بَعۡدَ إِیمَـٰنِكُمۡۚ﴾ أَيْ ظَهَرَ كُفْركُمْ بَعْد إظْهَار الْإِيمَان ﴿إِن یُعۡفَ﴾ بِالْيَاءِ مَبْنِيًّا لِلْمَفْعُولِ وَالنُّون مَبْنِيًّا لِلْفَاعِلِ ﴿عَن طَاۤىِٕفَةࣲ مِّنكُمۡ﴾ بِإِخْلَاصِهَا وَتَوْبَتهَا كَجَحْشِ بْن حمير ﴿تُعَذَّبۡ﴾ بِالتَّاءِ وَالنُّون ﴿طَاۤىِٕفَةُۢ بِأَنَّهُمۡ كَانُوا۟ مُجۡرِمِینَ ۝٦٦﴾ مُصِرِّينَ عَلَى النِّفَاق وَالِاسْتِهْزَاء"
  9,67,"﴿ٱلۡمُنَـٰفِقُونَ وَٱلۡمُنَـٰفِقَـٰتُ بَعۡضُهُم مِّنۢ بَعۡضࣲۚ﴾ أَيْ مُتَشَابِهُونَ فِي الدِّين كَأَبْعَاضِ الشَّيْء الْوَاحِد ﴿یَأۡمُرُونَ بِٱلۡمُنكَرِ﴾ الْكُفْر وَالْمَعَاصِي ﴿وَیَنۡهَوۡنَ عَنِ ٱلۡمَعۡرُوفِ﴾ الْإِيمَان وَالطَّاعَة ﴿وَیَقۡبِضُونَ أَیۡدِیَهُمۡۚ﴾ عَنْ الْإِنْفَاق فِي الطَّاعَة ﴿نَسُوا۟ ٱللَّهَ﴾ تَرَكُوا طَاعَته ﴿فَنَسِیَهُمۡۚ﴾ تَرَكَهُمْ مِنْ لُطْفه ﴿إِنَّ ٱلۡمُنَـٰفِقِینَ هُمُ ٱلۡفَـٰسِقُونَ ۝٦٧﴾"
  9,68,"﴿وَعَدَ ٱللَّهُ ٱلۡمُنَـٰفِقِینَ وَٱلۡمُنَـٰفِقَـٰتِ وَٱلۡكُفَّارَ نَارَ جَهَنَّمَ خَـٰلِدِینَ فِیهَاۚ هِیَ حَسۡبُهُمۡۚ﴾ جَزَاء وَعِقَابًا ﴿وَلَعَنَهُمُ ٱللَّهُۖ﴾ أَبْعَدهمْ عَنْ رَحْمَته ﴿وَلَهُمۡ عَذَابࣱ مُّقِیمࣱ ۝٦٨﴾ دائم"
  9,69,"أَنْتُمْ أَيّهَا الْمُنَافِقُونَ ﴿كَٱلَّذِینَ مِن قَبۡلِكُمۡ كَانُوۤا۟ أَشَدَّ مِنكُمۡ قُوَّةࣰ وَأَكۡثَرَ أَمۡوَ ٰ⁠لࣰا وَأَوۡلَـٰدࣰا فَٱسۡتَمۡتَعُوا۟﴾ تَمَتَّعُوا ﴿بِخَلَـٰقِهِمۡ﴾ نَصِيبهمْ مِنْ الدُّنْيَا ﴿فَٱسۡتَمۡتَعۡتُم﴾ أَيّهَا الْمُنَافِقُونَ ﴿بِخَلَـٰقِكُمۡ كَمَا ٱسۡتَمۡتَعَ ٱلَّذِینَ مِن قَبۡلِكُم بِخَلَـٰقِهِمۡ وَخُضۡتُمۡ﴾ فِي الْبَاطِل وَالطَّعْن فِي النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿كَٱلَّذِی خَاضُوۤا۟ۚ﴾ أَيْ خوضهم ﴿أُو۟لَـٰۤىِٕكَ حَبِطَتۡ أَعۡمَـٰلُهُمۡ فِی ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِۖ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡخَـٰسِرُونَ ۝٦٩﴾"
  9,70,"﴿أَلَمۡ یَأۡتِهِمۡ نَبَأُ﴾ خَبَر ﴿ٱلَّذِینَ مِن قَبۡلِهِمۡ قَوۡمِ نُوحࣲ وَعَادࣲ﴾ قوم هود ﴿وَثَمُودَ﴾ قوم صَالِح ﴿وَقَوۡمِ إِبۡرَ ٰ⁠هِیمَ وَأَصۡحَـٰبِ مَدۡیَنَ﴾ قَوْم شُعَيْب ﴿وَٱلۡمُؤۡتَفِكَـٰتِۚ﴾ قُرَى قَوْم لُوط أَيْ أَهْلهَا ﴿أَتَتۡهُمۡ رُسُلُهُم بِٱلۡبَیِّنَـٰتِۖ﴾ بِالْمُعْجِزَاتِ فَكَذَبُوهُمْ فَأُهْلِكُوا ﴿فَمَا كَانَ ٱللَّهُ لِیَظۡلِمَهُمۡ﴾ بِأَنْ يُعَذِّبهُمْ بِغَيْرِ ذَنْب ﴿وَلَـٰكِن كَانُوۤا۟ أَنفُسَهُمۡ یَظۡلِمُونَ ۝٧٠﴾ بِارْتِكَابِ الذَّنْب"
  9,71,"﴿وَٱلۡمُؤۡمِنُونَ وَٱلۡمُؤۡمِنَـٰتُ بَعۡضُهُمۡ أَوۡلِیَاۤءُ بَعۡضࣲۚ یَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَیَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَیُقِیمُونَ ٱلصَّلَوٰةَ وَیُؤۡتُونَ ٱلزَّكَوٰةَ وَیُطِیعُونَ ٱللَّهَ وَرَسُولَهُۥۤۚ أُو۟لَـٰۤىِٕكَ سَیَرۡحَمُهُمُ ٱللَّهُۗ إِنَّ ٱللَّهَ عَزِیزٌ﴾ لَا يُعْجِزهُ شَيْء عَنْ إنْجَاز وَعْده وَوَعِيده ﴿حَكِیمࣱ ۝٧١﴾ لَا يَضَع شَيْئًا إلَّا في محله"
  9,72,"﴿وَعَدَ ٱللَّهُ ٱلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِ جَنَّـٰتࣲ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُ خَـٰلِدِینَ فِیهَا وَمَسَـٰكِنَ طَیِّبَةࣰ فِی جَنَّـٰتِ عَدۡنࣲۚ﴾ إقَامَة ﴿وَرِضۡوَ ٰ⁠نࣱ مِّنَ ٱللَّهِ أَكۡبَرُۚ﴾ أعظم من ذلك كله ﴿ذَ ٰ⁠لِكَ هُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٧٢﴾"
  9,73,"﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ جَـٰهِدِ ٱلۡكُفَّارَ﴾ بِالسَّيْفِ ﴿وَٱلۡمُنَـٰفِقِینَ﴾ بِاللِّسَانِ وَالْحُجَّة ﴿وَٱغۡلُظۡ عَلَیۡهِمۡۚ﴾ بِالِانْتِهَارِ وَالْمَقْت ﴿وَمَأۡوَىٰهُمۡ جَهَنَّمُۖ وَبِئۡسَ ٱلۡمَصِیرُ ۝٧٣﴾ الْمَرْجِع هِيَ"
  9,74,"﴿یَحۡلِفُونَ﴾ أَيْ الْمُنَافِقُونَ ﴿بِٱللَّهِ مَا قَالُوا۟﴾ مَا بَلَغَك عَنْهُمْ مِنْ السَّبّ ﴿وَلَقَدۡ قَالُوا۟ كَلِمَةَ ٱلۡكُفۡرِ وَكَفَرُوا۟ بَعۡدَ إِسۡلَـٰمِهِمۡ﴾ أَظْهَرُوا الْكُفْر بَعْد إظْهَار الْإِسْلَام ﴿وَهَمُّوا۟ بِمَا لَمۡ یَنَالُوا۟ۚ﴾ مِنْ الْفَتْك بِالنَّبِيِّ لَيْلَة الْعَقَبَة عِنْد عَوْده مِنْ تَبُوك وَهُمْ بَضْعَة عَشَرَ رَجُلًا فَضَرَبَ عَمَّار بْن يَاسِر وُجُوه الرَّوَاحِل لَمَّا غَشُوهُ فَرُدُّوا ﴿وَمَا نَقَمُوۤا۟﴾ أَنْكَرُوا ﴿إِلَّاۤ أَنۡ أَغۡنَىٰهُمُ ٱللَّهُ وَرَسُولُهُۥ مِن فَضۡلِهِۦۚ﴾ بِالْغَنَائِمِ بَعْد شِدَّة حَاجَتهمْ الْمَعْنَى لَمْ يَنَلْهُمْ مِنْهُ إلَّا هَذَا وَلَيْسَ مِمَّا يَنْقِم ﴿فَإِن یَتُوبُوا۟﴾ عَنْ النِّفَاق وَيُؤْمِنُوا بِك ﴿یَكُ خَیۡرࣰا لَّهُمۡۖ وَإِن یَتَوَلَّوۡا۟﴾ عَنْ الإيمان ﴿یُعَذِّبۡهُمُ ٱللَّهُ عَذَابًا أَلِیمࣰا فِی ٱلدُّنۡیَا﴾ بِالْقَتْلِ ﴿وَٱلۡـَٔاخِرَةِۚ﴾ بِالنَّارِ ﴿وَمَا لَهُمۡ فِی ٱلۡأَرۡضِ مِن وَلِیࣲّ﴾ يَحْفَظهُمْ مِنْهُ ﴿وَلَا نَصِیرࣲ ۝٧٤﴾ يَمْنَعهُمْ"
  9,75,"﴿وَمِنۡهُم مَّنۡ عَـٰهَدَ ٱللَّهَ لَىِٕنۡ ءَاتَىٰنَا مِن فَضۡلِهِۦ لَنَصَّدَّقَنَّ﴾ فِيهِ إدْغَام التَّاء فِي الْأَصْل فِي الصَّاد ﴿وَلَنَكُونَنَّ مِنَ ٱلصَّـٰلِحِینَ ۝٧٥﴾ وَهُوَ ثَعْلَبَة بْن حَاطِب سَأَلَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ أَنْ يَدْعُو لَهُ أَنْ يَرْزُقهُ اللَّه مالا ويؤدي منه إلى كُلّ ذِي حَقّ حَقّه فَدَعَا لَهُ فَوَسَّعَ عَلَيْهِ فَانْقَطَعَ عَنْ الْجُمُعَة وَالْجَمَاعَة وَمَنَعَ الزَّكَاة كما قال تعالى"
  9,76,"﴿فَلَمَّاۤ ءَاتَىٰهُم مِّن فَضۡلِهِۦ بَخِلُوا۟ بِهِۦ وَتَوَلَّوا۟﴾ عن طاعة الله ﴿وَّهُم مُّعۡرِضُونَ ۝٧٦﴾"
  9,77,"﴿فَأَعۡقَبَهُمۡ﴾ أَيْ فَصَيَّرَ عَاقِبَتهمْ ﴿نِفَاقࣰا﴾ ثَابِتًا ﴿فِی قُلُوبِهِمۡ إِلَىٰ یَوۡمِ یَلۡقَوۡنَهُۥ﴾ أَيْ اللَّه وَهُوَ يوم القيامة ﴿بِمَاۤ أَخۡلَفُوا۟ ٱللَّهَ مَا وَعَدُوهُ وَبِمَا كَانُوا۟ یَكۡذِبُونَ ۝٧٧﴾ فيه فَجَاءَ بَعْد ذَلِكَ إلَى النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ بِزَكَاتِهِ فَقَالَ إنَّ اللَّه مَنَعَنِي أَنْ أَقْبَلَ مِنْك فَجَعَلَ يَحْثُو التُّرَاب عَلَى رأسه ثم جاء بها إلَى أَبِي بَكْر فَلَمْ يَقْبَلهَا ثُمَّ إلَى عُمَر فَلَمْ يَقْبَلهَا ثُمَّ إلَى عُثْمَان فَلَمْ يَقْبَلهَا وَمَاتَ فِي زَمَانه"
  9,78,"﴿أَلَمۡ یَعۡلَمُوۤا۟﴾ أَيْ الْمُنَافِقُونَ ﴿أَنَّ ٱللَّهَ یَعۡلَمُ سِرَّهُمۡ﴾ مَا أَسَرُّوهُ فِي أَنْفُسهمْ ﴿وَنَجۡوَىٰهُمۡ﴾ مَا تَنَاجَوْا بِهِ بَيْنهمْ ﴿وَأَنَّ ٱللَّهَ عَلَّـٰمُ ٱلۡغُیُوبِ ۝٧٨﴾ مَا غَابَ عَنْ الْعِيَان وَلَمَّا نَزَلَتْ آيَة الصَّدَقَة جَاءَ رَجُل فَتَصَدَّقَ بِشَيْءٍ كَثِير فَقَالَ الْمُنَافِقُونَ مُرَاءٍ وَجَاءَ رَجُل فَتَصَدَّقَ بِصَاعٍ فَقَالُوا إنَّ اللَّه غَنِيّ عَنْ صَدَقَة هَذَا فَنَزَلَ"
  9,79,"﴿ٱلَّذِینَ﴾ مُبْتَدَأ ﴿یَلۡمِزُونَ﴾ يَعِيبُونَ ﴿ٱلۡمُطَّوِّعِینَ﴾ الْمُتَنَفِّلِينَ ﴿مِنَ ٱلۡمُؤۡمِنِینَ فِی ٱلصَّدَقَـٰتِ وَٱلَّذِینَ لَا یَجِدُونَ إِلَّا جُهۡدَهُمۡ﴾ طَاقَتهمْ فَيَأْتُونَ بِهِ ﴿فَیَسۡخَرُونَ مِنۡهُمۡ﴾ وَالْخَبَر ﴿سَخِرَ ٱللَّهُ مِنۡهُمۡ﴾ جازاهم على سخريتهم ﴿وَلَهُمۡ عَذَابٌ أَلِیمٌ ۝٧٩﴾"
  9,80,"﴿ٱسۡتَغۡفِرۡ﴾ يَا مُحَمَّد ﴿لَهُمۡ أَوۡ لَا تَسۡتَغۡفِرۡ لَهُمۡ﴾ تَخْيِير لَهُ فِي الِاسْتِغْفَار وَتَرْكه قَالَ صلى الله عليه وسلم إني خيرت اخترت يَعْنِي الِاسْتِغْفَار رَوَاهُ الْبُخَارِيّ ﴿إِن تَسۡتَغۡفِرۡ لَهُمۡ سَبۡعِینَ مَرَّةࣰ فَلَن یَغۡفِرَ ٱللَّهُ لَهُمۡۚ﴾ قِيلَ الْمُرَاد بِالسَّبْعِينَ الْمُبَالَغَة فِي كَثْرَة الِاسْتِغْفَار وَفِي الْبُخَارِيّ حَدِيث لَوْ أَعْلَم أَنِّي لَوْ زِدْت عَلَى السَّبْعِينَ غُفِرَ لَزِدْت عَلَيْهَا وَقِيلَ الْمُرَاد العدد المخصوص لحديثه أيضا وسأزيد على السبعين فبين لَهُ حَسْم الْمَغْفِرَة بِآيَةِ {سَوَاۤءٌ عَلَیۡهِمۡ أَسۡتَغۡفَرۡتَ لَهُمۡ أَمۡ لَمۡ تَسۡتَغۡفِرۡ لَهُمۡ} ﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَفَرُوا۟ بِٱللَّهِ وَرَسُولِهِۦۗ وَٱللَّهُ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلۡفَـٰسِقِینَ﴾"
  9,81,"﴿فَرِحَ ٱلۡمُخَلَّفُونَ﴾ عَنْ تَبُوك ﴿بِمَقۡعَدِهِمۡ﴾ أَيْ بِقُعُودِهِمْ ﴿خِلَـٰفَ﴾ أَيْ بَعْد ﴿رَسُولِ ٱللَّهِ وَكَرِهُوۤا۟ أَن یُجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡ فِی سَبِیلِ ٱللَّهِ وَقَالُوا۟﴾ أَيْ قَالَ بَعْضهمْ لِبَعْضٍ ﴿لَا تَنفِرُوا۟﴾ تَخْرُجُوا إلَى الْجِهَاد ﴿فِی ٱلۡحَرِّۗ قُلۡ نَارُ جَهَنَّمَ أَشَدُّ حَرࣰّاۚ﴾ مِنْ تَبُوك فَالْأَوْلَى أَنْ يَتَّقُوهَا بِتَرْكِ التَّخَلُّف ﴿لَّوۡ كَانُوا۟ یَفۡقَهُونَ ۝٨١﴾ يَعْلَمُونَ ذَلِكَ مَا تَخَلَّفُوا"
  9,82,"﴿فَلۡیَضۡحَكُوا۟ قَلِیلࣰا﴾ فِي الدُّنْيَا ﴿وَلۡیَبۡكُوا۟﴾ فِي الْآخِرَة ﴿كَثِیرࣰا جَزَاۤءَۢ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٨٢﴾ خَبَر عَنْ حَالهمْ بِصِيغَةِ الْأَمْر"
  9,83,"﴿فَإِن رَّجَعَكَ﴾ رَدَّك ﴿ٱللَّهُ﴾ مِنْ تَبُوك ﴿إِلَىٰ طَاۤىِٕفَةࣲ مِّنۡهُمۡ﴾ مِمَّنْ تَخَلَّفَ بِالْمَدِينَةِ مِنْ الْمُنَافِقِينَ ﴿فَٱسۡتَـٔۡذَنُوكَ لِلۡخُرُوجِ﴾ مَعَك إلَى غَزْوَة أُخْرَى ﴿فَقُل﴾ لَهُمْ ﴿لَّن تَخۡرُجُوا۟ مَعِیَ أَبَدࣰا وَلَن تُقَـٰتِلُوا۟ مَعِیَ عَدُوًّاۖ إِنَّكُمۡ رَضِیتُم بِٱلۡقُعُودِ أَوَّلَ مَرَّةࣲ فَٱقۡعُدُوا۟ مَعَ ٱلۡخَـٰلِفِینَ ۝٨٣﴾ الْمُتَخَلِّفِينَ عَنْ الْغَزْو مِنْ النِّسَاء وَالصِّبْيَان وَغَيْرهمْ"
  9,84,"وَلَمَّا صَلَّى النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ على ابن أُبَيٍّ نَزَلَ ﴿وَلَا تُصَلِّ عَلَىٰۤ أَحَدࣲ مِّنۡهُم مَّاتَ أَبَدࣰا وَلَا تَقُمۡ عَلَىٰ قَبۡرِهِۦۤۖ﴾ لِدَفْنٍ أَوْ زِيَارَة ﴿إِنَّهُمۡ كَفَرُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَمَاتُوا۟ وَهُمۡ فَـٰسِقُونَ ۝٨٤﴾ كَافِرُونَ"
  9,85,"﴿وَلَا تُعۡجِبۡكَ أَمۡوَ ٰ⁠لُهُمۡ وَأَوۡلَـٰدُهُمۡۚ إِنَّمَا یُرِیدُ ٱللَّهُ أَن یُعَذِّبَهُم بِهَا فِی ٱلدُّنۡیَا وَتَزۡهَقَ﴾ تَخْرُج ﴿أَنفُسُهُمۡ وَهُمۡ كَـٰفِرُونَ ۝٨٥﴾"
  9,86,"﴿وَإِذَاۤ أُنزِلَتۡ سُورَةٌ﴾ أَيْ طَائِفَة مِنْ الْقُرْآن ﴿أَنۡ﴾ أَيْ بِأَنْ ﴿ءَامِنُوا۟ بِٱللَّهِ وَجَـٰهِدُوا۟ مَعَ رَسُولِهِ ٱسۡتَـٔۡذَنَكَ أُو۟لُوا۟ ٱلطَّوۡلِ﴾ ذوو الغنى ﴿مِنۡهُمۡ وَقَالُوا۟ ذَرۡنَا نَكُن مَّعَ ٱلۡقَـٰعِدِینَ ۝٨٦﴾"
  9,87,"﴿رَضُوا۟ بِأَن یَكُونُوا۟ مَعَ ٱلۡخَوَالِفِ﴾ جَمْع خَالِفَة أَيْ النِّسَاء اللَّاتِي تَخَلَّفْنَ فِي الْبُيُوت ﴿وَطُبِعَ عَلَىٰ قُلُوبِهِمۡ فَهُمۡ لَا یَفۡقَهُونَ ۝٨٧﴾ الْخَيْر"
  9,88,"﴿لَـٰكِنِ ٱلرَّسُولُ وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ جَـٰهَدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡۚ وَأُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡخَیۡرَ ٰ⁠تُۖ﴾ فِي الدُّنْيَا وَالْآخِرَة ﴿وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٨٨﴾ أي الفائزون"
  9,89,"﴿أَعَدَّ ٱللَّهُ لَهُمۡ جَنَّـٰتࣲ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُ خَـٰلِدِینَ فِیهَاۚ ذَ ٰ⁠لِكَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٨٩﴾"
  9,90,"﴿وَجَاۤءَ ٱلۡمُعَذِّرُونَ﴾ بِإِدْغَامِ التَّاء فِي الْأَصْل فِي الدَّال أَيْ الْمُعْتَذِرُونَ بِمَعْنَى الْمَعْذُورِينَ وَقُرِئَ بِهِ ﴿مِنَ ٱلۡأَعۡرَابِ﴾ إلَى النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿لِیُؤۡذَنَ لَهُمۡ﴾ فِي الْقُعُود لِعُذْرِهِمْ فَأَذِنَ لَهُمْ ﴿وَقَعَدَ ٱلَّذِینَ كَذَبُوا۟ ٱللَّهَ وَرَسُولَهُۥۚ﴾ فِي ادِّعَاء الْإِيمَان مِنْ مُنَافِقِي الْأَعْرَاب عَنْ الْمَجِيء للاعتذار ﴿سَیُصِیبُ ٱلَّذِینَ كَفَرُوا۟ مِنۡهُمۡ عَذَابٌ أَلِیمࣱ ۝٩٠﴾"
  9,91,"﴿لَّیۡسَ عَلَى ٱلضُّعَفَاۤءِ﴾ كَالشُّيُوخِ ﴿وَلَا عَلَى ٱلۡمَرۡضَىٰ﴾ كَالْعُمْيِ وَالزَّمْنَى ﴿وَلَا عَلَى ٱلَّذِینَ لَا یَجِدُونَ مَا یُنفِقُونَ﴾ فِي الْجِهَاد ﴿حَرَجٌ﴾ إثْم فِي التَّخَلُّف عَنْهُ ﴿إِذَا نَصَحُوا۟ لِلَّهِ وَرَسُولِهِۦۚ﴾ فِي حَال قُعُودهمْ بِعَدَمِ الْإِرْجَاف وَالتَّثْبِيط وَالطَّاعَة ﴿مَا عَلَى ٱلۡمُحۡسِنِینَ﴾ بِذَلِكَ ﴿مِن سَبِیلࣲۚ﴾ طَرِيق بِالْمُؤَاخَذَةِ ﴿وَٱللَّهُ غَفُورࣱ﴾ لَهُمْ ﴿رَّحِیمࣱ ۝٩١﴾ بِهِمْ فِي التَّوْسِعَة في ذلك"
  9,92,"﴿وَلَا عَلَى ٱلَّذِینَ إِذَا مَاۤ أَتَوۡكَ لِتَحۡمِلَهُمۡ﴾ مَعَك إلَى الْغَزْو وَهُمْ سَبْعَة مِنْ الْأَنْصَار وَقِيلَ بَنُو مُقْرِن ﴿قُلۡتَ لَاۤ أَجِدُ مَاۤ أَحۡمِلُكُمۡ عَلَیۡهِ﴾ حَال ﴿تَوَلَّوا۟﴾ جَوَاب إذَا أَيْ انْصَرَفُوا ﴿وَّأَعۡیُنُهُمۡ تَفِیضُ﴾ تَسِيل ﴿مِنَ﴾ لِلْبَيَانِ ﴿ٱلدَّمۡعِ حَزَنًا﴾ لِأَجْلِ ﴿أَلَّا یَجِدُوا۟ مَا یُنفِقُونَ ۝٩٢﴾ فِي الجهاد"
  9,93,"﴿إِنَّمَا ٱلسَّبِیلُ عَلَى ٱلَّذِینَ یَسۡتَـٔۡذِنُونَكَ﴾ فِي التَّخَلُّف ﴿وَهُمۡ أَغۡنِیَاۤءُۚ رَضُوا۟ بِأَن یَكُونُوا۟ مَعَ ٱلۡخَوَالِفِ وَطَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمۡ فَهُمۡ لَا یَعۡلَمُونَ ۝٩٣﴾ تقدم مثله"
  9,94,"﴿یَعۡتَذِرُونَ إِلَیۡكُمۡ﴾ فِي التَّخَلُّف ﴿إِذَا رَجَعۡتُمۡ إِلَیۡهِمۡۚ﴾ مِنْ الْغَزْو ﴿قُل﴾ لَهُمْ ﴿لَّا تَعۡتَذِرُوا۟ لَن نُّؤۡمِنَ لَكُمۡ﴾ نُصَدِّقكُمْ ﴿قَدۡ نَبَّأَنَا ٱللَّهُ مِنۡ أَخۡبَارِكُمۡۚ﴾ أَيْ أَخْبَرَنَا بِأَحْوَالِكُمْ ﴿وَسَیَرَى ٱللَّهُ عَمَلَكُمۡ وَرَسُولُهُۥ ثُمَّ تُرَدُّونَ﴾ بِالْبَعْثِ ﴿إِلَىٰ عَـٰلِمِ ٱلۡغَیۡبِ وَٱلشَّهَـٰدَةِ﴾ أَيْ اللَّه ﴿فَیُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٩٤﴾ فيجازيكم عليه"
  9,95,"﴿سَیَحۡلِفُونَ بِٱللَّهِ لَكُمۡ إِذَا ٱنقَلَبۡتُمۡ﴾ رَجَعْتُمْ ﴿إِلَیۡهِمۡ﴾ مِنْ تَبُوك أَنَّهُمْ مَعْذُورُونَ فِي التَّخَلُّف ﴿لِتُعۡرِضُوا۟ عَنۡهُمۡۖ﴾ بِتَرْكِ الْمُعَاتَبَة ﴿فَأَعۡرِضُوا۟ عَنۡهُمۡۖ إِنَّهُمۡ رِجۡسࣱۖ﴾ قذر لخبث باطنهم ﴿وَمَأۡوَىٰهُمۡ جَهَنَّمُ جَزَاۤءَۢ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٩٥﴾"
  9,96,"﴿یَحۡلِفُونَ لَكُمۡ لِتَرۡضَوۡا۟ عَنۡهُمۡۖ فَإِن تَرۡضَوۡا۟ عَنۡهُمۡ فَإِنَّ ٱللَّهَ لَا یَرۡضَىٰ عَنِ ٱلۡقَوۡمِ ٱلۡفَـٰسِقِینَ ۝٩٦﴾ أَيْ عَنْهُمْ وَلَا يَنْفَع رِضَاكُمْ مَعَ سَخَط الله"
  9,97,"﴿ٱلۡأَعۡرَابُ﴾ أَهْل الْبَدْو ﴿أَشَدُّ كُفۡرࣰا وَنِفَاقࣰا﴾ مِنْ أَهْل الْمُدُن لِجَفَائِهِمْ وَغِلَظ طِبَاعهمْ وَبُعْدهمْ عَنْ سماع القرآن ﴿وَأَجۡدَرُ﴾ أولى ﴿أَ﴾ن أَيْ بِأَنْ ﴿لَّا یَعۡلَمُوا۟ حُدُودَ مَاۤ أَنزَلَ ٱللَّهُ عَلَىٰ رَسُولِهِۦۗ﴾ مِنْ الْأَحْكَام وَالشَّرَائِع ﴿وَٱللَّهُ عَلِیمٌ﴾ بِخَلْقِهِ ﴿حَكِیمࣱ ۝٩٧﴾ فِي صُنْعه بِهِمْ"
  9,98,"﴿وَمِنَ ٱلۡأَعۡرَابِ مَن یَتَّخِذُ مَا یُنفِقُ﴾ فِي سَبِيل اللَّه ﴿مَغۡرَمࣰا﴾ غَرَامَة وَخُسْرَانًا لِأَنَّهُ لَا يَرْجُو ثَوَابه بَلْ يُنْفِقهُ خَوْفًا وَهُمْ بَنُو أَسَد وَغَطَفَان ﴿وَیَتَرَبَّصُ﴾ يَنْتَظِر ﴿بِكُمُ ٱلدَّوَاۤىِٕرَۚ﴾ دَوَائِر الزَّمَان أَنْ تَنْقَلِب عَلَيْكُمْ فَيَتَخَلَّص ﴿عَلَیۡهِمۡ دَاۤىِٕرَةُ ٱلسُّوٓءِۗ﴾ بِالضَّمِّ وَالْفَتْح أَيْ يَدُور الْعَذَاب وَالْهَلَاك عَلَيْهِمْ لَا عَلَيْكُمْ ﴿وَٱللَّهُ سَمِیعٌ﴾ لِأَقْوَالِ عِبَاده ﴿عَلِیمࣱ ۝٩٨﴾ بأفعالهم"
  9,99,"﴿وَمِنَ ٱلۡأَعۡرَابِ مَن یُؤۡمِنُ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ﴾ كَجُهَيْنَة وَمُزَيْنَةَ ﴿وَیَتَّخِذُ مَا یُنفِقُ﴾ فِي سَبِيل الله ﴿قُرُبَـٰتٍ﴾ تقربه ﴿عِندَ ٱللَّهِ وَ﴾ وسيلة إلى ﴿صَلَوَ ٰ⁠تِ﴾ دَعَوَات ﴿ٱلرَّسُولِۚ﴾ لَهُ ﴿أَلَاۤ إِنَّهَا﴾ أَيْ نَفَقَتهمْ ﴿قُرُبَةࣱ﴾ بِضَمِّ الرَّاء وَسُكُونهَا ﴿لَّهُمۡۚ﴾ عِنْده ﴿سَیُدۡخِلُهُمُ ٱللَّهُ فِی رَحۡمَتِهِۦۤۚ﴾ جَنَّته ﴿إِنَّ ٱللَّهَ غَفُورࣱ﴾ لِأَهْلِ طَاعَته ﴿رَّحِیمࣱ ۝٩٩﴾ بِهِمْ"
  9,100,"﴿وَٱلسَّـٰبِقُونَ ٱلۡأَوَّلُونَ مِنَ ٱلۡمُهَـٰجِرِینَ وَٱلۡأَنصَارِ﴾ وَهُمْ مَنْ شَهِدَ بَدْرًا أَوْ جَمِيع الصَّحَابَة ﴿وَٱلَّذِینَ ٱتَّبَعُوهُم﴾ إلَى يَوْم الْقِيَامَة ﴿بِإِحۡسَـٰنࣲ﴾ فِي الْعَمَل ﴿رَّضِیَ ٱللَّهُ عَنۡهُمۡ﴾ بِطَاعَتِهِ ﴿وَرَضُوا۟ عَنۡهُ﴾ بِثَوَابِهِ ﴿وَأَعَدَّ لَهُمۡ جَنَّـٰتࣲ تَجۡرِی تَحۡتَهَا ٱلۡأَنۡهَـٰرُ﴾ وَفِي قِرَاءَة بزيادة من ﴿خَـٰلِدِینَ فِیهَاۤ أَبَدࣰاۚ ذَ ٰ⁠لِكَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝١٠٠﴾"
  9,101,"﴿وَمِمَّنۡ حَوۡلَكُم﴾ يَا أَهْل الْمَدِينَة ﴿مِّنَ ٱلۡأَعۡرَابِ مُنَـٰفِقُونَۖ﴾ كَأَسْلَم وَأَشْجَع وَغِفَار ﴿وَمِنۡ أَهۡلِ ٱلۡمَدِینَةِ﴾ مُنَافِقُونَ أَيْضًا ﴿مَرَدُوا۟ عَلَى ٱلنِّفَاقِ﴾ لَجُّوا فِيهِ واستمروا ﴿لَا تَعۡلَمُهُمۡۖ نَحۡنُ نَعۡلَمُهُمۡۚ سَنُعَذِّبُهُم مَّرَّتَیۡنِ﴾ بِالْفَضِيحَةِ أَوْ الْقَتْل فِي الدُّنْيَا وَعَذَاب الْقَبْر ﴿ثُمَّ یُرَدُّونَ﴾ فِي الْآخِرَة ﴿إِلَىٰ عَذَابٍ عَظِیمࣲ ۝١٠١﴾ هو النار"
  9,102,"﴿وَ﴾ قَوْم ﴿ءَاخَرُونَ﴾ مُبْتَدَأ ﴿ٱعۡتَرَفُوا۟ بِذُنُوبِهِمۡ﴾ مِنْ التَّخَلُّف نَعْته وَالْخَبَر ﴿خَلَطُوا۟ عَمَلࣰا صَـٰلِحࣰا﴾ وَهُوَ جِهَادهمْ قَبْل ذَلِكَ أَوْ اعْتِرَافهمْ بِذُنُوبِهِمْ أَوْ غَيْر ذَلِكَ ﴿وَءَاخَرَ سَیِّئًا﴾ وَهُوَ تَخَلُّفهمْ ﴿عَسَى ٱللَّهُ أَن یَتُوبَ عَلَیۡهِمۡۚ إِنَّ ٱللَّهَ غَفُورࣱ رَّحِیمٌ ۝١٠٢﴾ نَزَلَتْ فِي أَبِي لُبَابَة وَجَمَاعَة أَوْثَقُوا أَنْفُسهمْ فِي سَوَارِي الْمَسْجِد لَمَّا بَلَغَهُمْ مَا نَزَلَ فِي الْمُتَخَلِّفِينَ وَحَلَفُوا لَا يُحِلّهُمْ إلَّا النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ فَحَلَّهُمْ لَمَّا نزلت"
  9,103,"﴿خُذۡ مِنۡ أَمۡوَ ٰ⁠لِهِمۡ صَدَقَةࣰ تُطَهِّرُهُمۡ وَتُزَكِّیهِم بِهَا﴾ مِنْ ذُنُوبهمْ فَأَخَذَ ثُلُث أَمْوَالهمْ وَتَصَدَّقَ بِهَا ﴿وَصَلِّ عَلَیۡهِمۡۖ﴾ أَيْ اُدْعُ لَهُمْ ﴿إِنَّ صَلَوٰتَكَ سَكَنࣱ﴾ رحمة ﴿لَّهُمۡۗ﴾ وقيل طمأنينة بقبول توبتهم ﴿وَٱللَّهُ سَمِیعٌ عَلِیمٌ ۝١٠٣﴾"
  9,104,"﴿أَلَمۡ یَعۡلَمُوۤا۟ أَنَّ ٱللَّهَ هُوَ یَقۡبَلُ ٱلتَّوۡبَةَ عَنۡ عِبَادِهِۦ وَیَأۡخُذُ﴾ يقبل ﴿ٱلصَّدَقَـٰتِ وَأَنَّ ٱللَّهَ هُوَ ٱلتَّوَّابُ﴾ عَلَى عِبَاده بقبول توبتهم ﴿ٱلرَّحِیمُ ۝١٠٤﴾ بهم وَالِاسْتِفْهَام لِلتَّقْرِيرِ وَالْقَصْد بِهِ هُوَ تَهْيِيجهمْ إلَى التوبة والصدقة"
  9,105,"﴿وَقُلِ﴾ لَهُمْ أَوْ لِلنَّاسِ ﴿ٱعۡمَلُوا۟﴾ مَا شِئْتُمْ ﴿فَسَیَرَى ٱللَّهُ عَمَلَكُمۡ وَرَسُولُهُۥ وَٱلۡمُؤۡمِنُونَۖ وَسَتُرَدُّونَ﴾ بِالْبَعْثِ ﴿إِلَىٰ عَـٰلِمِ ٱلۡغَیۡبِ وَٱلشَّهَـٰدَةِ﴾ أَيْ اللَّه ﴿فَیُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝١٠٥﴾ فَيُجَازِيكُمْ بِهِ"
  9,106,"﴿وَءَاخَرُونَ﴾ من المتخلفين ﴿مُرۡجَـُٔونَ﴾ بِالْهَمْزِ وَتَرْكه مُؤَخَّرُونَ عَنْ التَّوْبَة ﴿لِأَمۡرِ ٱللَّهِ﴾ فِيهِمْ بِمَا يَشَاء ﴿إِمَّا یُعَذِّبُهُمۡ﴾ بِأَنْ يُمِيتهُمْ بِلَا تَوْبَة ﴿وَإِمَّا یَتُوبُ عَلَیۡهِمۡۗ وَٱللَّهُ عَلِیمٌ﴾ بِخَلْقِهِ ﴿حَكِیمࣱ ۝١٠٦﴾ فِي صُنْعه بِهِمْ وَهُمْ الثَّلَاثَة الْآتُونَ بَعْد مَرَارَة بْن الرَّبِيع وَكَعْب بْن مَالِك وَهِلَال بْن أُمَيَّة تَخَلَّفُوا كَسَلًا وَمَيْلًا إلَى الدَّعَة لَا نِفَاقًا وَلَمْ يَعْتَذِرُوا إلَى النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ كَغَيْرِهِمْ فَوَقَفَ أَمْرهمْ خَمْسِينَ لَيْلَة وَهَجَرَهُمْ النَّاس حَتَّى نَزَلَتْ توبتهم بعد"
  9,107,"﴿وَ﴾ مِنْهُمْ ﴿ٱلَّذِینَ ٱتَّخَذُوا۟ مَسۡجِدࣰا﴾ وَهُمْ اثْنَا عَشَرَ مِنْ الْمُنَافِقِينَ ﴿ضِرَارࣰا﴾ مُضَارَّة لِأَهْلِ مَسْجِد قُبَاءَ ﴿وَكُفۡرࣰا﴾ لِأَنَّهُمْ بَنَوْهُ بِأَمْرِ أَبِي عَامِر الرَّاهِب لِيَكُونَ مَعْقِلًا لَهُ يَقْدُم فِيهِ مَنْ يَأْتِي مِنْ عِنْده وَكَانَ ذَهَبَ لِيَأْتِيَ بِجُنُودٍ مِنْ قَيْصَر لِقِتَالِ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿وَتَفۡرِیقَۢا بَیۡنَ ٱلۡمُؤۡمِنِینَ﴾ الَّذِينَ يُصَلُّونَ بِقُبَاءَ بِصَلَاةِ بَعْضهمْ فِي مَسْجِدهمْ ﴿وَإِرۡصَادࣰا﴾ تَرَقُّبًا ﴿لِّمَنۡ حَارَبَ ٱللَّهَ وَرَسُولَهُۥ مِن قَبۡلُۚ﴾ أَيْ قَبْل بِنَائِهِ وَهُوَ أَبُو عَامِر الْمَذْكُور ﴿وَلَیَحۡلِفُنَّ إِنۡ﴾ مَا ﴿أَرَدۡنَاۤ﴾ بِبِنَائِهِ ﴿إِلَّا﴾ الْفِعْلَة ﴿ٱلۡحُسۡنَىٰۖ﴾ مِنْ الرِّفْق بِالْمِسْكِينِ فِي الْمَطَر وَالْحَرّ وَالتَّوْسِعَة عَلَى الْمُسْلِمِينَ ﴿وَٱللَّهُ یَشۡهَدُ إِنَّهُمۡ لَكَـٰذِبُونَ ۝١٠٧﴾ فِي ذَلِكَ وَكَانُوا سَأَلُوا النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ أَنْ يُصَلِّي فِيهِ فَنَزَلَ"
  9,108,"﴿لَا تَقُمۡ﴾ تُصَلِّ ﴿فِیهِ أَبَدࣰاۚ﴾ فَأَرْسَلَ جَمَاعَة هَدَمُوهُ وَحَرَّقُوهُ وَجَعَلُوا مَكَانه كُنَاسَة تُلْقَى فِيهَا الْجِيَف ﴿لَّمَسۡجِدٌ أُسِّسَ﴾ بُنِيَتْ قَوَاعِده ﴿عَلَى ٱلتَّقۡوَىٰ مِنۡ أَوَّلِ یَوۡمٍ﴾ وُضِعَ يَوْم حَلَلْت بِدَارِ الْهِجْرَة وَهُوَ مَسْجِد قُبَاءَ كَمَا فِي الْبُخَارِيّ ﴿أَحَقُّ﴾ مِنْهُ ﴿أَن﴾ أَيْ بِأَنْ ﴿تَقُومَ﴾ تُصَلِّي ﴿فِیهِۚ فِیهِ رِجَالࣱ﴾ هُمْ الْأَنْصَار ﴿یُحِبُّونَ أَن یَتَطَهَّرُوا۟ۚ وَٱللَّهُ یُحِبُّ ٱلۡمُطَّهِّرِینَ ۝١٠٨﴾ أَيْ يُثِيبهُمْ فِيهِ إدْغَام التَّاء فِي الْأَصْل فِي الطَّاء رَوَى ابن خُزَيْمَةَ فِي صَحِيحه عَنْ عُوَيْمِر بْن سَاعِدَة أَنَّهُ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ أَتَاهُمْ فِي مَسْجِد قُبَاءَ فَقَالَ إنَّ اللَّه تَعَالَى قَدْ أَحْسَنَ عَلَيْكُمْ الثَّنَاء فِي الطَّهُور فِي قِصَّة مَسْجِدكُمْ فَمَا هَذَا الطَّهُور الَّذِي تَطَّهَّرُونَ بِهِ قَالُوا وَاَللَّه يَا رَسُول اللَّه مَا نَعْلَم شَيْئًا إلَّا أَنَّهُ كَانَ لَنَا جِيرَان مِنْ الْيَهُود وَكَانُوا يَغْسِلُونَ أَدْبَارهمْ مِنْ الْغَائِط فَغَسَلْنَا كَمَا غَسَلُوا وَفِي حَدِيث رَوَاهُ الْبَزَّار فَقَالُوا نَتْبَع الْحِجَارَة بِالْمَاءِ فَقَالَ هُوَ ذَاكَ فَعَلَيْكُمُوهُ"
  9,109,"﴿أَفَمَنۡ أَسَّسَ بُنۡیَـٰنَهُۥ عَلَىٰ تَقۡوَىٰ﴾ مَخَافَة ﴿مِنَ ٱللَّهِ وَ﴾ رَجَاء ﴿رِضۡوَ ٰ⁠نٍ﴾ مِنْهُ ﴿خَیۡرٌ أَم مَّنۡ أَسَّسَ بُنۡیَـٰنَهُۥ عَلَىٰ شَفَا﴾ طَرَف ﴿جُرُفٍ﴾ بِضَمِّ الرَّاء وَسُكُونهَا جَانِب ﴿هَارࣲ﴾ مُشْرِف عَلَى السُّقُوط ﴿فَٱنۡهَارَ بِهِۦ﴾ سَقَطَ مَعَ بَانِيه ﴿فِی نَارِ جَهَنَّمَۗ﴾ خَيْر تَمْثِيل لِلْبِنَاءِ عَلَى ضِدّ التَّقْوَى بِمَا يُؤَوَّل إلَيْهِ وَالِاسْتِفْهَام لِلتَّقْرِيرِ أَيْ الْأَوَّل خَيْر وَهُوَ مِثَال مَسْجِد قُبَاءَ وَالثَّانِي مثال مسجد الضرار ﴿وَٱللَّهُ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلظَّـٰلِمِینَ ۝١٠٩﴾"
  9,110,"﴿لَا یَزَالُ بُنۡیَـٰنُهُمُ ٱلَّذِی بَنَوۡا۟ رِیبَةࣰ﴾ شَكًّا ﴿فِی قُلُوبِهِمۡ إِلَّاۤ أَن تَقَطَّعَ﴾ تَنْفَصِل ﴿قُلُوبُهُمۡۗ﴾ بِأَنْ يَمُوتُوا ﴿وَٱللَّهُ عَلِیمٌ﴾ بِخَلْقِهِ ﴿حَكِیمٌ ۝١١٠﴾ فِي صنعه بهم"
  9,111,"﴿إِنَّ ٱللَّهَ ٱشۡتَرَىٰ مِنَ ٱلۡمُؤۡمِنِینَ أَنفُسَهُمۡ وَأَمۡوَ ٰ⁠لَهُم﴾ بِأَنْ يَبْذُلُوهَا فِي طَاعَته كَالْجِهَادِ ﴿بِأَنَّ لَهُمُ ٱلۡجَنَّةَۚ یُقَـٰتِلُونَ فِی سَبِیلِ ٱللَّهِ فَیَقۡتُلُونَ وَیُقۡتَلُونَۖ﴾ جُمْلَة اسْتِئْنَاف بَيَان لِلشِّرَاءِ وَفِي قِرَاءَة بِتَقْدِيمِ الْمَبْنِيّ لِلْمَفْعُولِ أَيْ فَيُقْتَل بَعْضهمْ وَيُقَاتِل الْبَاقِي ﴿وَعۡدًا عَلَیۡهِ حَقࣰّا﴾ مَصْدَرَانِ مَنْصُوبَانِ بِفِعْلِهِمَا الْمَحْذُوف ﴿فِی ٱلتَّوۡرَىٰةِ وَٱلۡإِنجِیلِ وَٱلۡقُرۡءَانِۚ وَمَنۡ أَوۡفَىٰ بِعَهۡدِهِۦ مِنَ ٱللَّهِۚ﴾ أَيْ لَا أَحَد أَوْفَى مِنْهُ ﴿فَٱسۡتَبۡشِرُوا۟﴾ فِيهِ الْتِفَات عَنْ الْغَيْبَة ﴿بِبَیۡعِكُمُ ٱلَّذِی بَایَعۡتُم بِهِۦۚ وَذَ ٰ⁠لِكَ﴾ الْبَيْع ﴿هُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝١١١﴾ الْمُنِيل غَايَة الْمَطْلُوب"
  9,112,"﴿ٱلتَّـٰۤىِٕبُونَ﴾ رُفِعَ عَلَى الْمَدْح بِتَقْدِيرِ مُبْتَدَأ مِنْ الشِّرْك وَالنِّفَاق ﴿ٱلۡعَـٰبِدُونَ﴾ الْمُخْلِصُونَ الْعِبَادَة لِلَّهِ ﴿ٱلۡحَـٰمِدُونَ﴾ لَهُ عَلَى كُلّ حَال ﴿ٱلسَّـٰۤىِٕحُونَ﴾ الصَّائِمُونَ ﴿ٱلرَّ ٰ⁠كِعُونَ ٱلسَّـٰجِدُونَ﴾ أَيْ الْمُصَلُّونَ ﴿ٱلۡـَٔامِرُونَ بِٱلۡمَعۡرُوفِ وَٱلنَّاهُونَ عَنِ ٱلۡمُنكَرِ وَٱلۡحَـٰفِظُونَ لِحُدُودِ ٱللَّهِۗ﴾ لِأَحْكَامِهِ بِالْعَمَلِ بِهَا ﴿وَبَشِّرِ ٱلۡمُؤۡمِنِینَ ۝١١٢﴾ بِالْجَنَّةِ"
  9,113,"وَنَزَلَ فِي اسْتِغْفَاره صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ لعمه أبي طالب واستغفار بَعْض الصَّحَابَة لِأَبَوَيْهِ الْمُشْرِكَيْنِ ﴿مَا كَانَ لِلنَّبِیِّ وَٱلَّذِینَ ءَامَنُوۤا۟ أَن یَسۡتَغۡفِرُوا۟ لِلۡمُشۡرِكِینَ وَلَوۡ كَانُوۤا۟ أُو۟لِی قُرۡبَىٰ﴾ ذوي قرابة ﴿مِنۢ بَعۡدِ مَا تَبَیَّنَ لَهُمۡ أَنَّهُمۡ أَصۡحَـٰبُ ٱلۡجَحِیمِ ۝١١٣﴾ النَّار بِأَنْ مَاتُوا عَلَى الْكُفْر"
  9,114,"﴿وَمَا كَانَ ٱسۡتِغۡفَارُ إِبۡرَ ٰ⁠هِیمَ لِأَبِیهِ إِلَّا عَن مَّوۡعِدَةࣲ وَعَدَهَاۤ إِیَّاهُ﴾ بِقَوْلِهِ سَأَسْتَغْفِرُ لَك رَبِّي رَجَاء أَنْ يُسْلِم ﴿فَلَمَّا تَبَیَّنَ لَهُۥۤ أَنَّهُۥ عَدُوࣱّ لِّلَّهِ﴾ بِمَوْتِهِ عَلَى الْكُفْر ﴿تَبَرَّأَ مِنۡهُۚ﴾ وَتَرَكَ الِاسْتِغْفَار لَهُ ﴿إِنَّ إِبۡرَ ٰ⁠هِیمَ لَأَوَّ ٰ⁠هٌ﴾ كَثِير التَّضَرُّع وَالدُّعَاء ﴿حَلِیمࣱ ۝١١٤﴾ صَبُور عَلَى الْأَذَى"
  9,115,"﴿وَمَا كَانَ ٱللَّهُ لِیُضِلَّ قَوۡمَۢا بَعۡدَ إِذۡ هَدَىٰهُمۡ﴾ لِلْإِسْلَامِ ﴿حَتَّىٰ یُبَیِّنَ لَهُم مَّا یَتَّقُونَۚ﴾ مِنْ الْعَمَل فَلَا يَتَّقُوهُ فَيَسْتَحِقُّوا الْإِضْلَال ﴿إِنَّ ٱللَّهَ بِكُلِّ شَیۡءٍ عَلِیمٌ ۝١١٥﴾ وَمِنْهُ مُسْتَحِقّ الْإِضْلَال والهداية"
  9,116,"﴿إِنَّ ٱللَّهَ لَهُۥ مُلۡكُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ یُحۡیِۦ وَیُمِیتُۚ وَمَا لَكُم﴾ أَيّهَا النَّاس ﴿مِّن دُونِ ٱللَّهِ﴾ أَيْ غَيْره ﴿مِن وَلِیࣲّ﴾ يَحْفَظكُمْ مِنْهُ ﴿وَلَا نَصِیرࣲ ۝١١٦﴾ يَمْنَعكُمْ عَنْ ضَرَره"
  9,117,"﴿لَّقَد تَّابَ ٱللَّهُ﴾ أَيْ أَدَامَ تَوْبَته ﴿عَلَى ٱلنَّبِیِّ وَٱلۡمُهَـٰجِرِینَ وَٱلۡأَنصَارِ ٱلَّذِینَ ٱتَّبَعُوهُ فِی سَاعَةِ ٱلۡعُسۡرَةِ﴾ أَيْ وَقْتهَا وَهِيَ حَالهمْ فِي غَزْوَة تَبُوك كَانَ الرَّجُلَانِ يَقْتَسِمَانِ تَمْرَة وَالْعَشَرَة يَعْتَقِبُونَ الْبَعِير الْوَاحِد وَاشْتَدَّ الْحَرّ حَتَّى شَرِبُوا الْفَرْث ﴿مِنۢ بَعۡدِ مَا كَادَ تَزِيغُ﴾ بِالتَّاءِ وَالْيَاء تَمِيل ﴿قُلُوبُ فَرِیقࣲ مِّنۡهُمۡ﴾ عَنْ اتِّبَاعه إلَى التَّخَلُّف لِمَا هُمْ فِيهِ مِنْ الشِّدَّة ﴿ثُمَّ تَابَ عَلَیۡهِمۡۚ﴾ بالثبات ﴿إِنَّهُۥ بِهِمۡ رَءُوفࣱ رَّحِیمࣱ ۝١١٧﴾"
  9,118,"﴿وَ﴾ تَابَ ﴿عَلَى ٱلثَّلَـٰثَةِ ٱلَّذِینَ خُلِّفُوا۟﴾ عَنْ التَّوْبَة عَلَيْهِمْ بِقَرِينَةِ ﴿حَتَّىٰۤ إِذَا ضَاقَتۡ عَلَیۡهِمُ ٱلۡأَرۡضُ بِمَا رَحُبَتۡ﴾ أَيْ مَعَ رَحْبهَا أَيْ سِعَتهَا فَلَا يَجِدُونَ مَكَانًا يَطْمَئِنُّونَ إلَيْهِ ﴿وَضَاقَتۡ عَلَیۡهِمۡ أَنفُسُهُمۡ﴾ قُلُوبهمْ لِلْغَمِّ وَالْوَحْشَة بِتَأْخِيرِ تَوْبَتهمْ فَلَا يَسَعهَا سُرُور وَلَا أُنْس ﴿وَظَنُّوۤا۟﴾ أَيْقَنُوا ﴿أَن﴾ مُخَفَّفَة ﴿لَّا مَلۡجَأَ مِنَ ٱللَّهِ إِلَّاۤ إِلَیۡهِ ثُمَّ تَابَ عَلَیۡهِمۡ﴾ وفقهم للتوبة ﴿لِیَتُوبُوۤا۟ۚ إِنَّ ٱللَّهَ هُوَ ٱلتَّوَّابُ ٱلرَّحِیمُ ۝١١٨﴾"
  9,119,"﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ ٱتَّقُوا۟ ٱللَّهَ﴾ بِتَرْكِ مَعَاصِيه ﴿وَكُونُوا۟ مَعَ ٱلصَّـٰدِقِینَ ۝١١٩﴾ فِي الْإِيمَان وَالْعُهُود بِأَنْ تَلْزَمُوا الصدق"
  9,120,"﴿مَا كَانَ لِأَهۡلِ ٱلۡمَدِینَةِ وَمَنۡ حَوۡلَهُم مِّنَ ٱلۡأَعۡرَابِ أَن یَتَخَلَّفُوا۟ عَن رَّسُولِ ٱللَّهِ﴾ إذَا غَزَا ﴿وَلَا یَرۡغَبُوا۟ بِأَنفُسِهِمۡ عَن نَّفۡسِهِۦۚ﴾ بِأَنْ يَصُونُوهَا عَمَّا رَضِيَهُ لِنَفْسِهِ مِنْ الشَّدَائِد وَهُوَ نَهْي بِلَفْظِ الْخَبَر ﴿ذَ ٰ⁠لِكَ﴾ أَيْ النَّهْي عَنْ التَّخَلُّف ﴿بِأَنَّهُمۡ﴾ بِسَبَبِ أَنَّهُمْ ﴿لَا یُصِیبُهُمۡ ظَمَأࣱ﴾ عَطَش ﴿وَلَا نَصَبࣱ﴾ تَعَب ﴿وَلَا مَخۡمَصَةࣱ﴾ جُوع ﴿فِی سَبِیلِ ٱللَّهِ وَلَا یَطَـُٔونَ مَوۡطِئࣰا﴾ مَصْدَر بمعنى وطأ ﴿یَغِیظُ﴾ يُغْضِب ﴿ٱلۡكُفَّارَ وَلَا یَنَالُونَ مِنۡ عَدُوࣲّ﴾ لِلَّهِ ﴿نَّیۡلًا﴾ قَتْلًا أَوْ أَسْرًا أَوْ نَهْبًا ﴿إِلَّا كُتِبَ لَهُم بِهِۦ عَمَلࣱ صَـٰلِحٌۚ﴾ لِيُجَازَوْا عَلَيْهِ ﴿إِنَّ ٱللَّهَ لَا یُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝١٢٠﴾ أَيْ أَجْرهمْ بَلْ يُثِيبهُمْ"
  9,121,"﴿وَلَا یُنفِقُونَ﴾ فِيهِ ﴿نَفَقَةࣰ صَغِیرَةࣰ﴾ وَلَوْ تَمْرَة ﴿وَلَا كَبِیرَةࣰ وَلَا یَقۡطَعُونَ وَادِیًا﴾ بِالسَّيْرِ ﴿إِلَّا كُتِبَ لَهُمۡ﴾ بِهِ عَمَل صَالِح ﴿لِیَجۡزِیَهُمُ ٱللَّهُ أَحۡسَنَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١٢١﴾ أَيْ جَزَاءَهُمْ"
  9,122,"وَلَمَّا وُبِّخُوا عَلَى التَّخَلُّف وَأَرْسَلَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ سَرِيَّة نَفَرُوا جَمِيعًا فَنَزَلَ ﴿وَمَا كَانَ ٱلۡمُؤۡمِنُونَ لِیَنفِرُوا۟﴾ إلَى الْغَزْو ﴿كَاۤفَّةࣰۚ فَلَوۡلَا﴾ فَهَلَّا ﴿نَفَرَ مِن كُلِّ فِرۡقَةࣲ﴾ قَبِيلَة ﴿مِّنۡهُمۡ طَاۤىِٕفَةࣱ﴾ جَمَاعَة وَمَكَثَ الْبَاقُونَ ﴿لِّیَتَفَقَّهُوا۟﴾ أَيْ الْمَاكِثُونَ ﴿فِی ٱلدِّینِ وَلِیُنذِرُوا۟ قَوۡمَهُمۡ إِذَا رَجَعُوۤا۟ إِلَیۡهِمۡ﴾ مِنْ الْغَزْو بِتَعْلِيمِهِمْ مَا تَعَلَّمُوهُ مِنْ الْأَحْكَام ﴿لَعَلَّهُمۡ یَحۡذَرُونَ ۝١٢٢﴾ عِقَاب اللَّه بِامْتِثَالِ أَمْره ونهيه قال ابن عَبَّاس فَهَذِهِ مَخْصُوصَة بِالسَّرَايَا وَاَلَّتِي قَبْلهَا بِالنَّهْيِ عَنْ تَخَلُّف وَاحِد فِيمَا إذَا خَرَجَ النَّبِيّ صلى الله عليه وسلم"
  9,123,"﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ قَـٰتِلُوا۟ ٱلَّذِینَ یَلُونَكُم مِّنَ ٱلۡكُفَّارِ﴾ أَيْ الْأَقْرَب فَالْأَقْرَب مِنْهُمْ ﴿وَلۡیَجِدُوا۟ فِیكُمۡ غِلۡظَةࣰۚ﴾ شِدَّة أَيْ أَغْلِظُوا عَلَيْهِمْ ﴿وَٱعۡلَمُوۤا۟ أَنَّ ٱللَّهَ مَعَ ٱلۡمُتَّقِینَ ۝١٢٣﴾ بِالْعَوْنِ وَالنَّصْر"
  9,124,"﴿وَإِذَا مَاۤ أُنزِلَتۡ سُورَةࣱ﴾ مِنْ الْقُرْآن ﴿فَمِنۡهُم﴾ أَيْ الْمُنَافِقِينَ ﴿مَّن یَقُولُ﴾ لِأَصْحَابِهِ اسْتِهْزَاء ﴿أَیُّكُمۡ زَادَتۡهُ هَـٰذِهِۦۤ إِیمَـٰنࣰاۚ﴾ تصديقا قال تعالى ﴿فَأَمَّا ٱلَّذِینَ ءَامَنُوا۟ فَزَادَتۡهُمۡ إِیمَـٰنࣰا﴾ لِتَصْدِيقِهِمْ بِهَا ﴿وَهُمۡ یَسۡتَبۡشِرُونَ ۝١٢٤﴾ يَفْرَحُونَ بِهَا"
  9,125,"﴿وَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ﴾ ضَعْف اعْتِقَاد ﴿فَزَادَتۡهُمۡ رِجۡسًا إِلَىٰ رِجۡسِهِمۡ﴾ كُفْرًا إلَى كُفْرهمْ لكفرهم بها ﴿وَمَاتُوا۟ وَهُمۡ كَـٰفِرُونَ ۝١٢٥﴾"
  9,126,"﴿أَوَلَا یَرَوۡنَ﴾ بِالْيَاءِ أَيْ الْمُنَافِقُونَ وَالتَّاء أَيّهَا الْمُؤْمِنُونَ ﴿أَنَّهُمۡ یُفۡتَنُونَ﴾ يُبْتَلَوْنَ ﴿فِی كُلِّ عَامࣲ مَّرَّةً أَوۡ مَرَّتَیۡنِ﴾ بِالْقَحْطِ وَالْأَمْرَاض ﴿ثُمَّ لَا یَتُوبُونَ﴾ مِنْ نِفَاقهمْ ﴿وَلَا هُمۡ یَذَّكَّرُونَ ۝١٢٦﴾ يَتَّعِظُونَ"
  9,127,"﴿وَإِذَا مَاۤ أُنزِلَتۡ سُورَةࣱ﴾ فِيهَا ذِكْرهمْ وَقَرَأَهَا النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿نَّظَرَ بَعۡضُهُمۡ إِلَىٰ بَعۡضٍ﴾ يُرِيدُونَ الْهَرَب يَقُولُونَ ﴿هَلۡ یَرَىٰكُم مِّنۡ أَحَدࣲ﴾ إذَا قُمْتُمْ فَإِنْ لَمْ يَرَهُمْ أَحَد قَامُوا وَإِلَّا ثَبَتُوا ﴿ثُمَّ ٱنصَرَفُوا۟ۚ﴾ عَلَى كُفْرهمْ ﴿صَرَفَ ٱللَّهُ قُلُوبَهُم﴾ عَنْ الْهُدَى ﴿بِأَنَّهُمۡ قَوۡمࣱ لَّا یَفۡقَهُونَ ۝١٢٧﴾ الْحَقّ لِعَدَمِ تَدَبُّرهمْ"
  9,128,"﴿لَقَدۡ جَاۤءَكُمۡ رَسُولࣱ مِّنۡ أَنفُسِكُمۡ﴾ أَيْ مِنْكُمْ مُحَمَّد صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿عَزِیزٌ﴾ شَدِيد ﴿عَلَیۡهِ مَا عَنِتُّمۡ﴾ أَيْ عَنَتكُمْ أَيْ مَشَقَّتكُمْ وَلِقَاؤُكُمْ الْمَكْرُوه ﴿حَرِیصٌ عَلَیۡكُم﴾ أَنْ تَهْتَدُوا ﴿بِٱلۡمُؤۡمِنِینَ رَءُوفࣱ﴾ شَدِيد الرَّحْمَة ﴿رَّحِیمࣱ ۝١٢٨﴾ يُرِيد لَهُمْ الْخَيْر"
  9,129,"﴿فَإِن تَوَلَّوۡا۟﴾ عَنْ الْإِيمَان بِك ﴿فَقُلۡ حَسۡبِیَ﴾ كافي ﴿ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَۖ عَلَیۡهِ تَوَكَّلۡتُۖ﴾ بِهِ وَثِقْت لَا بِغَيْرِهِ ﴿وَهُوَ رَبُّ ٱلۡعَرۡشِ﴾ الْكُرْسِيّ ﴿ٱلۡعَظِیمِ ۝١٢٩﴾ خَصَّهُ بِالذِّكْرِ لِأَنَّهُ أَعْظَم الْمَخْلُوقَات وَرَوَى الْحَاكِم فِي الْمُسْتَدْرَك عَنْ أُبَيّ بْن كَعْب قَالَ آخِر آيَة نَزَلَتْ {لَقَدۡ جَاۤءَكُمۡ رَسُولࣱ} إلى آخر السورة"
