tafsir[99]{c,v,t}:
  15,1,"﴿الۤرۚ﴾ اللَّه أَعْلَم بِمُرَادِهِ بِذَلِكَ ﴿تِلۡكَ﴾ هَذِهِ الْآيَات ﴿ءَایَـٰتُ ٱلۡكِتَـٰبِ﴾ الْقُرْآن وَالْإِضَافَة بِمَعْنَى مِنْ ﴿وَقُرۡءَانࣲ مُّبِینࣲ ۝١﴾ مُظْهِر لِلْحَقِّ مِنْ الْبَاطِل عَطْف بِزِيَادَةِ صفة"
  15,2,"﴿رُّبَّمَا﴾ بِالتَّشْدِيدِ وَالتَّخْفِيف ﴿یَوَدُّ﴾ يَتَمَنَّى ﴿ٱلَّذِینَ كَفَرُوا۟﴾ يَوْم الْقِيَامَة إذَا عَايَنُوا حَالهمْ وَحَال الْمُسْلِمِينَ ﴿لَوۡ كَانُوا۟ مُسۡلِمِینَ ۝٢﴾ وَرُبّ لِلتَّكْثِيرِ فَإِنَّهُ يَكْثُر مِنْهُمْ تَمَنِّي ذَلِك وَقِيلَ لِلتَّقْلِيلِ فَإِنَّ الْأَهْوَال تُدْهِشهُمْ فَلَا يُفِيقُونَ حَتَّى يَتَمَنَّوْا ذَلِكَ إلَّا فِي أَحْيَان قَلِيلَة"
  15,3,"﴿ذَرۡهُمۡ﴾ اُتْرُكْ الْكُفَّار يَا مُحَمَّد ﴿یَأۡكُلُوا۟ وَیَتَمَتَّعُوا۟﴾ بِدُنْيَاهُمْ ﴿وَیُلۡهِهِمُ﴾ يَشْغَلهُمْ ﴿ٱلۡأَمَلُۖ﴾ بِطُولِ الْعُمْر وَغَيْره عَنْ الْإِيمَان ﴿فَسَوۡفَ یَعۡلَمُونَ ۝٣﴾ عَاقِبَة أَمْرهمْ وَهَذَا قَبْل الْأَمْر بِالْقِتَالِ"
  15,4,"﴿وَمَاۤ أَهۡلَكۡنَا مِن﴾ زَائِدَة ﴿قَرۡیَةٍ﴾ أُرِيدَ أَهْلهَا ﴿إِلَّا وَلَهَا كِتَابࣱ﴾ أَجَل ﴿مَّعۡلُومࣱ ۝٤﴾ مَحْدُود لِإِهْلَاكِهَا"
  15,5,"﴿مَّا تَسۡبِقُ مِنۡ﴾ زَائِدَة ﴿أُمَّةٍ أَجَلَهَا وَمَا یَسۡتَـٔۡخِرُونَ ۝٥﴾ يَتَأَخَّرُونَ عَنْهُ"
  15,6,"﴿وَقَالُوا۟﴾ أَيْ كُفَّار مَكَّة لِلنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وسلم ﴿یَـٰۤأَیُّهَا ٱلَّذِی نُزِّلَ عَلَیۡهِ ٱلذِّكۡرُ﴾ الْقُرْآن فِي زَعْمه ﴿إِنَّكَ لَمَجۡنُونࣱ ۝٦﴾"
  15,7,"﴿لَّوۡ مَا﴾ هَلَّا ﴿تَأۡتِینَا بِٱلۡمَلَـٰۤىِٕكَةِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٧﴾ فِي قَوْلك إنَّك نَبِيّ وَإِنَّ هَذَا الْقُرْآن من عند الله"
  15,8,"قال تعالى ﴿مَا تَنَزَّلُ﴾ فِيهِ حَذْف إحْدَى التَّاءَيْنِ ﴿ٱلۡمَلَـٰۤىِٕكَةُ إِلَّا بِٱلۡحَقِّ﴾ بِالْعَذَابِ ﴿وَمَا كَانُوۤا۟ إِذࣰا﴾ أَيْ حِين نُزُول الْمَلَائِكَة بِالْعَذَابِ ﴿مُّنظَرِینَ ۝٨﴾ مُؤَخَّرِينَ"
  15,9,"﴿إِنَّا نَحۡنُ﴾ تَأْكِيد لِاسْمِ إنَّ أَوْ فَصْل ﴿نَزَّلۡنَا ٱلذِّكۡرَ﴾ الْقُرْآن ﴿وَإِنَّا لَهُۥ لَحَـٰفِظُونَ ۝٩﴾ مِنْ التَّبْدِيل وَالتَّحْرِيف وَالزِّيَادَة وَالنَّقْص"
  15,10,"﴿وَلَقَدۡ أَرۡسَلۡنَا مِن قَبۡلِكَ﴾ رُسُلًا ﴿فِی شِیَعِ﴾ فرق ﴿ٱلۡأَوَّلِینَ ۝١٠﴾"
  15,11,"﴿وَمَا﴾ كَانَ ﴿یَأۡتِیهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝١١﴾ كاستهزاء قومك به وَهَذَا تَسْلِيَة لَهُ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ"
  15,12,"﴿كَذَ ٰ⁠لِكَ نَسۡلُكُهُۥ﴾ أَيْ مِثْل إدْخَالنَا التَّكْذِيب فِي قُلُوب أُولَئِكَ نُدْخِلهُ ﴿فِی قُلُوبِ ٱلۡمُجۡرِمِینَ ۝١٢﴾ أَيْ كفار مكة"
  15,13,"﴿لَا یُؤۡمِنُونَ بِهِۦ﴾ بِالنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ ﴿وَقَدۡ خَلَتۡ سُنَّةُ ٱلۡأَوَّلِینَ ۝١٣﴾ أَيْ سُنَّة اللَّه فِيهِمْ مِنْ تَعْذِيبهمْ بِتَكْذِيبِهِمْ أَنْبِيَاءَهُمْ وَهَؤُلَاءِ مثلهم"
  15,14,"﴿وَلَوۡ فَتَحۡنَا عَلَیۡهِم بَابࣰا مِّنَ ٱلسَّمَاۤءِ فَظَلُّوا۟ فِیهِ﴾ فِي الْبَاب ﴿یَعۡرُجُونَ ۝١٤﴾ يَصْعَدُونَ"
  15,15,"﴿لَقَالُوۤا۟ إِنَّمَا سُكِّرَتۡ﴾ سُدَّتْ ﴿أَبۡصَـٰرُنَا بَلۡ نَحۡنُ قَوۡمࣱ مَّسۡحُورُونَ ۝١٥﴾ يُخَيَّل إلَيْنَا ذَلِكَ"
  15,16,"﴿وَلَقَدۡ جَعَلۡنَا فِی ٱلسَّمَاۤءِ بُرُوجࣰا﴾ اثْنَيْ عَشَر الْحَمْل وَالثَّوْر وَالْجَوْزَاء وَالسَّرَطَان وَالْأَسَد وَالسُّنْبُلَة وَالْمِيزَان وَالْعَقْرَب وَالْقَوْس وَالْجَدْي وَالدَّلْو وَالْحُوت وَهِيَ مَنَازِل الْكَوَاكِب السَّبْعَة السَّيَّارَة الْمِرِّيخ وَلَهُ الْحَمْل وَالْعَقْرَب وَالزُّهْرَة وَلَهَا الثَّوْر وَالْمِيزَان وَعُطَارِد وَلَهُ الْجَوْزَاء وَالسُّنْبُلَة وَالْقَمَر وَلَهُ السَّرَطَان وَالشَّمْس وَلَهَا الْأَسَد وَالْمُشْتَرِي وَلَهُ القوس والحوت وزحل له الجدي والدلو ﴿وَزَیَّنَّـٰهَا﴾ بالكواكب ﴿لِلنَّـٰظِرِینَ ۝١٦﴾"
  15,17,"﴿وَحَفِظۡنَـٰهَا﴾ بِالشُّهُبِ ﴿مِن كُلِّ شَیۡطَـٰنࣲ رَّجِیمٍ ۝١٧﴾ مَرْجُوم"
  15,18,"﴿إِلَّا﴾ لَكِنْ ﴿مَنِ ٱسۡتَرَقَ ٱلسَّمۡعَ﴾ خَطَفَهُ ﴿فَأَتۡبَعَهُۥ شِهَابࣱ مُّبِینࣱ ۝١٨﴾ كَوْكَب يُضِيء وَيُحْرِقهُ أَوْ يَثْقُبهُ أو يخبله"
  15,19,"﴿وَٱلۡأَرۡضَ مَدَدۡنَـٰهَا﴾ بَسَطْنَاهَا ﴿وَأَلۡقَیۡنَا فِیهَا رَوَ ٰ⁠سِیَ﴾ جِبَالًا ثَوَابِت لِئَلَّا تَتَحَرَّك بِأَهْلِهَا ﴿وَأَنۢبَتۡنَا فِیهَا مِن كُلِّ شَیۡءࣲ مَّوۡزُونࣲ ۝١٩﴾ مَعْلُوم مُقَدَّر"
  15,20,"﴿وَجَعَلۡنَا لَكُمۡ فِیهَا مَعَـٰیِشَ﴾ بِالْيَاءِ مِنْ الثِّمَار وَالْحُبُوب ﴿وَ﴾ جَعَلْنَا لَكُمْ ﴿مَن لَّسۡتُمۡ لَهُۥ بِرَ ٰ⁠زِقِینَ ۝٢٠﴾ مِنْ الْعَبِيد وَالدَّوَابّ وَالْأَنْعَام فَإِنَّمَا يَرْزُقهُمْ الله"
  15,21,"﴿وَإِن﴾ مَا ﴿مِّن﴾ زَائِدَة ﴿شَیۡءٍ إِلَّا عِندَنَا خَزَاۤىِٕنُهُۥ﴾ مَفَاتِيح خَزَائِنه ﴿وَمَا نُنَزِّلُهُۥۤ إِلَّا بِقَدَرࣲ مَّعۡلُومࣲ ۝٢١﴾ عَلَى حَسَب الْمَصَالِح"
  15,22,"﴿وَأَرۡسَلۡنَا ٱلرِّیَـٰحَ لَوَ ٰ⁠قِحَ﴾ تُلَقِّح السَّحَاب فَيَمْتَلِئ مَاء ﴿فَأَنزَلۡنَا مِنَ ٱلسَّمَاۤءِ﴾ السَّحَاب ﴿مَاۤءࣰ﴾ مَطَرًا ﴿فَأَسۡقَیۡنَـٰكُمُوهُ وَمَاۤ أَنتُمۡ لَهُۥ بِخَـٰزِنِینَ ۝٢٢﴾ أَيّ لَيْسَتْ خَزَائِنه بأيديكم"
  15,23,"﴿وَإِنَّا لَنَحۡنُ نُحۡیِۦ وَنُمِیتُ وَنَحۡنُ ٱلۡوَ ٰ⁠رِثُونَ ۝٢٣﴾ الْبَاقُونَ نَرِث جَمِيع الْخَلْق"
  15,24,"﴿وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَقۡدِمِینَ مِنكُمۡ﴾ أَيْ مَنْ تَقَدَّمَ مِنْ الْخَلْق مِنْ لَدُنْ آدَم ﴿وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَـٔۡخِرِینَ ۝٢٤﴾ الْمُتَأَخِّرِينَ إلَى يَوْم الْقِيَامَة"
  15,25,"﴿وَإِنَّ رَبَّكَ هُوَ یَحۡشُرُهُمۡۚ إِنَّهُۥ حَكِیمٌ﴾ فِي صُنْعه ﴿عَلِیمࣱ ۝٢٥﴾ بِخَلْقِهِ"
  15,26,"﴿وَلَقَدۡ خَلَقۡنَا ٱلۡإِنسَـٰنَ﴾ آدَم ﴿مِن صَلۡصَـٰلࣲ﴾ طِين يَابِس يُسْمَع لَهُ صَلْصَلَة إذَا نُقِرَ ﴿مِّنۡ حَمَإࣲ﴾ طِين أَسْوَد ﴿مَّسۡنُونࣲ ۝٢٦﴾ مُتَغَيِّر"
  15,27,"﴿وَٱلۡجَاۤنَّ﴾ أَبَا الْجَانّ وَهُوَ إبْلِيس ﴿خَلَقۡنَـٰهُ مِن قَبۡلُ﴾ أَيْ قَبْل خَلْق آدَم ﴿مِن نَّارِ ٱلسَّمُومِ ۝٢٧﴾ هِيَ نَار لَا دُخَان لَهَا تَنْفُذ من المسام"
  15,28,"﴿وَ﴾ اذكر ﴿إِذۡ قَالَ رَبُّكَ لِلۡمَلَـٰۤىِٕكَةِ إِنِّی خَـٰلِقُۢ بَشَرࣰا مِّن صَلۡصَـٰلࣲ مِّنۡ حَمَإࣲ مَّسۡنُونࣲ ۝٢٨﴾"
  15,29,"﴿فَإِذَا سَوَّیۡتُهُۥ﴾ أَتْمَمْته ﴿وَنَفَخۡتُ﴾ أَجْرَيْت ﴿فِیهِ مِن رُّوحِی﴾ فَصَارَ حَيًّا وَإِضَافَة الرُّوح إلَيْهِ تَشْرِيف لِآدَم ﴿فَقَعُوا۟ لَهُۥ سَـٰجِدِینَ ۝٢٩﴾ سُجُود تَحِيَّة بِالِانْحِنَاءِ"
  15,30,"﴿فَسَجَدَ ٱلۡمَلَـٰۤىِٕكَةُ كُلُّهُمۡ أَجۡمَعُونَ ۝٣٠﴾ فِيهِ تَأْكِيدَانِ"
  15,31,"﴿إِلَّاۤ إِبۡلِیسَ﴾ هُوَ أَبُو الْجِنّ كَانَ بَيْن الْمَلَائِكَة ﴿أَبَىٰۤ﴾ امْتَنَعَ مِنْ ﴿أَن یَكُونَ مَعَ ٱلسَّـٰجِدِینَ ۝٣١﴾"
  15,32,"﴿قَالَ﴾ تَعَالَى ﴿یَـٰۤإِبۡلِیسُ مَا لَكَ﴾ مَا منعك ﴿أَ﴾ن ﴿لَّا﴾ زائدة ﴿تَكُونَ مَعَ ٱلسَّـٰجِدِینَ ۝٣٢﴾"
  15,33,"﴿قَالَ لَمۡ أَكُن لِّأَسۡجُدَ﴾ لَا يَنْبَغِي لِي أن أسجد ﴿لِبَشَرٍ خَلَقۡتَهُۥ مِن صَلۡصَـٰلࣲ مِّنۡ حَمَإࣲ مَّسۡنُونࣲ ۝٣٣﴾"
  15,34,"﴿قَالَ فَٱخۡرُجۡ مِنۡهَا﴾ أَيْ مِنْ الْجَنَّة وَقِيلَ مِنْ السَّمَاوَات ﴿فَإِنَّكَ رَجِیمࣱ ۝٣٤﴾ مَطْرُود"
  15,35,"﴿وَإِنَّ عَلَیۡكَ ٱللَّعۡنَةَ إِلَىٰ یَوۡمِ ٱلدِّینِ ۝٣٥﴾ الْجَزَاء"
  15,36,"﴿قَالَ رَبِّ فَأَنظِرۡنِیۤ إِلَىٰ یَوۡمِ یُبۡعَثُونَ ۝٣٦﴾ أَيْ الناس"
  15,37,"﴿قَالَ فَإِنَّكَ مِنَ ٱلۡمُنظَرِینَ ۝٣٧﴾"
  15,38,"﴿إِلَىٰ یَوۡمِ ٱلۡوَقۡتِ ٱلۡمَعۡلُومِ ۝٣٨﴾ وَقْت النَّفْخَة الْأُولَى"
  15,39,"﴿قَالَ رَبِّ بِمَاۤ أَغۡوَیۡتَنِی﴾ أَيْ بِإِغْوَائِك لِي وَالْبَاء لِلْقَسَمِ وَجَوَابه ﴿لَأُزَیِّنَنَّ لَهُمۡ فِی ٱلۡأَرۡضِ﴾ المعاصي ﴿وَلَأُغۡوِیَنَّهُمۡ أَجۡمَعِینَ ۝٣٩﴾"
  15,40,"﴿إِلَّا عِبَادَكَ مِنۡهُمُ ٱلۡمُخۡلَصِینَ ۝٤٠﴾ أَيْ الْمُؤْمِنِينَ"
  15,41,"﴿قَالَ﴾ تعالى ﴿هَـٰذَا صِرَ ٰ⁠طٌ عَلَیَّ مُسۡتَقِیمٌ ۝٤١﴾"
  15,42,"وَهُو ﴿إِنَّ عِبَادِی﴾ أَيْ الْمُؤْمِنِينَ ﴿لَیۡسَ لَكَ عَلَیۡهِمۡ سُلۡطَـٰنٌ﴾ قُوَّة ﴿إِلَّا﴾ لَكِنْ ﴿مَنِ ٱتَّبَعَكَ مِنَ ٱلۡغَاوِینَ ۝٤٢﴾ الْكَافِرِينَ"
  15,43,"﴿وَإِنَّ جَهَنَّمَ لَمَوۡعِدُهُمۡ أَجۡمَعِینَ ۝٤٣﴾ أَيْ مَنْ اتَّبَعَك معك"
  15,44,"﴿لَهَا سَبۡعَةُ أَبۡوَ ٰ⁠بࣲ﴾ أَطْبَاق ﴿لِّكُلِّ بَابࣲ﴾ مِنْهَا ﴿مِّنۡهُمۡ جُزۡءࣱ﴾ نصيب ﴿مَّقۡسُومٌ ۝٤٤﴾"
  15,45,"﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ﴾ بَسَاتِين ﴿وَعُیُونٍ ۝٤٥﴾ تَجْرِي فيها"
  15,46,"ويقال لَهُمْ ﴿ٱدۡخُلُوهَا بِسَلَـٰمٍ﴾ أَيْ سَالِمِينَ مِنْ كُلّ مَخُوف أَوْ مَعَ سَلَام أَيْ سَلِّمُوا وَادْخُلُوا ﴿ءَامِنِینَ ۝٤٦﴾ مِنْ كُلّ فَزَع"
  15,47,"﴿وَنَزَعۡنَا مَا فِی صُدُورِهِم مِّنۡ غِلٍّ﴾ حقد ﴿إِخۡوَ ٰ⁠نًا﴾ حَال مِنْهُمْ ﴿عَلَىٰ سُرُرࣲ مُّتَقَـٰبِلِینَ ۝٤٧﴾ حَال أَيْضًا أَيْ لَا يَنْظُر بَعْضهمْ إلَى قَفَا بَعْض لِدَوَرَانِ الْأَسِرَّة بِهِمْ"
  15,48,"﴿لَا یَمَسُّهُمۡ فِیهَا نَصَبࣱ﴾ تَعَب ﴿وَمَا هُم مِّنۡهَا بِمُخۡرَجِینَ ۝٤٨﴾ أَبَدًا"
  15,49,"﴿نَبِّئۡ﴾ خَبِّرْ يَا مُحَمَّد ﴿عِبَادِیۤ أَنِّیۤ أَنَا ٱلۡغَفُورُ﴾ لِلْمُؤْمِنِينَ ﴿ٱلرَّحِیمُ ۝٤٩﴾ بِهِمْ"
  15,50,"﴿وَأَنَّ عَذَابِی﴾ لِلْعُصَاةِ ﴿هُوَ ٱلۡعَذَابُ ٱلۡأَلِیمُ ۝٥٠﴾ الْمُؤْلِم"
  15,51,"﴿وَنَبِّئۡهُمۡ عَن ضَیۡفِ إِبۡرَ ٰ⁠هِیمَ ۝٥١﴾ وَهُمْ الْمَلَائِكَة اثْنَا عَشَر أَوْ عَشْرَة أَوْ ثَلَاثَة مِنْهُمْ جِبْرِيل"
  15,52,"﴿إِذۡ دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰا﴾ أَيْ هَذَا اللَّفْظ ﴿قَالَ﴾ إبْرَاهِيم لَمَّا عَرَضَ عَلَيْهِمْ الْأَكْل فَلَمْ يَأْكُلُوا ﴿إِنَّا مِنكُمۡ وَجِلُونَ ۝٥٢﴾ خَائِفُونَ"
  15,53,"﴿قَالُوا۟ لَا تَوۡجَلۡ﴾ لَا تَخَفْ ﴿إِنَّا﴾ رُسُل رَبّك ﴿نُبَشِّرُكَ بِغُلَـٰمٍ عَلِیمࣲ ۝٥٣﴾ ذِي عِلْم كَثِير هُوَ إسْحَاق كَمَا ذَكَرْنَا فِي سُورَة هُود"
  15,54,"﴿قَالَ أَبَشَّرۡتُمُونِی﴾ بِالْوَلَدِ ﴿عَلَىٰۤ أَن مَّسَّنِیَ ٱلۡكِبَرُ﴾ حال أي مع مسه إياي ﴿فَبِمَ﴾ فبأي شيء ﴿تُبَشِّرُونَ ۝٥٤﴾ استفهام تعجب"
  15,55,"﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ﴾ بِالصِّدْقِ ﴿فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾ الآيسين"
  15,56,"﴿قَالَ وَمَن﴾ أَيْ لَا ﴿یَقۡنِطُ﴾ بِكَسْرِ النُّون وَفَتْحهَا ﴿مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾ الْكَافِرُونَ"
  15,57,"﴿قَالَ فَمَا خَطۡبُكُمۡ﴾ شأنكم ﴿أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٥٧﴾"
  15,58,"﴿قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٥٨﴾ كَافِرِينَ أَيْ قَوْم لُوط لِإِهْلَاكِهِمْ"
  15,59,"﴿إِلَّاۤ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمۡ أَجۡمَعِینَ ۝٥٩﴾ لِإِيمَانِهِمْ"
  15,60,"﴿إِلَّا ٱمۡرَأَتَهُۥ قَدَّرۡنَاۤ إِنَّهَا لَمِنَ ٱلۡغَـٰبِرِینَ ۝٦٠﴾ الْبَاقِينَ فِي الْعَذَاب لِكُفْرِهَا"
  15,61,"﴿فَلَمَّا جَاۤءَ ءَالَ لُوطٍ﴾ أي لوطا ﴿ٱلۡمُرۡسَلُونَ ۝٦١﴾"
  15,62,"﴿قَالَ﴾ لَهُمْ ﴿إِنَّكُمۡ قَوۡمࣱ مُّنكَرُونَ ۝٦٢﴾ لَا أَعْرِفكُمْ"
  15,63,"﴿قَالُوا۟ بَلۡ جِئۡنَـٰكَ بِمَا كَانُوا۟﴾ أَيْ قَوْمك ﴿فِیهِ یَمۡتَرُونَ ۝٦٣﴾ يَشُكُّونَ وَهُوَ الْعَذَاب"
  15,64,"﴿وَأَتَیۡنَـٰكَ بِٱلۡحَقِّ وَإِنَّا لَصَـٰدِقُونَ ۝٦٤﴾ فِي قَوْلنَا"
  15,65,"﴿فَأَسۡرِ بِأَهۡلِكَ بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ وَٱتَّبِعۡ أَدۡبَـٰرَهُمۡ﴾ امْشِ خَلْفهمْ ﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدࣱ﴾ لِئَلَّا يَرَى عَظِيم مَا يَنْزِل بِهِمْ ﴿وَٱمۡضُوا۟ حَیۡثُ تُؤۡمَرُونَ ۝٦٥﴾ وهو الشام"
  15,66,"﴿وَقَضَیۡنَاۤ﴾ أَوْحَيْنَا ﴿إِلَیۡهِ ذَ ٰ⁠لِكَ ٱلۡأَمۡرَ﴾ وَهُوَ ﴿أَنَّ دَابِرَ هَـٰۤؤُلَاۤءِ مَقۡطُوعࣱ مُّصۡبِحِینَ ۝٦٦﴾ حَال أَيْ يَتِمّ اسْتِئْصَالهمْ فِي الصَّبَاح"
  15,67,"﴿وَجَاۤءَ أَهۡلُ ٱلۡمَدِینَةِ﴾ مَدِينَة سدوم وَهُمْ قَوْم لُوط لَمَّا أُخْبِرُوا أَنَّ فِي بَيْت لُوط مُرْدًا حِسَانًا وَهُمْ الْمَلَائِكَة ﴿یَسۡتَبۡشِرُونَ ۝٦٧﴾ حَال طَمَعًا فِي فِعْل الْفَاحِشَة بِهِمْ"
  15,68,"﴿قَالَ﴾ لُوط ﴿إِنَّ هَـٰۤؤُلَاۤءِ ضَیۡفِی فَلَا تَفۡضَحُونِ ۝٦٨﴾"
  15,69,"﴿وَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخۡزُونِ ۝٦٩﴾ بِقَصْدِكُمْ إيَّاهُمْ بِفِعْلِ الفاحشة بهم"
  15,70,"﴿قَالُوۤا۟ أَوَلَمۡ نَنۡهَكَ عَنِ ٱلۡعَـٰلَمِینَ ۝٧٠﴾ عَنْ إضَافَتهمْ"
  15,71,"﴿قَالَ هَـٰۤؤُلَاۤءِ بَنَاتِیۤ إِن كُنتُمۡ فَـٰعِلِینَ ۝٧١﴾ مَا تريدون من قضاء الشهوة فتزوجوهن"
  15,72,"قال تعالى ﴿لَعَمۡرُكَ﴾ خِطَاب لِلنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ أَيْ وَحَيَاتك ﴿إِنَّهُمۡ لَفِی سَكۡرَتِهِمۡ یَعۡمَهُونَ ۝٧٢﴾ يَتَرَدَّدُونَ"
  15,73,"﴿فَأَخَذَتۡهُمُ ٱلصَّیۡحَةُ﴾ صَيْحَة جِبْرِيل ﴿مُشۡرِقِینَ ۝٧٣﴾ وَقْت شُرُوق الشمس"
  15,74,"﴿فَجَعَلۡنَا عَـٰلِیَهَا﴾ أَيْ قُرَاهُمْ ﴿سَافِلَهَا﴾ بِأَنْ رَفَعَهَا جِبْرِيل إلَى السَّمَاء وَأَسْقَطَهَا مَقْلُوبَة إلَى الْأَرْض ﴿وَأَمۡطَرۡنَا عَلَیۡهِمۡ حِجَارَةࣰ مِّن سِجِّیلٍ ۝٧٤﴾ طِين طُبِخَ بالنار"
  15,75,"﴿إِنَّ فِی ذَ ٰ⁠لِكَ﴾ المذكور ﴿لَـَٔایَـٰتࣲ﴾ دلالات على وَحْدَانِيَّة اللَّه ﴿لِّلۡمُتَوَسِّمِینَ ۝٧٥﴾ لِلنَّاظِرِينَ الْمُعْتَبِرِينَ"
  15,76,"﴿وَإِنَّهَا﴾ أَيْ قُرَى قَوْم لُوط ﴿لَبِسَبِیلࣲ مُّقِیمٍ ۝٧٦﴾ طَرِيق قُرَيْش إلَى الشَّام لَمْ تَنْدَرِس أَفَلَا يَعْتَبِرُونَ بِهِمْ"
  15,77,"﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ﴾ لعبرة ﴿لِّلۡمُؤۡمِنِینَ ۝٧٧﴾"
  15,78,"﴿وَإِن﴾ مُخَفَّفَة أَيْ إنَّهُ ﴿كَانَ أَصۡحَـٰبُ ٱلۡأَیۡكَةِ﴾ هِيَ غَيْضَة شَجَر بِقُرْبِ مَدْيَن وَهُمْ قَوْم شُعَيْب ﴿لَظَـٰلِمِینَ ۝٧٨﴾ بِتَكْذِيبِهِمْ شُعَيْبًا"
  15,79,"﴿فَٱنتَقَمۡنَا مِنۡهُمۡ﴾ بِأَنْ أَهْلَكْنَاهُمْ بِشِدَّةِ الْحَرّ ﴿وَإِنَّهُمَا﴾ أَيْ قُرَى قَوْم لُوط وَالْأَيْكَة ﴿لَبِإِمَامࣲ﴾ طَرِيق ﴿مُّبِینࣲ ۝٧٩﴾ واضح فلا تَعْتَبِرُونَ بِهِمْ يَا أَهْل مَكَّة"
  15,80,"﴿وَلَقَدۡ كَذَّبَ أَصۡحَـٰبُ ٱلۡحِجۡرِ﴾ وَادٍ بَيْن الْمَدِينَة وَالشَّام وَهُمْ ثَمُود ﴿ٱلۡمُرۡسَلِینَ ۝٨٠﴾ بِتَكْذِيبِهِمْ صَالِحًا لِأَنَّهُ تَكْذِيب لِبَاقِي الرُّسُل لِاشْتِرَاكِهِمْ فِي الْمَجِيء بِالتَّوْحِيدِ"
  15,81,"﴿وَءَاتَیۡنَـٰهُمۡ ءَایَـٰتِنَا﴾ فِي النَّاقَة ﴿فَكَانُوا۟ عَنۡهَا مُعۡرِضِینَ ۝٨١﴾ لا يتفكرون فيها"
  15,82,"﴿وَكَانُوا۟ یَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتًا ءَامِنِینَ ۝٨٢﴾"
  15,83,"﴿فَأَخَذَتۡهُمُ ٱلصَّیۡحَةُ مُصۡبِحِینَ ۝٨٣﴾ وَقْت الصَّبَاح"
  15,84,"﴿فَمَاۤ أَغۡنَىٰ﴾ دَفَعَ ﴿عَنۡهُم﴾ الْعَذَاب ﴿مَّا كَانُوا۟ یَكۡسِبُونَ ۝٨٤﴾ مِنْ بِنَاء الْحُصُون وَجَمْع الْأَمْوَال"
  15,85,"﴿وَمَا خَلَقۡنَا ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ وَمَا بَیۡنَهُمَاۤ إِلَّا بِٱلۡحَقِّۗ وَإِنَّ ٱلسَّاعَةَ لَـَٔاتِیَةࣱۖ﴾ لَا مَحَالَة فَيُجَازَى كُلّ أَحَد بِعَمَلِهِ ﴿فَٱصۡفَحِ﴾ يَا مُحَمَّد عَنْ قَوْمك ﴿ٱلصَّفۡحَ ٱلۡجَمِیلَ ۝٨٥﴾ أَعْرِضْ عَنْهُمْ إعْرَاضًا لَا جَزَع فِيهِ وَهَذَا مَنْسُوخ بِآيَةِ السَّيْف"
  15,86,"﴿إِنَّ رَبَّكَ هُوَ ٱلۡخَلَّـٰقُ﴾ لِكُلِّ شَيْء ﴿ٱلۡعَلِیمُ ۝٨٦﴾ بكل شيء"
  15,87,"﴿وَلَقَدۡ ءَاتَیۡنَـٰكَ سَبۡعࣰا مِّنَ ٱلۡمَثَانِی﴾ قَالَ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ هِيَ الْفَاتِحَة رَوَاهُ الشَّيْخَانِ لأنها تثنى في كل ركعة ﴿وَٱلۡقُرۡءَانَ ٱلۡعَظِیمَ ۝٨٧﴾"
  15,88,"﴿لَا تَمُدَّنَّ عَیۡنَیۡكَ إِلَىٰ مَا مَتَّعۡنَا بِهِۦۤ أَزۡوَ ٰ⁠جࣰا﴾ أَصْنَافًا ﴿مِّنۡهُمۡ وَلَا تَحۡزَنۡ عَلَیۡهِمۡ﴾ إنْ لم يؤمنوا ﴿وَٱخۡفِضۡ جَنَاحَكَ﴾ ألن جانبك ﴿لِلۡمُؤۡمِنِینَ ۝٨٨﴾"
  15,89,"﴿وَقُلۡ إِنِّیۤ أَنَا ٱلنَّذِیرُ﴾ مِنْ عَذَاب اللَّه أَنْ يَنْزِل عَلَيْكُمْ ﴿ٱلۡمُبِینُ ۝٨٩﴾ الْبَيِّن الْإِنْذَار"
  15,90,"﴿كَمَاۤ أَنزَلۡنَا﴾ الْعَذَاب ﴿عَلَى ٱلۡمُقۡتَسِمِینَ ۝٩٠﴾ الْيَهُود وَالنَّصَارَى"
  15,91,"﴿ٱلَّذِینَ جَعَلُوا۟ ٱلۡقُرۡءَانَ﴾ أَيْ كُتُبهمْ الْمُنَزَّلَة عَلَيْهِمْ ﴿عِضِینَ ۝٩١﴾ أَجْزَاء حَيْثُ آمَنُوا بِبَعْضٍ وَكَفَرُوا بِبَعْضٍ وَقِيلَ الْمُرَاد بِهِمْ الَّذِينَ اقْتَسَمُوا طُرُق مَكَّة يَصُدُّونَ النَّاس عَنْ الْإِسْلَام وَقَالَ بَعْضهمْ فِي الْقُرْآن سِحْر وَبَعْضهمْ كَهَانَة وَبَعْضهمْ شِعْر"
  15,92,"﴿فَوَرَبِّكَ لَنَسۡـَٔلَنَّهُمۡ أَجۡمَعِینَ ۝٩٢﴾ سؤال توبيخ"
  15,93,"﴿عَمَّا كَانُوا۟ یَعۡمَلُونَ ۝٩٣﴾"
  15,94,"﴿فَٱصۡدَعۡ﴾ يَا مُحَمَّد ﴿بِمَا تُؤۡمَرُ﴾ بِهِ أَيْ اجْهَرْ بِهِ وَأَمْضِهِ ﴿وَأَعۡرِضۡ عَنِ ٱلۡمُشۡرِكِینَ ۝٩٤﴾ هَذَا قَبْل الْأَمْر بِالْجِهَادِ"
  15,95,"﴿إِنَّا كَفَیۡنَـٰكَ ٱلۡمُسۡتَهۡزِءِینَ ۝٩٥﴾ بِك بِإِهْلَاكِنَا كُلًّا مِنْهُمْ بآفة وهم الوليد بن المغيرة والعاصي بْن وَائِل وَعَدِيّ بْن قَيْس وَالْأَسْوَد بْن الْمُطَّلِب وَالْأَسْوَد بْن عَبْد يَغُوث"
  15,96,"﴿ٱلَّذِینَ یَجۡعَلُونَ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَۚ﴾ صِفَة وَقِيلَ مُبْتَدَأ وَلِتَضَمُّنِهِ مَعْنَى الشَّرْط دَخَلَتْ الْفَاء فِي خَبَره وَهُوَ ﴿فَسَوۡفَ یَعۡلَمُونَ ۝٩٦﴾ عَاقِبَة أَمْرهمْ"
  15,97,"﴿وَلَقَدۡ﴾ لِلتَّحْقِيقِ ﴿نَعۡلَمُ أَنَّكَ یَضِیقُ صَدۡرُكَ بِمَا یَقُولُونَ ۝٩٧﴾ مِنْ الِاسْتِهْزَاء وَالتَّكْذِيب"
  15,98,"﴿فَسَبِّحۡ﴾ مُلْتَبِسًا ﴿بِحَمۡدِ رَبِّكَ﴾ أَيْ قُلْ سُبْحَان اللَّه وَبِحَمْدِهِ ﴿وَكُن مِّنَ ٱلسَّـٰجِدِینَ ۝٩٨﴾ الْمُصَلِّينَ"
  15,99,"﴿وَٱعۡبُدۡ رَبَّكَ حَتَّىٰ یَأۡتِیَكَ ٱلۡیَقِینُ ۝٩٩﴾ الْمَوْت"
