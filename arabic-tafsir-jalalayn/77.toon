tafsir[50]{c,v,t}:
  77,1,"﴿وَٱلۡمُرۡسَلَـٰتِ عُرۡفࣰا ۝١﴾ أَيْ الرِّيَاح مُتَتَابِعَة كَعُرْفِ الْفَرَس يَتْلُو بَعْضه بَعْضًا وَنَصْبه عَلَى الْحَال"
  77,2,"﴿فَٱلۡعَـٰصِفَـٰتِ عَصۡفࣰا ۝٢﴾ الرِّيَاح الشَّدِيدَة"
  77,3,"﴿وَٱلنَّـٰشِرَ ٰ⁠تِ نَشۡرࣰا ۝٣﴾ الرِّيَاح تَنْشُر الْمَطَر"
  77,4,"﴿فَٱلۡفَـٰرِقَـٰتِ فَرۡقࣰا ۝٤﴾ أَيْ آيَات الْقُرْآن تَفْرُق بَيْن الْحَقّ وَالْبَاطِل وَالْحَلَال وَالْحَرَام"
  77,5,"﴿فَٱلۡمُلۡقِیَـٰتِ ذِكۡرًا ۝٥﴾ أَيْ الْمَلَائِكَة تَنْزِل بِالْوَحْيِ إلَى الْأَنْبِيَاء وَالرُّسُل يُلْقُونَ الْوَحْي إلَى الْأُمَم"
  77,6,"﴿عُذۡرًا أَوۡ نُذۡرًا ۝٦﴾ أَيْ لِلْإِعْذَارِ وَالْإِنْذَار مِنْ اللَّه تَعَالَى وَفِي قِرَاءَة بِضَمِّ ذَال {نُذُرًا} وَقُرِئَ بِضَمِّ ذَال عُذْرًا"
  77,7,"﴿إِنَّمَا تُوعَدُونَ﴾ أَيْ يَا كُفَّار مَكَّة مِنْ الْبَعْث وَالْعَذَاب ﴿لَوَ ٰ⁠قِعࣱ ۝٧﴾ كَائِن لَا مَحَالَة"
  77,8,"﴿فَإِذَا ٱلنُّجُومُ طُمِسَتۡ ۝٨﴾ مُحِيَ نُورهَا"
  77,9,"﴿وَإِذَا ٱلسَّمَاۤءُ فُرِجَتۡ ۝٩﴾ شُقَّتْ"
  77,10,"﴿وَإِذَا ٱلۡجِبَالُ نُسِفَتۡ ۝١٠﴾ فُتِّتَتْ وَسُيِّرَتْ"
  77,11,"﴿وَإِذَا ٱلرُّسُلُ أُقِّتَتۡ ۝١١﴾ بِالْوَاوِ وَبِالْهَمْزَةِ بَدَلًا مِنْهَا أَيْ جُمِعَتْ لوقت"
  77,12,"﴿لِأَیِّ یَوۡمٍ﴾ لِيَوْمٍ عَظِيم ﴿أُجِّلَتۡ ۝١٢﴾ لِلشَّهَادَةِ عَلَى أممهم بالتبليغ"
  77,13,"﴿لِیَوۡمِ ٱلۡفَصۡلِ ۝١٣﴾ بَيْن الْخَلْق وَيُؤْخَذ مِنْهُ جَوَاب إذَا أَيْ وَقَعَ الْفَصْل بَيْن الْخَلَائِق"
  77,14,"﴿وَمَاۤ أَدۡرَىٰكَ مَا یَوۡمُ ٱلۡفَصۡلِ ۝١٤﴾ تَهْوِيل لِشَأْنِهِ"
  77,15,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾ هَذَا وَعِيد لَهُمْ"
  77,16,"﴿أَلَمۡ نُهۡلِكِ ٱلۡأَوَّلِینَ ۝١٦﴾ بِتَكْذِيبِهِمْ أَيْ أَهْلَكْنَاهُمْ"
  77,17,"﴿ثُمَّ نُتۡبِعُهُمُ ٱلۡـَٔاخِرِینَ ۝١٧﴾ مِمَّنْ كَذَّبُوا كَكُفَّارِ مَكَّة فَنُهْلِكهُمْ"
  77,18,"﴿كَذَ ٰ⁠لِكَ﴾ مِثْل مَا فَعَلْنَا بِالْمُكَذِّبِينَ ﴿نَفۡعَلُ بِٱلۡمُجۡرِمِینَ ۝١٨﴾ بِكُلِّ مَنْ أَجْرَمَ فِيمَا يَسْتَقْبِل فَنُهْلِكهُمْ"
  77,19,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٩﴾ تَأْكِيد"
  77,20,"﴿أَلَمۡ نَخۡلُقكُّم مِّن مَّاۤءࣲ مَّهِینࣲ ۝٢٠﴾ ضَعِيف وَهُوَ المني"
  77,21,"﴿فَجَعَلۡنَـٰهُ فِی قَرَارࣲ مَّكِینٍ ۝٢١﴾ حَرِيز وَهُوَ الرَّحِم"
  77,22,"﴿إِلَىٰ قَدَرࣲ مَّعۡلُومࣲ ۝٢٢﴾ وَهُوَ وَقْت الْوِلَادَة"
  77,23,"﴿فَقَدَرۡنَا﴾ على ذلك ﴿فَنِعۡمَ ٱلۡقَـٰدِرُونَ ۝٢٣﴾ نحن"
  77,24,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٢٤﴾"
  77,25,"﴿أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ كِفَاتًا ۝٢٥﴾ مَصْدَر كَفَتَ بِمَعْنَى ضَمَّ أَيْ ضَامَّة"
  77,26,"﴿أَحۡیَاۤءࣰ﴾ عَلَى ظَهْرهَا ﴿وَأَمۡوَ ٰ⁠تࣰا ۝٢٦﴾ فِي بَطْنهَا"
  77,27,"﴿وَجَعَلۡنَا فِیهَا رَوَ ٰ⁠سِیَ شَـٰمِخَـٰتࣲ﴾ جِبَالًا مُرْتَفِعَات ﴿وَأَسۡقَیۡنَـٰكُم مَّاۤءࣰ فُرَاتࣰا ۝٢٧﴾ عذبا"
  77,28,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٢٨﴾ وَيُقَال لِلْمُكَذِّبِينَ يَوْم الْقِيَامَة"
  77,29,"﴿ٱنطَلِقُوۤا۟ إِلَىٰ مَا كُنتُم بِهِۦ﴾ مِنْ الْعَذَاب ﴿تُكَذِّبُونَ ۝٢٩﴾"
  77,30,"﴿ٱنطَلِقُوۤا۟ إِلَىٰ ظِلࣲّ ذِی ثَلَـٰثِ شُعَبࣲ ۝٣٠﴾ هُوَ دُخَان جَهَنَّم إذَا ارْتَفَعَ افْتَرَقَ ثَلَاث فِرَق لعظمه"
  77,31,"﴿لَّا ظَلِیلࣲ﴾ كَنِين يُظِلّهُمْ مِنْ حَرّ ذَلِكَ الْيَوْم ﴿وَلَا یُغۡنِی﴾ يَرُدّ عَنْهُمْ شَيْئًا ﴿مِنَ ٱللَّهَبِ ۝٣١﴾ النار"
  77,32,"﴿إِنَّهَا﴾ أَيْ النَّار ﴿تَرۡمِی بِشَرَرࣲ﴾ هُوَ مَا تَطَايَرَ مِنْهَا ﴿كَٱلۡقَصۡرِ ۝٣٢﴾ مِنْ الْبِنَاء فِي عِظَمه وارتفاعه"
  77,33,"﴿كَأَنَّهُۥ جِمَـٰلَـٰتࣱ﴾ جمع جمالة جَمْع جَمَل وَفِي قِرَاءَة {جِمَـٰلَتࣱ} ﴿صُفۡرࣱ ۝٣٣﴾ فِي هَيْئَتهَا وَلَوْنهَا وَفِي الْحَدِيث شِرَار النَّاس أَسْوَد كَالْقِيرِ وَالْعَرَب تُسَمِّي سُود الْإِبِل صُفْرًا لِشَوْبِ سَوَادهَا بِصُفْرَةٍ فَقِيلَ صُفْر فِي الْآيَة بِمَعْنَى سُود لِمَا ذُكِرَ وَقِيلَ لَا وَالشَّرَر جَمْع شرارة والقير القار"
  77,34,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٣٤﴾"
  77,35,"﴿هَـٰذَا﴾ أَيْ يَوْم الْقِيَامَة ﴿یَوۡمُ لَا یَنطِقُونَ ۝٣٥﴾ فيه بشيء"
  77,36,"﴿وَلَا یُؤۡذَنُ لَهُمۡ﴾ فِي الْعُذْر ﴿فَیَعۡتَذِرُونَ ۝٣٦﴾ عَطْف عَلَى يُؤْذَن مِنْ غَيْر تَسَبُّب عَنْهُ فَهُوَ دَاخِل فِي حَيِّز النَّفْي أَيْ لَا إذْن فلا اعتذار"
  77,37,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٣٧﴾"
  77,38,"﴿هَـٰذَا یَوۡمُ ٱلۡفَصۡلِۖ جَمَعۡنَـٰكُمۡ﴾ أَيّهَا الْمُكَذِّبُونَ مِنْ هَذِهِ الْأُمَّة ﴿وَٱلۡأَوَّلِینَ ۝٣٨﴾ مِنْ الْمُكَذِّبِينَ قَبْلكُمْ فَتُحَاسَبُونَ وتعذبون جميعا"
  77,39,"﴿فَإِن كَانَ لَكُمۡ كَیۡدࣱ﴾ حِيلَة فِي دَفْع العذاب عنكم ﴿فَكِیدُونِ ۝٣٩﴾ فافعلوها"
  77,40,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٤٠﴾"
  77,41,"﴿إِنَّ ٱلۡمُتَّقِینَ فِی ظِلَـٰلࣲ﴾ أَيْ تَكَاثُف أَشْجَار إذْ لَا شَمْس يُظِلّ مِنْ حَرّهَا ﴿وَعُیُونࣲ ۝٤١﴾ نَابِعَة مِنْ الْمَاء"
  77,42,"﴿وَفَوَ ٰ⁠كِهَ مِمَّا یَشۡتَهُونَ ۝٤٢﴾ فِيهِ إعْلَام بِأَنَّ الْمَأْكَل وَالْمَشْرَب فِي الْجَنَّة بِحَسَبِ شَهَوَاتهمْ بِخِلَافِ الدُّنْيَا فَبِحَسَبِ مَا يَجِد النَّاس فِي الْأَغْلَب وَيُقَال لهم"
  77,43,"﴿كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا﴾ حَال أَيْ مُتَهَنِّئِينَ ﴿بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٤٣﴾ مِنْ الطَّاعَة"
  77,44,"﴿إِنَّا كَذَ ٰ⁠لِكَ﴾ كما جزينا المتقين ﴿نَجۡزِی ٱلۡمُحۡسِنِینَ ۝٤٤﴾"
  77,45,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٤٥﴾"
  77,46,"﴿كُلُوا۟ وَتَمَتَّعُوا۟﴾ خِطَاب لِلْكُفَّارِ فِي الدُّنْيَا ﴿قَلِیلًا﴾ مِنْ الزَّمَان وَغَايَته إلَى الْمَوْت وَفِي هَذَا تهديد لهم ﴿إِنَّكُم مُّجۡرِمُونَ ۝٤٦﴾"
  77,47,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٤٧﴾"
  77,48,"﴿وَإِذَا قِیلَ لَهُمُ ٱرۡكَعُوا۟﴾ صَلُّوا ﴿لَا یَرۡكَعُونَ ۝٤٨﴾ لا يصلون"
  77,49,"﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٤٩﴾"
  77,50,"﴿فَبِأَیِّ حَدِیثِۭ بَعۡدَهُۥ﴾ أَيْ الْقُرْآن ﴿یُؤۡمِنُونَ ۝٥٠﴾ أَيْ لَا يَمْكَن إيمَانهمْ بِغَيْرِهِ مِنْ كُتُب اللَّه بَعْد تَكْذِيبهمْ بِهِ لِاشْتِمَالِهِ عَلَى الْإِعْجَاز الَّذِي لم يشتمل عليه غيره"
