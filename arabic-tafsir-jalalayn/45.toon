tafsir[37]{c,v,t}:
  45,1,"﴿حمۤ ۝١﴾ اللَّه أَعْلَم بِمُرَادِهِ بِهِ"
  45,2,"﴿تَنزِیلُ ٱلۡكِتَـٰبِ﴾ القرآن مبتدأ ﴿مِنَ ٱللَّهِ﴾ خبره ﴿ٱلۡعَزِیزِ﴾ فِي مُلْكه ﴿ٱلۡحَكِیمِ ۝٢﴾ فِي صُنْعه"
  45,3,"﴿إِنَّ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾ أَيْ فِي خَلْقهمَا ﴿لَـَٔایَـٰتࣲ﴾ دَالَّة عَلَى قُدْرَة اللَّه وَوَحْدَانِيّته تَعَالَى ﴿لِّلۡمُؤۡمِنِینَ ۝٣﴾"
  45,4,"﴿وَفِی خَلۡقِكُمۡ﴾ أَيْ فِي خَلْق كُلّ مِنْكُمْ مِنْ نُطْفَة ثُمَّ عَلَقَة ثُمَّ مُضْغَة إلَى أن صار إنسانا ﴿وَ﴾ خلق ﴿مَا یَبُثُّ﴾ يُفَرَّق فِي الْأَرْض ﴿مِن دَاۤبَّةٍ﴾ هِيَ مَا يَدِبّ عَلَى الْأَرْض مِنْ النَّاس وَغَيْرهمْ ﴿ءَایَـٰتࣱ لِّقَوۡمࣲ یُوقِنُونَ ۝٤﴾ بِالْبَعْثِ"
  45,5,"﴿وَ﴾ فِي ﴿ٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ﴾ ذَهَابهمَا وَمَجِيئُهُمَا ﴿وَمَاۤ أَنزَلَ ٱللَّهُ مِنَ ٱلسَّمَاۤءِ مِن رِّزۡقࣲ﴾ مطر لأنه سبب الرزق ﴿فَأَحۡیَا بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَا وَتَصۡرِیفِ ٱلرِّیَـٰحِ﴾ تَقْلِيبهَا مَرَّة جَنُوبًا وَمَرَّة شِمَالًا وَبَارِدَة وَحَارَّة ﴿ءَایَـٰتࣱ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٥﴾ الدَّلِيل فَيُؤْمِنُونَ"
  45,6,"﴿تِلۡكَ﴾ الْآيَات الْمَذْكُورَة ﴿ءَایَـٰتُ ٱللَّهِ﴾ حُجَجه الدَّالَّة عَلَى وَحْدَانِيّته ﴿نَتۡلُوهَا﴾ نَقُصّهَا ﴿عَلَیۡكَ بِٱلۡحَقِّۖ﴾ مُتَعَلِّق بِنَتْلُو ﴿فَبِأَیِّ حَدِیثِۭ بَعۡدَ ٱللَّهِ﴾ أَيْ حَدِيثه وَهُوَ الْقُرْآن ﴿وَءَایَـٰتِهِۦ﴾ حُجَجه ﴿یُؤۡمِنُونَ ۝٦﴾ أَيْ كُفَّار مَكَّة أَيْ لَا يُؤْمِنُونَ وَفِي قِرَاءَة بِالتَّاءِ"
  45,7,"﴿وَیۡلࣱ﴾ كَلِمَة عَذَاب ﴿لِّكُلِّ أَفَّاكٍ﴾ كَذَّاب ﴿أَثِیمࣲ ۝٧﴾ كثير الإثم"
  45,8,"﴿یَسۡمَعُ ءَایَـٰتِ ٱللَّهِ﴾ الْقُرْآن ﴿تُتۡلَىٰ عَلَیۡهِ ثُمَّ یُصِرُّ﴾ عَلَى كُفْره ﴿مُسۡتَكۡبِرࣰا﴾ مُتَكَبِّرًا عَنْ الْإِيمَان ﴿كَأَن لَّمۡ یَسۡمَعۡهَاۖ فَبَشِّرۡهُ بِعَذَابٍ أَلِیمࣲ ۝٨﴾ مُؤْلِم"
  45,9,"﴿وَإِذَا عَلِمَ مِنۡ ءَایَـٰتِنَا﴾ أَيْ الْقُرْآن ﴿شَیۡـًٔا ٱتَّخَذَهَا هُزُؤًاۚ﴾ أَيْ مَهْزُوءًا بِهَا ﴿أُو۟لَـٰۤىِٕكَ﴾ أَيْ الْأَفَّاكُونَ ﴿لَهُمۡ عَذَابࣱ مُّهِینࣱ ۝٩﴾ ذُو إهَانَة"
  45,10,"﴿مِّن وَرَاۤىِٕهِمۡ﴾ أَيْ أَمَامهمْ لِأَنَّهُمْ فِي الدُّنْيَا ﴿جَهَنَّمُۖ وَلَا یُغۡنِی عَنۡهُم مَّا كَسَبُوا۟﴾ مِنْ المال والفعال ﴿شَیۡـࣰٔا وَلَا مَا ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ﴾ أي الأصنام ﴿أَوۡلِیَاۤءَۖ وَلَهُمۡ عَذَابٌ عَظِیمٌ ۝١٠﴾"
  45,11,"﴿هَـٰذَا﴾ أَيْ الْقُرْآن ﴿هُدࣰىۖ﴾ مِنْ الضَّلَالَة ﴿وَٱلَّذِینَ كَفَرُوا۟ بِـَٔایَـٰتِ رَبِّهِمۡ لَهُمۡ عَذَابࣱ﴾ حَظّ ﴿مِّن رِّجۡزٍ﴾ أَيْ عَذَاب ﴿أَلِیمٌ ۝١١﴾ مُوجِع"
  45,12,"﴿ٱللَّهُ ٱلَّذِی سَخَّرَ لَكُمُ ٱلۡبَحۡرَ لِتَجۡرِیَ ٱلۡفُلۡكُ﴾ السُّفُن ﴿فِیهِ بِأَمۡرِهِۦ﴾ بِإِذْنِهِ ﴿وَلِتَبۡتَغُوا۟﴾ تَطْلُبُوا بِالتِّجَارَةِ ﴿مِن فَضۡلِهِۦ وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝١٢﴾"
  45,13,"﴿وَسَخَّرَ لَكُم مَّا فِی ٱلسَّمَـٰوَ ٰ⁠تِ﴾ مِنْ شَمْس وَقَمَر وَنُجُوم وَمَاء وَغَيْره ﴿وَمَا فِی ٱلۡأَرۡضِ﴾ مِنْ دَابَّة وَشَجَر وَنَبَات وَأَنْهَار وَغَيْرهَا أَيْ خَلَقَ ذَلِكَ لِمَنَافِعِكُمْ ﴿جَمِیعࣰا﴾ تَأْكِيد ﴿مِّنۡهُۚ﴾ حَال أَيْ سَخَّرَهَا كَائِنَة مِنْهُ تَعَالَى ﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝١٣﴾ فِيهَا فَيُؤْمِنُونَ"
  45,14,"﴿قُل لِّلَّذِینَ ءَامَنُوا۟ یَغۡفِرُوا۟ لِلَّذِینَ لَا یَرۡجُونَ﴾ يَخَافُونَ ﴿أَیَّامَ ٱللَّهِ﴾ وَقَائِعه أَيْ اغْفِرُوا لِلْكُفَّارِ مَا وَقَعَ مِنْهُمْ مِنْ الْأَذَى لَكُمْ وَهَذَا قَبْل الْأَمْر بِجِهَادِهِمْ ﴿لِیَجۡزِیَ﴾ أَيْ اللَّه وَفِي قِرَاءَة بِالنُّونِ ﴿قَوۡمَۢا بِمَا كَانُوا۟ یَكۡسِبُونَ ۝١٤﴾ مِنْ الْغَفْر لِلْكُفَّارِ أَذَاهُمْ"
  45,15,"﴿مَنۡ عَمِلَ صَـٰلِحࣰا فَلِنَفۡسِهِۦۖ﴾ عمل ﴿وَمَنۡ أَسَاۤءَ فَعَلَیۡهَاۖ﴾ أَسَاءَ ﴿ثُمَّ إِلَىٰ رَبِّكُمۡ تُرۡجَعُونَ ۝١٥﴾ تَصِيرُونَ فَيُجَازِي الْمُصْلِح وَالْمُسِيء"
  45,16,"﴿وَلَقَدۡ ءَاتَیۡنَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ٱلۡكِتَـٰبَ﴾ التَّوْرَاة ﴿وَٱلۡحُكۡمَ﴾ بِهِ بَيْن النَّاس ﴿وَٱلنُّبُوَّةَ﴾ لِمُوسَى وَهَارُونَ مِنْهُمْ ﴿وَرَزَقۡنَـٰهُم مِّنَ ٱلطَّیِّبَـٰتِ﴾ الْحَلَالَاتِ كَالْمَنِّ وَالسَّلْوَى ﴿وَفَضَّلۡنَـٰهُمۡ عَلَى ٱلۡعَـٰلَمِینَ ۝١٦﴾ عَالِمِي زَمَانهمْ الْعُقَلَاء"
  45,17,"﴿وَءَاتَیۡنَـٰهُم بَیِّنَـٰتࣲ مِّنَ ٱلۡأَمۡرِۖ﴾ أَمْر الدِّين مِنْ الْحَلَال وَالْحَرَام وَبَعْثَة مُحَمَّد عَلَيْهِ أَفَضْل الصَّلَاة وَالسَّلَام ﴿فَمَا ٱخۡتَلَفُوۤا۟﴾ فِي بَعَثْته ﴿إِلَّا مِنۢ بَعۡدِ مَا جَاۤءَهُمُ ٱلۡعِلۡمُ بَغۡیَۢا بَیۡنَهُمۡۚ﴾ أَيْ لبغي حدث بينهم حسدا له ﴿إِنَّ رَبَّكَ یَقۡضِی بَیۡنَهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ فِیمَا كَانُوا۟ فِیهِ یَخۡتَلِفُونَ ۝١٧﴾"
  45,18,"﴿ثُمَّ جَعَلۡنَـٰكَ﴾ يَا مُحَمَّد ﴿عَلَىٰ شَرِیعَةࣲ﴾ طَرِيقَة ﴿مِّنَ ٱلۡأَمۡرِ﴾ أَمْر الدِّين ﴿فَٱتَّبِعۡهَا وَلَا تَتَّبِعۡ أَهۡوَاۤءَ ٱلَّذِینَ لَا یَعۡلَمُونَ ۝١٨﴾ فِي عِبَادَة غَيْر الله"
  45,19,"﴿إِنَّهُمۡ لَن یُغۡنُوا۟﴾ يَدْفَعُوا ﴿عَنكَ مِنَ ٱللَّهِ﴾ من عذابه ﴿شَیۡـࣰٔاۚ وَإِنَّ ٱلظَّـٰلِمِینَ﴾ الكافرين ﴿بَعۡضُهُمۡ أَوۡلِیَاۤءُ بَعۡضࣲۖ وَٱللَّهُ وَلِیُّ ٱلۡمُتَّقِینَ ۝١٩﴾"
  45,20,"﴿هَـٰذَا﴾ الْقُرْآن ﴿بَصَـٰۤىِٕرُ لِلنَّاسِ﴾ مَعَالِم يَتَبَصَّرُونَ بِهَا فِي الْأَحْكَام وَالْحُدُود ﴿وَهُدࣰى وَرَحۡمَةࣱ لِّقَوۡمࣲ یُوقِنُونَ ۝٢٠﴾ بالبعث"
  45,21,"﴿أَمۡ﴾ بِمَعْنَى هَمْزَة الْإِنْكَار ﴿حَسِبَ ٱلَّذِینَ ٱجۡتَرَحُوا۟﴾ اكْتَسَبُوا ﴿ٱلسَّیِّـَٔاتِ﴾ الْكُفْر وَالْمَعَاصِي ﴿أَن نَّجۡعَلَهُمۡ كَٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ سَوَاۤءࣱ﴾ خَبَر ﴿مَّحۡیَاهُمۡ وَمَمَاتُهُمۡۚ﴾ مُبْتَدَأ وَمَعْطُوف وَالْجُمْلَة بَدَل مِنْ الْكَاف وَالضَّمِيرَانِ لِلْكُفَّارِ الْمَعْنَى أَحَسِبُوا أَنْ نَجْعَلهُمْ فِي الْآخِرَة فِي خَيْر كَالْمُؤْمِنِينَ فِي رَغَد مِنْ الْعَيْش مُسَاوٍ لِعَيْشِهِمْ فِي الدُّنْيَا حَيْثُ قَالُوا لِلْمُؤْمِنِينَ لَئِنْ بُعِثْنَا لَنُعْطَى مِنْ الْخَيْر مِثْل مَا تُعْطُونَ قَالَ تَعَالَى عَلَى وَفْق إنْكَاره بِالْهَمْزَةِ ﴿سَاۤءَ مَا یَحۡكُمُونَ ۝٢١﴾ أَيْ لَيْسَ الْأَمْر كَذَلِكَ فَهُمْ فِي الْآخِرَة فِي الْعَذَاب عَلَى خِلَاف عَيْشهمْ فِي الدُّنْيَا وَالْمُؤْمِنُونَ فِي الْآخِرَة فِي الثَّوَاب بِعَمَلِهِمْ الصَّالِحَات فِي الدُّنْيَا مِنْ الصَّلَاة وَالزَّكَاة وَالصِّيَام وَغَيْر ذَلِكَ وَمَا مَصْدَرِيَّة أَيْ بئس حكما حكمهم هذا"
  45,22,"﴿وَخَلَقَ ٱللَّهُ ٱلسَّمَـٰوَ ٰ⁠تِ وَ﴾ خلق ﴿ٱلۡأَرۡضَ بِٱلۡحَقِّ﴾ مُتَعَلِّق بِخَلَقَ لِيَدُلّ عَلَى قُدْرَته وَوَحْدَانِيّته ﴿وَلِتُجۡزَىٰ كُلُّ نَفۡسِۭ بِمَا كَسَبَتۡ﴾ مِنْ الْمَعَاصِي والطاعات فلا يساوي الكافر المؤمن ﴿وَهُمۡ لَا یُظۡلَمُونَ ۝٢٢﴾"
  45,23,"﴿أَفَرَءَیۡتَ﴾ أَخْبِرْنِي ﴿مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾ مَا يَهْوَاهُ مِنْ حَجَر بَعْد حَجَر يَرَاهُ أَحْسَن ﴿وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلۡمࣲ﴾ مِنْهُ تَعَالَى أَيْ عَالِمًا بِأَنَّهُ مِنْ أَهْل الضَّلَالَة قَبْل خَلْقه ﴿وَخَتَمَ عَلَىٰ سَمۡعِهِۦ وَقَلۡبِهِۦ﴾ فَلَمْ يَسْمَع الْهُدَى وَلَمْ يَعْقِلهُ ﴿وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَـٰوَةࣰ﴾ ظُلْمَة فَلَمْ يُبْصِر الْهُدَى وَيُقَدَّر هُنَا الْمَفْعُول الثَّانِي لِرَأَيْت أَيَهْتَدِي ﴿فَمَن یَهۡدِیهِ مِنۢ بَعۡدِ ٱللَّهِۚ﴾ أَيْ بَعْد إضْلَاله إيَّاهُ أَيْ لَا يَهْتَدِي ﴿أَفَلَا تَذَّكَّرُونَ ۝٢٣﴾ تَتَّعِظُونَ فِيهِ إدْغَام إحْدَى التَّاءَيْنِ في الذال"
  45,24,"﴿وَقَالُوا۟﴾ أَيْ مُنْكِرُو الْبَعْث ﴿مَا هِیَ﴾ أَيْ الْحَيَاة ﴿إِلَّا حَیَاتُنَا﴾ الَّتِي فِي ﴿ٱلدُّنۡیَا نَمُوتُ وَنَحۡیَا﴾ أَيْ يَمُوت بَعْض وَيَحْيَا بَعْض بِأَنْ يُولَدُوا ﴿وَمَا یُهۡلِكُنَاۤ إِلَّا ٱلدَّهۡرُۚ﴾ أَيْ مُرُور الزمان قال تعالى ﴿وَمَا لَهُم بِذَ ٰ⁠لِكَ﴾ الْمَقُول ﴿مِنۡ عِلۡمٍۖ إِنۡ﴾ ما ﴿هُمۡ إِلَّا یَظُنُّونَ ۝٢٤﴾"
  45,25,"﴿وَإِذَا تُتۡلَىٰ عَلَیۡهِمۡ ءَایَـٰتُنَا﴾ مِنْ الْقُرْآن الدَّالَّة عَلَى قُدْرَتنَا عَلَى الْبَعْث ﴿بَیِّنَـٰتࣲ﴾ وَاضِحَات حَال ﴿مَّا كَانَ حُجَّتَهُمۡ إِلَّاۤ أَن قَالُوا۟ ٱئۡتُوا۟ بِـَٔابَاۤىِٕنَاۤ﴾ أَحْيَاء ﴿إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٥﴾ أَنَّا نُبْعَث"
  45,26,"﴿قُلِ ٱللَّهُ یُحۡیِیكُمۡ﴾ حِين كُنْتُمْ نُطَفًا ﴿ثُمَّ یُمِیتُكُمۡ ثُمَّ یَجۡمَعُكُمۡ﴾ أَحْيَاء ﴿إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ لَا رَیۡبَ﴾ شَكّ ﴿فِیهِ وَلَـٰكِنَّ أَكۡثَرَ ٱلنَّاسِ﴾ وهم القائلون ما ذكر ﴿لَا یَعۡلَمُونَ ۝٢٦﴾"
  45,27,"﴿وَلِلَّهِ مُلۡكُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ وَیَوۡمَ تَقُومُ ٱلسَّاعَةُ﴾ يُبْدَل مِنْهُ ﴿یَوۡمَىِٕذࣲ یَخۡسَرُ ٱلۡمُبۡطِلُونَ ۝٢٧﴾ الْكَافِرُونَ أَيْ يَظْهَر خُسْرَانهمْ بِأَنْ يَصِيرُوا إلَى النَّار"
  45,28,"﴿وَتَرَىٰ كُلَّ أُمَّةࣲ﴾ أَيْ أَهْل دِين ﴿جَاثِیَةࣰۚ﴾ عَلَى الرُّكَب أَوْ مُجْتَمِعَة ﴿كُلُّ أُمَّةࣲ تُدۡعَىٰۤ إِلَىٰ كِتَـٰبِهَا﴾ كِتَاب أَعْمَالهَا وَيُقَال لَهُمْ ﴿ٱلۡیَوۡمَ تُجۡزَوۡنَ مَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾ أَيْ جَزَاءَهُ"
  45,29,"﴿هَـٰذَا كِتَـٰبُنَا﴾ دِيوَان الْحَفَظَة ﴿یَنطِقُ عَلَیۡكُم بِٱلۡحَقِّۚ إِنَّا كُنَّا نَسۡتَنسِخُ﴾ نثبت ونحفظ ﴿مَا كُنتُمۡ تَعۡمَلُونَ ۝٢٩﴾"
  45,30,"﴿فَأَمَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَیُدۡخِلُهُمۡ رَبُّهُمۡ فِی رَحۡمَتِهِۦۚ﴾ جَنَّته ﴿ذَ ٰ⁠لِكَ هُوَ ٱلۡفَوۡزُ ٱلۡمُبِینُ ۝٣٠﴾ البين الظاهر"
  45,31,"﴿وَأَمَّا ٱلَّذِینَ كَفَرُوۤا۟﴾ فَيُقَال لَهُمْ ﴿أَفَلَمۡ تَكُنۡ ءَایَـٰتِی﴾ الْقُرْآن ﴿تُتۡلَىٰ عَلَیۡكُمۡ فَٱسۡتَكۡبَرۡتُمۡ﴾ تَكَبَّرْتُمْ ﴿وَكُنتُمۡ قَوۡمࣰا مُّجۡرِمِینَ ۝٣١﴾ كَافِرِينَ"
  45,32,"﴿وَإِذَا قِیلَ﴾ لَكُمْ أَيّهَا الْكُفَّار ﴿إِنَّ وَعۡدَ ٱللَّهِ﴾ بِالْبَعْثِ ﴿حَقࣱّ وَٱلسَّاعَةُ﴾ بِالرَّفْعِ وَالنَّصْب ﴿لَا رَیۡبَ﴾ شَكّ ﴿فِیهَا قُلۡتُم مَّا نَدۡرِی مَا ٱلسَّاعَةُ إِن﴾ مَا ﴿نَّظُنُّ إِلَّا ظَنࣰّا﴾ قَالَ الْمُبَرِّد أَصْله إنْ نَحْنُ إلَّا نَظُنّ ظَنًّا ﴿وَمَا نَحۡنُ بِمُسۡتَیۡقِنِینَ ۝٣٢﴾ أَنَّهَا آتِيَة"
  45,33,"﴿وَبَدَا﴾ ظَهَرَ ﴿لَهُمۡ﴾ فِي الْآخِرَة ﴿سَیِّـَٔاتُ مَا عَمِلُوا۟﴾ فِي الدُّنْيَا أَيْ جَزَاؤُهَا ﴿وَحَاقَ﴾ نَزَلَ ﴿بِهِم مَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٣٣﴾ أي العذاب"
  45,34,"﴿وَقِیلَ ٱلۡیَوۡمَ نَنسَىٰكُمۡ﴾ نَتْرُككُمْ فِي النَّار ﴿كَمَا نَسِیتُمۡ لِقَاۤءَ یَوۡمِكُمۡ هَـٰذَا﴾ أَيْ تَرَكْتُمْ الْعَمَل لِلِقَائِهِ ﴿وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٣٤﴾ مانعين منه"
  45,35,"﴿ذَ ٰ⁠لِكُم بِأَنَّكُمُ ٱتَّخَذۡتُمۡ ءَایَـٰتِ ٱللَّهِ﴾ القرآن ﴿هُزُؤࣰا وَغَرَّتۡكُمُ ٱلۡحَیَوٰةُ ٱلدُّنۡیَاۚ﴾ حَتَّى قُلْتُمْ لَا بَعْث وَلَا حِسَاب ﴿فَٱلۡیَوۡمَ لَا یَخۡرُجُونَ﴾ بِالْبِنَاءِ لِلْفَاعِلِ وَلِلْمَفْعُولِ ﴿مِنۡهَا﴾ مِنَ النَّار ﴿وَلَا هُمۡ یُسۡتَعۡتَبُونَ ۝٣٥﴾ لَا يُطْلَب مِنْهُمْ أَنْ يُرْضُوا رَبّهمْ بِالتَّوْبَةِ وَالطَّاعَة لِأَنَّهَا لَا تَنْفَع يَوْمئِذٍ"
  45,36,"﴿فَلِلَّهِ ٱلۡحَمۡدُ﴾ الْوَصْف بِالْجَمِيلِ عَلَى وَفَاء وَعْده فِي الْمُكَذِّبِينَ ﴿رَبِّ ٱلسَّمَـٰوَ ٰ⁠تِ وَرَبِّ ٱلۡأَرۡضِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٣٦﴾ خَالِق مَا ذُكِرَ وَالْعَالَم مَا سِوَى اللَّه وَجُمِعَ لِاخْتِلَافِ أَنْوَاعه وَرَبّ بَدَل"
  45,37,"﴿وَلَهُ ٱلۡكِبۡرِیَاۤءُ﴾ الْعَظَمَة ﴿فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ﴾ حَال أَيْ كَائِنَة فِيهِمَا ﴿وَهُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٣٧﴾ تَقَدَّمَ"
