quran[56]{c,v,t}:
  74,1,"ای کسی‌که خودش را با لباسش پوشانیده (یعنی پیامبر صلی الله علیه وسلم )."
  74,2,"برخیز و از عذاب الله بترسان."
  74,3,"و پروردگارت را بزرگ شمار."
  74,4,"و نفس خویش را از گناهان و لباست را از نجاست‌ها پاک کن."
  74,5,"و از عبادت بت‌ها دوری گزین."
  74,6,"و به سبب بزرگ پنداشتن عمل نیک خود، بر پروردگارت منت نگذار."
  74,7,"و در برابر آزارهایی که با آنها روبرو می‌شوی به خاطر الله شکیبایی کن."
  74,8,"پس آن‌گاه که برای بار دوم در صور دمیده شود."
  74,9,"آن روز، روزی سخت است."
  74,10,"بر کافران به الله و رسولش آسان نیست."
  74,11,"- ای رسول- مرا با کسی‌که او را در شکم مادرش تک و تنها بدون مال یا فرزند آفریدم (یعنی ولید بن مُغِیره) واگذار."
  74,12,"و مال زیادی برایش قرار دادم."
  74,13,"و پسرانی برایش قرار دادم که همراهش حاضر هستند و در محافل با او حضور دارند و به خاطر مال زیادش در هیچ سفری از او جدا نمی‌شوند."
  74,14,"و در زندگی و روزی و فرزند از هر نظر برایش گستراندم."
  74,15,"باز هم با وجود کفرش به من طمع دارد که پس از اینکه تمام این موارد را به او دادم برایش بیفزایم."
  74,16,"امر آن‌گونه که تصور کرد نیست، زیرا او ستیزه‌جو و تکذیب‌ کنندۀ آیاتی است که بر رسول مان نازل کردیم."
  74,17,"به‌زودی عذابی سخت بر دوش او می‌گذارم که توان تحملش را ندارد."
  74,18,"همانا این کافر که نعمت‌های مذکور را به او ارزانی داشتم برای ابطال آنچه قرآن در مورد او می‌گوید اندیشید، و طرحی در ذهنش آماده کرد."
  74,19,"نفرین و عذاب بر او باد چگونه ارزیابی کرد."
  74,20,"باز هم نفرین و عذاب بر او باد، چگونه سنجید و ارزیابی کرد."
  74,21,"دوباره در آنچه که می‌گوید نگریست و اندیشید."
  74,22,"سپس چون چیزی نیافت که با آن بر قرآن عیب وارد کند چهره در هم کشید و خشم کرد."
  74,23,"سپس از ایمان روی گرداند و از پیروی پیامبر صلی الله علیه وسلم خودداری کرد."
  74,24,"پس گفت: این چیزی که محمد آورده است سخن الله نیست، بلکه سحری است که از دیگران روایت می‌کند."
  74,25,"کلام الله نیست، بلکه کلام انسان است."
  74,26,"به‌زودی این کافر را در یکی از طبقات جهنم، یعنی سَقَر که گرمایی کشنده دارد وارد می‌کنم."
  74,27,"و - ای محمد- تو چه می‌دانی که سَقَر چیست؟!"
  74,28,"از عذاب‌شدۀ در خویش چیزی باقی نمی‌گذارد مگر اینکه او را فرا می‌گیرد، و رها نمی‌کند، سپس همان‌گونه که بود بازمی‌گردد، سپس بر او فرود می‌آید، و به همین ترتیب ادامه دارد."
  74,29,"پوست‌ها را سخت می‌سوزاند و تغییر می‌دهد."
  74,30,"بر آن نوزده فرشته گمارده شده است، که خزانه‌دارانش هستند."
  74,31,"و ما مأموران دوزخ را تنها از میان فرشتگان بر گزیده ایم، و انسان توانایی مقابله با آن ها را ندارد، و تعداد آن ها را جز آزمایشی برای کسانی که به الله کفر ورزیده اند، قرار ندادیم؛ تا در مورد آن ها هر چه كه می خواهند بگویند و در نهایت عذاب بر آنان دوچندان می شود، و تا یهود که تورات، و نصاری که انجیل به آن ها داده شده، اطمینان حاصل کنند که قرآن، تصدیق کننده ی آنچه مى باشد در کتاب هایشان است. همچنین مؤمنان زمانی که این (موضوع مورد) توافق را می بینند، ایمانشان افزايش يابد و یهود، نصاری و مؤمنان (در حق بودنش) شک و تردیدی نکنند، و تا کسانی که در دل هایشان بيمارى و ترديد وجود دارد و همچنين کافران، بگویند: الله با تعیین این عدد عجیب چه چیزی را اراده کرده است؟! همچنان که الله متعال تکذیب کننده ی این عدد را گمراه، و تصدیق کننده ی آن را مورد هدایت قرار داده است؛ هر کس را بخواهد گمراه و هر کس را بخواهد هدایت می دهد. به علت كثرت و فراوانی، کسی جز پروردگار از (انواع و ماهیت) لشکریانش آگاه نیست، و دوزخ جز اندرزى براى مردمان نيست تا با آن به بزرگی الله متعال پی ببرند."
  74,32,"سخن آن‌گونه نیست که یکی از مشرکان ادعا می‌کند یارانش برای چیره‌شدن بر خزانه‌داران جهنم کافی هستند. الله به ماه سوگند یاد فرمود."
  74,33,"و به شب آن‌گاه که پشت کند سوگند یاد فرمود."
  74,34,"و به صبح آن‌گاه که روشنایی آورد سوگند یاد فرمود."
  74,35,"که آتش جهنم به‌طور قطع یکی از بلایای بزرگ است."
  74,36,"وسیلۀ تهدید و ترساندن مردم است."
  74,37,"- ای مردم- برای هرکس از شما که بخواهد با ایمان به الله و عمل صالح پیشی جوید، یا با کفر و گناهان عقب بکشد."
  74,38,"هرکس در قبال اعمالی‌که کسب کرده گرفتار است. پس یا اعمالش او را نابود می‌کند، یا او را از نابودی می‌رهاند و نجات می‌دهد."
  74,39,"مگر مؤمنان که در قبال گناهان‌شان مواخذه نمی‌شوند، بلکه به‌سبب اعمال صالحی که دارند مورد عفو قرار می‌گیرند."
  74,40,"و آنها روز قیامت در بهشت‌هایی هستند و از یکدیگر می‌پرسند."
  74,41,"در مورد کافران که خودشان را با گناهانی که انجام دادند نابود کردند."
  74,42,"به آنها می‌گویند: چه چیزی شما را وارد جهنم کرد؟"
  74,43,"کافران این‌گونه به آنها پاسخ می‌دهند: از کسانی‌که نماز واجب را در زندگی دنیا برپا می‌داشتند نبودیم."
  74,44,"و از آنچه که الله به ما عطا کرده بود به فقیر اطعام نمی‌کردیم."
  74,45,"و همراه پیروان باطل بودیم که هرجا می‌گشتند با آنها می‌گشتیم، و با گمراهان و فریب ‌خوردگان سخن می‌گفتیم."
  74,46,"و روز جزا را تکذیب می‌کردیم."
  74,47,"و به تکذیب روز جزا ادامه دادیم تا مرگ ما را فرا گرفت، آن‌گاه میان ما و توبه مانع ایجاد کرد."
  74,48,"پس شفاعت شفاعتگران، اعم از فرشتگان و پیامبران و صالحان در روز قیامت به آنان سودی نمی رساند؛ چرا که یکی از شروط پذیرش شفاعت، رضایت از شفاعت شده است."
  74,49,"چه چیزی باعث رویگردانی این مشرکان از قرآن شد؟!"
  74,50,"گویی در رویگردانی و فرار از قرآن، گورخرانی بسیار رمنده هستند."
  74,51,"که از شیری به‌سبب ترس از آن می‌گریزند."
  74,52,"بلکه هر یک از این مشرکان می‌خواهد نامه‌ای برایش ارسال شود که به او خبر می‌دهد محمد رسولی از جانب الله است، و سبب این امر کمبود و ضعف دلایل و حجت‌ها نیست، بلکه فقط ستیزه‌جویی و تکبر است."
  74,53,"چنین نیست، بلکه سبب استمرار گمراهی آنها این است که به عذاب آخرت ایمان نمی‌آورند، و بر کفرشان باقی می‌مانند."
  74,54,"بدانید که این قرآن اندرز و یادآوری است."
  74,55,"پس هرکس که بخواهد می‌تواند قرآن را بخواند و از آن اندرز گیرد."
  74,56,"و پند نمی‌گیرند مگر اینکه الله بخواهد پند بگیرند. او سبحانه سزاوار است که با امتثال اوامر و اجتناب از نواهی‌اش از او ترسیده شود، و سزاوار است که گناهان بندگانش را آن‌گاه که به‌سوی او توبه کنند بیامرزد."
