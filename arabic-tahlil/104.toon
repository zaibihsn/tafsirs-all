quran[9]{c,v,t}:
  104,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَيْلٌ﴾</span></span> اسم، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُلِّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمَزَةٍ﴾</span></span> اسم، من مادّة <root>همز</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لُّمَزَةٍ﴾</span></span> اسم، من مادّة <root>لمز</root>، مؤنث، نكرة، مجرور.</p></div>"
  104,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَمَعَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جمع</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالًا﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَدَّدَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>عدد</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  104,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَحْسَبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>حسب</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالَ﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَخْلَدَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>خلد</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  104,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿يُنۢبَذَ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>نبذ</root>، غائب، مذكر، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> لام التوكيد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حُطَمَةِ﴾</span></span> اسم، من مادّة <root>حطم</root>، مؤنث، مجرور.</p></div>"
  104,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْرَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دري</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حُطَمَةُ﴾</span></span> اسم، من مادّة <root>حطم</root>، مؤنث، مرفوع.</p></div>"
  104,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿نَارُ﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُوقَدَةُ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>وقد</root>، مؤنث، مرفوع، نعت.</p></div>"
  104,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّتِى﴾</span></span> اسم موصول، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَطَّلِعُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>طلع</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَفْـِٔدَةِ﴾</span></span> اسم، من مادّة <root>فأد</root>، مذكر، جمع، مجرور.</p></div>"
  104,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّؤْصَدَةٌ﴾</span></span> اسم، من مادّة <root>وصد</root>، مؤنث، نكرة، مرفوع.</p></div>"
  104,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَمَدٍ﴾</span></span> اسم، من مادّة <root>عمد</root>، مذكر، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّمَدَّدَةٍۭ﴾</span></span> اسم مفعول مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>مدد</root>، مؤنث، نكرة، مجرور، نعت.</p></div>"
