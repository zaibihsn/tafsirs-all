quran[19]{c,v,t}:
  82,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَآءُ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱنفَطَرَتْ﴾</span></span> فعل ماض مزيد الخماسي باب (انْفَعَلَ)، من مادّة <root>فطر</root>، غائب، مؤنث، مفرد.</p></div>"
  82,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَوَاكِبُ﴾</span></span> اسم، من مادّة <root>كوكب</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱنتَثَرَتْ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>نثر</root>، غائب، مؤنث، مفرد.</p></div>"
  82,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بِحَارُ﴾</span></span> اسم، من مادّة <root>بحر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فُجِّرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>فجر</root>، غائب، مؤنث، مفرد.</p></div>"
  82,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قُبُورُ﴾</span></span> اسم، من مادّة <root>قبر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بُعْثِرَتْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>بعثر</root>، غائب، مؤنث، مفرد.</p></div>"
  82,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلِمَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>علم</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسٌ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدَّمَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدم</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَخَّرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>أخر</root>، غائب، مؤنث، مفرد.</p></div>"
  82,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَٰٓ﴾</span></span> حرف نداء، <span class="hlt"><span class="qpc-hafs">﴿أَيُّ﴾</span></span> اسم، من مادّة <root>أيي</root>، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> حرف تنبيه.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَرَّ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>غرر</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَرِيمِ﴾</span></span> اسم، من مادّة <root>كرم</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  82,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿سَوَّىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سوي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَدَلَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عدل</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p></div>"
  82,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِىٓ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> شرطية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صُورَةٍ﴾</span></span> اسم، من مادّة <root>صور</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> حرف زائد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَكَّبَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ركب</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p></div>"
  82,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  82,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿حَٰفِظِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>حفظ</root>، مذكر، جمع، منصوب.</p></div>"
  82,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كِرَامًا﴾</span></span> اسم، من مادّة <root>كرم</root>، مذكر، جمع، نكرة، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَٰتِبِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كتب</root>، مذكر، جمع، منصوب، نعت.</p></div>"
  82,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَفْعَلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>فعل</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  82,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَبْرَارَ﴾</span></span> اسم، من مادّة <root>برر</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَعِيمٍ﴾</span></span> اسم، من مادّة <root>نعم</root>، مذكر، نكرة، مجرور.</p></div>"
  82,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فُجَّارَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>فجر</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَحِيمٍ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، نكرة، مجرور.</p></div>"
  82,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَصْلَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>صلي</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿وْنَ﴾</span></span> ضمير، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  82,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف حال، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿غَآئِبِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>غيب</root>، مذكر، جمع، مجرور.</p></div>"
  82,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْرَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دري</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمُ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  82,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْرَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دري</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمُ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  82,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمْلِكُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>ملك</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسٌ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نَفْسٍ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَيْـًٔا﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَمْرُ﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p></div>"
