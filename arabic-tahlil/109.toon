quran[6]{c,v,t}:
  109,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قول</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَٰٓ﴾</span></span> حرف نداء، <span class="hlt"><span class="qpc-hafs">﴿أَيُّ﴾</span></span> اسم، من مادّة <root>أيي</root>، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> حرف تنبيه.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَٰفِرُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كفر</root>، مذكر، جمع، مرفوع.</p></div>"
  109,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  109,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَٰبِدُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عبد</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، مرفوع.</p></div>"
  109,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَا۠﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَابِدٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عبد</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَبَد﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عبد</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُّمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  109,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَٰبِدُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عبد</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، مرفوع.</p></div>"
  109,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دِينُ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ىَ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دِينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿—﴾</span></span> ضمير، متكلم، مفرد.</p></div>"
