quran[5]{c,v,t}:
  105,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَرَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رأي</root>، مخاطب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْفَ﴾</span></span> اسم، من مادّة <root>كيف</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَعَلَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>فعل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبِ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فِيلِ﴾</span></span> اسم، من مادّة <root>فيل</root>، مذكر، مجرور.</p></div>"
  105,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَجْعَلْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>جعل</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْدَ﴾</span></span> اسم، من مادّة <root>كيد</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَضْلِيلٍ﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ضلل</root>، مذكر، نكرة، مجرور.</p></div>"
  105,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَرْسَلَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رسل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿طَيْرًا﴾</span></span> اسم، من مادّة <root>طير</root>، مذكر، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَبَابِيلَ﴾</span></span> اسم، من مادّة <root>أبل</root>، مذكر، جمع، نكرة، منصوب، نعت.</p></div>"
  105,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿تَرْمِي﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رمي</root>، غائب، مؤنث، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هِم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حِجَارَةٍ﴾</span></span> اسم، من مادّة <root>حجر</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سِجِّيلٍ﴾</span></span> اسم، من مادّة <root>سجل</root>، مذكر، نكرة، مجرور.</p></div>"
  105,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَعَلَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿عَصْفٍ﴾</span></span> اسم، من مادّة <root>عصف</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّأْكُولٍۭ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>أكل</root>، مذكر، نكرة، مجرور، نعت.</p></div>"
