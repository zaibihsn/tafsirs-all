quran[59]{c,v,t}:
  44,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿حمٓ﴾</span></span> حروف مقطعة.</p></div>"
  44,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبِ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُبِينِ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، مجرور، نعت.</p></div>"
  44,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿آ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنزَلْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نزل</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَيْلَةٍ﴾</span></span> اسم، من مادّة <root>ليل</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبَٰرَكَةٍ﴾</span></span> اسم، من مادّة <root>برك</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُنذِرِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نذر</root>، مذكر، جمع، منصوب.</p></div>"
  44,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُفْرَقُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>فرق</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلُّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْرٍ﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَكِيمٍ﴾</span></span> اسم، من مادّة <root>حكم</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  44,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْرًا﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندِ﴾</span></span> اسم، من مادّة <root>عند</root>، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَآ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُرْسِلِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رسل</root>، مذكر، جمع، منصوب.</p></div>"
  44,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿رَحْمَةً﴾</span></span> اسم، من مادّة <root>رحم</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمِيعُ﴾</span></span> اسم، من مادّة <root>سمع</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَلِيمُ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، مفرد، مرفوع، نعت.</p></div>"
  44,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَٰوَٰتِ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضِ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَيْنَ﴾</span></span> ظرف مكان، من مادّة <root>بين</root>، <span class="hlt"><span class="qpc-hafs">﴿هُمَآ﴾</span></span> ضمير، غائب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّوقِنِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>يقن</root>، مذكر، جمع، منصوب.</p></div>"
  44,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَٰهَ﴾</span></span> اسم، من مادّة <root>أله</root>، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُحْىِۦ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حيي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يُمِيتُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>موت</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَابَآئِ﴾</span></span> اسم، من مادّة <root>أبو</root>، مذكر، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمُ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَوَّلِينَ﴾</span></span> اسم، من مادّة <root>أول</root>، مذكر، جمع، مجرور، نعت.</p></div>"
  44,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَكٍّ﴾</span></span> اسم، من مادّة <root>شكك</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَلْعَبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>لعب</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  44,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱرْتَقِبْ﴾</span></span> فعل أمر من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>رقب</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَأْتِى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أتي</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَآءُ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿دُخَانٍ﴾</span></span> اسم، من مادّة <root>دخن</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبِينٍ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، نكرة، مجرور.</p></div>"
  44,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَغْشَى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>غشو</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسَ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَا﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابٌ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَلِيمٌ﴾</span></span> اسم، من مادّة <root>ألم</root>، مذكر، مفرد، نكرة، مرفوع، نعت.</p></div>"
  44,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱكْشِفْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>كشف</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنَّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَذَابَ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُؤْمِنُونَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، مذكر، جمع، مرفوع.</p></div>"
  44,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّىٰ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ذِّكْرَىٰ﴾</span></span> اسم، من مادّة <root>ذكر</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جيأ</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَسُولٌ﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبِينٌ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، نكرة، مرفوع.</p></div>"
  44,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَوَلَّ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ولي</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وْا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قَالُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُعَلَّمٌ﴾</span></span> اسم مفعول مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>علم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّجْنُونٌ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>جنن</root>، مذكر، نكرة، مرفوع.</p></div>"
  44,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَاشِفُوا۟﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كشف</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَذَابِ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَلِيلًا﴾</span></span> اسم، من مادّة <root>قلل</root>، مذكر، مفرد، نكرة، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَآئِدُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عود</root>، مذكر، جمع، مرفوع.</p></div>"
  44,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَبْطِشُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>بطش</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَطْشَةَ﴾</span></span> اسم، من مادّة <root>بطش</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كُبْرَىٰٓ﴾</span></span> اسم، من مادّة <root>كبر</root>، مؤنث، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُنتَقِمُونَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>نقم</root>، مذكر، جمع، مرفوع.</p></div>"
  44,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَتَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>فتن</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلَ﴾</span></span> ظرف زمان، من مادّة <root>قبل</root>، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْمَ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِرْعَوْنَ﴾</span></span> علم، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جيأ</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَسُولٌ﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَرِيمٌ﴾</span></span> اسم، من مادّة <root>كرم</root>، مذكر، مفرد، نكرة، مرفوع، نعت.</p></div>"
  44,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنْ﴾</span></span> حرف تفسير.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدُّ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>أدي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وٓا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىَّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿—﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِبَادَ﴾</span></span> اسم، من مادّة <root>عبد</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنِّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَسُولٌ﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمِينٌ﴾</span></span> اسم، من مادّة <root>أمن</root>، مذكر، مفرد، نكرة، مرفوع، نعت.</p></div>"
  44,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف تفسير.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علو</root>، مخاطب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنِّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ىٓ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَاتِي﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أتي</root>، متكلم، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿سُلْطَٰنٍ﴾</span></span> اسم، من مادّة <root>سلط</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبِينٍ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، نكرة، مجرور.</p></div>"
  44,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنِّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عُذْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عوذ</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿ى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَرْجُمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رجم</root>، مخاطب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿نِ﴾</span></span> ضمير، متكلم، مفرد.</p></div>"
  44,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُؤْمِنُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، مخاطب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱعْتَزِلُ﴾</span></span> فعل أمر من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>عزل</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿نِ﴾</span></span> ضمير، متكلم، مفرد.</p></div>"
  44,22,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿دَعَا﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>دعو</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰٓ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ؤُلَآءِ﴾</span></span> اسم اشارة، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْمٌ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّجْرِمُونَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>جرم</root>، مذكر، جمع، مرفوع.</p></div>"
  44,23,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أَسْرِ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>سري</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿عِبَادِ﴾</span></span> اسم، من مادّة <root>عبد</root>، مذكر، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿ى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَيْلًا﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّتَّبَعُونَ﴾</span></span> اسم مفعول مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>تبع</root>، مذكر، جمع، مرفوع.</p></div>"
  44,24,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱتْرُكِ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>ترك</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَحْرَ﴾</span></span> اسم، من مادّة <root>بحر</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَهْوًا﴾</span></span> اسم، من مادّة <root>رهو</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جُندٌ﴾</span></span> اسم، من مادّة <root>جند</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّغْرَقُونَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>غرق</root>، مذكر، جمع، مرفوع.</p></div>"
  44,25,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَمْ﴾</span></span> اسم، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَرَكُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ترك</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّٰتٍ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عُيُونٍ﴾</span></span> اسم، من مادّة <root>عين</root>، مؤنث، جمع، نكرة، مجرور.</p></div>"
  44,26,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿زُرُوعٍ﴾</span></span> اسم، من مادّة <root>زرع</root>، مذكر، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَقَامٍ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَرِيمٍ﴾</span></span> اسم، من مادّة <root>كرم</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  44,27,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿نَعْمَةٍ﴾</span></span> اسم، من مادّة <root>نعم</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَٰكِهِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>فكه</root>، مذكر، جمع، منصوب.</p></div>"
  44,28,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَوْرَثْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ورث</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْمًا﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَاخَرِينَ﴾</span></span> اسم، من مادّة <root>أخر</root>، مذكر، جمع، منصوب، نعت.</p></div>"
  44,29,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَكَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>بكي</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَآءُ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضُ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُنظَرِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نظر</root>، مذكر، جمع، منصوب.</p></div>"
  44,30,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَجَّيْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>نجو</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَنِىٓ﴾</span></span> اسم، من مادّة <root>بني</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِسْرَٰٓءِيلَ﴾</span></span> علم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَذَابِ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُهِينِ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>هون</root>، مذكر، مجرور.</p></div>"
  44,31,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِرْعَوْنَ﴾</span></span> علم، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَالِيًا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>علو</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُسْرِفِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>سرف</root>، مذكر، جمع، مجرور.</p></div>"
  44,32,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدِ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱخْتَرْ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>خير</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِلْمٍ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَٰلَمِينَ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، جمع، مجرور.</p></div>"
  44,33,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ءَاتَيْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ءَايَٰتِ﴾</span></span> اسم، من مادّة <root>أيي</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلَٰٓؤٌا۟﴾</span></span> اسم، من مادّة <root>بلو</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبِينٌ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، نكرة، مرفوع.</p></div>"
  44,34,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰٓ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ؤُلَآءِ﴾</span></span> اسم اشارة، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿يَقُولُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  44,35,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هِىَ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَوْتَتُ﴾</span></span> اسم، من مادّة <root>موت</root>، مؤنث، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُولَىٰ﴾</span></span> اسم، من مادّة <root>أول</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَحْنُ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مُنشَرِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نشر</root>، مذكر، جمع، مجرور.</p></div>"
  44,36,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أْتُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>أتي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ـَٔابَآئِ﴾</span></span> اسم، من مادّة <root>أبو</root>، مذكر، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَآ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَٰدِقِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صدق</root>، مذكر، جمع، منصوب.</p></div>"
  44,37,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَيْرٌ﴾</span></span> اسم، من مادّة <root>خير</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْمُ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُبَّعٍ﴾</span></span> علم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلِ﴾</span></span> اسم، من مادّة <root>قبل</root>، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَهْلَكْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>هلك</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُجْرِمِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>جرم</root>، مذكر، جمع، منصوب.</p></div>"
  44,38,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَٰوَٰتِ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضَ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَيْنَ﴾</span></span> ظرف مكان، من مادّة <root>بين</root>، <span class="hlt"><span class="qpc-hafs">﴿هُمَا﴾</span></span> ضمير، غائب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَٰعِبِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>لعب</root>، مذكر، جمع، منصوب.</p></div>"
  44,39,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُمَآ﴾</span></span> ضمير، غائب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَقِّ﴾</span></span> اسم، من مادّة <root>حقق</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَٰكِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَكْثَرَ﴾</span></span> اسم، من مادّة <root>كثر</root>، مذكر، مفرد، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  44,40,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فَصْلِ﴾</span></span> اسم، من مادّة <root>فصل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِيقَٰتُ﴾</span></span> اسم، من مادّة <root>وقت</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَجْمَعِينَ﴾</span></span> اسم، من مادّة <root>جمع</root>، مذكر، جمع، منصوب.</p></div>"
  44,41,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُغْنِى﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>غني</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَوْلًى﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّوْلًى﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَيْـًٔا﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُنصَرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>نصر</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  44,42,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّحِمَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رحم</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَزِيزُ﴾</span></span> اسم، من مادّة <root>عزز</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رَّحِيمُ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، مرفوع، نعت.</p></div>"
  44,43,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَجَرَتَ﴾</span></span> اسم، من مادّة <root>شجر</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿زَّقُّومِ﴾</span></span> علم، من مادّة <root>زقم</root>، مذكر.</p></div>"
  44,44,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿طَعَامُ﴾</span></span> اسم، من مادّة <root>طعم</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَثِيمِ﴾</span></span> اسم، من مادّة <root>أثم</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  44,45,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُهْلِ﴾</span></span> اسم، من مادّة <root>مهل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَغْلِى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>غلي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بُطُونِ﴾</span></span> اسم، من مادّة <root>بطن</root>، مذكر، جمع، مجرور.</p></div>"
  44,46,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿غَلْىِ﴾</span></span> اسم، من مادّة <root>غلي</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَمِيمِ﴾</span></span> اسم، من مادّة <root>حمم</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  44,47,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿خُذُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>أخذ</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱعْتِلُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>عتل</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَوَآءِ﴾</span></span> اسم، من مادّة <root>سوي</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَحِيمِ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، مجرور.</p></div>"
  44,48,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صُبُّ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>صبب</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَوْقَ﴾</span></span> اسم، من مادّة <root>فوق</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَأْسِ﴾</span></span> اسم، من مادّة <root>رأس</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابِ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَمِيمِ﴾</span></span> اسم، من مادّة <root>حمم</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  44,49,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ذُقْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>ذوق</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَزِيزُ﴾</span></span> اسم، من مادّة <root>عزز</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَرِيمُ﴾</span></span> اسم، من مادّة <root>كرم</root>، مذكر، مفرد، مرفوع، نعت.</p></div>"
  44,50,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَا﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمْتَرُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>مري</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  44,51,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُتَّقِينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وقي</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَقَامٍ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمِينٍ﴾</span></span> اسم، من مادّة <root>أمن</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  44,52,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّٰتٍ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عُيُونٍ﴾</span></span> اسم، من مادّة <root>عين</root>، مؤنث، جمع، نكرة، مجرور.</p></div>"
  44,53,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَلْبَسُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>لبس</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُندُسٍ﴾</span></span> اسم، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِسْتَبْرَقٍ﴾</span></span> اسم، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّتَقَٰبِلِينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>قبل</root>، مذكر، جمع، منصوب.</p></div>"
  44,54,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿زَوَّجْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>زوج</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حُورٍ﴾</span></span> اسم، من مادّة <root>حور</root>، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِينٍ﴾</span></span> اسم، من مادّة <root>عين</root>، جمع، نكرة، مجرور.</p></div>"
  44,55,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَدْعُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>دعو</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُلِّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَٰكِهَةٍ﴾</span></span> اسم، من مادّة <root>فكه</root>، مؤنث، مفرد، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَامِنِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>أمن</root>، مذكر، جمع، منصوب.</p></div>"
  44,56,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَذُوقُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>ذوق</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَوْتَ﴾</span></span> اسم، من مادّة <root>موت</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَوْتَةَ﴾</span></span> اسم، من مادّة <root>موت</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُولَىٰ﴾</span></span> اسم، من مادّة <root>أول</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَقَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وقي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابَ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَحِيمِ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، مجرور.</p></div>"
  44,57,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَضْلًا﴾</span></span> اسم، من مادّة <root>فضل</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فَوْزُ﴾</span></span> اسم، من مادّة <root>فوز</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَظِيمُ﴾</span></span> اسم، من مادّة <root>عظم</root>، مذكر، مفرد، مرفوع، نعت.</p></div>"
  44,58,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف كاف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسَّرْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>يسر</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لِسَانِ﴾</span></span> اسم، من مادّة <root>لسن</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَعَلَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَذَكَّرُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ذكر</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  44,59,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱرْتَقِبْ﴾</span></span> فعل أمر من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>رقب</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّرْتَقِبُونَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>رقب</root>، مذكر، جمع، مرفوع.</p></div>"
