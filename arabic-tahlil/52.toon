quran[49]{c,v,t}:
  52,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿طُّورِ﴾</span></span> اسم، من مادّة <root>طور</root>، مذكر، مجرور.</p></div>"
  52,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبٍ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّسْطُورٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>سطر</root>، مذكر، نكرة، مجرور.</p></div>"
  52,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَقٍّ﴾</span></span> اسم، من مادّة <root>رقق</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّنشُورٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>نشر</root>، مذكر، نكرة، مجرور.</p></div>"
  52,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَيْتِ﴾</span></span> اسم، من مادّة <root>بيت</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَعْمُورِ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>عمر</root>، مذكر، مجرور.</p></div>"
  52,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّقْفِ﴾</span></span> اسم، من مادّة <root>سقف</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَرْفُوعِ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>رفع</root>، مذكر، مجرور.</p></div>"
  52,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَحْرِ﴾</span></span> اسم، من مادّة <root>بحر</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَسْجُورِ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>سجر</root>، مذكر، مجرور.</p></div>"
  52,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابَ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿وَٰقِعٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>وقع</root>، مذكر، نكرة، مرفوع.</p></div>"
  52,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دَافِعٍ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>دفع</root>، مذكر، نكرة، مجرور.</p></div>"
  52,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمُورُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>مور</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَآءُ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَوْرًا﴾</span></span> اسم، من مادّة <root>مور</root>، مذكر، نكرة، منصوب.</p></div>"
  52,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَسِيرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>سير</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِبَالُ﴾</span></span> اسم، من مادّة <root>جبل</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَيْرًا﴾</span></span> اسم، من مادّة <root>سير</root>، مذكر، نكرة، منصوب.</p></div>"
  52,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿وَيْلٌ﴾</span></span> اسم، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُكَذِّبِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مذكر، جمع، مجرور.</p></div>"
  52,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَوْضٍ﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>خوض</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَلْعَبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>لعب</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُدَعُّ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>دعع</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَارِ﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَهَنَّمَ﴾</span></span> علم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دَعًّا﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>دعع</root>، مذكر، نكرة، منصوب.</p></div>"
  52,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذِهِ﴾</span></span> اسم اشارة، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّارُ﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّتِى﴾</span></span> اسم موصول، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  52,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿سِحْرٌ﴾</span></span> اسم، من مادّة <root>سحر</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَآ﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُبْصِرُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بصر</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  52,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱصْلَ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>صلي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وْ﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱصْبِرُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>صبر</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وٓا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَصْبِرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>صبر</root>، مخاطب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَوَآءٌ﴾</span></span> اسم، من مادّة <root>سوي</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف كاف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُجْزَ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>جزي</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿وْنَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْمَلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عمل</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  52,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُتَّقِينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وقي</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّٰتٍ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿نَعِيمٍ﴾</span></span> اسم، من مادّة <root>نعم</root>، مذكر، نكرة، مجرور.</p></div>"
  52,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَٰكِهِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>فكه</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَاتَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَقَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وقي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابَ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَحِيمِ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، مجرور.</p></div>"
  52,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>أكل</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱشْرَبُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>شرب</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَنِيٓـًٔۢا﴾</span></span> اسم، من مادّة <root>هنأ</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْمَلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عمل</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  52,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مُتَّكِـِٔينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وكأ</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُرُرٍ﴾</span></span> اسم، من مادّة <root>سرر</root>، مذكر، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّصْفُوفَةٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>صفف</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿زَوَّجْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>زوج</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حُورٍ﴾</span></span> اسم، من مادّة <root>حور</root>، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِينٍ﴾</span></span> اسم، من مادّة <root>عين</root>، جمع، نكرة، مجرور.</p></div>"
  52,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَامَنُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱتَّبَعَتْ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>تبع</root>، غائب، مؤنث، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذُرِّيَّتُ﴾</span></span> اسم، من مادّة <root>ذرر</root>، مؤنث، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿إِيمَٰنٍ﴾</span></span> مصدر مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَلْحَقْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>لحق</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذُرِّيَّتَ﴾</span></span> اسم، من مادّة <root>ذرر</root>، مؤنث، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَلَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ألت</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَمَلِ﴾</span></span> اسم، من مادّة <root>عمل</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَىْءٍ﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلُّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱمْرِئٍۭ﴾</span></span> اسم، من مادّة <root>مرأ</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَسَبَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كسب</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَهِينٌ﴾</span></span> اسم، من مادّة <root>رهن</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
  52,22,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَمْدَدْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>مدد</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿فَٰكِهَةٍ﴾</span></span> اسم، من مادّة <root>فكه</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَحْمٍ﴾</span></span> اسم، من مادّة <root>لحم</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشْتَهُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>شهو</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,23,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَنَٰزَعُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>نزع</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَأْسًا﴾</span></span> اسم، من مادّة <root>كأس</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَغْوٌ﴾</span></span> اسم، من مادّة <root>لغو</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَأْثِيمٌ﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>أثم</root>، مذكر، نكرة، مرفوع.</p></div>"
  52,24,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يَطُوفُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>طوف</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غِلْمَانٌ﴾</span></span> اسم، من مادّة <root>غلم</root>، مذكر، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَأَنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لُؤْلُؤٌ﴾</span></span> اسم، من مادّة <root>لؤلؤ</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّكْنُونٌ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>كنن</root>، مذكر، نكرة، مرفوع.</p></div>"
  52,25,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَقْبَلَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>قبل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْضُ﴾</span></span> اسم، من مادّة <root>بعض</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْضٍ﴾</span></span> اسم، من مادّة <root>بعض</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَسَآءَلُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>سأل</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,26,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قَالُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وٓا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلُ﴾</span></span> ظرف زمان، من مادّة <root>قبل</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِىٓ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَهْلِ﴾</span></span> اسم، من مادّة <root>أهل</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُشْفِقِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>شفق</root>، مذكر، جمع، منصوب.</p></div>"
  52,27,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَنَّ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>منن</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَقَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وقي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابَ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمُومِ﴾</span></span> اسم، من مادّة <root>سمم</root>، مذكر، مجرور.</p></div>"
  52,28,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلُ﴾</span></span> اسم، من مادّة <root>قبل</root>، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَدْعُو﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>دعو</root>، متكلم، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَرُّ﴾</span></span> اسم، من مادّة <root>برر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رَّحِيمُ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، مرفوع، نعت.</p></div>"
  52,29,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ذَكِّرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ذكر</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نِعْمَتِ﴾</span></span> اسم، من مادّة <root>نعم</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَاهِنٍ﴾</span></span> اسم، من مادّة <root>كهن</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَجْنُونٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>جنن</root>، مذكر، نكرة، مجرور.</p></div>"
  52,30,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَقُولُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَاعِرٌ﴾</span></span> اسم، من مادّة <root>شعر</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَّتَرَبَّصُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ربص</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَيْبَ﴾</span></span> اسم، من مادّة <root>ريب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَنُونِ﴾</span></span> اسم، من مادّة <root>منن</root>، مذكر، مجرور.</p></div>"
  52,31,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قول</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَرَبَّصُ﴾</span></span> فعل أمر من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ربص</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِنِّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَعَ﴾</span></span> ظرف مكان، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُتَرَبِّصِينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ربص</root>، مذكر، جمع، مجرور.</p></div>"
  52,32,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَأْمُرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أمر</root>، غائب، مؤنث، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَحْلَٰمُ﴾</span></span> اسم، من مادّة <root>حلم</root>، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَآ﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْمٌ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿طَاغُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>طغي</root>، مذكر، جمع، مرفوع، نعت.</p></div>"
  52,33,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَقُولُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَقَوَّلَ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>قول</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَل﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُؤْمِنُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,34,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span> لام الامر، <span class="hlt"><span class="qpc-hafs">﴿يَأْتُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أتي</root>، غائب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حَدِيثٍ﴾</span></span> اسم، من مادّة <root>حدث</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّثْلِ﴾</span></span> اسم، من مادّة <root>مثل</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَٰدِقِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صدق</root>، مذكر، جمع، منصوب.</p></div>"
  52,35,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خُلِقُ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>خلق</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَيْرِ﴾</span></span> اسم، من مادّة <root>غير</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَىْءٍ﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿خَٰلِقُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>خلق</root>، مذكر، جمع، مرفوع.</p></div>"
  52,36,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَٰوَٰتِ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضَ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَل﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُوقِنُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>يقن</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,37,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَزَآئِنُ﴾</span></span> اسم، من مادّة <root>خزن</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُصَۣيْطِرُونَ﴾</span></span> اسم فاعل مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سطر</root>، مذكر، جمع، مرفوع.</p></div>"
  52,38,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُلَّمٌ﴾</span></span> اسم، من مادّة <root>سلم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسْتَمِعُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>سمع</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span> لام الامر، <span class="hlt"><span class="qpc-hafs">﴿يَأْتِ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُسْتَمِعُ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>سمع</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿سُلْطَٰنٍ﴾</span></span> اسم، من مادّة <root>سلط</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبِينٍ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، نكرة، مجرور.</p></div>"
  52,39,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَنَٰتُ﴾</span></span> اسم، من مادّة <root>بني</root>، مؤنث، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف حال، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمُ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَنُونَ﴾</span></span> اسم، من مادّة <root>بني</root>، مذكر، جمع، مرفوع.</p></div>"
  52,40,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَسْـَٔلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>سأل</root>، مخاطب، مذكر، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَجْرًا﴾</span></span> اسم، من مادّة <root>أجر</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّغْرَمٍ﴾</span></span> اسم، من مادّة <root>غرم</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّثْقَلُونَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ثقل</root>، مذكر، جمع، مرفوع.</p></div>"
  52,41,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>، <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿غَيْبُ﴾</span></span> اسم، من مادّة <root>غيب</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَكْتُبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كتب</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,42,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُرِيدُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رود</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْدًا﴾</span></span> اسم، من مادّة <root>كيد</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَفَرُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كفر</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَكِيدُونَ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>كيد</root>، مذكر، جمع، مرفوع.</p></div>"
  52,43,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَٰهٌ﴾</span></span> اسم، من مادّة <root>أله</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَيْرُ﴾</span></span> اسم، من مادّة <root>غير</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُبْحَٰنَ﴾</span></span> اسم، من مادّة <root>سبح</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُشْرِكُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>شرك</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,44,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَرَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿وْا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كِسْفًا﴾</span></span> اسم، من مادّة <root>كسف</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَآءِ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَاقِطًا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>سقط</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَقُولُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَحَابٌ﴾</span></span> اسم، من مادّة <root>سحب</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّرْكُومٌ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>ركم</root>، مذكر، نكرة، مرفوع.</p></div>"
  52,45,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ذَرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>وذر</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَتَّىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُلَٰقُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فاعَلَ)، من مادّة <root>لقي</root>، غائب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُصْعَقُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>صعق</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,46,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُغْنِى﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>غني</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْدُ﴾</span></span> اسم، من مادّة <root>كيد</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَيْـًٔا﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُنصَرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>نصر</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,47,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ظَلَمُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ظلم</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابًا﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دُونَ﴾</span></span> ظرف مكان، من مادّة <root>دون</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَٰكِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَكْثَرَ﴾</span></span> اسم، من مادّة <root>كثر</root>، مذكر، مفرد، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  52,48,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱصْبِرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>صبر</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حُكْمِ﴾</span></span> اسم، من مادّة <root>حكم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَعْيُنِ﴾</span></span> اسم، من مادّة <root>عين</root>، مؤنث، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿سَبِّحْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سبح</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حَمْدِ﴾</span></span> اسم، من مادّة <root>حمد</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حِينَ﴾</span></span> اسم، من مادّة <root>حين</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَقُومُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قوم</root>، مخاطب، مذكر، مفرد، مرفوع.</p></div>"
  52,49,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يْلِ﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿سَبِّحْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سبح</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِدْبَٰرَ﴾</span></span> مصدر مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دبر</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نُّجُومِ﴾</span></span> اسم، من مادّة <root>نجم</root>، مذكر، جمع، مجرور.</p></div>"
