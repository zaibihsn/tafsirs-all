quran[11]{c,v,t}:
  100,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَٰدِيَٰتِ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عدو</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ضَبْحًا﴾</span></span> اسم، من مادّة <root>ضبح</root>، مذكر، نكرة، منصوب.</p></div>"
  100,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُورِيَٰتِ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>وري</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدْحًا﴾</span></span> اسم، من مادّة <root>قدح</root>، مذكر، نكرة، منصوب.</p></div>"
  100,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُغِيرَٰتِ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>غير</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صُبْحًا﴾</span></span> ظرف زمان، من مادّة <root>صبح</root>، مذكر.</p></div>"
  100,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَثَرْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ثور</root>، غائب، مؤنث، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَقْعًا﴾</span></span> اسم، من مادّة <root>نقع</root>، مذكر، نكرة، منصوب.</p></div>"
  100,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَسَطْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وسط</root>، غائب، مؤنث، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَمْعًا﴾</span></span> اسم، من مادّة <root>جمع</root>، مذكر، نكرة، منصوب.</p></div>"
  100,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنَ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿كَنُودٌ﴾</span></span> اسم، من مادّة <root>كند</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
  100,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿شَهِيدٌ﴾</span></span> اسم، من مادّة <root>شهد</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
  100,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حُبِّ﴾</span></span> اسم، من مادّة <root>حبب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿خَيْرِ﴾</span></span> اسم، من مادّة <root>خير</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿شَدِيدٌ﴾</span></span> اسم، من مادّة <root>شدد</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
  100,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بُعْثِرَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>بعثر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قُبُورِ﴾</span></span> اسم، من مادّة <root>قبر</root>، مذكر، جمع، مجرور.</p></div>"
  100,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿حُصِّلَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>حصل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صُّدُورِ﴾</span></span> اسم، من مادّة <root>صدر</root>، مذكر، جمع، مجرور.</p></div>"
  100,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿خَبِيرٌۢ﴾</span></span> اسم، من مادّة <root>خبر</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
