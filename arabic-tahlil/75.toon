quran[40]{c,v,t}:
  75,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُقْسِمُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>قسم</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿يَوْمِ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قِيَٰمَةِ﴾</span></span> اسم، من مادّة <root>قوم</root>، مؤنث، مجرور.</p></div>"
  75,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُقْسِمُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>قسم</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّفْسِ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿لَّوَّامَةِ﴾</span></span> اسم، من مادّة <root>لوم</root>، مؤنث، مجرور، نعت.</p></div>"
  75,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿يَحْسَبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>حسب</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> حرف مصدري، <span class="hlt"><span class="qpc-hafs">﴿لَّن﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَّجْمَعَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>جمع</root>، متكلم، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِظَامَ﴾</span></span> اسم، من مادّة <root>عظم</root>، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلَىٰ﴾</span></span> حرف جواب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَٰدِرِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>قدر</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰٓ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُّسَوِّىَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سوي</root>، متكلم، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَنَانَ﴾</span></span> اسم، من مادّة <root>بنن</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُرِيدُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رود</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿يَفْجُرَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>فجر</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمَامَ﴾</span></span> ظرف زمان، من مادّة <root>أمم</root>، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسْـَٔلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>سأل</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَيَّانَ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمُ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قِيَٰمَةِ﴾</span></span> اسم، من مادّة <root>قوم</root>، مؤنث، مجرور.</p></div>"
  75,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَرِقَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>برق</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَصَرُ﴾</span></span> اسم، من مادّة <root>بصر</root>، مذكر، مرفوع.</p></div>"
  75,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿خَسَفَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خسف</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قَمَرُ﴾</span></span> اسم، من مادّة <root>قمر</root>، مذكر، مرفوع.</p></div>"
  75,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جُمِعَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>جمع</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿شَّمْسُ﴾</span></span> اسم، من مادّة <root>شمس</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قَمَرُ﴾</span></span> اسم، من مادّة <root>قمر</root>، مذكر، مرفوع.</p></div>"
  75,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَقُولُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَيْنَ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَفَرُّ﴾</span></span> اسم، من مادّة <root>فرر</root>، مذكر، مرفوع.</p></div>"
  75,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَزَرَ﴾</span></span> اسم، من مادّة <root>وزر</root>، مذكر، منصوب.</p></div>"
  75,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُسْتَقَرُّ﴾</span></span> اسم مفعول مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>قرر</root>، مذكر، مرفوع.</p></div>"
  75,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يُنَبَّؤُا۟﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>نبأ</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَۭ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍۭ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدَّمَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدم</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَخَّرَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>أخر</root>، غائب، مذكر، مفرد.</p></div>"
  75,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلِ﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسِ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَصِيرَةٌ﴾</span></span> اسم، من مادّة <root>بصر</root>، مؤنث، نكرة، مرفوع.</p></div>"
  75,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف حال، <span class="hlt"><span class="qpc-hafs">﴿لَوْ﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَلْقَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>لقي</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَعَاذِيرَ﴾</span></span> اسم، من مادّة <root>عذر</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُحَرِّكْ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>حرك</root>، مخاطب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِسَانَ﴾</span></span> اسم، من مادّة <root>لسن</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿تَعْجَلَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عجل</root>، مخاطب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَمْعَ﴾</span></span> اسم، من مادّة <root>جمع</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قُرْءَانَ﴾</span></span> اسم، من مادّة <root>قرأ</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَرَأْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>قرأ</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ٱتَّبِعْ﴾</span></span> فعل أمر من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>تبع</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُرْءَانَ﴾</span></span> اسم، من مادّة <root>قرأ</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَيَانَ﴾</span></span> اسم، من مادّة <root>بين</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  75,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُحِبُّ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حبب</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَاجِلَةَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عجل</root>، مؤنث، منصوب.</p></div>"
  75,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَذَرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وذر</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ءَاخِرَةَ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، منصوب.</p></div>"
  75,22,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وُجُوهٌ﴾</span></span> اسم، من مادّة <root>وجه</root>، مذكر، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَّاضِرَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>نضر</root>، مؤنث، نكرة، مرفوع.</p></div>"
  75,23,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَاظِرَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>نظر</root>، مؤنث، نكرة، مرفوع.</p></div>"
  75,24,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وُجُوهٌ﴾</span></span> اسم، من مادّة <root>وجه</root>، مذكر، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَۭ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍۭ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَاسِرَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>بسر</root>، مؤنث، نكرة، مرفوع.</p></div>"
  75,25,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿تَظُنُّ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>ظنن</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُفْعَلَ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>فعل</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَاقِرَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>فقر</root>، مؤنث، نكرة، مرفوع.</p></div>"
  75,26,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّآ﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلَغَتِ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>بلغ</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿تَّرَاقِىَ﴾</span></span> مصدر مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>ترق</root>، مذكر، منصوب.</p></div>"
  75,27,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قِيلَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>قول</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَاقٍ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>رقي</root>، مذكر، نكرة، مرفوع.</p></div>"
  75,28,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ظَنَّ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ظنن</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فِرَاقُ﴾</span></span> مصدر مزيد الرباعي باب (فاعَلَ)، من مادّة <root>فرق</root>، مذكر، مرفوع.</p></div>"
  75,29,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْتَفَّتِ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>لفف</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّاقُ﴾</span></span> اسم، من مادّة <root>سوق</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّاقِ﴾</span></span> اسم، من مادّة <root>سوق</root>، مذكر، مجرور.</p></div>"
  75,30,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَسَاقُ﴾</span></span> اسم، من مادّة <root>سوق</root>، مذكر، مرفوع.</p></div>"
  75,31,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَدَّقَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>صدق</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَلَّىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>صلو</root>، غائب، مذكر، مفرد.</p></div>"
  75,32,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لَٰكِن﴾</span></span> حرف استدراك.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَذَّبَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ولي</root>، غائب، مذكر، مفرد.</p></div>"
  75,33,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَهَبَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ذهب</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰٓ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَهْلِ﴾</span></span> اسم، من مادّة <root>أهل</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَمَطَّىٰٓ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>مطو</root>، غائب، مذكر، مفرد، مرفوع.</p></div>"
  75,34,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْلَىٰ﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَوْلَىٰ﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، مفرد، مرفوع.</p></div>"
  75,35,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْلَىٰ﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَوْلَىٰٓ﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، مفرد، مرفوع.</p></div>"
  75,36,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿يَحْسَبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>حسب</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُتْرَكَ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>ترك</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُدًى﴾</span></span> اسم، من مادّة <root>سدي</root>، مذكر، نكرة، منصوب.</p></div>"
  75,37,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَكُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُطْفَةً﴾</span></span> اسم، من مادّة <root>نطف</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّنِىٍّ﴾</span></span> اسم، من مادّة <root>مني</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُمْنَىٰ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>مني</root>، غائب، مذكر، مفرد، مرفوع.</p></div>"
  75,38,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَقَةً﴾</span></span> اسم، من مادّة <root>علق</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿خَلَقَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿سَوَّىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سوي</root>، غائب، مذكر، مفرد.</p></div>"
  75,39,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَعَلَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿زَّوْجَيْنِ﴾</span></span> اسم، من مادّة <root>زوج</root>، مذكر، مثنى، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ذَّكَرَ﴾</span></span> اسم، من مادّة <root>ذكر</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُنثَىٰٓ﴾</span></span> اسم، من مادّة <root>أنث</root>، مؤنث، منصوب.</p></div>"
  75,40,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَيْسَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ليس</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿قَٰدِرٍ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>قدر</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰٓ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُحْۦِىَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حيي</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَوْتَىٰ﴾</span></span> اسم، من مادّة <root>موت</root>، جمع، منصوب.</p></div>"
