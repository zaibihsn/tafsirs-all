quran[29]{c,v,t}:
  81,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿شَّمْسُ﴾</span></span> اسم، من مادّة <root>شمس</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُوِّرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>كور</root>، غائب، مؤنث، مفرد.</p></div>"
  81,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نُّجُومُ﴾</span></span> اسم، من مادّة <root>نجم</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱنكَدَرَتْ﴾</span></span> فعل ماض مزيد الخماسي باب (انْفَعَلَ)، من مادّة <root>كدر</root>، غائب، مؤنث، مفرد.</p></div>"
  81,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِبَالُ﴾</span></span> اسم، من مادّة <root>جبل</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُيِّرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>سير</root>، غائب، مؤنث، مفرد.</p></div>"
  81,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عِشَارُ﴾</span></span> اسم، من مادّة <root>عشر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عُطِّلَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>عطل</root>، غائب، مؤنث، مفرد.</p></div>"
  81,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وُحُوشُ﴾</span></span> اسم، من مادّة <root>وحش</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حُشِرَتْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>حشر</root>، غائب، مؤنث، مفرد.</p></div>"
  81,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بِحَارُ﴾</span></span> اسم، من مادّة <root>بحر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُجِّرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>سجر</root>، غائب، مؤنث، مفرد.</p></div>"
  81,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نُّفُوسُ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿زُوِّجَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>زوج</root>، غائب، مؤنث، مفرد.</p></div>"
  81,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَوْءُۥدَةُ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>وأد</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُئِلَتْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>سأل</root>، غائب، مؤنث، مفرد.</p></div>"
  81,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> استفهامية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَنۢبٍ﴾</span></span> اسم، من مادّة <root>ذنب</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُتِلَتْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>قتل</root>، غائب، مؤنث، مفرد.</p></div>"
  81,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صُّحُفُ﴾</span></span> اسم، من مادّة <root>صحف</root>، مؤنث، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُشِرَتْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>نشر</root>، غائب، مؤنث، مفرد.</p></div>"
  81,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَآءُ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُشِطَتْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>كشط</root>، غائب، مؤنث، مفرد.</p></div>"
  81,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَحِيمُ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُعِّرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>سعر</root>، غائب، مؤنث، مفرد.</p></div>"
  81,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَنَّةُ﴾</span></span> علم، من مادّة <root>جنن</root>، مؤنث.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُزْلِفَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>زلف</root>، غائب، مؤنث، مفرد.</p></div>"
  81,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلِمَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>علم</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسٌ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَحْضَرَتْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حضر</root>، غائب، مؤنث، مفرد.</p></div>"
  81,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُقْسِمُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>قسم</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿خُنَّسِ﴾</span></span> اسم، من مادّة <root>خنس</root>، مذكر، جمع، مجرور.</p></div>"
  81,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَوَارِ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>جري</root>، مؤنث، جمع، مجرور، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كُنَّسِ﴾</span></span> اسم، من مادّة <root>كنس</root>، مذكر، جمع، مجرور، نعت.</p></div>"
  81,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يْلِ﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَسْعَسَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عسعس</root>، غائب، مذكر، مفرد.</p></div>"
  81,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صُّبْحِ﴾</span></span> اسم، من مادّة <root>صبح</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَنَفَّسَ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>نفس</root>، غائب، مذكر، مفرد.</p></div>"
  81,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَوْلُ﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>قول</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَسُولٍ﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَرِيمٍ﴾</span></span> اسم، من مادّة <root>كرم</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  81,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِى﴾</span></span> اسم، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُوَّةٍ﴾</span></span> اسم، من مادّة <root>قوي</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِى﴾</span></span> اسم، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَرْشِ﴾</span></span> اسم، من مادّة <root>عرش</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَكِينٍ﴾</span></span> اسم، من مادّة <root>مكن</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  81,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّطَاعٍ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>طوع</root>، مذكر، نكرة، مجرور، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ثَمَّ﴾</span></span> ظرف مكان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمِينٍ﴾</span></span> اسم، من مادّة <root>أمن</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  81,22,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَاحِبُ﴾</span></span> اسم، من مادّة <root>صحب</root>، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَجْنُونٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>جنن</root>، مذكر، نكرة، مجرور.</p></div>"
  81,23,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَءَا﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُفُقِ﴾</span></span> اسم، من مادّة <root>أفق</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُبِينِ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، مجرور، نعت.</p></div>"
  81,24,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿غَيْبِ﴾</span></span> اسم، من مادّة <root>غيب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ضَنِينٍ﴾</span></span> اسم، من مادّة <root>ضنن</root>، مذكر، مفرد، نكرة، مجرور.</p></div>"
  81,25,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿قَوْلِ﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>قول</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَيْطَٰنٍ﴾</span></span> اسم، من مادّة <root>شطن</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّجِيمٍ﴾</span></span> اسم، من مادّة <root>رجم</root>، مذكر، مفرد، نكرة، مجرور، نعت.</p></div>"
  81,26,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أَيْنَ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَذْهَبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>ذهب</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  81,27,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِكْرٌ﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>ذكر</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَٰلَمِينَ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، جمع، مجرور.</p></div>"
  81,28,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسْتَقِيمَ﴾</span></span> فعل مضارع من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>قوم</root>، غائب، مذكر، مفرد، منصوب.</p></div>"
  81,29,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَشَآءُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّآ﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشَآءَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَٰلَمِينَ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، جمع، مجرور.</p></div>"
