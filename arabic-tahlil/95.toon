quran[8]{c,v,t}:
  95,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿تِّينِ﴾</span></span> اسم، من مادّة <root>تين</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿زَّيْتُونِ﴾</span></span> اسم، من مادّة <root>زيت</root>، مذكر، مجرور.</p></div>"
  95,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿طُورِ﴾</span></span> اسم، من مادّة <root>طور</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سِينِينَ﴾</span></span> علم.</p></div>"
  95,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَا﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَلَدِ﴾</span></span> اسم، من مادّة <root>بلد</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَمِينِ﴾</span></span> اسم، من مادّة <root>أمن</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  95,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنَ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِىٓ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَحْسَنِ﴾</span></span> اسم، من مادّة <root>حسن</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَقْوِيمٍ﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قوم</root>، مذكر، نكرة، مجرور.</p></div>"
  95,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَدَدْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ردد</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَسْفَلَ﴾</span></span> ظرف مكان، من مادّة <root>سفل</root>، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَٰفِلِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>سفل</root>، مذكر، جمع، مجرور.</p></div>"
  95,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة استثناء.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَامَنُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَمِلُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عمل</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صَّٰلِحَٰتِ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صلح</root>، مؤنث، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَجْرٌ﴾</span></span> اسم، من مادّة <root>أجر</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَيْرُ﴾</span></span> اسم، من مادّة <root>غير</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَمْنُونٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>منن</root>، مذكر، نكرة، مجرور.</p></div>"
  95,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُكَذِّبُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، غائب، مذكر، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْدُ﴾</span></span> ظرف زمان، من مادّة <root>بعد</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  95,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَيْسَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ليس</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَحْكَمِ﴾</span></span> اسم، من مادّة <root>حكم</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَٰكِمِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>حكم</root>، مذكر، جمع، مجرور.</p></div>"
