quran[56]{c,v,t}:
  74,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَٰٓ﴾</span></span> حرف نداء، <span class="hlt"><span class="qpc-hafs">﴿أَيُّ﴾</span></span> اسم، من مادّة <root>أيي</root>، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> حرف تنبيه.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُدَّثِّرُ﴾</span></span> اسم فاعل مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>دثر</root>، مذكر، مرفوع.</p></div>"
  74,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قُمْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قوم</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَنذِرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نذر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كَبِّرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كبر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ثِيَابَ﴾</span></span> اسم، من مادّة <root>ثوب</root>، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿طَهِّرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>طهر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رُّجْزَ﴾</span></span> اسم، من مادّة <root>رجز</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱهْجُرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>هجر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمْنُن﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>منن</root>، مخاطب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَسْتَكْثِرُ﴾</span></span> فعل مضارع من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>كثر</root>، مخاطب، مذكر، مفرد، مرفوع.</p></div>"
  74,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱصْبِرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>صبر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُقِرَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>نقر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاقُورِ﴾</span></span> اسم، من مادّة <root>نقر</root>، مذكر، مجرور.</p></div>"
  74,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمٌ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَسِيرٌ﴾</span></span> اسم، من مادّة <root>عسر</root>، مذكر، مفرد، نكرة، مرفوع، نعت.</p></div>"
  74,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَٰفِرِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كفر</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَيْرُ﴾</span></span> اسم، من مادّة <root>غير</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسِيرٍ﴾</span></span> اسم، من مادّة <root>يسر</root>، مذكر، مفرد، نكرة، مجرور.</p></div>"
  74,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>وذر</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿نِى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَحِيدًا﴾</span></span> اسم، من مادّة <root>وحد</root>، مذكر، مفرد، نكرة، منصوب.</p></div>"
  74,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَعَلْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالًا﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّمْدُودًا﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>مدد</root>، مذكر، نكرة، منصوب، نعت.</p></div>"
  74,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿بَنِينَ﴾</span></span> اسم، من مادّة <root>بني</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شُهُودًا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>شهد</root>، مذكر، جمع، نكرة، منصوب، نعت.</p></div>"
  74,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَهَّد﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>مهد</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُّ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمْهِيدًا﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>مهد</root>، مذكر، نكرة، منصوب.</p></div>"
  74,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَطْمَعُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>طمع</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنْ﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَزِيدَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>زيد</root>، متكلم، مفرد، منصوب.</p></div>"
  74,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّآ﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ءَايَٰتِ﴾</span></span> اسم، من مادّة <root>أيي</root>، مؤنث، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنِيدًا﴾</span></span> اسم، من مادّة <root>عند</root>، مذكر، مفرد، نكرة، منصوب.</p></div>"
  74,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿أُرْهِقُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رهق</root>، متكلم، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَعُودًا﴾</span></span> اسم، من مادّة <root>صعد</root>، مذكر، نكرة، منصوب.</p></div>"
  74,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَكَّرَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>فكر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قَدَّرَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدر</root>، غائب، مذكر، مفرد.</p></div>"
  74,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف سببية، <span class="hlt"><span class="qpc-hafs">﴿قُتِلَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>قتل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْفَ﴾</span></span> اسم، من مادّة <root>كيف</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدَّرَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدر</root>، غائب، مذكر، مفرد.</p></div>"
  74,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُتِلَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>قتل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْفَ﴾</span></span> اسم، من مادّة <root>كيف</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدَّرَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدر</root>، غائب، مذكر، مفرد.</p></div>"
  74,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَظَرَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>نظر</root>، غائب، مذكر، مفرد.</p></div>"
  74,22,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَبَسَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عبس</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿بَسَرَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>بسر</root>، غائب، مذكر، مفرد.</p></div>"
  74,23,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْبَرَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دبر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱسْتَكْبَرَ﴾</span></span> فعل ماض مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>كبر</root>، غائب، مذكر، مفرد.</p></div>"
  74,24,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قَالَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَآ﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سِحْرٌ﴾</span></span> اسم، من مادّة <root>سحر</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُؤْثَرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>أثر</root>، غائب، مذكر، مفرد، مرفوع.</p></div>"
  74,25,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَآ﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْلُ﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>قول</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَشَرِ﴾</span></span> اسم، من مادّة <root>بشر</root>، مذكر، مجرور.</p></div>"
  74,26,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿أُصْلِي﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>صلي</root>، متكلم، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَقَرَ﴾</span></span> علم.</p></div>"
  74,27,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْرَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دري</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَقَرُ﴾</span></span> علم.</p></div>"
  74,28,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُبْقِى﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بقي</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَذَرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وذر</root>، غائب، مؤنث، مفرد، مرفوع.</p></div>"
  74,29,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَوَّاحَةٌ﴾</span></span> اسم، من مادّة <root>لوح</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَشَرِ﴾</span></span> اسم، من مادّة <root>بشر</root>، مذكر، مجرور.</p></div>"
  74,30,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تِسْعَةَ﴾</span></span> اسم، من مادّة <root>تسع</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَشَرَ﴾</span></span> اسم، من مادّة <root>عشر</root>، مذكر، منصوب.</p></div>"
  74,31,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَعَلْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَآ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبَ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّارِ﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَلَٰٓئِكَةً﴾</span></span> اسم، من مادّة <root>ملك</root>، مذكر، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَعَلْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِدَّتَ﴾</span></span> اسم، من مادّة <root>عدد</root>، مؤنث، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِتْنَةً﴾</span></span> اسم، من مادّة <root>فتن</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَفَرُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كفر</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿يَسْتَيْقِنَ﴾</span></span> فعل مضارع من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>يقن</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُوتُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>أتي</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبَ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يَزْدَادَ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>زيد</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَامَنُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وٓا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِيمَٰنًا﴾</span></span> مصدر مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَرْتَابَ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>ريب</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُوتُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>أتي</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبَ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُؤْمِنُونَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿يَقُولَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُلُوبِ﴾</span></span> اسم، من مادّة <root>قلب</root>، مؤنث، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّرَضٌ﴾</span></span> اسم، من مادّة <root>مرض</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَٰفِرُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كفر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَاذَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَرَادَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رود</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَا﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَثَلًا﴾</span></span> اسم، من مادّة <root>مثل</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُضِلُّ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ضلل</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشَآءُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يَهْدِى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>هدي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشَآءُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جُنُودَ﴾</span></span> اسم، من مادّة <root>جند</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هِىَ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِكْرَىٰ﴾</span></span> اسم، من مادّة <root>ذكر</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَشَرِ﴾</span></span> اسم، من مادّة <root>بشر</root>، مذكر، مجرور.</p></div>"
  74,32,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قَمَرِ﴾</span></span> اسم، من مادّة <root>قمر</root>، مذكر، مجرور.</p></div>"
  74,33,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يْلِ﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذْ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْبَرَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دبر</root>، غائب، مذكر، مفرد.</p></div>"
  74,34,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صُّبْحِ﴾</span></span> اسم، من مادّة <root>صبح</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَآ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَسْفَرَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>سفر</root>، غائب، مذكر، مفرد.</p></div>"
  74,35,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿إِحْدَى﴾</span></span> اسم، من مادّة <root>أحد</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كُبَرِ﴾</span></span> اسم، من مادّة <root>كبر</root>، مذكر، جمع، مجرور.</p></div>"
  74,36,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿نَذِيرًا﴾</span></span> اسم، من مادّة <root>نذر</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَشَرِ﴾</span></span> اسم، من مادّة <root>بشر</root>، مذكر، مجرور.</p></div>"
  74,37,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَقَدَّمَ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>قدم</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَأَخَّرَ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>أخر</root>، غائب، مذكر، مفرد، منصوب.</p></div>"
  74,38,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلُّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسٍۭ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَسَبَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كسب</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَهِينَةٌ﴾</span></span> اسم، من مادّة <root>رهن</root>، مؤنث، نكرة، مرفوع.</p></div>"
  74,39,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّآ﴾</span></span> أداة استثناء.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبَ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يَمِينِ﴾</span></span> اسم، من مادّة <root>يمن</root>، مذكر، مجرور.</p></div>"
  74,40,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّٰتٍ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَسَآءَلُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>سأل</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  74,41,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنِ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُجْرِمِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>جرم</root>، مذكر، جمع، مجرور.</p></div>"
  74,42,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَلَكَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>سلك</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَقَرَ﴾</span></span> علم.</p></div>"
  74,43,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قَالُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَكُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُصَلِّينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>صلو</root>، مذكر، جمع، مجرور.</p></div>"
  74,44,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَكُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُطْعِمُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>طعم</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مِسْكِينَ﴾</span></span> اسم، من مادّة <root>سكن</root>، مذكر، مفرد، منصوب.</p></div>"
  74,45,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَخُوضُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>خوض</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَعَ﴾</span></span> ظرف مكان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿خَآئِضِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>خوض</root>، مذكر، جمع، مجرور.</p></div>"
  74,46,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُكَذِّبُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿يَوْمِ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  74,47,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿حَتَّىٰٓ﴾</span></span> حرف ابتداء.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَتَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يَقِينُ﴾</span></span> اسم، من مادّة <root>يقن</root>، مذكر، مفرد، مرفوع.</p></div>"
  74,48,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَنفَعُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>نفع</root>، غائب، مؤنث، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَفَٰعَةُ﴾</span></span> اسم، من مادّة <root>شفع</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿شَّٰفِعِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>شفع</root>، مذكر، جمع، مجرور.</p></div>"
  74,49,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنِ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿تَّذْكِرَةِ﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ذكر</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُعْرِضِينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>عرض</root>، مذكر، جمع، منصوب.</p></div>"
  74,50,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَأَنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حُمُرٌ﴾</span></span> اسم، من مادّة <root>حمر</root>، مذكر، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّسْتَنفِرَةٌ﴾</span></span> اسم فاعل مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>نفر</root>، مؤنث، نكرة، مرفوع، نعت.</p></div>"
  74,51,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَرَّتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>فرر</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَسْوَرَةٍۭ﴾</span></span> اسم، من مادّة <root>قسر</root>، مؤنث، نكرة، مجرور.</p></div>"
  74,52,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُرِيدُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رود</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلُّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱمْرِئٍ﴾</span></span> اسم، من مادّة <root>مرأ</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُؤْتَىٰ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صُحُفًا﴾</span></span> اسم، من مادّة <root>صحف</root>، مؤنث، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّنَشَّرَةً﴾</span></span> اسم مفعول مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>نشر</root>، مؤنث، نكرة، منصوب، نعت.</p></div>"
  74,53,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَل﴾</span></span> حرف اضراب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَخَافُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>خوف</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ءَاخِرَةَ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، منصوب.</p></div>"
  74,54,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّآ﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَذْكِرَةٌ﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ذكر</root>، مؤنث، نكرة، مرفوع.</p></div>"
  74,55,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَكَرَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ذكر</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  74,56,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَذْكُرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>ذكر</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّآ﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشَآءَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَهْلُ﴾</span></span> اسم، من مادّة <root>أهل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿تَّقْوَىٰ﴾</span></span> اسم، من مادّة <root>وقي</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَهْلُ﴾</span></span> اسم، من مادّة <root>أهل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَغْفِرَةِ﴾</span></span> اسم، من مادّة <root>غفر</root>، مؤنث، مجرور.</p></div>"
