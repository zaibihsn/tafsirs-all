quran[6]{c,v,t}:
  114,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قول</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعُوذُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عوذ</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسِ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، مجرور.</p></div>"
  114,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَلِكِ﴾</span></span> اسم، من مادّة <root>ملك</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسِ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، مجرور.</p></div>"
  114,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَٰهِ﴾</span></span> اسم، من مادّة <root>أله</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسِ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، مجرور.</p></div>"
  114,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَرِّ﴾</span></span> اسم، من مادّة <root>شرر</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وَسْوَاسِ﴾</span></span> اسم، من مادّة <root>وسوس</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿خَنَّاسِ﴾</span></span> اسم، من مادّة <root>خنس</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  114,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُوَسْوِسُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وسوس</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صُدُورِ﴾</span></span> اسم، من مادّة <root>صدر</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسِ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، مجرور.</p></div>"
  114,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِنَّةِ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسِ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، مجرور.</p></div>"
