quran[7]{c,v,t}:
  1,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿سْمِ﴾</span></span> اسم، من مادّة <root>سمو</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رَّحْمَٰنِ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، مجرور، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رَّحِيمِ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  1,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَمْدُ﴾</span></span> اسم، من مادّة <root>حمد</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَٰلَمِينَ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، جمع، مجرور.</p></div>"
  1,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رَّحْمَٰنِ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، مجرور، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رَّحِيمِ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، مجرور، نعت.</p></div>"
  1,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَٰلِكِ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>ملك</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمِ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  1,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِيَّاكَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِيَّاكَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَسْتَعِينُ﴾</span></span> فعل مضارع من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>عون</root>، متكلم، جمع، مرفوع.</p></div>"
  1,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱهْدِ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>هدي</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صِّرَٰطَ﴾</span></span> اسم، من مادّة <root>صرط</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُسْتَقِيمَ﴾</span></span> اسم فاعل مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>قوم</root>، مذكر، منصوب، نعت.</p></div>"
  1,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿صِرَٰطَ﴾</span></span> اسم، من مادّة <root>صرط</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنْعَمْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نعم</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَيْرِ﴾</span></span> اسم، من مادّة <root>غير</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَغْضُوبِ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>غضب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ضَّآلِّينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>ضلل</root>، مذكر، جمع، مجرور.</p></div>"
