quran[5]{c,v,t}:
  111,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿تَبَّتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>تبب</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَدَآ﴾</span></span> اسم، من مادّة <root>يدي</root>، مؤنث، مثنى، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَبِى﴾</span></span> اسم، من مادّة <root>أبو</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَهَبٍ﴾</span></span> اسم، من مادّة <root>لهب</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَبَّ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>تبب</root>، غائب، مذكر، مفرد.</p></div>"
  111,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَغْنَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>غني</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالُ﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَسَبَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كسب</root>، غائب، مذكر، مفرد.</p></div>"
  111,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿يَصْلَىٰ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>صلي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَارًا﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَاتَ﴾</span></span> اسم، مؤنث، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَهَبٍ﴾</span></span> اسم، من مادّة <root>لهب</root>، مذكر، نكرة، مجرور.</p></div>"
  111,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱمْرَأَتُ﴾</span></span> اسم، من مادّة <root>مرأ</root>، مؤنث، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَمَّالَةَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>حمل</root>، مؤنث، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَطَبِ﴾</span></span> اسم، من مادّة <root>حطب</root>، مذكر، مجرور.</p></div>"
  111,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جِيدِ﴾</span></span> اسم، من مادّة <root>جيد</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَبْلٌ﴾</span></span> اسم، من مادّة <root>حبل</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّسَدٍۭ﴾</span></span> اسم، من مادّة <root>مسد</root>، مذكر، نكرة، مجرور.</p></div>"
