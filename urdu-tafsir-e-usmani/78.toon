tafsir[40]{c,v,t}:
  78,1,"کیا بات پوچھتے ہیں لوگ آپس میں",footnotes:88547:1
  78,2,"پوچھتے ہیں اُس بڑی خبر سے"
  78,2,""
  78,3,"جس میں وہ مختلف ہیں",footnotes:88548:1
  78,4,"ہرگز نہیں اب جان لیں گے"
  78,4,""
  78,5,"پھر بھی ہر گز نہیں اب جان لیں گے",footnotes:88549:1
  78,6,"کیا ہم نے نہیں بنایا زمین کو بچھونا",footnotes:88550:1
  78,7,"اور پہاڑوں کو میخیں",footnotes:88551:1
  78,8,"اور تم کو بنایا ہم نے جوڑے جوڑے",footnotes:88552:1
  78,9,"اور بنایا نیند کو تمہاری تکان دفع کرنیکے لئے",footnotes:88553:1
  78,10,"اور بنایا رات کو اوڑھنا",footnotes:88554:1
  78,11,"اور بنایا دن کمائی کرنے کو",footnotes:88555:1
  78,12,"اور چنی ہم نے تم سےاوپر سات چنائی مضبوط",footnotes:88556:1
  78,13,"اور بنایا ایک چراغ چمکتا ہوا",footnotes:88557:1
  78,14,"اور اتارا نچڑنے والی بدلیوں سے پانی کا ریلا",footnotes:88558:1
  78,15,"تاکہ ہم نکالیں اس سے اناج اور سبزہ"
  78,6,""
  78,7,""
  78,8,""
  78,9,""
  78,10,""
  78,11,""
  78,12,""
  78,13,""
  78,14,""
  78,15,""
  78,16,"اور باغ پتوں میں لپٹے ہوئے",footnotes:88559:1
  78,17,"بیشک دن فیصلے کا ہے ایک وقت ٹھہرا ہوا",footnotes:88560:1
  78,18,"جس دن پھونکی جائے صور پھر تم چلے آؤ جٹ کے جٹ",footnotes:88561:1
  78,19,"اور کھولا جائے آسمان تو ہو جائیں اس میں دروازے",footnotes:88562:1
  78,20,"اور چلائے جائیں گے پہاڑ تو ہو جائیں گے چمکتا ریتا",footnotes:88563:1
  78,21,"بیشک دوزخ ہے تاک میں"
  78,17,""
  78,18,""
  78,19,""
  78,20,""
  78,21,""
  78,22,"شریروں کا ٹھکانا",footnotes:88564:1
  78,23,"رہا کریں اُس میں قرنوں",footnotes:88565:1
  78,24,"نہ چکھیں وہاں کچھ مزا ٹھنڈک کا اور نہ پینا ملے کچھ"
  78,23,""
  78,24,""
  78,25,"مگر گرم پانی اور بہتی پیپ",footnotes:88566:1
  78,26,"بدلا ہے پورا"
  78,26,""
  78,27,"اُنکو توقع نہ تھی حساب کی"
  78,28,"اور جھٹلاتے تھے ہماری آیتوں کو مکرا کر",footnotes:88567:1
  78,29,"اور ہر چیز ہم نے گن رکھی ہے لکھ کر",footnotes:88568:1
  78,30,"اب چکھو  کہ ہم نہ بڑھاتے جائیں گے تم پر مگر عذاب",footnotes:88569:1
  78,31,"بیشک ڈر والوں کو اُنکی مراد ملنی ہے"
  78,29,""
  78,30,""
  78,31,""
  78,32,"باغ ہیں اور انگور"
