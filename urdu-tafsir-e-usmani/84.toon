tafsir[25]{c,v,t}:
  84,1,"جب  آسمان پھٹ جائے"
  84,2,"اور سن لے حکم اپنے رب کا وہ آسمان اسی لائق ہے",footnotes:88696:1
  84,3,"اور جب زمین پھیلا دی جائے",footnotes:88697:1
  84,4,"اور نکال ڈالے جو کچھ اُس میں ہے اور خالی ہو جائے",footnotes:88698:1
  84,5,"اور سن لے حکم اپنے رب کا اور وہ زمین اسی لائق ہے",footnotes:88699:1
  84,6,"اے آدمی تجھ کو تکلیف اٹھانی ہے اپنے رب تک پہنچنے میں سہہ سہہ کر اُس سے ملنا ہے",footnotes:88700:1
  84,7,"سو جس کو ملا اعمالنامہ اس کا داہنے ہاتھ میں"
  84,3,""
  84,4,""
  84,5,""
  84,6,""
  84,7,""
  84,8,"تو اُس سے حساب لیں گے آسان حساب",footnotes:88701:1
  84,9,"اور پھر کر آئے گا اپنے لوگوں کے پاس خوش ہو کر",footnotes:88702:1
  84,10,"اور جس کو ملا اس کا اعمالنامہ پیٹھ کے پیچھے سے",footnotes:88703:1
  84,11,"سو وہ پکارے گا موت موت",footnotes:88704:1
  84,12,"اور پڑے گا  آگ میں"
  84,9,""
  84,10,""
  84,11,""
  84,12,""
  84,13,"وہ رہا تھا اپنے گھر میں بے غم",footnotes:88705:1
  84,14,"اُس نے خیال کیا تھا کہ پھر کر نہ جائے گا",footnotes:88706:1
  84,15,"کیوں نہیں اُس کا رب اُسکو دیکھتا تھا",footnotes:88707:1
  84,16,"سو قسم کھاتا ہوں شام کی سرخی کی"
  84,14,""
  84,15,""
  84,16,""
  84,17,"اور رات کی اور جو چیزیں اُس میں سمٹ آتی ہیں",footnotes:88708:1
  84,18,"اور چاند کی جب پورا بھر جائے",footnotes:88709:1
  84,19,"کہ تم کو  چڑھنا ہے سیڑھی پر سیڑھی",footnotes:88710:1
  84,20,"پھر کیا ہوا ہے اُنکو جو یقین نہیں لاتے",footnotes:88711:1
  84,21,"اور جب پڑھیے انکے پا س قرآن مجید وہ سجدہ نہیں کرتے",footnotes:88712:1
  84,22,"اوپر سے اور یہ کہ منکر جھٹلاتے ہیں"
  84,18,""
