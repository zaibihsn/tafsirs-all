tafsir[54]{c,v,t}:
  34,1,"سب خوبی اللہ کی ہے جس کا ہے جو کچھ کہ ہے آسمان اور زمین میں اور اسی کی تعریف ہے آخرت میں اور  وہی ہے حکمتوں والا سب کچھ جاننے والا",footnotes:86427:1
  34,2,"جانتا ہے جو کچھ کہ اندر گھستا ہے زمین کے اور جو کچھ کہ نکتا ہے اس سے اور جو  اترتا ہے آسمان سے اور جو چڑھتا ہے اس میں اور وہی ہے رحم  والا بخشنے والا",footnotes:86428:12
  34,3,"اور کہنے لگے منکر نہ آئے گی ہم پر قیامت تو کہہ کیوں نہیں قسم ہے میرے رب کی البتہ آئے گی تم  پر اس عالم الغیب کی غائب نہیں ہو سکتا اس سے کچھ ذرہ بھر آسمانوں میں اور نہ زمین میں اور کوئی چیز نہیں اس سےچھوٹی اور نہ اس سے بڑی جو نہیں ہے کھلی کتاب میں",footnotes:86430:123
  34,4,"تاکہ بدلا دے انکو جو یقین لائے اور کئے بھلے کام وہ لوگ جو ہیں ان کے لئے ہے معافی اور عزت کی روزی"
  34,2,""
  34,3,""
  34,4,""
  34,5,"اور جو لوگ دوڑے ہماری آیتوں کے ہرانے کو ان کو بلا کا عذاب ہے دردناک",footnotes:86433:1
  34,6,"اور دیکھ لیں جن کو ملی ہے سمجھ کہ جو تجھ پر  اترا  تیرے رب سے وہی ٹھیک ہے اور سجھاتا ہے راہ  اس زبردست خوبیوں والے کی",footnotes:86434:1
  34,7,"اور کہنے لگے منکر ہم بتلائیں تمکو  ایک مرد کہ تم کو خبر دیتا ہے جب تم پھٹ کر ہو جاؤ ٹکڑے ٹکڑے تم کو پھر نئے سرے سے بننا ہے"
  34,6,""
  34,7,""
  34,8,"کیا بنا لایا ہے اللہ پر جھوٹ یا ا سکو سودا ہے کچھ بھی نہیں پر جو یقین نہیں رکھتے آخرت کا آفت میں ہیں اور دور جا پڑے غلطی میں",footnotes:86435:12
  34,9,"کیا دیکھتے نہیں جو کچھ ان کے آگے ہے اور پیچھے ہے آسمان اور زمین سے اگر ہم چاہیں دھنسا دیں ان کو زمین میں یا گرا دیں ان پر ٹکڑا  آسمان سے تحقیق اس میں نشانی ہے ہر بندے رجوع کرنے  والے کے  واسطے",footnotes:86437:12
  34,10,"اور ہم نے دی ہے داؤد کو  اپنی طرف سے بڑائی اے پہاڑو خوش آوازی سے پڑھو  اسکے ساتھ اور اڑتے جانوروں کو اور نرم کر دیا ہم نے اس کے آگے لوہا",footnotes:86439:12
  34,11,"کہ بنا زرہیں کشادہ اور اندازے سے جوڑ کڑیاں اور کرو تم سب کام بھلا میں جو کچھ  تم کرتے ہو دیکھتا ہوں",footnotes:86441:12
  34,12,"اور مسخر کردیا سلیمان کے آگے ہوا کو صبح کی منزل اسکی ایک مہینہ اور شام کی منزل ایک مہینہ کی اور بہا د یا ہم نے اسکے واسطے چشمہ پگھلے ہوئے تانبے کا اور جنوں میں کتنے لوگ تھے جو محنت کرتے اس کے سامنے اسکے رب کے حکم سے اور جوکوئی پھرے ان میں سے ہمارے حکم سے چکھائیں ہم اسکو  آگ کا عذاب",footnotes:86443:12
  34,13,"بناتے اس کے واسطے جو کچھ چاہتا قلعے اور  تصویریں اور لگن جیسے تالاب اور دیگیں چولہوں پر جمی ہوئی کام کرو  ا ے داؤد کے گھر  والو احسان مان کر اور تھوڑے ہیں میرے بندوں میں احسان ماننے والے",footnotes:86445:12
  34,14,"پھر جب مقرر کیا ہم نےاس پر موت کو نہ جتلایا ان کو اس کا مرنا مگر کیڑے نے گھن کے کھاتا رہا اس کا عصا پھر جب وہ گر پڑا معلوم کیا جنوں نے کہ اگر خبر رکھتے ہوتے غیب کی نہ رہتے ذلت کی تکلیف میں",footnotes:86447:1
  34,15,"تحقیق قوم سبا کو تھی ان کی بستی میں نشانی دو باغ داہنے اور بائیں کھاؤ روزی اپنے رب کی اور اس کا شکر کرو شہر ہے پاکیزہ اور  رب ہے گناہ بخشنے والا",footnotes:86448:123
  34,16,"سو دھیان میں نہ لائے پھر چھوڑ دیا ہم نے ان پر ایک نالا زور کا اور دیے ہم نے انکو  بدلے میں ان دو باغوں کے دو اور باغ جن میں کچھ میوہ کسیلا تھا اور جھاؤ اور کچھ بیر تھوڑے سے",footnotes:86451:1
  34,17,"یہ بدلا دیا ہم نے ان کو اس پر کہ ناشکری کی اور ہم یہ بدلا اسی کو دیتے ہیں جو ناشکر  ہو",footnotes:86452:1
  34,18,"اور رکھی تھیں ہم نے ان میں اور ان بستیوں  میں جہاں ہم نے برکت رکھی ہے ایسی بستیاں جو  راہ پر نظر آتی تھیں اور منزلیں مقرر کر دیں ہم نے ان میں آنے جانے کی پھرو  ان میں راتوں کو  اور  دنوں کو امن سے",footnotes:86453:1
  34,19,"پھر کہنے لگے اے رب دراز کر دے ہمارے سفروں کو اور آپ اپنا برا کیا پھر کر ڈالا ہم نے انکو کہانیاں اور کر ڈالا چیر کر ٹکڑے ٹکڑے اس میں پتے کی باتیں ہیں ہر صبر کرنے والے شکر گذار کو",footnotes:86454:123
  34,20,"اور سچ کر دکھلائی ان پر ابلیس نے  اپنی اٹکل  پھر اسی کی راہ چلے مگر تھوڑے سے ایمان دار",footnotes:86457:1
  34,21,"اور اس کا ان پر کچھ زور نہ تھا مگر اتنے واسطے کہ معلوم کر لیں ہم  اسکو جو  یقین لاتا ہے آخرت پر جدا کر کے اس سے جو رہتا ہے آخرت کی طرف سے دھوکہ میں اور تیرا رب ہر چیز پر نگہبان ہے",footnotes:86458:1
  34,22,"تو کہہ پکارو ان کو جن کو گمان  کرتے ہو سوائے اللہ کے وہ مالک نہیں ایک ذرہ بھر کے آسمانوں میں اور نہ زمین میں اور نہ ان کا ان دونوں میں کچھ ساجھا اور نہ ان میں کوئی اس کا مددگار",footnotes:86459:1
  34,23,"اور کام نہیں آتی سفارش اس کے  پاس مگر اس کو کہ جس کے واسطے حکم کر دے یہاں تک کہ جب گھبراہٹ دور ہو جائے ان کے دل سےکہیں کیا فرمایا تمہارے رب نے وہ کہیں فرمایا جو  واجبی ہے اور وہی ہے سب سے اوپر بڑا",footnotes:86460:12
  34,24,"تو کہہ کون روزی دیتا ہے تم کو آسمان سے اور زمیں سے بتلا دے کہ اللہ اور یا ہم یا تم بیشک ہدایت پر ہیں یا پڑے ہیں گمراہی میں صریح",footnotes:86462:12
  34,25,"تو کہ تم سے پوچھ نہ ہوگی اسکی جو ہم نے گناہ کیا اور ہم سے پوچھ نہ ہوگی اسکی جو تم کرتے ہو"
