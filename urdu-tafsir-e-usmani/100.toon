tafsir[11]{c,v,t}:
  100,1,"قسم ہے دوڑنے والے گھوڑوں کی ہانپ کر"
  100,2,"پھر آگ سلگانے والے جھاڑ کر",footnotes:88901:1
  100,3,"پھر غارت کر ڈالنے والے صبح کو",footnotes:88902:1
  100,4,"پھر اٹھانے والے اُس میں گرد",footnotes:88903:1
  100,5,"پھر گھس جانے والے اُس وقت فوج میں",footnotes:88904:1
  100,6,"بیشک آدمی اپنے رب کا ناشکر ہے",footnotes:88905:1
  100,7,"اور وہ آدمی اس کام کو سامنے دیکھتا ہے",footnotes:88906:1
  100,8,"اور آدمی محبت پر مال کی بہت پکا ہے",footnotes:88907:1
  100,9,"کیا نہیں جانتا وہ وقت کہ کریدا جائے جو کچھ قبروں میں ہے"
  100,3,""
  100,4,""
  100,5,""
  100,6,""
  100,7,""
  100,8,""
  100,9,""
  100,10,""
  100,11,""
