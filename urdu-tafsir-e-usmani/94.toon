tafsir[8]{c,v,t}:
  94,1,"کیا ہم نے نہیں کھول دیا تیرا سینہ",footnotes:88850:1
  94,2,"اور اتار رکھا ہم نے تجھ پر سے بوجھ تیرا"
  94,2,""
  94,3,"جس نے جھکا دی تھی پیٹھ تیری",footnotes:88851:1
  94,4,"اور بلند کیا ہم نے مذکور تیرا",footnotes:88852:1
  94,5,"سو البتہ مشکل کے ساتھ آسانی ہے"
  94,4,""
  94,5,""
  94,6,"البتہ مشکل کے ساتھ آسانی ہے",footnotes:88853:1
  94,7,"پھر جب تو فارغ ہو تو محنت کر"
  94,7,""
  94,8,""
