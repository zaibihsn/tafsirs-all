tafsir[7]{c,v,t}:
  1,1,"شروع اللہ کے نام سے جو بڑا مہربان نہایت رحم والا ہے"
  1,2,"سب تعریفیں اللہ کے لئے ہیں جو پالنے والا سارے جہان کا",footnotes:81607:12
  1,3,"بےحد مہربان نہایت رحم والا"
  1,3,""
  1,4,"مالک روز جزا کا",footnotes:81609:1
  1,5,"تیری ہی ہم بندگی کرتے ہیں اور تجھی سے مدد چاہتے ہیں",footnotes:81610:1
  1,6,"بتلا ہم کو راہ سیدھی"
  1,5,""
  1,6,""
  1,7,""
