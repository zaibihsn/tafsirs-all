tafsir[26]{c,v,t}:
  88,1,"کچھ پہنچی تجھ کو بات اُس چھپا لینے والی کی",footnotes:88758:1
  88,2,"کتنے منہ اُس دن ذلیل ہونے والے ہیں"
  88,2,""
  88,3,"محنت کرنے والے تھکے ہوئے",footnotes:88759:1
  88,4,"گریں گے دہکتی ہوئی آگ میں"
  88,4,""
  88,5,"پانی ملے گا ایک چشمے کھولتے ہوئے کا",footnotes:88760:1
  88,6,"نہیں اُنکے پاس کھانا مگر جھاڑ کانٹوں والا",footnotes:88761:1
  88,7,"نہ موٹا کرے اور نہ کام آئے بھوک میں",footnotes:88762:1
  88,8,"کتنے منہ اُس دن تروتازہ ہیں"
  88,6,""
  88,7,""
  88,8,""
  88,9,"اپنی کمائی سے راضی",footnotes:88763:1
  88,10,"اونچے باغ میں"
  88,10,""
  88,11,"نہیں سنتے اُس میں بکواس",footnotes:88764:1
  88,12,"اُس میں ایک چشمہ ہے بہتا",footnotes:88765:1
  88,13,"اُس میں تخت ہیں اونچے بچھے ہوئے"
  88,12,""
  88,13,""
  88,14,"اور آبخورے سامنے چنے ہوئے",footnotes:88766:1
  88,15,"اور غالیچے برابر بچھے ہوئے",footnotes:88767:1
  88,16,"اور مخمل کے نہالچے جگہ جگہ پھیلے ہوئے",footnotes:88768:1
  88,17,"بھلا کیا نظر نہیں کرتے اونٹوں پر کہ کیسے بنائے ہیں",footnotes:88769:1
  88,18,"اور آسمان پر کہ کیسا اُس کو بلند کیا ہے",footnotes:88770:1
  88,19,"اور پہاڑوں پر کہ کیسے کھڑے کر دیے ہیں",footnotes:88771:1
  88,20,"اور زمین پر کہ کیسی صاف بچھائی ہے",footnotes:88772:1
  88,21,"سو تو سمجھائے جا تیرا کام تو یہی سمجھانا ہے"
  88,15,""
  88,16,""
  88,17,""
  88,18,""
  88,19,""
  88,20,""
  88,21,""
  88,22,"تو نہیں اُن پر داروغہ",footnotes:88773:1
  88,23,"مگر جس نے منہ موڑا اور منکر ہو گیا"
  88,23,""
  88,24,"تو عذاب کرے گا اُس پر اللہ وہ بڑا عذاب"
  88,25,"بیشک ہمارے پاس ہے اُنکو پھر آنا"
  88,26,""
