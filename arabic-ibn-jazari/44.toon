quran[59]{c,v,t}:
  44,1,"<div class=ar lang=ar><p>(p-٣٧١)سُورَةُ الدُخانِ</p><p>تَقَدَّمَ السَكْتُ والإمالَةُ في بابِهِما.</p><p>(وَفِيها مِنَ الإضافَةِ ياءانِ) <span class="qpc-hafs">﴿إنِّي آتِيكُمْ﴾</span> [الدخان: ١٩] فَتَحَها المَدَنِيّانِ، وابْنُ كَثِيرٍ وأبُو عَمْرٍو <span class="qpc-hafs">﴿تُؤْمِنُوا لِي﴾</span> [الدخان: ٢١] فَتَحَها ورْشٌ.</p><p>(وَمِنَ الزَوائِدِ ثِنْتانِ) <span class="qpc-hafs">﴿تَرْجُمُونِ﴾</span> [الدخان: ٢٠]، <span class="qpc-hafs">﴿فاعْتَزِلُونِ﴾</span> [الدخان: ٢١]، أثْبَتَهُما وصْلًا ورْشٌ، وفي الحالَيْنِ يَعْقُوبُ.</p></div>"
  44,2,""
  44,3,""
  44,4,""
  44,5,""
  44,6,""
  44,7,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿رَبِّ السَماواتِ﴾</span> فَقَرَأ الكُوفِيُّونَ بِخَفْضِ الباءِ، وقَرَأ الباقُونَ بِرَفْعِها.</p></div>"
  44,8,""
  44,9,""
  44,10,""
  44,11,""
  44,12,""
  44,13,""
  44,14,""
  44,15,""
  44,16,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿نَبْطِشُ﴾</span> لِأبِي جَعْفَرٍ في الأعْرافِ.</p></div>"
  44,17,""
  44,18,""
  44,19,""
  44,20,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿عُذْتُ﴾</span> في حُرُوفٍ قَرُبَتْ مَخارِجُها.</p></div>"
  44,21,""
  44,22,""
  44,23,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فَأسْرِ﴾</span> في هُودٍ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فَكِهِينَ﴾</span> [المطففين: ٣١] في يس لِأبِي جَعْفَرٍ.</p></div>"
  44,24,""
  44,25,""
  44,26,"<div class=ar lang=ar><p>[انظر الآية ٥١]</p></div>"
