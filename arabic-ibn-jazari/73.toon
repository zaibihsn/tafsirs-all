quran[20]{c,v,t}:
  73,1,""
  73,2,""
  73,3,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أوِ انْقُصْ﴾</span> في البَقَرَةِ.</p></div>"
  73,4,""
  73,5,""
  73,6,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿ناشِئَةَ﴾</span> في الهَمْزِ المُفْرَدِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أشَدُّ وطْئًا﴾</span> (p-٣٩٣)فَقَرَأ أبُو عَمْرٍو، وابْنُ عامِرٍ بِكَسْرِ الواوِ، وفَتْحِ الطاءِ وألِفٍ مَمْدُودَةٍ بَعْدَها. وقَرَأ الباقُونَ بِفَتْحِ الواوِ، وإسْكانِ الطاءِ مِن غَيْرِ مَدٍّ، وإذا وقَفَ حَمْزَةُ نَقَلَ حَرَكَةَ الهَمْزَةِ إلى الطاءِ فَحَرَّكَها عَلى أصْلِهِ.</p></div>"
  73,7,""
  73,8,""
  73,9,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿رَبُّ المَشْرِقِ﴾</span> فَقَرَأ ابْنُ عامِرٍ ويَعْقُوبُ، وحَمْزَةُ، والكِسائِيُّ، وخَلَفٌ، وأبُو بَكْرٍ بِخَفْضِ الباءِ، وقَرَأ الباقُونَ بِالرَفْعِ.</p></div>"
  73,10,""
  73,11,""
  73,12,""
  73,13,""
  73,14,""
  73,15,""
  73,16,""
  73,17,"<div class=ar lang=ar><p>واتَّفَقُوا عَلى فَتْحِ النُونِ مِن <span class="qpc-hafs">﴿فَكَيْفَ تَتَّقُونَ﴾</span> إلّا ما انْفَرَدَ بِهِ أبُو أحْمَدَ عَبْدُ السَلامِ بْنُ الحُسَيْنِ البَصْرِيُّ الجُوخانِيُّ عَنِ الأشْنانِيِّ عَنْ عُبَيْدِ بْنِ الصَبّاحِ عَنْ حَفْصٍ بِكَسْرِ النُونِ، فَخالَفَ سائِرَ الرُواةِ عَنْ أبِي الحَسَنِ البَصْرِيِّ، وعَنِ الأشْنائِيِّ عَنْ عُبَيْدٍ، وعَنْ حَفْصٍ، وعَنْ عاصِمٍ</p><p>وَلَكِنَّها رِوايَةُ أبِي بَكْرٍ مُحَمَّدِ بْنِ يَزِيدَ بْنِ هارُونَ القَطّانِ عَنْ عَمْرِو بْنِ الصَبّاحِ عَنْ حَفْصٍ - واللَهُ أعْلَمُ -.</p></div>"
  73,18,""
  73,19,""
  73,20,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿ثُلُثَيِ اللَيْلِ﴾</span> لِهِشامٍ في البَقَرَةِ عِنْدَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧].</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَنِصْفَهُ وثُلُثَهُ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ، والكُوفِيُّونَ بِنَصْبِ الفاءِ والثاءِ وضَمِّ الهاءَيْنِ، وقَرَأ الباقُونَ بِخَفْضِ الفاءِ والثاءِ وكَسْرِ الهاءَيْنِ.</p></div>"
