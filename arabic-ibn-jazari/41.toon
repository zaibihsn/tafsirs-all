quran[54]{c,v,t}:
  41,1,"<div class=ar lang=ar><p>سُورَةُ فُصِّلَتْ</p><p>تَقَدَّمَ <span class="qpc-hafs">﴿حم﴾</span> في الإمالَةِ والسَكْتِ.</p><p>(وَفِيها مِنَ الإضافَةِ ياءانِ) <span class="qpc-hafs">﴿شُرَكائِي قالُوا﴾</span> [فصلت: ٤٧] فَتَحَها ابْنُ كَثِيرٍ <span class="qpc-hafs">﴿إلى رَبِّي إنَّ﴾</span> [فصلت: ٥٠] فَتَحَها أبُو جَعْفَرٍ وأبُو عَمْرٍو ووَرْشٌ، واخْتُلِفَ عَنْ قالُونَ كَما تَقَدَّمَ.</p></div>"
  41,2,""
  41,3,""
  41,4,""
  41,5,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿آذانِنا﴾</span> لِلدُّورِيِّ عَنِ الكِسائِيِّ في الإمالَةِ.</p></div>"
  41,6,""
  41,7,""
  41,8,""
  41,9,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أئِنَّكم لَتَكْفُرُونَ﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  41,10,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿سَواءً لِلسّائِلِينَ﴾</span> فَقَرَأ أبُو جَعْفَرٍ سَواءٌ بِالرَفْعِ، وقَرَأ يَعْقُوبُ بِالخَفْضِ، وقَرَأ الباقُونَ بِالنَصْبِ.</p></div>"
  41,11,""
  41,12,""
  41,13,""
  41,14,""
  41,15,""
  41,16,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿نَحِساتٍ﴾</span> فَقَرَأ ابْنُ جَعْفَرٍ وابْنُ عامِرٍ، والكُوفِيُّونَ بِكَسْرِ الحاءِ، وقَرَأ الباقُونَ بِإسْكانِها. وما حَكاهُ الحافِظُ أبُو عَمْرٍو عَنْ أبِي طاهِرِ بْنِ أبِي هاشِمٍ عَنْ أصْحابِهِ عَنْ أبِي الحارِثِ مِن إمالَةِ فَتْحَةِ السِينِ - فَإنَّهُ وهْمٌ وغَلَطٌ لَمْ يَكُنْ مُحْتاجًا إلَيْهِ فَإنَّهُ لَوْ صَحَّ لَمْ يَكُنْ مِن طُرُقِهِ، ولا مِن طُرُقِنا.</p></div>"
  41,17,""
  41,18,""
  41,19,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُحْشَرُ أعْداءُ اللَهِ﴾</span> فَقَرَأ نافِعٌ ويَعْقُوبُ بِالنُونِ وفَتْحِها وضَمِّ الشِينَ أعْداءُ بِالنَصْبِ، وقَرَأ الباقُونَ بِالياءِ وضَمِّها وفَتْحِ الشِينِ ورَفْعِ أعْداءُ.</p></div>"
  41,20,""
  41,21,""
  41,22,""
  41,23,""
  41,24,""
  41,25,""
  41,26,""
  41,27,""
  41,28,""
  41,29,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿يَرْجِعُونَ﴾</span> [البقرة: ١٨] و<span class="qpc-hafs">﴿أرِنا﴾</span> (p-٣٦٧)فِي البَقَرَةِ</p><p>وَتَقَدَّمَ الَّذِينَ لِابْنِ كَثِيرٍ في النِساءِ</p><p>وَتَقَدَّمَ (رَبَأتْ) في الحَجِّ لِأبِي جَعْفَرٍ.</p></div>"
  41,30,""
  41,31,""
  41,32,""
  41,33,""
  41,34,""
  41,35,""
  41,36,""
  41,37,""
  41,38,""
  41,39,""
  41,40,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿يُلْحِدُونَ﴾</span> في الأعْرافِ.</p></div>"
  41,41,""
  41,42,""
  41,43,""
  41,44,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أأعْجَمِيٌّ﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  41,45,""
  41,46,""
  41,47,"<div class=ar lang=ar><p>(واخْتَلَفُوا) في <span class="qpc-hafs">﴿ثَمَراتٍ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ، والبَصْرِيّانِ، وحَمْزَةُ والكِسائِيُّ وخَلَفٌ وأبُو بَكْرٍ بِغَيْرِ ألِفٍ عَلى التَوْحِيدِ، وقَرَأ الباقُونَ بِالألِفِ عَلى الجَمْعِ</p><p>وَتَقَدَّمَ نَأى في الإسْراءِ والإمالَةِ.</p></div>"
  41,48,""
