quran[77]{c,v,t}:
  25,1,"<div class=ar lang=ar><p>(وَفِيها مِن ياءاتِ الإضافَةِ ياءانِ) <span class="qpc-hafs">﴿يالَيْتَنِي اتَّخَذْتُ﴾</span> [الفرقان: ٢٧] فَتَحَها أبُو عَمْرٍو و<span class="qpc-hafs">﴿إنَّ قَوْمِي اتَّخَذُوا﴾</span> [الفرقان: ٣٠] فَتَحَها المَدَنِيّانِ، وأبُو عَمْرٍو والبَزِّيُّ، ورَوْحٌ، واللَهُ تَعالى المُسْتَعانُ.</p></div>"
  25,2,""
  25,3,""
  25,4,""
  25,5,""
  25,6,""
  25,7,"<div class=ar lang=ar><p>سُورَةُ الفُرْقانِ</p><p>تَقَدَّمَ <span class="qpc-hafs">﴿مالِ هَذا الرَسُولِ﴾</span> في الوَقْفِ.</p></div>"
  25,8,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿جَنَّةٌ يَأْكُلُ مِنها﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِالنُونِ، وقَرَأ الباقُونَ بِالياءِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في ضَمِّ التَنْوِينِ وكَسْرِهِ مِن <span class="qpc-hafs">﴿مَسْحُورًا انْظُرْ﴾</span> في البَقَرَةِ.</p></div>"
  25,9,""
  25,10,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَيَجْعَلْ لَكَ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وابْنُ عامِرٍ وأبُو بَكْرٍ بِرَفْعِ اللامِ، وقَرَأ الباقُونَ بِجَزْمِها</p><p>وَتَقَدَّمَ " ضَيِّقًا " لِابْنِ كَثِيرٍ في الأنْعامِ.</p></div>"
  25,11,""
  25,12,""
  25,13,""
  25,14,""
  25,15,""
  25,16,""
  25,17,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَيَوْمَ يَحْشُرُهُمْ﴾</span> فَقَرَأ أبُو جَعْفَرٍ وابْنُ كَثِيرٍ ويَعْقُوبُ وحَفْصٌ بِالياءِ، وقَرَأ الباقُونَ بِالنُونِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَيَقُولُ﴾</span> فَقَرَأ ابْنُ عامِرٍ بِالنُونِ، وقَرَأ الباقُونَ بِالياءِ.</p></div>"
  25,18,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْ تَتَّخِذَ﴾</span> [الكهف: ٨٦] فَقَرَأ أبُو جَعْفَرٍ بِضَمِّ النُونِ وفَتْحِ الخاءِ، وهي قِراءَةُ زَيْدِ بْنِ ثابِتٍ، وأبِي الدَرْداءِ وأبِي رَجاءٍ وزَيْدِ بْنِ عَلِيٍّ وجَعْفَرٍ الصادِقِ وإبْراهِيمَ النَخَعِيِّ وحَفْصِ بْنِ عُبَيْدٍ ومَكْحُولٍ. فَقِيلَ: هو مُتَعَدٍّ إلى واحِدٍ كَقِراءَةِ الجُمْهُورِ. وقِيلَ: إلى اثْنَيْنِ، والأوَّلُ الضَمِيرُ في <span class="qpc-hafs">﴿تَتَّخِذَ﴾</span> [الكهف: ٨٦] النائِبُ عَنِ الفاعِلِ والثانِي <span class="qpc-hafs">﴿مِن أوْلِياءَ﴾</span>، و" مِن " زائِدَةٌ والأحْسَنُ ما قالَهُ ابْنُ جِنِّي، وغَيْرُهُ أنْ يَكُونَ مِن أوْلِياءَ حالًا، و" مِن " زائِدَةً لِمَكانِ النَفْيِ المُتَقَدِّمِ كَما يَقُولُ: ما اتَّخَذْتُ زَيْدًا مِن وكِيلٍ، والمَعْنى ما كانَ لَنا أنْ نُعْبَدَ مِن دُونِكَ، ولا نَسْتَحِقُّ الوَلاءَ والعِبادَةَ; وقَرَأ الباقُونَ بِفَتْحِ النُونِ وكَسْرِ الخاءِ.</p></div>"
  25,19,"<div class=ar lang=ar><p>(p-٣٣٤)واخْتُلِفَ عَنْ قُنْبُلٍ في <span class="qpc-hafs">﴿كَذَّبُوكم بِما تَقُولُونَ﴾</span>، فَرَوى عَنْهُ ابْنُ شَنَبُوذَ بِالغَيْبِ، وهي قِراءَةُ ابْنِ حَيْوَةَ، ونَصَّ عَلَيْها ابْنُ مُجاهِدٍ عَنِ البَزِّيِّ سَماعًا مِن قُنْبُلٍ، ورَوى عَنْهُ ابْنُ مُجاهِدٍ بِالخِطابِ، وبِذَلِكَ قَرَأ الباقُونَ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَما تَسْتَطِيعُونَ﴾</span>، فَرَوى حَفْصٌ بِالخِطابِ، وقَرَأ الباقُونَ بِالغَيْبِ.</p></div>"
  25,20,""
  25,21,""
  25,22,""
  25,23,""
  25,24,""
  25,25,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَشَقَّقُ السَماءُ﴾</span> هُنا، وفي ق فَقَرَأ أبُو عَمْرٍو، والكُوفِيُّونَ بِتَخْفِيفِ الشِينِ فِيهِما، وقَرَأ الباقُونَ بِالتَشْدِيدِ مِنهُما.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَنُزِّلَ المَلائِكَةُ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ بِنُونَيْنِ الأُولى مَضْمُومَةٌ والثانِيَةُ ساكِنَةٌ مَعَ تَخْفِيفِ الزايِ ورَفْعِ اللامِ، ونَصْبِ المَلائِكَةِ، وهي كَذَلِكَ في المُصْحَفِ المَكِّيِّ، وقَرَأ الباقُونَ بِنُونٍ واحِدَةٍ وتَشْدِيدِ الزايِ وفَتْحِ اللامِ ورَفْعِ <span class="qpc-hafs">﴿المَلائِكَةُ﴾</span>، وكَذَلِكَ هي في مَصاحِفِهِمْ واتَّفَقُوا عَلى كَسْرِ الزايِ.</p></div>"
  25,26,""
  25,27,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿اتَّخَذْتُ﴾</span> في الإدْغامِ و<span class="qpc-hafs">﴿ياوَيْلَتى﴾</span> [الفرقان: ٢٨] في الإمالَةِ والوَقْفِ عَلى المَرْسُومِ</p><p>وَتَقَدَّمَ وثَمُودا في هُودٍ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧] في البَقَرَةِ.</p></div>"
  25,28,"<div class=ar lang=ar><p>[انظر الآية ٢٧]</p></div>"
  25,29,""
  25,30,""
  25,31,""
  25,32,""
  25,33,""
  25,34,""
  25,35,""
  25,36,""
  25,37,""
  25,38,""
  25,39,""
  25,40,""
  25,41,""
  25,42,""
  25,43,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أفَأنْتَ﴾</span> لِلْأصْبَهانِيِّ والرِيحَ لِابْنِ كَثِيرٍ في البَقَرَةِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿نَشْرًا﴾</span> [المرسلات: ٣] مِنَ الأعْرافِ.</p></div>"
  25,44,""
  25,45,""
  25,46,""
  25,47,""
  25,48,""
  25,49,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿بَلْدَةً مَيْتًا﴾</span> لِأبِي جَعْفَرٍ في البَقَرَةِ.</p></div>"
  25,50,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِيَذَّكَّرُوا﴾</span> لِحَمْزَةَ والكِسائِيِّ وخَلَفٍ في الإسْراءِ.</p></div>"
  25,51,""
  25,52,""
  25,53,""
  25,54,""
  25,55,""
  25,56,""
  25,57,""
  25,58,""
  25,59,""
  25,60,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِما تَأْمُرُنا﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ بِالغَيْبِ، وقَرَأ الباقُونَ بِالخِطابِ.</p></div>"
  25,61,"<div class=ar lang=ar><p>(واخْتَلَفُوا) في <span class="qpc-hafs">﴿سِراجًا﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِضَمِّ السِينِ والراءِ مِن غَيْرِ ألِفٍ عَلى الجَمْعِ، وقَرَأ الباقُونَ بِكَسْرِ السِينِ وفَتْحِ الراءِ وألِفٍ بَعْدَها عَلى الإفْرادِ.</p></div>"
  25,62,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْ يَذَّكَّرَ﴾</span> فَقَرَأ حَمْزَةُ وخَلَفٌ بِتَخْفِيفِ الذالِ مُسَكَّنَةً وتَخْفِيفِ الكافِ مَضْمُومَةً، وقَرَأ الباقُونَ بِتَشْدِيدِهِما مَفْتُوحَيْنِ.</p></div>"
  25,63,""
  25,64,""
  25,65,""
  25,66,""
  25,67,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَلَمْ يَقْتُرُوا﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ عامِرٍ بِضَمِّ الياءِ وكَسْرِ التاءِ، وقَرَأ ابْنُ كَثِيرٍ، والبَصْرِيّانِ بِفَتْحِ الياءِ وكَسْرِ التاءِ، وقَرَأ الباقُونَ بِفَتْحِ الياءِ وضَمِّ التاءِ.</p></div>"
  25,68,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿يَفْعَلْ ذَلِكَ﴾</span> لِأبِي الحارِثِ في بابِ الإدْغامِ الصَغِيرِ.</p></div>"
  25,69,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُضاعَفْ﴾</span> <span class="qpc-hafs">﴿وَيَخْلُدْ﴾</span> فَقَرَأ ابْنُ عامِرٍ وأبُو بَكْرٍ بِرَفْعِ الفاءِ والدالِ، وقَرَأ الباقُونَ بِجَزْمِهِما</p><p>وَتَقَدَّمَ تَشْدِيدُ العَيْنِ لِأبِي جَعْفَرٍ، وابْنِ كَثِيرٍ ويَعْقُوبَ وابْنِ عامِرٍ مِنَ البَقَرَةِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فِيهِ مُهانًا﴾</span> لِحَفْصٍ وِفاقًا (p-٣٣٥)لِابْنِ كَثِيرٍ في بابِ هاءِ الكِنايَةِ.</p></div>"
  25,70,""
  25,71,""
  25,72,""
  25,73,""
  25,74,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَذُرِّيّاتِنا﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ ويَعْقُوبُ وابْنُ عامِرٍ وحَفْصٌ بِالألِفِ عَلى الجَمْعِ، وقَرَأ الباقُونَ بِغَيْرِ ألِفٍ عَلى الإفْرادِ.</p></div>"
  25,75,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَيُلَقَّوْنَ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وأبُو بَكْرٍ بِفَتْحِ اللامِ وتَخْفِيفِ القافِ، وقَرَأ الباقُونَ بِضَمِّ الياءِ وفَتْحِ اللامِ وتَشْدِيدِ القافِ.</p></div>"
  25,76,""
  25,77,""
