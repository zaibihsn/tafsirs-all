quran[118]{c,v,t}:
  23,1,"<div class=ar lang=ar><p>(وَفِيها مِن ياءاتِ الإضافَةِ ياءٌ واحِدَةٌ) <span class="qpc-hafs">﴿لَعَلِّي أعْمَلُ﴾</span> [المؤمنون: ١٠٠] أسْكَنَها الكُوفِيُّونَ ويَعْقُوبُ.</p><p>(وَمِنَ الزَوائِدِ سِتٌّ) <span class="qpc-hafs">﴿بِما كَذَّبُونِ﴾</span> [المؤمنون: ٣٩] مَوْضِعانِ <span class="qpc-hafs">﴿فاتَّقُونِ﴾</span> [المؤمنون: ٥٢]، <span class="qpc-hafs">﴿أنْ يَحْضُرُونِ﴾</span> [المؤمنون: ٩٨]، <span class="qpc-hafs">﴿رَبِّ ارْجِعُونِ﴾</span> [المؤمنون: ٩٩]، <span class="qpc-hafs">﴿وَلا تُكَلِّمُونِ﴾</span> [المؤمنون: ١٠٨] أثْبَتَهُنَّ في الحالَيْنِ يَعْقُوبُ.</p></div>"
  23,2,""
  23,3,""
  23,4,""
  23,5,""
  23,6,""
  23,7,""
  23,8,"<div class=ar lang=ar><p>(p-٣٢٨)سُورَةُ المُؤْمِنُونَ</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِأماناتِهِمْ﴾</span> هُنا والمَعارِجِ، فَقَرَأ ابْنُ كَثِيرٍ فِيهِما بِغَيْرِ ألِفٍ عَلى التَوْحِيدِ، وقَرَأهُما الباقُونَ بِالألِفِ عَلى الجَمْعِ.</p></div>"
  23,9,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عَلى صَلَواتِهِمْ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِالتَوْحِيدِ، وقَرَأها الباقُونَ بِالجَمْعِ.</p><p>(واتَّفَقُوا) عَلى الإفْرادِ في الأنْعامِ والمَعارِجِ لِأنَّهُ لَمْ يَكْتَنِفْها فِيهِما ما اكْتَنَفَها في المُؤْمِنُونَ قَبْلُ، وبَعْدُ مِن تَعْظِيمِ الوَصْفِ في المُتَقَدِّمِ وتَعْظِيمِ الجَزاءِ في المُتَأخِّرِ فَناسَبَ لَفْظَ الجَمْعِ، وكَذَلِكَ قَرَأ بِهِ أكْثَرُ القُرّاءِ، ولَمْ يَكُنْ ذَلِكَ في غَيْرِها فَناسَبَ الإفْرادَ - واللَهُ أعْلَمُ -.</p></div>"
  23,10,""
  23,11,""
  23,12,""
  23,13,""
  23,14,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عِظامًا فَكَسَوْنا العِظامَ﴾</span> فَقَرَأ ابْنُ عامِرٍ وأبُو بَكْرٍ (عَظْمًا) و(العَظْمَ) بِفَتْحِ العَيْنِ، وإسْكانِ الظاءِ مِن غَيْرِ ألِفٍ عَلى التَوْحِيدِ فِيهِما، وقَرَأهُما الباقُونَ بِكَسْرِ العَيْنِ وفَتْحِ الظاءِ وألِفٍ بَعْدَها.</p></div>"
  23,15,""
  23,16,""
  23,17,""
  23,18,""
  23,19,""
  23,20,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿طُورِ سَيْناءَ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ وأبُو عَمْرٍو بِكَسْرِ السِينِ، وقَرَأ الباقُونَ بِفَتْحِها.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَنْبُتُ بِالدُهْنِ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو ورُوَيْسٌ بِضَمِّ التاءِ وكَسْرِ الباءِ، وقَرَأ الباقُونَ بِفَتْحِ التاءِ وضَمِّ الباءِ.</p></div>"
  23,21,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿نُسْقِيكُمْ﴾</span> مِنَ النَحْلِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مِن إلَهٍ غَيْرُهُ﴾</span> [الأعراف: ٥٩] كِلاهُما في الأعْرافِ.</p></div>"
  23,22,""
  23,23,""
  23,24,""
  23,25,""
  23,26,""
  23,27,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مِن كُلٍّ﴾</span> في هُودٍ.</p></div>"
  23,28,""
  23,29,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْزِلْنِي مُنْزَلًا﴾</span>، فَرَوى أبُو بَكْرٍ بِفَتْحِ المِيمِ وكَسْرِ الزايِ، وقَرَأ الباقُونَ بِضَمِّ المِيمِ وفَتْحِ الزايِ.</p></div>"
  23,30,""
  23,31,""
  23,32,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أنِ اعْبُدُوا اللَهَ﴾</span> في البَقَرَةِ.</p></div>"
  23,33,""
  23,34,""
  23,35,""
  23,36,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿هَيْهاتَ هَيْهاتَ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِكَسْرِ التاءِ مِنهُما، وقَرَأ الباقُونَ بِفَتْحِها فِيهِما</p><p>وَتَقَدَّمَ مَذْهَبُهم في الوَقْفِ عَلَيْهِما في بابِ الوَقْفِ عَلى المَرْسُومِ.</p></div>"
  23,37,""
  23,38,""
  23,39,""
  23,40,""
  23,41,""
  23,42,""
  23,43,""
  23,44,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَتْرى﴾</span> فَقَرَأ أبُو جَعْفَرٍ وابْنُ كَثِيرٍ وأبُو عَمْرٍو بِالتَنْوِينِ، وقَرَأ الباقُونَ بِغَيْرِ تَنْوِينٍ</p><p>وَتَقَدَّمَ مَذْهَبُهم في إمالَتِها مِن بابِهِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في (رَبْوَةٍ) في البَقَرَةِ.</p></div>"
  23,45,""
  23,46,""
  23,47,""
  23,48,""
  23,49,""
  23,50,""
  23,51,""
  23,52,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَإنَّ هَذِهِ أُمَّتُكُمْ﴾</span> فَقَرَأ الكُوفِيُّونَ بِكَسْرِ الهَمْزَةِ، وقَرَأ الباقُونَ بِفَتْحِها، وأسْكَنَ النُونَ مِن " إنْ " مُخَفَّفَةً ابْنُ عامِرٍ وشَدَّدَها الباقُونَ. ٥٦</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿نُسارِعُ﴾</span> [المؤمنون: ٥٦].</p></div>"
  23,53,""
  23,54,""
  23,55,""
  23,56,""
  23,57,""
  23,58,""
  23,59,""
  23,60,""
  23,61,"<div class=ar lang=ar><p>وَ<span class="qpc-hafs">﴿يُسارِعُونَ﴾</span>.</p></div>"
  23,62,""
  23,63,""
  23,64,""
  23,65,""
  23,66,""
  23,67,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَهْجُرُونَ﴾</span> فَقَرَأ نافِعٌ بِضَمِّ التاءِ وكَسْرِ الجِيمِ، وقَرَأ الباقُونَ بِفَتْحِ التاءِ وضَمِّ الجِيمِ.</p></div>"
  23,68,""
  23,69,""
  23,70,""
  23,71,""
  23,72,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿خَرْجًا﴾</span>، وفي <span class="qpc-hafs">﴿فَخَراجُ رَبِّكَ﴾</span> في الكَهْفِ.</p></div>"
  23,73,""
  23,74,""
  23,75,"<div class=ar lang=ar><p>وَ<span class="qpc-hafs">﴿طُغْيانِهِمْ﴾</span> (p-٣٢٩)فِي الإمالَةِ.</p></div>"
  23,76,""
  23,77,""
  23,78,""
  23,79,""
  23,80,""
  23,81,""
  23,82,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿أئِذا مِتْنا﴾</span>، و<span class="qpc-hafs">﴿أئِنّا لَمَبْعُوثُونَ﴾</span> في بابِ الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  23,83,""
  23,84,"<div class=ar lang=ar><p>(واتَّفَقُوا) عَلى الحَرْفِ الأوَّلِ أنَّهُ لِلَّهِ لِأنَّ قَبْلَهُ <span class="qpc-hafs">﴿قُلْ لِمَنِ الأرْضُ ومَن فِيها﴾</span> فَجاءَ الجَوابُ عَلى لَفْظِ السُؤالِ.</p></div>"
  23,85,"<div class=ar lang=ar><p>[انظر الآية ٨٨]</p></div>"
  23,86,""
  23,87,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿سَيَقُولُونَ لِلَّهِ﴾</span>، <span class="qpc-hafs">﴿سَيَقُولُونَ لِلَّهِ﴾</span> [المؤمنون: ٨٩] في الأخِيرَتَيْنِ، فَقَرَأ البَصْرِيّانِ بِإثْباتِ ألِفِ الوَصْلِ قَبْلَ اللامِ فِيهِما ورَفْعِ الهاءِ مِنَ الجَلالَتَيْنِ، وكَذَلِكَ رُسِما في المَصاحِفِ البَصْرِيَّةِ، نَصَّ عَلى ذَلِكَ الحافِظُ، وأبُو عَمْرٍو في جامِعِهِ، وقَرَأ الباقُونَ لِلَّهِ، لِلَّهِ بِغَيْرِ ألِفٍ وخَفْضِ الهاءِ، وكَذا رُسِما في مَصاحِفِ الحِجازِ والشامِ والعِراقِ.</p></div>"
  23,88,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿بِيَدِهِ﴾</span> في هاءِ الكِنايَةِ <span class="qpc-hafs">﴿تَذَكَّرُونَ﴾</span> [المؤمنون: ٨٥] وفي الأنْعامِ.</p></div>"
  23,89,"<div class=ar lang=ar><p>[انظر الآية ٨٧]</p></div>"
  23,90,""
  23,91,""
  23,92,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عالِمِ الغَيْبِ﴾</span> فَقَرَأ المَدَنِيّانِ، وحَمْزَةُ والكِسائِيُّ وخَلَفٌ وأبُو بَكْرٍ بِرَفْعِ المِيمِ، واخْتُلِفَ عَنْ رُوَيْسٍ حالَةَ الِابْتِداءِ، فَرَوى الجَوْهَرِيُّ وابْنُ مِقْسَمٍ عَنِ التَمّارِ الرَفْعَ في حالَةِ الِابْتِداءِ، وكَذا رَوى القاضِي أبُو العَلاءِ والشَيْخُ أبُو عَبْدِ اللَهِ الكارَزِينِيُّ كِلاهُما عَنِ النَخّاسِ عَنْهُ. وهو المَنصُوصُ لَهُ عَلَيْهِ في المُبْهِجِ وكُتُبِ ابْنِ مِهْرانَ والتَذْكِرَةِ، وكَثِيرٍ مِن كُتُبِ العِراقِيِّينَ، والمِصْرِيِّينَ، ورَوى باقِي أصْحابِ رُوَيْسٍ الخَفْضَ في الحالَيْنِ مِن غَيْرِ اعْتِبارِ وقْفٍ، ولا ابْتِداءٍ، وهو الَّذِي في المُسْتَنِيرِ، والكامِلِ، وغايَةِ الحافِظِ أبِي العَلاءِ وخَصَّصَهُ أبُو العِزِّ في إرْشادَيْهِ بِغَيْرِ القاضِي أبِي العَلاءِ الواسِطِيِّ، وبِذَلِكَ قَرَأ الباقُونَ.</p></div>"
  23,93,""
  23,94,""
  23,95,""
  23,96,""
  23,97,""
  23,98,""
  23,99,""
  23,100,""
  23,101,"<div class=ar lang=ar><p>وَتَقَدَّمَ إدْغامُ رُوَيْسٍ في <span class="qpc-hafs">﴿فَلا أنْسابَ بَيْنَهُمْ﴾</span> مُوافَقَةً لِأبِي عَمْرٍو في الإدْغامِ الكَبِيرِ.</p></div>"
  23,102,""
  23,103,""
  23,104,""
  23,105,""
  23,106,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿شِقْوَتُنا﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِفَتْحِ الشِينِ والقافِ وألِفٍ بَعْدَها، وقَرَأ الباقُونَ بِكَسْرِ الشِينِ، وإسْكانِ القافِ مِن غَيْرِ ألِفٍ.</p></div>"
  23,107,""
  23,108,""
  23,109,""
  23,110,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فاتَّخَذْتُمُوهُمْ﴾</span> في الإدْغامِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿سِخْرِيًّا﴾</span> هُنا وص فَقَرَأ المَدَنِيّانِ، وحَمْزَةُ والكِسائِيُّ وخَلَفٌ بِضَمِّ السِينِ في المَوْضِعَيْنِ، وقَرَأ الباقُونَ بِكَسْرِها فِيهِما.</p><p>(واتَّفَقُوا) عَلى ضَمِّ السِينِ في حَرْفِ الزُخْرُفِ لِأنَّهُ مِنَ السُخْرَةِ لا مِنَ الهَزْءِ.</p></div>"
  23,111,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنَّهم هُمُ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ (p-٣٣٠)بِكَسْرِ الهَمْزَةِ، وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  23,112,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿قالَ كَمْ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وحَمْزَةُ والكِسائِيُّ، (قُلْ) بِغَيْرِ ألِفٍ عَلى الأمْرِ، وقَرَأ الباقُونَ بِالألِفِ عَلى الخَبَرِ.</p><p>وَتَقَدَّمَ اخْتِلافُهم في إدْغامِ <span class="qpc-hafs">﴿لَبِثْتُمْ﴾</span> في بابِ حُرُوفٍ قَرُبَتْ مَخارِجُها.</p></div>"
  23,113,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فاسْألِ﴾</span> في النَقْلِ، واخْتِلافُهم في <span class="qpc-hafs">﴿يَرْجِعُونَ﴾</span> [البقرة: ١٨] أوائِلَ البَقَرَةِ.</p></div>"
  23,114,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿قالَ إنْ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ، " قُلْ " عَلى الأمْرِ، وقَرَأ الباقُونَ عَلى الخَبَرِ.</p></div>"
  23,115,""
  23,116,""
  23,117,""
  23,118,""
