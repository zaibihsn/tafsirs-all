quran[111]{c,v,t}:
  17,1,"<div class=ar lang=ar><p>(وَفِيها مِن ياءاتِ الإضافَةِ واحِدَةٌ) <span class="qpc-hafs">﴿رَبِّي إذًا﴾</span> [الإسراء: ١٠٠] فَتَحَها المَدَنِيّانِ، وأبُو عَمْرٍو.</p><p>(وَمِنَ الزَوائِدِ ثِنْتانِ)</p><p><span class="qpc-hafs">﴿لَئِنْ أخَّرْتَنِ﴾</span> أثْبَتَها وصْلًا المَدَنِيّانِ وأبُو عَمْرٍو، وأثْبَتَها في الحالَيْنِ ابْنُ كَثِيرٍ ويَعْقُوبُ</p><p><span class="qpc-hafs">﴿فَهُوَ المُهْتَدِ﴾</span> أثْبَتَها وصْلًا المَدَنِيّانِ وأبُو عَمْرٍو، وأثْبَتَها في الحالَيْنِ يَعْقُوبُ ورُوَيْسٌ عَنْ قُنْبُلٍ مِن طَرِيقِ ابْنِ شَنَبُوذَ.</p></div>"
  17,2,"<div class=ar lang=ar><p>سُورَةُ الإسْراءِ</p><p>(اخْتَلَفُوا) في <span class="qpc-hafs">﴿ألّا تَتَّخِذُوا﴾</span> فَقَرَأ أبُو عَمْرٍو بِالغَيْبِ، وقَرَأ الباقُونَ بِالخِطابِ.</p></div>"
  17,3,""
  17,4,""
  17,5,""
  17,6,""
  17,7,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِيَسُوءُوا وُجُوهَكُمْ﴾</span> فَقَرَأ ابْنُ عامِرٍ وحَمْزَةُ وخَلَفٌ وأبُو بَكْرٍ بِالياءِ ونَصْبِ الهَمْزَةِ عَلى لَفْظِ الواحِدِ، وقَرَأ الكِسائِيُّ بِالنُونِ ونَصْبِ الهَمْزَةِ عَلى لَفْظِ الجَمْعِ لِلْمُتَكَلِّمِينَ، وقَرَأ الباقُونَ بِالياءِ وضَمِّ الهَمْزَةِ، وبَعْدَها واوُ الجَمْعِ.</p></div>"
  17,8,""
  17,9,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَيُبَشِّرُ المُؤْمِنِينَ﴾</span> لِحَمْزَةَ والكِسائِيِّ في آلِ عِمْرانَ.</p></div>"
  17,10,""
  17,11,""
  17,12,""
  17,13,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَنُخْرِجُ لَهُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِالياءِ وضَمِّها وفَتْحِ الراءِ، وقَرَأ يَعْقُوبُ بِالباءِ وفَتْحِها وضَمِّ الراءِ، وقَرَأ الباقُونَ بِالنُونِ وضَمِّها وكَسْرِ الراءِ.</p><p>(واتَّفَقُوا) عَلى نَصْبِ <span class="qpc-hafs">﴿كِتابًا﴾</span> ووَجْهُ نَصْبِهِ عَلى قِراءَةِ أبِي جَعْفَرٍ و نُخْرِجُ مَبْنِيًّا لِلْمَفْعُولِ، قِيلَ: إنَّ الجارَّ والمَجْرُورَ، وهُوَ<span class="qpc-hafs">﴿لَهُ﴾</span> قامَ مَقامَ الفاعِلِ، وقِيلَ: المَصْدَرِ عَلى أحَدِ قِراءَتِهِ <span class="qpc-hafs">﴿لِيَجْزِيَ قَوْمًا﴾</span> [الجاثية: ١٤] فَهو مَفْعُولٌ بِهِ، والأحْسَنُ أنْ يَكُونَ حالًا، أيْ ويُخْرِجُ الطائِرُ كِتابًا، وكَذا وجْهُ النَصْبِ عَلى قِراءَةِ يَعْقُوبَ أيْضًا فَتَتَّفِقُ القِراءَتانِ في التَوْجِيهِ عَلى الصَحِيحِ الفَصِيحِ الَّذِي لا يُخْتَلَفُ فِيهِ - واللَهُ أعْلَمُ -.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يَلْقاهُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ وابْنُ عامِرٍ بِضَمِّ الياءِ وفَتْحِ اللامِ وتَشْدِيدِ القافِ، وقَرَأ الباقُونَ بِفَتْحِ الياءِ، وإسْكانِ اللامِ وتَخْفِيفِ القافِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في إمالَتِهِ في بابِهِ.</p></div>"
  17,14,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿اقْرَأْ كِتابَكَ﴾</span> لِأبِي جَعْفَرٍ.</p></div>"
  17,15,""
  17,16,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أمَرْنا مُتْرَفِيها﴾</span> فَقَرَأ يَعْقُوبُ بِمَدِّ الهَمْزَةِ، وقَرَأ الباقُونَ بِقَصْرِها</p></div>"
  17,17,""
  17,18,""
  17,19,""
  17,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَحْظُورًا انْظُرْ﴾</span> و<span class="qpc-hafs">﴿مَسْحُورًا﴾</span> [الإسراء: ٤٧] <span class="qpc-hafs">﴿انْظُرْ﴾</span> [الإسراء: ٤٨] كِلاهُما في البَقَرَةِ عِنْدَ <span class="qpc-hafs">﴿فَمَنِ اضْطُرَّ﴾</span> [البقرة: ١٧٣].</p></div>"
  17,21,""
  17,22,""
  17,23,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إمّا يَبْلُغَنَّ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ (يَبْلُغانِ) بِألِفٍ مُطَوَّلَةٍ بَعْدَ الغَيْنِ وكَسْرِ النُونِ عَلى التَثْنِيَةِ، وقَرَأ الباقُونَ بِغَيْرِ ألِفٍ وفَتْحِ النُونِ عَلى التَوْحِيدِ</p><p>وَتَقَدَّمَ إمالَةُ <span class="qpc-hafs">﴿كِلاهُما﴾</span> في بابِها.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أُفٍّ﴾</span> هُنا والأنْبِياءِ والأحْقافِ فَقَرَأ ابْنُ كَثِيرٍ وابْنُ عامِرٍ (p-٣٠٧)وَيَعْقُوبُ بِفَتْحِ الفاءِ مِن غَيْرِ تَنْوِينٍ في الثَلاثَةِ، وقَرَأ المَدَنِيّانِ وحَفْصٌ بِكَسْرِ الفاءِ مَعَ التَنْوِينِ، وقَرَأ الباقُونَ بِكَسْرِ الفاءِ مِن غَيْرِ تَنْوِينٍ فِيهِنَّ.</p></div>"
  17,24,""
  17,25,""
  17,26,""
  17,27,""
  17,28,""
  17,29,""
  17,30,""
  17,31,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿خِطْئًا كَبِيرًا﴾</span> فَقَرَأ ابْنُ كَثِيرٍ بِكَسْرِ الخاءِ وفَتْحِ الطاءِ وألِفٍ مَمْدُودَةٍ بَعْدَها، وقَرَأ أبُو جَعْفَرٍ، وابْنُ ذَكْوانَ بِفَتْحِ الخاءِ والطاءِ مِن غَيْرِ ألِفٍ، ولا مَدٍّ.</p><p>(واخْتُلِفَ) عَنْ هِشامٍ، فَرَوى الشَذائِيُّ عَنِ الداجُونِيِّ وزَيْدِ بْنِ عَلِيٍّ مِن جَمِيعِ طُرُقِهِ إلّا مِن طَرِيقِ المُفَسِّرِ كَذَلِكَ، أعْنِي مِثْلَ ابْنِ ذَكْوانَ، وبِذَلِكَ قَطَعَ لَهُ صاحِبُ المُبْهِجِ مِن طُرُقِهِ إلّا الأخْفَشَ عَنْهُ. ورَوى عَنْهُ الحُلْوانِيُّ مِن جَمِيعِ طُرُقِهِ، وهِبَةُ اللَهِ المُفَسِّرُ عَنِ الداجُونِيِّ بِكَسْرِ الخاءِ وإسْكانِ الطاءِ، وبِذَلِكَ قَرَأ الباقُونَ، وحَمْزَةُ، عَلى أصْلِهِ في إلْقاءِ حَرَكَةِ الهَمْزَةِ عَلى الساكِنِ قَبْلَها وقْفًا، وهو وغَيْرُهُ عَلى أُصُولِهِمْ في السَكْتِ.</p></div>"
  17,32,""
  17,33,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَلا يُسْرِفْ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ، وخَلَفٌ بِالخِطابِ، وقَرَأ الباقُونَ بِالغَيْبِ.</p></div>"
  17,34,""
  17,35,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بِالقِسْطاسِ﴾</span> هُنا والشُعَراءِ، فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وحَفْصٌ بِكَسْرِ القافِ في المَوْضِعَيْنِ، وقَرَأ الباقُونَ بِضَمِّها فِيهِما.</p></div>"
  17,36,""
  17,37,""
  17,38,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿كانَ سَيِّئُهُ﴾</span> فَقَرَأ الكُوفِيُّونَ، وابْنُ عامِرٍ بِضَمِّ الهَمْزَةِ والهاءِ وإلْحاقِها الواوَ في اللَفْظِ عَلى الإضافَةِ والتَذْكِيرِ، وقَرَأ الباقُونَ بِفَتْحِ الهَمْزَةِ، ونَصْبِ تاءِ التَأْنِيثِ مَعَ التَنْوِينِ عَلى التَوْحِيدِ ز</p></div>"
  17,39,""
  17,40,"<div class=ar lang=ar><p>وَتَقَدَّمَ تَسْهِيلُ الهَمْزَةِ الثانِيَةِ مِن <span class="qpc-hafs">﴿أفَأصْفاكُمْ﴾</span> لِلْأصْفَهانِيِّ في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
  17,41,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِيَذَّكَّرُوا﴾</span> هُنا، والفُرْقانِ، فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِإسْكانِ الذالِ وضَمِّ الكافِ مَعَ تَخْفِيفِها في المَوْضِعَيْنِ، وقَرَأ الباقُونَ بِفَتْحِ الذالِ والكافِ مَعَ تَشْدِيدِها فِيهِما.</p></div>"
  17,42,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿كَما يَقُولُونَ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وحَفْصٌ بِالغَيْبِ، وقَرَأ الباقُونَ بِالخِطابِ.</p></div>"
  17,43,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عَمّا يَقُولُونَ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وأبُو الطَيِّبِ عَنِ التَمّارِ عَنْ رُوَيْسٍ بِالخِطابِ، وقَرَأ الباقُونَ بِالغَيْبِ.</p></div>"
  17,44,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُسَبِّحُ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ وابْنُ عامِرٍ وأبُو بَكْرٍ وأبُو الطَيِّبِ عَنِ التَمّارِ عَنْ رُوَيْسٍ بِالياءِ عَلى التَذْكِيرِ، وقَرَأ الباقُونَ بِالتاءِ عَلى التَأْنِيثِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أئِذا﴾</span> [الرعد: ٥] <span class="qpc-hafs">﴿أئِنّا﴾</span> [الرعد: ٥] في بابِ الهَمْزَتَيْنِ في كَلِمَةٍ المَوْضِعَيْنِ.</p></div>"
  17,45,""
  17,46,""
  17,47,"<div class=ar lang=ar><p>[انظر الآية ٢٠]</p></div>"
  17,48,"<div class=ar lang=ar><p>[انظر الآية ٢٠]</p></div>"
  17,49,""
  17,50,""
  17,51,""
  17,52,""
  17,53,""
  17,54,""
  17,55,""
  17,56,""
  17,57,""
  17,58,""
  17,59,""
  17,60,""
  17,61,"<div class=ar lang=ar><p>وَتَقَدَّمَ (p-٣٠٨)<span class="qpc-hafs">﴿زَبُورًا﴾</span> [النساء: ١٦٣] في النِساءِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿القُرْآنُ﴾</span> [البقرة: ١٨٥] في النَقْلِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِلْمَلائِكَةِ اسْجُدُوا﴾</span> [البقرة: ٣٤] في البَقَرَةِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أأسْجُدُ﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  17,62,""
  17,63,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿قالَ اذْهَبْ فَمَن﴾</span> في بابِ حُرُوفٍ قَرُبَتْ مَخارِجُها.</p></div>"
  17,64,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَرَجِلِكَ﴾</span>، فَرَوى حَفْصٌ بِكَسْرِ الجِيمِ، وقَرَأ الباقُونَ بِإسْكانِها.</p></div>"
  17,65,""
  17,66,""
  17,67,""
  17,68,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْ يَخْسِفَ بِكُمْ﴾</span> <span class="qpc-hafs">﴿أوْ يُرْسِلَ عَلَيْكُمْ﴾</span> <span class="qpc-hafs">﴿أنْ يُعِيدَكُمْ﴾</span> [الإسراء: ٦٩] <span class="qpc-hafs">﴿فَيُرْسِلَ عَلَيْكُمْ﴾</span> [الإسراء: ٦٩] <span class="qpc-hafs">﴿فَيُغْرِقَكُمْ﴾</span> [الإسراء: ٦٩] فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو بِالنُونِ في الخَمْسَةِ، وقَرَأ الباقُونَ بِالياءِ إلّا أبا جَعْفَرٍ ورُوَيْسًا في <span class="qpc-hafs">﴿فَيُغْرِقَكُمْ﴾</span> [الإسراء: ٦٩] فَقَرَأ بِالتاءِ عَلى التَأْنِيثِ، وانْفَرَدَ الشَطَوِيُّ عَنِ ابْنِ هارُونَ عَنِ الفَضْلِ عَنِ ابْنِ ورْدانَ بِتَشْدِيدِ الراءِ، وهي قِراءَةُ ابْنِ مِقْسَمٍ وقَتادَةَ والحَسَنِ في رِوايَةٍ</p><p>وَتَقَدَّمَ ذِكْرُ <span class="qpc-hafs">﴿الرِياحِ﴾</span> [البقرة: ١٦٤] لِأبِي جَعْفَرٍ في البَقَرَةِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿أعْمى﴾</span> [الرعد: ١٩] في المَوْضِعَيْنِ هُنا مِن بابِ الإمالَةِ.</p></div>"
  17,69,"<div class=ar lang=ar><p>[انظر الآية ٦٨]</p></div>"
