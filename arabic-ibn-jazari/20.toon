  20,57,""
  20,58,"<div class=ar lang=ar><p>(واخْتَلَفُوا) في <span class="qpc-hafs">﴿نُخْلِفُهُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِإسْكانِ الفاءِ جَزْمًا فَتَمْتَنِعُ الصِلَةُ لَهُ لِذَلِكَ، وقَرَأ الباقُونَ بِالرَفْعِ والصِلَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿سُوًى﴾</span> فَقَرَأ ابْنُ عامِرٍ ويَعْقُوبُ وعاصِمٌ وحَمْزَةُ وخَلَفٌ بِضَمِّ السِينِ، وقَرَأ الباقُونَ بِكَسْرِها</p><p>وَتَقَدَّمَ اخْتِلافُهم في الوَقْفِ عَلَيْها في بابِ الإمالَةِ.</p></div>"
  20,59,""
  20,60,""
  20,61,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَيُسْحِتَكُمْ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وحَفْصٌ ورُوَيْسٌ بِضَمِّ الياءِ وكَسْرِ الحاءِ، وقَرَأ الباقُونَ بِفَتْحِهِما</p><p>وَتَقَدَّمَ إمالَةُ <span class="qpc-hafs">﴿خابَ﴾</span> لِحَمْزَةَ وابْنِ عامِرٍ بِخِلافٍ عَنْهُ في بابِها.</p></div>"
  20,62,""
  20,63,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿قالُوا إنْ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ (p-٣٢١)وَحَفْصٌ بِتَخْفِيفِ النُونِ، وقَرَأ الباقُونَ بِتَشْدِيدِها.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿هَذانِ﴾</span> فَقَرَأ أبُو عَمْرٍو هَذَيْنِ بِالياءِ، وقَرَأ الباقُونَ بِالألِفِ، وابْنُ كَثِيرٍ عَلى أصْلِهِ في تَشْدِيدِ النُونِ.</p></div>"
  20,64,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَأجْمِعُوا كَيْدَكُمْ﴾</span> فَقَرَأ أبُو عُمَرَ بِوَصْلِ الهَمْزَةِ وفَتْحِ المِيمِ، وقَرَأ الباقُونَ بِالقَطْعِ وكَسْرِ المِيمِ.</p></div>"
  20,65,""
  20,66,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُخَيَّلُ إلَيْهِ﴾</span>، فَرَوى ابْنُ ذَكْوانَ ورَوْحٌ بِالتاءِ عَلى التَأْنِيثِ، وقَرَأ الباقُونَ بِالياءِ عَلى التَذْكِيرِ، وأهْمَلَ ابْنُ مُجاهِدٍ، وصاحِبُهُ ابْنُ أبِي هاشِمٍ ذِكْرَ هَذا الحَرْفِ في كُتُبِهِما، فَتَوَهَّمَ بَعْضُهُمُ الخِلافَ في ذَلِكَ لِابْنِ ذَكْوانَ، ولَيْسَ عَنْهُ فِيهِ خِلافٌ.</p></div>"
  20,67,""
  20,68,""
  20,69,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَلْقَفْ﴾</span>، فَرَوى ابْنُ ذَكْوانَ رَفْعَ الفاءِ، ورَوى حَفْصٌ إسْكانَ اللامِ مَعَ تَخْفِيفِ القافِ كَما تَقَدَّمَ في الأعْرافِ، وقَرَأ الباقُونَ بِالجَزْمِ والتَشْدِيدِ، والبَزِّيُّ عَلى أصْلِهِ في تَشْدِيدِ التاءِ وصْلًا كَما تَقَدَّمَ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿كَيْدُ ساحِرٍ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ، (سِحْرٍ) بِكَسْرِ السِينِ، وإسْكانِ الحاءِ مِن غَيْرِ ألِفٍ، وقَرَأ الباقُونَ بِالألِفِ وفَتْحِ السِينِ وكَسْرِ الحاءِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿أأمِنتُمْ﴾</span> [الملك: ١٦] في بابِ الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  20,70,""
  20,71,""
  20,72,""
  20,73,""
  20,74,""
  20,75,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿يَأْتِهِ مُؤْمِنًا﴾</span> في بابِ هاءِ الكِنايَةِ.</p></div>"
  20,76,""
  20,77,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أنْ أسْرِ﴾</span> لِابْنِ كَثِيرٍ والمَدَنِيَّيْنِ في هُودٍ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لا تَخافُ دَرَكًا﴾</span> فَقَرَأ حَمْزَةُ (تَخَفْ) بِالجَزْمِ، وقَرَأ الباقُونَ بِالرَفْعِ.</p></div>"
  20,78,""
  20,79,""
  20,80,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْجَيْناكُمْ﴾</span> و<span class="qpc-hafs">﴿واعَدْنا﴾</span> [البقرة: ٥١] و<span class="qpc-hafs">﴿رَزَقْناكُمْ﴾</span> [طه: ٨١] فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ، (أنْجَيْتُكُمْ) و(واعَدْتُكُمْ) و(رَزَقْتُكُمْ) بِالتاءِ مَضْمُومَةً عَلى لَفْظِ الواحِدِ مِن غَيْرِ ألِفٍ في الثَلاثَةِ، وقَرَأ الباقُونَ بِالنُونِ مَفْتُوحَةً وألِفٍ بَعْدَها فِيهِنَّ.</p><p>وَتَقَدَّمَ حَذْفُ الألِفِ بَعْدَ الواوِ مِن <span class="qpc-hafs">﴿وَواعَدْناكُمْ﴾</span> لِأبِي جَعْفَرٍ، والبَصْرِيِّينَ في البَقَرَةِ.</p></div>"
  20,81,"<div class=ar lang=ar><p>[انظر الآية ٨٠]</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَيَحِلَّ عَلَيْكُمْ﴾</span>، <span class="qpc-hafs">﴿وَمَن يَحْلِلْ﴾</span> فَقَرَأ الكِسائِيُّ بِضَمِّ الحاءِ مِن (فَيَحُلَّ) واللامِ مِن (يَحْلُلْ)، وقَرَأ الباقُونَ بِكَسْرِ الحاءِ واللامِ مِنهُما.</p></div>"
  20,82,""
  20,83,""
  20,84,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عَلى أثَرِي﴾</span>، فَرَوى رُوَيْسٌ بِكَسْرِ الهَمْزَةِ، وإسْكانِ الثاءِ، وقَرَأ الباقُونَ بِفَتْحِهِما.</p></div>"
  20,85,""
  20,86,"<div class=ar lang=ar><p>(واتَّفَقُوا) عَلى كَسْرِ الحاءِ مِن قَوْلِهِ <span class="qpc-hafs">﴿أمْ أرَدْتُمْ أنْ يَحِلَّ عَلَيْكُمْ﴾</span> لِأنَّ المُرادَ بِهِ الجَوابُ لا النُزُولُ.</p></div>"
  20,87,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بِمَلْكِنا﴾</span> فَقَرَأ المَدَنِيّانِ، وعاصِمٌ، (p-٣٢٢)بِفَتْحِ المِيمِ، وقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِضَمِّها، وقَرَأ الباقُونَ بِكَسْرِها.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿حُمِّلْنا أوْزارًا﴾</span> فَقَرَأ أبُو عَمْرٍو وحَمْزَةُ والكِسائِيُّ وخَلَفٌ وأبُو بَكْرٍ ورَوْحٌ بِفَتْحِ الحاءِ والمِيمِ مُخَفَّفَةً، وقَرَأ الباقُونَ بِضَمِّ الحاءِ وكَسْرِ المِيمِ مُشَدَّدَةً</p><p>وَتَقَدَّمَ يا ابْنَ أُمَّ في الأعْرافِ.</p></div>"
  20,88,""
  20,89,""
  20,90,""
  20,91,""
  20,92,""
  20,93,""
  20,94,""
  20,95,""
  20,96,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يَبْصُرُوا بِهِ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِالخِطابِ، وقَرَأ الباقُونَ بِالغَيْبِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في إدْغامِ <span class="qpc-hafs">﴿فَنَبَذْتُها﴾</span> في بابِ حُرُوفٍ قَرُبَتْ مَخارِجُها، وكَذا <span class="qpc-hafs">﴿فاذْهَبْ فَإنَّ﴾</span> [طه: ٩٧].</p></div>"
  20,97,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَنْ تُخْلَفَهُ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ، والبَصْرِيّانِ بِكَسْرِ اللامِ، وقَرَأ الباقُونَ بِفَتْحِها.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَنُحَرِّقَنَّهُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِإسْكانِ الحاءِ وتَخْفِيفِ الراءِ، وقَرَأ الباقُونَ بِفَتْحِ الحاءِ وتَشْدِيدِ الراءِ، ورَوى ابْنُ ورْدانَ عَنْهُ بِفَتْحِ النُونِ وضَمِّ الراءِ، وهي قِراءَةُ عَلِيِّ بْنِ أبِي طالِبٍ رَضِيَ اللَهُ عَنْهُ، وانْفَرَدَ ابْنُ سَوّارٍ بِهَذا عَنِ ابْنِ جَمّازٍ كَما انْفَرَدَ ابْنُ مِهْرانَ بِالأُولى عَنِ ابْنِ ورْدانَ والصَوابُ كَما ذَكَرْناهُ، وقَرَأ الباقُونَ بِضَمِّ النُونِ وكَسْرِ الراءِ.</p></div>"
  20,98,""
  20,99,""
  20,100,""
  20,101,""
  20,102,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُنْفَخُ في الصُورِ﴾</span> فَقَرَأ أبُو عَمْرٍو بِالنُونِ وفَتْحِها وضَمِّ الفاءِ، وقَرَأ الباقُونَ بِالياءِ وضَمِّها وفَتْحِ الفاءِ.</p></div>"
  20,103,""
  20,104,""
  20,105,""
  20,106,""
  20,107,""
  20,108,""
  20,109,""
  20,110,""
  20,111,""
  20,112,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَلا يَخافُ ظُلْمًا﴾</span> فَقَرَأ ابْنُ كَثِيرٍ (يَخَفْ) بِالجَزْمِ، وقَرَأ الباقُونَ بِالرَفْعِ.</p></div>"
  20,113,""
  20,114,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُقْضى إلَيْكَ وحْيُهُ﴾</span> فَقَرَأ يَعْقُوبُ (نَقْضِيَ) بِالنُونِ وكَسْرِ الضادِ وفَتْحِ الياءِ نَصْبًا عَلى تَسْمِيَةِ الفاعِلِ (وَحْيَهُ) بِالنَصْبِ، وقَرَأ الباقُونَ <span class="qpc-hafs">﴿يُقْضى﴾</span> بِالياءِ مَضْمُومَةً وفَتْحِ الضادِ ورَفْعِ <span class="qpc-hafs">﴿وَحْيُهُ﴾</span></p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِلْمَلائِكَةِ اسْجُدُوا﴾</span> [البقرة: ٣٤] لِأبِي جَعْفَرٍ في البَقَرَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إنَّكَ لا﴾</span> [آل عمران: ١٩٤] فَقَرَأ نافِعٌ وأبُو بَكْرٍ بِكَسْرِ الهَمْزَةِ، وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  20,115,""
  20,116,""
