quran[12]{c,v,t}:
  65,1,""
  65,2,""
  65,3,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بالِغُ أمْرِهِ﴾</span>، فَرَوى حَفْصٌ <span class="qpc-hafs">﴿بالِغُ﴾</span> بِغَيْرِ تَنْوِينٍ <span class="qpc-hafs">﴿أمْرِهِ﴾</span> بِالخَفْضِ، وقَرَأ الباقُونَ بِالتَنْوِينِ والنَصْبِ.</p></div>"
  65,4,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿واللائِي﴾</span> في الهَمْزِ المُفْرَدِ.</p></div>"
  65,5,""
  65,6,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وُجْدِكُمْ﴾</span>، فَرَوى رَوْحٌ بِكَسْرِ الواوِ، وانْفَرَدَ ابْنُ مِهْرانَ بِالخِلافِ عَنْهُ، وقَرَأ الباقُونَ بِضَمِّها.</p></div>"
  65,7,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿عُسْرٍ يُسْرًا﴾</span> لِأبِي جَعْفَرٍ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَكَأيِّنْ﴾</span> [آل عمران: ١٤٦] في آلِ عِمْرانَ والهَمْزِ المُفْرَدِ.</p></div>"
  65,8,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿نُكْرًا﴾</span> في البَقَرَةِ عِنْدَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧].</p></div>"
  65,9,""
  65,10,""
  65,11,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مُبَيِّناتٍ﴾</span> <span class="qpc-hafs">﴿وَيُدْخِلْهُ﴾</span> [التغابن: ٩] في النِساءِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مَرْضاةِ﴾</span> [النساء: ١١٤].</p></div>"
  65,12,""
