quran[88]{c,v,t}:
  38,1,"<div class=ar lang=ar><p>سُورَةُ ص</p><p>تَقَدَّمَ سَكْتُ أبِي جَعْفَرٍ عَلى (ص) في بابِهِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿القُرْآنِ﴾</span> لِابْنِ كَثِيرٍ في بابِ النَقْلِ.</p><p>(وَفِيها مِنَ الإضافَةِ سِتُّ ياءاتٍ) لِيَ نَعْجَةٌ فَتَحَها حَفْصٌ وهِشامٌ بِخِلافٍ عَنْهُ <span class="qpc-hafs">﴿إنِّي أحْبَبْتُ﴾</span> [ص: ٣٢] فَتَحَها المَدَنِيّانِ، وابْنُ كَثِيرٍ وأبُو عَمْرٍو <span class="qpc-hafs">﴿مِن بَعْدِي إنَّكَ﴾</span> [ص: ٣٥] فَتَحَها المَدَنِيّانِ، وأبُو عَمْرٍو <span class="qpc-hafs">﴿لَعْنَتِي إلى﴾</span> [ص: ٧٨] فَتَحَها المَدَنِيّانِ <span class="qpc-hafs">﴿ما كانَ لِيَ مِن عِلْمٍ﴾</span> [ص: ٦٩] فَتَحَها حَفْصٌ <span class="qpc-hafs">﴿مَسَّنِيَ الشَيْطانُ﴾</span> [ص: ٤١] أسْكَنَها حَمْزَةُ.</p><p>(وَمِنَ الزَوائِدِ ياءانِ) عِقابِ وعَذابِ أثْبَتَهُما في الحالَيْنِ يَعْقُوبُ، ولا يَصِحُّ عَنْ قُنْبُلٍ في عَذابِ شَيْءٌ، واللَهُ تَعالى أعْلَمُ.</p></div>"
  38,2,""
  38,3,"<div class=ar lang=ar><p>وَتَقَدَّمَ وقْفُ الكِسائِيِّ عَلى <span class="qpc-hafs">﴿وَلاتَ﴾</span> بِالهاءِ في بابِهِ.</p></div>"
  38,4,""
  38,5,""
  38,6,""
  38,7,""
  38,8,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿أؤُنْزِلَ﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لَيْكَةَ﴾</span> لِابْنِ كَثِيرٍ وابْنِ عامِرٍ والمَدَنِيِّينَ في الشُعَراءِ.</p></div>"
  38,9,""
  38,10,""
  38,11,""
  38,12,""
  38,13,""
  38,14,""
  38,15,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَواقٍ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِضَمِّ الفاءِ، وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  38,16,""
  38,17,""
  38,18,""
  38,19,""
  38,20,""
  38,21,""
  38,22,""
  38,23,""
  38,24,""
  38,25,""
  38,26,""
  38,27,""
  38,28,"<div class=ar lang=ar><p>وَتَقَدَّمَ إمالَةُ <span class="qpc-hafs">﴿كالفُجّارِ﴾</span> في بابِهِ.</p></div>"
  38,29,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِيَدَّبَّرُوا﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِالخِطابِ مَعَ تَخْفِيفِ الدالِ، وقَرَأ الباقُونَ بِالغَيْبِ والتَشْدِيدِ.</p></div>"
  38,30,""
  38,31,""
  38,32,""
  38,33,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿بِالسُوقِ﴾</span> لِقُنْبُلٍ في النَمْلِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿الرِياحِ﴾</span> [البقرة: ١٦٤] في البَقَرَةِ.</p></div>"
  38,34,""
  38,35,""
  38,36,""
  38,37,""
  38,38,""
  38,39,""
  38,40,""
  38,41,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بِنُصْبٍ وعَذابٍ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِضَمِّ النُونِ والصادِ، وقَرَأ يَعْقُوبُ بِفَتْحِها، وقَرَأ الباقُونَ بِضَمِّ النُونِ، وإسْكانِ الصادِ.</p></div>"
  38,42,""
  38,43,""
  38,44,""
  38,45,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿واذْكُرْ عِبادَنا﴾</span> فَقَرَأ ابْنُ كَثِيرٍ عَبْدَنا بِغَيْرِ ألِفٍ عَلى التَوْحِيدِ، وقَرَأ الباقُونَ بِالألِفِ عَلى الجَمْعِ.</p></div>"
  38,46,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بِخالِصَةٍ ذِكْرى﴾</span> فَقَرَأ المَدَنِيّانِ <span class="qpc-hafs">﴿بِخالِصَةٍ﴾</span> بِغَيْرِ تَنْوِينٍ عَلى الإضافَةِ (واخْتُلِفَ) عَنْ هِشامٍ، فَرَوى عَنْهُ الحُلْوانِيُّ كَذَلِكَ، وهي رِوايَةُ ابْنِ عَبّادٍ عَنْهُ، ورَوى عَنْهُ الداجُونِيُّ وسائِرُ أصْحابِهِ بِالتَنْوِينِ، وكَذَلِكَ قَرَأ الباقُونَ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿واليَسَعَ﴾</span> [الأنعام: ٨٦] في الأنْعامِ (وَ<span class="qpc-hafs">﴿مُتَّكِئِينَ﴾</span> [الكهف: ٣١]) في الهَمْزِ المُفْرَدِ.</p></div>"
  38,47,""
  38,48,""
  38,49,""
  38,50,""
  38,51,""
  38,52,""
  38,53,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿هَذا ما تُوعَدُونَ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو <span class="qpc-hafs">﴿بِالغَيْبِ﴾</span> [البقرة: ٣]، وقَرَأ الباقُونَ بِالخِطابِ.</p><p>(واخْتَلَفُوا) فِي: غَسّاقٌ هُنا <span class="qpc-hafs">﴿وَغَسّاقًا﴾</span> [النبإ: ٢٥] في النَبَأِ فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وحَفْصٌ بِتَشْدِيدِ السِينِ في المَوْضِعَيْنِ. وقَرَأ الباقُونَ بِتَخْفِيفِها فِيها.</p></div>"
  38,54,""
  38,55,""
  38,56,""
  38,57,""
  38,58,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَآخَرُ مِن شَكْلِهِ﴾</span> فَقَرَأ البَصْرِيّانِ بِضَمِّ الهَمْزَةِ مِن غَيْرِ مَدٍّ عَلى الجَمْعِ، وقَرَأ الباقُونَ بِفَتْحِ الهَمْزَةِ وألِفٍ بَعْدَها عَلى التَوْحِيدِ.</p></div>"
  38,59,""
  38,60,""
  38,61,""
  38,62,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿مِنَ الأشْرارِ أأتَّخَذْناهُمْ﴾</span> فَقَرَأ البَصْرِيّانِ (p-٣٦٢)، وحَمْزَةُ، والكِسائِيُّ.</p></div>"
  38,63,"<div class=ar lang=ar><p>وَخَلَفٌ بِوَصْلِ هَمْزِ <span class="qpc-hafs">﴿أأتَّخَذْناهُمْ﴾</span> عَلى الخَبَرِ والِابْتِداءِ بِكَسْرِ الهَمْزَةِ، وقَرَأ الباقُونَ بِقَطْعِ الهَمْزَةِ مَفْتُوحَةً عَلى الِاسْتِفْهامِ</p><p>وَتَقَدَّمَ الخِلافُ في <span class="qpc-hafs">﴿سِخْرِيًّا﴾</span> [المؤمنون: ١١٠] في المُؤْمِنِينَ.</p></div>"
  38,64,""
  38,65,""
  38,66,""
  38,67,""
  38,68,""
  38,69,""
  38,70,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إلّا أنَّما أنا﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِكَسْرِ هَمْزَةِ <span class="qpc-hafs">﴿أنَّما﴾</span> عَلى الحِكايَةِ، وقَرَأ الباقُونَ بِفَتْحِها</p><p>وَتَقَدَّمَ الخِلافُ في <span class="qpc-hafs">﴿المُخْلَصِينَ﴾</span> [يوسف: ٢٤] في يُوسُفَ.</p></div>"
  38,71,""
  38,72,""
  38,73,""
  38,74,""
  38,75,""
  38,76,""
  38,77,""
  38,78,""
  38,79,""
  38,80,""
  38,81,""
  38,82,""
  38,83,""
  38,84,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿قالَ فالحَقُّ﴾</span> فَقَرَأ عاصِمٌ وحَمْزَةُ وخَلَفٌ بِالرَفْعِ، وقَرَأ الباقُونَ بِالنَصْبِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لَأمْلَأنَّ﴾</span> [الأعراف: ١٨] لِلْأصْبَهانِيِّ في الهَمْزِ المُفْرَدِ.</p></div>"
