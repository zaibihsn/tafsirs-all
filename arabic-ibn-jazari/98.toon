  98,1,""
  98,2,""
  98,3,""
  98,4,""
  98,5,""
  98,6,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿البَرِيَّةِ﴾</span> لِنافِعٍ وابْنِ ذَكْوانَ في الهَمْزِ المُفْرَدِ.</p></div>"
  98,7,""
  98,8,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿خَشِيَ رَبَّهُ﴾</span> في هاءِ الكِنايَةِ</p></div>"
