quran[88]{c,v,t}:
  28,1,"<div class=ar lang=ar><p>(p-٣٤١)سُورَةُ القَصَصِ</p><p>تَقَدَّمَ اخْتِلافُهم في إمالَةِ " طا "، وسَكْتُ أبِي جَعْفَرٍ وإظْهارُ السِينِ وأئِمَّةً كِلاهُما في أبْوابِهِ.</p><p>(وَفِيها مِن ياءاتِ الإضافَةِ اثْنَتا عَشْرَةَ ياءً) <span class="qpc-hafs">﴿رَبِّي أنْ﴾</span> [القصص: ٢٢] <span class="qpc-hafs">﴿إنِّي آنَسْتُ﴾</span> [القصص: ٢٩] <span class="qpc-hafs">﴿إنِّي أنا اللَهُ﴾</span> [القصص: ٣٠] <span class="qpc-hafs">﴿إنِّي أخافُ﴾</span> [القصص: ٣٤] <span class="qpc-hafs">﴿رَبِّي أعْلَمُ﴾</span> [القصص: ٣٧] مَوْضِعانِ، فَتَحَ السِتَّ المَدَنِيّانِ، وابْنُ كَثِيرٍ وأبُو عَمْرٍو لِعَلِيٍّ مَوْضِعانِ أسْكَنَها فِيهِما يَعْقُوبُ، والكُوفِيُّونَ، <span class="qpc-hafs">﴿إنِّي أُرِيدُ﴾</span> [القصص: ٢٧] <span class="qpc-hafs">﴿سَتَجِدُنِي إنْ شاءَ اللَهُ﴾</span> [القصص: ٢٧] فَتَحَهُما المَدَنِيّانِ <span class="qpc-hafs">﴿مَعِيَ رِدْءًا﴾</span> [القصص: ٣٤] فَتَحَها حَفْصٌ، <span class="qpc-hafs">﴿عِنْدِي أوَلَمْ﴾</span> [القصص: ٧٨] يَفْتَحُها المَدَنِيّانِ، وأبُو عَمْرٍو، واخْتَلَفَ ابْنُ كَثِيرٍ كَما تَقَدَّمَ.</p><p>(وَمِنَ الزَوائِدِ ثِنْتانِ) <span class="qpc-hafs">﴿أنْ يَقْتُلُونِ﴾</span> [القصص: ٣٣] أثْبَتَ الياءَ فِيها في الحالَيْنِ يَعْقُوبُ <span class="qpc-hafs">﴿أنْ يُكَذِّبُونِ﴾</span> [القصص: ٣٤] أثْبَتَها في الوَصْلِ ورْشٌ، وأثْبَتَها في الحالَيْنِ يَعْقُوبُ، واللَهُ تَعالى المُوَفِّقُ.</p></div>"
  28,2,""
  28,3,""
  28,4,""
  28,5,""
  28,6,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَنُرِيَ فِرْعَوْنَ وهامانَ وجُنُودَهُما﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِالياءِ وفَتْحِها، وإمالَةِ فَتْحَةِ الراءِ بَعْدَها ورَفْعِ الأسْماءِ الثَلاثَةِ، وقَرَأ الباقُونَ بِالنُونِ وضَمِّها وكَسْرِ الراءِ وفَتْحِ الياءِ، ونَصْبِ الأسْماءِ الثَلاثَةِ.</p></div>"
  28,7,""
  28,8,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَحَزَنًا﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِضَمِّ الحاءِ، وإسْكانِ الزايِ وقَرَأ الباقُونَ بِفَتْحِهِما.</p></div>"
  28,9,""
  28,10,""
  28,11,""
  28,12,""
  28,13,""
  28,14,""
  28,15,""
  28,16,""
  28,17,""
  28,18,""
  28,19,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿يَبْطِشَ﴾</span> لِأبِي جَعْفَرٍ في الأعْرافِ.</p></div>"
  28,20,""
  28,21,""
  28,22,""
  28,23,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُصْدِرَ الرِعاءُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ وابْنُ عامِرٍ بِفَتْحِ الياءِ وضَمِّ الدالِ، وقَرَأ الباقُونَ بِضَمِّ الياءِ وكَسْرِ الدالِ</p><p>وَتَقَدَّمَ إشْمامُ الصادِ لِحَمْزَةَ والكِسائِيِّ وخَلَفٍ ورُوَيْسٍ في سُورَةِ النِساءِ.</p></div>"
  28,24,""
  28,25,""
  28,26,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿ياأبَتِ﴾</span> في يُوسُفَ والوَقْفِ، وفي <span class="qpc-hafs">﴿هاتَيْنِ﴾</span> [القصص: ٢٧] لِابْنِ كَثِيرٍ في النِساءِ.</p></div>"
  28,27,"<div class=ar lang=ar><p>[انظر الآية ٢٦]</p></div>"
  28,28,""
  28,29,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِأهْلِهِ امْكُثُوا﴾</span> لِحَمْزَةَ مِن هاءِ الكِنايَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿جَذْوَةٍ﴾</span> فَقَرَأ عاصِمٌ بِفَتْحِ الجِيمِ، وقَرَأ حَمْزَةُ وخَلَفٌ بِضَمِّها، وقَرَأ الباقُونَ بِكَسْرِها.</p></div>"
  28,30,""
  28,31,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿رَآها تَهْتَزُّ﴾</span> لِلْأصْبَهانِيِّ في الهَمْزِ المُفْرَدِ، وإمالَتُها أيْضًا في الإمالَةِ.</p></div>"
  28,32,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿الرَهْبِ﴾</span> فَقَرَأ المَدَنِيّانِ، والبَصْرِيّانِ، وابْنُ كَثِيرٍ بِفَتْحِ الراءِ والهاءِ، ورَواهُ حَفْصٌ بِفَتْحِ الراءِ، وإسْكانِ الهاءِ، وقَرَأ الباقُونَ بِضَمِّ الراءِ، وإسْكانِ الهاءِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فَذانِكَ﴾</span> لِابْنِ كَثِيرٍ وأبِي عَمْرٍو ورُوَيْسٍ في النِساءِ.</p></div>"
  28,33,""
  28,34,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿رِدْءًا﴾</span> لِأبِي جَعْفَرٍ ولِنافِعٍ في بابِ النَقْلِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُصَدِّقُنِي﴾</span> فَقَرَأ عاصِمٌ وحَمْزَةُ بِرَفْعِ القافِ، وقَرَأ الباقُونَ بِالجَزْمِ.</p></div>"
  28,35,""
  28,36,""
  28,37,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَقالَ مُوسى﴾</span> فَقَرَأ ابْنُ كَثِيرٍ بِغَيْرِ واوٍ قَبْلَ (قالَ)، وكَذَلِكَ هي في مُصْحَفِ أهْلِ مَكَّةَ، وقَرَأ الباقُونَ بِالواوِ، وكَذَلِكَ هي في مَصاحِفِهِمْ</p><p>وَتَقَدَّمَ ومَن تَكُونُ لَهُ لِحَمْزَةَ والكِسائِيِّ وخَلَفٍ في الأنْعامِ.</p></div>"
  28,38,""
  28,39,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لا يُرْجَعُونَ﴾</span> في البَقَرَةِ.</p></div>"
  28,40,""
  28,41,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أئِمَّةً﴾</span> في بابِ الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  28,42,""
  28,43,""
  28,44,""
  28,45,""
  28,46,""
  28,47,""
  28,48,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿قالُوا سِحْرانِ﴾</span> فَقَرَأ الكُوفِيُّونَ سِحْرانِ بِكَسْرِ السِينِ (p-٣٤٢)، وإسْكانِ الحاءِ مِن غَيْرِ ألِفٍ قَبْلَها، وقَرَأ الباقُونَ بِفَتْحِ السِينِ وألِفٍ بَعْدَها وكَسْرِ الحاءِ.</p></div>"
  28,49,""
  28,50,""
  28,51,""
  28,52,""
  28,53,""
  28,54,""
  28,55,""
  28,56,""
  28,57,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُجْبى﴾</span> فَقَرَأ المَدَنِيّانِ ورُوَيْسٌ بِالتاءِ عَلى التَأْنِيثِ، وقَرَأ الباقُونَ بِالياءِ عَلى التَذْكِيرِ.</p></div>"
  28,58,""
  28,59,"<div class=ar lang=ar><p>وَتَقَدَّمَ في <span class="qpc-hafs">﴿أُمِّها﴾</span> لِحَمْزَةَ والكِسائِيِّ في النِساءِ.</p></div>"
  28,60,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أفَلا تَعْقِلُونَ﴾</span>، فَرَوى الدُورِيُّ عَنْ أبِي عَمْرٍو بِالغَيْبِ، واخْتُلِفَ عَنِ السُوسِيِّ عَنْهُ، فالَّذِي قَطَعَ لَهُ بِهِ كَثِيرٌ مِنَ الأئِمَّةِ أصْحابِ الكُتُبِ - الغَيْبُ، كَذَلِكَ، وهو اخْتِيارُ الدانِيِّ، وشَيْخِهِ أبِي الحَسَنِ بْنِ غَلْبُونَ وابْنِ شُرَيْحٍ ومَكِّيٍّ، وغَيْرِهِمْ، وقَطَعَ لَهُ آخَرُونَ بِالخِطابِ كالأُسْتاذِ أبِي طاهِرِ بْنِ سَوّارٍ والحافِظِ أبِي العَلاءِ، وقَطَعَ جَماعَةٌ لَهُ ولِلدُّورِيِّ، وغَيْرِهِما عَنْ أبِي عَمْرٍو بِالتَخْيِيرِ بَيْنَ الغَيْبِ والخِطابِ عَلى السَواءِ كَأبِي العَبّاسِ المَهْدَوِيِّ وأبِي القاسِمِ الهُذَلِيِّ.</p><p>(قُلْتُ): والوَجْهانِ صَحِيحانِ عَنْ أبِي عَمْرٍو مِن هَذِهِ الطُرُقِ، وغَيْرِهِما إلّا أنَّ الأشْهَرَ عَنْهُ بِالغَيْبِ، وبِهِما آخُذُ في رِوايَةِ السُوسِيِّ لِثُبُوتِ ذَلِكَ عِنْدِي عَنْهُ نَصًّا وأداءً، وبِالخِطابِ قَرَأ الباقُونَ.</p></div>"
  28,61,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿ثُمَّ هُوَ﴾</span> في أوائِلِ البَقَرَةِ.</p></div>"
  28,62,""
  28,63,""
  28,64,""
  28,65,""
  28,66,""
  28,67,""
  28,68,""
  28,69,""
  28,70,""
  28,71,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أرَأيْتُمْ﴾</span> <span class="qpc-hafs">﴿وَضِياءً﴾</span> [الأنبياء: ٤٨] مِنَ الهَمْزِ المُفْرَدِ.</p></div>"
  28,72,""
  28,73,""
  28,74,""
  28,75,""
  28,76,""
  28,77,""
  28,78,""
  28,79,""
  28,80,""
  28,81,""
  28,82,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَيْكَأنَّ﴾</span> و<span class="qpc-hafs">﴿وَيْكَأنَّهُ﴾</span> فِيهِ أيْضًا، وفي الوَقْفِ عَلى المَرْسُومِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَخَسَفَ بِنا﴾</span> فَقَرَأ يَعْقُوبُ وحَفْصٌ بِفَتْحِ الخاءِ والسِينِ، وقَرَأ الباقُونَ بِضَمِّ الخاءِ وكَسْرِ السِينِ.</p></div>"
  28,83,""
  28,84,""
  28,85,""
  28,86,""
  28,87,""
  28,88,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿تُرْجَعُونَ﴾</span> لِيَعْقُوبَ في البَقَرَةِ.</p></div>"
