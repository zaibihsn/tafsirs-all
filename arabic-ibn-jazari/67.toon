quran[30]{c,v,t}:
  67,1,"<div class=ar lang=ar><p>(وَفِيها مِن ياءاتِ الإضافَةِ ياءانِ) <span class="qpc-hafs">﴿أهْلَكَنِيَ اللَهُ﴾</span> [الملك: ٢٨] أسْكَنَها حَمْزَةُ (وَ<span class="qpc-hafs">﴿مَعِيَ أوْ رَحِمَنا﴾</span> [الملك: ٢٨]) أسْكَنَها حَمْزَةُ، والكِسائِيُّ، ويَعْقُوبُ، وخَلَفٌ، وأبُو بَكْرٍ.</p><p>(وَمِنَ الزَوائِدِ ثِنْتانِ) <span class="qpc-hafs">﴿نَذِيرٌ﴾</span> [الملك: ٨] و<span class="qpc-hafs">﴿نَكِيرِ﴾</span> [الملك: ١٨] أثْبَتَهُما وصْلًا ورْشٌ، وفي الحالَيْنِ يَعْقُوبُ.</p></div>"
  67,2,""
  67,3,"<div class=ar lang=ar><p>وَمِن سُورَةِ المُلْكِ إلى سُورَةِ الجِنِّ</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَفاوُتٍ﴾</span> فَقَرَأ حَمْزَةُ، والكِسائِيُّ، " تَفَوُّتٍ " بِضَمِّ الواوِ مُشَدَّدَةً مِن غَيْرِ ألِفٍ، وقَرَأ الباقُونَ بِألِفٍ والتَخْفِيفِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿هَلْ تَرى﴾</span> في بابِهِ.</p></div>"
  67,4,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿خاسِئًا﴾</span> في الهَمْزِ المُفْرَدِ لِأبِي جَعْفَرٍ والأصْبَهانِيِّ</p><p>وَتَقَدَّمَ (تَكادُ تَّمَيَّزُ) في تاءاتِ البَزِّيِّ مِنَ البَقَرَةِ</p><p>وَتَقَدَّمَ " سُحْقًا " في البَقَرَةِ عِنْدَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧].</p></div>"
  67,5,""
  67,6,""
  67,7,""
  67,8,""
  67,9,""
  67,10,""
  67,11,""
  67,12,""
  67,13,""
  67,14,""
  67,15,""
  67,16,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أأمِنتُمْ﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةِ</p></div>"
  67,17,"<div class=ar lang=ar><p>(واتَّفَقُوا) عَلى الأوَّلِ أنَّهُ بِالخِطابِ، وهُوَ<span class="qpc-hafs">﴿فَسَتَعْلَمُونَ كَيْفَ نَذِيرِ﴾</span> لِاتِّصالِهِ بِالخِطابِ.</p></div>"
  67,18,""
  67,19,""
  67,20,""
  67,21,""
  67,22,""
  67,23,""
  67,24,""
  67,25,""
  67,26,""
  67,27,"<div class=ar lang=ar><p>وَ<span class="qpc-hafs">﴿سِيئَتْ﴾</span> و<span class="qpc-hafs">﴿قِيلَ﴾</span> [البقرة: ١١] في أوائِلِ البَقَرَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بِهِ تَدَّعُونَ﴾</span> فَقَرَأ يَعْقُوبُ بِإسْكانِ الدالِ مُخَفَّفَةً، وقَرَأ الباقُونَ بِفَتْحِها مُشَدَّدَةً.</p></div>"
  67,28,""
  67,29,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَسَتَعْلَمُونَ مَن هُوَ﴾</span> فَقَرَأ الكِسائِيُّ بِالغَيْبِ، وقَرَأ الباقُونَ بِالخِطابِ.</p></div>"
  67,30,""
