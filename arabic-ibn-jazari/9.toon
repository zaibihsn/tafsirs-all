quran[129]{c,v,t}:
  9,1,"<div class=ar lang=ar><p>(وَفِيها مِن ياءاتِ الإضافَةِ ثِنْتانِ) <span class="qpc-hafs">﴿مَعِيَ أبَدًا﴾</span> [التوبة: ٨٣] أسْكَنَها يَعْقُوبُ وحَمْزَةُ والكِسائِيُّ وخَلَفٌ وأبُو بَكْرٍ <span class="qpc-hafs">﴿مَعِيَ عَدُوًّا﴾</span> [التوبة: ٨٣] فَتَحَها حَفْصٌ واللَهُ المُسْتَعانُ.</p></div>"
  9,2,""
  9,3,""
  9,4,""
  9,5,""
  9,6,""
  9,7,""
  9,8,""
  9,9,""
  9,10,""
  9,11,""
  9,12,"<div class=ar lang=ar><p>(p-٢٧٨)سُورَةُ التَوْبَةِ</p><p>تَقَدَّمَ اخْتِلافُهم في الهَمْزَةِ الثانِيَةِ مِن <span class="qpc-hafs">﴿أئِمَّةَ الكُفْرِ﴾</span> في بابِ الهَمْزَتَيْنِ مِن كُلِّ كَلِمَةٍ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لا أيْمانَ لَهُمْ﴾</span> فَقَرَأ ابْنُ عامِرٍ بِكَسْرِ الهَمْزَةِ عَلى أنَّهُ مَصْدَرُهُ، وقَرَأ الباقُونَ عَلى أنَّهُ جَمْعٌ.</p></div>"
  9,13,""
  9,14,""
  9,15,"<div class=ar lang=ar><p>وانْفَرَدَ ابْنُ العَلّافِ عَنِ النَخّاسِ عَنْ رُوَيْسٍ في <span class="qpc-hafs">﴿وَيَتُوبُ اللَهُ﴾</span> بِنَصْبِ الباءِ عَلى أنَّهُ جَوابُ الأمْرِ مِن حَيْثُ إنَّهُ دَخَلَ فِيهِ مِن جِهَةِ المَعْنى; قالَ ابْنُ عَطِيَّةَ: يَعْنِي أنَّ قَتْلَ الكُفّارِ والجِهادَ في سَبِيلِ اللَهِ تَوْبَةٌ لَكم أيُّها المُؤْمِنُونَ; وقالَ غَيْرُهُ: يُحْتَمَلُ أنْ يَكُونَ ذَلِكَ بِالنِسْبَةِ إلى الكُفّارِ لِأنَّ قِتالَ الكُفّارِ وغَلَبَةَ المُسْلِمِينَ عَلَيْهِمْ يَنْشَأُ عَنْها إسْلامُ كَثِيرٍ مِنَ الناسِ، وهي رِوايَةُ رَوْحِ بْنِ قُرَّةَ وفَهْدِ بْنِ الصَقْرِ كِلاهُما عَنْ يَعْقُوبَ، ورِوايَةُ يُونُسَ عَنْ أبِي عَمْرٍو، وقِراءَةُ زَيْدِ بْنِ عَلِيٍّ واخْتِيارُ الزَعْفَرانِيِّ.</p></div>"
  9,16,""
  9,17,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْ يَعْمُرُوا مَساجِدَ اللَهِ﴾</span> فَقَرَأ البَصْرِيّانِ، وابْنُ كَثِيرٍ (مَسْجِدَ اللَهِ) عَلى التَوْحِيدِ، وقَرَأ الباقُونَ بِالجَمْعِ.</p></div>"
  9,18,"<div class=ar lang=ar><p>(واتَّفَقُوا) عَلى الجَمْعِ بِالحَرْفِ الثانِي <span class="qpc-hafs">﴿إنَّما يَعْمُرُ مَساجِدَ اللَهِ﴾</span> لِأنَّهُ يُرِيدُ جَمِيعَ المَساجِدِ.</p></div>"
  9,19,"<div class=ar lang=ar><p>وانْفَرَدَ الشَطَوِيُّ عَنِ ابْنِ هارُونَ في رِوايَةِ ابْنِ ورْدانَ في <span class="qpc-hafs">﴿سِقايَةَ الحاجِّ وعِمارَةَ المَسْجِدِ﴾</span> " سُقاةَ " بِضَمِّ السِينِ وحَذْفِ الياءِ بَعْدَ الألِفِ جَمْعُ ساقٍ كَرامٍ ورُماةٍ و" عَمَرَةَ " بِفَتْحِ العَيْنِ وحَذْفِ الألِفِ جَمْعُ عامِرٍ مِثْلُ صانِعٍ وصَنَعَةٍ، وهي رِوايَةُ مَيْمُونَةَ والقُورَسِيِّ عَنْ أبِي جَعْفَرٍ، وكَذا رَوى أحْمَدُ بْنُ جُبَيْرٍ الأنْطاكِيُّ عَنِ ابْنِ جَمّازٍ، وهي قِراءَةُ عَبْدِ اللَهِ بْنِ الزُبَيْرِ، وقَدْ رَأيْتُهُما في المَصاحِفِ القَدِيمَةِ مَحْذُوفَتَيِ الألِفِ كَقِيامَةٍ وجِمالَةٍ ; ثُمَّ رَأيْتُها كَذَلِكَ في مُصْحَفِ المَدِينَةِ الشَرِيفَةِ، ولَمْ أعْلَمْ أحَدًا نَصَّ عَلى إثْباتِ الألِفِ فِيهِما، ولا في إحْداهُما، وهَذِهِ الرِوايَةُ تَدُلُّ عَلى حَذْفِها مِنهُما: إذْ هي مُحْتَمِلَةٌ الرَسْمَ، وقَرَأ الباقُونَ بِكَسْرِ السِينِ وبِياءٍ مَفْتُوحَةٍ بَعْدَ الألِفِ وبِكَسْرِ العَيْنِ وبِألِفٍ بَعْدَ المِيمِ.</p></div>"
  9,20,""
  9,21,"<div class=ar lang=ar><p>وَتَقَدَّمَ الخِلافُ في <span class="qpc-hafs">﴿يُبَشِّرُهُمْ﴾</span> في آلِ عِمْرانَ.</p></div>"
  9,22,""
  9,23,""
  9,24,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَعَشِيرَتُكُمْ﴾</span>، فَرَوى أبُو بَكْرٍ بِالألِفِ عَلى الجَمْعِ، وقَرَأ (p-٢٧٩)الباقُونَ بِغَيْرِ ألِفٍ عَلى الإفْرادِ.</p><p>(واتَّفَقُوا) مِن هَذِهِ الطُرُقِ عَلى الإفْرادِ في المُجادَلَةِ لِأنَّ المَقامَ لَيْسَ مَقامَ بَسْطٍ، ولا إطْنابٍ، ألا تَراهُ عَدَّدَ هُنا ما لَمْ يُعَدِّدْهُ في المُجادَلَةِ وأتى هُنا بِالواوِ وهُناكَ بِـ " أوْ " ؟ - واللَهُ أعْلَمُ -.</p><p>.</p></div>"
  9,25,""
  9,26,""
  9,27,""
  9,28,""
  9,29,""
  9,30,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عُزَيْرٌ ابْنُ﴾</span> فَقَرَأ عاصِمٌ والكِسائِيُّ ويَعْقُوبُ، وكَسْرِهِ حالَةَ الوَصْلِ، ولا يَجُوزُ ضَمُّهُ في مَذْهَبِ الكِسائِيِّ لِأنَّ الضَمَّةَ في ابْنُ ضَمَّةُ إعْرابٍ، وقَرَأ الباقُونَ بِغَيْرِ تَنْوِينٍ.</p><p>وَتَقَدَّمَ هَمْزُ <span class="qpc-hafs">﴿يُضاهِئُونَ﴾</span> لِعاصِمٍ في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
  9,31,""
  9,32,""
  9,33,""
  9,34,""
  9,35,""
  9,36,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿اثْنا عَشَرَ﴾</span> و<span class="qpc-hafs">﴿أحَدَ عَشَرَ﴾</span> [يوسف: ٤] و<span class="qpc-hafs">﴿تِسْعَةَ عَشَرَ﴾</span> [المدثر: ٣٠] فَقَرَأ أبُو جَعْفَرٍ بِإسْكانِ العَيْنِ مِنَ الثَلاثَةِ، ولا بُدَّ مِن مَدِّ ألِفِ <span class="qpc-hafs">﴿اثْنا﴾</span> لِالتِقاءِ الساكِنَيْنِ، نَصَّ عَلى ذَلِكَ الحافِظُ أبُو عَمْرٍو الدانِيُّ، وغَيْرُهُ، وهي رِوايَةُ هُبَيْرَةَ عَنْ حَفْصٍ مِن طُرُقِ فارِسِ بْنِ أحْمَدَ، وقَرَأهُ شَيْبَةُ وطَلْحَةُ فِيما رَواهُ الحُلْوانِيُّ عَنْهُ.</p><p>وَقَدْ تَقَدَّمَ وجْهُ مَدِّهِ في بابِ المَدِّ، وقِيلَ لَيْسَ مِن ذَلِكَ، بَلْ هو فَصِيحٌ سُمِعَ مِثْلُهُ مِنَ العَرَبِ في قَوْلِهِمُ التَقَتْ حَلْقَتا البَطّانِ: بِإثْباتِ ألِفِ حَلْقَتا، وانْفَرَدَ النَهْرَوانِيُّ عَنْ زَيْدٍ في رِوايَةِ ابْنِ ورْدانَ بِحَذْفِ الألِفِ، وهي لُغَةٌ أيْضًا، وقَرَأ الباقُونَ بِفَتْحِ العَيْنِ في الثَلاثَةِ.</p></div>"
  9,37,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿النَسِيءُ﴾</span> في بابِ الهَمْزِ المُفْرَدِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُضِلُّ بِهِ﴾</span> [البقرة: ٢٦] فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وحَفْصٌ بِضَمِّ الياءِ وفَتْحِ الضادِ، وقَرَأ يَعْقُوبُ بِضَمِّ الياءِ وكَسْرِ الضادِ، وقَرَأ الباقُونَ بِفَتْحِ الياءِ وكَسْرِ الضادِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِيُواطِئُوا﴾</span>. و<span class="qpc-hafs">﴿أنْ يُطْفِئُوا﴾</span> [التوبة: ٣٢] لِأبِي جَعْفَرٍ في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
  9,38,""
  9,39,""
  9,40,"<div class=ar lang=ar><p>وَتَقَدَّمَ ذِكْرُ <span class="qpc-hafs">﴿الغارِ﴾</span> في بابِ الإمالَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَكَلِمَةُ اللَهِ هِيَ﴾</span> فَقَرَأ يَعْقُوبُ بِنَصْبِ تاءِ التَأْنِيثِ، وقَرَأ الباقُونَ بِالرَفْعِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿كَرْهًا﴾</span> [النساء: ١٩] في سُورَةِ النِساءِ.</p></div>"
  9,41,""
  9,42,""
  9,43,""
  9,44,""
  9,45,""
  9,46,""
  9,47,""
  9,48,""
  9,49,""
  9,50,""
  9,51,""
  9,52,""
  9,53,""
  9,54,"<div class=ar lang=ar><p>(واخْتَلَفُوا) في <span class="qpc-hafs">﴿أنْ تُقْبَلَ مِنهُمْ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِالياءِ عَلى التَذْكِيرِ، وقَرَأ الباقُونَ بِالتاءِ عَلى التَأْنِيثِ وما حَكاهُ الإمامُ أبُو عُبَيْدٍ في كِتابِهِ مِنَ التَذْكِيرِ عَنْ عاصِمٍ ونافِعٍ فَهو غَلَطٌ، نَصَّ عَلى ذَلِكَ الحافِظُ أبُو عَمْرٍو.</p></div>"
  9,55,""
  9,56,""
  9,57,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أوْ مُدَّخَلًا﴾</span> فَقَرَأ يَعْقُوبُ بِفَتْحِ المِيمِ، وإسْكانِ الدالِ مُخَفَّفَةً، وقَرَأ الباقُونَ بِضَمِّ المِيمِ وفَتْحِ الدالِ مُشَدَّدَةً.</p></div>"
  9,58,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يَلْمِزُكَ﴾</span> و<span class="qpc-hafs">﴿يَلْمِزُونَ﴾</span> [التوبة: ٧٩] و<span class="qpc-hafs">﴿تَلْمِزُوا﴾</span> [الحجرات: ١١] (p-٢٨٠)فَقَرَأ يَعْقُوبُ بِضَمِّ المِيمِ مِنَ الثَلاثَةِ وقَرَأ الباقُونَ بِكَسْرِها مِنها.</p></div>"
  9,59,""
  9,60,""
  9,61,"<div class=ar lang=ar><p>وَتَقَدَّمَ ذِكْرُ إسْكانِ <span class="qpc-hafs">﴿أُذُنٌ﴾</span> لِنافِعٍ في سُورَةِ البَقَرَةِ عِنْدَ ذِكْرِ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧].</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَرَحْمَةٌ لِلَّذِينَ آمَنُوا﴾</span> فَقَرَأ حَمْزَةُ بِالخَفْضِ، وقَرَأ الباقُونَ بِالرَفْعِ.</p></div>"
  9,62,""
  9,63,""
  9,64,""
  9,65,""
  9,66,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إنْ نَعْفُ عَنْ طائِفَةٍ مِنكم نُعَذِّبْ طائِفَةً﴾</span> فَقَرَأ عاصِمٌ <span class="qpc-hafs">﴿نَعْفُ﴾</span> بِنُونٍ مَفْتُوحَةٍ وضَمِّ الفاءِ <span class="qpc-hafs">﴿نُعَذِّبْ﴾</span> بِالنُونِ وكَسْرِ الذالِ <span class="qpc-hafs">﴿طائِفَةٌ﴾</span> [آل عمران: ٦٩] بِالنَصْبِ، وقَرَأ الباقُونَ <span class="qpc-hafs">﴿وَيَعْفُ﴾</span> [الشورى: ٣٤] بِياءٍ مَضْمُومَةٍ وفَتْحِ الفاءِ " تَعَذَّبْ " بِتاءٍ مَضْمُومَةٍ وفَتْحِ الذالِ <span class="qpc-hafs">﴿طائِفَةٌ﴾</span> [آل عمران: ٦٩] بِالرَفْعِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿والمُؤْتَفِكاتُ﴾</span> [الحاقة: ٩] في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
