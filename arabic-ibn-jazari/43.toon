quran[89]{c,v,t}:
  43,1,"<div class=ar lang=ar><p>(وَفِيها مِنَ الإضافَةِ ياءانِ) <span class="qpc-hafs">﴿مِن تَحْتِي أفَلا﴾</span> [الزخرف: ٥١] فَتَحَها المَدَنِيّانِ، وأبُو عَمْرٍو والبَزِّيُّ، وكَذَلِكَ انْفَرَدَ الكارَزِينِيُّ عَنِ الشَطَوِيِّ عَنِ ابْنِ شَنَبُوذَ عَنْ قُنْبُلٍ كَما تَقَدَّمَ. <span class="qpc-hafs">﴿ياعِبادِ لا خَوْفٌ عَلَيْكُمُ﴾</span> [الزخرف: ٦٨] فَتَحَها أبُو بَكْرٍ ورُوَيْسٌ بِخِلافٍ عَنْهُ ووَقَفَ عَلَيْها بِالياءِ، وأسْكَنَها المَدَنِيّانِ، وأبُو عَمْرٍو وابْنُ عامِرٍ ووَقَفُوا عَلَيْها كَذَلِكَ لِأنَّها في مَصاحِفِ المَدِينَةِ والشامِ ثابِتَةٌ، وحَذَفَها الباقُونَ في الحالَيْنِ لِأنَّها كَذَلِكَ في مَصاحِفِهِمْ، وقالَ الإمامُ أبُو عَمْرِو بْنُ العَلاءِ: رَأيْتُها في مَصاحِفِ المَدِينَةِ والحِجازِ بِالياءِ.</p><p>(وَمِنَ الزَوائِدِ ثَلاثٌ) <span class="qpc-hafs">﴿سَيَهْدِينِ﴾</span> [الزخرف: ٢٧]، <span class="qpc-hafs">﴿وَأطِيعُونِ﴾</span> [الزخرف: ٦٣] أثْبَتَهُما في الحالَيْنِ يَعْقُوبُ <span class="qpc-hafs">﴿واتَّبِعُونِ﴾</span> [الزخرف: ٦١] أثْبَتَها وصْلًا أبُو جَعْفَرٍ وأبُو عَمْرٍو، وفي الحالَيْنِ يَعْقُوبُ، ورُوِيَ إثْباتُها عَنْ قُنْبُلٍ مِن طَرِيقِ ابْنِ شَنَبُوذَ كَما تَقَدَّمَ.</p></div>"
  43,2,""
  43,3,""
  43,4,"<div class=ar lang=ar><p>سُورَةُ الزُخْرُفِ</p><p>تَقَدَّمَ الإمالَةُ والسَكْتُ في بابِهِما</p><p>وَتَقَدَّمَ في <span class="qpc-hafs">﴿أُمِّ الكِتابِ﴾</span> في النِساءِ.</p></div>"
  43,5,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أنْ كُنْتُمْ﴾</span> فَقَرَأ المَدَنِيّانِ، وحَمْزَةُ والكِسائِيُّ وخَلَفٌ بِكَسْرِ الهَمْزَةِ. وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  43,6,""
  43,7,""
  43,8,""
  43,9,""
  43,10,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مَهْدًا﴾</span> في طه.</p></div>"
  43,11,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مَيْتًا﴾</span> في البَقَرَةِ. <span class="qpc-hafs">﴿وَتُخْرِجُونَ﴾</span> [البقرة: ٨٥] في الأعْرافِ.</p></div>"
  43,12,""
  43,13,""
  43,14,""
  43,15,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿جُزْءًا﴾</span> في البَقَرَةِ، وفي الهَمْزِ المُفْرَدِ.</p></div>"
  43,16,""
  43,17,""
  43,18,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُنَشَّأُ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ وحَفْصٌ بِضَمِّ الياءِ وفَتْحِ النُونِ وتَشْدِيدِ الشِينِ، وقَرَأ الباقُونَ بِفَتْحِ الياءِ، وإسْكانِ النُونِ وتَخْفِيفِ الشِيِنِ.</p></div>"
  43,19,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عِبادُ الرَحْمَنِ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ وابْنُ عامِرٍ ويَعْقُوبُ (عِنْدَ) بِالنُونِ ساكِنَةً وفَتْحِ الدالِ مِن غَيْرِ ألِفٍ عَلى أنَّهُ ظَرْفٌ. وقَرَأ الباقُونَ بِالباءِ وألِفٍ بَعْدَها ورَفْعِ الدالِ، جَمْعُ عَبْدٍ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أشَهِدُوا﴾</span> فَقَرَأهَ المَدَنِيّانِ (أأُشْهِدُوا) بِهَمْزَتَيْنِ الأُولى (p-٣٦٩)مَفْتُوحَةٌ والثانِيَةُ مَضْمُومَةٌ مُسَهَّلَةٌ، عَلى أصْلِهِما مَعَ إسْكانِ الشِينِ، وفَصَلَ بَيْنَهُما بِألِفٍ أبُو جَعْفَرٍ وقالُونُ بِخِلافٍ عَلى أصْلِهِما المُتَقَدِّمِ في بابِ الهَمْزَتَيْنِ مِن كَلِمَةٍ. وقَرَأ الباقُونَ بِهَمْزَةٍ واحِدَةٍ مَفْتُوحَةٍ وفَتْحِ الشِينَ.</p><p>(واخْتَلَفُوا) فِي: (<span class="qpc-hafs">﴿قُلْ أوَلَوْ﴾</span> [الزمر: ٤٣]) فَقَرَأ ابْنُ عامِرٍ وحَفْصٌ قالَ عَلى الخَبَرِ، وقَرَأ الباقُونَ (قُلْ) عَلى الأمْرِ.</p></div>"
  43,20,""
  43,21,""
  43,22,""
  43,23,""
  43,24,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أوَلَوْ جِئْتُكُمْ﴾</span> فَقَرَأ أبُو جَعْفَرٍ (جِئْناكُمْ) بِنُونٍ وألِفٍ عَلى الجَمْعِ، وهو في إبْدالِ الهَمْزِ والصِلَةِ عَلى أصْلِهِ. وقَرَأ الباقُونَ بِالتاءِ مَضْمُومَةً عَلى التَوْحِيدِ، وهم عَلى أُصُولِهِمْ أيْضًا.</p></div>"
  43,25,""
  43,26,""
  43,27,""
  43,28,""
  43,29,""
  43,30,""
  43,31,""
  43,32,""
  43,33,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿سُقُفًا﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو وأبُو جَعْفَرٍ بِفَتْحِ السِينِ، وإسْكانِ القافِ، وقَرَأ الباقُونَ بِضَمِّها.</p></div>"
  43,34,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿يَتَّكِئُونَ﴾</span> في الهَمْزِ المُفْرَدِ لِأبِي جَعْفَرٍ</p><p>وَتَقَدَّمَ لَمّا هو في هُودٍ لِعاصِمٍ وحَمْزَةَ وابْنٍ جَمّازٍ وهِشامٍ بِخِلافٍ.</p></div>"
  43,35,""
  43,36,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿نُقَيِّضْ لَهُ﴾</span> فَقَرَأ يَعْقُوبُ بِالياءِ، واخْتُلِفَ عَنْ أبِي بَكْرٍ، فَرَوى عَنْهُ العُلَيْمِيُّ كَذَلِكَ، وكَذا رَوى خَلَفٌ عَنْ يَحْيى. وكَذا رَوى أبُو الحَسَنِ الخَيّاطُ عَنْ شُعَيْبٍ الصَرِيفِينِيِّ عَنْ يَحْيى، وهي رِوايَةُ عِصْمَةَ عَنْ أبِي بَكْرٍ، ورَوى يَحْيى مِن سائِرِ طُرُقِهِ بِالنُونِ، وكَذا رَوى سائِرُ الرُواةِ عَنْ أبِي بَكْرٍ، وبِذَلِكَ قَرَأ الباقُونَ.</p></div>"
  43,37,""
  43,38,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿حَتّى إذا جاءَنا﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ وابْنُ عامِرٍ وأبُو بَكْرٍ بِألِفٍ بَعْدَ هَمْزَةٍ عَلى التَثْنِيَةِ، وقَرَأ الباقُونَ بِغَيْرِ ألِفٍ عَلى التَوْحِيدِ، وكُلٌّ في إمالَتِهِ وفَتْحِهِ عَلى أصْلِهِ.</p></div>"
  43,39,""
  43,40,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أفَأنْتَ﴾</span> لِلْأصْبَهانِيِّ في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
  43,41,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿نَذْهَبَنَّ بِكَ﴾</span>.</p></div>"
  43,42,"<div class=ar lang=ar><p>وَ<span class="qpc-hafs">﴿نُرِيَنَّكَ﴾</span> لِرُوَيْسٍ في أواخِرِ آلِ عِمْرانَ</p><p>وَتَقَدَّمَ رُسُلٌ في بابِ النَقْلِ.</p></div>"
  43,43,""
  43,44,""
  43,45,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿رُسُلِنا﴾</span> في البَقَرَةِ.</p></div>"
  43,46,""
  43,47,""
  43,48,""
  43,49,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿ياأيُّها الساحِرُ﴾</span> في الوَقْفِ عَلى الرَسْمِ.</p></div>"
  43,50,""
  43,51,""
  43,52,""
  43,53,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أسْوِرَةٌ﴾</span> فَقَرَأ يَعْقُوبُ وحَفْصٌ <span class="qpc-hafs">﴿أسْوِرَةٌ﴾</span> بِإسْكانِ السِينِ مِن غَيْرِ ألِفٍ، وانْفَرَدَ ابْنُ العَلّافِ عَنِ النَخّاسِ عَنِ التَمّارِ عَنْ رُوَيْسٍ بِفَتْحِ السِينِ وألِفٍ بَعْدَها، وكَذَلِكَ قَرَأ الباقُونَ.</p></div>"
  43,54,""
  43,55,""
  43,56,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿سَلَفًا﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ بِضَمِّ السِينِ واللامِ، وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  43,57,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ، والبَصْرِيّانِ، وعاصِمٌ وحَمْزَةُ بِكَسْرِ الصادِ، وقَرَأ الباقُونَ بِضَمِّها.</p></div>"
  43,58,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أآلِهَتُنا﴾</span> (p-٣٧٠)فِي الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  43,59,""
  43,60,""
  43,61,""
  43,62,""
  43,63,""
  43,64,""
  43,65,""
  43,66,""
  43,67,""
  43,68,""
  43,69,""
  43,70,""
  43,71,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَشْتَهِيهِ الأنْفُسُ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ عامِرٍ وحَفْصٌ <span class="qpc-hafs">﴿تَشْتَهِيهِ﴾</span> بِزِيادَةِ هاءِ ضَمِيرِ مُذَكَّرٍ بَعْدَ الياءِ، وكَذَلِكَ هو في المَصاحِفِ المَدَنِيَّةِ، والشامِيَّةِ. وقَرَأ الباقُونَ بِحَذْفِ الهاءِ، وكَذَلِكَ هو في مَصاحِفِ مَكَّةَ والعِراقِ.</p></div>"
  43,72,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أُورِثْتُمُوها﴾</span> في حُرُوفٍ قَرُبَتْ مَخارِجُها.</p></div>"
  43,73,""
  43,74,""
  43,75,""
  43,76,""
  43,77,""
  43,78,""
  43,79,""
  43,80,""
  43,81,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَلَدٌ﴾</span> في مَرْيَمَ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فَأنا أوَّلُ﴾</span> في البَقَرَةِ.</p></div>"
  43,82,""
  43,83,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُلاقُوا﴾</span> هُنا والطُورِ والمَعارِجِ، فَقَرَأ أبُو جَعْفَرٍ بِفَتْحِ الياءِ، وإسْكانِ اللامِ وفَتْحِ القافِ مِن غَيْرِ ألِفٍ قَبْلَها في الثَلاثَةِ، وقَرَأ الباقُونَ بِضَمِّ الياءِ وفَتْحِ اللامِ وألِفٍ بَعْدَها وضَمِّ القافِ فِيهِنَّ، ولَمْ يَذْكُرْها ابْنُ مِهْرانَ في كُتُبِهِ البَتَّةَ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَإلَيْهِ يُرْجَعُونَ﴾</span> [آل عمران: ٨٣] فَقَرَأ ابْنُ كَثِيرٍ وحَمْزَةُ والكِسائِيُّ وخَلَفٌ ورُوَيْسٌ بِالغَيْبِ، وقَرَأ الباقُونَ بِالخِطابِ ويَعْقُوبُ عَلى أصْلِهِ في فَتْحِ حَرْفِ المُضارَعَةِ وكَسْرِ الجِيمِ.</p></div>"
  43,84,""
  43,85,""
  43,86,""
  43,87,""
  43,88,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَقِيلِهِ﴾</span> فَقَرَأ حَمْزَةُ وعاصِمٌ بِخَفْضِ اللامِ وكَسْرِ الهاءِ، وقَرَأ الباقُونَ بِنَصْبِ اللامِ وضَمِّ الهاءِ.</p></div>"
  43,89,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ عامِرٍ بِالخِطابِ، وقَرَأ الباقُونَ بِالغَيْبِ.</p></div>"
