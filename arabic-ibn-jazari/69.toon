quran[52]{c,v,t}:
  69,1,""
  69,2,""
  69,3,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أدْراكَ﴾</span> في الإمالَةِ.</p></div>"
  69,4,""
  69,5,""
  69,6,""
  69,7,""
  69,8,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿فَهَلْ تَرى لَهُمْ﴾</span> في بابِهِ.</p></div>"
  69,9,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿قَبْلَهُ﴾</span> فَقَرَأ البَصْرِيّانِ، والكِسائِيُّ بِكَسْرِ القافِ وفَتْحِ الباءِ، وقَرَأ الباقُونَ بِفَتْحِ القافِ، وإسْكانِ الباءِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿والمُؤْتَفِكاتُ بِالخاطِئَةِ﴾</span> في الهَمْزِ المُفْرَدِ.</p></div>"
  69,10,""
  69,11,""
  69,12,""
  69,13,""
  69,14,""
  69,15,""
  69,16,""
  69,17,""
  69,18,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لا تَخْفى﴾</span> فَقَرَأ حَمْزَةُ، والكِسائِيُّ، وخَلَفٌ بِالياءِ عَلى التَذْكِيرِ، وقَرَأ الباقُونَ (p-٣٩٠)بِالتاءِ عَلى التَأْنِيثِ.</p></div>"
  69,19,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿كِتابِيَهْ﴾</span> و<span class="qpc-hafs">﴿حِسابِيَهْ﴾</span> [الحاقة: ٢٠] و<span class="qpc-hafs">﴿مالِيَهْ﴾</span> [الحاقة: ٢٨] و<span class="qpc-hafs">﴿سُلْطانِيَهْ﴾</span> [الحاقة: ٢٩] في الوَقْفِ عَلى المَرْسُومِ.</p></div>"
  69,20,"<div class=ar lang=ar><p>[انظر الآية ١٩]</p></div>"
