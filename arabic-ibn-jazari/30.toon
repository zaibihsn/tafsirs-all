quran[60]{c,v,t}:
  30,1,"<div class=ar lang=ar><p>سُورَةُ الرُومِ</p><p>تَقَدَّمَ مَذْهَبُ أبِي جَعْفَرٍ في السَكْتِ عَلى الحُرُوفِ.</p></div>"
  30,2,""
  30,3,""
  30,4,""
  30,5,""
  30,6,""
  30,7,""
  30,8,""
  30,9,""
  30,10,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿عاقِبَةَ الَّذِينَ أساءُوا﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ، والبَصْرِيّانِ بِالرَفْعِ، وقَرَأ الباقُونَ بِالنَصْبِ.</p></div>"
  30,11,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إلَيْهِ يُرْجَعُونَ﴾</span> فَقَرَأ أبُو عَمْرٍو وأبُو بَكْرٍ ورَوْحٌ بِالغَيْبِ، وقَرَأ الباقُونَ بِالخِطابِ. ويَعْقُوبُ عَلى أصْلِهِ.</p></div>"
  30,12,""
  30,13,""
  30,14,""
  30,15,""
  30,16,""
  30,17,""
  30,18,""
  30,19,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿المَيِّتِ﴾</span> في المَوْضِعَيْنِ عِنْدَ <span class="qpc-hafs">﴿المَيْتَةَ﴾</span> [البقرة: ١٧٣] في سُورَةِ البَقَرَةِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَكَذَلِكَ تُخْرَجُونَ﴾</span> في الأعْرافِ.</p></div>"
  30,20,""
  30,21,""
  30,22,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِلْعالِمِينَ﴾</span>، فَرَوى حَفْصٌ بِكَسْرِ اللامِ.</p></div>"
  30,23,""
  30,24,""
  30,25,""
  30,26,""
  30,27,""
  30,28,""
