quran[62]{c,v,t}:
  53,1,"<div class=ar lang=ar><p>سُورَةُ والنَجْمِ</p><p>تَقَدَّمَ مَذْهَبُهم في إمالَةِ رُءُوسِ آيِها.</p></div>"
  53,2,""
  53,3,""
  53,4,""
  53,5,""
  53,6,""
  53,7,""
  53,8,""
  53,9,""
  53,10,""
  53,11,"<div class=ar lang=ar><p>وَكَذا <span class="qpc-hafs">﴿رَأى﴾</span> و<span class="qpc-hafs">﴿رَآهُ﴾</span> [النجم: ١٣] في الإمالَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ وهِشامٌ بِتَشْدِيدِ الذالِ، وقَرَأ الباقُونَ بِتَخْفِيفِها.</p></div>"
  53,12,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أفَتُمارُونَهُ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ ويَعْقُوبُ، أفَتَمْرُونَهُ بِفَتْحِ التاءِ، وإسْكانِ المِيمِ مِن غَيْرِ ألِفٍ، وقَرَأ الباقُونَ بِضَمِّ التاءِ وفَتْحِ المِيمِ وألِفٍ بَعْدَها.</p></div>"
  53,13,"<div class=ar lang=ar><p>[انظر الآية ١١]</p></div>"
  53,14,""
  53,15,""
  53,16,""
  53,17,""
  53,18,""
  53,19,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿اللاتَ﴾</span>، فَرَوى رُوَيْسٌ بِتَشْدِيدِ التاءِ وبِمَدٍّ لِلسّاكِنَيْنِ، وهي قِراءَةُ ابْنِ عَبّاسٍ ومُجاهِدٍ ومَنصُورِ بْنِ المُعْتَمِرِ وطَلْحَةَ وأبِي الجَوْزاءِ، وقَرَأ الباقُونَ بِتَخْفِيفِها</p><p>وَتَقَدَّمَ وقْفُ الكِسائِيِّ عَلَيْها في الوَقْفِ عَلى المَرْسُومِ.</p></div>"
  53,20,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿مَناةَ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ بِهَمْزَةٍ بَعْدَ الألِفِ (، فَيَمُدُّ) لِلِاتِّصالِ. وقَرَأ الباقُونَ بِغَيْرِ هَمْزٍ، والوَقْفُ عَلَيْها لِجَمِيعِ القُرّاءِ بِالهاءِ اتِّباعًا لِلرَّسْمِ. وما وقَعَ في كُتُبِ بَعْضِهِمْ مِن أنَّ الكِسائِيَّ وحْدَهُ يَقِفُ بِالهاءِ، والباقُونَ بِالتاءِ فَوَهْمٌ، لَعَلَّهُ انْقَلَبَ عَلَيْهِمْ مِنَ " اللاتِ " كَما قَدَّمْنا في بابِهِ - واللَهُ أعْلَمُ -.</p></div>"
  53,21,""
  53,22,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿ضِيزى﴾</span> لِابْنِ كَثِيرٍ في الهَمْزِ المُفْرَدِ</p><p>وَتَقَدَّمَ كَبِيرَ الإثْمِ في الشُورى</p><p>وَتَقَدَّمَ في بُطُونِ إمِّهاتِهِمْ لِحَمْزَةَ والكِسائِيِّ في النِساءِ.</p></div>"
  53,23,""
  53,24,""
  53,25,""
  53,26,""
  53,27,""
  53,28,""
  53,29,""
  53,30,""
  53,31,""
  53,32,""
  53,33,""
  53,34,""
  53,35,""
  53,36,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أمْ لَمْ يُنَبَّأْ﴾</span> في الهَمْزِ المُفْرَدِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿إبْراهِيمَ﴾</span> [البقرة: ١٢٤] في البَقَرَةِ.</p></div>"
  53,37,""
  53,38,""
  53,39,""
  53,40,""
  53,41,""
  53,42,""
  53,43,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَأنَّهُ هُوَ﴾</span> لِرُوَيْسٍ بِخِلافٍ في الأرْبَعَةِ، وأنَّ الجُمْهُورَ عَنْهُ عَلى إدْغامِ الحَرْفَيْنِ الأخِيرَيْنِ، وأنَّ بَعْضَهم ذَكَرَ الأوَّلَيْنِ مُوافَقَةً لِأبِي عَمْرٍو في الإدْغامِ الكَبِيرِ.</p></div>"
  53,44,""
  53,45,""
  53,46,""
  53,47,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿النَشْأةَ﴾</span> في العَنْكَبُوتِ.</p></div>"
  53,48,""
  53,49,""
  53,50,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿عادًا الأُولى﴾</span> في بابِ النَقْلِ.</p></div>"
  53,51,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَثَمُودَ فَما أبْقى﴾</span> في هُودٍ</p><p>وَتَقَدَّمَ المُؤْتَفِكَةَ في الهَمْزِ المُفْرَدِ.</p></div>"
  53,52,""
  53,53,""
  53,54,""
  53,55,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿رَبِّكَ تَتَمارى﴾</span> لِيَعْقُوبَ في الإدْغامِ الكَبِيرِ.</p></div>"
