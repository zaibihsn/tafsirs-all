quran[110]{c,v,t}:
  18,1,"<div class=ar lang=ar><p>(p-٣١٠)سُورَةُ الكَهْفِ</p><p>تَقَدَّمَ سَكْتُ حَفْصٍ عَلى <span class="qpc-hafs">﴿عِوَجا﴾</span> في بابِهِ.</p><p>(وَفِيها مِن ياءاتِ الإضافَةِ تِسْعٌ) <span class="qpc-hafs">﴿رَبِّي أعْلَمُ﴾</span> [الكهف: ٢٢]، <span class="qpc-hafs">﴿بِرَبِّي أحَدًا﴾</span> [الكهف: ٣٨]، <span class="qpc-hafs">﴿بِرَبِّي أحَدًا﴾</span> [الكهف: ٣٨] في المَوْضِعَيْنِ رَبِّي أنْ يُؤْتِيَنِ فَتَحَ الأرْبَعَةَ المَدَنِيّانِ، وابْنُ كَثِيرٍ وأبُو عَمْرٍو، و<span class="qpc-hafs">﴿سَتَجِدُنِي إنْ﴾</span> [الكهف: ٦٩] فَتَحَها المَدَنِيّانِ <span class="qpc-hafs">﴿مَعِيَ صَبْرًا﴾</span> [الكهف: ٦٧] في الثَلاثَةِ فَتَحَها حَفْصٌ <span class="qpc-hafs">﴿مِن دُونِي﴾</span> [الكهف: ٥٠]، <span class="qpc-hafs">﴿أوْلِياءَ﴾</span> [الكهف: ٥٠] فَتَحَها المَدَنِيّانِ، وأبُو عَمْرٍو.</p><p>(وَمِنَ الزَوائِدِ سِتٌّ): المُهْتَدِ أثْبَتَها وصْلًا المَدَنِيّانِ، وأبُو عَمْرٍو وأثْبَتَها في الحالَيْنِ يَعْقُوبُ ووَرَدَتْ عَنِ ابْنِ شَنَبُوذَ عَنْ قُنْبُلٍ أنْ يَهْدِيَنِ، و<span class="qpc-hafs">﴿أنْ يُؤْتِيَنِ﴾</span> [الكهف: ٤٠]، و<span class="qpc-hafs">﴿أنْ تُعَلِّمَنِ﴾</span> [الكهف: ٦٦] أثْبَتَها وصْلًا المَدَنِيّانِ، وأبُو عَمْرٍو وأثْبَتَها في الحالَيْنِ ابْنُ كَثِيرٍ ويَعْقُوبُ، <span class="qpc-hafs">﴿إنْ تَرَنِ﴾</span> [الكهف: ٣٩] أثْبَتَها وصْلًا أبُو جَعْفَرٍ وأبُو عَمْرٍو وقالُونُ والأصْبَهانِيُّ عَنْ ورْشٍ، وأثْبَتَها في الحالَيْنِ ابْنُ كَثِيرٍ ويَعْقُوبُ، <span class="qpc-hafs">﴿ما كُنّا نَبْغِ﴾</span> [الكهف: ٦٤] أثْبَتَها وصْلًا المَدَنِيّانِ، وأبُو عَمْرٍو والكِسائِيُّ، وفي الحالَيْنِ ابْنُ كَثِيرٍ ويَعْقُوبُ،.</p><p>وَأمّا <span class="qpc-hafs">﴿فَلا تَسْألْنِي﴾</span> [الكهف: ٧٠] فَلَيْسَتْ مِنَ الزَوائِدِ</p><p>وَتَقَدَّمَ الكَلامُ عَلى حَذْفِها في مَوْضِعِها واللَهُ المُوَفِّقُ.</p></div>"
  18,2,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿مِن لَدُنْهُ﴾</span>، فَرَوى أبُو بَكْرٍ بِإسْكانِ الدالِ وإشْمامِها الضَمَّ وكَسْرِ النُونِ والهاءِ ووَصْلِها بِياءِ اللَفْظِ، وانْفَرَدَ نِفْطَوَيْهِ عَنِ الصَرِيفِينِيِّ عَنْ يَحْيى عَنْ أبِي بَكْرٍ بِكَسْرِ الهاءِ مِن غَيْرِ صِلَةٍ، وهي رِوايَةُ خَلَفٍ عَنْ يَحْيى، وقَرَأ الباقُونَ بِضَمِّ الهاءِ والدالِ، وإسْكانِ النُونِ، وابْنُ كَثِيرٍ عَلى أصْلِهِ في الصِلَةِ بِواوٍ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَيُبَشِّرَ المُؤْمِنِينَ﴾</span> في آلِ عِمْرانَ.</p></div>"
  18,3,""
  18,4,""
  18,5,""
  18,6,""
  18,7,""
  18,8,""
  18,9,""
  18,10,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَهَيِّئْ لَنا﴾</span> <span class="qpc-hafs">﴿وَيُهَيِّئْ لَكُمْ﴾</span> [الكهف: ١٦] لِأبِي جَعْفَرٍ في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
  18,11,""
  18,12,""
  18,13,""
  18,14,""
  18,15,""
  18,16,"<div class=ar lang=ar><p>[انظر الآية ١٠]</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿مِرفَقًا﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ عامِرٍ بِفَتْحِ المِيمِ وكَسْرِ الفاءِ، وقَرَأ الباقُونَ بِكَسْرِ المِيمِ وفَتْحِ الفاءِ، وذَكَرْنا تَرْقِيقَ الراءِ لِمَن كَسَرَ المِيمَ في بابِ الراءاتِ.</p></div>"
  18,17,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَزاوَرُ﴾</span> فَقَرَأ ابْنُ عامِرٍ ويَعْقُوبُ، (تَزْوَرُّ) بِإسْكانِ الزايِ وتَشْدِيدِ الراءِ مِن غَيْرِ ألِفٍ مِثْلَ تَحْمَرُّ، وقَرَأ الكُوفِيُّونَ بِفَتْحِ الزايِ وتَخْفِيفِها وألِفٍ بَعْدَها وتَخْفِيفِ الراءِ، وقَرَأ الباقُونَ كَذَلِكَ إلّا أنَّهم شَدَّدُوا الزايَ.</p></div>"
  18,18,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَلَمُلِئْتَ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ بِتَشْدِيدِ اللامِ الثانِيَةِ، وقَرَأ الباقُونَ بِتَخْفِيفِها، وهم عَلى أُصُولِهِمْ في الهَمْزِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿رُعْبًا﴾</span> في البَقَرَةِ.</p></div>"
  18,19,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿بِوَرِقِكُمْ﴾</span> فَقَرَأ أبُو عَمْرٍو وحَمْزَةُ وخَلَفٌ وأبُو بَكْرٍ ورَوْحٌ بِإسْكانِ الراءِ، وقَرَأ الباقُونَ بِكَسْرِها.</p></div>"
  18,20,""
  18,21,""
  18,22,""
  18,23,""
  18,24,""
  18,25,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿ثَلاثَ مِائَةٍ سِنِينَ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِغَيْرِ تَنْوِينٍ عَلى الإضافَةِ; وقَرَأ الباقُونَ بِالتَنْوِينِ.</p></div>"
  18,26,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَلا يُشْرِكُ﴾</span> فَقَرَأ ابْنُ عامِرٍ بِالخِطابِ وجَزْمِ الكافِ عَلى النَهْيِ، وقَرَأ الباقُونَ بِالغَيْبِ ورَفْعِ الكافِ عَلى الخَبَرِ</p><p>وَتَقَدَّمَ (بِالغُدْوَةِ) لِابْنِ عامِرٍ في الأنْعامِ.</p></div>"
  18,27,""
  18,28,""
  18,29,""
  18,30,""
  18,31,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مُتَّكِئِينَ﴾</span> لِأبِي جَعْفَرٍ في بابِ الهَمْزِ المُفْرَدِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أُكُلَها﴾</span> [البقرة: ٢٦٥] في البَقَرَةِ عِنْدَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧].</p></div>"
  18,32,""
  18,33,""
  18,34,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَكانَ لَهُ ثَمَرٌ﴾</span> <span class="qpc-hafs">﴿وَأُحِيطَ بِثَمَرِهِ﴾</span> [الكهف: ٤٢] فَقَرَأ أبُو جَعْفَرٍ وعاصِمٌ ورَوْحٌ بِفَتْحِ الثاءِ والمِيمِ، وافَقَهم رُوَيْسٌ في الأوَّلِ، وقَرَأ أبُو عَمْرٍو بِضَمِّ الثاءِ، وإسْكانِ المِيمِ فِيهِما، وقَرَأ الباقُونَ بِضَمِّ الثاءِ والمِيمِ في المَوْضِعَيْنِ</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أنا أكْثَرُ﴾</span> و<span class="qpc-hafs">﴿أنا أقَلَّ﴾</span> [الكهف: ٣٩] عِنْدَ <span class="qpc-hafs">﴿أنا أُحْيِي﴾</span> [البقرة: ٢٥٨] مِنَ البَقَرَةِ.</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِلْمَلائِكَةِ اسْجُدُوا﴾</span> [البقرة: ٣٤] في البَقَرَةِ.</p></div>"
  18,35,""
  18,36,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿خَيْرًا مِنها﴾</span> فَقَرَأ (p-٣١١)المَدَنِيّانِ، وابْنُ كَثِيرٍ وابْنُ عامِرٍ (مِنهُما) بِمِيمٍ بَعْدَ الهاءِ عَلى التَثْنِيَةِ، وكَذَلِكَ هي في مَصاحِفِهِمْ، وقَرَأ الباقُونَ بِحَذْفِ المِيمِ عَلى الإفْرادِ، وكَذَلِكَ هي في مَصاحِفِهِمْ.</p></div>"
  18,37,""
  18,38,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَكِنّا هو اللَهُ﴾</span> فَقَرَأ أبُو جَعْفَرٍ وابْنُ عامِرٍ ورُوَيْسٌ <span class="qpc-hafs">﴿لَكِنّا﴾</span> بِإثْباتِ الألِفِ بَعْدَ النُونِ وصْلًا، وقَرَأ الباقُونَ بِغَيْرِ ألِفٍ، ولا خِلافَ في إثْباتِها في الوَقْفِ اتِّباعًا لِلرَّسْمِ.</p></div>"
  18,39,"<div class=ar lang=ar><p>[انظر الآية ٣٤]</p></div>"
  18,40,""
  18,41,""
  18,42,"<div class=ar lang=ar><p>[انظر الآية ٣٤]</p></div>"
  18,43,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَلَمْ تَكُنْ لَهُ﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِالياءِ عَلى التَذْكِيرِ، وقَرَأ الباقُونَ بِالتاءِ عَلى التَأْنِيثِ.</p></div>"
  18,44,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿الوَلايَةُ﴾</span> آخِرَ الأنْفالِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِلَّهِ الحَقِّ﴾</span> فَقَرَأ أبُو عَمْرٍو والكِسائِيُّ بِرَفْعِ القافِ، وقَرَأ الباقُونَ بِخَفْضِها</p><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿عُقْبًا﴾</span> عِنْدَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧] في البَقَرَةِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿الرِياحِ﴾</span> [البقرة: ١٦٤] في البَقَرَةِ.</p></div>"
  18,45,""
  18,46,""
  18,47,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿نُسَيِّرُ الجِبالَ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو، وابْنُ عامِرٍ بِالتاءِ وضَمِّها وفَتْحِ الياءِ ورَفْعِ " الجِبالُ "، وقَرَأ الباقُونَ بِالنُونِ وضَمِّها وكَسْرِ الياءِ، ونَصْبِ <span class="qpc-hafs">﴿الجِبالَ﴾</span>.</p></div>"
  18,48,""
  18,49,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿مالِ هَذا الكِتابِ﴾</span> في بابِ الوَقْفِ عَلى المَرْسُومِ.</p></div>"
  18,50,""
  18,51,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿ما أشْهَدْتُهم خَلْقَ﴾</span> فَقَرَأ أبُو جَعْفَرٍ (أشْهَدْناهُمْ) بِالنُونِ والألِفِ عَلى الجَمْعِ لِلْعَظَمَةِ، وقَرَأ الباقُونَ بِالتاءِ مَضْمُومَةً مِن غَيْرِ ألِفٍ عَلى ضَمِيرِ المُتَكَلِّمِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَما كُنْتُ مُتَّخِذَ المُضِلِّينَ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِفَتْحِ التاءِ، وانْفَرَدَ أبُو القاسِمِ الهُذَلِيُّ عَنِ الهاشِمِيِّ عَنْ إسْماعِيلَ عَنِ ابْنِ جَمّازٍ عَنْهُ بِضَمِّ التاءِ، وكَذَلِكَ قَرَأ الباقُونَ.</p></div>"
  18,52,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَيَوْمَ يَقُولُ﴾</span> فَقَرَأ حَمْزَةُ بِالنُونِ، وقَرَأ الباقُونَ بِالياءِ.</p></div>"
  18,53,""
  18,54,""
  18,55,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿العَذابُ قُبُلًا﴾</span> فَقَرَأ أبُو جَعْفَرٍ، والكُوفِيُّونَ بِضَمِّ القافِ والباءِ، وقَرَأ الباقُونَ بِكَسْرِ القافِ وفَتْحِ الباءِ.</p></div>"
  18,56,""
  18,57,""
  18,58,""
  18,59,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لِمَهْلِكِهِمْ﴾</span> هُنا، وفي النَمْلِ <span class="qpc-hafs">﴿مَهْلِكَ أهْلِهِ﴾</span> [النمل: ٤٩]، فَرَوى أبُو بَكْرٍ بِفَتْحِ المِيمِ واللامِ الَّتِي بَعْدَ الهاءِ فِيهِما، ورَوى حَفْصٌ بِفَتْحِ المِيمِ وكَسْرِ اللامِ في المَوْضِعَيْنِ، وقَرَأ الباقُونَ بِضَمِّ المِيمِ وفَتْحِ اللامِ.</p></div>"
  18,60,""
  18,61,""
  18,62,""
  18,63,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أنْسانِيهُ﴾</span> لِحَفْصٍ في بابِ هاءِ الكِنايَةِ</p><p>وَتَقَدَّمَ إمالَتُهُ في بابِها.</p></div>"
  18,64,""
  18,65,""
  18,66,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿مِمّا عُلِّمْتَ رُشْدًا﴾</span> فَقَرَأ البَصْرِيّانِ بِفَتْحِ الراءِ والشِينِ، وقَرَأ الباقُونَ بِضَمِّ الراءِ، وإسْكانِ الشِينِ.</p><p>(واتَّفَقُوا) عَلى المَوْضِعَيْنِ (p-٣١٢)المُتَقَدِّمَيْنِ مِن هَذِهِ السُورَةِ، وهُما <span class="qpc-hafs">﴿وَهَيِّئْ لَنا مِن أمْرِنا رَشَدًا﴾</span> [الكهف: ١٠]، و<span class="qpc-hafs">﴿لِأقْرَبَ مِن هَذا رَشَدًا﴾</span> [الكهف: ٢٤] أنَّهُما بِفَتْحِ الراءِ والشِينِ، وقَدْ سُئِلَ الإمامُ أبُو عَمْرِو بْنُ العَلاءِ عَنْ ذَلِكَ فَقالَ: الرُشْدُ بِالضَمِّ هو الصَلاحُ وبِالفَتْحِ هو العِلْمُ، ومُوسى عَلَيْهِ السَلامُ إنَّما طَلَبَ مِنَ الخَضِرِ عَلَيْهِ السَلامُ العِلْمَ، وهَذا في غايَةِ الحُسْنِ، ألا تَرى إلى قَوْلِهِ تَعالى: <span class="qpc-hafs">﴿فَإنْ آنَسْتُمْ مِنهم رُشْدًا﴾</span> [النساء: ٦] كَيْفَ أُجْمِعَ عَلى فَتْحِهِ ؟</p><p>وَلَكِنَّ جُمْهُورَ أهْلِ اللُغَةِ عَلى أنَّ الفَتْحَ والضَمَّ في الرُشْدِ والرَشَدِ لُغَتانِ كالبُخْلِ والبَخَلِ والسُقْمِ والسَقَمِ والحُزْنِ والحَزَنِ، فَيَحْتَمِلُ عِنْدِي أنْ يَكُونَ الِاتِّفاقُ عَلى فَتْحِ الحَرْفَيْنِ الأوَّلِينَ لِمُناسِبَةِ رُءُوسِ الآيِ ومُوازَنَتِها لِما قَبْلُ، ولِما بَعْدُ نَحْوَ<span class="qpc-hafs">﴿عَجَبًا﴾</span> [الكهف: ٩] و<span class="qpc-hafs">﴿عَدَدًا﴾</span> [الكهف: ١١] و<span class="qpc-hafs">﴿أحَدًا﴾</span> [الكهف: ١٩] بِخِلافِ الثالِثِ فَإنَّهُ وقَعَ قَبْلَهُ <span class="qpc-hafs">﴿عِلْمًا﴾</span> [الكهف: ٦٥]، وبَعْدَهُ <span class="qpc-hafs">﴿صَبْرًا﴾</span> [الكهف: ٦٧] فَمَن سَكَّنَ فَلِلْمُناسِبَةِ أيْضًا، ومَن فَتَحَ فَإلْحاقًا بِالنَظِيرِ واللَهُ تَعالى أعْلَمُ.</p></div>"
  18,67,""
