quran[30]{c,v,t}:
  32,1,"<div class=ar lang=ar><p>سُورَةُ السَجْدَةِ</p><p>تَقَدَّمَ سَكْتُ أبِي جَعْفَرٍ.</p></div>"
  32,2,""
  32,3,""
  32,4,""
  32,5,""
  32,6,""
  32,7,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿خَلَقَهُ﴾</span> فَقَرَأ نافِعٌ، والكُوفِيُّونَ بِفَتْحِ اللامِ، وقَرَأ الباقُونَ بِإسْكانِها.</p></div>"
  32,8,""
  32,9,""
  32,10,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أئِذا﴾</span>، و<span class="qpc-hafs">﴿أئِنّا﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  32,11,""
  32,12,""
  32,13,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لَأمْلَأنَّ﴾</span> في الهَمْزِ المُفْرَدِ لِلْأصْبَهانِيِّ.</p></div>"
  32,14,""
  32,15,""
  32,16,""
  32,17,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿ما أُخْفِيَ﴾</span> فَقَرَأ يَعْقُوبُ وحَمْزَةُ بِإسْكانِ الياءِ، وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  32,18,""
  32,19,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿المَأْوى﴾</span> في الهَمْزِ المُفْرَدِ.</p></div>"
  32,20,""
  32,21,""
  32,22,""
  32,23,""
  32,24,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أئِمَّةً﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَمّا صَبَرُوا﴾</span> فَقَرَأ حَمْزَةُ والكِسائِيُّ ورُوَيْسٌ بِكَسْرِ اللامِ وتَخْفِيفِ المِيمِ، وقَرَأ الباقُونَ بِفَتْحِ اللامِ وتَشْدِيدِ المِيمِ.</p></div>"
  32,25,""
  32,26,""
  32,27,""
  32,28,""
  32,29,""
  32,30,""
