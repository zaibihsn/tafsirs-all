quran[26]{c,v,t}:
  88,1,""
  88,2,""
  88,3,""
  88,4,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿تَصْلى نارًا﴾</span> فَقَرَأ البَصْرِيّانِ، وأبُو بَكْرٍ بِضَمِّ التاءِ وقَرَأ الباقُونَ بِفَتْحِها</p></div>"
  88,5,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿آنِيَةٍ﴾</span> لِهِشامٍ في الإمالَةِ.</p></div>"
  88,6,""
  88,7,""
  88,8,""
  88,9,""
  88,10,""
  88,11,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</span> فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو ورُوَيْسٌ <span class="qpc-hafs">﴿لا يُسْمَعُ﴾</span> بِياءٍ مَضْمُومَةٍ عَلى التَذْكِيرِ لاغِيَةٌ بِالرَفْعِ، وقَرَأ نافِعٌ كَذَلِكَ إلّا أنَّهُ بِالتاءِ عَلى التَأْنِيثِ، وقَرَأ الباقُونَ بِالتاءِ مَفْتُوحَةً لاغِيَةً بِالنَصْبِ</p></div>"
  88,12,""
  88,13,""
  88,14,""
  88,15,""
  88,16,""
  88,17,""
  88,18,""
  88,19,""
  88,20,""
  88,21,""
  88,22,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿بِمُسَيْطِرٍ﴾</span> في الطُورِ.</p></div>"
  88,23,""
  88,24,""
  88,25,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إيابَهُمْ﴾</span> فَقَرَأ أبُو جَعْفَرٍ بِتَشْدِيدِ الياءِ، وقَرَأ الباقُونَ بِتَخْفِيفِها.</p></div>"
  88,26,""
