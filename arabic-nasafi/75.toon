quran[40]{c,v,t}:
  75,1,"<div class=ar lang=ar><p>(p-٥٧٠)سُورَةُ "اَلْقِيامَةِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span> أيْ: أُقْسِمُ، عَنِ ابْنِ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما -: و"لا"، صِلَةٌ، كَقَوْلِهِ: <span class="qpc-hafs">﴿لِئَلا يَعْلَمَ﴾</span> [الحديد: ٢٩]، وقَوْلِهِ:</p><p>فِي بِئْرِ لاحُورٍ سَرى وما شَعَرْ</p><p>وَكَقَوْلِهِ:</p><p>؎ تَذَكَّرْتُ لَيْلى فاعْتَرَتْنِي صَبابَةٌ... وكادَ ضَمِيرُ القَلْبِ لا يَتَقَطَّعُ</p><p>وَعَلَيْهِ الجُمْهُورُ، وعَنِ الفَرّاءِ: "لا"، رَدٌّ لِإنْكارِ المُشْرِكِينَ البَعْثَ، كَأنَّهُ قِيلَ: لَيْسَ الأمْرُ كَما تَزْعُمُونَ، ثُمَّ قِيلَ: "أُقْسِمُ بِيَوْمِ القِيامَةِ"، وقِيلَ: أصْلُهُ: "لَأُقْسِمُ"، كَقِراءَةِ ابْنِ كَثِيرٍ، عَلى أنَّ اللامَ لِلِابْتِداءِ، و"أُقْسِمُ"، خَبَرُ مُبْتَدَإٍ مَحْذُوفٍ، أيْ: "لَأنا أُقْسِمُ"، ويُقَوِّيهِ أنَّهُ في الإمامِ بِغَيْرِ الألِفِ، ثُمَّ أُشْبِعَ، فَظَهَرَ مِنَ الإشْباعِ ألِفٌ، وهَذا اللامُ يَصْحَبُهُ نُونُ التَأْكِيدِ في الأغْلَبِ، وقَدْ يُفارِقُهُ.</p></div>"
  75,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا أُقْسِمُ بِالنَفْسِ اللَوّامَةِ﴾</span>، اَلْجُمْهُورُ عَلى أنَّهُ قَسَمٌ أخَرُ، عَنِ الحَسَنِ: "أقْسَمَ بِيَوْمِ القِيامَةِ، ولَمْ يُقْسِمْ بِالنَفْسِ اللَوّامَةِ، فَهي صِفَةُ ذَمٍّ"، وعَلى القَسَمِ صِفَةُ (p-٥٧١)مَدْحٍ، أيْ: اَلنَّفْسِ المُتَّقِيَةِ، الَّتِي تَلُومُ عَلى التَقْصِيرِ في التَقْوى، وقِيلَ: هي نَفْسُ آدَمَ، لَمْ تَزَلْ تَلُومُ عَلى فِعْلِها الَّتِي خَرَجَتْ بِهِ مِنَ الجَنَّةِ، وجَوابُ القَسَمِ مَحْذُوفٌ، أيْ: لَتُبْعَثُنَّ، دَلِيلُهُ:</p></div>"
  75,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أيَحْسَبُ الإنْسانُ﴾</span> أيْ: اَلْكافِرُ المُنْكِرُ لِلْبَعْثِ،</p><p><span class="qpc-hafs">﴿ألَّنْ نَجْمَعَ عِظامَهُ﴾</span>، بَعْدَ تَفَرُّقِها، ورُجُوعِها رُفاتًا مُخْتَلِطًا بِالتُرابِ.</p></div>"
  75,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلى﴾</span>، أوْجَبَتْ ما بَعْدَ النَفْيِ، أيْ: بَلى نَجْمَعُها،</p><p><span class="qpc-hafs">﴿قادِرِينَ﴾</span>، حالٌ مِنَ الضَمِيرِ في "نَجْمَعَ"، أيْ: نَجْمَعُها قادِرِينَ عَلى جَمْعِها، وإعادَتِها كَما كانَتْ،</p><p><span class="qpc-hafs">﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، أصابِعَهُ، كَما كانَتْ في الدُنْيا، بِلا نُقْصانٍ وتَفاوُتٍ، مَعَ صِغَرِها، فَكَيْفَ بِكِبارِ العِظامِ؟!</p></div>"
  75,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ﴾</span>، عَطْفٌ عَلى "أيَحْسَبُ"، فَيَجُوزُ أنْ يَكُونَ - مِثْلَهُ - اسْتِفْهامًا،</p><p><span class="qpc-hafs">﴿لِيَفْجُرَ أمامَهُ﴾</span>، لِيَدُومَ عَلى فُجُورِهِ فِيما يَسْتَقْبِلُهُ مِنَ الزَمانِ.</p></div>"
  75,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسْألُ أيّانَ﴾</span>، مَتى،</p><p><span class="qpc-hafs">﴿يَوْمُ القِيامَةِ﴾</span>، سُؤالَ مُتَعَنِّتٍ، مُسْتَبْعِدٍ لِقِيامِ الساعَةِ.</p></div>"
  75,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span>، تَحَيَّرَ فَزَعًا، وبِفَتْحِ الراءِ "مَدَنِيٌّ"، شَخَصَ.</p></div>"
  75,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَخَسَفَ القَمَرُ﴾</span>، وذَهَبَ ضَوْؤُهُ، أوْ غابَ، مِن قَوْلِهِ: <span class="qpc-hafs">﴿فَخَسَفْنا بِهِ﴾</span> [القصص: ٨١]، وقَرَأ أبُو حَيْوَةَ بِضَمِّ الخاءِ.</p></div>"
  75,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجُمِعَ الشَمْسُ والقَمَرُ﴾</span> أيْ: جُمِعَ بَيْنَهُما في الطُلُوعِ مِنَ المَغْرِبِ، أوْ جُمِعا في ذَهابِ الضَوْءِ، أوْ يُجْمَعانِ فَيُقْذَفانِ في البَحْرِ، فَيَكُونُ نارَ اللهِ الكُبْرى.</p></div>"
  75,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُولُ الإنْسانُ﴾</span>، اَلْكافِرُ،</p><p><span class="qpc-hafs">﴿يَوْمَئِذٍ أيْنَ المَفَرُّ﴾</span>، هو مَصْدَرٌ، أيْ: اَلْفِرارُ مِنَ النارِ، أوِ المُؤْمِنُ أيْضًا مِنَ الهَوْلِ، وقَرَأ الحَسَنُ بِكَسْرِ الفاءِ، وهو يَحْتَمِلُ المَكانَ، والمَصْدَرَ.</p></div>"
  75,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ عَنْ طَلَبِ المَفَرِّ،</p><p><span class="qpc-hafs">﴿لا وزَرَ﴾</span>، لا مَلْجَأ.</p></div>"
  75,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلى رَبِّكَ﴾</span>، خاصَّةً،</p><p><span class="qpc-hafs">﴿يَوْمَئِذٍ المُسْتَقَرُّ﴾</span>، مُسْتَقَرُّ العِبادِ، أوْ مَوْضِعُ قَرارِهِمْ، مِن جَنَّةٍ، أوْ نارٍ، مُفَوَّضٌ ذَلِكَ لِمَشِيئَتِهِ، مَن شاءَ أدْخَلَهُ الجَنَّةَ، ومَن شاءَ أدْخَلَهُ النارَ.</p></div>"
  75,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ﴾</span>، يُخْبَرُ،</p><p><span class="qpc-hafs">﴿بِما قَدَّمَ﴾</span>، مِن عَمَلٍ عَمِلَهُ،</p><p><span class="qpc-hafs">﴿وَأخَّرَ﴾</span>، ما لَمْ يَعْمَلْهُ.</p></div>"
  75,14,"<div class=ar lang=ar><p>(p-٥٧٢)<span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span>، شاهِدٌ، والهاءُ لِلْمُبالَغَةِ، كَـ "عَلّامَةٌ"، أوْ أنَّثَهُ لِأنَّهُ أرادَ بِهِ جَوارِحَهُ، إذْ جَوارِحُهُ تَشْهَدُ عَلَيْهِ، أوْ هو حُجَّةٌ عَلى نَفْسِهِ، والبَصِيرَةُ: اَلْحُجَّةُ، قالَ اللهُ (تَعالى): <span class="qpc-hafs">﴿قَدْ جاءَكم بَصائِرُ مِن رَبِّكُمْ﴾</span> [الأنعام: ١٠٤]، وتَقُولُ لِغَيْرِكَ: "أنْتَ حُجَّةٌ عَلى نَفْسِكَ"، و"بَصِيرَةٌ"، رَفْعٌ بِالِابْتِداءِ، وخَبَرُهُ: "عَلى نَفْسِهِ"، تَقَدَّمَ عَلَيْهِ، والجُمْلَةُ خَبَرُ "اَلْإنْسانُ"، كَقَوْلِكَ: "زَيْدٌ عَلى رَأْسِهِ عِمامَةٌ"، و"اَلْبَصِيرَةُ"، عَلى هَذا، يَجُوزُ أنْ يَكُونَ المَلَكَ المُوَكَّلَ عَلَيْهِ.</p></div>"
  75,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوْ ألْقى مَعاذِيرَهُ﴾</span>، أرْخى سُتُورَهُ، و"اَلْمِعْذارُ": اَلسِّتْرُ، وقِيلَ: ولَوْ جاءَ بِكُلِّ مَعْذِرَةٍ، ما قُبِلَتْ مِنهُ، فَعَلَيْهِ مَن يُكَذِّبُ عُذْرَهُ، و"اَلْمَعاذِيرُ"، لَيْسَ بِجَمْعِ "مَعْذِرَةٌ"، لِأنَّ جَمْعَها "مَعاذِرُ"، بَلْ هي اسْمُ جَمْعٍ لَها، ونَحْوُهُ: "اَلْمَناكِيرُ"، في "اَلْمُنْكَرُ".</p></div>"
  75,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ﴾</span>، بِالقُرْآنِ،</p><p><span class="qpc-hafs">﴿لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>، بِالقُرْآنِ، وكانَ ﷺ يَأْخُذُ في القِراءَةِ قَبْلَ فَراغِ جِبْرِيلَ، كَراهَةَ أنْ يَتَفَلَّتَ مِنهُ، فَقِيلَ لَهُ: لا تُحَرِّكْ لِسانَكَ بِقِراءَةِ الوَحْيِ، ما دامَ جِبْرِيلُ يَقْرَأُ، لِتَعْجَلَ بِهِ، لِتَأْخُذَهُ عَلى عَجَلَةٍ، ولِئَلّا يَتَفَلَّتَ مِنكَ، ثُمَّ عَلَّلَ النَهْيَ عَنِ العَجَلَةِ بِقَوْلِهِ:</p></div>"
  75,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ عَلَيْنا جَمْعَهُ﴾</span>، في صَدْرِكَ،</p><p><span class="qpc-hafs">﴿وَقُرْآنَهُ﴾</span>، وإثْباتُ قِراءَتِهِ في لِسانِكَ، و"اَلْقُرْآنُ": اَلْقِراءَةُ، ونَحْوُهُ: <span class="qpc-hafs">﴿وَلا تَعْجَلْ بِالقُرْآنِ مِن قَبْلِ أنْ يُقْضى إلَيْكَ وحْيُهُ﴾</span> [طه: ١١٤]</p></div>"
  75,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإذا قَرَأْناهُ﴾</span> أيْ: قَرَأهُ عَلَيْكَ جِبْرِيلُ، فَجَعَلَ قِراءَةَ جِبْرِيلَ قِراءَتَهُ،</p><p><span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span> أيْ: قِراءَتَهُ عَلَيْكَ.</p></div>"
  75,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</span>، إذا أشْكَلَ عَلَيْكَ شَيْءٌ مِن مَعانِيهِ.</p></div>"
  75,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ عَنْ إنْكارِ البَعْثِ، أوْ رَدْعٌ لِرَسُولِ اللهِ ﷺ عَنِ العَجَلَةِ، وإنْكارٌ لَها عَلَيْهِ، وأكَّدَهُ بِقَوْلِهِ: <span class="qpc-hafs">﴿بَلْ تُحِبُّونَ العاجِلَةَ﴾</span>، كَأنَّهُ قِيلَ بَلْ أنْتُمْ يا بَنِي آدَمَ - لِأنَّكم خُلِقْتُمْ مِن عَجَلٍ، وطُبِعْتُمْ عَلَيْهِ - تَعْجَلُونَ في كُلِّ شَيْءٍ، ومِن ثَمَّ تُحِبُّونَ العاجِلَةَ، الدُنْيا، وشَهَواتِها.</p></div>"
  75,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَذَرُونَ الآخِرَةَ﴾</span>، اَلدّارَ الآخِرَةَ، ونَعِيمَها، فَلا (p-٥٧٣)تَعْمَلُونَ لَها، والقِراءَةُ بِالتاءِ فِيهِما "مَدَنِيٌّ وكُوفِيٌّ".</p></div>"
  75,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوهٌ﴾</span>، هي وُجُوهُ المُؤْمِنِينَ،</p><p><span class="qpc-hafs">﴿يَوْمَئِذٍ ناضِرَةٌ﴾</span>، حَسَنَةٌ، ناعِمَةٌ.</p></div>"
  75,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلى رَبِّها ناظِرَةٌ﴾</span>، بِلا كَيْفِيَّةٍ، ولا وُجْهَةٍ، ولا ثُبُوتِ مَسافَةٍ، وحَمْلُ النَظَرِ عَلى الِانْتِظارِ لِأمْرِ رَبِّها، أوْ لِثَوابِهِ، لا يَصِحُّ، لِأنَّهُ يُقالُ: "نَظَرْتُ فِيهِ"، أيْ: تَفَكَّرْتُ، و"نَظَرْتُهُ": اِنْتَظَرْتُهُ، ولا يُعَدّى بِـ "إلى"، إلّا بِمَعْنى "اَلرُّؤْيَةُ"، مَعَ أنَّهُ لا يَلِيقُ الِانْتِظارُ في دارِ القَرارِ.</p></div>"
  75,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوُجُوهٌ يَوْمَئِذٍ باسِرَةٌ﴾</span>، كالِحَةٌ شَدِيدَةُ العُبُوسَةِ، وهي وُجُوهُ الكُفّارِ.</p></div>"
  75,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَظُنُّ﴾</span>، تَتَوَقَّعُ أنْ يُفْعَلَ بِها فِعْلٌ، هو في شِدَّتِهِ <span class="qpc-hafs">﴿فاقِرَةٌ﴾</span>، داهِيَةٌ تَقْصِمُ فَقارَ الظَهْرِ.</p></div>"
  75,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ عَنْ إيثارِ الدُنْيا عَلى الآخِرَةِ، كَأنَّهُ قِيلَ: اِرْتَدِعُوا عَنْ ذَلِكَ، وتَنَبَّهُوا عَلى ما بَيْنَ أيْدِيكم مِنَ المَوْتِ، الَّذِي عِنْدَهُ تَنْقَطِعُ العاجِلَةُ عَنْكُمْ، وتَنْتَقِلُونَ إلى الآجِلَةِ الَّتِي تَبْقَوْنَ فِيها مُخَلَّدِينَ،</p><p><span class="qpc-hafs">﴿إذا بَلَغَتِ﴾</span> أيْ: الرُوحُ، وجازَ - وإنْ لَمْ يَجْرِ لَها ذِكْرٌ - لِأنَّ الآيَةَ تَدُلُّ عَلَيْها،</p><p><span class="qpc-hafs">﴿التَراقِيَ﴾</span>، اَلْعِظامَ المُكْتَنِفَةَ لِثُغْرَةِ النَحْرِ، عَنْ يَمِينٍ وشِمالٍ، جَمْعُ "تَرْقُوَةٌ".</p></div>"
  75,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِيلَ مَن راقٍ﴾</span>، يَقِفُ حَفْصٌ عَلى "مَن"، وُقَيْفَةً، أيْ: قالَ حاضِرُو المُحْتَضَرِ بَعْضُهم لِبَعْضٍ: أيُّكم يَرْقِيهِ مِمّا بِهِ؟ مِن "اَلرُّقْيَةُ"، مِن حَدِّ "ضَرَبَ"، أوْ هو مِن كَلامِ المَلائِكَةِ: أيُّكم يَرْقى بِرُوحِهِ؟ أمَلائِكَةُ الرَحْمَةِ أمْ مَلائِكَةُ العَذابِ؟ مِن "اَلرُّقِيُّ"، مِن حَدِّ "عَلِمَ".</p></div>"
  75,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَظَنَّ﴾</span> أيْقَنَ المُحْتَضَرُ،</p><p><span class="qpc-hafs">﴿أنَّهُ الفِراقُ﴾</span>، أنَّ هَذا الَّذِي نَزَلَ بِهِ هو فِراقُ الدُنْيا المَحْبُوبَةِ.</p></div>"
  75,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والتَفَّتِ الساقُ بِالساقِ﴾</span>، اِلْتَوَتْ ساقاهُ عِنْدَ مَوْتِهِ، وعَنْ سَعِيدِ بْنِ المُسَيِّبِ: "هُما ساقاهُ حِينَ تُلَفّانِ في أكْفانِهِ"، وقِيلَ: شِدَّةُ فِراقِ الدُنْيا، بِشِدَّةِ إقْبالِ الآخِرَةِ، عَلى أنَّ الساقَ مَثَلٌ في الشِدَّةِ، وعَنِ ابْنِ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما - "هُما هَمّانِ: هَمُّ الأهْلِ والوَلَدِ، وهَمُّ القُدُومِ عَلى الواحِدِ الصَمَدِ".</p></div>"
  75,30,"<div class=ar lang=ar><p>(p-٥٧٤)<span class="qpc-hafs">﴿إلى رَبِّكَ يَوْمَئِذٍ المَساقُ﴾</span>، هو مَصْدَرُ "ساقَهُ"، أيْ: مَساقُ العِبادِ إلى حَيْثُ أمَرَ اللهُ، إمّا إلى الجَنَّةِ، أوْ إلى النارِ.</p></div>"
  75,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلا صَدَّقَ﴾</span>، بِالرَسُولِ، والقُرْآنِ،</p><p><span class="qpc-hafs">﴿وَلا صَلّى﴾</span>، اَلْإنْسانُ، في قَوْلِهِ: <span class="qpc-hafs">﴿أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ﴾</span> [القيامة: ٣]</p></div>"
  75,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَكِنْ كَذَّبَ﴾</span>، بِالقُرْآنِ،</p><p><span class="qpc-hafs">﴿وَتَوَلّى﴾</span>، عَنِ الإيمانِ، أوْ فَلا صَدَّقَ مالَهُ، يَعْنِي: فَلا زَكّاهُ.</p></div>"
  75,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ ذَهَبَ إلى أهْلِهِ يَتَمَطّى﴾</span>، يَتَبَخْتَرُ، وأصْلُهُ "يَتَمَطَّطُ"، أيْ: يَتَمَدَّدُ، لِأنَّ المُتَبَخْتِرَ يَمُدُّ خُطاهُ، فَأُبْدِلَتِ الطاءُ ياءً، لِاجْتِماعِ ثَلاثَةِ أحْرُفٍ مُتَماثِلَةٍ.</p></div>"
  75,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أوْلى لَكَ﴾</span>، بِمَعْنى: "وَيْلٌ لَكَ"، وهو دُعاءٌ عَلَيْهِ بِأنْ يَلِيَهُ ما يَكْرَهُ،</p><p><span class="qpc-hafs">﴿فَأوْلى﴾</span></p></div>"
  75,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ أوْلى لَكَ فَأوْلى﴾</span>، كَرَّرَ لِلتَّأْكِيدِ، كَأنَّهُ قالَ: "وَيْلٌ لَكَ، فَوَيْلٌ، ثُمَّ ويْلٌ لَكَ، فَوَيْلٌ"، وقِيلَ: ويْلٌ لَكَ يَوْمَ المَوْتِ، ووَيْلٌ لَكَ في القَبْرِ، ووَيْلٌ لَكَ حِينَ البَعْثِ، ووَيْلٌ لَكَ في النارِ.</p></div>"
  75,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أيَحْسَبُ الإنْسانُ أنْ يُتْرَكَ سُدًى﴾</span> أيَحْسَبُ الكافِرُ أنْ يُتْرَكَ مُهْمَلًا، لا يُؤْمَرُ، ولا يُنْهى، ولا يُبْعَثُ، ولا يُجازى.</p></div>"
  75,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألَمْ يَكُ نُطْفَةً مِن مَنِيٍّ يُمْنى﴾</span>، بِالياءِ، " اِبْنُ عامِرٍ وحَفْصٌ "، أيْ: يُراقُ المَنِيُّ في الرَحِمِ، وبِالتاءِ، يَعُودُ إلى النُطْقَةِ.</p></div>"
  75,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ كانَ عَلَقَةً﴾</span> أيْ: صارَ المَنِيُّ قِطْعَةَ دَمٍ جامِدٍ، بَعْدَ أرْبَعِينَ يَوْمًا،</p><p><span class="qpc-hafs">﴿فَخَلَقَ فَسَوّى﴾</span>، فَخَلَقَ اللهُ مِنهُ بَشَرًا سَوِيًّا.</p></div>"
  75,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَجَعَلَ مِنهُ﴾</span>، مِنَ الإنْسانِ،</p><p><span class="qpc-hafs">﴿الزَوْجَيْنِ الذَكَرَ والأُنْثى﴾</span> أيْ: مِنَ المَنِيِّ الصِنْفَيْنِ.</p></div>"
  75,40,"<div class=ar lang=ar><p>(p-٥٧٥)<span class="qpc-hafs">﴿ألَيْسَ ذَلِكَ بِقادِرٍ عَلى أنْ يُحْيِيَ المَوْتى﴾</span>، ألَيْسَ الفَعّالُ لِهَذِهِ الأشْياءِ بِقادِرٍ عَلى الإعادَةِ؟! «وَكانَ ﷺ إذا قَرَأها يَقُولُ: "سُبْحانَكَ، بَلى » ".</p></div>"
