quran[42]{c,v,t}:
  80,1,"<div class=ar lang=ar><p>(p-٦٠١)سُورَةُ "عَبَسَ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿عَبَسَ﴾</span>، كَلَحَ، أيْ: اَلنَّبِيُّ ﷺ،</p><p><span class="qpc-hafs">﴿وَتَوَلّى﴾</span>، أعْرَضَ.</p></div>"
  80,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أنْ جاءَهُ﴾</span>، "لِأنْ جاءَهُ"، ومَحَلُّهُ نَصْبٌ، لِأنَّهُ مَفْعُولٌ لَهُ، والعامِلُ فِيهِ: "عَبَسَ"، أوْ: "تَوَلّى"، عَلى اخْتِلافِ المَذْهَبَيْنِ،</p><p><span class="qpc-hafs">﴿الأعْمى﴾</span>، عَبْدُ اللهِ بْنُ أُمِّ مَكْتُومٍ، و"أُمُّ مَكْتُومٍ "، أُمُّ أبِيهِ، وأبُوهُ شُرَيْحُ بْنُ مالِكٍ، «أتى النَبِيَّ ﷺ وهو يَدْعُو أشْرافَ قُرَيْشٍ إلى الإسْلامِ، فَقالَ: يا رَسُولَ اللهِ، عَلِّمْنِي مِمّا عَلَّمَكَ اللهُ، وكَرَّرَ ذَلِكَ، وهو لا يَعْلَمُ تَشاغُلَهُ بِالقَوْمِ، فَكَرِهَ رَسُولُ اللهِ ﷺ قَطْعَهُ لِكَلامِهِ، وعَبَسَ، وأعْرَضَ عَنْهُ، فَنَزَلَتْ، فَكانَ رَسُولُ اللهِ ﷺ يُكْرِمُهُ بَعْدَها، ويَقُولُ: "مَرْحَبًا بِمَن عاتَبَنِي فِيهِ رَبِّي" »، واسْتَخْلَفَهُ عَلى المَدِينَةِ مَرَّتَيْنِ.</p></div>"
  80,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما يُدْرِيكَ﴾</span>، وأيُّ شَيْءٍ يَجْعَلُكَ دارِيًا بِحالِ هَذا الأعْمى؟! <span class="qpc-hafs">﴿لَعَلَّهُ يَزَّكّى﴾</span>، لَعَلَّ الأعْمى يَتَطَهَّرُ بِما يَسْمَعُ مِنكَ مِن دَنَسِ الجَهْلِ، وأصْلُهُ "يَتَزَكّى"، فَأُدْغِمَتِ التاءُ في الزايِ، وكَذا:</p></div>"
  80,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أوْ يَذَّكَّرُ﴾</span>، يَتَّعِظُ،</p><p><span class="qpc-hafs">﴿فَتَنْفَعَهُ﴾</span>، نَصْبُهُ " عاصِمٌ غَيْرَ الأعْشى"، جَوابًا لِـ "لَعَلَّ"، وغَيْرُهُ رَفَعَهُ، عَطْفًا عَلى "يَذَّكَّرُ"،</p><p><span class="qpc-hafs">﴿الذِكْرى﴾</span>، ذِكْراكَ، أيْ: (p-٦٠٢)مَوْعِظَتُكَ، أيْ: إنَّكَ لا تَدْرِي ما هو مُتَرَقَّبٌ مِنهُ، مِن تَزَكٍّ، أوْ تَذَكُّرٍ، ولَوْ دَرَيْتَ لَما فَرَطَ ذَلِكَ مِنكَ.</p></div>"
  80,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أمّا مَنِ اسْتَغْنى﴾</span> أيْ: مَن كانَ غَنِيًّا بِالمالِ.</p></div>"
  80,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأنْتَ لَهُ تَصَدّى﴾</span>، تَتَعَرَّضُ بِالإقْبالِ عَلَيْهِ، حِرْصًا عَلى إيمانِهِ، "تَصَّدّى"، بِإدْغامِ التاءِ في الصادِ "حِجازِيٌّ".</p></div>"
  80,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما عَلَيْكَ ألا يَزَّكّى﴾</span>، ولَيْسَ عَلَيْكَ بَأْسٌ في ألّا يَتَزَكّى بِالإسْلامِ، إنْ عَلَيْكَ إلّا البَلاغُ.</p></div>"
  80,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأمّا مَن جاءَكَ يَسْعى﴾</span>، يُسْرِعُ في طَلَبِ الخَيْرِ.</p></div>"
  80,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُوَ يَخْشى﴾</span>، اَللَّهَ، أوِ الكُفّارَ، أيْ: أذاهم في إتْيانِكَ، أوِ الكَبْوَةَ، كَعادَةِ العُمْيانِ.</p></div>"
  80,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأنْتَ عَنْهُ تَلَهّى﴾</span>، تَتَشاغَلُ، وأصْلُهُ: "تَتَلَهّى"، ورُوِيَ أنَّهُ ما عَبَسَ بَعْدَها في وجْهِ فَقِيرٍ قَطُّ، ولا تَصَدّى لِغَنِيٍّ، ورُوِيَ أنَّ الفُقَراءَ في مَجْلِسِ الشُورى كانُوا أُمَراءَ.</p></div>"
  80,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ، أيْ: لا تَعُدْ إلى مِثْلِهِ،</p><p><span class="qpc-hafs">﴿إنَّها﴾</span>، إنَّ السُورَةَ، أوِ الآياتِ،</p><p><span class="qpc-hafs">﴿تَذْكِرَةٌ﴾</span>، مَوْعِظَةٌ يَجِبُ الِاتِّعاظُ بِها، والعَمَلُ بِمُوجِبِها.</p></div>"
  80,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَن شاءَ ذَكَرَهُ﴾</span>، فَمَن شاءَ اللهُ أنْ يَذْكُرَهُ، أوْ ذَكَرَ الضَمِيرَ، لِأنَّ التَذْكِرَةَ في مَعْنى الذِكْرِ والوَعْظِ، والمَعْنى: فَمَن شاءَ الذِكْرَ ألْهَمَهُ اللهُ (تَعالى) إيّاهُ.</p></div>"
  80,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي صُحُفٍ﴾</span>، صِفَةٌ لِـ "تَذْكِرَةٌ"، أيْ: إنَّها مُثْبَتَةٌ في صُحُفٍ مُنْتَسَخَةٌ مِنَ اللَوْحِ، أوْ خَبَرُ مُبْتَدَإٍ مَحْذُوفٍ، أيْ: "هِيَ في صُحُفٍ"،</p><p><span class="qpc-hafs">﴿مُكَرَّمَةٍ﴾</span>، عِنْدَ اللهِ.</p></div>"
  80,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرْفُوعَةٍ﴾</span>، في السَماءِ، أوْ مَرْفُوعَةِ القَدْرِ، والمَنزِلَةِ،</p><p><span class="qpc-hafs">﴿مُطَهَّرَةٍ﴾</span>، عَنْ مَسِّ غَيْرِ المَلائِكَةِ، أوْ عَمّا لَيْسَ مِن كَلامِ اللهِ (تَعالى).</p></div>"
  80,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأيْدِي سَفَرَةٍ﴾</span>، كَتَبَةٍ، جَمْعُ "سافِرٌ"، أيْ: اَلْمَلائِكَةُ يَنْتَسِخُونَ الكُتُبَ مِنَ اللَوْحِ.</p></div>"
  80,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِرامٍ﴾</span>، عَلى اللهِ، أوْ عَنِ المَعاصِي،</p><p><span class="qpc-hafs">﴿بَرَرَةٍ﴾</span>، أتْقِياءَ، جَمْعُ "بارٌّ".</p></div>"
  80,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُتِلَ الإنْسانُ﴾</span>، لُعِنَ الكافِرُ، أوْ هو أُمَيَّةُ، أوْ عُتْبَةُ،</p><p><span class="qpc-hafs">﴿ما أكْفَرَهُ﴾</span>، اِسْتِفْهامُ تَوْبِيخٍ، أيْ: أيُّ شَيْءٍ حَمَلَهُ عَلى الكُفْرِ؟! أوْ هو تَعَجُّبٌ، أيْ: ما أشَدَّ كُفْرَهُ!</p></div>"
  80,18,"<div class=ar lang=ar><p>(p-٦٠٣)<span class="qpc-hafs">﴿مِن أيِّ شَيْءٍ خَلَقَهُ﴾</span>، مِن أيِّ حَقِيرٍ خَلَقَهُ؟! وهو اسْتِفْهامٌ، ومَعْناهُ التَقْرِيرُ، ثُمَّ بَيَّنَ ذَلِكَ الشَيْءَ، فَقالَ:</p></div>"
  80,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾</span>، عَلى ما يَشاءُ مِن خِلْقَةٍ.</p></div>"
  80,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ السَبِيلَ يَسَّرَهُ﴾</span>، نُصِبَ "اَلسَّبِيلَ"، بِإضْمارِ "يَسَّرَ"، أيْ: ثُمَّ سَهَّلَ لَهُ سَبِيلَ الخُرُوجِ مِن بَطْنِ أُمِّهِ، أوْ بَيَّنَ لَهُ سَبِيلَ الخَيْرِ والشَرِّ.</p></div>"
  80,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ أماتَهُ فَأقْبَرَهُ﴾</span>، جَعَلَهُ ذا قَبْرٍ يُوارى فِيهِ، لا كالبَهائِمِ، كَرامَةً لَهُ، "قَبَرَ المَيِّتَ": دَفَنَهُ، و"أقْبَرَ المَيِّتَ"، أمَرَهُ أنْ يُقْبِرَهُ، ومَكَّنَهُ مِنهُ.</p></div>"
  80,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ إذا شاءَ أنْشَرَهُ﴾</span>، أحْياهُ بَعْدَ مَوْتِهِ.</p></div>"
  80,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ لِلْإنْسانِ عَنِ الكُفْرِ،</p><p><span class="qpc-hafs">﴿لَمّا يَقْضِ ما أمَرَهُ﴾</span>، لَمْ يَفْعَلْ هَذا الكافِرُ ما أمَرَهُ اللهُ بِهِ مِنَ الإيمانِ، ولَمّا عَدَّدَ النِعَمَ في نَفْسِهِ، مِنَ ابْتِداءِ حُدُوثِهِ، إلى أنِ انْتَهى، أتْبَعَهُ ذِكْرَ النِعَمِ فِيما يَحْتاجُ إلَيْهِ، فَقالَ:</p></div>"
  80,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</span>، اَلَّذِي يَأْكُلُهُ، ويَحْيا بِهِ، كَيْفَ دَبَّرْنا أمْرَهُ.</p></div>"
  80,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أنّا﴾</span>، بِالفَتْحِ "كُوفِيٌّ"، عَلى أنَّهُ بَدَلُ اشْتِمالٍ مِنَ الطَعامِ، وبِالكَسْرِ، عَلى الِاسْتِئْنافِ، غَيْرُهُمْ،</p><p><span class="qpc-hafs">﴿صَبَبْنا الماءَ صَبًّا﴾</span>، يَعْنِي المَطَرَ، مِنَ السَحابِ.</p></div>"
  80,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ شَقَقْنا الأرْضَ شَقًّا﴾</span>، بِالنَباتِ.</p></div>"
  80,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأنْبَتْنا فِيها حَبًّا﴾</span>، كالبُرِّ، والشَعِيرِ، وغَيْرِهِما مِمّا يُتَغَذّى بِهِ.</p></div>"
  80,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعِنَبًا﴾</span>، ثَمَرَةُ الكَرْمِ، أيْ: اَلطَّعامَ، والفاكِهَةَ،</p><p><span class="qpc-hafs">﴿وَقَضْبًا﴾</span>، رُطَبَةٌ، سُمِّيَ بِمَصْدَرِ "قَضَبَهُ"، أيْ: قَطَعَهُ، لِأنَّهُ يُقْضَبُ مَرَّةً بَعْدَ مَرَّةٍ.</p></div>"
  80,29,"<div class=ar lang=ar></div>"
  80,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَدائِقَ﴾</span>، وبَساتِينَ،</p><p><span class="qpc-hafs">﴿غُلْبًا﴾</span>، غِلاظَ الأشْجارِ، جَمْعُ "غَلْباءُ".</p></div>"
  80,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفاكِهَةً﴾</span>، لَكُمْ،</p><p><span class="qpc-hafs">﴿وَأبًّا﴾</span>، مَرْعًى لِدَوابِّكم.</p></div>"
  80,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتاعًا﴾</span>، مَصْدَرٌ أيْ: مَنفَعَةً،</p><p><span class="qpc-hafs">﴿لَكم ولأنْعامِكُمْ﴾</span></p></div>"
  80,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإذا جاءَتِ الصاخَّةُ﴾</span>، صَيْحَةُ القِيامَةِ، لِأنَّها تَصُخُّ الآذانَ، أيْ: (p-٦٠٤)تَصِمُّها، وجَوابُهُ مَحْذُوفٌ، لِظُهُورِهِ.</p></div>"
  80,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ يَفِرُّ المَرْءُ مِن أخِيهِ﴾</span> <span class="qpc-hafs">﴿وَأُمِّهِ وأبِيهِ﴾</span>، لِتَبِعاتٍ بَيْنَهُ وبَيْنَهُمْ، أوْ لِاشْتِغالِهِ بِنَفْسِهِ.</p></div>"
  80,35,"80:34"
  80,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصاحِبَتِهِ﴾</span>، وزَوْجَتِهِ،</p><p><span class="qpc-hafs">﴿وَبَنِيهِ﴾</span>، بَدَأ بِالأخِ، ثُمَّ بِالأبَوَيْنِ، لِأنَّهُما أقْرَبُ مِنهُ، ثُمَّ بِالصاحِبَةِ، والبَنِينَ، لِأنَّهم أحَبُّ، قِيلَ: أوَّلُ مَن يَفِرُّ مِن أخِيهِ: هابِيلُ، ومِن أبَوَيْهِ: إبْراهِيمُ، ومِن صاحِبَتِهِ: نُوحٌ ولُوطٌ، ومِنَ ابْنِهِ: نُوحٌ.</p></div>"
  80,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِكُلِّ امْرِئٍ مِنهم يَوْمَئِذٍ شَأْنٌ﴾</span>، في نَفْسِهِ،</p><p><span class="qpc-hafs">﴿يُغْنِيهِ﴾</span>، يَكْفِيهِ في الِاهْتِمامِ بِهِ، ويَشْغَلُهُ عَنْ غَيْرِهِ.</p></div>"
  80,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ﴾</span>، مُضِيئَةٌ، مِن قِيامِ اللَيْلِ، أوْ مِن آثارِ الوُضُوءِ.</p></div>"
  80,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضاحِكَةٌ مُسْتَبْشِرَةٌ﴾</span> أيْ: أصْحابُ هَذِهِ الوُجُوهِ، وهُمُ المُؤْمِنُونَ، ضاحِكُونَ، مَسْرُورُونَ.</p></div>"
  80,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوُجُوهٌ يَوْمَئِذٍ عَلَيْها غَبَرَةٌ﴾</span>، غُبارٌ.</p></div>"
  80,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرْهَقُها قَتَرَةٌ﴾</span>، يَعْلُو الغُبارَ سَوادٌ كالدُخانِ، ولا تَرى أوْحَشَ مِنَ اجْتِماعِ الغَبَرَةِ والسَوادِ في الوَجْهِ.</p></div>"
  80,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُولَئِكَ﴾</span>، أهْلُ هَذِهِ الحالَةِ،</p><p><span class="qpc-hafs">﴿هُمُ الكَفَرَةُ﴾</span>، في حُقُوقِ اللهِ،</p><p><span class="qpc-hafs">﴿الفَجَرَةُ﴾</span>، في حُقُوقِ العِبادِ، ولَمّا جَمَعُوا الفُجُورَ إلى الكُفْرِ، جُمِعَ إلى سَوادِ وُجُوهِهِمُ الغَبَرَةُ.</p></div>"
