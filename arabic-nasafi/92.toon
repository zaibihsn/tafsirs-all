quran[21]{c,v,t}:
  92,1,"<div class=ar lang=ar><p>(p-٦٥٠)سُورَةُ "اَللَّيْلِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿واللَيْلِ إذا يَغْشى﴾</span>، اَلْمَغْشِيُّ إمّا الشَمْسُ، مِن قَوْلِهِ: <span class="qpc-hafs">﴿واللَيْلِ إذا يَغْشاها﴾</span> [الشمس: ٤]، أوِ النَهارُ، مِن قَوْلِهِ: <span class="qpc-hafs">﴿يُغْشِي اللَيْلَ النَهارَ﴾</span> [الأعراف: ٥٤]، أوْ كُلُّ شَيْءٍ يُوارِيهِ بِظَلامِهِ، مِن قَوْلِهِ: <span class="qpc-hafs">﴿إذا وقَبَ﴾</span> [الفلق: ٣]</p></div>"
  92,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والنَهارِ إذا تَجَلّى﴾</span>، ظَهَرَ بِزَوالِ ظُلْمَةِ اللَيْلِ.</p></div>"
  92,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما خَلَقَ الذَكَرَ والأُنْثى﴾</span>، والقادِرِ العَظِيمِ القُدْرَةِ، الَّذِي قَدَرَ عَلى خَلْقِ الذَكَرِ والأُنْثى، مِن ماءٍ واحِدٍ، وجَوابُ القَسَمِ:</p></div>"
  92,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ سَعْيَكم لَشَتّى﴾</span>، إنَّ عَمَلَكم لَمُخْتَلِفٌ، وبَيانُ الِاخْتِلافِ فِيما فَصَّلَ عَلى أثَرِهِ:</p></div>"
  92,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأمّا مَن أعْطى﴾</span>، حُقُوقَ مالِهِ،</p><p><span class="qpc-hafs">﴿واتَّقى﴾</span> رَبَّهُ، فاجْتَنَبَ مَحارِمَهُ.</p></div>"
  92,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَدَّقَ بِالحُسْنى﴾</span>، مِلَّةِ الحُسْنى، وهي مِلَّةُ الإسْلامِ، أوْ بِالمَثُوبَةِ الحُسْنى، وهي الجَنَّةُ، أوْ بِالكَلِمَةِ الحُسْنى، وهِيَ: "لا إلَهَ إلّا اللهُ".</p></div>"
  92,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَنُيَسِّرُهُ لِلْيُسْرى﴾</span>، فَسَنُهَيِّئُهُ لِلْخَلَّةِ اليُسْرى، وهي العَمَلُ بِما يَرْضاهُ رَبُّهُ.</p></div>"
  92,8,"<div class=ar lang=ar><p>(p-٦٥١)<span class="qpc-hafs">﴿وَأمّا مَن بَخِلَ﴾</span>، بِمالِهِ،</p><p><span class="qpc-hafs">﴿واسْتَغْنى﴾</span>، عَنْ رَبِّهِ، فَلَمْ يَتَّقِهِ، أوِ اسْتَغْنى بِشَهَواتِ الدُنْيا عَنْ نَعِيمِ العُقْبى.</p></div>"
  92,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَّبَ بِالحُسْنى﴾</span>، بِالإسْلامِ، أوِ الجَنَّةِ.</p></div>"
  92,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَنُيَسِّرُهُ لِلْعُسْرى﴾</span> لِلْخَلَّةِ المُؤَدِّيَةِ إلى النارِ، فَتَكُونُ الطاعَةُ أعْسَرَ شَيْءٍ عَلَيْهِ، وأشَدَّ، أوْ سَمّى طَرِيقَةَ الخَيْرِ بِـ "اَلْيُسْرى"، لِأنَّ عاقِبَتَها اليُسْرُ، وطَرِيقَةَ الشَرِّ بِـ "اَلْعُسْرى"، لِأنَّ عاقِبَتَها العُسْرُ، أوْ أرادَ بِهِما طَرِيقَيِ الجَنَّةِ، والنارِ.</p></div>"
  92,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما يُغْنِي عَنْهُ مالُهُ إذا تَرَدّى﴾</span>، ولَمْ يَنْفَعْهُ مالُهُ إذا هَلَكَ، و"تَرَدّى": "تَفَعَّلَ مِن "اَلرَّدى"، وهو الهَلاكُ، أوْ: تَرَدّى في القَبْرِ، أوْ في قَعْرِ جَهَنَّمَ، أيْ: سَقَطَ.</p></div>"
  92,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ عَلَيْنا لَلْهُدى﴾</span>، إنَّ عَلَيْنا الإرْشادَ إلى الحَقِّ، بِنَصْبِ الدَلائِلِ وبَيانِ الشَرائِعِ.</p></div>"
  92,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّ لَنا لَلآخِرَةَ والأُولى﴾</span>، فَلا يَضُرُّنا ضَلالُ مَن ضَلَّ، ولا يَنْفَعُنا اهْتِداءُ مَنِ اهْتَدى، أوْ: إنَّهُما لَنا، فَمَن طَلَبَهُما مِن غَيْرِنا فَقَدْ أخْطَأ الطَرِيقَ.</p></div>"
  92,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأنْذَرْتُكُمْ﴾</span>، خَوَّفْتُكُمْ،</p><p><span class="qpc-hafs">﴿نارًا تَلَظّى﴾</span>، تَتَلَهَّبُ.</p></div>"
  92,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لا يَصْلاها﴾</span>، لا يَدْخُلُها لِلْخُلُودِ فِيها،</p><p><span class="qpc-hafs">﴿إلا الأشْقى﴾</span> <span class="qpc-hafs">﴿الَّذِي كَذَّبَ وتَوَلّى﴾</span>، إلّا الكافِرَ الَّذِي كَذَّبَ الرُسُلَ، وأعْرَضَ عَنِ الإيمانِ.</p></div>"
  92,16,"92:15"
  92,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسَيُجَنَّبُها﴾</span>، وسُبْعَدُ مِنها،</p><p><span class="qpc-hafs">﴿الأتْقى﴾</span>، اَلْمُؤْمِنُ.</p></div>"
  92,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي يُؤْتِي مالَهُ﴾</span>، لِلْفُقَراءِ،</p><p><span class="qpc-hafs">﴿يَتَزَكّى﴾</span>، مِن "اَلزَّكاةِ"، أيْ: يَطْلُبُ أنْ يَكُونَ عِنْدَ اللهِ زاكِيًا، لا يُرِيدُ بِهِ رِياءً، ولا سُمْعَةً، أوْ "يَتَفَعَّلُ"، مِن "اَلزَّكاةُ"، و"يَتَزَكّى"، إنْ جَعَلْتَهُ بَدَلًا مِن "يُؤْتِي"، فَلا مَحَلَّ لَهُ، لِأنَّهُ داخِلٌ في حُكْمِ الصِلَةِ، والصِلاتُ لا مَحَلَّ لَها، وإنْ جَعَلْتَهُ حالًا مِنَ الضَمِيرِ في "يُؤْتِي"، فَمَحَلُّهُ النَصْبُ، قالَ أبُو عُبَيْدَةَ: "اَلْأشْقى"، بِمَعْنى: "اَلشَّقِيُّ"، وهو الكافِرُ، و"اَلْأتْقى"، بِمَعْنى "اَلتَّقِيُّ"، وهو المُؤْمِنُ، لِأنَّهُ لا يُخْتَصُّ بِالصِّلِيِّ أشْقى الأشْقِياءِ، ولا بِالنَجاةِ أتْقى الأتْقِياءِ، وإنْ زَعَمْتَ أنَّهُ نَكَّرَ النارَ فَأرادَ نارًا مَخْصُوصَةً بِالأشْقى، فَما تَصْنَعُ بِقَوْلِهِ: "وَسَيُجَنَّبُها الأتْقى"؟! لِأنَّ المُتَّقِي يُجَنَّبُ تِلْكَ النارَ المَخْصُوصَةَ، لا الأتْقى مِنهم (p-٦٥٢)خاصَّةً، وقِيلَ: اَلْآيَةُ وارِدَةٌ في المُوازَنَةِ بَيْنَ حالَتَيْ عَظِيمٍ مِنَ المُشْرِكِينَ، وعَظِيمٍ مِنَ المُؤْمِنِينَ، فَأُرِيدَ أنْ يُبالَغَ في صِفَتَيْهِما، فَقِيلَ: "اَلْأشْقى"، وجُعِلَ مُخْتَصًّا بِالصِلِيِّ، كَأنَّ النارَ لَمْ تُخْلَقْ إلّا لَهُ، وقِيلَ: "اَلْأتْقى"، وجُعِلَ مُخْتَصًّا بِالنَجاةِ، كَأنَّ الجَنَّةَ لَمْ تُخْلَقْ إلّا لَهُ، وقِيلَ: هُما أبُو جَهْلٍ، وأبُو بَكْرٍ، وفِيهِ بُطْلانُ زَعْمِ المُرْجِئَةِ، لِأنَّهم يَقُولُونَ: لا يَدْخُلُ النارَ إلّا كافِرٌ.</p></div>"
  92,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما لأحَدٍ عِنْدَهُ مِن نِعْمَةٍ تُجْزى﴾</span> <span class="qpc-hafs">﴿إلا ابْتِغاءَ وجْهِ رَبِّهِ﴾</span> أيْ: وما لِأحَدٍ عِنْدَ اللهِ نِعْمَةٌ يُجازِيهِ بِها إلّا أنْ يَفْعَلَ فِعْلًا يَبْتَغِي بِهِ وجْهَ رَبِّهِ، فَيُجازى عَلَيْهِ،</p><p><span class="qpc-hafs">﴿الأعْلى﴾</span>، هو الرَفِيعُ بِسُلْطانِهِ، المَنِيعُ في شَأْنِهِ وبُرْهانِهِ، ولَمْ يُرَدْ بِهِ العُلُوُّ مِن حَيْثُ المَكانُ، فَذا آيَةُ الحُدْثانِ.</p></div>"
  92,20,"92:19"
  92,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَسَوْفَ يَرْضى﴾</span>، مَوْعِدٌ بِالثَوابِ الَّذِي يُرْضِيهِ، ويُقِرُّ عَيْنَهُ، وهو كَقَوْلِهِ (تَعالى) لِنَبِيِّهِ ﷺ: <span class="qpc-hafs">﴿وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضى﴾</span> [الضحى: ٥]</p></div>"
