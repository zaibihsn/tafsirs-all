quran[19]{c,v,t}:
  82,1,"<div class=ar lang=ar><p>(p-٦١٠)سُورَةُ "اَلِانْفِطارِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿إذا السَماءُ انْفَطَرَتْ﴾</span>، اِنْشَقَّتْ.</p></div>"
  82,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا الكَواكِبُ انْتَثَرَتْ﴾</span>، تَساقَطَتْ.</p></div>"
  82,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا البِحارُ فُجِّرَتْ﴾</span>، فُتِحَ بَعْضُها إلى بَعْضٍ، وصارَتِ البِحارُ بَحْرًا واحِدًا.</p></div>"
  82,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا القُبُورُ بُعْثِرَتْ﴾</span>، بُحِثَتْ، وأُخْرِجَ مَوْتاها، وجَوابُ "إذا":</p></div>"
  82,5,"<div class=ar lang=ar><p>.</p><p><span class="qpc-hafs">﴿عَلِمَتْ نَفْسٌ﴾</span> أيْ: كُلُّ نَفْسٍ بَرَّةٍ، وفاجِرَةٍ،</p><p><span class="qpc-hafs">﴿ما قَدَّمَتْ﴾</span>، ما عَمِلَتْ مِن طاعَةٍ،</p><p><span class="qpc-hafs">﴿وَأخَّرَتْ﴾</span>، وتَرَكَتْ، فَلَمْ تَعْمَلْ، أوْ: ما قَدَّمَتْ مِنَ الصَدَقاتِ، وما أخَّرَتْ مِنَ المِيراثِ.</p></div>"
  82,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يا أيُّها الإنْسانُ﴾</span>، قِيلَ: اَلْخِطابُ لِمُنْكِرِي البَعْثِ،</p><p><span class="qpc-hafs">﴿ما غَرَّكَ بِرَبِّكَ الكَرِيمِ﴾</span> <span class="qpc-hafs">﴿الَّذِي خَلَقَكَ﴾</span> أيُّ شَيْءٍ خَدَعَكَ حَتّى ضَيَّعْتَ ما وجَبَ عَلَيْكَ، مَعَ كَرَمِ رَبِّكَ، حَيْثُ أنْعَمَ عَلَيْكَ بِالخَلْقِ، والتَسْوِيَةِ، والتَعْدِيلِ، «وَعَنْهُ ﷺ حِينَ تَلاها -: "غَرَّهُ جَهْلُهُ"، » وعَنْ عُمَرَ - رَضِيَ اللهُ عَنْهُ -: "غَرَّهُ حُمْقُهُ"، وعَنِ الحَسَنِ: "غَرَّهُ شَيْطانُهُ"، وعَنِ الفُضَيْلِ: "لَوْ خُوطِبْتُ، أقُولُ: غَرَّتْنِي سُتُورُكَ المُرْخاةُ"، وعَنْ يَحْيى بْنِ مُعاذٍ: "أقُولُ: غَرَّنِي بِرُّكَ بِي سالِفًا وآنِفًا"،</p><p><span class="qpc-hafs">﴿فَسَوّاكَ﴾</span>، فَجَعَلَكَ مُسْتَوِيَ (p-٦١١)الخَلْقِ، سالِمَ الأعْضاءِ، "فَعَدَّلَكَ"، فَصَيَّرَكَ مُعْتَدِلًا، مُتَناسِبَ الخَلْقِ، مِن غَيْرِ تَفاوُتٍ فِيهِ، فَلَمْ يَجْعَلْ إحْدى اليَدَيْنِ أطْوَلَ، ولا إحْدى العَيْنَيْنِ أوْسَعَ، ولا بَعْضَ الأعْضاءِ أبْيَضَ وبَعْضَها أسْوَدَ، أوْ جَعَلَكَ مُعْتَدِلَ الخَلْقِ تَمْشِي قائِمًا، لا كالبَهائِمِ، وبِالتَخْفِيفِ، "كُوفِيٌّ"، وهو بِمَعْنى المُشَدَّدِ، أيْ: عَدَلَ بَعْضَ أعْضائِكَ بِبَعْضٍ، حَتّى اعْتَدَلَتْ، فَكُنْتَ مُعْتَدِلَ الخِلْقَةِ، مُتَناسِبًا.</p></div>"
  82,7,"82:6"
  82,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي أيِّ صُورَةٍ ما شاءَ رَكَّبَكَ﴾</span>، "ما"، مَزِيدٌ لِلتَّوْكِيدِ، أيْ: رَكَّبَكَ في أيِّ صُورَةٍ اقْتَضَتْها مَشِيئَتُهُ، مِنَ الصُوَرِ المُخْتَلِفَةِ في الحُسْنِ، والقُبْحِ، والطُولِ، والقِصَرِ، ولَمْ تُعْطَفْ هَذِهِ الجُمْلَةُ كَما عُطِفَ ما قَبْلَها، لِأنَّها بَيانٌ لِـ "عَدَلَكَ"، والجارُّ يَتَعَلَّقُ بِـ "رَكَّبَكَ"، عَلى مَعْنى: وضَعَكَ في بَعْضِ الصُوَرِ، ومَكَّنَكَ فِيها، أوْ بِمَحْذُوفٍ، أيْ: رَكَّبَكَ حاصِلًا في بَعْضِ الصُوَرِ.</p></div>"
  82,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ عَنِ الغَفْلَةِ عَنِ اللهِ (تَعالى)،</p><p><span class="qpc-hafs">﴿بَلْ تُكَذِّبُونَ بِالدِينِ﴾</span>، أصْلًا، وهو الجَزاءُ، أوْ دِينُ الإسْلامِ، فَلا تُصَدِّقُونَ ثَوابًا، ولا عِقابًا.</p></div>"
  82,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّ عَلَيْكم لَحافِظِينَ﴾</span>، أعْمالَكُمْ، وأقْوالَكُمْ، مِنَ المَلائِكَةِ.</p></div>"
  82,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِرامًا كاتِبِينَ﴾</span>، يَعْنِي: إنَّكم تُكَذِّبُونَ بِالجَزاءِ، والكاتِبُونَ يَكْتُبُونَ عَلَيْكم أعْمالَكُمْ، لِتُجازَوْا بِها.</p></div>"
  82,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعْلَمُونَ ما تَفْعَلُونَ﴾</span>، لا يَخْفى عَلَيْهِمْ شَيْءٌ مِن أعْمالِكُمْ، وفي تَعْظِيمِ الكَتَبَةِ، بِالثَناءِ عَلَيْهِمْ، تَعْظِيمٌ لِأمْرِ الجَزاءِ، وأنَّهُ عِنْدَ اللهِ مِن جَلائِلِ الأُمُورِ، وفِيهِ إنْذارٌ، وتَهْوِيلٌ لِلْمُجْرِمِينَ، ولُطْفٌ لِلْمُتَّقِينَ، وعَنِ الفُضَيْلِ أنَّهُ إذا قَرَأها قالَ: "ما أشَدَّها مِن آيَةٍ عَلى الغافِلِينَ!".</p></div>"
  82,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ الأبْرارَ لَفي نَعِيمٍ﴾</span> إنَّ المُؤْمِنِينَ لَفي نَعِيمِ الجَنَّةِ.</p></div>"
  82,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّ الفُجّارَ لَفي جَحِيمٍ﴾</span>، وإنَّ الكُفّارَ لَفي النارِ.</p></div>"
  82,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصْلَوْنَها يَوْمَ الدِينِ﴾</span>، يَدْخُلُونَها يَوْمَ الجَزاءِ.</p></div>"
  82,16,"<div class=ar lang=ar><p>(p-٦١٢)<span class="qpc-hafs">﴿وَما هم عَنْها بِغائِبِينَ﴾</span> أيْ: لا يَخْرُجُونَ مِنها، كَقَوْلِهِ (تَعالى): <span class="qpc-hafs">﴿وَما هم بِخارِجِينَ مِنها﴾</span> [المائدة: ٣٧]، ثُمَّ عَظَّمَ شَأْنَ يَوْمِ القِيامَةِ، فَقالَ:</p></div>"
  82,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أدْراكَ ما يَوْمُ الدِينِ﴾</span> <span class="qpc-hafs">﴿ثُمَّ ما أدْراكَ ما يَوْمُ الدِينِ﴾</span>، فَكَرَّرَ لِلتَّأْكِيدِ، والتَهْوِيلِ، وبَيَّنَهُ بِقَوْلِهِ:</p></div>"
  82,18,"82:17"
  82,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ لا تَمْلِكُ نَفْسٌ لِنَفْسٍ شَيْئًا﴾</span> أيْ: لا تَسْتَطِيعُ دَفْعًا عَنْها، ولا نَفْعًا لَها بِوَجْهٍ، وإنَّما تُمْلَكُ الشَفاعَةُ بِالإذْنِ، "يَوْمُ"، بِالرَفْعِ، "مَكِّيٌّ وبَصْرِيٌّ"، أيْ: "هُوَ يَوْمُ... "، أوْ بَدَلٌ مِن "يَوْمُ الدِينِ"، ومَن نَصَبَ فَبِإضْمارِ "اُذْكُرْ"، أوْ بِإضْمارِ "يُدانُونَ"، لِأنَّ "اَلدِّينِ"، يَدُلُّ عَلَيْهِ،</p><p><span class="qpc-hafs">﴿والأمْرُ يَوْمَئِذٍ لِلَّهِ﴾</span> أيْ: لا أمْرَ إلّا لِلَّهِ (تَعالى) وحْدَهُ، فَهو القاضِي فِيهِ دُونَ غَيْرِهِ.</p></div>"
