quran[50]{c,v,t}:
  77,1,"<div class=ar lang=ar><p>(p-٥٨٤)سُورَةُ "اَلْمُرْسَلاتِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿والمُرْسَلاتِ عُرْفًا﴾</span> <span class="qpc-hafs">﴿فالعاصِفاتِ عَصْفًا﴾</span> <span class="qpc-hafs">﴿والناشِراتِ نَشْرًا﴾</span> <span class="qpc-hafs">﴿فالفارِقاتِ فَرْقًا﴾</span> <span class="qpc-hafs">﴿فالمُلْقِياتِ ذِكْرًا﴾</span> <span class="qpc-hafs">﴿عُذْرًا أوْ نُذْرًا﴾</span>، أقْسَمَ - سُبْحانَهُ وتَعالى - بِطَوائِفَ مِنَ المَلائِكَةِ، أرْسَلَهُنَّ بِأوامِرِهِ، فَعَصَفْنَ في مُضِيِّهِنَّ، وبِطَوائِفَ مِنهم نَشَرْنَ أجْنِحَتَهُنَّ في الجَوِّ عِنْدَ انْحِطاطِهِنَّ بِالوَحْيِ، أوْ نَشَرْنَ الشَرائِعَ في الأرْضِ، أوْ نَشَرْنَ النُفُوسَ المَوْتى بِالكُفْرِ والجَهْلِ بِما أوْحَيْنَ فَفَرَقْنَ بَيْنَ الحَقِّ، والباطِلِ، فَألْقَيْنَ ذِكْرًا إلى الأنْبِياءِ - عَلَيْهِمُ السَلامُ -، عُذْرًا لِلْمُحِقِّينَ، أوْ نُذُرًا لِلْمُبْطِلِينَ، أوْ: أقْسَمَ بِرِياحِ عَذابٍ، أرْسَلَهُنَّ فَعَصَفْنَ، وبِرِياحِ رَحْمَةٍ نَشَرْنَ السَحابَ في الجَوِّ، فَفَرَقْنَ بَيْنَهُ، كَقَوْلِهِ: <span class="qpc-hafs">﴿وَيَجْعَلُهُ كِسَفًا﴾</span> [الروم: ٤٨]، فَألْقَيْنَ ذِكْرًا، إمّا عُذْرًا لِلَّذِينِ يَعْتَذِرُونَ إلى اللهِ بِتَوْبَتِهِمْ، واسْتِغْفارِهِمْ، إذا رَأوْا نِعْمَةَ اللهِ في الغَيْثِ، ويَشْكُرُونَها، وإمّا نُذْرًا لِلَّذِينِ لا يَشْكُرُونَ، ويَنْسُبُونَ ذَلِكَ إلى الأنْواءِ، وجُعِلْنَ مُلْقِياتِ الذِكْرِ بِاعْتِبارِ السَبَبِيَّةِ، "عُرْفًا"، حالٌ، أيْ: مُتَتابِعَةً، كَعُرْفِ الفَرَسِ، يَتْلُو بَعْضُهُ بَعْضًا، أوْ مَفْعُولٌ لَهُ، أيْ: أُرْسِلْنَ لِلْإحْسانِ، والمَعْرُوفِ، و"عَصْفًا"، و"نَشْرًا"، مَصْدَرانِ، "أوْ نُذْرًا"، " أبُو عَمْرٍو وكُوفِيٌّ غَيْرَ أبِي بَكْرٍ وحَمّادٌ"، و"اَلْعُذْرُ"، و"اَلنُّذْرُ"، مَصْدَرانِ مِن "عَذَرَ"، إذا مَحا الإساءَةَ، ومِن "أنْذَرَ"، إذا خَوَّفَ عَلى فِعْلٍ، كَـ "اَلْكُفْرُ"، و"اَلشُّكْرُ"، (p-٥٨٥)وانْتِصابُهُما عَلى البَدَلِ مِن "ذِكْرًا"، أوْ عَلى المَفْعُولِ لَهُ.</p></div>"
  77,2,"77:1"
  77,3,"77:1"
  77,4,"77:1"
  77,5,"77:1"
  77,6,"77:1"
  77,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّما تُوعَدُونَ﴾</span>، إنَّ الَّذِي تُوعَدُونَهُ مِن مَجِيءِ يَوْمِ القِيامَةِ،</p><p><span class="qpc-hafs">﴿لَواقِعٌ﴾</span>، لَكائِنٌ، نازِلٌ، لا رَيْبَ فِيهِ، وهو جَوابُ القَسَمِ، ولا وقْفَ إلى هُنا، لِوَصْلِ الجَوابِ بِالقَسَمِ.</p></div>"
  77,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإذا النُجُومُ طُمِسَتْ﴾</span>، مُحِيَتْ، أوْ ذُهِبَ بِنُورِها، وجَوابُ "فَإذا"، مَحْذُوفٌ، والعامِلُ فِيها جَوابُها، وهو وُقُوعُ الفَصْلِ ونَحْوِهِ، و"اَلنُّجُومُ"، فاعِلُ فِعْلٍ يُفَسِّرُهُ "طُمِسَتْ".</p></div>"
  77,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا السَماءُ فُرِجَتْ﴾</span>، فُتِحَتْ، فَكانَتْ أبْوابًا.</p></div>"
  77,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا الجِبالُ نُسِفَتْ﴾</span>، قُلِعَتْ مِن أماكِنِها.</p></div>"
  77,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا الرُسُلُ أُقِّتَتْ﴾</span> أيْ: وُقِّتَتْ، كَقِراءَةِ أبِي عَمْرٍو، وأُبْدِلَتِ الهَمْزَةُ مِنَ الواوِ، ومَعْنى تَوْقِيتِ الرُسُلِ: تَبْيِينُ وقْتِها الَّذِي يَحْضُرُونَ فِيهِ لِلشَّهادَةِ عَلى أُمَمِهِمْ.</p></div>"
  77,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لأيِّ يَوْمٍ أُجِّلَتْ﴾</span>، أُخِّرَتْ، وأُمْهِلَتْ، وفِيهِ تَعْظِيمٌ لِلْيَوْمِ، وتَعْجِيبُ مِن هَوْلِهِ، والتَأْجِيلُ مِن "اَلْأجَلُ"، كَـ "اَلتَّوْقِيتُ"، مِن "اَلْوَقْتُ".</p></div>"
  77,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَوْمِ الفَصْلِ﴾</span>، بَيانٌ لِيَوْمِ التَأْجِيلِ، وهو اليَوْمُ الَّذِي يُفْصَلُ فِيهِ بَيْنَ الخَلائِقِ.</p></div>"
  77,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أدْراكَ ما يَوْمُ الفَصْلِ﴾</span>، تَعْجِيبٌ آخَرُ وتَعْظِيمٌ لِأمْرِهِ.</p></div>"
  77,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ﴾</span> [المرسلات: ١٩]، مُبْتَدَأٌ، وإنْ كانَ نَكِرَةً، لِأنَّهُ في أصْلِهِ مَصْدَرٌ مَنصُوبٌ سادٌّ مَسَدَّ فِعْلِهِ، ولَكِنَّهُ عُدِلَ بِهِ إلى الرَفْعِ، لِلدَّلالَةِ عَلى مَعْنى ثَباتِ الهَلاكِ، ودَوامِهِ لِلْمَدْعُوِّ عَلَيْهِ، ونَحْوُهُ: <span class="qpc-hafs">﴿سَلامٌ عَلَيْكُمْ﴾</span> [الرعد: ٢٤] <span class="qpc-hafs">﴿يَوْمَئِذٍ﴾</span>، ظَرْفُهُ،</p><p><span class="qpc-hafs">﴿لِلْمُكَذِّبِينَ﴾</span>، بِذَلِكَ اليَوْمِ، خَبَرُهُ.</p></div>"
  77,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألَمْ نُهْلِكِ الأوَّلِينَ﴾</span>، اَلْأُمَمَ الخالِيَةَ المُكَذِّبَةَ.</p></div>"
  77,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ نُتْبِعُهُمُ الآخِرِينَ﴾</span>، مُسْتَأْنَفٌ بَعْدَ وقْفٍ، وهو وعِيدٌ لِأهْلِ مَكَّةَ، أيْ: (p-٥٨٦)ثُمَّ نَفْعَلُ بِأمْثالِهِمْ مِنَ الآخِرِينَ مِثْلَما فَعَلْنا بِالأوَّلِينَ، لِأنَّهم كَذَّبُوا مِثْلَ تَكْذِيبِهِمْ.</p></div>"
  77,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَلِكَ﴾</span>، مِثْلُ ذَلِكَ الفِعْلِ الشَنِيعِ،</p><p><span class="qpc-hafs">﴿نَفْعَلُ بِالمُجْرِمِينَ﴾</span>، بِكُلِّ مَن أجْرَمَ.</p></div>"
  77,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِما أوْعَدْنا.</p></div>"
  77,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألَمْ نَخْلُقْكم مِن ماءٍ مَهِينٍ﴾</span>، حَقِيرٍ، وهو النُطْفَةُ.</p></div>"
  77,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَجَعَلْناهُ﴾</span> أيْ: اَلْماءَ،</p><p><span class="qpc-hafs">﴿فِي قَرارٍ مَكِينٍ﴾</span>، مَقَرٍّ يَتَمَكَّنُ فِيهِ، وهو الرَحِمُ، ومَحَلُّ.</p></div>"
  77,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلى قَدَرٍ مَعْلُومٍ﴾</span>، اَلْحالُ، أيْ: مُؤَخَّرًا إلى مِقْدارٍ مِنَ الوَقْتِ مَعْلُومٍ، قَدْ عَلِمَهُ اللهُ، وحَكَمَ بِهِ، وهو تِسْعَةُ أشْهُرٍ، أوْ ما فَوْقَها، أوْ ما دُونَها.</p></div>"
  77,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَدَرْنا﴾</span>، فَقَدَرْناهُ ذَلِكَ تَقْدِيرًا،</p><p><span class="qpc-hafs">﴿فَنِعْمَ القادِرُونَ﴾</span>، فَنِعْمَ المُقَدِّرُونَ لَهُ نَحْنُ! أوْ فَقَدَرْنا عَلى ذَلِكَ، فَنِعْمَ القادِرُونَ عَلَيْهِ نَحْنُ! والأوَّلُ أحَقُّ، لِقِراءَةِ نافِعٍ وعَلِيٍّ بِالتَشْدِيدِ، ولِقَوْلِهِ: <span class="qpc-hafs">﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾</span> [عبس: ١٩]</p></div>"
  77,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِنِعْمَةِ الفِطْرَةِ.</p></div>"
  77,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأرْضَ كِفاتًا﴾</span>، وهو مِن "كَفَتَ الشَيْءَ"، إذا ضَمَّهُ، وجَمَعَهُ، وهو اسْمُ ما يَكْفِتُ، كَقَوْلِهِمْ: "اَلضِّمامُ"، لِما يَضُمُّ، وبِهِ انْتَصَبَ.</p></div>"
  77,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أحْياءً وأمْواتًا﴾</span>، كَأنَّهُ قِيلَ: "كافِتَةً أحْياءً وأمْواتًا"، أوْ بِفِعْلٍ مُضْمَرٍ، يَدُلُّ عَلَيْهِ "كِفاتًا"، وهو "تَكْفِتُ"، أيْ: تَكْفِتُ أحْياءً عَلى ظَهْرِها، وأمْواتًا في بَطْنِها، والتَنْكِيرُ فِيهِما لِلتَّفْخِيمِ، أيْ: "تَكْفِتُ أحْياءً لا يُعَدُّونَ، وأمْواتًا لا يُحْصَرُونَ.</p></div>"
  77,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلْنا فِيها رَواسِيَ﴾</span>، جِبالًا ثَوابِتَ،</p><p><span class="qpc-hafs">﴿شامِخاتٍ﴾</span>، عالِياتٍ،</p><p><span class="qpc-hafs">﴿وَأسْقَيْناكم ماءً فُراتًا﴾</span>، عَذْبًا.</p></div>"
  77,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِهَذِهِ النِعْمَةِ.</p></div>"
  77,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span> أيْ: يُقالُ لِلْكافِرِينَ يَوْمَ القِيامَةِ: سِيرُوا إلى النارِ الَّتِي كُنْتُمْ بِها تُكَذِّبُونَ.</p></div>"
  77,30,"<div class=ar lang=ar><p>(p-٥٨٧)<span class="qpc-hafs">﴿انْطَلِقُوا﴾</span>، تَكْرِيرٌ لِلتَّوْكِيدِ،</p><p><span class="qpc-hafs">﴿إلى ظِلٍّ﴾</span>، دُخانِ جَهَنَّمَ،</p><p><span class="qpc-hafs">﴿ذِي ثَلاثِ شُعَبٍ﴾</span>، يَتَشَعَّبُ لِعِظَمِهِ ثَلاثَ شُعَبٍ، وهَكَذا الدُخانُ العَظِيمُ يَتَفَرَّقُ ثَلاثَ فِرَقٍ.</p></div>"
  77,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لا ظَلِيلٍ﴾</span>، نَعْتُ "ظَلٍّ"، أيْ: "لا مُظِلٍّ مِن حَرِّ ذَلِكَ اليَوْمِ، وحَرِّ النارِ،</p><p><span class="qpc-hafs">﴿وَلا يُغْنِي﴾</span>، في مَحَلِّ الجَرِّ، أيْ: وغَيْرُ مُغْنٍ عَنْهُمْ،</p><p><span class="qpc-hafs">﴿مِنَ اللهَبِ﴾</span>، مِن حَرِّ اللهَبِ شَيْئًا.</p></div>"
  77,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّها﴾</span> أيْ: اَلنّارُ،</p><p><span class="qpc-hafs">﴿تَرْمِي بِشَرَرٍ﴾</span>، هو ما تَطايَرَ مِنَ النارِ،</p><p><span class="qpc-hafs">﴿كالقَصْرِ﴾</span>، في العِظَمِ، وقِيلَ: هو الغَلِيظُ مِنَ الشَجَرِ، الواحِدَةُ "قَصْرَةٌ".</p></div>"
  77,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأنَّهُ جِمالَتٌ﴾</span>، "كُوفِيٌّ غَيْرَ أبِي بَكْرٍ "، جَمْعُ "جَمَلٌ"، "جِمالاتٌ"، غَيْرُهُمْ، جَمْعُ الجَمْعِ، "صُفْرٌ": جَمْعُ "أصْفَرُ"، أيْ: سُودٌ، تَضْرِبُ إلى الصُفْرَةِ، وشَبَّهَ الشَرَرَ بِالقُصُورِ، لِعِظَمِهِ، وارْتِفاعِهِ، وبِالجِمالِ، لِلْعِظَمِ والطُولِ واللَوْنِ.</p></div>"
  77,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِأنَّ هَذِهِ صِفَتُها.</p></div>"
  77,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</span>، وقُرِئَ بِنَصْبِ اليَوْمِ، أيْ: هَذا الَّذِي قُصَّ عَلَيْكم واقِعٌ يَوْمَئِذٍ، وسُئِلَ ابْنُ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما - عَنْ هَذِهِ الآيَةِ، وعَنْ قَوْلِهِ: <span class="qpc-hafs">﴿ثُمَّ إنَّكم يَوْمَ القِيامَةِ عِنْدَ رَبِّكم تَخْتَصِمُونَ﴾</span> [الزمر: ٣١]، فَقالَ: "فِي ذَلِكَ اليَوْمِ مَواقِفُ، في بَعْضِها يَخْتَصِمُونَ، وفي بَعْضِها لا يَنْطِقُونَ"، أوْ لا يَنْطِقُونَ بِما يَنْفَعُهُمْ، فَجُعِلَ نُطْقُهم كَـ "لا نُطْقَ".</p></div>"
  77,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا يُؤْذَنُ لَهُمْ﴾</span>، في الِاعْتِذارِ،</p><p><span class="qpc-hafs">﴿فَيَعْتَذِرُونَ﴾</span>، عَطْفٌ عَلى "يُؤْذَنُ"، مُنْخَرِطٌ في سِلْكِ النَفْيِ، أيْ: لا يَكُونُ لَهم إذَنٌ واعْتِذارٌ.</p></div>"
  77,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِهَذا اليَوْمِ.</p></div>"
  77,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذا يَوْمُ الفَصْلِ﴾</span>، بَيْنَ المُحِقِّ، والمُبْطِلِ، والمُحْسِنِ، والمُسِيءِ، بِالجَزاءِ، (p-٥٨٨)<span class="qpc-hafs">﴿جَمَعْناكُمْ﴾</span>، يا مُكَذِّبِي مُحَمَّدٍ،</p><p><span class="qpc-hafs">﴿والأوَّلِينَ﴾</span>، والمُكَذِّبِينَ قَبْلَكم.</p></div>"
  77,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإنْ كانَ لَكم كَيْدٌ﴾</span>، حِيلَةٌ في دَفْعِ العَذابِ،</p><p><span class="qpc-hafs">﴿فَكِيدُونِ﴾</span>، فاحْتالُوا عَلَيَّ بِتَخْلِيصِ أنْفُسِكم مِنَ العَذابِ، و"اَلْكَيْدُ"، مُتَّعَدٍ، تَقُولُ: "كِدْتُ فُلانًا"، إذا احْتَلْتَ عَلَيْهِ.</p></div>"
  77,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِالبَعْثِ.</p></div>"
  77,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ المُتَّقِينَ﴾</span>، مِن عَذابِ اللهِ،</p><p><span class="qpc-hafs">﴿فِي ظِلالٍ﴾</span>، جَمْعُ "ظِلٌّ"،</p><p><span class="qpc-hafs">﴿وَعُيُونٍ﴾</span>، جارِيَةٍ في الجَنَّةِ.</p></div>"
  77,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَواكِهَ مِمّا يَشْتَهُونَ﴾</span> أيْ: لَذِيذَةٍ مُشْتَهاةٍ.</p></div>"
  77,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلُوا واشْرَبُوا﴾</span>، في مَوْضِعِ الحالِ مِن ضَمِيرِ "اَلْمُتَّقِينَ"، في الظَرْفِ الَّذِي هو "فِي ظِلالٍ"، أيْ: هم مُسْتَقِرُّونَ في ظِلالٍ، مَقُولًا لَهم ذَلِكَ،</p><p><span class="qpc-hafs">﴿هَنِيئًا بِما كُنْتُمْ تَعْمَلُونَ﴾</span>، في الدُنْيا.</p></div>"
  77,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾</span>، فَأحْسِنُوا، تُجْزَوْا بِهَذا.</p></div>"
  77,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِالجَنَّةِ.</p></div>"
  77,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلُوا وتَمَتَّعُوا﴾</span>، كَلامٌ مُسْتَأْنَفٌ، خِطابٌ لِلْمُكَذِّبِينَ في الدُنْيا، عَلى وجْهِ التَهْدِيدِ، كَقَوْلِهِ: <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span> [فصلت: ٤٠] <span class="qpc-hafs">﴿قَلِيلا﴾</span>، لِأنَّ مَتاعَ الدُنْيا قَلِيلٌ،</p><p><span class="qpc-hafs">﴿إنَّكم مُجْرِمُونَ﴾</span>، كافِرُونَ، أيْ: إنَّ كُلَّ مُجْرِمٍ يَأْكُلُ ويَتَمَتَّعُ أيّامًا قَلائِلَ، ثُمَّ يَبْقى في الهَلاكِ الدائِمِ.</p></div>"
  77,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِالنِعَمِ.</p></div>"
  77,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا قِيلَ لَهُمُ ارْكَعُوا﴾</span>، اِخْشَعُوا لِلَّهِ، وتَواضَعُوا إلَيْهِ بِقَبُولِ وحْيِهِ، واتِّباعِ دِينِهِ، ودَعُوا هَذا الِاسْتِكْبارَ،</p><p><span class="qpc-hafs">﴿لا يَرْكَعُونَ﴾</span>، لا يَخْشَعُونَ، ولا يَقْبَلُونَ ذَلِكَ، ويُصِرُّونَ عَلى اسْتِكْبارِهِمْ، وإذا قِيلَ لَهُمْ: صَلُّوا، لا يُصَلُّونَ.</p></div>"
  77,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span>، بِالأمْرِ، والنَهْيِ.</p></div>"
  77,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأيِّ حَدِيثٍ بَعْدَهُ﴾</span>، بَعْدَ القُرْآنِ،</p><p><span class="qpc-hafs">﴿يُؤْمِنُونَ﴾</span> أيْ: إنْ لَمْ يُؤْمِنُوا بِالقُرْآنِ، مَعَ أنَّهُ آيَةٌ مُبْصِرَةٌ، ومُعْجِزَةٌ باهِرَةٌ، مِن بَيْنِ الكُتُبِ السَماوِيَّةِ، فَبِأيِّ كِتابٍ بَعْدَهُ يُؤْمِنُونَ؟!</p></div>"
