quran[25]{c,v,t}:
  84,1,"<div class=ar lang=ar><p>(p-٦١٩)سُورَةُ "اَلِانْشِقاقِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿إذا السَماءُ انْشَقَّتْ﴾</span>، تَصَدَّعَتْ وتَشَقَّقَتْ.</p></div>"
  84,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأذِنَتْ لِرَبِّها﴾</span>، سَمِعَتْ، وأطاعَتْ، وأجابَتْ رَبَّها إلى الِانْشِقاقِ، ولَمْ تَأْبَ، ولَمْ تَمْتَنِعْ،</p><p><span class="qpc-hafs">﴿وَحُقَّتْ﴾</span>، وحُقَّ لَها أنْ تَسْمَعَ وتُطِيعَ لِأمْرِ اللهِ، إذْ هي مَصْنُوعَةٌ مَرْبُوبَةٌ لِلَّهِ (تَعالى).</p></div>"
  84,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا الأرْضُ مُدَّتْ﴾</span> بُسِطَتْ، وسُوِّيَتْ بِانْدِكاكِ جِبالِها، وكُلِّ أمْتٍ فِيها.</p></div>"
  84,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَألْقَتْ ما فِيها﴾</span>، ورَمَتْ ما في جَوْفِها مِنَ الكُنُوزِ والمَوْتى،</p><p><span class="qpc-hafs">﴿وَتَخَلَّتْ﴾</span>، وخَلَتْ غايَةَ الخُلُوِّ، حَتّى لَمْ يَبْقَ شَيْءٌ في باطِنِها، كَأنَّها تَكَلَّفَتْ أقْصى جُهْدِها في الخُلُوِّ، يُقالُ: "تَكَرَّمَ الكَرِيمُ"، إذا بَلَغَ جُهْدَهُ في الكَرَمِ، وتَكَلَّفَ فَوْقَ ما في طَبْعِهِ.</p></div>"
  84,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأذِنَتْ لِرَبِّها﴾</span> [الإنشقاق: ٢]، في إلْقاءِ ما في بَطْنِها، وتَخَلِّيها،</p><p><span class="qpc-hafs">﴿وَحُقَّتْ﴾</span> [الإنشقاق: ٢]، وهي حَقِيقَةٌ بِأنْ تَنْقادَ، ولا تَمْتَنِعَ، وحَذَفَ جَوابَ "إذا"، لِيَذْهَبَ المُقَدَّرُ كُلَّ مُذْهَبٍ، أوِ اكْتِفاءً بِما عُلِمَ بِمِثْلِها مِن سُورَتَيِ "اَلتَّكْوِيرِ"، و"اَلِانْفِطارِ"، أوْ جَوابُهُ ما دَلَّ عَلَيْهِ "فَمُلاقِيهِ"، أيْ: إذا السَماءُ انْشَقَّتْ لاقى الإنْسانُ كَدْحَهُ.</p></div>"
  84,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يا أيُّها الإنْسانُ﴾</span>، خِطابٌ لِلْجِنْسِ،</p><p><span class="qpc-hafs">﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span>، جاهِدٌ إلى لِقاءِ رَبِّكَ كَدْحًا، وهو المَوْتُ، وما بَعْدَهُ مِنَ الحالِ المُمَثَّلَةِ بِاللِقاءِ،</p><p><span class="qpc-hafs">﴿فَمُلاقِيهِ﴾</span> اَلضَّمِيرُ لِلْكَدْحِ، وهو جُهْدُ النَفْسِ في العَمَلِ، والكَدُّ فِيهِ حَتّى يُؤَثِّرَ فِيها، (p-٦٢٠)والمُرادُ جَزاءُ الكَدْحِ، إنْ خَيْرًا فَخَيْرٌ وإنْ شَرًّا فَشَرٌّ، وقِيلَ: لِقاءُ الكَدْحِ لِقاءُ كِتابٍ فِيهِ ذَلِكَ الكَدْحُ، يَدُلُّ عَلَيْهِ قَوْلُهُ:</p></div>"
  84,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ﴾</span> أيْ: كِتابَ عَمَلِهِ.</p></div>"
  84,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span>، سَهْلًا، هَيِّنًا، وهو أنْ يُجازى عَلى الحَسَناتِ ويُتَجاوَزَ عَنِ السَيِّئاتِ، وفي الحَدِيثِ: « "مَن يُحاسَبْ يُعَذَّبْ » "، فَقِيلَ: فَأيْنَ قَوْلُهُ: <span class="qpc-hafs">﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span>، قالَ: « "ذَلِكُمُ العَرْضُ، مَن نُوقِشَ في الحِسابِ عُذِّبَ" ».</p></div>"
  84,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَنْقَلِبُ إلى أهْلِهِ مَسْرُورًا﴾</span>، إلى عَشِيرَتِهِ، إنْ كانُوا مُؤْمِنِينَ، أوْ إلى فَرِيقِ المُؤْمِنِينَ، أوْ إلى أهْلِهِ في الجَنَّةِ، مِنَ الحُورِ العِينِ،</p><p><span class="qpc-hafs">﴿مَسْرُورًا﴾</span>، فَرِحًا.</p></div>"
  84,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</span>، قِيلَ: تُغَلُّ يُمْناهُ إلى عُنُقِهِ، وتُجْعَلُ شِمالَهُ وراءَ ظَهْرِهِ، فَيُؤْتى كِتابَهُ بِشِمالِهِ، مِن وراءِ ظَهْرِهِ.</p></div>"
  84,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَوْفَ يَدْعُو ثُبُورًا﴾</span>، يَقُولُ: يا ثُبُوراهُ، و"اَلثُّبُورُ": اَلْهَلاكُ.</p></div>"
  84,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَصْلى﴾</span>، "عِراقِيٌّ غَيْرَ عَلِيٍّ"،</p><p><span class="qpc-hafs">﴿سَعِيرًا﴾</span> أيْ: ويَدْخُلُ جَهَنَّمَ.</p></div>"
  84,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّهُ كانَ﴾</span>، في الدُنْيا،</p><p><span class="qpc-hafs">﴿فِي أهْلِهِ﴾</span>، مَعَهُمْ،</p><p><span class="qpc-hafs">﴿مَسْرُورًا﴾</span>، بِالكُفْرِ، يَضْحَكُ مِمَّنْ آمَنَ بِالبَعْثِ، قِيلَ: كانَ لِنَفْسِهِ مُتابِعًا، وفي مَراتِعِ هَواهُ راتِعًا.</p></div>"
  84,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</span>، لَنْ يَرْجِعَ إلى رَبِّهِ، تَكْذِيبًا بِالبَعْثِ، قالَ ابْنُ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما -: "ما عَرَفْتُ تَفْسِيرَهُ حَتّى سَمِعْتُ أعْرابِيَّةً تَقُولُ لِبِنْتِها: حُورِي، أيْ: اِرْجِعِي".</p></div>"
  84,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلى﴾</span>، إيجابٌ لِما بَعْدَ النَفْيِ في أنْ يَحُورَ، أيْ: بَلى، لَيَحُورَنَّ،</p><p><span class="qpc-hafs">﴿إنَّ رَبَّهُ كانَ بِهِ﴾</span>، وبِأعْمالِهِ،</p><p><span class="qpc-hafs">﴿بَصِيرًا﴾</span>، لا تَخْفى عَلَيْهِ، فَلا بُدَّ أنْ يُرْجِعَهُ ويُجازِيَهُ عَلَيْها.</p></div>"
  84,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلا أُقْسِمُ بِالشَفَقِ﴾</span>، فَأُقْسِمُ بِالبَياضِ بَعْدَ الحُمْرَةِ، أوِ الحُمْرَةِ.</p></div>"
  84,17,"<div class=ar lang=ar><p>(p-٦٢١)<span class="qpc-hafs">﴿واللَيْلِ وما وسَقَ﴾</span>، جُمِعَ وضُمَّ، والمُرادُ ما جَمَعَهُ مِنَ الظُلْمَةِ والنَجْمِ، أوْ ما عَمِلَ فِيهِ مِنَ التَهَجُّدِ وغَيْرِهِ.</p></div>"
  84,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، اجْتَمَعَ، وتَمَّ بَدْرًا، "اِفْتَعَلَ"، مِن "اَلْوَسْقُ".</p></div>"
  84,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَتَرْكَبُنَّ﴾</span> أيُّها الإنْسانُ، عَلى إرادَةِ الجِنْسِ،</p><p><span class="qpc-hafs">﴿طَبَقًا عَنْ طَبَقٍ﴾</span>، حالًا بَعْدَ حالٍ، كُلُّ واحِدَةٍ مُطابِقَةٌ لِأُخْتِها في الشِدَّةِ، والهَوْلِ، و"اَلطَّبَقُ": ما طابَقَ غَيْرَهُ، يُقالُ: "ما هَذا بِطَبَقٍ لِذا"، أيْ: لا يُطابِقُهُ، ومِنهُ قِيلٌ لِلْغِطاءِ: اَلطَّبَقُ، ويَجُوزُ أنْ يَكُونَ جَمْعَ "طَبَقَةٌ"، وهي المَرْتَبَةُ، مِن قَوْلِهِمْ: "هُوَ عَلى طَبَقاتٍ"، أيْ: لَتَرْكَبُنَّ أحْوالًا بَعْدَ أحْوالٍ، هي طَبَقاتٌ في الشِدَّةِ، بَعْضُها أرْفَعُ مِن بَعْضٍ، وهي المَوْتُ، وما بَعْدَهُ مِن مَواطِنِ القِيامَةِ وأهْوالِها، ومَحَلُّ "عَنْ طَبَقٍ"، نَصْبٌ، عَلى أنَّهُ صِفَةٌ لِـ "طَبَقًا"، أيْ: طَبَقًا مُجاوِزًا لِطَبَقٍ، أوْ حالٌ مِنَ الضَمِيرِ في "لَتَرْكَبُنَّ"، أيْ: لَتَرْكَبُنَّ طَبَقًا، مُجاوِزِينَ لِطَبَقٍ، وقالَ مَكْحُولٌ: "فِي كُلِّ عِشْرِينَ عامًا تَجِدُونَ أمْرًا لَمْ تَكُونُوا عَلَيْهِ"، بِفَتْحِ الياءِ "مَكِّيٌّ وعَلِيٌّ وحَمْزَةُ "، والخِطابُ لَهُ ﷺ، أيْ: طَبَقًا مِن طِباقِ السَماءِ، بَعْدَ طَبَقٍ، أيْ: في المِعْراجِ.</p></div>"
  84,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَما لَهم لا يُؤْمِنُونَ﴾</span>، فَما لَهم ألّا يُؤْمِنُوا؟!</p></div>"
  84,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</span>، لا يَخْضَعُونَ.</p></div>"
  84,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلِ الَّذِينَ كَفَرُوا يُكَذِّبُونَ﴾</span>، بِالبَعْثِ، والقُرْآنِ.</p></div>"
  84,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واللهُ أعْلَمُ بِما يُوعُونَ﴾</span>، بِما يَجْمَعُونَ في صُدُورِهِمْ، ويُضْمِرُونَ، مِنَ الكُفْرِ، وتَكْذِيبِ النَبِيِّ ﷺ، أوْ بِما يَجْمَعُونَ في صُحُفِهِمْ مِن أعْمالِ السُوءِ، ويَدَّخِرُونَ لِأنْفُسِهِمْ مِن أنْواعِ العَذابِ.</p></div>"
  84,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَشِّرْهم بِعَذابٍ ألِيمٍ﴾</span>، أخْبِرْهم خَبَرًا يَظْهَرُ أثَرُهُ عَلى بَشَرَتِهِمْ.</p></div>"
  84,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلا الَّذِينَ آمَنُوا وعَمِلُوا الصالِحاتِ﴾</span>، اِسْتِثْناءٌ مُنْقَطِعٌ،</p><p><span class="qpc-hafs">﴿لَهم أجْرٌ غَيْرُ مَمْنُونٍ﴾</span>، غَيْرُ مَقْطُوعٍ، أوْ غَيْرُ مَنقُوصٍ.</p></div>"
