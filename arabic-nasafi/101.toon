quran[11]{c,v,t}:
  101,1,"<div class=ar lang=ar><p>(p-٦٧٣)سُورَةُ "اَلْقارِعَةِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿القارِعَةُ﴾</span>، مُبْتَدَأٌ.</p></div>"
  101,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ما﴾</span>، مُبْتَدَأٌ ثانٍ،</p><p><span class="qpc-hafs">﴿القارِعَةُ﴾</span>، خَبَرُهُ، والجُمْلَةُ خَبَرُ المُبْتَدَإ الأوَّلِ، وكانَ حَقُّهُ: "ما هِيَ"، وإنَّما كَرَّرَ تَفْخِيمًا لِشَأْنِها.</p></div>"
  101,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أدْراكَ ما القارِعَةُ﴾</span> أيْ: أيّ شَيْءٍ أعْلَمَكَ ما هِيَ؟! ومِن أيْنَ عَلِمْتَ ذَلِكَ؟!</p></div>"
  101,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ﴾</span>، نُصِبَ بِمُضْمَرٍ، دَلَّتْ عَلَيْهِ "اَلْقارِعَةُ"، أوْ: تَقْرَعُ يَوْمَ <span class="qpc-hafs">﴿يَكُونُ الناسُ كالفَراشِ المَبْثُوثِ﴾</span>، شَبَّهَهم بِالفَراشِ في الكَثْرَةِ، والِانْتِشارِ، والضَعْفِ، والذِلَّةِ، والتَطايُرِ إلى الداعِي مِن كُلِّ جانِبٍ، كَما يَتَطايَرُ الفَراشُ إلى النارِ، وسُمِّيَ "فَراشًا"، لِتَفَرُّشِهِ وانْتِشارِهِ.</p></div>"
  101,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَكُونُ الجِبالُ كالعِهْنِ المَنفُوشِ﴾</span>، وشَبَّهَ الجِبالَ بِالعِهْنِ، وهو الصُوفُ المُصَبَّغُ ألْوانًا، لِأنَّها ألْوانٌ،</p><p><span class="qpc-hafs">﴿وَمِنَ الجِبالِ جُدَدٌ بِيضٌ وحُمْرٌ مُخْتَلِفٌ ألْوانُها﴾</span> [فاطر: ٢٧]، وبِالمَنفُوشِ مِنهُ، لِتَفَرُّقِ أجْزائِها.</p></div>"
  101,6,"<div class=ar lang=ar><p>(p-٦٧٤)<span class="qpc-hafs">﴿فَأمّا مَن ثَقُلَتْ مَوازِينُهُ﴾</span>، بِاتِّباعِهِمُ الحَقَّ، وهي جَمْعُ "مَوْزُونٌ"، وهو العَمَلُ الَّذِي لَهُ وزْنٌ وخَطَرٌ عِنْدَ اللهِ، أوْ جَمْعُ "مِيزانٌ"، وثِقْلُها: رُجْحانُها.</p></div>"
  101,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهُوَ في عِيشَةٍ راضِيَةٍ﴾</span>، ذاتِ رِضًا، أوْ: مَرْضِيَّةٍ.</p></div>"
  101,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأمّا مَن خَفَّتْ مَوازِينُهُ﴾</span>، بِاتِّباعِهِمُ الباطِلَ.</p></div>"
  101,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأُمُّهُ هاوِيَةٌ﴾</span>، فَمَسْكَنُهُ ومَأْواهُ النارُ، وقِيلَ لِلْمَأْوى: "أُمٌّ"، عَلى التَشْبِيهِ، لِأنَّ الأُمَّ مَأْوى الوَلَدِ ومَفْزَعُهُ.</p></div>"
  101,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أدْراكَ ما هِيَهْ﴾</span></p><p>١٠. - <span class="qpc-hafs">﴿وَما أدْراكَ ما هِيَهْ﴾</span>، اَلضَّمِيرُ يَعُودُ إلى "هاوِيَةٌ"، والهاءُ لِلسَّكْتِ، ثُمَّ فَسَّرَها، فَقالَ:</p></div>"
  101,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نارٌ حامِيَةٌ﴾</span>، بَلَغَتِ النِهايَةَ في الحَرارَةِ.</p></div>"
