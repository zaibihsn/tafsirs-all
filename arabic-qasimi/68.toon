  68,17,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١٧ - ١٨] <span class="qpc-hafs">﴿إنّا بَلَوْناهم كَما بَلَوْنا أصْحابَ الجَنَّةِ إذْ أقْسَمُوا لَيَصْرِمُنَّها مُصْبِحِينَ﴾</span> <span class="qpc-hafs">﴿ولا يَسْتَثْنُونَ﴾</span> [القلم: ١٨]</p><p><span class="qpc-hafs">﴿إنّا بَلَوْناهم كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span> أيْ: بَلَوْنا مُشْرِكِي مَكَّةَ، فاخْتَبَرْنا بِهَذا التَّنْزِيلِ الحَكِيمِ، هَلْ يَشْكُرُونَ نِعْمَتَهُ، فَيَحْيَوْا حَياةً طَيِّبَةً، أوْ يُصِرُّونَ عَلى تَكْذِيبِهِ، فَلا تَكُونُ عاقِبَتُهم إلّا كَعاقِبَةِ أهْلِ الجَنَّةِ في امْتِحانِهِمُ الآتِي، ثُمَّ دَمارُهم.</p><p>وقِيلَ: مَعْناهُ أصَبْناهم بِبَلِيَّةٍ، وهي القَحْطُ والجُوعُ، بِدَعْوَةِ رَسُولِ اللَّهِ ﷺ، <span class="qpc-hafs">﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</span> وهم قَوْمٌ مِن أهْلِ الكِتابِ، عَلى ما رُوِيَ عَنِ ابْنِ عَبّاسٍ، أوْ ناسٌ مِنَ الحَبَشَةِ في قَوْلِ عِكْرِمَةَ، أيْ: كِتابِيُّونَ، فَيَتَّفِقُ مَعَ ما قَبْلَهُ، ولَيْسَ مِن ضَرُورَةِ الِاعْتِبارِ بِالمَثَلِ والعِظَةِ بِهِ تَعْيِينُ أهْلِهِ، لَوْلا مَحَبَّةُ المَأْثُورِ <span class="qpc-hafs">﴿إذْ أقْسَمُوا لَيَصْرِمُنَّها مُصْبِحِينَ﴾</span> أيْ: لِيَقْطَعُنَّ ثِمارَها مُبَكِّرِينَ بِحَيْثُ لا يَعْلَمُ مِسْكِينٌ بِذَلِكَ <span class="qpc-hafs">﴿ولا يَسْتَثْنُونَ﴾</span> [القلم: ١٨] قالَ المَهايِمِيُّ: أيْ: ولا يُخْرِجُونَ شَيْئًا مِن حَقِّ المَساكِينِ، واقْتَصَرَ عَلَيْهِ، وحَكاهُ الرّازِيُّ والقاضِي قَوْلًا ثانِيًا، والأوَّلُ أنَّ مَعْناهُ: ولا يَقُولُونَ: إنْ شاءَ اللَّهُ، واقْتَصَرَ عَلَيْهِ ابْنُ جَرِيرٍ. والأوَّلُ أظْهَرُ، والِاسْتِثْناءُ بِمَعْنى الإخْراجِ الحِسِّيِّ، والجُمْلَةُ مَعْطُوفَةٌ عَلى: <span class="qpc-hafs">﴿لَيَصْرِمُنَّها﴾</span> ومَقْسَمٌ عَلَيْها.</p></div>"
  68,18,""
  68,19,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١٩ - ٢٠] <span class="qpc-hafs">﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ وهم نائِمُونَ﴾</span> <span class="qpc-hafs">﴿فَأصْبَحَتْ كالصَّرِيمِ﴾</span> [القلم: ٢٠]</p><p><span class="qpc-hafs">﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ﴾</span> أيْ: فَطَرَقَ جَنَّةَ هَؤُلاءِ القَوْمِ، طارِقٌ مِن أمْرِ اللَّهِ لِتَدْمِيرِها.</p><p>(p-٥٨٩٨)قالَ ابْنُ جَرِيرٍ: ولا يَكُونُ الطّائِفُ في كَلامِ العَرَبِ إلّا لَيْلًا، ولا يَكُونُ نَهارًا. وقَدْ يَقُولُونَ: أطَفْتُ بِها نَهارًا. وذَكَرَ الفَرّاءُ أنَّ أبا الجَرّاحِ أنْشَدَهُ:</p><p>؎أطَفْتَ بِها نَهارًا غَيْرَ لَيْلٍ وألْهى رَبَّها طَلَبُ الرِّخالِ</p><p>و(الرِّخالُ): أوْلادُ الضَّأْنِ لِلْإناثِ.</p><p>فَقَوْلُهُ: <span class="qpc-hafs">﴿وهم نائِمُونَ﴾</span> أيْ: مُسْتَغْرِقُونَ في سُباتِهِمْ، غافِلُونَ عَمّا يُمْكَرُ بِهِمْ. تَأْكِيدٌ عَلى الأوَّلِ، وتَأْسِيسٌ عَلى الثّانِي.</p><p><span class="qpc-hafs">﴿فَأصْبَحَتْ كالصَّرِيمِ﴾</span> [القلم: ٢٠] أيْ: كالبُسْتانِ الَّذِي صُرِمَ ثَمَرُهُ بِحَيْثُ لَمْ يَبْقَ فِيهِ شَيْءٌ، أوْ كاللَّيْلِ الأسْوَدِ لِاحْتِراقِها. وأنْشَدَ في ذَلِكَ ابْنُ جَرِيرٍ لِأبِي عَمْرِو بْنِ العَلاءِ:</p><p>؎ألا بَكَرَتْ وعاذِلَتِي تَلُومُ ∗∗∗ تُهَجِّدُنِي وما انْكَشَفَ الصَّرِيمُ</p><p>(p-٥٨٩٩)وقالَ أيْضًا:</p><p>؎تَطاوَلَ لَيْلُكَ الجَوْنُ البَهِيمُ ∗∗∗ فَما يَنْجابُ عَنْ صُبْحٍ صَرِيمُ</p></div>"
  68,20,""
  68,21,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٢١ - ٢٧] <span class="qpc-hafs">﴿فَتَنادَوْا مُصْبِحِينَ﴾</span> <span class="qpc-hafs">﴿أنِ اغْدُوا عَلى حَرْثِكم إنْ كُنْتُمْ صارِمِينَ﴾</span> [القلم: ٢٢] <span class="qpc-hafs">﴿فانْطَلَقُوا وهم يَتَخافَتُونَ﴾</span> [القلم: ٢٣] <span class="qpc-hafs">﴿أنْ لا يَدْخُلَنَّها اليَوْمَ عَلَيْكم مِسْكِينٌ﴾</span> [القلم: ٢٤] <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</span> [القلم: ٢٥] <span class="qpc-hafs">﴿فَلَمّا رَأوْها قالُوا إنّا لَضالُّونَ﴾</span> [القلم: ٢٦] <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [القلم: ٢٧]</p><p><span class="qpc-hafs">﴿فَتَنادَوْا﴾</span> أيْ: فَنادى بَعْضُهم بَعْضًا <span class="qpc-hafs">﴿مُصْبِحِينَ﴾</span> أيْ: وقْتَ الصُّبْحِ، ولَمْ يَشْعُرُوا (p-٥٩٠٠)بِما جَرى عَلَيْهِمْ بِاللَّيْلِ <span class="qpc-hafs">﴿أنِ اغْدُوا﴾</span> [القلم: ٢٢] أيِ: اخْرُجُوا غَدْوَةً <span class="qpc-hafs">﴿عَلى حَرْثِكُمْ﴾</span> [القلم: ٢٢] أيْ: زَرْعِكم <span class="qpc-hafs">﴿إنْ كُنْتُمْ صارِمِينَ﴾</span> [القلم: ٢٢] أيْ: قاصِدِينَ قَطْعَ ثِمارِها، وقَدْ قَطَعَها البَلاءُ مِن أصْلِها.</p><p><span class="qpc-hafs">﴿فانْطَلَقُوا وهم يَتَخافَتُونَ﴾</span> [القلم: ٢٣] أيْ: يَكْتُمُونَ ذَهابَهم ويَتَسارُّونَ فِيما بَيْنَهم.</p><p><span class="qpc-hafs">﴿أنْ لا يَدْخُلَنَّها اليَوْمَ عَلَيْكم مِسْكِينٌ﴾</span> [القلم: ٢٤] أيْ: فَقِيرٌ، فالجُمْلَةُ مُفَسِّرَةٌ. أوْ " أنْ " مَصْدَرِيَّةٌ، أيْ: بِأنْ.</p><p>قالَ الزَّمَخْشَرِيُّ: والنَّهْيُ عَنِ الدُّخُولِ لِلْمِسْكِينِ، نَهْيٌ لَهم عَنْ تَمْكِينِهِ مِنهُ. أيْ: لا تُمَكِّنُوهُ مِنَ الدُّخُولِ حَتّى يَدْخُلَ، كَقَوْلِكَ: لا أرَيَنَّكَ هاهُنا.</p><p><span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ﴾</span> [القلم: ٢٥] أيْ: غَدَوْا إلى جَنَّتِهِمْ، عَلى نَشاطٍ وسُرْعَةٍ وجِدٍّ مِن أمْرِهِمْ، أوْ عَلى مَنعٍ وغَضَبٍ.</p><p><span class="qpc-hafs">﴿قادِرِينَ﴾</span> [القلم: ٢٥] أيْ: في زَعْمِهِمْ عَلى ما أصَرُّوا عَلَيْهِ مِنَ الصِّرامِ وحِرْمانِ المَساكِينِ.</p><p><span class="qpc-hafs">﴿فَلَمّا رَأوْها﴾</span> [القلم: ٢٦] أيْ: فَلَمّا صارُوا إلَيْها، ورَأوْها مُحْتَرِقًا حَرْثُها.</p><p><span class="qpc-hafs">﴿قالُوا إنّا لَضالُّونَ﴾</span> [القلم: ٢٦] <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [القلم: ٢٧] أيْ: أنْكَرُوها وشَكُّوا فِيها: هَلْ هي جَنَّتُهم أمْ لا؛ فَقالَ بَعْضُهم لِأصْحابِهِ: ظَنًّا مِنهُ أنَّهم قَدْ أغْفَلُوا طَرِيقَ جَنَّتِهِمْ وأنَّ الَّتِي رَأوْها غَيْرُها: إنّا أيُّها القَوْمُ، لَضالُّونَ طَرِيقَ جَنَّتِنا! فَقالَ مَن عَلِمَ أنَّها جَنَّتُهُمْ، وأنَّهم لَمْ يُخْطِئُوا الطَّرِيقَ: بَلْ نَحْنُ أيُّها القَوْمُ، مَحْرُومُونَ، حُرِمْنا مَنفَعَةَ جَنَّتِنا بِذَهابِ حَرْثِها.</p></div>"
  68,22,""
  68,23,""
  68,24,""
  68,25,""
  68,26,""
  68,27,""
  68,28,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٢٨ - ٣٢] <span class="qpc-hafs">﴿قالَ أوْسَطُهم ألَمْ أقُلْ لَكم لَوْلا تُسَبِّحُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا سُبْحانَ رَبِّنا إنّا كُنّا ظالِمِينَ﴾</span> [القلم: ٢٩] <span class="qpc-hafs">﴿فَأقْبَلَ بَعْضُهم عَلى بَعْضٍ يَتَلاوَمُونَ﴾</span> [القلم: ٣٠] <span class="qpc-hafs">﴿قالُوا يا ويْلَنا إنّا كُنّا طاغِينَ﴾</span> [القلم: ٣١] <span class="qpc-hafs">﴿عَسى رَبُّنا أنْ يُبْدِلَنا خَيْرًا مِنها إنّا إلى رَبِّنا راغِبُونَ﴾</span> [القلم: ٣٢]</p><p><span class="qpc-hafs">﴿قالَ أوْسَطُهُمْ﴾</span> أيْ: أعْدَلُهم وخَيْرُهم رَأْيًا <span class="qpc-hafs">﴿ألَمْ أقُلْ لَكم لَوْلا تُسَبِّحُونَ﴾</span> أيْ: (p-٥٩٠١)تَذْكُرُونَ اللَّهَ وتَتُوبُونَ إلَيْهِ مَن خُبْثِ نِيَّتِكُمْ، وتَخْشَوْنَ انْتِقامَهُ مِنَ المُجْرِمِينَ. وكانَ أوْسَطُهم وعَظَهم حِينَ عَزَمُوا عَلى عَزِيمَتِهِمُ الخَبِيثَةِ، فَعَصَوْهُ، فَعَيَّرَهم.</p><p><span class="qpc-hafs">﴿قالُوا سُبْحانَ رَبِّنا إنّا كُنّا ظالِمِينَ﴾</span> [القلم: ٢٩] أيْ: في تَرْكِ اسْتِثْناءِ حَقِّ المَساكِينِ ومَنعِ المَعْرُوفِ عَنْهم مِن تِلْكَ الجَنَّةِ. <span class="qpc-hafs">﴿فَأقْبَلَ بَعْضُهم عَلى بَعْضٍ يَتَلاوَمُونَ﴾</span> [القلم: ٣٠] أيْ: يَلُومُ بَعْضُهم بَعْضًا.</p><p><span class="qpc-hafs">﴿قالُوا يا ويْلَنا إنّا كُنّا طاغِينَ﴾</span> [القلم: ٣١] أيْ: مُتَجاوِزِينَ حُدُودَ اللَّهِ تَعالى في تَفْرِيطِنا وعَزْمِنا السَّيِّءِ <span class="qpc-hafs">﴿عَسى رَبُّنا أنْ يُبْدِلَنا خَيْرًا مِنها﴾</span> [القلم: ٣٢] أيْ: بِتَوْبَتِنا إلَيْهِ، ونَدَمِنا عَلى خَطَأِ فِعْلِنا، وعَزْمِنا عَلى عَدَمِ العَوْدَةِ إلى مِثْلِهِ.</p><p><span class="qpc-hafs">﴿إنّا إلى رَبِّنا راغِبُونَ﴾</span> [القلم: ٣٢] أيْ: في العَفْوِ عَمّا فَرَطَ مِنّا، والتَّعْوِيضِ عَمّا فاتَنا.</p></div>"
