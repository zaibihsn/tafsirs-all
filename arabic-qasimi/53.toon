  53,49,""
  53,50,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٠ - ٥٦] <span class="qpc-hafs">﴿وأنَّهُ أهْلَكَ عادًا الأُولى﴾</span> <span class="qpc-hafs">﴿وثَمُودَ فَما أبْقى﴾</span> [النجم: ٥١] <span class="qpc-hafs">﴿وقَوْمَ نُوحٍ مِن قَبْلُ إنَّهم كانُوا هم أظْلَمَ وأطْغى﴾</span> [النجم: ٥٢] (p-٥٥٨٨)<span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span> [النجم: ٥٣] <span class="qpc-hafs">﴿فَغَشّاها ما غَشّى﴾</span> [النجم: ٥٤] <span class="qpc-hafs">﴿فَبِأيِّ آلاءِ رَبِّكَ تَتَمارى﴾</span> [النجم: ٥٥] <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span> [النجم: ٥٦]</p><p><span class="qpc-hafs">﴿وأنَّهُ أهْلَكَ عادًا الأُولى﴾</span> يَعْنِي قَوْمَ هُودٍ. وسُمِّيَتِ الأُولى لِتَقَدُّمِها في الزَّمانِ.</p><p><span class="qpc-hafs">﴿وثَمُودَ﴾</span> [النجم: ٥١] أيْ: قَوْمَ صالِحٍ، <span class="qpc-hafs">﴿فَما أبْقى﴾</span> [النجم: ٥١] <span class="qpc-hafs">﴿وقَوْمَ نُوحٍ مِن قَبْلُ إنَّهم كانُوا هم أظْلَمَ وأطْغى﴾</span> [النجم: ٥٢] أيْ: أشَدَّ في كُفْرِهِمْ <span class="qpc-hafs">﴿وأطْغى﴾</span> [النجم: ٥٢] أيْ: أشَدَّ طُغْيانًا وعِصْيانًا مِنَ الَّذِينَ أُهْلِكُوا بَعْدَهُمْ، لِتَمَرُّدِهِمْ عَلى الكُفْرِ، ورَدَّ دَعْوَتَهُ في طُولِ مُدَّتِهِ بَيْنَهُمْ، وهي أطْوَلُ مُدَدِ الأنْبِياءِ عَلَيْهِمُ السَّلامُ.</p><p><span class="qpc-hafs">﴿والمُؤْتَفِكَةَ﴾</span> [النجم: ٥٣] أيْ: قُرى قَوْمِ لُوطٍ الَّتِي ائْتَفَكَتْ بِأهْلِها، أيِ: انْقَلَبَتْ.</p><p><span class="qpc-hafs">﴿أهْوى﴾</span> [النجم: ٥٣] أيْ: أهْواها عَلى أهْلِها ودَمَّرَها.</p><p><span class="qpc-hafs">﴿فَغَشّاها ما غَشّى﴾</span> [النجم: ٥٤] أيْ: مِنَ العَذابِ السَّماوِيِّ الَّذِي صُبَّ عَلَيْها.</p><p><span class="qpc-hafs">﴿فَبِأيِّ آلاءِ رَبِّكَ﴾</span> [النجم: ٥٥] أيْ: نَعْمائِهِ.</p><p><span class="qpc-hafs">﴿تَتَمارى﴾</span> [النجم: ٥٥] أيْ: تَرْتابُ وتَشُكُّ وتُجادِلُ في أنَّها لَيْسَتْ مِن عِنْدِهِ، وهو الَّذِي أنْعَمَ بِالإغْناءِ والإقْناءِ وإرْسالِ الرُّسُلِ، وقَهْرِ أعْدائِهِمْ.</p><p><span class="qpc-hafs">﴿هَذا﴾</span> [النجم: ٥٦] أيِ: القُرْآنُ <span class="qpc-hafs">﴿نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span> [النجم: ٥٦] أيْ: إنْذارٌ مِن جِنْسِ الإنْذاراتِ الأُولى الَّتِي أنْذَرَ بِها مَن قَبْلَكم. أوْ هَذا الرَّسُولُ نَذِيرٌ مِن جِنْسِ مَن تَقَدَّمَهُ، لَيْسَ بِدْعًا مِنَ الرُّسُلِ.</p></div>"
  53,51,""
