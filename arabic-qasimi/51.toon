  51,29,""
  51,30,""
  51,31,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٣١ - ٣٧] <span class="qpc-hafs">﴿قالَ فَما خَطْبُكم أيُّها المُرْسَلُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا إنّا أُرْسِلْنا إلى قَوْمٍ مُجْرِمِينَ﴾</span> [الذاريات: ٣٢] <span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ﴾</span> [الذاريات: ٣٣] <span class="qpc-hafs">﴿مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span> [الذاريات: ٣٤] <span class="qpc-hafs">﴿فَأخْرَجْنا مَن كانَ فِيها مِنَ المُؤْمِنِينَ﴾</span> [الذاريات: ٣٥] <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span> [الذاريات: ٣٦] <span class="qpc-hafs">﴿وتَرَكْنا فِيها آيَةً لِلَّذِينَ يَخافُونَ العَذابَ الألِيمَ﴾</span> [الذاريات: ٣٧]</p><p><span class="qpc-hafs">﴿قالَ﴾</span> أيْ: إبْراهِيمُ لِضَيْفِهِ <span class="qpc-hafs">﴿فَما خَطْبُكُمْ﴾</span> أيْ: أمْرُكم وشَأْنُكم <span class="qpc-hafs">﴿أيُّها المُرْسَلُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا إنّا أُرْسِلْنا إلى قَوْمٍ مُجْرِمِينَ﴾</span> [الذاريات: ٣٢] أيْ: مُؤاخَذَتُهُمْ؛ <span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ﴾</span> [الذاريات: ٣٣] أيْ: رَجْمًا عَلى فِعْلِهِمُ الفاحِشَةَ.</p><p><span class="qpc-hafs">﴿مُسَوَّمَةً﴾</span> [الذاريات: ٣٤] أيْ: مُرْسَلَةً، أوْ مُعَلَّمَةً <span class="qpc-hafs">﴿عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span> [الذاريات: ٣٤] أيِ: المُتَعَدِّينَ حُدُودَ اللَّهِ، الكافِرِينَ بِهِ.</p><p><span class="qpc-hafs">﴿فَأخْرَجْنا مَن كانَ فِيها﴾</span> [الذاريات: ٣٥] أيْ: في تِلْكَ القَرْيَةِ مِنَ المُؤْمِنِينَ أيْ: بِإيحاءِ الخُرُوجِ إلَيْهِمْ عَلى لِسانِ المَلائِكَةِ، وهم لُوطٌ وابْنَتاهُ عَلَيْهِمُ السَّلامُ.</p><p><span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span> [الذاريات: ٣٦] يَعْنِي بَيْتَ قَوْمِ لُوطٍ عَلَيْهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿وتَرَكْنا فِيها﴾</span> [الذاريات: ٣٧] أيْ: في تِلْكَ القَرْيَةِ <span class="qpc-hafs">﴿آيَةً﴾</span> [الذاريات: ٣٧] أيْ: عَلامَةً تَدُلُّ عَلى إهْلاكِهِمُ الدُّنْيَوِيِّ الدّالِّ عَلى الأُخْرَوِيِّ <span class="qpc-hafs">﴿لِلَّذِينَ يَخافُونَ العَذابَ الألِيمَ﴾</span> [الذاريات: ٣٧] أيْ: في الآخِرَةِ، وقَوْلُهُ تَعالى:</p><p>(p-٥٥٣٣)</p></div>"
  51,32,""
  51,33,""
  51,34,""
  51,35,""
  51,36,""
  51,37,""
  51,38,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٣٨ - ٤٠] <span class="qpc-hafs">﴿وفِي مُوسى إذْ أرْسَلْناهُ إلى فِرْعَوْنَ بِسُلْطانٍ مُبِينٍ﴾</span> <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ وقالَ ساحِرٌ أوْ مَجْنُونٌ﴾</span> [الذاريات: ٣٩] <span class="qpc-hafs">﴿فَأخَذْناهُ وجُنُودَهُ فَنَبَذْناهم في اليَمِّ وهو مُلِيمٌ﴾</span> [الذاريات: ٤٠]</p><p><span class="qpc-hafs">﴿وفِي مُوسى﴾</span> عَطْفٌ عَلى " فِيها " بِإعادَةِ الجارِّ؛ لِأنَّ المَعْطُوفَ عَلَيْهِ ضَمِيرٌ مَجْرُورٌ، أيْ: وتَرَكْنا في قِصَّةِ مُوسى بِإهْلاكِ أعْدائِهِ آيَةً وحُجَّةً تُبَيِّنُ لِمَن رَآها حَقِيقَةَ دَعْواهُ.</p><p><span class="qpc-hafs">﴿إذْ أرْسَلْناهُ إلى فِرْعَوْنَ بِسُلْطانٍ مُبِينٍ﴾</span> أيْ: بِبُرْهانٍ ظاهِرٍ.</p><p><span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span> [الذاريات: ٣٩] أيْ: فَأعْرَضَ عَنِ الإيمانِ. والرُّكْنُ: جانِبُ الشَّيْءِ. فَـ(رُكْنُهُ) جانِبُ بَدَنِهِ، فالتَّوَلِّي بِهِ كِنايَةٌ عَنِ الإعْراضِ. والباءُ لِلتَّعْدِيَةِ، لِأنَّ مَعْناهُ ثَنى عِطْفَهُ، أوْ لِلْمُلابَسَةِ، أوِ الرَّكْنُ فِيهِ بِمَعْنى الجَيْشِ؛ لِأنَّهُ يَرْكَنُ إلَيْهِ ويَتَقَوّى بِهِ، والباءُ لِلْمُصاحَبَةِ أوْ لِلْمُلابَسَةِ.</p><p><span class="qpc-hafs">﴿وقالَ ساحِرٌ﴾</span> [الذاريات: ٣٩] أيْ: هو ساحِرٌ.</p><p><span class="qpc-hafs">﴿أوْ مَجْنُونٌ﴾</span> [الذاريات: ٣٩] <span class="qpc-hafs">﴿فَأخَذْناهُ وجُنُودَهُ فَنَبَذْناهم في اليَمِّ﴾</span> [الذاريات: ٤٠] أيْ: فَأغْرَقْناهم في البَحْرِ <span class="qpc-hafs">﴿وهُوَ مُلِيمٌ﴾</span> [الذاريات: ٤٠] أيْ: آتٍ بِما يُلامُ عَلَيْهِ مِنَ الكُفْرِ والعِنادِ.</p></div>"
  51,39,""
  51,40,""
  51,41,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٤١ - ٤٢] <span class="qpc-hafs">﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</span> <span class="qpc-hafs">﴿ما تَذَرُ مِن شَيْءٍ أتَتْ عَلَيْهِ إلا جَعَلَتْهُ كالرَّمِيمِ﴾</span> [الذاريات: ٤٢]</p><p><span class="qpc-hafs">﴿وفِي عادٍ﴾</span> أيْ: وتَرَكْنا في عادٍ -قَوْمِ هُودٍ عَلَيْهِ السَّلامُ- آيَةً <span class="qpc-hafs">﴿إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</span> أيِ: الَّتِي لا خَيْرَ فِيها مِن إنْشاءِ المَطَرِ، أوْ إلْقاحِ الشَّجَرِ. وهي رِيحُ الهَلاكِ.</p><p><span class="qpc-hafs">﴿ما تَذَرُ مِن شَيْءٍ أتَتْ عَلَيْهِ إلا جَعَلَتْهُ كالرَّمِيمِ﴾</span> [الذاريات: ٤٢] أيِ: الشَّيْءِ الهالِكِ. وأصْلُ الرَّمِيمِ: البالِي المُفَتَّتُ مِن عَظْمٍ أوْ نَباتٍ أوْ غَيْرِ ذَلِكَ.</p><p>(p-٥٥٣٤)</p></div>"
  51,42,""
  51,43,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٤٣ - ٤٥] <span class="qpc-hafs">﴿وفِي ثَمُودَ إذْ قِيلَ لَهم تَمَتَّعُوا حَتّى حِينٍ﴾</span> <span class="qpc-hafs">﴿فَعَتَوْا عَنْ أمْرِ رَبِّهِمْ فَأخَذَتْهُمُ الصّاعِقَةُ وهم يَنْظُرُونَ﴾</span> [الذاريات: ٤٤] <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مِن قِيامٍ وما كانُوا مُنْتَصِرِينَ﴾</span> [الذاريات: ٤٥]</p><p><span class="qpc-hafs">﴿وفِي ثَمُودَ﴾</span> أيْ: وتَرَكْنا في ثَمُودَ قَوْمِ صالِحٍ عَلَيْهِ السَّلامُ <span class="qpc-hafs">﴿إذْ قِيلَ لَهُمْ﴾</span> أيْ: بَعْدَ عَقْرِهِمُ النّاقَةَ <span class="qpc-hafs">﴿تَمَتَّعُوا﴾</span> أيْ: في دارِكم <span class="qpc-hafs">﴿حَتّى حِينٍ﴾</span> يَعْنِي: ثَلاثَةَ أيّامٍ، كَما بَيَّنَتْهُ الآيَةُ الأُخْرى.</p><p><span class="qpc-hafs">﴿فَعَتَوْا عَنْ أمْرِ رَبِّهِمْ﴾</span> [الذاريات: ٤٤] أيْ: فاسْتَكْبَرُوا عَنِ امْتِثالِهِ، <span class="qpc-hafs">﴿فَأخَذَتْهُمُ الصّاعِقَةُ﴾</span> [الذاريات: ٤٤] يَعْنِي العَذابَ الحالَّ بِهِمُ، المَعْهُودَ <span class="qpc-hafs">﴿وهم يَنْظُرُونَ﴾</span> [الذاريات: ٤٤] أيْ: إلَيْها، فَإنَّها نَزَلَتْ بِهِمْ نَهارًا.</p><p><span class="qpc-hafs">﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</span> [الذاريات: ٤٥] أيْ: نُهُوضٍ، فَضْلًا عَنْ دِفاعِ عَذابِ اللَّهِ <span class="qpc-hafs">﴿وما كانُوا مُنْتَصِرِينَ﴾</span> [الذاريات: ٤٥] أيْ: مُمْتَنِعِينَ مِنَ العَذابِ، وقَوْلُهُ تَعالى:</p></div>"
  51,44,""
  51,45,""
  51,46,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٤٦] <span class="qpc-hafs">﴿وقَوْمَ نُوحٍ مِن قَبْلُ إنَّهم كانُوا قَوْمًا فاسِقِينَ﴾</span></p><p><span class="qpc-hafs">﴿وقَوْمَ نُوحٍ﴾</span> قُرِئَ بِالجَرِّ عَطْفًا عَلى <span class="qpc-hafs">﴿وفِي ثَمُودَ﴾</span> [الذاريات: ٤٣] أوِ المَجْرُوراتِ قَبْلُ. وبِالنَّصْبِ مَفْعُولًا لِمُضْمَرٍ دَلَّ عَلَيْهِ السِّياقُ والسِّباقُ، أيْ: وأهْلَكْنا قَوْمَ نُوحٍ، أوْ عَطْفًا عَلى مَفْعُولِ فَأخَذْناهُ أوْ عَلى مَحَلِّ <span class="qpc-hafs">﴿وفِي مُوسى﴾</span> [الذاريات: ٣٨] <span class="qpc-hafs">﴿مِن قَبْلُ إنَّهم كانُوا قَوْمًا فاسِقِينَ﴾</span> أيْ: مُخالِفِينَ أمْرَ اللَّهِ، خارِجِينَ عَنْ طاعَتِهِ.</p></div>"
  51,47,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٤٧ - ٤٨] <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأيْدٍ وإنّا لَمُوسِعُونَ﴾</span> <span class="qpc-hafs">﴿والأرْضَ فَرَشْناها فَنِعْمَ الماهِدُونَ﴾</span> [الذاريات: ٤٨]</p><p><span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأيْدٍ﴾</span> أيْ: رَفَعْناها بِقُوَّةٍ <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span> أيْ: لَقادِرُونَ عَلى (p-٥٥٣٥)الإيساعِ، كَما أوْسَعْنا بِناءَها.</p><p><span class="qpc-hafs">﴿والأرْضَ فَرَشْناها﴾</span> [الذاريات: ٤٨] أيْ: مَهَّدْناها لِيَتَمَتَّعُوا بِها <span class="qpc-hafs">﴿فَنِعْمَ الماهِدُونَ﴾</span> [الذاريات: ٤٨] أيْ: لَهم. وفي إيثارِ صِيغَةِ فاعِلٍ مِن: (مَهَدَ) عَلى فَرْشٍ، إشارَةً إلى أنَّ مِنَ المَوادِّ ما تَخْتَلِفُ صِيغَتُهُ في النَّظْمِ فِعْلًا واسِمًا، فَيَكُونُ في أحَدِهِما أرَقَّ وألْطَفَ وأفْصَحَ، فَيُؤْثَرُ عَلى غَيْرِهِ في ظَرْفٍ، ويُؤْثَرُ عَلَيْهِ غَيْرُهُ في آخَرَ، والمَرْجِعُ الذَّوْقُ، كَما بَسَطَهُ ابْنُ خَلْدُونَ وابْنُ الأثِيرِ.</p></div>"
  51,48,""
  51,49,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٤٩] <span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ لَعَلَّكم تَذَكَّرُونَ﴾</span></p><p><span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</span> أيْ: ذَكَرًا وأُنْثى، أوْ نَوْعَيْنِ مُتَقابِلَيْنِ.</p><p>قالَ ابْنُ كَثِيرٍ: جَمِيعُ المَخْلُوقاتِ أزْواجٌ: سَماءٌ وأرْضٌ، لَيْلٌ ونَهارٌ، شَمْسٌ وقَمَرٌ، وبَرٌّ وبَحْرٌ، وضِياءٌ وظَلامٌ، وإيمانٌ وكُفْرٌ، وحَياةٌ ومَوْتٌ، وشَقاءٌ وسَعادَةٌ، وجَنَّةٌ ونارٌ. حَتّى الحَيَواناتُ والنَّباتاتُ. انْتَهى. وهو مَأْخُوذٌ مِن كَلامِ ابْنِ جَرِيرٍ في تَأْيِيدِ تَفْسِيرِ مُجاهِدٍ، وعِبارَةُ ابْنِ جَرِيرٍ: وأوْلى القَوْلَيْنِ في ذَلِكَ قَوْلُ مُجاهِدٍ: وهو أنَّ اللَّهَ تَبارَكَ وتَعالى خَلَقَ لِكُلِّ ما خَلَقَ مِن خَلْقِهِ ثانِيًا لَهُ مُخالِفًا في مَعْناهُ، فَكُلُّ واحِدٍ مِنهُما زَوْجٌ لِلْآخَرِ، ولِذَلِكَ قِيلَ: (خَلَقْنا زَوْجَيْنِ)، وإنَّما نَبَّهَ جَلَّ ثَناؤُهُ بِذَلِكَ مِن قَوْلِهِ " خَلْقِهِ " عَلى قُدْرَتِهِ عَلى خَلْقِ ما يَشاءُ، وأنَّهُ لَيْسَ كالأشْياءِ الَّتِي شَأْنُها فِعْلُ نَوْعٍ واحِدٍ دُونَ خِلافِهِ، إذْ كُلُّ ما صِفَتُهُ فِعْلُ نَوْعٍ واحِدٍ دُونَ ما عَداهُ، كالنّارِ الَّتِي شَأْنُها التَّسْخِينُ ولا تَصْلُحُ لِلتَّبْرِيدِ، وكالثَّلْجِ الَّذِي شَأْنُهُ التَّبْرِيدُ ولا يَصْلُحُ لِلتَّسْخِينِ، فَلا يَجُوزُ أنْ يُوصَفَ بِالكَمالِ، وإنَّما كَمالُ المَدْحِ لِلْقادِرِ عَلى فِعْلِ كُلِّ ما شاءَ فِعْلَهُ مِنَ الأشْياءِ المُخْتَلِفَةِ والمُتَّفِقَةِ. انْتَهى.</p><p><span class="qpc-hafs">﴿لَعَلَّكم تَذَكَّرُونَ﴾</span> قالَ ابْنُ جَرِيرٍ: أيْ: لِتَذَكَّرُوا وتَعْتَبِرُوا بِذَلِكَ، فَتَعْلَمُوا (p-٥٥٣٦)أيُّها المُشْرِكُونَ بِاللَّهِ أنَّ رَبَّكُمُ الَّذِي يَسْتَوْجِبُ عَلَيْكُمُ العِبادَةَ هو الَّذِي يَقْدِرُ عَلى خَلْقِ الشَّيْءِ وخِلافِهِ، وابْتِداعِ زَوْجَيْنِ مِن كُلِّ شَيْءٍ، لا ما لا يَقْدِرُ عَلى ذَلِكَ.</p></div>"
  51,50,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٠] <span class="qpc-hafs">﴿فَفِرُّوا إلى اللَّهِ إنِّي لَكم مِنهُ نَذِيرٌ مُبِينٌ﴾</span></p><p><span class="qpc-hafs">﴿فَفِرُّوا إلى اللَّهِ﴾</span> أيْ: فِرُّوا مِن عِقابِهِ إلى رَحْمَتِهِ بِالإيمانِ بِهِ واتِّباعِ أمْرِهِ والعَمَلِ بِطاعَتِهِ. قالَ الشِّهابُ: الأمْرُ بِالفِرارِ مِنَ العِقابِ، المُرادُ بِهِ الأمْرُ بِالإيمانِ والطّاعَةِ، لِأنَّهُ لِأمْنِهِ مِنَ العِقابِ بِالطّاعَةِ كَأنَّهُ فَرَّ لِمَأْمَنِهِ، فَهو اسْتِعارَةٌ تَمْثِيلِيَّةٌ.</p><p><span class="qpc-hafs">﴿إنِّي لَكم مِنهُ نَذِيرٌ مُبِينٌ﴾</span> أيْ: أُنْذِرُكم عِقابَهُ وأُخَوِّفُكم عَذابَهُ الَّذِي أحَلَّهُ بِهَؤُلاءِ الأُمَمِ الَّذِينَ قَصَّ عَلَيْكم قَصَصَهُمْ، والَّذِي هو مُذِيقُهم في الآخِرَةِ.</p></div>"
  51,51,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥١] <span class="qpc-hafs">﴿ولا تَجْعَلُوا مَعَ اللَّهِ إلَهًا آخَرَ إنِّي لَكم مِنهُ نَذِيرٌ مُبِينٌ﴾</span></p><p><span class="qpc-hafs">﴿ولا تَجْعَلُوا مَعَ اللَّهِ إلَهًا آخَرَ إنِّي لَكم مِنهُ نَذِيرٌ مُبِينٌ﴾</span> أيْ: قَدْ أبانَ النِّذارَةَ، قالَ أبُو السُّعُودِ: وفِيهِ تَأْكِيدٌ لِما قَبْلَهُ مِنَ الأمْرِ بِالفِرارِ مِنَ العِقابِ إلَيْهِ تَعالى، لَكِنْ لا بِطَرِيقِ التَّكْرِيرِ -كَما قِيلَ- بَلْ بِالنَّهْيِ عَنْ سَبَبِهِ، وإيجابِ الفِرارِ مِنهُ.</p></div>"
  51,52,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٢_٥٣_٥٤] <span class="qpc-hafs">﴿كَذَلِكَ ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلا قالُوا ساحِرٌ أوْ مَجْنُونٌ﴾</span> <span class="qpc-hafs">﴿أتَواصَوْا بِهِ بَلْ هم قَوْمٌ طاغُونَ﴾</span> [الذاريات: ٥٣] <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهم فَما أنْتَ بِمَلُومٍ﴾</span> [الذاريات: ٥٤]</p><p><span class="qpc-hafs">﴿كَذَلِكَ﴾</span> أيْ: كَما ذَكَرَ مِن تَكْذِيبِهِمُ الرَّسُولَ وتَسْمِيَتِهِمْ لَهُ ساحِرًا أوْ مَجْنُونًا (p-٥٥٣٧)<span class="qpc-hafs">﴿ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلا قالُوا ساحِرٌ أوْ مَجْنُونٌ﴾</span> يَعْنِي تَقْلِيدًا لِآبائِهِمْ واقْتِداءً لِآثارِهِمْ، فَمَوْرِدُ جَهالَتِهِمْ مُؤْتَلِفٌ، ومَشْرُوعُ تَعَنُّتِهِمْ مُتَّحِدٌ.</p><p>وقَوْلُهُ تَعالى: <span class="qpc-hafs">﴿أتَواصَوْا بِهِ﴾</span> [الذاريات: ٥٣] إنْكارٌ وتَعْجِيبٌ مِن حالِهِمْ وإجْماعِهِمْ عَلى تِلْكَ الكَلِمَةِ الشَّنِيعَةِ الَّتِي لا تَكادُ تَخْطُرُ بِبالِ أحَدٍ مِنَ العُقَلاءِ، فَضْلًا عَنِ التَّفَوُّهِ بِها، أيْ: أأوْصى بِهَذا القَوْلِ بَعْضُهم بَعْضًا حَتّى اتَّفَقُوا عَلَيْهِ.</p><p>وقَوْلُهُ تَعالى: <span class="qpc-hafs">﴿بَلْ هم قَوْمٌ طاغُونَ﴾</span> [الذاريات: ٥٣] إضْرابٌ عَنْ كَوْنِ مَدارِ اتِّفاقِهِمْ عَلى الشَّرِّ تَواصِيهِمْ بِذَلِكَ، وإثْباتٌ لِكَوْنِهِ أمْرًا أقْبَحَ مِنَ التَّواصِي وأشْنَعَ مِنهُ مِنَ الطُّغْيانِ الشّامِلِ لِلْكُلِّ، الدّالِّ عَلى أنَّ صُدُورَ تِلْكَ الكَلِمَةِ الشَّنِيعَةِ مِن كُلِّ واحِدٍ مِنهُمْ، بِمُقْتَضى جِبِلَّتِهِ الخَبِيثَةِ، لا بِمُوجِبِ وصِيَّةِ مَن قَبْلَهم بِذَلِكَ، أفادَهُ أبُو السُّعُودِ.</p><p><span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> [الذاريات: ٥٤] أيْ: أعْرِضْ عَنْ مُقابَلَتِهِمْ بِالأسْوَأِ كَقَوْلِهِ تَعالى: <span class="qpc-hafs">﴿ودَعْ أذاهُمْ﴾</span> [الأحزاب: ٤٨] وقَوْلِهِ: <span class="qpc-hafs">﴿واهْجُرْهم هَجْرًا جَمِيلا﴾</span> [المزمل: ١٠] <span class="qpc-hafs">﴿فَما أنْتَ بِمَلُومٍ﴾</span> [الذاريات: ٥٤] أيْ: في إعْراضِهِمْ، إذْ لَسْتَ عَلَيْهِمْ بِجَبّارٍ ولا مُسَيْطِرٍ، وما عَلَيْكَ مِن حِسابِهِمْ مِن شَيْءٍ.</p><p>تَنْبِيهٌ:</p><p>قَوْلُ بَعْضِ المُفَسِّرِينَ هُنا – <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> [الذاريات: ٥٤] أيْ: فَأعْرِضْ عَنْ مُجادَلَتِهِمْ، بَعْدَ ما كَرَّرْتَ عَلَيْهِمُ الدَّعْوَةَ- بَعِيدٌ عَنِ المَعْنى بِمَراحِلَ؛ لِأنَّ مُجادَلَتَهم مِمّا كانَ مَأْمُورًا بِها عَلى المَدى، لِأنَّها العامِلُ الأكْبَرُ لِإظْهارِ الحَقِّ، كَما قالَ تَعالى: <span class="qpc-hafs">﴿وجاهِدْهم بِهِ جِهادًا كَبِيرًا﴾</span> [الفرقان: ٥٢]</p><p>وكَذا قَوْلُ البَعْضِ في قَوْلِهِ تَعالى: <span class="qpc-hafs">﴿فَما أنْتَ بِمَلُومٍ﴾</span> [الذاريات: ٥٤] أيْ: في إعْراضِكَ بَعْدَ ما بَلَّغْتَ، فَإنَّهُ مُنافٍ لِلْأمْرِ بِالذِّكْرى بَعْدُ. فالصَّوابُ ما ذَكَرْناهُ في تَفْسِيرِ الآيَةِ، لِأنَّهُ المُحاكِي لِنَظائِرِها. وأعْقَدُ التَّفاسِيرِ ما كانَ بِالأشْباهِ والنَّظائِرِ -كَما قِيلَ- وخَيْرُ ما فَسَّرْتَهُ بِالوارِدِ.</p><p>(p-٥٥٣٨)</p></div>"
  51,53,""
  51,54,""
  51,55,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٥] <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span></p><p><span class="qpc-hafs">﴿وذَكِّرْ﴾</span> أيْ: عِظْهم <span class="qpc-hafs">﴿فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> أيْ: مَن قَدَّرَ اللَّهُ إيمانَهُ، أوِ الَّذِينَ آمَنُوا فَإنَّهُمُ المَقْصُودُونَ مِنَ الخَلْقِ، لا مِن سِواهُمْ؛ إذْ هُمُ العابِدُونَ.</p></div>"
  51,56,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٦] <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلا لِيَعْبُدُونِ﴾</span></p><p><span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلا لِيَعْبُدُونِ﴾</span> أيْ: لِهَذِهِ الحِكْمَةِ، وهي عِبادَتُهُ تَعالى بِما أمَرَ عَلى لِسانِ رَسُولِهِ؛ إذْ لا يَتِمُّ صَلاحٌ ولا تُنالُ سَعادَةٌ في الدّارَيْنِ إلّا بِها. وقَوْلُهُ تَعالى:</p></div>"
  51,57,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٧ - ٥٨] <span class="qpc-hafs">﴿ما أُرِيدُ مِنهم مِن رِزْقٍ وما أُرِيدُ أنْ يُطْعِمُونِ﴾</span> <span class="qpc-hafs">﴿إنَّ اللَّهَ هو الرَّزّاقُ ذُو القُوَّةِ المَتِينُ﴾</span> [الذاريات: ٥٨]</p><p><span class="qpc-hafs">﴿إنَّ اللَّهَ هو الرَّزّاقُ ذُو القُوَّةِ المَتِينُ﴾</span> [الذاريات: ٥٨] بَيانٌ لِعَظَمَتِهِ عَزَّ وجَلَّ، وأنَّ شَأْنَهُ مَعَ عَبِيدِهِ لا يُقاسُ بِهِ شَأْنُ عَبِيدِ الخَلْقِ مَعَهُمْ، فَإنَّ عَبِيدَهم مَطْلُوبُونَ بِالخِدْمَةِ والتَّكَسُّبِ لِلسّادَةِ، وبِواسِطَةِ كاسِبِ عَبِيدِهِمْ، قَدَّرَ أرْزاقَهم واللَّهُ تَعالى لا يَطْلُبُ مِن عِبادِهِ رِزْقًا ولا إطْعامًا، بَلْ هو الَّذِي يَرْزُقُهُمْ، وإنَّما يَطْلُبُ مِنهم عِبادَتَهُ لِيَصْرِفُوا ما أنْعَمَ بِهِ عَلَيْهِمْ إلى ما خُلِقُوا لِأجْلِهِ.</p></div>"
  51,58,""
  51,59,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥٩] <span class="qpc-hafs">﴿فَإنَّ لِلَّذِينَ ظَلَمُوا ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ فَلا يَسْتَعْجِلُونِ﴾</span></p><p><span class="qpc-hafs">﴿فَإنَّ لِلَّذِينَ ظَلَمُوا﴾</span> أيْ: ظَلَمُوا أنْفُسَهم بِتَعْرِيضِها لِلْعَذابِ الخالِدِ بِتَكْذِيبِ الرَّسُولِ، (p-٥٥٣٩)والإصْرارِ عَلى الشِّرْكِ والبَغْيِ والفَسادِ، <span class="qpc-hafs">﴿ذَنُوبًا﴾</span> أيْ: نَصِيبًا وافِرًا مِنَ العَذابِ، <span class="qpc-hafs">﴿مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span> أيْ: مِثْلَ أنْصِباءِ نُظَرائِهِمْ مِنَ الأُمَمِ المَحْكِيَّةِ. وأصْلُ (الذَّنُوبَ) الدَّلْوُ العَظِيمَةُ المُمْتَلِئَةُ ماءً، أوِ القَرِيبَةُ مِن الِامْتِلاءِ. وهي تُذَكَّرُ وتُؤَنَّثُ، فاسْتُعِيرَتْ لِلنَّصِيبِ مُطْلَقًا، شَرًّا كالنَّصِيبِ مِنَ العَذابِ في الآيَةِ، أوْ خَيْرًا كَما في العَطاءِ في قَوْلِ عَمْرِو بْنِ شاسٍ:</p><p>؎وفِي كُلِّ حَيٍّ قَدْ خَبَطْتَ بِنِعْمَةٍ فَحُقَّ لِشَأْسٍ مِن نَداكَ ذَنُوبُ</p><p>وهُوَ مَأْخُوذٌ مِن مُقاسَمَةِ السُّقاةِ الماءَ بِالذَّنُوبِ، فَيُعْطى لِهَذا ذَنُوبٌ، ولِآخَرَ مِثْلُهُ.</p><p><span class="qpc-hafs">﴿فَلا يَسْتَعْجِلُونِ﴾</span> أيْ: لا يَطْلُبُوا مِنِّي أنْ أُعَجِّلَ بِهِ قَبْلَ أجَلِهِ، فَإنَّهُ لا بُدَّ آتِيهِمْ، ولَكِنْ في حِينِهِ المُؤَخَّرِ لِحِكْمَةٍ.</p></div>"
  51,60,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٦٠] <span class="qpc-hafs">﴿فَوَيْلٌ لِلَّذِينَ كَفَرُوا مِن يَوْمِهِمُ الَّذِي يُوعَدُونَ﴾</span></p><p><span class="qpc-hafs">﴿فَوَيْلٌ لِلَّذِينَ كَفَرُوا مِن يَوْمِهِمُ الَّذِي يُوعَدُونَ﴾</span> أيْ: أُوعِدُوا فِيهِ نُزُولَ العَذابِ بِهِمْ، ماذا يَلْقَوْنَ فِيهِ مِنَ البَلاءِ والجُهْدِ. و(اليَوْمُ) إمّا يَوْمُ القِيامَةِ، أوْ يَوْمُ بَدْرٍ.</p><p>قالَ أبُو السُّعُودِ: والأوَّلُ هو الأنْسَبُ بِما في صَدْرِ السُّورَةِ الكَرِيمَةِ الآتِيَةِ.</p><p>والثّانِي هو الأوْفَقُ لِما قَبْلَهُ، مِن حَيْثُ إنَّهُما مِنَ العَذابِ الدُّنْيَوِيِّ، واللَّهُ أعْلَمُ.</p></div>"
