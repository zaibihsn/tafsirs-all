tafsir[98]{c,v,t}:
  19,1,"سووره‌تی (مه‌ریه‌م) سووره‌تێكى مه‌ككى یه‌ ته‌نها ئایه‌تى (٥٨ و ٧١) نه‌بێت كه‌ مه‌ده‌نى یه‌ (٩٨) ئایه‌ته‌ بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ  له‌ سه‌ره‌تای سووره‌تی (به‌قه‌ره‌) باسی ئه‌م پیتانه‌مان كرد كه‌ له‌سه‌ره‌تای هه‌ندێك له‌ سووره‌ته‌كانى قورئانى پیرۆزدا هاتوون."
  19,2,"{بەسەرهاتی زەكەریا پێغەمبەر - صلی الله علیه وسلم -}  ئه‌مه‌ باسی ڕه‌حمه‌تی په‌روه‌ردگارته‌ بۆ به‌نده‌و پێغه‌مبه‌ری خۆی زه‌كه‌ریا - صلى الله عليه وسلم - كه‌ یه‌كێك بووه‌ له‌ پێغه‌مبه‌رانی به‌نی ئیسرائیل، وه‌ دارتاش بووه‌، وه‌ خێزانه‌كه‌یشی خوشكی مه‌ریه‌م بووه‌و پووری عیسا پێغه‌مبه‌ر بووه‌ - صلى الله عليه وسلم -."
  19,3," كاتێك پاڕایه‌وه‌ و بانگی له‌ په‌روه‌ردگاری خۆی كرد به‌ نهێنی، چونكه‌ لاى خواى گه‌وره‌ دوعاى نهێنى خۆشه‌ویستتره‌."
  19,4,"[ قَالَ رَبِّ إِنِّي وَهَنَ الْعَظْمُ مِنِّي ] فه‌رمووی: ئه‌ی په‌روه‌ردگارم من ئێسكه‌كانم لاواز بووه‌ [ وَاشْتَعَلَ الرَّأْسُ شَيْبًا ] وه‌ سه‌رم سپی بووه‌ واته‌: پیر بوومه‌  وه‌ ئه‌ی په‌روه‌ردگار هه‌رگیز من له‌ وه‌ڵامدانه‌وه‌ی دوعاو پاڕانه‌وه‌كانم كه‌ لێت ئه‌پاڕێمه‌وه‌ نائومێد نه‌بوومه‌و هه‌میشه‌ وه‌ڵامی منت داوه‌ته‌وه‌."
  19,5,"[ وَإِنِّي خِفْتُ الْمَوَالِيَ مِنْ وَرَائِي ] وه‌ من له‌ خزم و نه‌وه‌كانم ئه‌ترسێم له‌ پاش خۆم كه‌ بمرم ئه‌وان پشت له‌ دین بكه‌ن [ وَكَانَتِ امْرَأَتِي عَاقِرًا ] وه‌ خێزانه‌كه‌یشم نه‌زۆكه‌و منداڵی نابێ وه‌ ته‌مه‌نی زۆر گه‌وره‌یه‌  ئه‌ی په‌روه‌ردگار له‌لایه‌ن خۆته‌وه‌ منداڵێكم پێ ببه‌خشه‌."
  19,6,"[ يَرِثُنِي وَيَرِثُ مِنْ آلِ يَعْقُوبَ ] تا ببێ به‌ میراتگری من و میراتگری ئالی یه‌عقوب له‌ میراتی زانست و زانیارى و پێغه‌مبه‌رایه‌تی نه‌ك میراتی ماڵ، له‌به‌ر ئه‌وه‌ی زه‌كه‌ریا - صلى الله عليه وسلم - خۆی كه‌سێكی هه‌ژار بووه‌و دارتاش بووه‌، وه‌ پێغه‌مبه‌رانیش له‌وه‌ گه‌وره‌ترن كه‌ داوای منداڵ بكه‌ن بۆ ئه‌وه‌ی كه‌ ببێ به‌ میراتگری ماڵ و سه‌روه‌ت و سامانیان، وه‌ كه‌س نابێت به‌ میراتگرى پێغه‌مبه‌ران و ئه‌وه‌ى به‌جێى ده‌هێڵن ده‌بێت به‌ صه‌ده‌قه‌  وه‌ ئه‌ی په‌روه‌ردگار ئه‌و مناڵه‌ی كه‌ پێم ئه‌به‌خشی منداڵێك بێ كه‌ خۆت وه‌ به‌نده‌كانیش لێی ڕازی بن له‌ دین و ڕه‌وشت و ئه‌خلاقی."
  19,7,"{موژدەی یەحیا بە زەكەریا پێغەمبەر - صلی الله علیه وسلم – درا} [ يَا زَكَرِيَّا إِنَّا نُبَشِّرُكَ بِغُلَامٍ اسْمُهُ يَحْيَى ] خوای گه‌وره‌ وه‌ڵامی دایه‌وه‌ ئه‌ی زه‌كه‌ریا - صلى الله عليه وسلم - ئێمه‌ موژده‌ت پێ ده‌ده‌ین به‌ مناڵێك كه‌ ناوی لێ ئه‌نێین یه‌حیا  پێش ئه‌م هیچ كه‌سێكی ترمان ناو نه‌ناوه‌ به‌ یه‌حیا، یان هاوشێوه‌ی نه‌بووه‌."
  19,8,"[ قَالَ رَبِّ أَنَّى يَكُونُ لِي غُلَامٌ وَكَانَتِ امْرَأَتِي عَاقِرًا ] زه‌كه‌ریاش - صلى الله عليه وسلم - سه‌ری سوڕما له‌ تواناو ده‌سه‌ڵاتی خوای گه‌وره‌و وتى: ئه‌ى په‌روه‌ردگار من چۆن منداڵم ئه‌بێ له‌و ته‌مه‌نه‌ پیره‌، كه‌ ته‌مه‌نى سه‌دو بیست ساڵ بووه‌، وه‌ خێزانه‌كه‌یشم نه‌زۆكه‌و به‌ گه‌نجى منداڵى نه‌بووه‌ چۆن له‌م ته‌مه‌نه‌ منداڵی ده‌بێت، كه‌ ته‌مه‌نى نه‌وه‌دو هه‌شت ساڵ بووه‌  وه‌ گه‌یشتوومه‌ته‌ ئه‌وپه‌ڕی ته‌مه‌نی پیرێتی."
  19,9,"[ قَالَ كَذَلِكَ ] فریشته‌كه‌ فه‌رمووی: به‌ڵێ به‌م شێوازه‌یه‌ [ قَالَ رَبُّكَ هُوَ عَلَيَّ هَيِّنٌ ] په‌روه‌ردگارت ده‌فه‌رمووێ: ئه‌م شته‌ له‌ لای من زۆر سووك و ئاسانه‌  كه‌ من پێشتر تۆم دروست كردووه‌ له‌ نه‌بوونه‌وه‌ تۆم هێناوه‌ته‌ بوون و هیچ شتێك نه‌بوویته‌ ئێستا له‌ دایك و باوكێك مناڵێك دروست بكه‌م زۆر ئاسانتره."
  19,10,"[ قَالَ رَبِّ اجْعَلْ لِي آيَةً ] زه‌كه‌ریا - صلى الله عليه وسلم - فه‌رمووی: ئه‌ی په‌روه‌ردگار نیشانه‌یه‌كم پێ بده‌ له‌سه‌ر ئه‌م موژده‌یه‌ كه‌ منداڵمان ده‌بێ تا زیاتر دڵئارام بم  خوای گه‌وره‌ فه‌رمووی: نیشانه‌ی تۆ ئه‌وه‌ بێ كه‌ سێ شه‌و وسێ رۆژ له‌سه‌ر یه‌ك ناتوانیت قسه‌ له‌گه‌ڵ كه‌سدا بكه‌یت له‌ كاتێكدا كه‌ تۆ ساغ و سه‌لیمی لاڵ نیت (سێ شه‌و وسێ رۆژ له‌سه‌ر یه‌ك زمانى به‌سترا ته‌نها زیكرى خواى پێ ده‌كردو نه‌یده‌توانى قسه‌ى له‌گه‌ڵ خه‌ڵكى پێ بكات ته‌نها به‌ ئاماژه‌ نه‌بێت)."
  19,11,"[ فَخَرَجَ عَلَى قَوْمِهِ مِنَ الْمِحْرَابِ ] له‌ نوێژگه‌كه‌ی خۆی له‌ شوێنی نوێژه‌كه‌ی هاته‌ ده‌ره‌وه‌ بۆ ناو قه‌ومه‌كه‌ی [ فَأَوْحَى إِلَيْهِمْ ] ئاماژه‌ى بۆ كردن و قسه‌ی له‌گه‌ڵدا نه‌كردن  كه‌ (سبحان الله) بكه‌ن له‌ به‌یانیان و ئێواراندا، یاخود نوێژی به‌یانی و نوێژی عه‌صر ئه‌نجام بده‌ن."
  19,12,"[ يَا يَحْيَى خُذِ الْكِتَابَ بِقُوَّةٍ ] دوای ئه‌وه‌ی كه‌ یه‌حیای پێ به‌خشی خوای گه‌وره‌ فه‌رمووی: ئه‌ی یه‌حیا ئه‌و كتابه‌ی كه‌ بۆت دێت، یاخود ته‌ورات به‌ جددی و هێزو عه‌زیمه‌ت و كۆششه‌وه‌ به‌ جوانی بیگره‌  وه‌ هه‌ر له‌ منداڵیه‌وه‌ حیكمه‌ت و دانایی و تێگه‌یشتن و زانیارى و كۆشش و رووكردنه‌ چاكه‌، یاخود پێغه‌مبه‌رایه‌تیمان پێ به‌خشی."
  19,13,"[ وَحَنَانًا مِنْ لَدُنَّا وَزَكَاةً ] وه‌ ڕه‌حم و سۆزو به‌زه‌یی و خۆشه‌ویستى و پاكێتیمان پێی به‌خشی له‌ لایه‌ن خۆمانه‌وه‌  وه‌ كه‌سێكی له‌ خواترس و خۆپارێز بوو له‌ تاوان و گوێڕایه‌ڵی خوای گه‌وره‌ بوو [ وَبَرًّا بِوَالِدَيْهِ ] وه‌ چاكه‌كار بوو له‌گه‌ڵ دایك و باوكیدا."
  19,14," وه‌ كه‌سێك نه‌بوو كه‌ خۆ به‌گه‌وره‌زان و سه‌رپێچیكاری دایك و باوكی یان په‌روه‌ردگاری بێت، به‌ڵكو گوێڕایه‌ڵیان بوو."
  19,15," وه‌ سه‌لامی خوای گه‌وره‌ له‌سه‌ر یه‌حیا بێت له‌و ڕۆژه‌ی كه‌ له‌ دایك بوو، وه‌ له‌و ڕۆژه‌ش كه‌ ئه‌مرێ، وه‌ ئه‌و ڕۆژه‌ش كه‌ زیندوو ئه‌بێته‌وه‌، یاخود ئه‌مینه‌ له‌ شه‌یتان كه‌ له‌دایك ده‌بێت، وه‌ ئه‌مینه‌ له‌ خوای گه‌وره‌ كه‌ ده‌مرێت و زیندوو ده‌بێته‌وه‌."
  19,16,"{بەسەرهاتی خاتوو مەریەم } [ وَاذْكُرْ فِي الْكِتَابِ مَرْيَمَ ] ئه‌ی محمد - صلى الله عليه وسلم - له‌م سووره‌ته‌دا له‌م قورئانه‌ پیرۆزه‌دا باسی (مه‌ریه‌مى كچى عیمران) بۆ خه‌ڵكی بكه‌ كه‌ له‌ نه‌وه‌ى داود - صلى الله عليه وسلم - بووه‌  كاتێك كه‌ دووركه‌وته‌وه‌و تاك بووه‌وه‌ له‌ كه‌سوكاری بۆ عیباده‌ت كردنی خوای گه‌وره‌ چووه‌ لای ڕۆژهه‌ڵاتی (بیت المقدس)."
  19,17,"[ فَاتَّخَذَتْ مِنْ دُونِهِمْ حِجَابًا ] له‌وێ په‌رده‌ی هه‌ڵخست بۆ ئه‌وه‌ی خه‌ڵكی نه‌یبینێ له‌ كاتی عیباده‌ت كردنی خوای گه‌وره‌دا [ فَأَرْسَلْنَا إِلَيْهَا رُوحَنَا ] جبریلمان نارد بۆ لای مه‌ریه‌م  خۆی له‌سه‌ر شێوه‌ی مرۆڤێكی ته‌واو نیشان دا."
  19,18,"[ قَالَتْ إِنِّي أَعُوذُ بِالرَّحْمَنِ مِنْكَ ] مه‌ریه‌م وایزانی ئه‌م پیاوه‌ ئه‌یه‌وێ زیانی پێ بگه‌یه‌نێت و تووشی خراپه‌ی بكات بۆیه‌ فه‌رمووی: په‌نا ئه‌گرم به‌ په‌روه‌ردگاری به‌ڕه‌حم و سۆزو میهره‌بان له‌ تۆ  ئه‌گه‌ر تۆ كه‌سێكی ته‌قوای خوای گه‌وره‌ ئه‌كه‌ی لێم دووركه‌وه‌."
  19,19,"[ قَالَ إِنَّمَا أَنَا رَسُولُ رَبِّكِ ] جبریل (عليه الصلاة والسلام) فه‌رمووی: من خراپه‌ت تووش ناكه‌م به‌ڵكو من نێردراوی په‌روه‌ردگارتم بۆلات  تا منداڵێكی پاكت پێ ببه‌خشم."
  19,20,"قَالَتْ أَنَّى يَكُونُ لِي غُلَامٌ وَلَمْ يَمْسَسْنِي بَشَرٌ] مه‌ریه‌میش سه‌رى سوڕماو فه‌رمووی: چۆن من منداڵم ئه‌بێ له‌ كاتێكدا هیچ مرۆڤێك جیماعی له‌گه‌ڵ نه‌كردووم و لێم نزیك نه‌بۆته‌وه‌  وه‌ من شووم نه‌كردووه‌ به‌ حه‌ڵاڵی، وه‌ داوێن پیسیش نیم كه‌ زینام كردبێ."
  19,21,"[ قَالَ كَذَلِكِ ] فه‌رمووی: به‌ڵێ به‌م شێوازه‌یه‌ [ قَالَ رَبُّكِ هُوَ عَلَيَّ هَيِّنٌ ] په‌روه‌ردگارت ئه‌فه‌رمووێ: ئه‌م شته‌ له‌لای من ئاسانه‌ كه‌ كه‌سێك به‌بێ باوك له‌ دایك بێت، پێشتریش ئاده‌مم به‌بێ دایك و باوك دروستكردو حه‌ووایشم له‌ په‌راسوى چه‌پى ئاده‌م دروستكرد [ وَلِنَجْعَلَهُ آيَةً لِلنَّاسِ ] وه‌ تا ئه‌و منداڵه‌ ببێته‌ نیشانه‌یه‌ك له‌ نیشانه‌كانی تواناو ده‌سه‌ڵاتی خوای گه‌وره‌ بۆ خه‌ڵكی [ وَرَحْمَةً مِنَّا ] وه‌ ببێته‌ هۆی ڕه‌حمه‌تێك له‌ خواوه‌ بۆ هیدایه‌ت دانی خه‌ڵكی و ببێت به‌ پێغه‌مبه‌ر  وه‌ ئه‌مه‌ كارێكه‌و بڕیاری له‌سه‌ر دراوه‌و ئه‌بێ ڕووبدات بۆیه‌ ئارام بگره‌ له‌سه‌ر بڕیارى په‌روه‌ردگارت."
  19,22,"[ فَحَمَلَتْهُ ] ئه‌و كاته‌ جبریل فووی كرده‌ ناو ملوانی كراسه‌كه‌ى یه‌كسه‌ر به‌ ئیزنی خوای گه‌وره‌ حه‌ملی بوو  ڕۆیشت و دووركه‌وته‌وه‌ بۆ شوێنێكی دوور."
  19,23,"[ فَأَجَاءَهَا الْمَخَاضُ إِلَى جِذْعِ النَّخْلَةِ ] كه‌ ژانی منداڵ بوونی بۆ هات ژانی مناڵ بوونه‌كه‌ بردی به‌ره‌و ژێر دارخورمایه‌ك [ قَالَتْ يَا لَيْتَنِي مِتُّ قَبْلَ هَذَا ] ئه‌میش ئاواتی خواست خۆزگه‌ پێش ئه‌وه‌ی ئه‌مه‌م به‌سه‌ردا بێ بمردمایه‌ بۆ ئه‌وه‌ی خه‌ڵكى گومانی خراپم پێ نه‌بات (ئه‌مه‌یش به‌ڵگه‌یه‌ له‌سه‌ر ئه‌وه‌ى كه‌ دروسته‌ مرۆڤـ له‌ كاتى فیتنه‌دا ئاوات بخوازێت به‌ مردن)  وه‌ خۆزگه‌ من شتێكی بێ ڕێز بوومایه‌و هه‌ر باس نه‌كرامایه‌، یاخود هه‌ر دروست نه‌كرامایه‌، یاخود وه‌كو په‌ڕۆی حه‌یزاوی بوومایه‌ كه‌ فڕێ ئه‌درێ و ناوم نه‌بوایه‌."
  19,24,"[ فَنَادَاهَا مِنْ تَحْتِهَا ] له‌ ژێرێوه‌ له‌ژێر داره‌كه‌وه‌ جبریل، یاخود عیسى بانگی لێ كرد [ أَلَّا تَحْزَنِي ] خه‌فه‌ت نه‌خۆی  ئه‌وه‌ په‌روه‌ردگارت كانیاو و جۆگه‌له‌ ئاوێكی له‌ ژێرته‌وه‌ ده‌ركردووه‌و تێ ئه‌په‌ڕێ له‌و ئاوه‌ بخۆره‌وه‌."
  19,25," وه‌ ئه‌و قه‌دی دار خورمایه‌ ڕابوه‌شێنه‌ خورمای ته‌ڕت بۆ دێته‌ خواره‌وه‌ (كاتى خورما پێگه‌یشتن نه‌بووه‌)."
  19,26,"[ فَكُلِي وَاشْرَبِي ] له‌ خورما ته‌ڕه‌كه‌ بخۆ و له‌ ئاوه‌كه‌ بخۆره‌وه‌ (هیچ شتێك وه‌كو خورماى ته‌ڕ بۆ ئافره‌تى زه‌یستان به‌سوود نیه‌) [ وَقَرِّي عَيْنًا ] وه‌ چاوڕۆشنابه‌ پێی و خۆت له‌ خه‌فه‌ت دوورخه‌ره‌وه‌  وه‌ ئه‌گه‌ر هه‌ر مرۆڤێكت بینی ئه‌وه‌ به‌ ئاماژه‌ پێیان بڵێ: من نه‌زرم كردووه‌ بۆ په‌روه‌ردگارم كه‌ خۆم بگرمه‌وه‌ له‌ قسه‌ كردن و ئه‌مڕۆ قسه‌ له‌گه‌ڵ هیچ مرۆڤێكدا ناكه‌م (وتراوه‌ له‌ به‌رۆژوو بوونى ئه‌واندا خواردن و قسه‌ كردنیش حه‌رام بووه‌)."
  19,27,"[ فَأَتَتْ بِهِ قَوْمَهَا تَحْمِلُهُ ] دوای ئه‌وه‌ی كه‌ عیسای بوو - صلى الله عليه وسلم - وه‌ عیسای هێنایه‌وه‌ قه‌ومه‌كه‌ی سه‌رزه‌نشتیان كرد  وتیان: ئه‌ی مه‌ریه‌م به‌ڕاستی كارێكی زۆر گه‌وره‌و خراپت كردووه‌."
  19,28,"[ يَا أُخْتَ هَارُونَ ] ئه‌ی خوشكی هارون واته‌: له‌ عیباده‌تدا تۆ خۆت ئه‌چواند به‌ هارون پێغه‌مبه‌ر- صلى الله عليه وسلم -، یاخود هارون پیاوچاكێك بووه‌ له‌ ناویاندا وتوویانه‌: ئه‌ی وه‌كو ئه‌و پیاوچاكه‌، یاخود وتراوه‌: پیاو خراپێك بووه‌ وتوویانه‌: ئه‌ی خوشكی ئه‌و پیاوخراپه‌ وه‌كو ئه‌و خراپه‌ت كردووه‌ [ مَا كَانَ أَبُوكِ امْرَأَ سَوْءٍ ] به‌ڕاستی تۆ باوكت پیاوێكی خراپ نه‌بووه‌  وه‌ دایكیشت داوێن پیس نه‌بووه‌ ئیتر تۆ ئه‌م منداڵه‌ت له‌ كوێ هێنا."
  19,29,"[ فَأَشَارَتْ إِلَيْهِ ] مه‌ریه‌میش ئاماژه‌ی بۆ عیسا كرد كه‌ له‌ باوه‌شیدا بوو تازه‌ له‌ دایك بووه‌  وتیان: چۆن قسه‌ له‌گه‌ڵ منداڵێكدا بكه‌ین كه‌ منداڵه‌و تازه‌ له‌ دایك بووه‌و له‌ناو بێشكه‌دایه‌ [ قَالَ إِنِّي عَبْدُ اللَّهِ ] به‌ ئیزنی خوای گه‌وره‌ عیسا - صلى الله عليه وسلم - هاته‌ قسه‌و یه‌كه‌م قسه‌ كه‌ كردى وتی: من عه‌بدو به‌نده‌ی خوای گه‌وره‌م ( ئه‌مه‌ ڕه‌ده‌ بۆ سه‌ر گاوره‌كان كه‌ من كوڕی خوا نیم به‌ڵكو عه‌بدی خوام)."
  19,30,"[ آتَانِيَ الْكِتَابَ ] وه‌ له‌ داهاتوودا خوای گه‌وره‌ ئینجیلم پێ ئه‌به‌خشێ  وه‌ ده‌مكات به‌ پێغه‌مبه‌ر."
  19,31,"[ وَجَعَلَنِي مُبَارَكًا أَيْنَ مَا كُنْتُ ] وه‌ من كه‌سێكی موباره‌ك و پیرۆزو پڕ خێرو مامۆستاى چاكه‌و به‌سود ئه‌بم بۆ به‌نده‌كان له‌ هه‌ر شوێنێكدا بم  وه‌ خوای گه‌وره‌ فه‌رمانی پێ كردووم و ئامۆژگاری كردووم به‌ نوێژ كردن و به‌ زه‌كات دان تا له‌ ژیاندا بم و زیندوو بم."
  19,32,"[ وَبَرًّا بِوَالِدَتِي ] وه‌ فه‌رمانم پێ كراوه‌ به‌ چاكه‌كردن له‌گه‌ڵ دایكمدا (له‌به‌ر ئه‌وه‌ی باوكی نه‌بووه‌ ته‌نها باسی دایكی ئه‌كات)  وه‌ خوای گه‌وره‌ منی وا لێ نه‌كردووه‌ كه‌سێكی لووتبه‌رزو خۆبه‌گه‌وره‌زان بم وه‌ سه‌رپێچی خوای گه‌وره‌ یان دایكم بكه‌م یان ئازاری دایكم بده‌م."
  19,33,"[ وَالسَّلَامُ عَلَيَّ ] سه‌لامی خوای گه‌وره‌ له‌سه‌ر منه‌و پارێزراوم  له‌و ڕۆژه‌ی كه‌ له‌ دایك بووم وه‌ له‌و ڕۆژه‌ی كه‌ ئه‌مرم وه‌ له‌و ڕۆژه‌ی كه‌ زیندوو ئه‌بمه‌وه‌ (ئه‌مه‌یش به‌ڵگه‌یه‌كى تره‌ له‌سه‌ر ئه‌وه‌ى كه‌ عیسى - صلى الله عليه وسلم - نه‌ خوایه‌ نه‌ كوڕى خوایه‌، به‌ڵكو به‌نده‌و پێغه‌مبه‌رى خوایه‌و له‌دایك بووه‌و ده‌مرێت و زیندوویش ده‌بێته‌وه‌ وه‌كو سه‌رجه‌م مرۆڤه‌كانى تر، ئه‌گه‌ر خوا بوایه‌ یان كوڕى خوا بوایه‌ نابوایه‌ بمردایه‌، به‌ڵكو ده‌بوایه‌ بۆ هه‌میشه‌یى بمایاته‌وه‌و زیندوو بوایه‌، چۆن ده‌بێت خوا بمرێت!؟)."
  19,34," ئا ئه‌مه‌ عیسای كوڕی مه‌ریه‌مه‌و ئه‌مه‌ وته‌ی حه‌قه‌ ده‌رباره‌ی عیسا نه‌ك ئه‌وه‌ی كه‌ ئه‌و كه‌سانه‌ ئیختیلافیان هه‌یه‌ ده‌رباره‌ی عیسا كه‌ ئه‌ڵێن: كوڕی خوایه‌ یان خوایه‌."
  19,35,"[ مَا كَانَ لِلَّهِ أَنْ يَتَّخِذَ مِنْ وَلَدٍ ] خوای گه‌وره‌ پێویستی به‌وه‌ نیه‌ كه‌ منداڵ بۆ خۆی بڕیار بدات [ سُبْحَانَهُ ] پاك و مونه‌ززه‌هی بۆ خوای گه‌وره‌ له‌و قسه‌یه‌  خوای گه‌وره‌ ئه‌گه‌ر بڕیاری هه‌ر شتێك بدات ئه‌وه‌ ته‌نها پێی ئه‌فه‌رمووێ: ببه‌ ئه‌ویش یه‌كسه‌ر ئه‌بێت."
  19,36,"[ وَإِنَّ اللَّهَ رَبِّي وَرَبُّكُمْ فَاعْبُدُوهُ ] وه‌ عیسى - صلى الله عليه وسلم - له‌ناو بێشكه‌ پێى فه‌رموون: وه‌ به‌ دڵنیایى الله په‌روه‌ردگاری من و په‌روه‌ردگاری ئێوه‌یشه‌، ئێوه‌ به‌تاك و ته‌نها عیباده‌تی خوای گه‌وره‌ بكه‌ن  ئه‌مه‌ ڕێگای ڕاستی خوای گه‌وره‌یه‌."
  19,37,"[ فَاخْتَلَفَ الْأَحْزَابُ مِنْ بَيْنِهِمْ ] حیزب و فیرقه‌و گروپه‌كانى ئه‌هلی كتاب ئیختیلاف و جیاوازی كه‌وته‌ نێوانیانه‌وه‌ ده‌رباره‌ی عیسا - صلى الله عليه وسلم - جووله‌كه‌ ئه‌یانوت: كوڕی زینایه‌و دایكی زینای كردووه‌، گاوره‌كان هه‌ندێكیان ئه‌یانوت: خوایه‌، وه‌ هه‌ندێكیان ده‌یانوت: كوڕی خوایه‌، وه‌ هه‌ندێكیان ئه‌یانوت: یه‌كێكه‌ له‌ سێ خوایه‌كه‌، وه‌ موسڵمانان وتیان به‌نده‌و پێغه‌مبه‌رى خوایه‌ كه‌ ئه‌مه‌ وته‌و بیروباوه‌ڕى حه‌قه‌ سه‌باره‌ت به‌ عیسى- صلى الله عليه وسلم - كه‌ خواى گه‌وره‌ رێنمایى كردووین بۆى  خوای گه‌وره‌ش ئه‌فه‌رمووێ: هه‌ڕه‌شه‌و دۆزه‌خ بۆ ئه‌و كافرانه‌ له‌ دیمه‌نه‌كانی ڕۆژی قیامه‌ت كه‌ ڕۆژێكی یه‌كجار گه‌وره‌یه‌ خوای گه‌وره‌ سزایان ئه‌دا له‌سه‌ر ئه‌و قسانه‌یان كه‌ درۆ بۆ خواى گه‌وره‌ هه‌ڵده‌به‌ستن و ده‌ڵێن منداڵى هه‌یه‌."
  19,38,"[ أَسْمِعْ بِهِمْ وَأَبْصِرْ يَوْمَ يَأْتُونَنَا ] ئای كه‌ بیستن و بینینیان یه‌كجار به‌هێزه‌ له‌ ڕۆژی قیامه‌تدا له‌ ڕۆژی لێپرسینه‌وه‌دا كه‌ هه‌موو شتێك ئه‌بیستن و ئه‌بینن به‌ڵام سودیان پێناگه‌یه‌نێت  به‌ڵام سته‌مكاران ئه‌مڕۆ له‌ دونیادا له‌ گومڕاییه‌كی ئاشكرادان و حه‌ق نابیستن و حه‌ق نابینن."
  19,39," پێغه‌مبه‌رى خوا - صلى الله عليه وسلم - ده‌فه‌رمێت: كه‌ به‌هه‌شتییه‌كان چونه‌ به‌هه‌شته‌وه‌و دۆزه‌خییه‌كان چوونه‌ دۆزه‌خه‌وه‌ مردن له‌سه‌ر شێوه‌ به‌رانێك ده‌هێنرێت و له‌ نێوان به‌هه‌شت و دۆزه‌خ راده‌گیرێت و ده‌وترێت: ئه‌ى به‌هه‌شتییه‌كان ئایا ئه‌مه‌ ده‌ناسن؟ ده‌ڵێن به‌ڵێ مردنه‌، وه‌ به‌دۆزه‌خییه‌كان ده‌وترێت: ئایا ئه‌مه‌ ده‌ناسن؟ ده‌ڵێن: به‌ڵێ مردنه‌، فه‌رمان ده‌كرێت و سه‌رده‌بڕدرێت و ده‌وترێت: ئه‌ى به‌هه‌شتییه‌كان ئێوه‌ نه‌مرن و مردن نه‌ما، وه‌ ئه‌ى دۆزه‌خیه‌كان ئێوه‌ نه‌مرن و مردن نه‌ما، پاشان پێغه‌مبه‌رى خوا - صلى الله عليه وسلم - ئه‌م ئایه‌ته‌ى خوێنده‌وه‌: ئه‌ی محمد - صلى الله عليه وسلم - ئاگاداریان بكه‌وه‌ له‌و ڕۆژه‌ی كه‌ په‌شیمان ئه‌بنه‌وه‌ كه‌ ڕۆژی قیامه‌ته‌ كاتێك كه‌ هه‌موو شتێك بڕیاری له‌سه‌ر ئه‌درێ و یه‌كلا ئه‌كرێته‌وه‌و كۆمه‌ڵێك بۆ به‌هه‌شت و كۆمه‌ڵێك بۆ دۆزه‌خ جیا ده‌كرێته‌وه‌ به‌ڵام ئه‌وانه‌ی ئێستا له‌ دونیان بێئاگان وه‌ ئه‌وان ئیمان ناهێنن."
  19,40,"[ إِنَّا نَحْنُ نَرِثُ الْأَرْضَ وَمَنْ عَلَيْهَا ] ئێمه‌ خۆمان ئه‌بین به‌ میراتگری زه‌وی و هیچ كه‌سێك له‌سه‌ر زه‌ویدا نامێنێ، ئه‌وه‌ی له‌سه‌ریه‌تی ئه‌بێ هه‌مووی بمرێت و دونیا به‌جێ بێلێت  وه‌ هه‌مووشیان بۆ لای ئێمه‌ ئه‌گه‌ڕێنه‌وه‌ له‌ ڕۆژی قیامه‌ت تا پاداشت یان سزایان بده‌ینه‌وه‌."
  19,41,"{گفتوگۆی نێوان ئیبراهیم پێغەمبەر - صلی الله علیه وسلم -و باوكی} [ وَاذْكُرْ فِي الْكِتَابِ إِبْرَاهِيمَ ] ئه‌ی محمد - صلى الله عليه وسلم - تۆ له‌م قورئانه‌ پیرۆزه‌ باسی ئیبراهیم پێغه‌مبه‌ر - صلى الله عليه وسلم - بۆ بت په‌رستان بكه‌  كه‌ به‌دڵنیایى ئه‌و كه‌سێك بووه‌ كه‌ زۆر ڕاستگۆ بووه‌، یان زۆر ئایه‌ته‌كانی خوای گه‌وره‌ی به‌ڕاست داناوه‌، وه‌ پێغه‌مبه‌ری خوا بووه‌."
  19,42,"[ إِذْ قَالَ لِأَبِيهِ يَا أَبَتِ لِمَ تَعْبُدُ مَا لَا يَسْمَعُ وَلَا يُبْصِرُ ] كاتێك كه‌ به‌ (ئازه‌ر)ی باوكی فه‌رموو: ئه‌ی باوكه‌ تۆ بۆ عیباده‌ت بۆ ئه‌و بتانه‌ ئه‌كه‌ی كه‌ نه‌ هیچ شتێك ئه‌بیستن نه‌ هیچ شتێك ئه‌بینن  وه‌ هیچ سوودێك به‌ تۆ ناگه‌یه‌نن."
  19,43,"[ يَا أَبَتِ إِنِّي قَدْ جَاءَنِي مِنَ الْعِلْمِ مَا لَمْ يَأْتِكَ ] ئه‌ی باوكه‌ من هه‌ندێك له‌ زانیاری و وه‌حیم بۆ هاتووه‌ له‌ لایه‌ن خوای گه‌وره‌وه‌ كه‌ بۆ تۆ نه‌هاتووه‌  بۆیه‌ تۆ شوێنی من بكه‌وه‌ هیدایه‌تت ئه‌ده‌م بۆ ڕێگای ڕاستی خوای گه‌وره‌."
  19,44,"[ يَا أَبَتِ لَا تَعْبُدِ الشَّيْطَانَ ] ئه‌ی باوكه‌ تۆ شه‌یتان مه‌په‌رسته‌ له‌به‌ر ئه‌وه‌ی په‌رستنی بته‌كان گوێڕایه‌ڵی كردنی شه‌یتانه‌و په‌رستنی شه‌یتانه‌  له‌به‌ر ئه‌وه‌ی به‌ڕاستی شه‌یتان سه‌رپێچی فه‌رمانی خوای گه‌وره‌ی كرد."
  19,45,"[ يَا أَبَتِ إِنِّي أَخَافُ أَنْ يَمَسَّكَ عَذَابٌ مِنَ الرَّحْمَنِ ] ئه‌ی باوكه‌ من له‌وه‌ ئه‌ترسێم كه‌ له‌ لایه‌ن په‌روه‌ردگارو خوای به‌ڕه‌حم و به‌زه‌ییه‌وه‌ سزایه‌كی به‌ئێش و ئازارت پێ بگات  به‌هۆی ئه‌وه‌ی كه‌ تۆ دۆست و خۆشه‌ویستی شه‌یتانی."
  19,46,"[ قَالَ أَرَاغِبٌ أَنْتَ عَنْ آلِهَتِي يَا إِبْرَاهِيمُ ] باوكی وتی: ئه‌ی ئیبراهیم ئایا تۆ پشت له‌ خواكانی من هه‌ڵئه‌كه‌یت و وازیان لێ دێنی [ لَئِنْ لَمْ تَنْتَهِ لَأَرْجُمَنَّكَ ] ئه‌گه‌ر واز له‌م قسانه‌ نه‌هێنی ئه‌وه‌ به‌ دڵنیایى ڕه‌جم و به‌رد بارانت ئه‌كه‌م  وه‌ ماوه‌یه‌كی یه‌كجار زۆر لێم دووركه‌وه‌ به‌ سه‌لامه‌تى پێش ئه‌وه‌ى سزات بده‌م."
  19,47,"[ قَالَ سَلَامٌ عَلَيْكَ ] ئیبراهیم - صلى الله عليه وسلم - وتی: ئه‌ی باوكه‌ سڵاوت لێ بێت و تۆ سه‌لامه‌تیت و له‌ لایه‌ن منه‌وه‌ توشى خراپه‌و ئازار نابیت له‌به‌ر رێزى باوكایه‌تى [ سَأَسْتَغْفِرُ لَكَ رَبِّي ] ئه‌بێ داوای لێ خۆشبوونت بۆ بكه‌م له‌ په‌روه‌ردگارم  له‌به‌ر ئه‌وه‌ی خوای گه‌وره‌ زۆر چاكه‌كاره‌ له‌گه‌ڵ منداو بایه‌خم پێ ده‌دات و دوعاكانم قه‌بوڵ ده‌كات، (ئه‌مه‌ كاتێك بوو كه‌ نه‌یزانی باوكی له‌سه‌ر كوفر ئه‌مرێ و به‌كافری ئه‌مرێ دواتر لێی په‌شیمان بووه‌وه‌، چونكه‌ دروست نیه‌ داواى لێخۆشبوون بۆ كافران بكرێت)."
  19,48,"[ وَأَعْتَزِلُكُمْ وَمَا تَدْعُونَ مِنْ دُونِ اللَّهِ ] وه‌ لێتان دوور ئه‌كه‌ومه‌وه‌ له‌ خۆتان و له‌و شتانه‌ی كه‌ ئێوه‌ جگه‌ له‌ خوای گه‌وره‌ ئه‌یپه‌رستن [ وَأَدْعُو رَبِّي ] وه‌ من به‌تاك و ته‌نها عیباده‌تی خوای گه‌وره‌ ئه‌كه‌م  به‌دڵنیایى من بێئومێد نابم له‌ دوعاو پاڕانه‌وه‌م، یاخود له‌ په‌رستنى خوای گه‌وره‌."
  19,49,"[ فَلَمَّا اعْتَزَلَهُمْ وَمَا يَعْبُدُونَ مِنْ دُونِ اللَّهِ ] كاتێك كه‌ لێیان دووركه‌وته‌وه‌و زه‌وییه‌كه‌یانی به‌جێهێشت و كۆچی كرد له‌ پێناو خواى گه‌وره‌ بۆ (بیت المقدس) [ وَهَبْنَا لَهُ إِسْحَاقَ ] خوای گه‌وره‌ ئیسحاقی پێ به‌خشی [ وَيَعْقُوبَ ] وه‌ یه‌عقوبیش كه‌ كوڕی ئیسحاق بوو دواتر ئه‌ویشی به‌ ئیسحاق به‌خشی  وه‌ هه‌موویانی كرد به‌ پێغه‌مبه‌رو ئیبراهیم - صلى الله عليه وسلم - چاوڕۆشنا بوو پێیان."
  19,50,"[ وَوَهَبْنَا لَهُمْ مِنْ رَحْمَتِنَا ] وه‌ له‌ ڕه‌حمه‌ت و میهره‌بانی خۆمان پێغه‌مبه‌رایه‌تی و ماڵ و منداڵ و كتابمان پێ به‌خشین  وه‌ زمانی ڕاستگۆی به‌رزمان پێ به‌خشین، واته‌: له‌سه‌ر زمانی به‌نده‌كان به‌ باشه‌ باس ده‌كرێن."
  19,51,"[ وَاذْكُرْ فِي الْكِتَابِ مُوسَى ] وه‌ هه‌ر له‌و قورئانه‌ پیرۆزه‌ ئه‌ی محمد - صلى الله عليه وسلم - باسی موسى پێغه‌مبه‌ریان - صلى الله عليه وسلم - بۆ بكه‌ [ إِنَّهُ كَانَ مُخْلَصًا ] به‌دڵنیایى ئه‌و كه‌سێك بووه‌ كه‌ خوای گه‌وره‌ هه‌ڵیبژاردووه‌و دڵسۆزو نیازپاك بووه‌ له‌ په‌رستندا  وه‌ كه‌سێك بووه‌ كه‌ ره‌سول و نه‌بی و پێغه‌مبه‌ری خوای گه‌وره‌ بووه‌."
  19,52,"[ وَنَادَيْنَاهُ مِنْ جَانِبِ الطُّورِ الْأَيْمَنِ ] وه‌ خوای گه‌وره‌ له‌ لای ڕاستی كێوی (طور)ه‌وه‌ بانگی له‌ موسى - صلى الله عليه وسلم - كرد (ئه‌مه‌یش به‌ڵگه‌یه‌ له‌سه‌ر ئه‌وه‌ى كه‌ خواى گه‌وره‌ قسه‌ ده‌كات و سیفه‌تى قسه‌ كردنى هه‌یه‌)  وه‌ له‌ خۆمان نزیكمان كرده‌وه‌و موناجاتمان له‌گه‌ڵدا كرد تا قسه‌ی خوای گه‌وره‌ی بیست."
  19,53," وه‌ له‌ ڕه‌حمه‌تی خۆمان براكه‌یشی كه‌ هارون بوو كردمان به‌ پێغه‌مبه‌ر كاتێك كه‌ داوای كردو تكاى له‌ خواى گه‌وره‌ كرد كه‌ هارونم له‌گه‌ڵدا بنێره‌و بیكه‌ به‌ پێغه‌مبه‌ر (هیچ كه‌سێك له‌ دونیادا شه‌فاعه‌ت و تكاى باشترو گه‌وره‌ترى بۆ كه‌س نه‌كردووه‌ وه‌كو ئه‌وه‌ى كه‌ موسى بۆ هارونى براى كردو خواى گه‌وره‌ كردى به‌ پێغه‌مبه‌ر)."
  19,54,"[ وَاذْكُرْ فِي الْكِتَابِ إِسْمَاعِيلَ ] ئه‌ی محمد - صلى الله عليه وسلم - له‌و قورئانه‌ پیرۆزه‌ باسی ئیسماعیل پێغه‌مبه‌ریش - صلى الله عليه وسلم - بۆ خه‌ڵكی بكه‌ [ إِنَّهُ كَانَ صَادِقَ الْوَعْدِ ] به‌ دڵنیایى ئه‌و كه‌سێك بووه‌ كه‌ له‌ وه‌عدو به‌ڵێنه‌كانیدا ڕاستگۆ بووه‌و هیچ به‌ڵێنێكى نه‌داوه‌ ئیلا بردۆتیه‌سه‌ر (هه‌رچه‌نده‌ هه‌موو پێغه‌مبه‌ران وابوونه‌ به‌ڵام ئه‌م زیاتر په‌یوه‌ست بووه‌ پێوه‌ی بۆیه‌ به‌ تایبه‌ت باسكراوه‌)  وه‌ پێغه‌مبه‌ری نێردراوی خوای گه‌وره‌ بووه‌."
  19,55,"[ وَكَانَ يَأْمُرُ أَهْلَهُ بِالصَّلَاةِ وَالزَّكَاةِ ] وه‌ فه‌رمانی ئه‌كرد به‌ كه‌سوكاری یان به‌ خه‌ڵكی به‌تێكڕا به‌ نوێژ كردن و به‌ زه‌كات دان  وه‌ له‌ لای خوای گه‌وره‌ش كه‌سێك بووه‌ كه‌ خوای گه‌وره‌ لێی ڕازی بووه‌."
  19,56,"[ وَاذْكُرْ فِي الْكِتَابِ إِدْرِيسَ ] ئه‌ی محمد - صلى الله عليه وسلم - له‌و قورئانه‌ پیرۆزه‌ باسی ئیدریس پێغه‌مبه‌ریش - صلى الله عليه وسلم - بۆ خه‌ڵكی بكه‌  به‌ دڵنیایى ئه‌ویش زۆر ڕاستگۆ بووه‌ وه‌ پێغه‌مبه‌ری خوای گه‌وره‌ بووه‌."
  19,57," وه‌ به‌رزمان كردۆته‌وه‌و پله‌و پایه‌ی به‌رزمان پێ به‌خشیووه‌ كه‌ له‌ ئاسمانی چواره‌مه‌، یاخود پێغه‌مبه‌رایه‌تیمان پێ به‌خشیووه‌، یاخود له‌به‌هه‌شتدا پله‌مان به‌رز كردۆته‌وه‌."
  19,58,"[ أُولَئِكَ الَّذِينَ أَنْعَمَ اللَّهُ عَلَيْهِمْ ] ئه‌مانه‌ كه‌سانێكن كه‌ خوای گه‌وره‌ نیعمه‌تی خۆی ڕژاندووه‌ به‌سه‌ریاندا [ مِنَ النَّبِيِّينَ مِنْ ذُرِّيَّةِ آدَمَ ] له‌ پێغه‌مبه‌ران له‌ نه‌وه‌ی ئاده‌م [ وَمِمَّنْ حَمَلْنَا مَعَ نُوحٍ ] وه‌ له‌و كه‌سانه‌ی كه‌ له‌گه‌ڵ نوحدا - صلى الله عليه وسلم - له‌ناو كه‌شتییه‌كه‌ هه‌ڵمانگرتن [ وَمِنْ ذُرِّيَّةِ إِبْرَاهِيمَ ] وه‌ له‌ نه‌وه‌ی ئیبراهیم - صلى الله عليه وسلم - [ وَإِسْرَائِيلَ ] وه‌ ئیسرائیل، واته‌: یه‌عقوب پێغه‌مبه‌ر - صلى الله عليه وسلم - [ وَمِمَّنْ هَدَيْنَا وَاجْتَبَيْنَا ] وه‌ له‌و كه‌سانه‌ی كه‌ هیدایه‌تمان داون بۆ ئیسلام وه‌ هه‌ڵمان بژاردوون و كردوومانن به‌ پێغه‌مبه‌ر  ئه‌مانه‌ كاتێك ئایه‌ته‌كانی خوای گه‌وره‌یان به‌سه‌ردا ئه‌خوێندرێته‌وه‌ ئه‌چنه‌ كڕنوش به‌ گریانه‌وه‌و كڕنوش بۆ خوای گه‌وره‌ ئه‌به‌ن و له‌ ترسی خوای گه‌وره‌دا ده‌ست به‌ گریان ئه‌كه‌ن."
  19,59,"[ فَخَلَفَ مِنْ بَعْدِهِمْ خَلْفٌ ] له‌ پاش ئه‌م پێغه‌مبه‌ره‌ باشانه‌ و شوێن كه‌وتووه‌ چاكه‌كانیان كه‌سانێكی خراپ هاتن [ أَضَاعُوا الصَّلَاةَ ] كه‌ نوێژه‌كانیان فه‌وتاندو ئه‌نجامیان نه‌دا، یان له‌سه‌ر شێوازی خۆی نه‌یان ئه‌كرد، یان له‌ كاتى خۆیدا نه‌یانده‌كرد [ وَاتَّبَعُوا الشَّهَوَاتِ ] وه‌ شوێنی هه‌واو ئاره‌زوو شته‌ حه‌رامه‌كان كه‌وتن  ئه‌وانه‌ تووشی شه‌ڕو خراپه‌و زه‌ره‌رمه‌ندی ئه‌بن."
  19,60,"[ إِلَّا مَنْ تَابَ وَآمَنَ وَعَمِلَ صَالِحًا ] ته‌نها كه‌سانێك نه‌بێت كه‌ ته‌وبه‌ بكه‌ن و ئیمان بێنن و كرده‌وه‌ی چاك بكه‌ن، (كرده‌وه‌ى چاك ئه‌وه‌یه‌ بۆ خوا بێت و بۆ ریا نه‌بێت، وه‌ له‌سه‌ر سوننه‌ت بێت و بیدعه‌ نه‌بێت) [ فَأُولَئِكَ يَدْخُلُونَ الْجَنَّةَ ] ئا ئه‌مانه‌ ئه‌چنه‌ به‌هه‌شته‌وه‌، چونكه‌ ته‌وبه‌ كردن تاوانى پێشتر ناهێڵێت و ده‌یسڕێته‌وه‌  وه‌ هیچ زوڵم و سته‌میان لێ ناكرێ و پاداشتیان لێ كه‌م ناكرێته‌وه‌."
  19,61,"[ جَنَّاتِ عَدْنٍ الَّتِي وَعَدَ الرَّحْمَنُ عِبَادَهُ بِالْغَيْبِ ] خوای گه‌وره‌ ئه‌یانخاته‌ به‌هه‌شتانێكه‌وه‌ كه‌ شوێنی مانه‌وه‌ی هه‌میشه‌ییه‌ كه‌ خوای گه‌وره‌ به‌ڵێنی به‌ به‌نده‌كانی داوه‌ كه‌ به‌ غه‌یب ئیمانیان پێی هێناوه‌و نه‌یانبینیوه‌  به‌ دڵنیایى هه‌ر به‌ڵێنێكیش كه‌ خوای گه‌وره‌ بیدات دێته‌جێ."
  19,62,"[ لَا يَسْمَعُونَ فِيهَا لَغْوًا إِلَّا سَلَامًا ] له‌ناو به‌هه‌شتیشدا هیچ قسه‌یه‌كی پڕوپووچ و بێ مانا نابیستن ته‌نها سه‌لام نه‌بێ كه‌ سه‌لام له‌ یه‌كتری ئه‌كه‌ن، یاخود فریشته‌كان سه‌لامیان لێ ئه‌كه‌ن  وه‌ هه‌موو به‌یانیان و ئێوارانێك ڕزق و ڕۆزی خۆیان پێ ئه‌درێ (هه‌رچه‌نده‌ له‌به‌هه‌شتدا شه‌و ورۆژ نیه‌و ژیانێكى هه‌میشه‌ییه‌و نورو روناكیه‌و هه‌موو كات له‌ نازو نیعمه‌تدان)."
  19,63," ئا ئه‌مه‌ ئه‌و به‌هه‌شته‌یه‌ كه‌ به‌نده‌كانی خۆمان ئه‌كه‌ین به‌ میراتگری و ئه‌یانخه‌ینه‌ ناوى ئه‌وانه‌ی ته‌قوای خوای گه‌وره‌ بكه‌ن و له‌ خوای گه‌وره‌ بترسێن."
  19,64,"[ وَمَا نَتَنَزَّلُ إِلَّا بِأَمْرِ رَبِّكَ ] پێغه‌مبه‌رى خوا - صلى الله عليه وسلم - به‌ جبریلى فه‌رموو: چى رێگریت ده‌كات و بۆ له‌وه‌ زیاتر سه‌ردانمان ناكه‌یت؟ خواى گه‌وره‌ ئه‌م ئایه‌ته‌ى دابه‌زاند: جبریل ئه‌فه‌رمووێ: وه‌ ئێمه‌ به‌فه‌رمانی په‌روه‌ردگار نه‌بێ ناتوانین دابه‌زین و بێین بۆ لای تۆ ئه‌ی محمد - صلى الله عليه وسلم - [ لَهُ مَا بَيْنَ أَيْدِينَا وَمَا خَلْفَنَا وَمَا بَيْنَ ذَلِكَ ] وه‌ له‌ پێش و پاشی خۆمانه‌وه‌ وه‌ له‌و نێوانه‌یشه‌وه‌ به‌ ئه‌مری خوای گه‌وره‌ دائه‌به‌زین، یاخود بۆ كارى دونیاو قیامه‌ت و نێوانیشیان به‌ فه‌رمانى خواى گه‌وره‌ داده‌به‌زین  پێغه‌مبه‌رى خوا - صلى الله عليه وسلم - فه‌رمووى: (ئه‌وه‌ى خواى گه‌وره‌ حه‌ڵاڵى كردووه‌ ئه‌وه‌ حه‌ڵاڵه‌، وه‌ ئه‌وه‌ى خواى گه‌وره‌ حه‌رامى كردووه‌ ئه‌وه‌ حه‌رامه‌، وه‌ ئه‌وه‌یشى لێى بێده‌نگ بووه‌ ئه‌وه‌ لێى بوراوه‌و له‌ خواى گه‌وره‌ى وه‌ربگرن، چونكه‌ خواى گه‌وره‌ هیچ شتێك له‌ بیر ناكات) پاشان ئه‌م ئایه‌ته‌ى خوێنده‌وه‌: كه‌ جبریل ئه‌فه‌رمووێ: كاتێك كه‌ ئێمه‌ دوابكه‌وین یان وه‌حی له‌ تۆ دوابكه‌وێ ئه‌وه‌ نه‌بێ كه‌ خوای گه‌وره‌ تۆی له‌بیر كردبێ، نه‌خێر خوای گه‌وره‌ هیچ شتێك له‌بیر ناكات."
  19,65,"[ رَبُّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا ] خوای گه‌وره‌ په‌روه‌ردگارو هه‌ڵسوڕێنه‌رو خاوه‌نی ئاسمانه‌كان و زه‌وی و ئه‌وه‌ی نێوانیانه‌ [ فَاعْبُدْهُ وَاصْطَبِرْ لِعِبَادَتِهِ ] تۆ عیباده‌تی ئه‌و خوایه‌ بكه‌، وه‌ ئارامگرو دامه‌زراو به‌ له‌سه‌ر عیباده‌تی خوا  ئایا ئه‌زانی خوای گه‌وره‌ هاوشێوه‌یه‌كی هه‌بێ و كه‌سێك هه‌بێ وه‌كو خوای گه‌وره‌ بێت؟، واته‌: خوای گه‌وره‌ بێ شه‌ریكه‌، یان كه‌س نیه‌ ناوى الرحمن بێت جگه‌ له‌ خواى گه‌وره‌."
  19,66," وه‌ كافرو بێباوه‌ڕان ئه‌ڵێن ئایا ئه‌گه‌ر ئێمه‌ مردین دووباره‌ زیندوو ئه‌كرێینه‌وه‌و له‌ناو گۆڕه‌كان ده‌رئه‌كرێین."
  19,67," خوای گه‌وره‌ ئه‌فه‌رمووێ: ئایا مرۆڤ ئه‌وه‌ی له‌یادچووه‌و بیری ئه‌وه‌ی نیه‌ كه‌ ئێمه‌ دروستمان كردووه‌ له‌ پێشترا كه‌ هیچ شتێك نه‌بووه‌ له‌ عه‌ده‌مه‌وه‌ دروستمان كردووه‌."
  19,68,"[ فَوَرَبِّكَ لَنَحْشُرَنَّهُمْ وَالشَّيَاطِينَ ] خوای گه‌وره‌ سوێند ئه‌خوات سوێند بێت به‌ په‌روه‌ردگارت ئه‌ی محمد - صلى الله عليه وسلم - هه‌موویان له‌ گۆڕه‌كانیان ده‌رئه‌كه‌ین و زیندوویان ئه‌كه‌ینه‌وه‌ وه‌ ئه‌و شه‌یتانانه‌ش كه‌ ئه‌مانیان له‌ خشته‌ بردووه‌  پاشان ئاماده‌یان ده‌كه‌ین له‌ ده‌وروبه‌ری دۆزه‌خ له‌سه‌ر چۆكیان ئه‌بێ له‌و دیمه‌نه‌ سه‌ختانه‌دا ڕابوه‌ستن."
  19,69," پاشان له‌ هه‌ر كۆمه‌ڵ و گروپ و دینێك ئه‌وانه‌یان كه‌ زۆر سه‌ركه‌ش بوونه‌و سه‌ركرده‌یان بوونه‌ ئه‌وان جیا ئه‌كه‌ینه‌وه‌و سزایان سه‌ختتر ئه‌بێ."
  19,70," پاشان ئێمه‌ خۆمان زاناترین به‌وانه‌ی كه‌ كێ زیاتر شایه‌نی ئه‌وه‌یه‌ كه‌ بچێته‌ ناو ئاگری دۆزه‌خه‌وه‌ بسووتێ."
  19,71,"[ وَإِنْ مِنْكُمْ إِلَّا وَارِدُهَا ] وه‌ هیچ كه‌سێك له‌ ئێوه‌ نیه‌ ئیلا ئه‌بێ به‌سه‌ر پردی (سيراط) دا تێپه‌ڕێ و بچێته‌ سه‌ر ئاگری دۆزه‌خ  ئه‌مه‌ كارێكه‌و بڕاوه‌ته‌وه‌و كۆتایی هاتووه‌و خوای گه‌وره‌ بڕیاری له‌سه‌ر داوه‌."
  19,72,"[ ثُمَّ نُنَجِّي الَّذِينَ اتَّقَوْا ] پاشان ئه‌وانه‌ی ته‌قوای خوای گه‌وره‌یان كردووه‌و له‌ خوای گه‌وره‌ ترساون و خۆیان له‌ تاوان پاراستووه‌ ئه‌وانه‌ ڕزگار ئه‌كه‌ین و له‌سه‌ر پرده‌كه‌ ده‌یانپه‌ڕێنینه‌وه‌  وه‌ ئه‌وانه‌یشی كه‌ سته‌مكار بوونه‌و سته‌میان له‌ خۆیان كردووه‌ به‌ كوفر كردن و هاوبه‌شبڕیاردان له‌سه‌ر چۆكیان فڕێ ئه‌درێنه‌ دۆزه‌خه‌وه‌."
  19,73,"[ وَإِذَا تُتْلَى عَلَيْهِمْ آيَاتُنَا بَيِّنَاتٍ ] وه‌ كاتێك كه‌ ئایه‌ته‌ ڕوون و ئاشكراكانی ئێمه‌یان به‌سه‌ردا بخوێندرێته‌وه‌ [ قَالَ الَّذِينَ كَفَرُوا لِلَّذِينَ آمَنُوا أَيُّ الْفَرِيقَيْنِ خَيْرٌ مَقَامًا ] كافران به‌ باوه‌ڕداران ئه‌ڵێن: ئایا ئه‌م دوو كۆمه‌ڵه‌: موسڵمانان و كافران كامیان پله‌و پایه‌یان له‌ناو خه‌ڵكدا باشتره‌و ناودارترن و پشتیوانیان زۆرتره‌  وه‌ كامیان نادی و شوێنی كۆبوونه‌وه‌یان قه‌ڵه‌باڵغتره‌و خه‌ڵكیان زیاتر به‌دواوه‌یه‌."
  19,74,"[ وَكَمْ أَهْلَكْنَا قَبْلَهُمْ مِنْ قَرْنٍ ] خوای گه‌وره‌ ئه‌فه‌رمووێ: له‌ پێش ئه‌مانه‌ چه‌نده‌ها ئوممه‌تان و كۆمه‌ڵانی ترمان له‌ناو بردووه‌  كه‌ ئه‌و ئوممه‌تانه‌ی تر شتومه‌كی ماڵ و سه‌روه‌ت و سامانیان له‌مان جوانترو زیاترو بینراوتریش بوون."
  19,75,"[ قُلْ مَنْ كَانَ فِي الضَّلَالَةِ ] ئه‌ی محمد - صلى الله عليه وسلم - پێیان بڵێ: هه‌ر كه‌سێك له‌ گومڕاییدا بێت [ فَلْيَمْدُدْ لَهُ الرَّحْمَنُ مَدًّا ] ئه‌وا خوای گه‌وره‌ بۆی درێژ ئه‌كاته‌وه‌ له‌ گومڕایی خۆی بمێنێته‌وه‌ [ حَتَّى إِذَا رَأَوْا مَا يُوعَدُونَ ] به‌ڵام تا كاتێك ئه‌زانن ئه‌وه‌ی كه‌ هه‌ڕه‌شه‌یان لێكراوه‌ له‌ ڕۆژی قیامه‌ت به‌چاوی خۆیان ئه‌یبینن [ إِمَّا الْعَذَابَ ] یان ئه‌وه‌تا سزایه‌ له‌ دونیا خوای گه‌وره‌ سزایان ئه‌دات یان سزای قیامه‌ت [ وَإِمَّا السَّاعَةَ ] یان له‌ناكاو قیامه‌ت دێت [ فَسَيَعْلَمُونَ مَنْ هُوَ شَرٌّ مَكَانًا ] له‌و كاته‌دا له‌ ڕۆژی قیامه‌ت ئه‌زانن كێ پله‌و پایه‌ی خراپتره‌  وه‌ كێ سه‌ربازانی لاوازتره‌ كه‌ له‌ دونیا ئه‌وان شانازیان به‌و شتانه‌ ئه‌كرد به‌سه‌ر ئیمانداران."
  19,76,"[ وَيَزِيدُ اللَّهُ الَّذِينَ اهْتَدَوْا هُدًى ] وه‌ خوای گه‌وره‌ ئه‌وانه‌ی كه‌ ئه‌هلی هیدایه‌ت بوونه‌ زیاتر هیدایه‌تیان ئه‌دات [ وَالْبَاقِيَاتُ الصَّالِحَاتُ خَيْرٌ عِنْدَ رَبِّكَ ثَوَابًا ] وه‌ ئه‌و شتانه‌ی كه‌ ئه‌مێننه‌وه‌ له‌ چاكه‌كان له‌ زیكر كردن (سبحان الله والحمد لله ولا إله إلا الله والله أكبر) یاخود نوێژه‌ جه‌ماعه‌ته‌كان، یان هه‌ر كرده‌وه‌یه‌كی چاك ئه‌وانه‌ باشتره‌ كه‌ مرۆڤـ بیكات و لای خوای گه‌وره‌ پاداشتی باشتره‌  وه‌ باشترین سه‌ره‌نجامه‌ كه‌ ئه‌گه‌ڕێنه‌وه‌ بۆی."
  19,77,"{گومانی بێ‌ بنەمای كافران}  (خه‌ببابی كوڕی ئه‌ڕه‌ت) قه‌رزی له‌سه‌ر (عاصی كوڕی وائیل) بوو كه‌ چوو قه‌رزه‌كه‌ی نه‌دایه‌وه‌ وتی: تا كوفر به‌ محمد - صلى الله عليه وسلم - نه‌كه‌ی ناتده‌مه‌وه‌، ئه‌میش وتی: سوێند به‌ خواى گه‌وره‌ كوفری پێ ناكه‌م تا نه‌مریت و زیندوو نه‌بیته‌وه‌، ئه‌ویش وتی: ئه‌گه‌ر بمرم و زیندوو ببمه‌وه‌ ئه‌وه‌ ماڵ و منداڵم یه‌كجار زۆره‌و له‌گه‌ڵمدا دێت و فریام ئه‌كه‌وێ و له‌وێ ده‌تده‌مه‌وه‌، خواى گه‌وره‌ ئه‌م ئایه‌ته‌ى دابه‌زاند: ئایا هه‌واڵم پێ ناده‌ی ده‌رباره‌ی ئه‌و كه‌سه‌ی كه‌ كوفری كرد به‌ ئایه‌ته‌كانی ئێمه‌ وه‌ وتی: ئه‌گه‌ر له‌ قیامه‌تدا زیندوو بوونه‌وه‌ هه‌بێ ئه‌وا من ماڵ و منداڵم زۆره‌و له‌وێ فریام ئه‌كه‌وێ."
  19,78," ئایا ئه‌مه‌ غه‌یب و قیامه‌تی بینیوه‌؟ یان به‌ڵێنی له‌ خوای گه‌وره‌ وه‌رگرتووه‌ كه‌ ماڵ و منداڵه‌كه‌ی له‌وێ فریای بكه‌وێ."
  19,79,"[ كَلَّا سَنَكْتُبُ مَا يَقُولُ ] نه‌خێر شتی وا نیه‌و ئه‌و قسانه‌ی هه‌مووی ئه‌نووسین و ئه‌یپارێزین  وه‌ له‌ ڕۆژی قیامه‌تیشدا سزای بۆ زیاد ئه‌كه‌ین."
  19,80,"[ وَنَرِثُهُ مَا يَقُولُ ] وه‌ ئه‌یمرێنین وه‌ ماڵ و منداڵ له‌گه‌ڵ خۆیدا نابات و به‌ جێى دێلێت و كه‌سانێك ئه‌بن به‌ میراتگری  وه‌ ئه‌و به‌ ته‌نها خۆی دێت و به‌ ته‌نها زیندوو ئه‌كرێته‌وه‌و كه‌سی له‌گه‌ڵدا نابێت."
  19,81," ئه‌مانه‌ جگه‌ له‌ خواى گه‌وره‌ كۆمه‌ڵێك خوایان بۆ خۆیان بڕیار دابوو بۆ ئه‌وه‌ی ئه‌و خوایانه‌ سه‌ریان بخه‌ن و تكایان بۆ بكه‌ن له‌ قیامه‌ت."
  19,82,"[ كَلَّا ] نه‌خێر شتی وا نیه‌و ناتوانن شه‌فاعه‌تیان بۆ بكه‌ن [ سَيَكْفُرُونَ بِعِبَادَتِهِمْ ] ئه‌وانه‌ له‌ ڕۆژی قیامه‌ت كوفر ئه‌كه‌ن به‌ عیباده‌تی ئه‌وان و ئه‌ڵێن: بۆ ئێمه‌تان كرده‌ شه‌ریك بۆ خوا  وه‌ ئه‌بن به‌ دوژمنیان و دژیان ڕائه‌وه‌ستن."
  19,83,"{ سزاى كافران}  ئایا نابینی ئێمه‌ شه‌یتانه‌كان ئه‌نێرین بۆ سه‌ر كافران و زاڵیان ئه‌كه‌ین به‌سه‌ریانداو شه‌یتانه‌كانن كه‌ كافران ئه‌جوولێنن بۆ تاوان و سه‌رپێچی و له‌ خشته‌یان ده‌بن و فریویان ده‌ده‌ن."
  19,84,"[ فَلَا تَعْجَلْ عَلَيْهِمْ ] ئه‌ی محمد - صلى الله عليه وسلم - په‌له‌ مه‌كه‌ له‌سزادانیان  ئێمه‌ ڕۆژگارو مانگ و ساڵیان بۆ ئه‌ژمێرین تا ئه‌گاته‌ كۆتایی ته‌مه‌نیان."
  19,85," له‌ ڕۆژی قیامه‌ت ئه‌وه‌ی كه‌ ته‌قوای خوای گه‌وره‌ی كردووه‌ كۆیان ئه‌كه‌ینه‌وه‌و به‌ره‌و لای خوای گه‌وره‌ دێن و بۆ به‌هه‌شته‌كه‌ی خوا به‌ڕێ ئه‌خرێن."
  19,86," وه‌ خراپه‌كارانیش به‌ره‌و دۆزه‌خ به‌ڕێ ئه‌كرێن به‌ تینووێتی."
  19,87,"[ لَا يَمْلِكُونَ الشَّفَاعَةَ ] كه‌س نیه‌ شه‌فاعه‌تیان بۆ بكات  ئیلا ئه‌وه‌ی كه‌ له‌ لای خوای گه‌وره‌ به‌ڵێنی هه‌بێ ئه‌وانه‌ ئه‌توانن شه‌فاعه‌ت بكه‌ن، واته‌: ئه‌هلی ته‌وحیدو یه‌كخواپه‌رستان كه‌ شه‌ریكیان بۆ خوا دانه‌ناوه‌و خوا لێیان ڕازیه‌ له‌پاش رێگه‌ پێدانى خواى گه‌وره‌ ئه‌توانن شه‌فاعه‌ت بكه‌ن."
  19,88,"{ كافران منداڵ بۆ خوا بڕیار دەدەن!}  وه‌ كافران وتیان: خوای گه‌وره‌ كوڕی بۆ خۆی بڕیار داوه‌، كه‌ جووله‌كه‌ ئه‌یانوت: عوزێر كوڕی خوایه‌و، گاوره‌كان ئه‌یانوت: عیسا كوڕی خوایه‌و، عه‌ره‌به‌كانیش ئه‌یانوت: مه‌لائیكه‌ت كچی خوایه‌."
  19,89," به‌ڕاستی ئێوه‌ قسه‌یه‌كی یه‌كجار گه‌وره‌و ناڕێكتان كرد."
  19,90,"[ تَكَادُ السَّمَاوَاتُ يَتَفَطَّرْنَ مِنْهُ ] نزیكه‌ ئاسمانه‌كان له‌ت بێت و له‌ناوبچێت له‌و قسه‌یه‌ كه‌ ئه‌یكه‌ن بۆ خوای گه‌وره‌ [ وَتَنْشَقُّ الْأَرْضُ ] وه‌ نزیكه‌ زه‌ویش به‌هه‌مان شێوه‌ له‌ت بێت و شه‌ق بێت  وه‌ نزیكه‌ شاخه‌كان بڕوخێن به‌سه‌ر یه‌كتریدا."
  19,91," كاتێك كه‌ بانگه‌شه‌ی كوڕ ئه‌كه‌ن بۆ خوای گه‌وره‌، خوای گه‌وره‌ ئه‌وه‌نده‌ له‌و قسه‌یه‌ تووڕه‌یه‌."
  19,92," گونجاو نیه‌ بۆ خوا وه‌ خوای گه‌وره‌ پێویستی به‌ منداڵ نیه‌."
  19,93," چونكه‌ هه‌رچی له‌ ئاسمانه‌كان و زه‌وی هه‌یه‌ هه‌موویان عه‌بدی خوای گه‌وره‌ن و دان به‌ به‌ندایه‌تیدا ئه‌نێن بۆ خوای گه‌وره‌ ئیتر چۆن ئه‌بێ ئه‌م به‌ندانه‌ ببن به‌ كوڕی خوا."
  19,94,"[ لَقَدْ أَحْصَاهُمْ ] وه‌ خوای گه‌وره‌ سه‌رژمێری كردوون  وه‌ ژماردوونی و هیچیان له‌ خوای گه‌وره‌ ناشاردرێنه‌وه‌و كه‌سیان دوا ناكه‌ون و هه‌موویان له‌به‌ر ده‌ستی خواى گه‌وره‌دا ئاماده‌ ده‌بن."
  19,95," وه‌ هه‌موویان له‌ ڕۆژی قیامه‌تدا به‌ تاك تاك دێن [ إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ ] به‌ دڵنیایى ئه‌وانه‌ی كه‌ ئیمانیان هێناوه‌و كرده‌وه‌ی چاكیان كردووه‌ (كرده‌وه‌ى چاك ئه‌وه‌یه‌ نیه‌تت بۆ خوا بێت و بۆ ریات نه‌بێت، وه‌ له‌سه‌ر سوننه‌ت بێت و بیدعه‌ نه‌بێت)."
  19,96," خوای گه‌وره‌ خۆشی ئه‌وێن پاشان ئه‌هلی ئاسمان خۆشی ئه‌وێن پاشان خه‌ڵكی زه‌ویش خۆشی ئه‌وێن و له‌ لای خه‌ڵكی خۆشه‌ویستیان ئه‌كات."
  19,97,"[ فَإِنَّمَا يَسَّرْنَاهُ بِلِسَانِكَ ] ئه‌ی محمد - صلى الله عليه وسلم - ئه‌م قورئانه‌مان له‌سه‌ر زمانی تۆ سووك كردووه‌و به‌ زمانی تۆ دامان به‌زاندووه‌ به‌ عه‌ره‌بی [ لِتُبَشِّرَ بِهِ الْمُتَّقِينَ ] تا موژده‌ بده‌ی به‌و كه‌سانه‌ی كه‌ ته‌قوای خوای گه‌وره‌ ئه‌كه‌ن به‌ به‌هه‌شت  وه‌ ئاگاداری كه‌سانێكیش بكه‌ی كه‌ زۆر موناقه‌شه‌و ده‌مه‌قاڵێ و مشتومڕ ئه‌كه‌ن، یان له‌ حه‌ق لایانداوه‌ بۆ باتڵ."
  19,98,"[ وَكَمْ أَهْلَكْنَا قَبْلَهُمْ مِنْ قَرْنٍ ] له‌ پێش ئه‌ماندا چه‌نده‌ها ئوممه‌تان و كۆمه‌ڵانی ترمان له‌ناو برد [ هَلْ تُحِسُّ مِنْهُمْ مِنْ أَحَدٍ ] ئایا هه‌ست ئه‌كه‌ی یه‌كێك له‌وان مابێ  یاخود گوێت له‌ ده‌نگی نهێنی ئه‌وانه‌ ده‌بێت؟ نه‌خێر هه‌موویان له‌ناوچوون و خوای گه‌وره‌ له‌ناوی بردن، والله أعلم."
