tafsir[227]{c,v,t}:
  26,1,"سووره‌تی (شوعراء) (واته‌: شاعیران) سووره‌تێكى مه‌ككی یه‌ ته‌نها ئایه‌تى (١٩٧) و (٢٢٤) تا كۆتایى نه‌بێت مه‌ده‌نى یه‌ (٢٢٧) ئایه‌ته‌ بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ  له‌ سه‌ره‌تای سووره‌تی (به‌قه‌ره‌)دا باسی ئه‌م پیتانه‌مان كرد كه‌ له‌ سه‌ره‌تای هه‌ندێك له‌ سووره‌ته‌كاندا هاتوون."
  26,2," ئه‌مه‌ ئایه‌ته‌كانی ئه‌م قورئانه‌ پیرۆزه‌یه‌ كه‌ روون و ئاشكرایه‌."
  26,3," له‌وانه‌یه‌ ئه‌ی محمد - صلی الله علیه وسلم - نه‌فسی خۆت به‌هیلاك بده‌ی له‌ غه‌م و په‌ژاره‌دا كه‌ كافران باوه‌ڕ ناهێنن."
  26,4,"[ إِنْ نَشَأْ نُنَزِّلْ عَلَيْهِمْ مِنَ السَّمَاءِ آيَةً ] ئه‌گه‌ر ئێمه‌ ویستمان لێ بێ له‌ ئاسمانه‌وه‌ موعجیزه‌یه‌كیان بۆ دائه‌به‌زێنین ناچاریان بكات كه‌ ئیمان بێنن  به‌رده‌وام ئه‌و كاته‌ گه‌ردنیان ملكه‌چ ئه‌بێت بۆی، به‌ڵام نابێت كه‌س به‌ زۆر موسڵمان بكرێت به‌ڵكو به‌ ویستى خۆیانه‌."
  26,5," وه‌ هیچ زیكرو یاد كردنه‌وه‌یه‌كیان له‌لایه‌ن خوای گه‌وره‌وه‌ له‌ قورئانی پیرۆزدا بۆ نایات كه‌ تازه‌ بێت ئیلا ئه‌وان پشتی تێ ئه‌كه‌ن وه‌ باوه‌ڕی پێ ناهێنن."
  26,6,"[ فَقَدْ كَذَّبُوا ] به‌ دڵنیایی ئه‌وان قورئانیان به‌درۆ زانی  وه‌ له‌ داهاتوودا هه‌واڵ و سه‌ره‌نجامى ئه‌م گاڵته‌ پێ كردنه‌یان پێ ئه‌گات، واته‌: خوای گه‌وره‌ سزایان ئه‌دات."
  26,7," ئایا نابینن له‌سه‌ر زه‌ویدا ئێمه‌ چه‌ندێك ڕووه‌ك و دانه‌وێڵه‌مان ڕواندووه‌ له‌ هه‌موو جۆرێك جووتێكی به‌سوودو جوان."
  26,8,"[ إِنَّ فِي ذَلِكَ لَآيَةً ] به‌ دڵنیایى ئه‌مانه‌ هه‌مووی نیشانه‌و به‌ڵگه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌  به‌ڵام زۆربه‌ی زۆریان ئیمان ناهێنن."
  26,9," وه‌ به‌ دڵنیایى په‌روه‌ردگارت زۆر باڵاده‌ست و به‌ به‌زه‌ییه‌."
  26,10,"{گفتوگۆی نێوان موسا پێغەمبەر - صلی الله علیه وسلم - و خوای گەورە}  وه‌ په‌روه‌ردگارت بانگی له‌ موسا - صلی الله علیه وسلم - كرد بڕۆ بۆ لای ئه‌و قه‌ومه‌ سته‌مكاره‌ كه‌ قه‌ومی فیرعه‌ونه‌ (ئه‌میش به‌ڵگه‌یه‌ له‌سه‌ر ئه‌وه‌ى كه‌ خواى گه‌وره‌ قسه‌ ده‌كات و سیفه‌تى قسه‌ كردنى هه‌یه‌)."
  26,11," قه‌ومی فیرعه‌ونه‌ كه‌ ته‌قوای خوای گه‌وره‌ ناكه‌ن، پێیان بڵێ: ئایا بۆ له‌ سزای خوای گه‌وره‌ ناترسێن."
  26,12," موسا - صلی الله علیه وسلم - فه‌رمووی: ئه‌ی په‌روه‌ردگار من له‌وه‌ ئه‌ترسێم كه‌ به‌ درۆم بزانن."
  26,13,"[ وَيَضِيقُ صَدْرِي ] وه‌ دڵم ته‌نگ بێ [ وَلَا يَنْطَلِقُ لِسَانِي ] وه‌ زمانم نه‌كرێته‌وه‌ بۆ قسه‌ كردن له‌به‌ر ئه‌وه‌ى گیریه‌ك له‌ زمانیدا هه‌بوو، (موسا - صلی الله علیه وسلم - كه‌ منداڵ بوو ده‌ستى بۆ ریشى فیرعه‌ون برد، ئه‌ویش توڕه‌ بوو وتى سوكایه‌تى پێكردووم ده‌بێت بیكوژم، ئاسیاى خێزانى وتى ئه‌مه‌ منداڵه‌و نافامێت تاقیبكه‌وه‌و پشكۆیه‌ك ئاگرو هه‌ندێك خورما دابنێ ئه‌گه‌ر ده‌ستى برد بۆ خورماكه‌ ئه‌وا بیكوژه‌، وه‌ ئه‌گه‌ر ده‌ستى برد بۆ پشكۆ ئاگره‌كه‌ ئه‌وا دیاره‌ نافامێت و مه‌یكوژه‌، موسا - صلی الله علیه وسلم - ده‌ستى برد بۆ پشكۆ ئاگره‌كه‌و بردى بۆ ده‌مى و رزگارى بوو له‌ كوشتن، جا له‌و كاته‌وه‌ گیرییه‌ك له‌ زمانیدا هه‌بوو)  په‌یام بنێره‌ بۆ هارونی برام و بیكه‌ به‌ پێغه‌مبه‌ر تا له‌گه‌ڵمدا بێت وه‌كو یارمه‌تیده‌رێك (باشترین چاكه‌یه‌ك كه‌ برا له‌گه‌ڵ براكه‌ى كردبێتى ئه‌مه‌یه‌ كه‌ موسى له‌گه‌ڵ هارونى براى كردى كه‌ داواى له‌ خواى گه‌وره‌ كرد بیكات به‌ پێغه‌مبه‌ر)."
  26,14,"[ وَلَهُمْ عَلَيَّ ذَنْبٌ ] وه‌ ئه‌وان تاوانێكیان له‌سه‌ر منه‌ كه‌ كاتی خۆی یه‌كێكم لێ كوشتن له‌ (قيبطي)هكان له‌ هۆزى فیرعه‌ون كه‌ نه‌مزانی و مه‌به‌ستم كوشتنى نه‌بوو  وه‌ له‌وه‌ش ئه‌ترسێم كه‌ ئه‌وان بمكوژن و تۆڵه‌ی خۆیان بكه‌نه‌وه‌، كه‌ ئه‌م ترسه‌ ترسێكی سروشتیه‌و ئاساییه‌و دروسته‌."
  26,15,"[ قَالَ كَلَّا ] خوای گه‌وره‌ فه‌رمووی: نه‌خێر بڕۆ مه‌ترسێ ناتكوژن [ فَاذْهَبَا بِآيَاتِنَا ] خوای گه‌وره‌ وه‌ڵامی دایه‌وه‌و هارونی برای كرد به‌ پێغه‌مبه‌رو فه‌رمووى هه‌ردووكتان به‌یه‌كه‌وه‌ بڕۆن به‌ موعجیزه‌كانم پشتیوانیتان ده‌كه‌م مه‌ترسێن  وه‌ منیش له‌گه‌ڵتاندام ئه‌بیستم، به‌ بیستن و بینین و تواناو ده‌سه‌ڵات و پاراستن و سه‌رخستن له‌گه‌ڵتاندام."
  26,16,"[ فَأْتِيَا فِرْعَوْنَ ] بڕۆن بۆ لای فیرعه‌ون  بڵێن ئێمه‌ نێردراو و پێغه‌مبه‌ری په‌روه‌ردگاری هه‌موو جیهانین."
  26,17," به‌ فیرعه‌ون بڵێن كه‌ به‌نی ئیسرائیلى كردووه‌ به‌ كۆیله‌ با ئازادیان بكات و له‌گه‌ڵ ئێمه‌دا بیاننێره‌."
  26,18,"{گفتوگۆی نێوان موسا پێغەمبەر - صلی الله علیه وسلم - و فیرعەون} [ قَالَ أَلَمْ نُرَبِّكَ فِينَا وَلِيدًا ] كاتێك كه‌ چوون بۆ لای فیرعه‌ون و به‌ نه‌رم ونیانی قسه‌یان له‌گه‌ڵدا كردو پێیان وت، فیرعه‌ون وتی: ئه‌ی موسا ئایا به‌ منداڵی ئێمه‌ به‌خێومان نه‌كردیت و له‌ ماڵى ئێمه‌دا گه‌وره‌ نه‌بوویت له‌ كاتێكدا منداڵنی ترمان ئه‌كوشت تۆمان نه‌كوشت؟  وه‌ چه‌نده‌ها ساڵ له‌ لای ئێمه‌ مایته‌وه‌ ئێستا خۆت كردووه‌ به‌ پێغه‌مبه‌ر له‌ ئێمه‌!"
  26,19,"[ وَفَعَلْتَ فَعْلَتَكَ الَّتِي فَعَلْتَ ] وه‌ ئه‌و كرده‌وه‌ خراپه‌یشت كرد كه‌ كوشتنی (قيبطي)هكه‌ بوو  وه‌ تۆ كه‌سێكی كه‌ نكوڵى و كوفرانه‌ی ئه‌و نیعمه‌تانه‌ى ئێمه‌ ئه‌كه‌ی به‌سه‌رته‌وه‌."
  26,20," موسا - صلی الله علیه وسلم - فه‌رمووی: به‌ڵێ من ئه‌و پیاوه‌ (قيبطي)هم كوشت به‌ڵام من ئه‌و كاته‌ كه‌سێكی نه‌زان و وێڵ بووم له‌به‌ر ئه‌وه‌ی هێشتا وه‌حیم بۆ نه‌هاتبوو وه‌ پێغه‌مبه‌ر نه‌بووم."
  26,21,"[ فَفَرَرْتُ مِنْكُمْ لَمَّا خِفْتُكُمْ ] بۆیه‌ له‌ ئێوه‌ ڕامكرد بۆ (مه‌دیه‌ن) كاتێك كه‌ لێتان ترسام تۆڵه‌ی خۆتان بسه‌نن [ فَوَهَبَ لِي رَبِّي حُكْمًا ] په‌روه‌ردگارم حوكم و پێغه‌مبه‌رایه‌تی پێ به‌خشیم  وه‌ منی كرد به‌ یه‌كێك له‌ پێغه‌مبه‌ران و نێردراوانی خۆی [ وَتِلْكَ نِعْمَةٌ تَمُنُّهَا عَلَيَّ ] وه‌ ئه‌م نیعمه‌ته‌یش كه‌ تۆ منه‌ت ئه‌كه‌ی به‌سه‌ر مندا كه‌ منت به‌ منداڵی گه‌وره‌ كردووه‌."
  26,22," به‌ڵام باسی ئه‌وه‌ ناكه‌ی كه‌ هه‌موو به‌نو ئیسرائیلت كردووه‌ به‌ عه‌بدو كۆیله‌ی خۆت و ده‌یانچه‌وسێنیته‌وه‌ كه‌ هه‌ر ئه‌مه‌یش وای كرد دایكم له‌ ترسی ئه‌وه‌ى تۆ نه‌مكوژیت منی هه‌ڵدایه‌ ناو ئاوه‌كه‌وه‌و كه‌وتمه‌ ژێر ده‌ستت ئێستاش منه‌ت ئه‌كه‌ی به‌سه‌رمدا."
  26,23," فیرعه‌ون وتی: ئه‌و په‌روه‌ردگاری هه‌موو جیهانه‌ی تۆ باسی ئه‌كه‌ی چیه‌و كێیه‌؟"
  26,24,"[ قَالَ رَبُّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا ] موسا - صلی الله علیه وسلم - فه‌رمووی: په‌روه‌ردگاری هه‌ر حه‌وت ئاسمانه‌كه‌و هه‌ر حه‌وت زه‌ویه‌كه‌و ئه‌وه‌ی له‌ نێوانیاندایه‌ خواو به‌ڕێوبه‌رو هه‌ڵسوڕێنه‌ری هه‌موویه‌تی  ئه‌گه‌ر ئێوه‌ دڵنیایی و یه‌قینتان هه‌یه‌."
  26,25," فیرعه‌ون وه‌كو سوكایه‌تى و گاڵته‌ پێكردن به‌وانه‌ی ده‌وروپشت و ده‌ست و پێوه‌نده‌كانی خۆی وت ئایا نابیستن و پێتان سه‌یر نیه‌ موسا - صلی الله علیه وسلم - چی ئه‌ڵێ؟"
  26,26," موسا - صلی الله علیه وسلم - فه‌رمووی: الله په‌روه‌ردگاری ئێوه‌و په‌روه‌ردگاری باوك و باپیرانی پێشینه‌یشتانه‌."
  26,27," فیرعه‌ون وتی: به‌ڕاستی ئه‌م پێغه‌مبه‌ره‌ی كه‌ نێردراوه‌ بۆ لای ئێوه‌ كه‌ موسایه‌ كه‌سێكی شێته‌، گاڵته‌ی پێئه‌كرد."
  26,28," موساش - صلی الله علیه وسلم - فه‌رمووی: په‌روه‌ردگاری من په‌روه‌ردگاری ڕۆژهه‌ڵات و ڕۆژئاواو ئه‌وه‌ی له‌ نێوانیاندایه‌، وه‌ هه‌مووی موڵكی خوای گه‌وره‌یه‌و خۆى هه‌ڵی ئه‌سووڕێنێ ئه‌گه‌ر ئێوه‌ عه‌قڵتان هه‌یه‌و بیر ئه‌كه‌نه‌وه."
  26,29,"{فیرعەون هەڕەشە لە موسا پێغەمبەر - صلی الله علیه وسلم - دەكات}  فیرعه‌ون كه‌ ده‌مكوت كرا به‌ به‌ڵگه‌ و قسه‌ى نه‌ما په‌ناى برد بۆ هێزو ده‌سه‌ڵاتى و هه‌ڕه‌شه‌ی لێ كردو وتی: ئه‌ی موسا - صلی الله علیه وسلم - ئه‌گه‌ر جگه‌ له‌ من خوایه‌كی تر بۆ خۆت بڕیار بده‌ی ئه‌وه‌ ئه‌تخه‌مه‌ به‌ندینخانه‌وه‌."
  26,30," موسا - صلی الله علیه وسلم - فه‌رمووی: ئایا من به‌ڵگه‌یه‌كى یه‌كلاكه‌ره‌وه‌و ئاشكرام بۆت نه‌هێناوه‌ كه‌ ئاشكرایه‌ له‌سه‌ر ڕاستگۆیی من."
  26,31," فیرعه‌ون وتی: ئه‌گه‌ر ڕاست ئه‌كه‌ی موعجیزه‌و شتێكی ئاشكرام بۆ بێنه‌."
  26,32,"{موسا پێغەمبەر - صلی الله علیه وسلم - موعجیزە نیشان فیرعەون دەدات}  موساش - صلی الله علیه وسلم - گۆچانه‌كه‌ی ده‌ستی هه‌ڵداو بوو به‌ مارێكی گه‌وره‌و ئاشكراو دیار كه‌ ده‌بینرا."
  26,33,"[ وَنَزَعَ يَدَهُ ] وه‌ ده‌ستیشی ده‌ركرد  ده‌ستی زۆر سپی و پرشنگدار بوو وه‌كو مانگى چوارده‌ ئه‌دره‌وشایه‌وه‌ هه‌موو به‌ چاوی خۆیان بینیان، (موسا - صلی الله علیه وسلم - خۆى كه‌سێكى ئه‌سمه‌ر بوو)"
  26,34,"[ قَالَ لِلْمَلَإِ حَوْلَهُ ] فیرعه‌ون له‌ جیاتى ئه‌وه‌ى ئیمانى پێ بێنێت به‌ ده‌سه‌ڵاتدارانی ده‌وروپشتی وت:  به‌ڕاستی ئه‌مه‌ جادووگه‌رێكی زۆر زانایه‌."
  26,35,"[ يُرِيدُ أَنْ يُخْرِجَكُمْ مِنْ أَرْضِكُمْ بِسِحْرِهِ ] ئینجا فیرعه‌ون خه‌ڵكى لێ هانداو وتی: موسا مه‌به‌ستی ئه‌وه‌یه‌ به‌م سیحره‌ی سه‌ره‌نجى خه‌ڵكى راكێشێت و شوێنكه‌وتوانى زۆر بكات و زاڵ بێت به‌سه‌ر ئێوه‌داو له‌ شاری خۆتان ده‌رتات بكات و ده‌ست بگرێت به‌سه‌ر وڵاته‌كه‌تاندا، (ئه‌مه‌ پیشه‌ى كافران و بێباوه‌ڕانه‌ كه‌ درۆ بۆ پێغه‌مبه‌ران و شوێنكه‌وتوانیان هه‌ڵده‌به‌ستن و تۆمه‌تباریان ده‌كه‌ن به‌ جۆره‌ها تۆمه‌تى پوچه‌ڵ و بێبنه‌ما تا له‌ پێش چاو خه‌ڵكى ناشیرینیان بكه‌ن، به‌ڵام سه‌ره‌نجام راستیه‌كان ده‌رده‌كه‌ون و خواى گه‌وره‌ حه‌ق و شوێنكه‌وتوانى سه‌رده‌خات)  بۆ ئه‌وه‌ی زیاتر سه‌رنجیان ڕاكێشێ وتی: ئێوه‌ فه‌رمانتان به‌ چیه‌و چی ئه‌ڵێن؟"
  26,36," وتیان: ئیشی خۆی و براكه‌ی دوابخه‌، وه‌ بنێره‌ به‌ شاره‌كاندا بگه‌ڕێن وه‌ خه‌ڵكى هه‌ر هه‌مووی كۆ بكه‌نه‌وه‌."
  26,37,"{فیرعەون جادووگەران كۆ دەكاتەوە}  وه‌ بگه‌ڕێن هه‌رچی جادووگه‌ری زۆر زاناو شاره‌زایه‌ هه‌ر هه‌مووی كۆ بكه‌نه‌وه‌و بیانهێنن."
  26,38," هه‌رچی ساحیرو جادووگه‌ری به‌ناوبانگ و زانا هه‌بوو هه‌موویان كۆكرده‌وه‌ بۆ كاتێكی دیاریكراو كه‌ ڕۆژی جه‌ژن بوو (هه‌زاران ساحیر بوون)."
  26,39," وه‌ به‌ خه‌ڵكی وترا یان هانی خه‌ڵكى درا كه‌ هه‌موویان كۆببنه‌وه‌ بۆ ئه‌وه‌ی ئه‌م شته‌ ببینن له‌ نێوان موساو - صلی الله علیه وسلم - ساحیره‌كاندا."
  26,40," وتیان: به‌ڵكو ئێمه‌ شوێن ساحیره‌كان بكه‌وین ئه‌گه‌ر ئه‌مان سه‌ركه‌ون و بیبه‌نه‌وه‌ (نه‌یانووت شوێن حه‌ق ده‌كه‌وین)."
  26,41,"[ فَلَمَّا جَاءَ السَّحَرَةُ قَالُوا لِفِرْعَوْنَ ] كاتێك كه‌ ساحیره‌كان هاتن به‌ فیرعه‌ونیان وت:  ئه‌ی فیرعه‌ون ئه‌گه‌ر ئێمه‌ زاڵ بین و بیبه‌ینه‌وه‌ ئایا هیچ ئه‌جرو پاداشتێكمان بۆ هه‌یه‌؟"
  26,42," فیرعه‌ون وتی: به‌ڵێ، وه‌ ئێوه‌ ئه‌كه‌مه‌ كه‌سه‌ نزیكه‌كانی خۆم، واته‌: پله‌و پایه‌تان ئه‌ده‌مێ."
  26,43," موسا - صلی الله علیه وسلم - فه‌رمووی: چیتان پێیه‌ هه‌ڵی بده‌ن و جادووی خۆتان بكه‌ن."
  26,44,"[ فَأَلْقَوْا حِبَالَهُمْ وَعِصِيَّهُمْ ] حه‌بل و گۆچانه‌كانیان هه‌ڵداو  وه‌ وتیان: به‌عیززه‌ت و تواناو ده‌سه‌ڵات و گه‌وره‌یی فیرعه‌ون به‌ دڵنیایى ئێمه‌ زاڵ ئه‌بین و ئه‌یبه‌ینه‌وه‌ [ فَأَلْقَى مُوسَى عَصَاهُ ] موسایش - صلی الله علیه وسلم - گۆچانه‌كه‌ی هه‌ڵدا."
  26,45," ئه‌و ئیفك و درۆیه‌ی كه‌ ئه‌وان هه‌ڵیانبه‌ستبوو له‌ سیحرو جادوو ئه‌مه‌ی موسا - صلی الله علیه وسلم - هه‌موو ئه‌وه‌ی ئه‌وانی قووتداو نه‌یهێشت."
  26,46,"{جادووگەران موسڵمان دەبن‌و كڕنوش بۆ خوا دەبەن}  كاتێك ساحیره‌كان ئه‌م شته‌یان بینی زانیان ئه‌مه‌ سیحرو جادوو نیه‌ به‌ڵكو ئه‌مه‌ موعجیزه‌یه‌و له‌لایه‌ن خوای گه‌وره‌وه‌یه‌ بۆیه‌ هه‌موویان باوه‌ڕیان هێناو كڕنوشیان بۆ خوای گه‌وره‌ برد."
  26,47," وتیان: ئیمانمان به‌ په‌روه‌ردگاری هه‌موو جیهان هێنا."
  26,48," په‌روه‌ردگاری موسا و هارون، واته‌: فیرعه‌ون تۆ په‌روه‌ردگارو خوا نیت."
  26,49,"{فیرعەون هەڕەشە دەكات} [ قَالَ آمَنْتُمْ لَهُ قَبْلَ أَنْ آذَنَ لَكُمْ ] فیرعه‌ون وتی: ئایا ئێوه‌ ئیمانتان به‌ موسا هێنا پێش ئه‌وه‌ی كه‌ من ئیزنتان بده‌م [ إِنَّهُ لَكَبِيرُكُمُ الَّذِي عَلَّمَكُمُ السِّحْرَ ] موسا پیاوه‌ گه‌وره‌كه‌تان بوو كه‌ فێره‌ سیحری كردن، واته‌: ئێوه‌ ئه‌م سیحره‌ له‌ موساوه‌ فێر بوونه‌، (خۆیشى ده‌یزانى وا نیه‌و درۆ ده‌كات بۆ ئه‌وه‌ى رێگرى بكات له‌ موسڵمان بوونى خه‌ڵكى) [ فَلَسَوْفَ تَعْلَمُونَ ] ئه‌وه‌ له‌ داهاتووێكی نزیكدا ئه‌زانن كه‌ چیتان به‌سه‌ر دێنم [ لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُمْ مِنْ خِلَافٍ ] ئه‌بێ ده‌ست و پێتان به‌ پێچه‌وانه‌وه‌ ببڕمه‌وه‌ ده‌ستی ڕاست و پێی چه‌پ و به‌ پێچه‌وانه‌وه‌ به‌م شێوازه‌  وه‌ ئه‌بێ هه‌ر هه‌مووتان له‌ خاچ و دار بده‌م و هه‌ڵتان بواسم تا ببن به‌ په‌ندو عیبره‌ت بۆ خه‌ڵكى، (كافران كه‌ به‌ به‌ڵگه‌ ده‌مكوت بكرێن و بیروباوه‌ڕه‌ پوچه‌ڵه‌كه‌یان بۆ خه‌ڵكى روون بكرێته‌وه‌ په‌نا ده‌به‌ن بۆ كوشتن و بڕین و توندوتیژى و هه‌ڕه‌شه‌و ترساندن و تۆقاندن، كه‌ ئه‌مه‌ پیشه‌ى هه‌میشه‌یى ئه‌وان بووه‌ به‌ڵام موسڵمانانى پێ تۆمه‌تبار ده‌كه‌ن و ده‌ستى چه‌ورى خۆیان به‌سه‌ر موسڵماناندا ده‌ساون)."
  26,50,"{جادوگەرە موسڵمان بووەكان بێباكن لە هەڕەشەكانی فیرعەون} [ قَالُوا لَا ضَيْرَ ] وتیان: ئێمه‌ هیچ زه‌ره‌رو زیانێكمان پێ ناگات هه‌رچیمان پێ لێبكه‌ی له‌ دونیادا بێباكین و گوێى پێ ناده‌ین له‌به‌ر ئه‌وه‌ی كۆتایی دێت و ئه‌ڕوات  ئێمه‌ بۆ لای خوای گه‌وره‌ ئه‌گه‌ڕێینه‌وه‌و مه‌به‌ستمان ئه‌وه‌یه‌."
  26,51,"[ إِنَّا نَطْمَعُ أَنْ يَغْفِرَ لَنَا رَبُّنَا خَطَايَانَا ] ئێمه‌ به‌ ئومێدی ئه‌وه‌ین كه‌ خوای گه‌وره‌ له‌ تاوانه‌كانی ڕابردوومان خۆش بێت  كه‌ ئێمه‌ ئێستا یه‌كه‌مجار موسڵمان بووین و له‌ یه‌كه‌م موسڵمانانین و له‌ پێش خه‌ڵكیدا موسڵمان بووینه‌."
  26,52,"{موسا پێغەمبەر - صلی الله علیه وسلم - بەشەو بە نهێنی موسڵمانان دەرباز دەكات}  خوای گه‌وره‌ وه‌حی بۆ موسا - صلی الله علیه وسلم - نارد كه‌ به‌ شه‌و به‌نی ئیسرائیلى به‌نده‌كانی من ده‌ربكه‌ له‌ میصر چونكه‌ فیرعه‌ون و سه‌ربازه‌كانی شوێنتان ئه‌كه‌ون، ئه‌ویش به‌شه‌و به‌نهێنى ده‌ری كردن."
  26,53," فیرعه‌ون كه‌ بینى به‌نى ئیسرائیل رۆیشتوون و نه‌ماون توڕه‌ بوو به‌ناو شاره‌كاندا خه‌ڵكی ناردو شوێنكه‌وتوان و سه‌ربازه‌كانی خۆی هه‌ر هه‌مووی كۆ كرده‌وه‌و وتی:"
  26,54," به‌ دڵنیایى ئه‌مانه‌ كه‌سانێكی نزم و بێڕێزو كه‌من."
  26,55," وه‌ ئه‌مانه‌ هه‌میشه‌ ئێمه‌ دڵ ته‌نگ و توڕه‌ ئه‌كه‌ن و خه‌فه‌تمان ئه‌ده‌نێ."
  26,56," وه‌ ئێمه‌ له‌وپه‌ڕی ئاماده‌باشیداین بۆ شوێن كه‌وتنی به‌نی ئیسرائیل و له‌ناو بردنیان."
  26,57," خوای گه‌وره‌ ئه‌فه‌رمووێ: فیرعه‌ون و سه‌ربازه‌كانیمان ده‌ركرد له‌ شوێنێكدا كه‌ باخ و بێستان و كانی و ڕووبارو سه‌رچاوه‌ی ئاویان هه‌بوو."
  26,58,"[ وَكُنُوزٍ ] وه‌ كه‌نزو ئاڵتوون و خشڵیان هه‌بوو  وه‌ شوێن و كۆشكی چاكیان هه‌بوو."
  26,59," به‌و شێوازه‌ به‌نی ئیسرائیلمان كرد به‌ میراتگریان ئه‌وانمان له‌ناوبردو به‌نی ئیسرائیل چوونه‌ شوێنیان."
  26,60,"{فیرعەون‌و سەربازانی شوێن موسا پێغەمبەر - صلی الله علیه وسلم - و موسڵمانان دەكەون }  وه‌ له‌ كاتی به‌ره‌به‌یان و ڕۆژهه‌ڵاتندا فیرعه‌ون و وه‌زیرو ده‌سه‌ڵاتداران و سه‌ربازانى هه‌موویان شوێنی موساو - صلی الله علیه وسلم - موسڵمانان كه‌وتن."
  26,61,"[ فَلَمَّا تَرَاءَى الْجَمْعَانِ ] كاتێك كه‌ هه‌ردوو كۆمه‌ڵه‌كه‌ رووبه‌ڕووی یه‌كتر بوونه‌وه‌و یه‌كتریان لێ ده‌ركه‌وت و یه‌كتریان بینى  هاوه‌ڵانى موسا - صلی الله علیه وسلم - وتیان: ئه‌ی موسا - صلی الله علیه وسلم - ئه‌وه‌ فیرعه‌ون پێمان گه‌یشت و پێشمان ئاوه‌كه‌یه‌و دواشمان فیرعه‌ون و سه‌ربازه‌كانێتی."
  26,62,"[ قَالَ كَلَّا ] موسا - صلی الله علیه وسلم - فه‌رمووی: نه‌خێر ئه‌وان به‌ ئێمه‌ ناگه‌ن  به‌ دڵنیایى من په‌روه‌ردگارم له‌گه‌ڵدایه‌ به‌زانیارى و بیستن و بینین و تواناو ده‌سه‌ڵاتى، ئه‌و سه‌رمان ئه‌خات و ڕێنماییمان ئه‌كات و ڕزگارمان ئه‌كات."
  26,63,"{بە ئیزنی خوا دەریا دەبێت بە زەوی وشك} [ فَأَوْحَيْنَا إِلَى مُوسَى ] خوای گه‌وره‌ ئه‌فه‌رمووێ: وه‌حیمان بۆ موسا - صلی الله علیه وسلم - نارد [ أَنِ اضْرِبْ بِعَصَاكَ الْبَحْرَ ] به‌و گۆچانه‌ی به‌ ده‌ستته‌وه‌یه‌ بیده‌ به‌ ده‌ریاكه‌دا [ فَانْفَلَقَ ] ده‌ریاكه‌ له‌ت بوو، بوو به‌ زه‌ویه‌كی وشك  وه‌ به‌ ئیزنی خوای گه‌وره‌ ئاوه‌كه‌ به‌رز بووه‌وه‌و هه‌ر شه‌پۆلێكی وه‌كو پارچه‌ شاخێكی گه‌وره‌ له‌ ئاسمان ڕاوه‌ستاو بوو به‌ دوانزه‌ ڕێگا، له‌به‌ر ئه‌وه‌ی دوانزه‌ هۆز بوون بۆ ئه‌وه‌ی هه‌ر هۆزێك به‌ ئیسراحه‌ت بپه‌ڕنه‌وه‌، وه‌ نێوانی ئاوه‌كه‌یش خوای گه‌وره‌ بای ناردو وشكی كردو به‌ناو وشكانیدا تێ ئه‌په‌ڕین، وه‌ تاق و كه‌لێنی له‌ نێوان ئاوه‌كاندا كرده‌وه‌ تا له‌ یه‌كترى دیار بن و دڵنیا بن هه‌موویان رزگاریان بووه‌."
  26,64,"{موسا پێغەمبەر - صلی الله علیه وسلم - و موسڵمانان رزگاریان دەبێت‌و فیرعەون‌و سەربازانی نوقمی دەریاكە دەبن}  وه‌ ئه‌له‌وێدا فیرعه‌ون و سه‌ربازه‌كانیمان نزیك كرده‌وه‌ له‌ ده‌ریاكه‌ تا چوونه‌ ناو ده‌ریاكه‌وه‌ ئه‌وانیش به‌ دوایاندا ڕۆیشتن."
  26,65," موساو - صلی الله علیه وسلم - ئه‌وانه‌ی له‌گه‌ڵیاندا بوون هه‌موومان ڕزگار كردن و له‌ ده‌ریاكه‌ په‌ڕینه‌وه‌."
  26,66," پاشان فیرعه‌ون و سه‌ربازو وه‌زیرو ده‌ست و پێوه‌ندیمان هه‌مووی له‌ناو ئاوه‌كه‌دا غه‌رق كردو كه‌سیان رزگاریان نه‌بوو."
  26,67,"[ إِنَّ فِي ذَلِكَ لَآيَةً ] كه‌ ئه‌مه‌ به‌ڕاستی ئایه‌ت و موعجیزه‌یه‌كی گه‌وره‌یه‌و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌ ده‌رئه‌خات  به‌ڵام زۆربه‌یان ئیمانیان نه‌هێنا ته‌نها كه‌مێكیان نه‌بێ وه‌كو (ئاسیای خێزانی فیرعه‌ون)."
  26,68," وه‌ په‌روه‌ردگاری تۆ به‌ڕاستی زۆر باڵاده‌ست و به‌ عیززه‌ته‌، وه‌ زۆر به‌ڕه‌حم و به‌زه‌ییه‌ بۆ باوه‌ڕداران."
  26,69,"{گفتوگۆی نێوان ئیبراهیم پێغەمبەر - صلی الله علیه وسلم - و قەومەكەی}  ئه‌ی محمد - صلی الله علیه وسلم - باسی به‌سه‌رهاتی ئیبراهیم پێغه‌مبه‌ریان - صلی الله علیه وسلم - بۆ بخوێنه‌وه‌."
  26,70," كاتێك كه‌ به‌ باوكی و قه‌ومه‌كه‌ی فه‌رموو: ئه‌وه‌ ئێوه‌ چی ئه‌په‌رستن؟ ئه‌یزانی بت ئه‌په‌رستن به‌ڵام بۆ ئه‌وه‌ی پابه‌ندیان بكات."
  26,71,"[ قَالُوا نَعْبُدُ أَصْنَامًا ] وتیان: ئێمه‌ بت ئه‌په‌رستین  وه‌ به‌رده‌وام به‌ دیاریانه‌وه‌ نیشته‌جێین و ماوینه‌ته‌وه‌و ده‌یانپه‌رستین."
  26,72," ئیبراهیم - صلی الله علیه وسلم - فه‌رمووی: ئایا كاتێك ئێوه‌ لێیان بپاڕێنه‌وه‌ ئه‌و بتانه‌ قسه‌ی ئێوه‌ ئه‌بیستن؟"
  26,73,"[ أَوْ يَنْفَعُونَكُمْ ] یان كه‌ شوێنیان كه‌وتوونه‌و ئه‌یانپه‌رستن ئه‌وان سوودتان پێ ئه‌گه‌یه‌نن؟  یان ئه‌گه‌ر واز له‌ په‌رستنیان بێنن ئه‌توانن زیانتان پێ بگه‌یه‌نن؟"
  26,74," دانیان نا كه‌ بته‌كانیان هیچ سودو زیانیان به‌ده‌ست نیه‌و وتیان: به‌ڵكو ئێمه‌ باوك و باپیرانی خۆمان بینیوه‌ به‌م شێوه‌یه‌ عیباده‌تیان بۆ ئه‌و بتانه‌ ئه‌كرد ئێمه‌ش چاو له‌وان ئه‌كه‌ین و لاسایی ئه‌وان ئه‌كه‌ینه‌وه‌ (ئه‌مه‌یش به‌ڵگه‌یه‌ له‌سه‌ر ئه‌وه‌ى ته‌قلیدو لاسایی كردنه‌وه‌ى كوێرانه‌ حه‌رامه‌و مرۆڤ ده‌بێت شوێن به‌ڵگه‌ بكه‌وێت)."
  26,75," ئیبراهیم - صلی الله علیه وسلم - فه‌رمووی: پێم بڵێن ئه‌و شتانه‌ی كه‌ ئێوه‌ ئه‌یپه‌رستن هیچ سوودو كاریگه‌رییه‌كیان هه‌یه‌؟"
  26,76," ئێوه‌و باوك و باپیرانی پێشینه‌تان هه‌مووتان ئه‌مانه‌ ئه‌په‌رستن هیچ سوودێكتان پێ ناگه‌یه‌نن."
  26,77,"[ فَإِنَّهُمْ عَدُوٌّ لِي ] به‌ڵكو ئه‌وانه‌ هه‌موو دوژمنی منن  ته‌نها په‌روه‌ردگاری هه‌موو جیهان نه‌بێ ئه‌و دۆست و خۆشه‌ویستی منه‌ چونكه‌ تواناى به‌سه‌ر ئه‌م شتانه‌دا هه‌یه‌:"
  26,78," هه‌ر ئه‌و خوایه‌یه‌ كه‌ منی دروست كردووه‌، وه‌ هه‌ر ئه‌ویش هیدایه‌تم ئه‌دات و ڕێنماییم ئه‌كات بۆ به‌رژه‌وه‌ندی دین و دونیام."
  26,79," وه‌ هه‌ر ئه‌و خوایه‌یه‌ كه‌ خواردن و خواردنه‌وه‌م پێ ئه‌به‌خشێ."
  26,80," وه‌ كاتێك كه‌ نه‌خۆش بكه‌وم هه‌ر ئه‌و خوایه‌یه‌ كه‌ شیفام ئه‌دات (وه‌كو ئه‌ده‌بێك نه‌خۆشییه‌كه‌ی نه‌دایه‌ پاڵ خوای گه‌وره‌ ته‌نها شیفاكه‌ى بۆ خواى گه‌وره‌ گه‌ڕانده‌وه‌)."
  26,81," وه‌ هه‌ر ئه‌و خوایه‌یه‌ كاتێك كه‌ ئه‌ممرێنێ وه‌ دواتریش زیندووم ئه‌كاته‌وه‌ بۆ لێپرسینه‌وه‌  وه‌ هه‌ر ئه‌و خوایه‌یه‌ كه‌ ئومێدم پێیه‌تى كه‌ له‌ تاوانه‌كانم خۆش بێ له‌ ڕۆژی قیامه‌تدا (كاتێك كه‌ بته‌كانی شكاند وتی: گه‌وره‌كه‌یان شكاندوویه‌تی، وانه‌بوو خۆى شكاندیانى، وه‌ كاتێك كه‌ ئه‌وان چوونه‌ ده‌ره‌وه‌ی شار وتی: من نه‌خۆشم، وه‌ نه‌خۆش نه‌بوو، وه‌ كاتێك كه‌ سارای خێزانى له‌گه‌ڵدا بوو وتی: خوشكمه‌ مه‌به‌ستى خوشكى دینى بوو بۆ ئه‌وه‌ى رزگارى بكات له‌ ده‌ستدرێژى پاشا كافره‌كه‌، به‌ ئومێدم خوای گه‌وره‌ له‌م تاوانانه‌م خۆش بێ) [ رَبِّ هَبْ لِي حُكْمًا ] ئه‌ی په‌روه‌ردگار زانیارى و زانستێكی به‌سوود یان پێغه‌مبه‌رایه‌تیم پێ ببه‌خشه‌  وه‌ بمگه‌یه‌نه‌ به‌ پیاوچاكان له‌ به‌هه‌شتدا."
  26,82," وه‌ هه‌ر ئه‌و خوایه‌یه‌ كه‌ ئومێدم پێیه‌تى كه‌ له‌ تاوانه‌كانم خۆش بێ له‌ ڕۆژی قیامه‌تدا (كاتێك كه‌ بته‌كانی شكاند وتی: گه‌وره‌كه‌یان شكاندوویه‌تی، وانه‌بوو خۆى شكاندیانى، وه‌ كاتێك كه‌ ئه‌وان چوونه‌ ده‌ره‌وه‌ی شار وتی: من نه‌خۆشم، وه‌ نه‌خۆش نه‌بوو، وه‌ كاتێك كه‌ سارای خێزانى له‌گه‌ڵدا بوو وتی: خوشكمه‌ مه‌به‌ستى خوشكى دینى بوو بۆ ئه‌وه‌ى رزگارى بكات له‌ ده‌ستدرێژى پاشا كافره‌كه‌، به‌ ئومێدم خوای گه‌وره‌ له‌م تاوانانه‌م خۆش بێ)."
  26,83,"[ رَبِّ هَبْ لِي حُكْمًا ] ئه‌ی په‌روه‌ردگار زانیارى و زانستێكی به‌سوود یان پێغه‌مبه‌رایه‌تیم پێ ببه‌خشه‌  وه‌ بمگه‌یه‌نه‌ به‌ پیاوچاكان له‌ به‌هه‌شتدا."
  26,84," وه‌ زمانێكی ڕاستگۆم پێ ببه‌خشه‌ له‌ دونیادا كه‌ ئه‌وانه‌ی دوای خۆم دێن به‌ باشه‌ باسم بكه‌ن و له‌ چاكه‌دا شوێنم بكه‌ون."
  26,85," وه‌ له‌ قیامه‌تدا بمكه‌ به‌ میراتگری به‌هه‌شتێك كه‌ پڕ له‌ نازو نیعمه‌ته‌."
  26,86,"[ وَاغْفِرْ لِأَبِي ] وه‌ له‌ باوكم خۆشبه‌  له‌به‌ر ئه‌وه‌ی كه‌سێكی گومڕا بووه‌، سه‌ره‌تا نه‌یزانی كه‌ باوكی له‌سه‌ر كوفر ئه‌مرێ، به‌ڵام دواتر كه‌ زانی باوكی دوژمنی خوای گه‌وره‌یه‌ له‌م شته‌ په‌شیمان بووه‌وه‌و به‌ڕائه‌تی لێ كرد، (دروست نیه‌ داواى لێخۆشبوون بۆ كافران و موشریكان بكرێت ئه‌گه‌ر دایك و باوكیش بن)."
  26,87," ئه‌ی په‌روه‌ردگار ئابڕووم مه‌به‌و سه‌رشۆڕم مه‌كه‌ له‌ ڕۆژی قیامه‌تدا كه‌ خه‌ڵكی زیندوو ئه‌كه‌یته‌وه‌، واته‌: له‌پێش چاوم باوكم مه‌خه‌ره‌ ئاگری دۆزه‌خه‌وه‌، پێغه‌مبه‌رى خوا - صلی الله علیه وسلم - ده‌فه‌رمێت: (له‌ رۆژى قیامه‌ت ئیبراهیم - صلی الله علیه وسلم - باوكى ده‌بینێت رووى ره‌ش و ته‌پوتۆزاویه‌و ده‌فه‌رمووێت: ئه‌ى باوكه‌ نه‌مووت سه‌رپێچیم مه‌كه‌و شوێنم بكه‌وه‌، ئه‌ویش ده‌ڵێت: ئه‌مڕۆ سه‌رپێچیت ناكه‌م، ئیبراهیم - صلی الله علیه وسلم - ده‌فه‌رمووێت: ئه‌ى په‌روه‌ردگار تۆ به‌ڵێنت پێدام كه‌ سه‌رشۆڕم نه‌كه‌یت له‌ رۆژى قیامه‌ت، چ سه‌رشۆڕییه‌ك له‌مه‌ خراپتره‌ كه‌ باوكم بخه‌یته‌ ناو ئاگرى دۆزه‌خ؟ خواى گه‌وره‌ ده‌فه‌رمێت: من به‌هه‌شتم له‌ كافران حه‌رام كردووه‌، پاشان خوای گه‌وره‌ باوكی ئه‌كاته‌ كه‌متیارێكى نێرو فڕێ ئه‌درێته‌ دۆزه‌خه‌وه‌)، وه‌كو له‌ بوخاری و موسلیمدا هاتووه‌."
  26,88," له‌ ڕۆژێك كه‌ رۆژى قیامه‌ته‌ هیچ شتێك سوودی نیه‌ نه‌ ماڵ و سه‌روه‌ت و سامان نه‌ منداڵ سوود به‌ هیچ كه‌سێك ناگه‌یه‌نێت و له‌ سزاى خواى گه‌وره‌ رزگارى ناكات."
  26,89," ئیلا ئه‌گه‌ر كه‌سێك بگاته‌ خوای گه‌وره‌ به‌ دڵێكی پاكه‌وه‌ كه‌ پڕ بێت له‌ ته‌وحیدو سوننه‌ت دوور بێت له‌ شیرك و بیدعه‌، وه‌ دڵێك پاك بێت له‌ تاوان و سه‌رپێچى كه‌ دڵی مرۆڤی ئیمانداره‌."
  26,90," وه‌ به‌هه‌شت نزیك ئه‌كرێته‌وه‌و ده‌ڕازێنرێته‌وه‌ بۆ ئه‌و كه‌سانه‌ی كه‌ ته‌قوای خوای گه‌وره‌یان كردووه‌."
  26,91," وه‌ دۆزه‌خیش ده‌ر ئه‌كه‌وێت بۆ ئه‌و كه‌سانه‌ی كه‌ گومڕاو خراپه‌كار بوونه‌."
  26,92," وه‌ پێیان ئه‌ووترێ ئێوه‌ چیتان ئه‌په‌رست له‌ دونیا؟"
  26,93,"[ مِنْ دُونِ اللَّهِ ] جگه‌ له‌ خوای گه‌وره‌  ئایا ئه‌وانه‌ توانایان هه‌یه‌ ئێوه‌ سه‌ربخه‌ن؟ یان ئه‌توانن خۆیان سه‌ربخه‌ن؟"
  26,94," هه‌موویان فڕێ ئه‌درێنه‌ دۆزه‌خه‌وه‌ په‌رستراو و په‌رسته‌ر."
  26,95," وه‌ سه‌ربازانی ئیبلیسیش به‌ جن و مرۆڤه‌وه‌ هه‌موویان فڕێ ئه‌درێنه‌ ئاگری دۆزه‌خه‌وه‌."
  26,96,"{مشتومڕی نێوان سەركردەكان‌و شوێنكەوتوانیان لەناو ئاگری دۆزەخ}  ئه‌وان هه‌موویان له‌ناو دۆزه‌خدا ده‌مه‌قاڵێ ئه‌كه‌ن و ئه‌ڵێن:"
  26,97," ژێرده‌سته‌كان به‌ سه‌ركرده‌و گه‌وره‌كانیان ئه‌ڵێن: سوێند به‌ خوای گه‌وره‌ ئێمه‌ له‌ گومڕاییه‌كی زۆر ئاشكرادا بووین."
  26,98," كاتێك ئێوه‌مان یه‌كسان كرد به‌ په‌روه‌ردگاری هه‌موو جیهان و جگه‌ له‌ خوای گه‌وره‌ ئێوه‌مان په‌رست."
  26,99," وه‌ هیچ كه‌سێك ئێمه‌ی گومڕا نه‌كرد ته‌نها ئه‌م تاوانبارانه‌ نه‌بێ له‌ جن و مرۆڤ."
  26,100," وه‌ ئێستا كه‌سێك نیه‌ كه‌ تكامان بۆ بكات هه‌روه‌كو چۆن باوه‌ڕداران به‌ ئیزنی خوا كه‌سانێك تكایان بۆ ئه‌كات."
  26,101," وه‌ هیچ هاوڕێیه‌كی خۆشه‌ویست و نزیكمان نیه‌ كه‌ ڕزگارمان بكات."
  26,102," ئای ئه‌گه‌ر جارێكی تر بگه‌ڕاینایه‌ته‌وه‌ بۆ دونیا ئه‌وا ده‌بوایه‌ له‌ باوه‌ڕداران بووینایه‌و شوێن ئێوه‌ نه‌كه‌وتینایه‌ (خواى گه‌وره‌ ده‌زانێت درۆ ده‌كه‌ن ئه‌گه‌ر بگه‌ڕێنه‌وه‌ بۆ دونیایش هه‌ر تاوان و خراپه‌ ده‌كه‌ن)."
  26,103,"[ إِنَّ فِي ذَلِكَ لَآيَةً ] به‌ دڵنیایى ئه‌و شتانه‌ی كه‌ باسكرا هه‌مووی به‌ڵگه‌و نیشانه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌  هه‌ر چه‌نده‌ زۆربه‌ی زۆریان ئیمانیان نه‌هێنا."
  26,104," وه‌ به‌ دڵنیایى په‌روه‌ردگارت زۆر به‌ عیززه‌ت و باڵاده‌سته‌ وه‌ زۆر به‌ڕه‌حم و سۆزو به‌زه‌ییه‌."
  26,105,"{گفتوگۆی نێوان نوح پێغەمبەر - صلی الله علیه وسلم - و قەومەكەی}  قه‌ومی نوح سه‌رجه‌م پێغه‌مبه‌رانیان به‌درۆ زانی، (كه‌ باوه‌ڕیان به‌ پێغه‌مبه‌ره‌كه‌ی خۆیان نه‌بوو وه‌ك ئه‌وه‌ وایه‌ هه‌موو پێغه‌مبه‌رانیان به‌درۆ زانیبێت)."
  26,106," كاتێك نوح - صلی الله علیه وسلم - (له‌به‌ر ئه‌وه‌ی له‌ هۆزو نه‌ته‌وه‌ی خۆیان بوو خوای گه‌وره‌ به‌ برا ناوی ئه‌بات) پێی وتن: ئایا بۆ ته‌قوای خوای گه‌وره‌ ناكه‌ن و واز له‌ په‌رستنی ئه‌و بتانه‌ ناهێنن و شوێن من ناكه‌ون."
  26,107," له‌به‌ر ئه‌وه‌ی به‌دڵنیایى من پێغه‌مبه‌رێكی ئه‌مینم بۆ ئێوه‌و ئه‌مینم له‌وه‌ی كه‌ پێتانی ڕائه‌گه‌یه‌نم له‌لایه‌ن خواى گه‌وره‌وه‌و هیچى لێ زیادو كه‌م ناكه‌م."
  26,108," وه‌ ئێوه‌ ته‌قواى خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵى منیش بكه‌ن."
  26,109,"[ وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ] وه‌ من له‌م شته‌دا داوای هیچ ئه‌جرو پاداشت و پاره‌یه‌ك له‌ ئێوه‌ ناكه‌م  به‌ڵكو ئه‌جرو پاداشتی من ته‌نها له‌لای خوای گه‌وره‌یه‌و ئه‌و ئه‌جرو پاداشتم ئه‌داته‌وه‌ له‌سه‌ر گه‌یاندنی دینه‌كه‌ی."
  26,110," وه‌ ئێوه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵى من بكه‌ن."
  26,111," وتیان: ئایا ئێمه‌ ئیمان به‌ تۆ بێنین له‌ كاتێكدا كه‌سانێكی نزم و فه‌قیرو هه‌ژار دوای تۆ كه‌وتوونه‌؟ له‌گه‌ڵ ئه‌واندا ئیمان به‌ تۆ بێنین؟"
  26,112," نوح - صلی الله علیه وسلم - فه‌رمووی: من زانیاریم به‌ ئیشوكارو پیشه‌ی ئه‌وان نیه‌و پێویستم به‌و شته‌ نیه‌ ته‌نها داوا ئه‌كه‌م كه‌ ئیمان بێنن."
  26,113," حسابی ئه‌وان له‌ ناخیاندا چی هه‌یه‌ ئه‌وه‌ ته‌نها له‌سه‌ر خوای گه‌وره‌یه‌ ئه‌گه‌ر ئێوه‌ هه‌ست ده‌كه‌ن."
  26,114," داوایان له‌ نوح - صلی الله علیه وسلم - كرد كه‌ موسڵمانه‌ هه‌ژاره‌كان دور بخاته‌وه‌ ئه‌مان موسڵمان ده‌بن، نوحیش - صلی الله علیه وسلم - داواكاریه‌كه‌ى ره‌ت كردنه‌وه‌و فه‌رمووى: وه‌ من باوه‌ڕداره‌ فه‌قیرو هه‌ژاره‌كان ده‌رناكه‌م بۆ ئه‌وه‌ی ئێوه‌ موسڵمان بن."
  26,115," وه‌ من هیچ شتێك نیم ته‌نها ترسێنه‌رو ئاگاداركه‌ره‌وه‌یه‌ك نه‌بێت كه‌ به‌ ئاشكرا ئاگادارتان ئه‌كه‌مه‌وه‌."
  26,116,"{كافران هەڕەشە لە نوح پێغەمبەر - صلی الله علیه وسلم – دەكەن}  وتیان: ئه‌ی نوح - صلی الله علیه وسلم - ئه‌گه‌ر واز نه‌هێنی له‌ بانگه‌واز كردنمان بۆ ئه‌م دینه‌ تازه‌یه‌ ئه‌وه‌ به‌ردبارانت ئه‌كه‌ین."
  26,117," نوح - صلی الله علیه وسلم - فه‌رمووی: ئه‌ی په‌روه‌ردگارم به‌ڕاستی قه‌ومه‌كه‌م به‌ درۆیانزانیم و وه‌ڵامیان نه‌دامه‌وه‌."
  26,118,"[ فَافْتَحْ بَيْنِي وَبَيْنَهُمْ فَتْحًا ] وه‌ جیاوازی و جیاكاری و بڕیارێك بده‌ له‌ نێوان من و ئه‌واندا تا ده‌ركه‌وێ كێمان له‌سه‌ر حه‌قین وه‌ كێمان له‌سه‌ر باتڵین  وه‌ خۆم و ئه‌و باوه‌ڕدارانه‌ی له‌گه‌ڵمدان ڕزگارمان بكه‌ وه‌ ئه‌وان له‌ناو بده‌."
  26,119,"{خوای گەورە نوح پێغەمبەر - صلی الله علیه وسلم - و شوێنكەوتوانی رزگار دەكات‌و كافران نگرۆی ئاوەكە دەكات}  وه‌ نوح و - صلی الله علیه وسلم - ئه‌و باوه‌ڕدارانه‌ی كه‌ له‌گه‌ڵیدا بوون له‌ناو كه‌شتییه‌ پڕه‌كه‌دا هه‌موومان ڕزگار كردن (كه‌ پڕ بوو له‌ هه‌موو شتومه‌ك و جووت نێرو مێ¬یه‌ك له‌ باڵنده‌و گیانله‌به‌ر بۆ ئه‌وه‌ى دواتر ژیان ده‌ست پێ بكاته‌وه‌)."
  26,120," پاشان ئه‌وانه‌ی كه‌ مانه‌وه‌ له‌ قه‌ومه‌كه‌ی كه‌ ئیمانیان نه‌هێنا هه‌موومان نوقمى ئاوه‌كه‌ كردن."
  26,121,"[ إِنَّ فِي ذَلِكَ لَآيَةً ] به‌دڵنیایى ئه‌مه‌ هه‌مووی نیشانه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌  هه‌ر چه‌نده‌ زۆربه‌ی زۆریان ئیمانیان نه‌هێنا."
  26,122," وه‌ به‌دڵنیایى په‌روه‌ردگارت زۆر باڵاده‌ست و به‌توانایه‌ بۆ كافران، وه‌ زۆر به‌ڕه‌حم و به‌زه‌ییه‌ بۆ باوه‌ڕداران. {گفتوگۆی نێوان هود پێغەمبەر - صلی الله علیه وسلم - و قەومەكەی}."
  26,123," قه‌ومی عادیش سه‌رجه‌م پێغه‌مبه‌رانیان به‌ درۆزانی، كه‌ باوه‌ڕیان به‌ پێغه‌مبه‌ره‌كه‌ی خۆیان نه‌هێنا واته‌ باوه‌ڕیان به‌ سه‌رجه‌م پێغه‌مبه‌ران نه‌هێناوه‌ (قه‌ومى عاد له‌ نزیك حه‌زره‌مه‌وت له‌ یه‌مه‌ن ده‌ژیان له‌ دواى قه‌ومى نوح ژیاون وه‌ زۆر به‌هێزو توانا بوونه‌)."
  26,124," كه‌ هود پێغه‌مبه‌ر - صلی الله علیه وسلم - له‌ هۆزو عه‌شیره‌تی خۆیان بوو پێی وتن بۆ ته‌قوای خوای گه‌وره‌ ناكه‌ن به‌وه‌ی كه‌ ئیمان بێنن."
  26,125," به‌ دڵنیایى من پێغه‌مبه‌رێكی ئه‌مینم بۆ ئێوه‌و په‌یامى خواى گه‌وره‌تان وه‌كو خۆى پێده‌گه‌یه‌نم به‌ بێ زیادو كه‌م."
  26,126," ده‌ى ئێوه‌یش ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵی من بكه‌ن [ وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ] وه‌ من داوای هیچ ئه‌جرو پاداشتێكتان لێ ناكه‌م له‌سه‌ر گه‌یاندنی دینه‌كه‌."
  26,127," به‌ڵكو ئه‌جرو پاداشتی من ته‌نها له‌سه‌ر په‌روه‌ردگاری هه‌موو جیهانه‌و ته‌نها چاوه‌ڕێى پاداشتم له‌و."
  26,128," ئایا ئێوه‌ له‌ هه‌موو شوێنێكی به‌رزو سه‌ر ڕێگاو له‌ شاخه‌ به‌رزه‌كاندا كۆشك و ته‌لاری به‌رزو پته‌و گه‌وره‌و سه‌ره‌نجڕاكێش دروست ئه‌كه‌ن له‌ كاتێكدا پێویستتان پێ نیه‌و ته‌نها بۆ فه‌خرو شانازی و ده‌رخستنى تواناتانه‌و ته‌نها كات به‌سه‌ر بردن و خۆماندوو كردن و به‌فیڕۆدانى تواناتانه‌  وه‌ كۆشك و ته‌لاری به‌رزو قه‌ڵاو شورای پته‌و دروست ده‌كه‌ن وه‌كو ئه‌وه‌ی كه‌ ئێوه‌ نه‌مرن و به‌هه‌میشه‌یی بمێننه‌وه‌  وه‌ كاتێك كه‌ بتانه‌وێ به‌سه‌ر كه‌سێكدا زاڵ بن زۆر به‌ توندوتیژی زاڵ ئه‌بن به‌سه‌ریدا له‌ ناحه‌قی و سته‌مدا  ده‌ى ئێوه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن و له‌ خوا بترسێن وه‌ گوێڕایه‌ڵی من بكه‌ن  وه‌ ته‌قوای ئه‌و خوایه‌ بكه‌ن كه‌ یارمه‌تی داون به‌و هه‌موو شته‌ی كه‌ خۆتان ئه‌زانن له‌ ماڵ و منداڵ و سه‌روه‌ت و سامان  یارمه‌تی داون و پشتیوانی كردوون به‌ جۆره‌ها ئاژه‌ڵ وه‌ به‌ منداڵ  وه‌ باخ و باخات و سه‌رچاوه‌ی ئاو و كانی و ڕووبارو بیره‌كان  ئه‌گه‌ر ئیمان نه‌هێنن و به‌رده‌وام بن له‌سه‌ر كوفرتان ئه‌وه‌ من له‌وه‌ ئه‌ترسێم كه‌ خوای گه‌وره‌ سزاتان بدات له‌ ڕۆژێكی زۆر گه‌وره‌دا كه‌ ڕۆژی قیامه‌ته‌  وتیان: ئه‌ى هود - صلی الله علیه وسلم - یه‌كسانه‌ ئه‌گه‌ر تۆ ئامۆژگاریمان بكه‌ی یان نه‌یكه‌ی ئێمه‌ گوێ به‌ ئامۆژگاری تۆ ناده‌ین وه‌ به‌ قسه‌ت ناكه‌ین و ده‌ستبه‌ردارى دین و خواكانمان نابین."
  26,129," وه‌ كۆشك و ته‌لاری به‌رزو قه‌ڵاو شورای پته‌و دروست ده‌كه‌ن وه‌كو ئه‌وه‌ی كه‌ ئێوه‌ نه‌مرن و به‌هه‌میشه‌یی بمێننه‌وه‌."
  26,130," وه‌ كاتێك كه‌ بتانه‌وێ به‌سه‌ر كه‌سێكدا زاڵ بن زۆر به‌ توندوتیژی زاڵ ئه‌بن به‌سه‌ریدا له‌ ناحه‌قی و سته‌مدا."
  26,131," ده‌ى ئێوه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن و له‌ خوا بترسێن وه‌ گوێڕایه‌ڵی من بكه‌ن."
  26,132," وه‌ ته‌قوای ئه‌و خوایه‌ بكه‌ن كه‌ یارمه‌تی داون به‌و هه‌موو شته‌ی كه‌ خۆتان ئه‌زانن له‌ ماڵ و منداڵ و سه‌روه‌ت و سامان."
  26,133," یارمه‌تی داون و پشتیوانی كردوون به‌ جۆره‌ها ئاژه‌ڵ وه‌ به‌ منداڵ."
  26,134," وه‌ باخ و باخات و سه‌رچاوه‌ی ئاو و كانی و ڕووبارو بیره‌كان."
  26,135," ئه‌گه‌ر ئیمان نه‌هێنن و به‌رده‌وام بن له‌سه‌ر كوفرتان ئه‌وه‌ من له‌وه‌ ئه‌ترسێم كه‌ خوای گه‌وره‌ سزاتان بدات له‌ ڕۆژێكی زۆر گه‌وره‌دا كه‌ ڕۆژی قیامه‌ته‌."
  26,136," وتیان: ئه‌ى هود - صلی الله علیه وسلم - یه‌كسانه‌ ئه‌گه‌ر تۆ ئامۆژگاریمان بكه‌ی یان نه‌یكه‌ی ئێمه‌ گوێ به‌ ئامۆژگاری تۆ ناده‌ین وه‌ به‌ قسه‌ت ناكه‌ین و ده‌ستبه‌ردارى دین و خواكانمان نابین."
  26,137," ئه‌م بیروباوه‌ڕه‌ى كه‌ ئێمه‌ی له‌سه‌رین ئه‌مه‌ ڕه‌وشت و داب و نه‌ریت و دینى باوك و باپیرانمانه‌و بۆمان ماوه‌ته‌وه‌و لاسایی ئه‌وان ده‌كه‌ینه‌وه‌ و له‌سه‌رى ده‌ڕۆین، یاخود ئه‌م دینه‌ى تۆ بۆت هێناوین هیچ شتێك نیه‌ ته‌نها به‌سه‌رهات و سه‌رگوزشته‌ى ئوممه‌تانى پێشتره‌و تۆ له‌لایه‌ن خواوه‌ نه‌نێردراوى، یاخود خوای گه‌وره‌ ده‌فه‌رمووێ: ئه‌م به‌درۆزانینه‌ی ئه‌وان وه‌كو به‌درۆزانینى سه‌رجه‌م ئوممه‌تانی پێشتر وایه‌."
  26,138," وه‌ ئه‌یانووت: ئێمه‌ له‌سه‌ر ئه‌م شته‌ سزا نادرێین."
  26,139,"[ فَكَذَّبُوهُ ] هود پێغه‌مبه‌ریان - صلی الله علیه وسلم - به‌درۆ زانی [ فَأَهْلَكْنَاهُمْ ] ئێمه‌ش بایه‌كى ساردى سه‌ختى به‌رده‌واممان بۆ ناردن و له‌ناومان بردن  به‌ دڵنیایى ئه‌مه‌ به‌ڵگه‌و نیشانه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌ هه‌ر چه‌نده‌ زۆربه‌یان ئیمانیان نه‌هێنا."
  26,140," وه‌ به‌دڵنیایى په‌روه‌ردگارت زۆر به‌عیززه‌ت و باڵاده‌سته‌ بۆ كافران، وه‌ زۆر به‌ڕه‌حم و به‌زه‌ییه‌ به‌ باوه‌ڕداران."
  26,141,"{گفتوگۆی نێوان ساڵح پێغەمبەر - صلی الله علیه وسلم - و قەومەكەی}  قه‌ومی ثهمودیش سه‌رجه‌م پێغه‌مبه‌رانیان به‌درۆ زانی، له‌به‌ر ئه‌وه‌ی باوه‌ڕیان به‌ پێغه‌مبه‌ره‌كه‌ی خۆیان نه‌بوو وه‌ك ئه‌وه‌ وایه‌ باوه‌ڕیان به‌ هیچ پێغه‌مبه‌رێك نه‌بووبێت (له‌ حیجر نیشته‌جێ بوون له‌ نێوان وادى القرى و وڵاتى شام، له‌ پاش قه‌ومى عاد ژیاون پێش ئیبراهیم پێغه‌مبه‌ر - صلی الله علیه وسلم - وه‌ عه‌ره‌ب بوونه‌)."
  26,142," صاڵح پێغه‌مبه‌ریش - صلی الله علیه وسلم - كه‌ له‌ هۆزو عه‌شیره‌تی خۆیان بوو پێی وتن ئه‌وه‌ بۆ ته‌قوای خوای گه‌وره‌ ناكه‌ن."
  26,143," به‌ دڵنیایى من پێغه‌مبه‌رێكی ئه‌مینم بۆ ئێوه‌و په‌یامى خواى گه‌وره‌تان وه‌كو خۆى پێده‌گه‌یه‌نم به‌بێ زیادو كه‌م."
  26,144," وه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵی من بكه‌ن [ وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ] وه‌ من له‌ گه‌یاندنی دینه‌كه‌ى خواى گه‌وره‌دا داوای ئه‌جرو پاداشت و پاره‌ له‌ ئێوه‌ ناكه‌م."
  26,145," به‌ڵكو ئه‌جرو پاداشتی من ته‌نها له‌سه‌ر په‌روه‌ردگاری هه‌موو جیهانه‌و ته‌نها چاوه‌ڕوانى پاداشتم له‌و."
  26,146," ئایا ئێوه‌ واده‌زانن وازتان لێ ئه‌هێنرێ له‌و نازو نیعمه‌ته‌ی كه‌ خوای گه‌وره‌ پێی به‌خشیوون به‌ ئه‌مینی بمێننه‌وه‌و مردن و سزاتان به‌سه‌ردا نه‌یات، نه‌خێر شتی وا نیه‌و خۆتان مه‌خه‌ڵه‌تێنن."
  26,147," له‌ناو باخ و باخات و له‌سه‌رچاوه‌ی ئاو و كانی و ڕووباره‌كان هه‌روا نامێنێته‌وه‌."
  26,148," وه‌ له‌و كشتوكاڵانه‌ى كه‌ هه‌تانه‌، وه‌ له‌و دار خورمایانه‌ی كه‌ لق و په‌له‌كانیان له‌به‌ر زۆری خورما پێوه‌ی شۆڕ بۆته‌ خواره‌وه‌و زۆر پڕو تێكهه‌ڵكێشه‌، یاخود پێگه‌یشتووه‌و هاتۆته‌ به‌رهه‌م و بێناوكه‌ هه‌روا نامێننه‌وه‌."
  26,149," وه‌ له‌ناو شاخه‌كانیشدا زۆر به‌ لێهاتوویی ماڵ دروست ئه‌كه‌ن و هه‌ڵیده‌كۆڵن بۆ فه‌خرو شانازی كردن به‌بێ ئه‌وه‌ی كه‌ پێویستتان بێت."
  26,150," ده‌ى ئێوه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵی من بكه‌ن."
  26,151," وه‌ گوێڕایه‌ڵی موشریكان مه‌كه‌ن كه‌ ئیسراف و زیادڕه‌ویان كردووه‌ له‌ تاوان و شیركدا كه‌ بانگه‌وازتان ده‌كه‌ن بۆ كوفرو شیرك و تاوان."
  26,152," ئه‌و كه‌سانه‌ی كه‌ ئاشووب ئه‌گێڕن له‌سه‌ر زه‌ویدا وه‌ چاكسازی ناكه‌ن."
  26,153," وتیان: تۆ هیچ كه‌سێك نیت ته‌نها یه‌كێك نه‌بێت له‌وانه‌ی كه‌ جادووت لێكراوه‌و ده‌ستت لێوه‌شێندراوه‌."
  26,154,"[ مَا أَنْتَ إِلَّا بَشَرٌ مِثْلُنَا ] وه‌ تۆ هیچ كه‌سێك نیت ته‌نها مرۆڤێكی وه‌كو ئێمه‌ نه‌بێت ئیتر چۆن له‌ناو ئێمه‌دا وه‌حى بۆ تۆ هاتووه‌  ئه‌گه‌ر ڕاست ئه‌كه‌ی تۆ پێغه‌مبه‌رى خوایت موعجیزه‌یه‌كمان بۆ بێنه‌ له‌لایه‌ن خوای گه‌وره‌وه‌."
  26,155,"{حوشترەكەی ساڵح پێغەمبەر - صلی الله علیه وسلم - }  له‌سه‌ر داواو پێشنیاری خۆیان خوای گه‌وره‌ حوشترێكی له‌ناو تاوێرێك به‌ زیندوویی بۆ ده‌ركردن كه‌ به‌ چاوی خۆیان بینیان وه‌كو به‌ڵگه‌یه‌ك له‌سه‌ر ڕاستێتی پێغه‌مبه‌رایه‌تی صاڵح - صلی الله علیه وسلم - ، كه‌ پێى فه‌رمووی: ئه‌مه‌ حوشترێكه‌ ڕۆژی ئاودانی ئه‌و جیاوازه‌ له‌ ڕۆژی چوونه‌ سه‌ر ئاوی ئێوه‌و لێی نزیك نه‌بنه‌وه‌ له‌و ڕۆژه‌ی كه‌ سه‌ره‌ی خۆیه‌تی."
  26,156,"[ وَلَا تَمَسُّوهَا بِسُوءٍ ] وه‌ به‌ خراپه‌ ده‌ستی بۆ نه‌به‌ن و سه‌ری نه‌بڕن  ئه‌و كاته‌ سزای ڕۆژێكی گه‌وره‌ ئه‌تانگرێته‌وه‌."
  26,157," به‌ڵام ئه‌وان سه‌ریانبڕی و دوای ئه‌وه‌ى كه‌ دڵنیا بوون سزای خوای گه‌وره‌یان بۆ دێت په‌شیمان بوونه‌وه‌ به‌ڵام په‌شیمانی سوودی بۆیان نه‌بوو."
  26,158,"[ فَأَخَذَهُمُ الْعَذَابُ ] خوای گه‌وره‌ سزایدان، سزایه‌ك كه‌ زه‌ویه‌كه‌یان له‌ ژێردا هه‌ژا، وه‌ له‌ بانیشه‌وه‌ خوای گه‌وره‌ ده‌نگێكی بۆ ناردن و له‌ناوی بردن [ إِنَّ فِي ذَلِكَ لَآيَةً ] به‌ دڵنیایی ئه‌مانه‌ هه‌موو به‌ڵگه‌و نیشانه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌  هه‌ر چه‌نده‌ زۆربه‌یان ئیمانیان نه‌هێنا."
  26,159," وه‌ به‌ دڵنیایی په‌روه‌ردگارت زۆر به‌عیززه‌ت و باڵاده‌سته‌ بۆ كافران، وه‌ زۆر به‌ڕه‌حم و سۆزو به‌زه‌ییه‌ بۆ باوه‌ڕداران."
  26,160,"{گفتوگۆی نێوان لوگ پێغەمبەر - صلی الله علیه وسلم - و قەومەكەی}  قه‌ومی لوطيش - صلی الله علیه وسلم - سه‌رجه‌م پێغه‌مبه‌رانیان به‌درۆ زانی، كه‌ باوه‌ڕیان به‌ پێغه‌مبه‌ره‌كه‌ی خۆیان نه‌بوو واته‌: باوه‌ڕیان به‌ سه‌رجه‌م پێغه‌مبه‌ران نه‌بووه‌ (له‌ سه‌دوم نیشته‌جێ بوونه‌ نزیك بیت المقدس، وه‌ خواى گه‌وره‌ له‌ناوى بردون و له‌شوێنى ئه‌وان ده‌ریاچه‌یه‌كى بۆگه‌نى داناوه‌، لوط كوڕى هاران كوڕى ئازه‌ر بووه‌ برازاى ئیبراهیم پێغه‌مبه‌ر - صلی الله علیه وسلم - بووه‌)."
  26,161," كاتێك لوط - صلی الله علیه وسلم - كه‌ له‌ هۆزو عه‌شیره‌تی خۆیان بوو پێی فه‌رموون: ئه‌وه‌ بۆ ته‌قوای خوای گه‌وره‌ ناكه‌ن وه‌ ئیمان ناهێنن."
  26,162," به‌دڵنیایى من پێغه‌مبه‌رێكی ئه‌مینم بۆ ئێوه‌و په‌یامى خواى گه‌وره‌تان وه‌كو خۆى پێده‌گه‌یه‌نم به‌بێ زیادو كه‌م."
  26,163," ده‌ى ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵی من بكه‌ن."
  26,164,"[ وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ] وه‌ من داوای هیچ ئه‌جرو پاداشتێك له‌ ئێوه‌ ناكه‌م له‌ گه‌یاندنی دینه‌كه‌  به‌ڵكو ئه‌جرو پاداشتی من ته‌نها له‌سه‌ر خوای گه‌وره‌یه‌و خوای گه‌وره‌ ئه‌جرو پاداشتم ئه‌داته‌وه‌."
  26,165," ئایا ئێوه‌ ئه‌ڕۆن نێربازی ئه‌كه‌ن له‌گه‌ڵ ئاده‌میزاددا."
  26,166,"[ وَتَذَرُونَ مَا خَلَقَ لَكُمْ رَبُّكُمْ مِنْ أَزْوَاجِكُمْ ] وه‌ واز له‌و ئافره‌تانه‌ دێنن كه‌ خوای گه‌وره‌ بۆ ئێوه‌ی دروست كردوون  به‌ڵكو ئێوه‌ قه‌ومێكن به‌ڕاستی سنوورتان به‌زاندووه‌."
  26,167," وتیان: ئه‌ی (لوط) ئه‌گه‌ر واز له‌م قسانه‌ نه‌هێنی ئه‌وا شاربه‌ده‌رت ئه‌كه‌ین."
  26,168," (لوط) - صلی الله علیه وسلم - فه‌رمووی: من ڕقم له‌م كرده‌وه‌ی ئێوه‌یه‌و پێى رازی نیم و به‌ریم لێى."
  26,169," ئه‌ی په‌روه‌ردگار خۆم و شوێنكه‌وتوانم ڕزگار بكه‌ له‌م كرده‌وه‌ خراپه‌ی ئه‌مان كاتێك كه‌ سزایان ئه‌ده‌ی."
  26,170," خوای گه‌وره‌ ئه‌فه‌رمووێ: خۆی و كه‌سوكاری واته‌: شوێنكه‌وتوانی هه‌موومان ڕزگار كردن."
  26,171," ته‌نها پیره‌ژنێك نه‌بێ كه‌ خێزانه‌كه‌ی بوو له‌ناو سزادا مایه‌وه‌ له‌به‌ر ئه‌وه‌ی باوه‌ڕی نه‌هێنابوو، وه‌ لوط - صلی الله علیه وسلم - میوانى بهاتایا خه‌ڵگى ئاگادار ده‌كرده‌وه‌ تا بێنه‌سه‌ر میوانه‌كانى و ده‌ستدرێژى بكه‌نه‌ سه‌ریان، خوای گه‌وره‌ ئه‌ویشی سزاداو له‌ناوى بردو به‌ردبارانى كردن."
  26,172," پاشان ئه‌وانه‌ی ترمان هه‌موو له‌ناوبرد."
  26,173,"[ وَأَمْطَرْنَا عَلَيْهِمْ مَطَرًا ] وه‌ به‌ردبارانمان كردن له‌ ئاسمانه‌وه‌  كه‌ به‌ڕاستی خراپترین به‌ردبارانێك بوو كه‌ ئه‌وان پێی به‌ردباران كران ئه‌وانه‌ی كه‌ ئاگادار كرابوونه‌وه‌."
  26,174,"[ إِنَّ فِي ذَلِكَ لَآيَةً ] به‌دڵنیایى ئه‌مه‌ هه‌مووی به‌ڵگه‌و نیشانه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌  هه‌ر چه‌نده‌ زۆربه‌یان باوه‌ڕیان نه‌هێناوه‌و باوه‌ڕدار نه‌بوون."
  26,175," وه‌ به‌ دڵنیایى په‌روه‌ردگارت زۆر به‌عیززه‌ت و باڵاده‌سته‌ بۆ كافران، وه‌ زۆر به‌ڕه‌حم و سۆزو به‌زه‌ییه‌ به‌ باوه‌ڕداران."
  26,176,"{گفتوگۆی نێوان شوعەیب پێغەمبەر - صلی الله علیه وسلم - و قەومەكەی}  (ئه‌صحابی ئه‌یكه‌) واته‌: قه‌ومی شوعه‌یب پێغه‌مبه‌ر - صلی الله علیه وسلم - كه‌ دارێكیان ئه‌په‌رست لای (مه‌دیه‌ن) خوای گه‌وره‌ ئه‌فه‌رمووێ: ئه‌وانیش سه‌رجه‌م پێغه‌مبه‌رانیان به‌درۆ زانی."
  26,177," شوعه‌یب - صلی الله علیه وسلم - پێی فه‌رموون: ئه‌وه‌ بۆ ته‌قوای خوای گه‌وره‌ ناكه‌ن به‌وه‌ی كه‌ ئیمان بێنن."
  26,178," من پێغه‌مبه‌رێكی ئه‌مینم بۆ ئێوه‌و په‌یامى خواى گه‌وره‌تان وه‌كو خۆى پێده‌گه‌یه‌نم به‌بێ زیادو كه‌م."
  26,179," ده‌ى ئێوه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵی من بكه‌ن."
  26,180,"[ وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ] وه‌ من داوای هیچ ئه‌جرو پاداشتێك له‌ ئێوه‌ ناكه‌م له‌سه‌ر گه‌یاندنی دینه‌كه‌  به‌ڵكو ئه‌جرو پاداشتی من ته‌نها له‌سه‌ر په‌روه‌ردگاری هه‌موو جیهانه‌و ئه‌و ئه‌جرو پاداشتم ئه‌داته‌وه."
  26,181,"‌[ أَوْفُوا الْكَيْلَ ] با كێشانه‌و پێوانه‌تان به‌ته‌واوی بێت  وه‌ له‌و كه‌سانه‌ مه‌بن كه‌ له‌ فرۆشتندا به‌ كه‌می و سوكى ئه‌یكێشن و كه‌م به‌ خه‌ڵكى ئه‌ده‌ن، به‌ڵام بۆ خۆیان بیكڕن به‌ قورسى ده‌یكێشن."
  26,182," وه‌ به‌ پێوانه‌و كێشانه‌و ته‌رازویه‌كی دادپه‌روه‌رانه‌ شت به‌ خه‌ڵكی بده‌ن و حه‌قی خۆیان پێ بده‌ن."
  26,183,"[ وَلَا تَبْخَسُوا النَّاسَ أَشْيَاءَهُمْ ] وه‌ شتێكتان به‌ خه‌ڵكدا مافی خه‌ڵكى به‌ كه‌م مه‌زانن و به‌ كه‌م و سوك مه‌یانده‌نێ  وه‌ له‌سه‌ر زه‌ویشدا ئاشووب مه‌گێڕن و رێگرى مه‌كه‌ن."
  26,184," وه‌ ته‌قوای ئه‌و خوایه‌ بكه‌ن كه‌ ئێوه‌و ئوممه‌تانی پێش ئێوه‌یشی دروست كردووه‌."
  26,185," وتیان: ئه‌ی شوعه‌یب به‌ڕاستی تۆ له‌و كه‌سانه‌ی كه‌ جادوو سیحرت لێكراوه‌."
  26,186,"[ وَمَا أَنْتَ إِلَّا بَشَرٌ مِثْلُنَا ] وه‌ تۆ هیچ شتێك نیت ته‌نها مرۆڤێكی وه‌كو ئێمه‌  وه‌ ئێمه‌ گومانی ئه‌وه‌ ئه‌به‌ین كه‌ تۆ له‌ درۆزانانى كه‌ ئه‌ڵێی من پێغه‌مبه‌ری خوام."
  26,187,"[ فَأَسْقِطْ عَلَيْنَا كِسَفًا مِنَ السَّمَاءِ ] ئه‌گه‌ر ڕاست ئه‌كه‌یت تۆ پێغه‌مبه‌رى خوایت ئه‌وه‌ پارچه‌یه‌ك له‌ ئاسمان به‌رده‌وه‌ بان سه‌رمان، یان ئاگرێك له‌ ئاسمانه‌وه‌ بێت و سزامانی پێ بده‌  ئه‌گه‌ر تۆ له‌ ڕاستگۆیانى و پێغه‌مبه‌ری خوایت و له‌لایه‌ن خوای گه‌وره‌وه‌ نێردراوی."
  26,188," شوعه‌یب - صلی الله علیه وسلم - فه‌رمووی: په‌روه‌ردگارم زاناتره‌ به‌وه‌ی كه‌ ئێوه‌ ئه‌یكه‌ن له‌ شیرك و سه‌رپێچى و تاوان، وه‌ به‌ ده‌ست خوای گه‌وره‌یه‌ كه‌ سزاتان بدات به‌ ده‌ست من نیه‌."
  26,189,"[ فَكَذَّبُوهُ ] ئه‌وان شوعه‌یبیان - صلی الله علیه وسلم - به‌درۆیان زانی [ فَأَخَذَهُمْ عَذَابُ يَوْمِ الظُّلَّةِ ] وه‌ خوای گه‌وره‌ سزای دان له‌ ڕۆژی سێبه‌ره‌كه‌، حه‌وت رۆژ توشى گه‌رمایه‌كى سه‌خت بوون هیچ سێبه‌ریك نه‌بوو بچنه‌ ژێریه‌وه‌، خواى گه‌وره‌ پارچه‌یه‌ك هه‌وری نارد سێبه‌ری بۆ كردن، وایانزانی سێبه‌ره‌ هه‌موویان چوونه‌ ژێری و كۆبوونه‌وه‌، خوای گه‌وره‌ له‌و هه‌وره‌وه‌ ئاگرو بڵێسه‌یه‌كى گه‌وره‌ی بارانده‌ سه‌ریان وه‌كو خۆیان داوایان كرد، وه‌ زه‌وى له‌ ژێریاندا هه‌ژاند، وه‌ ده‌نگێكى گه‌وره‌ى ناردو گیانى كێشان و له‌ ناوى بردن  به‌ دڵنیایی ئه‌وه‌ سزای ڕۆژێكی زۆر سه‌خت و گه‌وره‌ بوو."
  26,190,"[ إِنَّ فِي ذَلِكَ لَآيَةً ] به‌ دڵنیایى ئه‌مه‌ هه‌مووی نیشانه‌و به‌ڵگه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌  هه‌ر چه‌نده‌ زۆربه‌یان ئیمانیان نه‌هێنا."
  26,191," وه‌ به‌ دڵنیایى په‌روه‌ردگارت زۆر به‌عیززه‌ت و باڵاده‌سته‌ بۆ كافران، وه‌ زۆر به‌ڕه‌حم و سۆزو به‌زه‌ییه‌ به‌ باوه‌ڕداران."
  26,192," وه‌ ئه‌ی محمد - صلی الله علیه وسلم - ئه‌م قورئانه‌ پیرۆزه‌ش له‌لایه‌ن په‌روه‌ردگاری هه‌موو جیهانه‌وه‌ بۆ تۆ دابه‌زێندراوه‌."
  26,193," كه‌ ئه‌و روحه‌ ئه‌مینه‌ دایبه‌زاندووه‌ كه‌ جبریله‌."
  26,194,"[ عَلَى قَلْبِكَ ] بۆ سه‌ر دڵی تۆ  بۆ ئه‌وه‌ی تۆش یه‌كێك بیت له‌وانه‌ی كه‌ خه‌ڵكی ئاگادار ئه‌كه‌یته‌وه‌و ده‌یانترسێنیت له‌ سزاى خواى گه‌وره‌ ئه‌گه‌ر ئیمان نه‌هێنن."
  26,195," به‌ زمانێكی عه‌ره‌بی ئاشكرا، ئه‌گه‌ر به‌ زمانێكی تر بوایه‌ موشریكانی عه‌ره‌ب ده‌یانووت: ئێمه‌ لێی تێناگه‌ین."
  26,196," وه‌ ئه‌م قورئانه‌ له‌ كتێبه‌كانی سه‌ره‌تایشه‌وه‌ وه‌كو ته‌ورات و ئینجیل باسكراوه‌و موژده‌ی پێدراوه‌، یاخود له‌ زه‌بورى داود پێغه‌مبه‌ر - صلی الله علیه وسلم - باسكراوه‌."
  26,197," ئایا زانا دادپه‌روه‌ره‌كانی به‌نی ئیسرائیل كه‌ موسڵمان بوونه‌و شایه‌تن له‌سه‌ر راستى ئه‌م قورئانه‌و له‌ كتابه‌كانى خۆیان بینیویانه‌ وه‌كو (عبدالله¬ی كوڕی سه‌لام و سه‌لمانى فارسی) به‌س نیه‌و به‌ڵگه‌ نیه‌ بۆ ئه‌وان كه‌ موسڵمان بن."
  26,198," وه‌ ئه‌گه‌ر ئه‌م قورئانه‌مان داببه‌زاندایه‌ته‌ سه‌ر كه‌سانێكی جگه‌ له‌ عه‌ره‌ب كه‌ هیچ عه‌ره‌بی نه‌زانن."
  26,199," وه‌ به‌ عه‌ره‌بیش به‌سه‌ریاندا بیخوێندایه‌ته‌وه‌ ئه‌وه‌ ئه‌و كاته‌ ئیمانیان نه‌ئه‌هێنا، واته‌: ئه‌و موعجیزانه‌ی تیایدایه‌ ده‌رنه‌ئه‌كه‌وت."
  26,200," به‌م شێوازه‌ شیرك و به‌درۆ زانینمان خستۆته‌ دڵی تاوانباران و خراپه‌كارانه‌وه‌."
  26,201,"[ لَا يُؤْمِنُونَ بِهِ ] ئه‌وان ئیمانی پێ ناهێنن  تا سزای به‌ ئێش و ئازار به‌ چاوی خۆیان نه‌بینن و خوای گه‌وره‌ سزایان نه‌دات."
  26,202," وه‌ ئه‌و سزایه‌ش له‌ ناكاودا بۆیان دێت و ئه‌وان هه‌ست ناكه‌ن به‌ هاتنی."
  26,203," ئه‌و كاته‌ ئه‌ڵێن: ئایا ئێمه‌ دواخراوین و مۆڵه‌ت پێ دراوین، واته‌ خۆزگه‌ دوابخراینایه‌و مۆڵه‌تمان پێ بدرایه‌، یان بگه‌ڕاینایه‌ته‌وه‌ بۆ دونیا."
  26,204," ئایا ئه‌وان په‌له‌ ئه‌كه‌ن له‌ سزای ئێمه‌و داوای سزای ئێمه‌ ئه‌كه‌ن."
  26,205," ئایا پێم بڵێ ئه‌گه‌ر چه‌نده‌ها ساڵی تریش له‌ ژیاندا بیانژیه‌نین و ته‌مه‌نیان درێژ بكه‌ین."
  26,206," پاشان ئه‌و هه‌ڕه‌شانه‌ی كه‌ لێیان كراوه‌ به‌ سزا بۆیان بێت و سزایان بده‌ین."
  26,207," ئه‌و ته‌مه‌ن درێژی و ڕابواردنه‌ی له‌ ژیاندا به‌سه‌ریان برد هیچ سوودیان پێ ناگه‌یه‌نێ."
  26,208," وه‌ ئێمه‌ هیچ دێ و شارێكمان له‌ناو نه‌بردووه‌ ئیلا پێغه‌مبه‌رو ئاگاداركه‌ره‌وه‌مان بۆ ناردوون."
  26,209," ئه‌م هه‌واڵانه‌ هه‌مووی یادخستنه‌وه‌یه‌ بۆ خه‌ڵكی وه‌ ئێمه‌ سته‌م له‌ خه‌ڵكی ناكه‌ین."
  26,210," وه‌ ئه‌م قورئانه‌ پیرۆزه‌یش شه‌یتان نه‌یهێناوه‌ته‌ خواره‌وه‌و له‌لایه‌ن شه‌یتانه‌وه‌ نیه‌ وه‌كو چۆن شه‌یتان قسه‌ بۆ كاهین و فاڵچیان دێنن."
  26,211,"[ وَمَا يَنْبَغِي لَهُمْ ] وه‌ شه‌یتانه‌كان بۆیان نیه‌و ئیشى ئه‌وان نیه‌ به‌ڵكو ئیشى ئه‌وان خراپه‌و ئاشوبگێڕانه‌  وه‌ توانای ئه‌م شته‌شیان نیه‌ له‌به‌ر ئه‌وه‌ی ئاسمان پارێزراوه‌ به‌ فریشته‌كان."
  26,212," به‌دڵنیایى ئه‌وان له‌ بیستنی قورئان جیا كراونه‌ته‌وه‌و په‌رده‌و شیهاب و نه‌یزه‌ك هه‌یه‌ به‌و نه‌یزه‌كانه‌ خوای گه‌وره‌ ده‌یانسووتێنێ."
  26,213,"[ فَلَا تَدْعُ مَعَ اللَّهِ إِلَهًا آخَرَ ] تۆ له‌گه‌ڵ خوای گه‌وره‌دا له‌ خوایه‌كی تر مه‌پاڕێره‌وه‌و خوایه‌كى تر مه‌په‌رسته‌  له‌به‌ر ئه‌وه‌ی دواتر خوای گه‌وره‌ سزات ئه‌دات و له‌ سزادراوان ئه‌بی، واته‌: ئه‌گه‌ر پێغه‌مبه‌ری خوایش - صلی الله علیه وسلم - شه‌ریك بۆ خوا دابنێت خوای گه‌وره‌ سزای ئه‌دات چ جای ئێوه‌، هه‌رچه‌نده‌ ئه‌و شه‌ریك بۆ خوا دانانێت."
  26,214," وه‌ خزم و كه‌سوكاره‌ نزیكه‌كانت ئاگادار بكه‌وه‌، كه‌ ئه‌م ئایه‌ته‌ دابه‌زى پێغه‌مبه‌رى خوا - صلی الله علیه وسلم - كه‌سوكارو خزمه‌ نزیكه‌كانى بانگ كردو كۆكرده‌وه‌و ئاگادارى كردنه‌وه‌ له‌ سزاى خواى گه‌وره‌ ئه‌گه‌ر ئیمان نه‌هێنن، وه‌ ئه‌م تواناى نیه‌ هیچیان بۆ بكات له‌ رۆژى قیامه‌ت ئه‌گه‌ر كرده‌وه‌ى چاكى خۆیان نه‌بێت."
  26,215," وه‌ باڵی خۆت شۆڕ بكه‌و نه‌رمونیان به‌، وه‌ خۆشه‌ویستی بۆ ئه‌و باوه‌ڕدارانه‌ ده‌ربڕه‌ كه‌ شوێنت كه‌وتوون."
  26,216,"[ فَإِنْ عَصَوْكَ ] وه‌ ئه‌گه‌ر ئه‌وان سه‌رپێچی تۆیان كرد  ئه‌و كاته‌ بڵێ: من به‌ریم له‌ هه‌ر كرده‌وه‌یه‌ك كه‌ ئێوه‌ ئه‌یكه‌ن"
  26,217," وه‌ پشت به‌و خوایه‌ ببه‌سته‌و كاره‌كانت به‌و خوایه‌ بسپێره‌ كه‌ زۆر به‌عیززه‌ت و باڵاده‌سته‌ به‌رامبه‌ر كافران، وه‌ زۆر به‌ڕه‌حم و سۆزو به‌زه‌ییه‌ به‌رامبه‌ر باوه‌ڕداران."
  26,218," ئه‌و خوایه‌ی كه‌ تۆ ئه‌بینێ كاتێك ڕاوه‌ستاوی نوێژ ئه‌كه‌ی."
  26,219," وه‌ كاتێك كه‌ ئه‌چیته‌ ڕكوع و سجود، یان كاتێك به‌ته‌نها نوێژ ئه‌كه‌ی ئه‌تبینێ وه‌ كاتێك كه‌ له‌گه‌ڵ كڕنوشبه‌راندا كڕنوش ئه‌به‌ی خوای گه‌وره‌ ئه‌تبینێ."
  26,220," به‌ دڵنیایی خوای گه‌وره‌ زۆر بیسه‌ره‌ به‌ وته‌تان، وه‌ زۆر زانایه‌ به‌ جوله‌ و راوه‌ستانتان."
  26,221," ئایا پێتان بڵێم شه‌یتان دائه‌به‌زێته‌ سه‌ر كێ؟"
  26,222," دائه‌به‌زێته‌ سه‌ر هه‌موو كه‌سێك كه‌ زۆر درۆ ئه‌كات و زۆر تاوانباره‌، واته‌: فاڵچیان و جادووگه‌ران."
  26,223,"[ يُلْقُونَ السَّمْعَ ] ئه‌وان گوێ له‌ هه‌ندێك شت ئه‌گرن تا بیدزن و بیهێنن بۆ فاڵچیان  به‌ڵام زۆربه‌ی ئه‌و فاڵچیانه‌ درۆ ئه‌كه‌ن له‌وه‌ی كه‌ شتیان له‌ شه‌یتانه‌وه‌ بیستبێ."
  26,224,"{شاعيران دوو جۆرن}  دوو شاعیر هه‌جوى یه‌كیان كردو قسه‌یان به‌ یه‌ك كرد، كه‌سانێكى خراپ و گێل شوێنیان كه‌وتن، خواى گه‌وره‌ ئه‌م ئایه‌ته‌ى دابه‌زاند: وه‌ شاعیرانیش خه‌ڵكی خراپ شوێنیان ئه‌كه‌وێت."
  26,225," ئایا نابینی ئه‌وان له‌ هه‌موو دۆڵێكدا قسه‌ ئه‌كه‌ن و ڕۆئه‌چن، واته‌: له‌ هه‌موو بوارێكدا قسه‌ ئه‌كه‌ن، جارێك مه‌دح و سه‌ناى خه‌ڵكى ده‌كه‌ن به‌ ناحه‌ق، وه‌ جارێك قسه‌ ده‌كه‌ن به‌ خه‌ڵكى به‌ ناحه‌ق، وه‌ جارێك باسى ئافره‌ت ده‌كه‌ن، بۆیه‌ پێغه‌مبه‌ری خوا - صلی الله علیه وسلم - ده‌فه‌رمێت: (ئه‌گه‌ر یه‌كێك له‌ ئێوه‌ پڕ سكى له‌ كێماو و زوخاو بێت باشتره‌ له‌وه‌ى كه‌ سكى پڕ بێت له‌م جۆره‌ شیعرانه‌)."
  26,226," وه‌ ئه‌وه‌ی كه‌ ئه‌وان به‌ ده‌م ئه‌یڵێن به‌ كرده‌وه‌ نایسه‌لمێنن، ئه‌ڵێ: وامان كردو نه‌یان كردووه‌."
  26,227,"[ إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ ] كه‌ زه‌مى شاعیران كرا (حه‌سانى كوڕى سابت و عبدالله¬ى كوڕى ره‌وواحه‌و كه‌عبى كوڕى مالیك) به‌ گریانه‌وه‌ هاتن بۆ لاى پێغه‌مبه‌ری خوا - صلی الله علیه وسلم - وتیان: خواى گه‌وره‌ كه‌ ئه‌م ئایه‌ته‌ى دابه‌زاندووه‌ ده‌زانێت ئێمه‌ شاعیرین و مه‌به‌ستى ئێمه‌یه‌، خواى گه‌وره‌ ئه‌م ئایه‌ته‌ى دابه‌زاندو شاعیره‌ باوه‌ڕداره‌كانى جیا كرده‌وه‌و فه‌رمووى: ته‌نها ئه‌و شاعیرانه‌ نه‌بێ كه‌ باوه‌ڕدارن وه‌ كرده‌وه‌ی چاكیان كردووه‌ [ وَذَكَرُوا اللَّهَ كَثِيرًا ] وه‌ زۆر زیكرو یادی خوای گه‌وره‌یان كردووه‌ به‌ شیعره‌كانیان [ وَانْتَصَرُوا مِنْ بَعْدِ مَا ظُلِمُوا ] وه‌ دوای ئه‌وه‌ی كه‌ سته‌میان لێكراوه‌ خۆیان سه‌ر ئه‌كه‌ون به‌سه‌ر كافران و بێباوه‌ڕان و به‌ شیعر وه‌ڵامیان ئه‌ده‌نه‌وه‌و به‌رگری له‌ دین ئه‌كه‌ن  وه‌ ئه‌و زاڵم و سته‌مكارانه‌ له‌ داهاتوویه‌كی نزیكدا ئه‌زانن به‌ره‌و كوێ وه‌رئه‌گێڕدرێنه‌وه‌ له‌ناو ئاگری دۆزه‌خداو ئه‌مدیو دیو ئه‌كرێن، واته‌: خراپی سه‌ره‌نجامیان له‌ ڕۆژی قیامه‌تدا ئه‌زانن، والله أعلم ."
