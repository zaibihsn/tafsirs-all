tafsir[50]{c,v,t}:
  77,1,"سووره‌تی (موڕسه‌لات) (واته‌: نێردراوان) سووره‌تێكى مه‌ككى یه‌ ته‌نها ئایه‌تى (٤٨) نه‌بێت كه‌ مه‌ده‌نى یه‌و (٥٠) ئایه‌ته‌ (عبدالله ى كوڕى مه‌سعود) ده‌فه‌رمێت: ئێمه‌ له‌گه‌ڵ پێغه‌مبه‌ری خوا - صلی الله علیه وسلم - بووین له‌ (مینا) له‌ ناو ئه‌شكه‌وتێك ئه‌م سووره‌ته‌ى بۆ دابه‌زى بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ  (الْمُرْسَلَاتِ) و (الْعَاصِفَاتِ) و (النَّاشِرَاتِ) مه‌به‌ست پێی فریشته‌كانه‌، وه‌ ته‌واوتر ئه‌وه‌یه‌ كه‌ مه‌به‌ست پێی بایه‌، خوای گه‌وره‌ سوێند ئه‌خوات به‌ با كاتێك كه‌ هێدی هێدی هه‌ڵئه‌كات."
  77,2," (الْمُرْسَلَاتِ) و (الْعَاصِفَاتِ) و (النَّاشِرَاتِ) مه‌به‌ست پێی فریشته‌كانه‌، وه‌ ته‌واوتر ئه‌وه‌یه‌ كه‌ مه‌به‌ست پێی بایه‌، خوای گه‌وره‌ سوێند ئه‌خوات به‌ با كاتێك كه‌ هێدی هێدی هه‌ڵئه‌كات."
  77,3," (الْمُرْسَلَاتِ) و (الْعَاصِفَاتِ) و (النَّاشِرَاتِ) مه‌به‌ست پێی فریشته‌كانه‌، وه‌ ته‌واوتر ئه‌وه‌یه‌ كه‌ مه‌به‌ست پێی بایه‌، خوای گه‌وره‌ سوێند ئه‌خوات به‌ با كاتێك كه‌ هێدی هێدی هه‌ڵئه‌كات."
  77,4," زاناكان جه‌ختیان له‌مه‌یان كردۆته‌وه‌ كه‌ مه‌به‌ست پێى فریشته‌یه‌ كه‌ به‌هۆی ئه‌و وه‌حییه‌ی كه‌ بۆ پێغه‌مبه‌رانى دێنن جیاوازی ئه‌خه‌نه‌ نێوان حه‌ق و باتڵ و حه‌ڵاڵ و حه‌رام و هیدایه‌ت و گومڕاییه‌وه‌."
  77,5," ئه‌و مه‌لائیكه‌تانه‌ كه‌ وه‌حی و زیكر دێنن بۆ پێغه‌مبه‌ران."
  77,6," ئه‌و وه‌حییه‌ له‌لایه‌ن خوای گه‌وره‌وه‌ ئه‌هێنن تا خه‌ڵكى عوزریان نه‌مێنێت، وه‌ ئینزارو ئاگاداركردنه‌وه‌یشه‌ له‌ سزای خوای گه‌وره‌ ئه‌گه‌ر ئیمان نه‌هێنن."
  77,7," ئه‌مه‌ وه‌ڵامی سوێند خواردنه‌كانه‌: ئه‌و هه‌ڕه‌شانه‌ی كه‌ له‌ ئێوه‌ كراوه‌ به‌ هاتنی ڕۆژی قیامه‌ت و زیندوو بوونه‌وه‌و لێپرسینه‌وه‌و وه‌رگرتنى پاداشت و سزا به‌ دڵنیایی هه‌مووى ڕوو ئه‌دات و هیچ گومانێكی تیادا نیه‌."
  77,8,"{چه‌ند دیمه‌نێكى رۆژى قیامه‌ت}  كاتێك كه‌ ئه‌ستێره‌كان ڕووناكییان نامێنێ."
  77,9," وه‌ كاتێك كه‌ ئاسمانه‌كان له‌ت ئه‌بن و شه‌ق ئه‌بن و ئه‌كرێنه‌وه‌."
  77,10," وه‌ كاتێك كه‌ شاخه‌كان له‌ شوێنی خۆیان هه‌ڵئه‌كه‌نرێن و به‌ هه‌وادا ئه‌ڕۆن وه‌كو تۆز به‌ بادا بڕوات به‌و شێوازه‌، وه‌ زه‌وی ته‌خت ئه‌بێت و شاخی تیادا نامێنێ و شوێنه‌وارى نامێنێت."
  77,11," وه‌ كاتێك كه‌ پێغه‌مبه‌ران كات و مه‌وعیدیان بۆ دائه‌نرێ بۆ بڕیاردان له‌ نێوان ئه‌وان و ئوممه‌ته‌كانیاندا، یاخود كۆ ئه‌كرێنه‌وه‌."
  77,12," بۆ چ ڕۆژێك ئه‌و كۆكردنه‌وه‌یه‌ دواخراوه‌و كاتی بۆ دانراوه‌ واته‌: بۆ ڕۆژی قیامه‌ته‌ كه‌ ڕۆژێكی زۆر سه‌خته‌."
  77,13," ئه‌و ڕۆژه‌یه‌ كه‌ خوای گه‌وره‌ بڕیاری یه‌كلاكه‌ره‌وه‌ ئه‌دات له‌ نێوان مرۆڤو جنیه‌كاندا كۆمه‌ڵێك بۆ به‌هه‌شت و كۆمه‌ڵێك بۆ دۆزه‌خ."
  77,14," ئه‌ی محمد - صلی الله علیه وسلم - تۆ چوزانی ئه‌و ڕۆژی یه‌كلا كردنه‌وه‌و جیاكردنه‌وه‌ چ ڕۆژێكه‌، بۆ به‌گه‌وره‌ زانینه‌ واته‌: ڕۆژێكی یه‌كجار گه‌وره‌یه‌."
  77,15," هه‌ڕه‌شه‌ی سه‌خت، یان دۆڵێك له‌ دۆزه‌خدا بۆ ئه‌و كه‌سانه‌ی كه‌ ئه‌و ڕۆژه‌یان به‌درۆ زانیوه‌و باوه‌ڕیان پێ نه‌كردووه‌."
  77,16," ئایا ئێمه‌ ئوممه‌ته‌ كافره‌كانى پێشومان له‌ناونه‌برد له‌ كاتی ئاده‌مه‌وه‌ تا پێغه‌مبه‌ری خوا - صلی الله علیه وسلم - ئه‌وه‌ی كافر بووبێ هه‌موومان له‌ناو بردون."
  77,17," پاشان ئه‌مانه‌ی دواتریش به‌دوای ئه‌واندا ئه‌به‌ین، واته‌: كافرانی مه‌ككه‌یش ئه‌گه‌ر ئیمان نه‌هێنن وه‌كو ئوممه‌تانی پێشتر له‌ناویان ئه‌به‌ین."
  77,18," به‌م شێوازه‌ ئێمه‌ سزای خۆمان دائه‌به‌زێنینه‌ سه‌ر تاوانباران له‌ دونیادا پێش قیامه‌ت."
  77,19," هه‌ڕه‌شه‌ی سه‌خت و ئاگرى دۆزه‌خ بۆ ئه‌و كه‌سانه‌ی كه‌ ئه‌و ڕۆژه‌ به‌درۆ ئه‌زانن."
  77,20," ئایا ئێوه‌مان دروست نه‌كردووه‌ له‌ ئاوێكی بێ ڕێز، مرۆڤ له‌ دڵۆپه‌ ئاوێك دروست بووه‌ كه‌ مه‌نی یه‌."
  77,21," ئه‌و ئاوه‌ له‌ شوێنێكی پارێزراو دانراوه‌ كه‌ ناو ڕه‌حمی ئافره‌ته‌."
  77,22," تا كاتی دیاریكراوی خۆی كه‌ ماوه‌ی حه‌مله‌، لای كه‌مه‌كه‌ی شه‌ش مانگه‌و لای زۆره‌كه‌ی نۆ مانگه‌."
  77,23," ئێمه‌ ئه‌ندامه‌كانی له‌شی مرۆڤمان ڕێكخستووه‌و ته‌قدیرمان كردووه‌، وه‌ باشترین ته‌قدیركار خوای گه‌وره‌یه‌."
  77,24," هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ بۆ ئه‌و كه‌سانه‌ی كه‌ ڕۆژی زیندوو بوونه‌وه‌ به‌درۆ ئه‌زانن."
  77,25," ئایا زه‌ویمان وا لێ نه‌كردووه‌ كه‌ بتانگرێته‌ خۆی و كۆتان بكاته‌وه‌."
  77,26," به‌ زیندووێتی و به‌ مردووێتی، سه‌ر زه‌وی بۆ زیندووه‌كانه‌و له‌سه‌ری ئه‌ژین، ناویشى بۆ مردووه‌كانه‌و له‌ناو گۆڕدان."
  77,27,"[ وَجَعَلْنَا فِيهَا رَوَاسِيَ شَامِخَاتٍ ] وه‌ له‌ناو زه‌ویشدا ئه‌و شاخانه‌مان داناوه‌ وه‌كو سنگ و مێخ داكوتاوه‌ بۆ ئه‌وه‌ی زه‌وی نه‌هه‌ژێت و نه‌جوولێت و نه‌له‌رزێت  وه‌ ئاوێكی سازگاریشمان پێ به‌خشیوون."
  77,28," هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌ زیندوو بوونه‌وه‌و ڕۆژی دوایی نیه‌."
  77,29," له‌ رۆژى قیامه‌ت به‌ كافران ئه‌ووترێ: بڕۆن بۆ ئه‌و شوێنه‌ی كه‌ ئێوه‌ له‌ دونیا به‌درۆتان ئه‌زانی، واته‌: بڕۆن بۆ ناو ئاگری دۆزه‌خ كه‌ ئه‌تانووت دۆزه‌خ نیه‌و زیندوو بوونه‌وه‌ نیه‌و قیامه‌ت نیه‌."
  77,30,"{سزاى دۆزه‌خییه‌كان}  بڕۆن به‌ره‌و سێبه‌رێك له‌ ئاگری دۆزه‌خ كه‌ له‌ سه‌ختى و گه‌وره‌ییدا سێ لقی لێ بۆته‌وه‌، ئه‌و ئاگره‌ دووكه‌ڵه‌كه‌ی بووه‌ به‌ سێبه‌ر بۆیان."
  77,31,"[ لَا ظَلِيلٍ ] به‌ڵام سێبه‌رێكه‌ وه‌كو سێبه‌ری دونیا نیه‌ كه‌ فێنك بێ، وه‌ وایش نیه‌ كه‌ گه‌رمی ئاگری جه‌هه‌ننه‌میان لێ بگه‌ڕێنێته‌وه‌  وه‌ هیچ سوودێكی نیه‌ له‌ گڕو بڵێسه‌ی ئاگری دۆزه‌خ."
  77,32," ئه‌و ئاگری دۆزه‌خه‌ پریشك فڕێ ئه‌دات هه‌ر پریشكێكی به‌ئه‌ندازه‌ى كۆشكێك گه‌وره‌یه‌، یاخود به‌ئه‌ندازه‌ى قه‌ڵایه‌ك گه‌وره‌یه‌، یاخود به‌ئه‌ندازه‌ى دارێك كه‌ سێ گه‌ز بێ ئه‌وه‌نده‌ گه‌وره‌یه‌ (په‌نا به‌خوای گه‌وره‌)."
  77,33," هه‌ر پریشكێكی به‌ئه‌ندازه‌ى حوشترێكی ڕه‌شه‌، كه‌ حوشتری ڕه‌ش تێكه‌ڵی زه‌رد ئه‌بێ پێی ئه‌ووترێ: (صُفْرٌ) یاخود به‌ئه‌ندازه‌ى حه‌بلی كه‌شتی كه‌ به‌قه‌ده‌ر ناو قه‌دی مرۆڤێك ئه‌ستووره‌، هه‌ر پریشكێكی ئه‌وه‌نده‌ گه‌وره‌یه."
  77,34,"‌ هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ و سزای خوای گه‌وره‌ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌ ڕۆژی دوایی نیه‌."
  77,35," ئه‌مه‌ ڕۆژێكه‌ له‌ ساحه‌ی مه‌حشه‌ردا كه‌ كافران و بێباوه‌ڕان هیچ قسه‌ ناكه‌ن، وه‌ ڕێگه‌یان پێ نادرێ كه‌ قسه‌ بكه‌ن."
  77,36," وه‌ ڕێگه‌یان پێ نادرێ كه‌ عوزرو بیانوو بهێننه‌وه‌، چونكه‌ هیچ بیانوویه‌كیان نیه‌و به‌ڵگه‌یان به‌سه‌ردا جێگیر كراوه‌."
  77,37," هه‌ڕه‌شه‌ی سه‌خت و سزای ئاگری دۆزه‌خ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ ئه‌و ڕۆژه‌یان به‌درۆ زانیوه‌."
  77,38," ئه‌مه‌ ڕۆژی یه‌كلا بوونه‌وه‌و یه‌كلایی كردنه‌وه‌و جیاكردنه‌وه‌یه‌ كه‌ ئێوه‌و سه‌ره‌تاكان و كۆتاییه‌كانمان هه‌ر هه‌مووی تیادا كۆكردۆته‌وه‌ له‌ یه‌ك شوێنێكدا."
  77,39," ئه‌گه‌ر هه‌ر نه‌خشه‌و پیلان و فێڵێكتان هه‌یه‌ بۆ ئه‌وه‌ی كه‌ خۆتان ڕزگار بكه‌ن فه‌رموو بیكه‌ن، به‌ڵام كه‌س تواناو ده‌سه‌ڵاتی نیه‌."
  77,40," هه‌ڕه‌شه‌ی سه‌خت و سزای ئاگری دۆزه‌خ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌و ڕۆژه‌ نه‌بووه‌و به‌درۆیان زانیوه‌."
  77,41,"{پاداشتى موتته‌قى و خۆپارێزان له‌ به‌هه‌شتدا}  به‌ڵام ئه‌و كه‌سانه‌ی كه‌ ته‌قوای خوای گه‌وره‌یان كردووه‌و خۆیان له‌ تاوان پاراستووه‌ له‌ ترسی خوای گه‌وره‌ ئه‌مانه‌ له‌ سێبه‌ری دارو كۆشكه‌كانی به‌هه‌شتدان، وه‌ سه‌رچاوه‌ی ئاوی سازگاریان له‌ به‌هه‌شته‌وه‌ بۆ ده‌رئه‌چێ."
  77,42," وه‌ جۆره‌ها میوه‌ كه‌ حه‌زو ئاره‌زووی بكه‌ن بۆیان دێت و پێیان ئه‌به‌خشرێ."
  77,43," پێیان ئه‌ووترێ بخۆن و بخۆنه‌وه‌ نۆشی گیانتان بێ ئه‌مه‌ به‌هۆی ئه‌و كرده‌وه‌ چاكانه‌یه‌ كه‌ له‌ دونیادا ئه‌نجامتاندا."
  77,44," ئێمه‌ به‌م شێوازه‌ پاداشتی چاكه‌كاران ئه‌ده‌ینه‌وه‌ به‌ به‌هه‌شت."
  77,45," هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ ڕۆژی قیامه‌تیان به‌درۆ زانیوه‌و باوه‌ڕیان پێی نه‌بووه‌."
  77,46," به‌ كافران و بێباوه‌ڕان ئه‌ووترێ: له‌ دونیادا بخۆن و كه‌مێك ڕابوێرن له‌به‌ر ئه‌وه‌ی ژیانی دونیا كه‌مه‌، به‌ڵام دواتر ئه‌ی سته‌مكاران و تاوانباران ئه‌گه‌ڕێنه‌وه‌ بۆ سزای خوای گه‌وره‌."
  77,47," هه‌ڕه‌شه‌ی سه‌خت و سزای قورس له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌ ڕۆژی دوایی و زیندوو بوونه‌وه‌ نه‌بووه‌."
  77,48," وه‌ كاتێك پێیان بووترایه‌ نوێژ بكه‌ن و ڕكوع به‌رن له‌گه‌ڵ نوێژخوێنانداو نوێژی جه‌ماعه‌ت بكه‌ن ئه‌وان نه‌ئه‌ڕۆیشتن، یاخود وتراوه‌: له‌ ڕۆژی قیامه‌ت كه‌ بانگ ئه‌كرێن بۆ ئه‌وه‌ی سوجده‌ به‌رن مونافیقان پشتیان ناچه‌مێته‌وه."
  77,49," هه‌ڕه‌شه‌ی سه‌خت و سزای قورس له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ ئه‌و ڕۆژه‌یان به‌درۆ زانیوه‌و باوه‌ڕیان پێی نه‌كردووه‌."
  77,50," ئه‌گه‌ر باوه‌ڕ به‌ قورئانی پیرۆز نه‌كه‌ن ئیتر له‌ پاش قورئان باوه‌ڕ به‌ چ قسه‌و چ فه‌رمووده‌یه‌كی تر ئه‌كه‌ن، (ئه‌م ئایه‌ته‌ به‌ڵگه‌یه‌ له‌سه‌ر ئه‌وه‌ى كه‌ قورئان فه‌رمووده‌و فه‌رمایشت و كه‌لامی خوای گه‌وره‌یه‌)، والله أعلم."
