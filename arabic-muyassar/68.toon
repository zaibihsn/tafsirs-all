quran[52]{c,v,t}:
  68,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نٓ﴾</span>: سَبَقَ الكَلامُ عَلى الحروفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البَقَرَةِ.</p><p><span class="qpc-hafs">﴿وَٱلۡقَلَمِ﴾</span>: أقْسَمَ اللهُ بالقلمِ الَّذِي يَكْتُبُ بهِ الملائِكةُ والنّاسُ.</p><p><span class="qpc-hafs">﴿وَمَا يَسۡطُرُونَ﴾</span>: أقْسَمَ اللهُ بِما يَكْتُبُونَ مِنَ الخَيرِ والنَّفْعِ والعُلُومِ.</p></div>"
  68,2,""
  68,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَأَجۡرًا﴾</span>: لَثَوابًا عَظِيمًا.</p><p><span class="qpc-hafs">﴿غَيۡرَ مَمۡنُونࣲ﴾</span>: غيرَ مَنقُوصٍ ولا مَقْطُوعٍ.</p></div>"
  68,4,""
  68,5,""
  68,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَييِّكُمُ﴾</span>: في أيٍّ مِنكُم.</p><p><span class="qpc-hafs">﴿ٱلۡمَفۡتُونُ﴾</span>: الفِتْنَةُ و الجنُونُ.</p></div>"
  68,7,""
  68,8,""
  68,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَدُّواْ﴾</span>: تَمَنَّوا وأحَبُّوا.</p><p><span class="qpc-hafs">﴿لَوۡ تُدۡهِنُ﴾</span>: لو تُلايِنُهُم وتُصانِعُهُم عَلى بَعْضِ ما هُم عَلَيهِ.</p><p><span class="qpc-hafs">﴿فَيُدۡهِنُونَ﴾</span>: فَيَلِينُونَ لَكَ.</p></div>"
  68,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَلَّافࣲ﴾</span>: كَثِيرِ الحَلْفِ.</p><p><span class="qpc-hafs">﴿مَّهِينٍ﴾</span>: حَقِيرٍ.</p></div>"
  68,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَمَّازࣲ﴾</span>: مُغْتابٍ للنّاسِ.</p><p><span class="qpc-hafs">﴿مَّشَّآءِۭ بِنَمِيمࣲ﴾</span>: يَمْشِي بَينَ النّاسِ ويَنْقُلُ حَدِيثَ بَعْضِهِم إلى بَعْضٍ عَلى وجْهِ الإفْسادِ بَيْنَهُم.</p></div>"
  68,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّنَّاعࣲ﴾</span>: شَدِيدِ المنْعِ لِلخَيْرِ.</p><p><span class="qpc-hafs">﴿مُعۡتَدٍ﴾</span>: مُتَجاوِزٍ حَدَّه في العُدْوانِ عَلى النّاسِ وتَناوُلِ الُمحَرَّماتِ.</p><p><span class="qpc-hafs">﴿أَثِيمٍ﴾</span>: كَثِيرِ الآثامِ.</p></div>"
  68,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُتُلِّۭ﴾</span>: شَدَيدٍ في كُفْرِهِ، فاحِشٍ لَئِيمٍ.</p><p><span class="qpc-hafs">﴿زَنِيمٍ﴾</span>: مَنسُوبٍ إلى غَيرِ أبِيهِ.</p></div>"
  68,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن كَانَ ذَا مَالࣲ وَبَنِينَ﴾</span>: طَغى وتَكَبَّرَ لِأَجْلِ أن رَّزَقَهُ اللهُ مالًا وبَنِينَ فَلَمْ يَشْكُرِ النِّعْمَةَ.</p></div>"
  68,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: أباطِيلُ الأوَّلِينَ وخُرافاتُهُم.</p></div>"
  68,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنَسِمُهُۥ﴾</span>: سَنَجْعلُ عَلامةً لازِمةً لا تُفارِقُهُ.</p><p><span class="qpc-hafs">﴿عَلَى ٱلۡخُرۡطُومِ﴾</span>: عَلى أنْفِهِ عُقُوبةً لَهُ.</p></div>"
  68,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلَوۡنَـٰهُمۡ﴾</span>: اخْتَبَرْنا أهْلَ مَكَّةَ بالجُوعِ والقَحْطِ.</p><p><span class="qpc-hafs">﴿ٱلۡجَنَّةِ﴾</span>: الحَدِيقَةِ.</p><p><span class="qpc-hafs">﴿لَيَصۡرِمُنَّهَا﴾</span>: لَيَقْطَعُنَّ ثِمارَها.</p><p><span class="qpc-hafs">﴿مُصۡبِحِينَ﴾</span>: مُبَكِّرِينَ في الصَّباحِ.</p></div>"
  68,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَسۡتَثۡنُونَ﴾</span>: ولَمْ يَقُولُوا: إن شاءَ اللهُ.</p></div>"
  68,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَافَ عَلَيۡهَا طَآئِفࣱ مِّن رَّبِّكَ﴾</span>: فَأَنْزَلَ اللهُ عَلَيها نارًا أحْرَقَتْها لَيلًا.</p></div>"
  68,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلصَّرِيمِ﴾</span>: مُحْتَرِقَةً سَوْداءَ كالليلِ المُظْلمِ.</p></div>"
  68,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنَادَوۡاْ﴾</span>: فَنادى بَعْضُهُم بَعْضا.</p><p><span class="qpc-hafs">﴿مُصۡبِحِينَ﴾</span>: وقْتَ الصَّباحِ.</p></div>"
  68,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱغۡدُواْ﴾</span>: اذْهَبُوا مُبَكِّرِينَ.</p><p><span class="qpc-hafs">﴿حَرۡثِكُمۡ﴾</span>: زَرْعِكُم.</p><p><span class="qpc-hafs">﴿صَـٰرِمِينَ﴾</span>: قاطِعِينَ ثِمارَكُم.</p></div>"
  68,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَخَـٰفَتُونَ﴾</span>: يُسِرُّ بَعْضُهُم إلى بَعْضٍ في الكَلامِ.</p></div>"
  68,24,""
  68,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَغَدَوۡاْ﴾</span>: سارُوا في أوَّلِ النَّهارِ.</p><p><span class="qpc-hafs">﴿عَلَىٰ حَرۡدࣲ﴾</span>: على أمْرٍ مُجْمَعٍ عَلَيهِ.</p></div>"
  68,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَمَّا رَأَوۡهَا﴾</span>: أي مُحْتَرِقَةً.</p><p><span class="qpc-hafs">﴿لَضَآلُّونَ﴾</span>: أخْطأنا الطَّريقَ إلى حَدِيقَتِنا.</p></div>"
  68,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَحۡرُومُونَ﴾</span>: حُرِمْنا خيرَها بِسَبَبِ مَنعِنا الَمساكِينَ.</p></div>"
  68,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡسَطُهُمۡ﴾</span>: أعْدَلُهُم وأَفْضَلُهُم.</p><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿تُسَبِّحُونَ﴾</span>: تَقُولُونَ: إن شاء اللهُ.</p></div>"
  68,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَ رَبِّنَآ﴾</span>: نُنَزِّهُ رَبَّنا عَنِ الظُّلْمِ فِيما أصابَنا.</p></div>"
  68,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَلَـٰوَمُونَ﴾</span>: يَلُومُ بَعْضُهم بَعْضًا.</p></div>"
  68,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰوَيۡلَنَآ﴾</span>: نادَوا عَلى أنْفُسِهِم بِالشَّرِّ والعَذابِ.</p><p><span class="qpc-hafs">﴿طَـٰغِينَ﴾</span>: مُتَجاوِزِينَ الحدَّ في مَنعِنا الفُقَراءَ.</p></div>"
  68,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَ ٰ⁠غِبُونَ﴾</span>: طالِبُونَ الخيرَ والعفوَ عَن سيِّئاتِنا.</p></div>"
  68,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ ٱلۡعَذَابُ﴾</span>: نَفْعَلُ بِمن تَعَدّى حُدُودَنا مِثلَ ما فَعَلْنا بِهَؤُلاءِ.</p></div>"
  68,34,""
  68,35,""
  68,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡفَ تَحۡكُمُونَ﴾</span>: كَيفَ تَقْضُونَ بِهذا الحُكْمِ الظّالِمِ؟</p></div>"
  68,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبࣱ﴾</span>: أُنْزِلَ مِن عِنْدِ اللهِ.</p><p><span class="qpc-hafs">﴿تَدۡرُسُونَ﴾</span>: تَقْرَؤونَ فِيهِ هَذا الحُكْمَ الجائِرَ.</p></div>"
  68,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَا تَخَيَّرُونَ﴾</span>: ما تَشْتَهُونَ وتَخْتارُونَ، ليسَ لَكُم ذَلِكَ.</p></div>"
  68,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيۡمَـٰنٌ عَلَيۡنَا﴾</span>: عُهُودٌ ومَواثِيقُ عَلَينا.</p><p><span class="qpc-hafs">﴿بَـٰلِغَةٌ﴾</span>: مُؤَكَّدةٌ.</p></div>"
  68,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَعِيمٌ﴾</span>: كَفِيلٌ وضامِنٌ.</p></div>"
  68,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ لَهُمۡ شُرَكَآءُ﴾</span>: ألَهُم أرْبابٌ يَفْعَلُونَ بِهِم ما زَعَمُوا مِنَ الكَرامةِ؟</p></div>"
  68,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَاقࣲ﴾</span>: يَكْشِفُ رَبُّنا عَن ساقِهِ يَوْمَ القِيامَةِ فَيَسْجُدُ لَهُ كُلُّ مُؤْمِنٍ ومُؤْمِنَةٍ، ولا يَتَمكَّنُ المنافِقُونَ مِنَ السُّجُودِ.</p></div>"
  68,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ﴾</span>: مُنْكَسِرَةً لا يَرْفَعُونَها.</p><p><span class="qpc-hafs">﴿تَرۡهَقُهُمۡ﴾</span>: تَغْشاهُم.</p></div>"
  68,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَرۡنِي وَمَن يُكَذِّبُ﴾</span>: خَلِّ بينِي وبَينَ مَنُ يُكذِّبُ.</p><p><span class="qpc-hafs">﴿سَنَسۡتَدۡرِجُهُم﴾</span>: سَنَمُدُّهُم بالأمْوالِ والأَولادِ والنِّعَمِ اسْتِدْراجًا لَهُم.</p></div>"
  68,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُمۡلِي لَهُمۡ﴾</span>: وأُمْهِلُهُم وأُطِيلُ أعْمارَهُم لِيَزْدادُوا إثْما.</p><p><span class="qpc-hafs">﴿كَيۡدِي﴾</span>: مَكْرِي بِالكُفّارِ.</p><p><span class="qpc-hafs">﴿مَتِينٌ﴾</span>: قَوِيٌّ شدِيدٌ.</p></div>"
  68,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن مَّغۡرَمࣲ﴾</span>: مِن غَرامَةِ ذَلِكَ الأَجْرِ.</p><p><span class="qpc-hafs">﴿مُّثۡقَلُونَ﴾</span>: يَثْقُلُ عَلَيهِم حِمْلُهُ.</p></div>"
  68,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ عِندَهُمُ ٱلۡغَيۡبُ﴾</span>: بَلْ أعِنْدَهُم عِلْمُ الغَيبِ؟</p></div>"
  68,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَصَاحِبِ ٱلۡحُوتِ﴾</span>: هُو يُونُسُ -عَلَيهِ السَّلامُ-.</p><p><span class="qpc-hafs">﴿مَكۡظُومࣱ﴾</span>: مَمْلُوءٌ غَمًّا وكَرْبًا.</p></div>"
  68,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعۡمَةࣱ مِّن رَّبِّهِۦ﴾</span>: التَّوبَةُ وقَبُولُها مِنهُ.</p><p><span class="qpc-hafs">﴿لَنُبِذَ﴾</span>: لَطُرِحَ.</p><p><span class="qpc-hafs">﴿بِٱلۡعَرَآءِ﴾</span>: بالأرْضِ الفَضاءِ المهْلِكَةِ.</p><p><span class="qpc-hafs">﴿مَذۡمُومࣱ﴾</span>: آتٍ بِما يُلامُ عَلَيهِ.</p></div>"
  68,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱجۡتَبَـٰهُ﴾</span>: فاخْتارَهُ لِرِسالتِهِ.</p></div>"
  68,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيُزۡلِقُونَكَ﴾</span>: لَيُصِيبُونَكَ بالعَينِ لِبُغْضِهِم إيّاكَ.</p><p><span class="qpc-hafs">﴿ٱلذِّكۡرَ﴾</span>: القُرَآنَ.</p></div>"
  68,52,""
