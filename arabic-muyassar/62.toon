quran[11]{c,v,t}:
  62,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُسَبِّحُ﴾</span>: يُنَزِّهُ.</p><p><span class="qpc-hafs">﴿ٱلۡمَلِكِ﴾</span>: المالِكِ لِكُلِّ شَيءٍ المتَصَرِّفِ فِيهِ بِلا مُنازِعٍ.</p><p><span class="qpc-hafs">﴿ٱلۡقُدُّوسِ﴾</span>: المنَزَّهِ عَن كُلِّ نَقْصٍ.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزِ﴾</span>: الَّذِي لا يُغالَبُ</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمِ﴾</span>: المحْكِم فِي تَدْبِيرِهِ وصُنْعِهِ.</p></div>"
  62,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأُمِّيِّـۧنَ﴾</span>: العربِ الَّذِينَ لا يَقْرَؤُونَ ولا يَكْتُبُونَ.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِهِۦ﴾</span>: القُرْآنَ.</p><p><span class="qpc-hafs">﴿وَيُزَكِّيهِمۡ﴾</span>: ويُطَهِّرهم مِنَ العقائِدِ الفاسِدَةِ والأخْلاقِ السَّيِّئةِ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القُرْآنَ.</p><p><span class="qpc-hafs">﴿وَٱلۡحِكۡمَةَ﴾</span>: والسُّنَّةَ.</p></div>"
  62,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاخَرِينَ﴾</span>: وأَرْسَلَهُ إلى آخَرِينَ.</p><p><span class="qpc-hafs">﴿مِنۡهُمۡ﴾</span>: مِنَ العَرَبِ ومِن غَيْرِهِم.</p><p><span class="qpc-hafs">﴿لَمَّا يَلۡحَقُواْ بِهِمۡ﴾</span>: لَمْ يَجِيئُوا بَعْدُ، وسَيَجِيئُونَ.</p></div>"
  62,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضۡلُ ٱللَّهِ﴾</span>: مِمّا تَفَضَّلَ اللهُ بِهِ عَلى هَؤلاءِ دُونَ غَيرِهِم.</p><p><span class="qpc-hafs">﴿ٱلۡفَضۡلِ ٱلۡعَظِيمِ﴾</span>: الإحْسانِ والعَطاءِ الجَزِيلِ.</p></div>"
  62,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثَلُ﴾</span>: شَبَهُ.</p><p><span class="qpc-hafs">﴿حُمِّلُواْ ٱلتَّوۡرَىٰةَ﴾</span>: كُلِّفُوا العَمَلَ بِها.</p><p><span class="qpc-hafs">﴿لَمۡ يَحۡمِلُوهَا﴾</span>: لم يَعْمَلُوا بِها.</p><p><span class="qpc-hafs">﴿أَسۡفَارَۢا﴾</span>: كُتُبًا لا يَدْرِي ما فِيها.</p><p><span class="qpc-hafs">﴿بِئۡسَ﴾</span>: قَبُحَ.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوفِّقُ.</p></div>"
  62,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَادُوٓاْ﴾</span>: تَمَسَّكُوا بالِملَّةِ اليهُودِيَّةِ.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءُ لِلَّهِ﴾</span>: أحِبّاءُ للهِ.</p></div>"
  62,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾</span>: بِسببِ ما اكْتَسَبُوا في هذه الدُّنيا مِنَ الآثامِ.</p></div>"
  62,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّهُۥ مُلَـٰقِيكُمۡ﴾</span>: آتٍ إلَيكُم وقْتَ مَجِيءِ آجالِكُم.</p><p><span class="qpc-hafs">﴿ثُمَّ تُرَدُّونَ﴾</span>: ثم تُرْجَعُونَ يَومَ القِيامةِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَيۡبِ﴾</span>: ما غابَ.</p><p><span class="qpc-hafs">﴿ٱلشَّهَـٰدَةِ﴾</span>: ما حَضَرَ.</p></div>"
  62,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُودِيَ﴾</span>: نادى المؤَذِّنُ.</p><p><span class="qpc-hafs">﴿فَٱسۡعَوۡاْ﴾</span>: فامْضُوا وأَقْبِلُوا إلَيها.</p><p><span class="qpc-hafs">﴿ذِكۡرِ ٱللَّهِ﴾</span>: الموعظةِ في خُطْبَةِ الإمامِ.</p><p><span class="qpc-hafs">﴿وَذَرُواْ﴾</span>: واتْرُكُوا.</p></div>"
  62,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱبۡتَغُواْ مِن فَضۡلِ ٱللَّهِ﴾</span>: واطْلُبُوا مِن رِزْقِ اللهِ.</p><p><span class="qpc-hafs">﴿تُفۡلِحُونَ﴾</span>: تَفُوزُونَ بِخَيرَيِ الدُّنيا والآخِرَةِ.</p></div>"
  62,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهۡوًا﴾</span>: صارِفًا عَنِ الصَّلاةِ.</p><p><span class="qpc-hafs">﴿ٱنفَضُّوٓاْ﴾</span>: تَفَرَّقُوا.</p><p><span class="qpc-hafs">﴿قَآئِمࣰا﴾</span>: أي: عَلى الِمنْبَرِ.</p></div>"
