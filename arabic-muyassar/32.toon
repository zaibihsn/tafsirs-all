quran[30]{c,v,t}:
  32,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الٓمٓ﴾</span>: سَبَقَ الكَلامُ عَلى مِثْلهِ في أوَّلِ سُورةِ البقرةِ.</p></div>"
  32,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا رَيۡبَ فِيهِ﴾</span>: لاشَكَّ فِيه.</p></div>"
  32,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ يَقُولُونَ﴾</span>: بل أيقُولُ المشرِكُونَ.</p><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰهُ﴾</span>: اختَلَقَ محمدٌ ﷺ القرآنَ مِن تِلْقاءِ نَفْسِهِ.</p><p><span class="qpc-hafs">﴿نَّذِيرࣲ﴾</span>: أي: رَسُولٍ مُنْذِرٍ.</p></div>"
  32,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِ﴾</span>: عَلا وارْتَفَعَ سُبْحانَه وتَعالى عَلى عَرْشِهِ كَما يَليقُ بِجَلالِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هُوَ سَريرُ المُلْكِ الَّذي اسْتَوى عَلَيهِ الرَّحْمَنُ، وتَحْمِلُهُ الملائِكَةُ، وهْوَ أعْظَمُ المْخلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: ناصِرٍ يَنْصُرُكُم.</p><p><span class="qpc-hafs">﴿تَتَذَكَّرُونَ﴾</span>: تَتَّعِظُونَ.</p></div>"
  32,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾</span>: يَقْضِي القَضاءَ.</p><p><span class="qpc-hafs">﴿يَعۡرُجُ﴾</span>: يَصْعَدُ.</p></div>"
  32,6,""
  32,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡسَنَ كُلَّ شَيۡءٍ﴾</span>: أحْكَمَهُ وأَتْقَنَهُ.</p><p><span class="qpc-hafs">﴿طِينࣲ﴾</span>: تُرابٍ.</p></div>"
  32,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَسۡلَهُۥ﴾</span>: ذُرِّيَّتَه.</p><p><span class="qpc-hafs">﴿سُلَـٰلَةࣲ﴾</span>: نُطْفَةٍ مَسْلُولَةٍ.</p><p><span class="qpc-hafs">﴿مَّهِينࣲ﴾</span>: ذَلِيلٍ.</p></div>"
  32,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَّىٰهُ﴾</span>: أتمَّ خَلْقَهُ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَفۡـِٔدَةَ﴾</span>: القُلُوبَ.</p></div>"
  32,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَلۡنَا فِي ٱلۡأَرۡضِ﴾</span>: ضِعْنا فِيها وصِرْنا تُرابًا.</p><p><span class="qpc-hafs">﴿كَـٰفِرُونَ﴾</span>: مُنْكِرُونَ.</p></div>"
  32,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَفَّىٰكُم﴾</span>: يَقبِضُ أرْواحَكُم.</p><p><span class="qpc-hafs">﴿وُكِّلَ بِكُمۡ﴾</span>: وُكِّلَ بِقَبْضِ أرْواحِكِم.</p></div>"
  32,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَاكِسُواْ رُءُوسِهِمۡ﴾</span>: أي: مُطْرِقُوها خِزْيًا ونَدامَةً.</p><p><span class="qpc-hafs">﴿مُوقِنُونَ﴾</span>: مُصَدِّقُونَ.</p></div>"
  32,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُدَىٰهَا﴾</span>: رُشْدَها، وتَوفِيقَها لِلْإيمانِ.</p><p><span class="qpc-hafs">﴿حَقَّ﴾</span>: وجَبَ وثَبَتَ.</p></div>"
  32,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخُلۡدِ﴾</span>: الدّائِمِ.</p></div>"
  32,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡمِنُ﴾</span>: يُصَدِّقُ.</p><p><span class="qpc-hafs">﴿ذُكِّرُواْ بِهَا﴾</span>: وُعِظِوُا بِها.</p><p><span class="qpc-hafs">﴿خَرُّواْ﴾</span>: سَقَطوُا.</p></div>"
  32,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتَجَافَىٰ﴾</span>: تَرْتَفِعُ وتَتَنَحّى.</p><p><span class="qpc-hafs">﴿عَنِ ٱلۡمَضَاجِعِ﴾</span>: عَنِ الفُرُشِ الَّتِي يُضْطَجَعُ عَلَيها.</p></div>"
  32,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قُرَّةِ أَعۡيُنࣲ﴾</span>: مِن موجِباتِ المسَرَّةِ والفَرَحِ.</p></div>"
  32,18,""
  32,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُزُلَۢا﴾</span>: ما يُهيَّأُ للنَّزيلِ ضِيافَةً وإكْرامًا.</p></div>"
  32,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَأۡوَىٰهُمُ﴾</span>: المكانُ الَّذي يَأْوُونَ إليه.</p></div>"
  32,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَذَابِ ٱلۡأَدۡنَىٰ﴾</span>: وهو ما يُصِيبُهُم في الدُّنيا مِنَ البَلاءِ والِمحَنَ.</p><p><span class="qpc-hafs">﴿ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾</span>: وهو ما يُصِيبُهُم يومَ القِيامةِ مِن عَذابِ جَهَنَّمَ.</p></div>"
  32,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُكِّرَ﴾</span>: وُعِظَ.</p></div>"
  32,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي مِرۡيَةࣲ﴾</span>: في شَكٍّ.</p><p><span class="qpc-hafs">﴿مِّن لِّقَآئِهِۦ﴾</span>: أي: مِن لِقاءِ مُوسى عَلَيهِ الصَّلاةُ والسَّلامُ.</p></div>"
  32,24,""
  32,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡصِلُ﴾</span>: يَقْضِي.</p></div>"
  32,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَهۡدِ لَهُمۡ﴾</span>: أوَلم يُبَيِّنْ لَهُم.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡقُرُونِ﴾</span>: مِنَ الأُمَمِ السّابقِةِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتٍ﴾</span>: لَعِبَرًا وعِظاتٍ.</p></div>"
  32,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجُرُزِ﴾</span>: الأرْضِ اليابِسةِ الغَلِيظَةِ الجرْداءِ الَّتي لا نَباتَ فِيها.</p></div>"
  32,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا ٱلۡفَتۡحُ﴾</span>: هذا القضاءُ بين العِبادِ.</p></div>"
  32,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنظَرُونَ﴾</span>: يُمْهَلُونَ لِيؤْمِنُوا.</p></div>"
  32,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱنتَظِرۡ﴾</span>: أي: انْتَظِرْ ما اللهُ صانِعٌ بِهِم.</p></div>"
