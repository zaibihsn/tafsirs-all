quran[37]{c,v,t}:
  45,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: سَبقَ الكلامُ على الحروف المقطَّعة أولَ سورة البقرة.</p></div>"
  45,2,""
  45,3,""
  45,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يَبُثُّ﴾</span>: وما يَنْشُرُ ويُفَرِّقُ.</p><p><span class="qpc-hafs">﴿دَآبَّةٍ﴾</span>: ما يَدِبُّ عَلى الأرضِ غَيرَ الإنْسانِ.</p><p><span class="qpc-hafs">﴿يُوقِنُونَ﴾</span>: يَعْلَمُونَ حَقائِقَ الأَشْياءِ، فيُقِرُّونَ بِها.</p></div>"
  45,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: تَعاقُبِهِما، أو تَفاوَتِهِما بالطُّولِ والقِصَرِ والظُّلْمَةِ والضِّياءِ.</p><p><span class="qpc-hafs">﴿رِّزۡقࣲ﴾</span>: مَطَرٍ يَكُونُ مِنهُ القُوتُ.</p><p><span class="qpc-hafs">﴿وَتَصۡرِيفِ ٱلرِّيَـٰحِ﴾</span>: تَبْدِيلِ اللهِ سبحانه وتعالى للرِّياحِ صُعُودًا ونُزُولًا، واخْتلِافِ جِهاتِ هُبُوبِها.</p></div>"
  45,6,""
  45,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: هَلاكٌ شَدِيدٌ.</p><p><span class="qpc-hafs">﴿أَفَّاكٍ﴾</span>: كَذّابٍ.</p><p><span class="qpc-hafs">﴿أَثِيمࣲ﴾</span>: كَثِيرِ الآثامِ.</p></div>"
  45,8,""
  45,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوًا﴾</span>: مَوْضِعَ سُخْرِيةٍ واسْتِخْفافٍ.</p></div>"
  45,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن وَرَآئِهِمۡ﴾</span>: من أمامِهم.</p><p><span class="qpc-hafs">﴿وَلَا يُغۡنِي عَنۡهُم﴾</span>: ولا يَنْفَعُهُم.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: نُصَراءَ.</p></div>"
  45,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِّجۡزٍ﴾</span>: أسْوأِ العَذابِ.</p></div>"
  45,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكُ﴾</span>: السُّفُنُ.</p></div>"
  45,13,""
  45,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغۡفِرُواْ﴾</span>: يَعْفُوا ويَتجاوَزُوا.</p><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ﴾</span>: لا يَخافُونَ.</p><p><span class="qpc-hafs">﴿أَيَّامَ ٱللَّهِ﴾</span>: بأسَهُ ووَقائِعَه ونِقَمَهُ.</p></div>"
  45,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَلَيۡهَا﴾</span>: فَعَلى نَفْسِهِ جَنى.</p></div>"
  45,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التَّوْراةَ والإنْجِيلَ.</p><p><span class="qpc-hafs">﴿وَٱلۡحُكۡمَ﴾</span>: الفَهْمَ للكِتابِ والعِلْمَ بِالسُّنَنِ الَّتي لم تَنْزِلْ في الكِتابِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: عالمَي أهلِ زَمانِهِم.</p></div>"
  45,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَـٰتࣲ﴾</span>: دَلالاتٍ تُبَيِّنُ الحقَّ مِنَ الباطِلِ.</p><p><span class="qpc-hafs">﴿ٱلۡعِلۡمُ﴾</span>: الكتابُ والنُّبُوَّةُ والدَّلائِلُ الواضِحَةُ الَّتِي تُفَرِّقُ بين الحقِّ والباطِلِ.</p><p><span class="qpc-hafs">﴿بَغۡيَۢا﴾</span>: ظُلْمًا وحَسَدًا.</p></div>"
  45,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَرِيعَةࣲ﴾</span>: مِنهاجٍ واضِحٍ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡأَمۡرِ﴾</span>: مِن أمْرِ الدِّينِ.</p><p><span class="qpc-hafs">﴿أَهۡوَآءَ﴾</span>: ما تَمِيلُ نُفُوسُهُم إلَيهِ مِمّا يُخالِفُ شَرْعَ اللهِ.</p></div>"
  45,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغۡنُواْ﴾</span>: يَدْفَعُوا.</p></div>"
  45,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَصَـٰٓئِرُ﴾</span>: جَمْعُ بصِيرةِ، وهي الحُجَّةُ فِيما يحتاجُونَ إليهِ مِنَ الأحْكامِ.</p></div>"
  45,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱجۡتَرَحُواْ﴾</span>: اكْتَسَبُوا.</p><p><span class="qpc-hafs">﴿سَوَآءࣰ مَّحۡيَاهُمۡ وَمَمَاتُهُمۡ﴾</span>: مُسْتَويةً حالةُ حياتِهِم وحالاتُ موتِهِم.</p></div>"
  45,22,""
  45,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَخَتَمَ عَلَىٰ سَمۡعِهِۦ﴾</span>: وطَبَع عَلى سَمْعِهَ، فَلا يَسْمَعُ مَواعِظَ اللهِ.</p><p><span class="qpc-hafs">﴿غِشَـٰوَةࣰ﴾</span>: غِطاءً فَلا يَنْتَفِعُ بِبَصَرِهِ.</p></div>"
  45,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدَّهۡرُ﴾</span>: مُرورُ السِّنينَ والأَيّامِ.</p><p><span class="qpc-hafs">﴿عِلۡمٍ﴾</span>: يَقِينٍ بَلْ يَقُولُونَ ذَلكَ تَخَرُّصًا.</p></div>"
  45,25,""
  45,26,""
  45,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُبۡطِلُونَ﴾</span>: الَّذِينَ أبْطَلُوا في دَعْواهُم للهِ شَرِيكًا.</p></div>"
  45,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَاثِيَةࣰ﴾</span>: بارِكَةً عَلى الرُّكَبِ مُسْتَوفِزَةً.</p><p><span class="qpc-hafs">﴿كِتَـٰبِهَا﴾</span>: كِتابِ أعْمالِها.</p></div>"
  45,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبُنَا﴾</span>: كِتابُ أعْمالِكُم الَّذِي دوَّنَتْهُ ملائِكَتِي.</p><p><span class="qpc-hafs">﴿نَسۡتَنسِخُ﴾</span>: نَأمُرُ الحَفَظَةَ أن تَكْتُبَ.</p></div>"
  45,30,""
  45,31,""
  45,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُسۡتَيۡقِنِينَ﴾</span>: بِمُتَحَقِّقِينَ.</p></div>"
  45,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَدَا﴾</span>: وظَهَرَ.</p><p><span class="qpc-hafs">﴿وَحَاقَ﴾</span>: ونَزَلَ وأَحاطَ.</p></div>"
  45,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَنسَىٰكُمۡ﴾</span>: نَتْرُكُكُم في عَذابِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿وَمَأۡوَىٰكُمُ﴾</span>: ومَسْكَنُكُم.</p></div>"
  45,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوࣰا﴾</span>: مُسْتَهْزَأً بِها.</p><p><span class="qpc-hafs">﴿وَغَرَّتۡكُمُ﴾</span>: وخَدَعَتْكُم.</p><p><span class="qpc-hafs">﴿لَا يُخۡرَجُونَ مِنۡهَا﴾</span>: أي مِنَ النّارِ.</p><p><span class="qpc-hafs">﴿يُسۡتَعۡتَبُونَ﴾</span>: يُرْضِيهِم أحَدٌ بِتَمْكِينِهِم مِنَ التَّوبَةِ.</p></div>"
  45,36,""
  45,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِبۡرِيَآءُ﴾</span>: السُّلطانُ والعَظَمَةُ.</p></div>"
