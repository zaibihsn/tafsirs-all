quran[112]{c,v,t}:
  21,1,""
  21,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن ذِكۡرࣲ﴾</span>: أي: مِن قُرْآنٍ.</p><p><span class="qpc-hafs">﴿مُّحۡدَثٍ﴾</span>: أي: يَتَجَدَّدُ نُزُولُه.</p></div>"
  21,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَاهِيَةࣰ﴾</span>: غافِلةً.</p><p><span class="qpc-hafs">﴿وَأَسَرُّواْ ٱلنَّجۡوَى﴾</span>: اجْتَمَعُوا سِرًّا على أمْرٍ خَفِيٍّ.</p><p><span class="qpc-hafs">﴿ٱلسِّحۡرَ﴾</span>: القرآنَ (على زَعْمِ الكُفّار).</p></div>"
  21,4,""
  21,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَضۡغَـٰثُ أَحۡلَـٰمِۭ﴾</span>: أخْلاطُ أحْلامٍ لا حقيقةَ لها.</p><p><span class="qpc-hafs">﴿بَلِ ٱفۡتَرَىٰهُ﴾</span>: بَلِ اخْتَلَقَه.</p></div>"
  21,6,""
  21,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا رِجَالࣰا﴾</span>: أي: مِنَ البَشَرِ فقط.</p><p><span class="qpc-hafs">﴿أَهۡلَ ٱلذِّكۡرِ﴾</span>: أهْلَ العِلْمِ بالكُتُبِ الُمنَزَّلةِ السّابقَةِ.</p></div>"
  21,8,""
  21,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُسۡرِفِينَ﴾</span>: الُمتَجاوِزِينَ الحَدَّ بِكُفْرِهم بِرَبِّهم.</p></div>"
  21,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرُكُمۡ﴾</span>: عِزُّكُم وشَرَفُكم إنْ عَمِلْتُم بما جاءَ فيه.</p></div>"
  21,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَصَمۡنَا﴾</span>: أهْلَكْنا واسَتْأصَلْنا.</p><p><span class="qpc-hafs">﴿كَانَتۡ ظَالِمَةࣰ﴾</span>: كانَ أهلُها ظالِميَنَ بِكُفْرِهم باللهِ وبِما جاءتْهم به رُسُلُه.</p><p><span class="qpc-hafs">﴿وَأَنشَأۡنَا﴾</span>: خَلَقْنا وأَوْجَدْنا.</p></div>"
  21,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحَسُّواْ بَأۡسَنَآ﴾</span>: أي: عَلِمُوا وتيَقَّنُوا بِوُقُوعِ عَذابِنا بِمُشاهَدَةِ بَوادِرِه.</p><p><span class="qpc-hafs">﴿يَرۡكُضُونَ﴾</span>: يَهرُبُون مُسرِعِينَ.</p></div>"
  21,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَرۡكُضُواْ﴾</span>: لا تَهرُبُوا.</p><p><span class="qpc-hafs">﴿أُتۡرِفۡتُمۡ فِيهِ﴾</span>: أُنْعِمْتُم فِيه مِنَ التَّرفِ.</p><p><span class="qpc-hafs">﴿لَعَلَّكُمۡ تُسۡـَٔلُونَ﴾</span>: لَعَلَّكُم تُسْأَلُونَ مِن دُنْياكُم شَيْئًا، قِيلَ لَهُم ذَلك اسْتِهْزاءً بِهِم.</p></div>"
  21,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰوَيۡلَنَآ﴾</span>: يا هَلاكَنا.</p></div>"
  21,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تِّلۡكَ دَعۡوَىٰهُمۡ﴾</span>: أي: كلِمتَهم: «يا ويلَنا» يَدْعُونَ بها، ويُرَدِّدُونَها.</p><p><span class="qpc-hafs">﴿حَصِيدًا﴾</span>: مُسْتَأْصَلِينَ كما يُحصَدُ الزَّرْعُ.</p><p><span class="qpc-hafs">﴿خَـٰمِدِينَ﴾</span>: هالِكِينَ، قدِ انْطَفَأَتْ شَرارَةُ حَياتِهمِ.</p></div>"
  21,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـٰعِبِينَ﴾</span>: عَبَثًا ولَهْوًا وباطِلًا.</p></div>"
  21,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهۡوࣰا﴾</span>: ما يُتلهّى بِه مِن زَوْجَةٍ ووَلَدٍ.</p><p><span class="qpc-hafs">﴿مِن لَّدُنَّآ﴾</span>: مِن عِنْدِنا مِنَ أهْل السَّماءِ مِنَ الحُورِ العِينِ.</p></div>"
  21,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلۡ نَقۡذِفُ﴾</span>: بل نَرْمِي.</p><p><span class="qpc-hafs">﴿فَيَدۡمَغُهُۥ﴾</span>: فيَمْحَقُه ويَدْحَضُه.</p><p><span class="qpc-hafs">﴿زَاهِقࣱ﴾</span>: زائِلٌ وذاهِبٌ.</p><p><span class="qpc-hafs">﴿ٱلۡوَيۡلُ﴾</span>: العَذابُ.</p></div>"
  21,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِهِۦ﴾</span>: لا يَتَعاظَمُونَ عَن عِبادتِه.</p><p><span class="qpc-hafs">﴿وَلَا يَسۡتَحۡسِرُونَ﴾</span>: لا يُصِيبُهُم إعياءٌ ولا مَلَلٌ مِن عِبادَةِ اللهِ.</p></div>"
  21,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَفۡتُرُونَ﴾</span>: لا يَضْعُفُونَ ولا يَسْأمُونَ.</p></div>"
  21,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمِ ٱتَّخَذُوٓاْ ءَالِهَةࣰ مِّنَ ٱلۡأَرۡضِ هُمۡ يُنشِرُونَ﴾</span>: هَلِ اتَّخَذَ المُشْرِكُونَ آلهةً مِنَ الأرْضِ قادِرَةً على إحْياءِ المَوتى؟</p></div>"
  21,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَفَسَدَتَا﴾</span>: لبَطَلَتا، واخْتَلَّ نِظامُهما.</p><p><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ﴾</span>: تَنَزَّهَ اللهُ تعالى.</p><p><span class="qpc-hafs">﴿عَمَّا يَصِفُونَ﴾</span>: عَمّا يَصِفُه الكافِرونَ مِنِ ادِّعاءِ شَريكٍ لَه.</p></div>"
  21,23,""
  21,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمِ ٱتَّخَذُواْ﴾</span>: بَلِ اتَّخَذُوا.</p><p><span class="qpc-hafs">﴿هَاتُواْ بُرۡهَـٰنَكُمۡ﴾</span>: ايتُوا بِحُجَّتِكُم على اتِّخاذِكُم الآلِهَةَ المزْعُومةَ.</p><p><span class="qpc-hafs">﴿ذِكۡرُ مَن مَّعِيَ﴾</span>: القرآنُ الذي جِئْتُ به.</p><p><span class="qpc-hafs">﴿وَذِكۡرُ مَن قَبۡلِي﴾</span>: أي: الكُتُبُ السّابِقَةُ.</p></div>"
  21,25,""
  21,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱتَّخَذَ ٱلرَّحۡمَـٰنُ وَلَدࣰا﴾</span>: أي: بزَعْمِهِم أنّ الملائِكةَ بناتُ اللهِ.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تَنَزَّهَ اللهُ عَنْ ذَلِكَ.</p><p><span class="qpc-hafs">﴿مُّكۡرَمُونَ﴾</span>: أكْرَمَهُم الله بِعِبادَتِه وخَصَّصَهم بالفَضائِلِ.</p></div>"
  21,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسۡبِقُونَهُۥ بِٱلۡقَوۡلِ﴾</span>: أي: لا يَتَكَلَّمُونَ إلّا بما يْأمُرُهم بِه ربُّهم؛ لِكَمالِ انْقِيادِهم وطاعَتِهم.</p></div>"
  21,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡلَمُ مَا بَيۡنَ أَيۡدِيهِمۡ﴾</span>: يَعلَمُ كلَّ ما عَمِلُوه.</p><p><span class="qpc-hafs">﴿وَمَا خَلۡفَهُمۡ﴾</span>: وما هم عامِلُونَ في الُمسْتَقْبَل.</p><p><span class="qpc-hafs">﴿إِلَّا لِمَنِ ٱرۡتَضَىٰ﴾</span>: أي: إلا لِمَن رَضِيَ اللهُ بشَفاعَتِهم لَهُ.</p><p><span class="qpc-hafs">﴿مُشۡفِقُونَ﴾</span>: حَذِرونَ أن يَعْصُوه.</p></div>"
  21,29,""
  21,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَتۡقࣰا﴾</span>: مُلْتَصِقَتَينِ لا فاصِلَ بَيْنَهما.</p><p><span class="qpc-hafs">﴿فَفَتَقۡنَـٰهُمَا﴾</span>: ففَصَلْناهُما بِقُدرَتِنا.</p></div>"
  21,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿أَن تَمِيدَ بِهِمۡ﴾</span>: لِئلا تَتَحَرَّكَ الأرضُ وتَضطَرِبَ بِأهْلِها.</p><p><span class="qpc-hafs">﴿فِجَاجࣰا سُبُلࣰا﴾</span>: طُرُقًا واسِعةً.</p></div>"
  21,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَقۡفࣰا﴾</span>: أي: سَقْفًا لِلأَرْضِ.</p><p><span class="qpc-hafs">﴿مَّحۡفُوظࣰا﴾</span>: أي: عَنِ السُّقوطِ، وعَنِ اخْتِراقِ الشَّياطِينِ.</p></div>"
  21,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلࣱّ﴾</span>: أي: كلٌّ مِنَ الشَّمسِ والقَمَرِ والنُّجُومِ.</p><p><span class="qpc-hafs">﴿فَلَكࣲ﴾</span>: مَدارٍ.</p><p><span class="qpc-hafs">﴿يَسۡبَحُونَ﴾</span>: يدُورُونَ بانْبِساطٍ وسُهُولةٍ.</p></div>"
  21,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخُلۡدَ﴾</span>: دَوامَ البقاءِ في الدُّنيا.</p></div>"
  21,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَبۡلُوكُم﴾</span>: نَخْتَبِرُكُم ونَبْتَلِيكُم.</p><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: اخْتِبارًا وابْتِلاءً.</p></div>"
  21,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوًا﴾</span>: مُسْتَهْزَأً بِك.</p><p><span class="qpc-hafs">﴿يَذۡكُرُ ءَالِهَتَكُمۡ﴾</span>: يَعِيبُ آلهتَكُم.</p></div>"
  21,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُلِقَ ٱلۡإِنسَـٰنُ مِنۡ عَجَلࣲ﴾</span>: خُلِقَ الإنسانُ عَجُولًا مُتَسَرِّعًا بِفِطْرَتِه.</p><p><span class="qpc-hafs">﴿سَأُوْرِيكُمۡ ءَايَـٰتِي﴾</span>: أي: بنَصْرِ هذا الدِّينِ وهَلاكِ مَن كَفَرَ به وحارَبَه.</p></div>"
  21,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَعۡدُ﴾</span>: أي: الوعدُ بالعذابِ.</p></div>"
  21,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَكُفُّونَ﴾</span>: لا يَقْدِرُونَ أن يَمْنَعُوا.</p></div>"
  21,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأَةً.</p><p><span class="qpc-hafs">﴿فَتَبۡهَتُهُمۡ﴾</span>: فتُحَيِّرُهم.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يُنظَرُونَ﴾</span>: ولا هم يُؤخَّرُونَ، ولا هم يُمهَلُونَ لتوبَةٍ أو اعْتِذارٍ.</p></div>"
  21,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَاقَ﴾</span>: نَزَلَ وأَحاطَ.</p><p><span class="qpc-hafs">﴿سَخِرُواْ مِنۡهُم﴾</span>: اسْتَهْزَؤُوا بهم.</p></div>"
  21,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكۡلَؤُكُم﴾</span>: يَحْفَظُكُم ويَحْرُسُكُم.</p><p><span class="qpc-hafs">﴿مِنَ ٱلرَّحۡمَـٰنِ﴾</span>: أي: مِن عَذابِه وعِقابِه إذا حَلَّ بِكُم.</p><p><span class="qpc-hafs">﴿ذِكۡرِ رَبِّهِم﴾</span>: أي: القرآنِ وما فيه مِن مَّواعِظَ.</p></div>"
  21,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا هُم مِّنَّا يُصۡحَبُونَ﴾</span>: أي: ولا هم يُجارُون مِن عَذابِنا.</p></div>"
  21,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلۡ مَتَّعۡنَا﴾</span>: بل أمهَلْناهُم؛ لِيَتَمَتَّعُوا.</p><p><span class="qpc-hafs">﴿نَنقُصُهَا مِنۡ أَطۡرَافِهَآ﴾</span>: أي: نَنْقُصُ أرضَ الكفّارِ بالظُّهُورِ والغَلَبَةِ عليها مِن كُلِّ ناحيةٍ وجِهَةٍ، فنَفْتحُها بلَدًا بعد بلَدٍ.</p><p><span class="qpc-hafs">﴿أَفَهُمُ ٱلۡغَـٰلِبُونَ﴾</span>: أي: كيف يكونُون غالِبينَ بعد نَقْصِنا لأَرْضِهم مِن أطْرافِها؟</p></div>"
  21,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُنذِرُكُم﴾</span>: أُخَوِّفُكُم.</p><p><span class="qpc-hafs">﴿بِٱلۡوَحۡيِ﴾</span>: بالقرآنِ.</p><p><span class="qpc-hafs">﴿ٱلصُّمُّ﴾</span>: جمعُ الأصَمّ، وهو الذي لا يَسْمَعُ، والمرادُ الكافرُ الذي لا يُصْغِي لِلْحَقِّ.</p><p><span class="qpc-hafs">﴿ٱلدُّعَآءَ﴾</span>: النِّداءَ.</p></div>"
  21,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّسَّتۡهُمۡ﴾</span>: أصابَتْهُم.</p><p><span class="qpc-hafs">﴿نَفۡحَةࣱ﴾</span>: دُفْعَةٌ يسيرةٌ.</p><p><span class="qpc-hafs">﴿يَـٰوَيۡلَنَآ﴾</span>: يا هلاكَنا.</p></div>"
  21,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَوَ ٰ⁠زِينَ ٱلۡقِسۡطَ﴾</span>: المَوازِينَ العادلةَ.</p><p><span class="qpc-hafs">﴿لِيَوۡمِ ٱلۡقِيَـٰمَةِ﴾</span>: لِأهْلِ يومِ القيامةِ.</p><p><span class="qpc-hafs">﴿مِثۡقَالَ حَبَّةࣲ﴾</span>: وزنَ حَبَّة</p><p><span class="qpc-hafs">﴿خَرۡدَلٍ﴾</span>: وهو أصغرُ الحُبوبِ، والمرادُ أصْغرُ شَيءٍ.</p></div>"
  21,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُرۡقَانَ﴾</span>: المُعْجِزاتِ التي يُمَيَّزُ بها الحقُّ عنِ الباطِلِ.</p><p><span class="qpc-hafs">﴿وَضِيَآءࣰ﴾</span>: أي: التَّوْراةَ التي أضاءتْ لهم أمرَ دينِهِم.</p><p><span class="qpc-hafs">﴿وَذِكۡرࣰا﴾</span>: يَتَذَكَّرُونَ بما في التَّوراةِ من المواعظِ.</p></div>"
  21,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡشَوۡنَ رَبَّهُم﴾</span>: يخافُونَ عذابَه.</p><p><span class="qpc-hafs">﴿بِٱلۡغَيۡبِ﴾</span>: في حالِ غيابِهم عَنْ أعْيُنِ النّاسِ.</p><p><span class="qpc-hafs">﴿مُشۡفِقُونَ﴾</span>: خائِفُونَ.</p></div>"
  21,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَـٰذَا ذِكۡرࣱ﴾</span>: وهذا القرآنُ موعظَة لِمَن اتَّعَظَ به.</p></div>"
  21,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُشۡدَهُۥ﴾</span>: هُداه اللائقَ به.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: مِن قَبْلِ مُوسى وهارُونَ.</p></div>"
  21,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلتَّمَاثِيلُ﴾</span>: الأصنامُ التي صَنَعْتُمُوها بِأَيْدِيكُم.</p><p><span class="qpc-hafs">﴿لَهَا عَـٰكِفُونَ﴾</span>: مُقِيمُونَ على عِبادَتِها على الدَّوامِ.</p></div>"
  21,53,""
  21,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينࣲ﴾</span>: خُسْرانٍ واضِحٍ.</p></div>"
  21,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: أي: أجادٌّ أنت فيما تَقُولُ؟</p><p><span class="qpc-hafs">﴿ٱللَّـٰعِبِينَ﴾</span>: مِن الهازِلِينَ.</p></div>"
  21,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَرَهُنَّ﴾</span>: خَلَقَهُنَّ.</p></div>"
  21,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَأَكِيدَنَّ أَصۡنَـٰمَكُم﴾</span>: لَأَمْكُرَنَّ بأصنامِكُم ولَأَكْسِرَنَّها.</p></div>"
  21,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُذَ ٰ⁠ذًا﴾</span>: حُطامًا قِطَعًا مُكسَّرةً.</p></div>"
  21,59,""
  21,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَذۡكُرُهُمۡ﴾</span>: يَعِيبُهم.</p></div>"
  21,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰٓ أَعۡيُنِ ٱلنَّاسِ﴾</span>: ظاهرًا بِمَرْأىً مِنَ النّاسِ.</p><p><span class="qpc-hafs">﴿يَشۡهَدُونَ﴾</span>: أي: يَشْهَدُونَ عليه أنّه يَذْكُرُهم بِسُوءٍ.</p></div>"
  21,62,""
  21,63,""
  21,64,""
  21,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُكِسُواْ عَلَىٰ رُءُوسِهِمۡ﴾</span>: أي: لمّا غُلِبوا في الحُجَّةِ غَيَّروا رأيَهم.</p></div>"
  21,66,""
  21,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُفࣲّ لَّكُمۡ﴾</span>: قُبْحًا لكم.</p></div>"
  21,68,""
  21,69,""
  21,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدࣰا﴾</span>: مَكْرًا لهلاكِه.</p></div>"
  21,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَى ٱلۡأَرۡضِ﴾</span>: هي أرضُ «الشّام».</p><p><span class="qpc-hafs">﴿بَـٰرَكۡنَا فِيهَا﴾</span>: أي: بِكَثْرَةِ الخيراتِ، وبِكَوْنِها أرْضَ الأنبياءِ عليهمُ الصَّلاةُ والسَّلامُ.</p></div>"
  21,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَعۡقُوبَ نَافِلَةࣰ﴾</span>: زِيادةً عمّا طَلَبَ إبراهيمُ عليه الصَّلاةُ والسَّلامُ.</p></div>"
  21,73,""
  21,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُكۡمࣰا﴾</span>: نُبُوَّةً وفَصْلَ القَضاءِ بينَ الخُصُومِ.</p><p><span class="qpc-hafs">﴿ٱلۡقَرۡيَةِ﴾</span>: هي قريةُ «سَدُوم».</p><p><span class="qpc-hafs">﴿ٱلۡخَبَـٰٓئِثَ﴾</span>: هي أفعالُهم الُمنْكَرَةُ من إتيانِهم الرِّجالَ، وقَطْعِ السبيلِ وغيرِ ذلك.</p><p><span class="qpc-hafs">﴿قَوۡمَ سَوۡءࣲ﴾</span>: قومًا عُرِفُوا بالأعمالِ القبيحةِ.</p><p><span class="qpc-hafs">﴿فَـٰسِقِينَ﴾</span>: خارجِينَ عَن طاعةِ اللهِ.</p></div>"
  21,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي رَحۡمَتِنَآ﴾</span>: أي: في أهلِ رحمتِنا، وهم الأنبياءُ عليهمُ الصَّلاةُ والسَّلامُ.</p></div>"
  21,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: أي: مِن قَبْلِ إبراهيمَ ولوطٍ عليهما الصَّلاةُ والسَّلامُ.</p><p><span class="qpc-hafs">﴿ٱلۡكَرۡبِ﴾</span>: أي: الغَرَقِ بالطُّوفانِ.</p></div>"
  21,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بِحُجَجِنا الدالَّةِ على صِدْقِه.</p><p><span class="qpc-hafs">﴿قَوۡمَ سَوۡءࣲ﴾</span>: قَومًا عُرِفُوا بالسُّوءِ والقُبْحِ.</p><p><span class="qpc-hafs">﴿فَأَغۡرَقۡنَـٰهُمۡ﴾</span>: أي: بالطُّوفانِ الذي حَلَّ بهم.</p></div>"
  21,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡحَرۡثِ﴾</span>: أي: في قَضِيَّةِ الحَرْثِ.</p><p><span class="qpc-hafs">﴿نَفَشَتۡ فِيهِ﴾</span>: انْتَشَرَتْ في الحَرْثِ ليلًا مِن غَيرِ راعٍ.</p></div>"
  21,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَفَهَّمۡنَـٰهَا سُلَيۡمَـٰنَ﴾</span>: ففَهَّمنا سُليمانَ المسْأَلةَ بِمُراعاةِ مَصْلَحَةِ الطرفَينِ بالعَدْلِ.</p><p><span class="qpc-hafs">﴿حُكۡمࣰا وَعِلۡمࣰا﴾</span>: نُبُوَّةً وعِلْمًا بأحْكامِ اللهِ.</p><p><span class="qpc-hafs">﴿وَسَخَّرۡنَا﴾</span>: طَوَّعْنا.</p></div>"
  21,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَنۡعَةَ لَبُوسࣲ﴾</span>: صِناعةَ دُروعٍ تُلبَسُ في الحربِ.</p><p><span class="qpc-hafs">﴿لِتُحۡصِنَكُم﴾</span>: لِتَحْمِيَكم وتحفظَكُم.</p><p><span class="qpc-hafs">﴿مِّنۢ بَأۡسِكُمۡ﴾</span>: مِن حَرْبِكُم.</p></div>"
  21,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَاصِفَةࣰ﴾</span>: شديدةَ الهَبُوب.</p><p><span class="qpc-hafs">﴿إِلَى ٱلۡأَرۡضِ﴾</span>: أي: أرْضِ بيتِ المقْدِسِ بالشّامِ.</p></div>"
  21,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغُوصُونَ لَهُۥ﴾</span>: يَنْزِلُونَ له في البحرِ لاسْتِخْراجِ ما يُطْلَبُ.</p><p><span class="qpc-hafs">﴿حَـٰفِظِينَ﴾</span>: أي: حفِظَهمُ اللهُ من أنْ يَنْفَلِتُوا عَنْ سُليمانَ ومِن أنْ يُفْسِدُوا أعْمالَهم.</p></div>"
  21,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَسَّنِيَ ٱلضُّرُّ﴾</span>: أصابَنِي الضُّرُّ مِن مَّرَضٍ ونَحْوِه.</p></div>"
  21,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَشَفۡنَا مَا بِهِۦ مِن ضُرࣲّ﴾</span>: فَرَفَعْنا عَنْه مَرَضَهُ بِشِفائِنا إيِّاهُ.</p><p><span class="qpc-hafs">﴿وَذِكۡرَىٰ﴾</span>: تَذْكِرَةً.</p></div>"
  21,85,""
  21,86,""
  21,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَذَا ٱلنُّونِ﴾</span>: أي: واذْكُرْ صاحِبَ الحُوتِ، وذو النُّون لَقَبُ نَبِيِّ اللهِ يُونُسَ عليه الصَّلاةُ والسَّلامُ لابْتِلاعِ الحُوتِ لَه.</p><p><span class="qpc-hafs">﴿مُغَـٰضِبࣰا﴾</span>: غَضْبانَ على قَومِه؛ لِكُفْرِهم.</p><p><span class="qpc-hafs">﴿أَن لَّن نَّقۡدِرَ عَلَيۡهِ﴾</span>: أن لَن نُّضَيِّقَ عليه، ولَن نُّؤاخِذَه بِخُروجِه مِن بَيْنِ قومِه.</p><p><span class="qpc-hafs">﴿ٱلظُّلُمَـٰتِ﴾</span>: هي ظُلْمَةُ الليلِ، وظُلْمَةُ البحرِ، وظُلْمَةُ بَطْنِ الحُوتِ.</p></div>"
  21,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَجَّيۡنَـٰهُ مِنَ ٱلۡغَمِّ﴾</span>: وخَلَّصْناه مِن غَمِّهِ بإخْراجِنا له مِن بَطْنِ الحُوتِ.</p></div>"
  21,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَذَرۡنِي فَرۡدࣰا﴾</span>: لا تَتْرُكْنِي وحِيدًا لا عَقِبَ لي.</p></div>"
  21,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡلَحۡنَا لَهُۥ زَوۡجَهُۥٓ﴾</span>: أي: جَعَلْناها صالحةً في أخْلاقِها وصالحةً للحَمْلِ والولادةِ.</p><p><span class="qpc-hafs">﴿وَيَدۡعُونَنَا رَغَبࣰا﴾</span>: يَعْبُدُونَنا راغِبينَ فيما عِنْدَنا.</p><p><span class="qpc-hafs">﴿وَرَهَبࣰا﴾</span>: خائِفِينَ من عُقُوبَتِنا.</p><p><span class="qpc-hafs">﴿خَـٰشِعِينَ﴾</span>: مُتَواضِعِينَ مُتَذَلِّلينَ.</p></div>"
  21,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡصَنَتۡ فَرۡجَهَا﴾</span>: حَفِظَتْ فَرْجَها مِنَ الحَلالِ والحَرام ولْم يَمَسَّها بَشَرٌ.</p><p><span class="qpc-hafs">﴿فَنَفَخۡنَا فِيهَا مِن رُّوحِنَا﴾</span>: أي: أمَرْنا جبريلَ حتّى نَفَخَ في جَيْبِ قميصِها، فَخَلقَ اللهُ بذلكَ النَّفْخِ عيسى عليه السلام في بَطْنِها.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ لِّلۡعَـٰلَمِينَ﴾</span>: علامةً للخلْقِ على قُدْرِة اللهِ تعالى.</p></div>"
  21,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّتُكُمۡ﴾</span>: أي: الأنبياءُ عليهمُ الصَّلاةُ والسَّلامُ.</p><p><span class="qpc-hafs">﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: أي: دينُهم واحدٌ، وهو الإسلامُ.</p></div>"
  21,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَقَطَّعُوٓاْ أَمۡرَهُم﴾</span>: تَفَرَّقُوا في أمْرِ دِينِهم فِرَقًا.</p></div>"
  21,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا كُفۡرَانَ لِسَعۡيِهِۦ﴾</span>: لا جُحَودَ لِعَمَلِه بل يُشْكَرُ سَعْيُه ويُثابُ عليه.</p></div>"
  21,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَرَ ٰ⁠مٌ﴾</span>: واجِبٌ.</p></div>"
  21,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُتِحَتۡ يَأۡجُوجُ وَمَأۡجُوجُ﴾</span>: أي: يُفْتَحُ السَّدُّ عنهما فينطَلِقُونَ.</p><p><span class="qpc-hafs">﴿حَدَبࣲ﴾</span>: مَكانٍ مُرْتَفعٍ مِنَ الأَرْضِ.</p><p><span class="qpc-hafs">﴿يَنسِلُونَ﴾</span>: يَتَفَّرقُونَ في الأَرْضِ مُسْرِعِينَ.</p></div>"
  21,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَعۡدُ ٱلۡحَقُّ﴾</span>: يومُ القيامةِ.</p><p><span class="qpc-hafs">﴿شَـٰخِصَةٌ﴾</span>: مَفْتُوحَةٌ أجْفانُهم لا تَطْرِفُ.</p><p><span class="qpc-hafs">﴿مِّنۡ هَـٰذَا﴾</span>: أي: يومِ البعثِ والحسابِ.</p></div>"
  21,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَصَبُ﴾</span>: حَطَبُ.</p><p><span class="qpc-hafs">﴿وَ ٰ⁠رِدُونَ﴾</span>: داخِلُونَ.</p></div>"
  21,99,""
  21,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَفِيرࣱ﴾</span>: أنينُ تَنَفُّسِهم الشَّدِيدُ.</p><p><span class="qpc-hafs">﴿لَا يَسۡمَعُونَ﴾</span>: مِن هَولِ عَذابِهم.</p></div>"
  21,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰٓ﴾</span>: السَّعادَةُ بِدُخُولِ الجنَّة.</p><p><span class="qpc-hafs">﴿عَنۡهَا﴾</span>: أي: عَن نّارِ جَهَنَّمَ.</p></div>"
  21,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسِيسَهَا﴾</span>: أي: صَوْتَ لَهِيبِها.</p></div>"
  21,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَحۡزُنُهُمُ﴾</span>: لا يُخِيفُهم.</p><p><span class="qpc-hafs">﴿ٱلۡفَزَعُ ٱلۡأَكۡبَرُ﴾</span>: الهولُ العظيمُ يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿تَتَلَقَّىٰهُمُ﴾</span>: تَسْتَقْبِلُهم مُهَنِّئين.</p></div>"
  21,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَطۡوِي ٱلسَّمَآءَ﴾</span>: أي: نَطْويها كما يَطْوي الكاتِبُ الوَرَقَةَ التي يَكْتُبُ فيها.</p><p><span class="qpc-hafs">﴿ٱلسِّجِلِّ﴾</span>: الصَّحِيفَةِ، الورقةِ التي يُكتبُ فيها.</p><p><span class="qpc-hafs">﴿لِلۡكُتُبِ﴾</span>: هي ما دُوِّن في الصَّحيفة وكُتِب فيها.</p><p><span class="qpc-hafs">﴿كَمَا بَدَأۡنَآ أَوَّلَ خَلۡقࣲ نُّعِيدُهُۥ﴾</span>: أي: نُعيدُ الخَلْقَ حُفاةً عُراةً غُرْلًا يومَ القيامةِ، كما بَدَأْناهم أوَّلَ مرَّةٍ في بُطُونِ أمَّهاتِهم.</p></div>"
  21,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلزَّبُورِ﴾</span>: كِتابِ داودَ عليه الصلاةُ والسلامُ، أو الكُتُبِ المنزَّلَةِ.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ ٱلذِّكۡرِ﴾</span>: أي: مِن بَعْدِ الكِتابةِ في الذِّكْرِ، وهو التَّوراةُ، أو اللَّوحُ الَمحْفُوظُ.</p></div>"
  21,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ فِي هَـٰذَا﴾</span>: أي: في هذا المَتْلُوِّ.</p><p><span class="qpc-hafs">﴿لَبَلَـٰغࣰا﴾</span>: وُصُولًا إلى البُغْيةِ.</p></div>"
  21,107,""
  21,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّسۡلِمُونَ﴾</span>: مُسْتَسْلِمُونَ مُنْقادُونَ للهِ تعالى.</p></div>"
  21,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِن تَوَلَّوۡاْ﴾</span>: فَإنْ أعْرَضُوا عَنِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿ءَاذَنتُكُمۡ﴾</span>: أعْلَمْتُكُم مِن أنَّ بَعْضَكُم لِبَعْضٍ حَرْبٌ، لا صُلْحَ بَيْنَكُم ولا سِلْمَ.</p><p><span class="qpc-hafs">﴿عَلَىٰ سَوَآءࣲ﴾</span>: فأنا وأنتم مُسْتَوُونَ في العِلْمِ.</p><p><span class="qpc-hafs">﴿وَإِنۡ أَدۡرِيٓ﴾</span>: لا أدْرِي.</p></div>"
  21,110,""
  21,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعَلَّهُۥ فِتۡنَةࣱ لَّكُمۡ﴾</span>: أي: لعلَّ الإمهالَ اختبارٌ لَكُمَ.</p></div>"
  21,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَـٰلَ رَبِّ ٱحۡكُم بِٱلۡحَقِّ﴾</span>: أي: افصِلْ بَيْنِيَ وبْيَنَ قومِي بِما هُو الحقُّ عِنْدَكَ.</p></div>"
