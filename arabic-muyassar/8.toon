quran[75]{c,v,t}:
  8,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَنفَالِ﴾</span>: جَمْعُ نَفَل، وهي: الغنائمُ في غزوةِ «بَدْر».</p><p><span class="qpc-hafs">﴿ذَاتَ بَيۡنِكُمۡ﴾</span>: الصِّلَةُ التي تَرْبِطُ بعضَكم ببعض.</p></div>"
  8,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجِلَتۡ﴾</span>: خافَتْ وفَزِعَتْ.</p><p><span class="qpc-hafs">﴿وَعَلَىٰ رَبِّهِمۡ يَتَوَكَّلُونَ﴾</span>: يعتمدون عليه ويُفَوِّضون أمرَهم إليه.</p></div>"
  8,3,""
  8,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَرَجَـٰتٌ﴾</span>: منازلُ عاليةٌ.</p></div>"
  8,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَآ أَخۡرَجَكَ﴾</span>: هذه الحالُ في كراهةِ فريقٍ من المؤمنين للقتالِ بعد تَبَيُّنِه، مثلُ إخراجِك في حالِ كراهتِهم.</p></div>"
  8,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡحَقِّ﴾</span>: في القتالِ.</p></div>"
  8,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّآئِفَتَيۡنِ﴾</span>: القافلةِ الآتيةِ من الشام وما تحمِلُه من أرزاقٍ، أو النَّفيرِ لقتالِ الأعداءِ.</p><p><span class="qpc-hafs">﴿غَيۡرَ ذَاتِ ٱلشَّوۡكَةِ﴾</span>: غيرَ ذاتِ السِّلاحِ والقُوَّةِ، وهي: القافلةُ.</p><p><span class="qpc-hafs">﴿وَيَقۡطَعَ دَابِرَ ٱلۡكَـٰفِرِينَ﴾</span>: الدابِرُ: الآخِرُ، أي: ويستأصِلَ الكافرين بالهَلاكِ.</p></div>"
  8,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُحِقَّ ٱلۡحَقَّ﴾</span>: ليُظْهِرَه للناسِ ويُبَيِّنَه.</p></div>"
  8,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡتَغِيثُونَ﴾</span>: تَطْلُبون النَّصْرَ على عَدُوِّكم.</p><p><span class="qpc-hafs">﴿مُرۡدِفِينَ﴾</span>: يَتْبَعُ بعضُهم بعضًا.</p></div>"
  8,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا جَعَلَهُ ٱللَّهُ﴾</span>: وما جَعَلَ الإمدادَ.</p><p><span class="qpc-hafs">﴿وَلِتَطۡمَئِنَّ﴾</span>: ولِتَسْكُنَ وتُوقِنَ بنَصْرِ اللهِ.</p></div>"
  8,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغَشِّيكُمُ﴾</span>: يُلْقي اللهُ عليكم.</p><p><span class="qpc-hafs">﴿أَمَنَةࣰ مِّنۡهُ﴾</span>: أمانًا من الله لكم.</p><p><span class="qpc-hafs">﴿وَيُذۡهِبَ﴾</span>: ويُزيلَ.</p><p><span class="qpc-hafs">﴿رِجۡزَ ٱلشَّيۡطَـٰنِ﴾</span>: وساوِسَه بما خَطَرَ لهم من الخوفِ والفَشَلِ.</p><p><span class="qpc-hafs">﴿وَلِيَرۡبِطَ عَلَىٰ قُلُوبِكُمۡ﴾</span>: وليُقَوِّيَها بالصَّبرِ والشَّجاعةِ.</p></div>"
  8,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنِّي مَعَكُمۡ﴾</span>: بإعانتي ونَصْري.</p><p><span class="qpc-hafs">﴿فَثَبِّتُواْ ٱلَّذِينَ ءَامَنُواْ﴾</span>: فَقَوُّوا عزائمَهم، وبَشِّرُوهم بالنَّصْرِ.</p><p><span class="qpc-hafs">﴿ٱلرُّعۡبَ﴾</span>: الخوفَ الشديدَ.</p><p><span class="qpc-hafs">﴿فَوۡقَ ٱلۡأَعۡنَاقِ﴾</span>: رؤوسَ الكفارِ.</p><p><span class="qpc-hafs">﴿كُلَّ بَنَانࣲ﴾</span>: كلَّ طَرَفٍ ومِفْصَلٍ في الجسمِ.</p></div>"
  8,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: ما وقَعَ عليهم من القَتْل.</p><p><span class="qpc-hafs">﴿شَآقُّواْ ٱللَّهَ﴾</span>: خالَفُوا أمْرَه.</p></div>"
  8,14,""
  8,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَحۡفࣰا﴾</span>: مُتقارِبين يَدْنُو كلُّ فريقٍ من الآخَرِ.</p><p><span class="qpc-hafs">﴿فَلَا تُوَلُّوهُمُ ٱلۡأَدۡبَارَ﴾</span>: فلا تُدِيروا لهم ظُهورَكم مُنْهَزِمين.</p></div>"
  8,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَحَرِّفࣰا لِّقِتَالٍ﴾</span>: مائِلًا عن موقفِه إلى موضعٍ أصلَحَ للقتالِ فيه.</p><p><span class="qpc-hafs">﴿مُتَحَيِّزًا﴾</span>: مُنْحازًا ومنضَمًّا.</p><p><span class="qpc-hafs">﴿فِئَةࣲ﴾</span>: جماعةٍ من المسلمين في ميدانِ القتالِ.</p><p><span class="qpc-hafs">﴿بَآءَ بِغَضَبࣲ مِّنَ ٱللَّهِ﴾</span>: استحَقَّ غضَبه.</p></div>"
  8,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيُبۡلِيَ ٱلۡمُؤۡمِنِينَ﴾</span>: وليختبرَ اللهُ المؤمنين بنِعَمِه وإحسانِه.</p></div>"
  8,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُوهِنُ﴾</span>: مُضْعِفُ ومُبْطِلُ.</p><p><span class="qpc-hafs">﴿كَيۡدِ ٱلۡكَـٰفِرِينَ﴾</span>: مَكْرِهم واحتيالِهم.</p></div>"
  8,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡتَفۡتِحُواْ﴾</span>: تطلُبوا النَّصْرَ أيها الكفارُ.</p><p><span class="qpc-hafs">﴿جَآءَكُمُ ٱلۡفَتۡحُ﴾</span>: تَهَكُّمٌ بالكفارِ، فقد نَصَرَ اللهُ المؤمنين ب «بَدْرٍ».</p><p><span class="qpc-hafs">﴿وَإِن تَعُودُواْ﴾</span>: إلى الكفرِ وقتالِ النبيِّ ﷺ.</p><p><span class="qpc-hafs">﴿نَعُدۡ﴾</span>: بهزيمَتِكم ونَصْرِه - ﷺ - عليكم.</p><p><span class="qpc-hafs">﴿فِئَتُكُمۡ﴾</span>: جماعتُكم.</p><p><span class="qpc-hafs">﴿مَعَ ٱلۡمُؤۡمِنِينَ﴾</span>: بتأييدِه ونَصْرِه.</p></div>"
  8,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَوَلَّوۡاْ﴾</span>: ولا تُعْرِضُوا عن طاعةِ اللهِ ورسولهِ.</p><p><span class="qpc-hafs">﴿تَسۡمَعُونَ﴾</span>: ما يُتلى عليكم من الحُجَجِ والبراهينِ.</p></div>"
  8,21,""
  8,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدَّوَآبِّ﴾</span>: جَمْعُ دابّة، وهي: ما دَبَّ على الأرضِ مِن خَلْقِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلصُّمُّ﴾</span>: مَنِ انسَدَّتْ آذانُهم عن سماعِ الحقِّ.</p><p><span class="qpc-hafs">﴿ٱلۡبُكۡمُ﴾</span>: مَن خَرِسَتْ ألسنتُهم عن النُّطقِ به.</p></div>"
  8,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّأَسۡمَعَهُمۡ﴾</span>: مواعِظَ القرآنِ وعِبَرَه.</p><p><span class="qpc-hafs">﴿لَتَوَلَّواْ﴾</span>: لَأَعْرَضُوا عن الإيمان عِنادًا.</p><p><span class="qpc-hafs">﴿مُّعۡرِضُونَ﴾</span>: صادُّون عنه.</p></div>"
  8,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَا يُحۡيِيكُمۡ﴾</span>: لما فيه الحياةُ الأبديةُ.</p><p><span class="qpc-hafs">﴿بَيۡنَ ٱلۡمَرۡءِ وَقَلۡبِهِۦ﴾</span>: بين الإنسانِ وخواطِرِ قلبِه، فاللهُ أملكُ لقلوبِ عبادِه منهم.</p></div>"
  8,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: ابتلاءً ومِحْنَةً تنزِلُ بكم.</p></div>"
  8,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّسۡتَضۡعَفُونَ﴾</span>: قليلُو العَدَدِ، مَقْهُورون.</p><p><span class="qpc-hafs">﴿يَتَخَطَّفَكُمُ﴾</span>: يَأْخُذَكُم بسُرعةٍ.</p><p><span class="qpc-hafs">﴿ٱلنَّاسُ﴾</span>: كفارُ قريشٍ.</p><p><span class="qpc-hafs">﴿فَـَٔاوَىٰكُمۡ﴾</span>: جَعَلَ اللهُ لكم «المدينةَ» مَأْوىً تَأْوُون إليه.</p></div>"
  8,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَخُونُواْ ٱللَّهَ﴾</span>: بتَرْكِ ما أوْجَبَه عليكم، وارتكابِ ما نَهاكم عنه.</p><p><span class="qpc-hafs">﴿أَمَـٰنَـٰتِكُمۡ﴾</span>: ما ائتُمِنتُم عليه من التكاليفِ الشرعيةِ.</p></div>"
  8,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: اختبارٌ لكم.</p></div>"
  8,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُرۡقَانࣰا﴾</span>: فَصْلًا بين الحَقِّ والباطِلِ.</p></div>"
  8,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَمۡكُرُ بِكَ﴾</span>: يَكِيدُ لك.</p><p><span class="qpc-hafs">﴿لِيُثۡبِتُوكَ﴾</span>: ليَحْبِسُوك.</p><p><span class="qpc-hafs">﴿يُخۡرِجُوكَ﴾</span>: من بلدِك «مكةَ».</p></div>"
  8,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: جَمْعُ أُسْطُورة، وهي: ما سُطِّرَ في كُتُبِ السابقين من الأخبارِ المكذوبةِ.</p></div>"
  8,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن كَانَ هَـٰذَا﴾</span>: ما جاءَ به محمدٌ.</p></div>"
  8,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنتَ فِيهِمۡ﴾</span>: وأنت مقيمٌ بينَهم في «مكةَ».</p></div>"
  8,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لَهُمۡ أَلَّا يُعَذِّبَهُمُ ٱللَّهُ﴾</span>: وأيُّ شيءٍ يَمْنَعُ من عذابه لهم؟</p><p><span class="qpc-hafs">﴿يَصُدُّونَ﴾</span>: يَمْنَعُون.</p><p><span class="qpc-hafs">﴿عَنِ ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span>: عن الطَّوافِ بالكعبةِ، والصَّلاةِ فيه.</p><p><span class="qpc-hafs">﴿وَمَا كَانُوٓاْ أَوۡلِيَآءَهُۥٓ﴾</span>: وما كان الكفارُ أولياءَ اللهِ ولا المسجدِ الحرامِ.</p></div>"
  8,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُكَآءࣰ﴾</span>: صَفيرًا.</p><p><span class="qpc-hafs">﴿وَتَصۡدِيَةࣰ﴾</span>: وتَصْفيقًا.</p><p><span class="qpc-hafs">﴿فَذُوقُواْ ٱلۡعَذَابَ﴾</span>: في الدنيا بالقَتْلِ والأَسْرِ في «بدرٍ»، وفي الآخرةِ بالنارِ.</p></div>"
  8,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسۡرَةࣰ﴾</span>: ندامةً وأَسَفًا.</p></div>"
  8,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَمِيزَ﴾</span>: ليَفْصِلَ.</p><p><span class="qpc-hafs">﴿فَيَرۡكُمَهُۥ﴾</span>: يَجْمَعَه ويَضُمَّ بعضَه إلى بعضٍ.</p></div>"
  8,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَنتَهُواْ﴾</span>: عن الكفرِ، ويَرْجِعُوا إلى الإيمان.</p><p><span class="qpc-hafs">﴿وَإِن يَعُودُواْ﴾</span>: إلى قتالِ النبيِّ ﷺ.</p><p><span class="qpc-hafs">﴿مَضَتۡ﴾</span>: سَبَقَتْ.</p><p><span class="qpc-hafs">﴿سُنَّتُ ٱلۡأَوَّلِينَ﴾</span>: سنَّتُنا في عقوبةِ مَن كَذَّبَ واستمرَّ على كُفْرِه.</p></div>"
  8,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: شِرْكٌ وصَدٌّ عن سبيل الله.</p><p><span class="qpc-hafs">﴿وَيَكُونَ ٱلدِّينُ كُلُّهُۥ لِلَّهِ﴾</span>: وتكونَ الطاعةُ والعبادةُ كلُّهاخالصةً لله.</p><p><span class="qpc-hafs">﴿فَإِنِ ٱنتَهَوۡاْ﴾</span>: فإن انزجَرَ المشركون عن شِرْكِهم وفتنةِ المؤمنين.</p></div>"
  8,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَوۡلَىٰكُمۡ﴾</span>: مُعينُكم وناصِرُكم.</p></div>"
  8,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَنِمۡتُم﴾</span>: ظَفِرْتُمْ به من الأعداءِ بالجِهادِ.</p><p><span class="qpc-hafs">﴿وَلِذِي ٱلۡقُرۡبَىٰ﴾</span>: قَرابةِ الرسولِ ﷺ، وهم بنو هاشمٍ وبنو المطَّلِبِ.</p><p><span class="qpc-hafs">﴿وَٱلۡيَتَـٰمَىٰ﴾</span>: الأطفالِ الذين مات آباؤُهم وهم دونَ سِنِّ البُلوغ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: أهلِ الحاجةِ الذين لا يَمْلِكُون ما يَكْفيهم.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: المسافرِ الذي انقطعَتْ به النفقةُ.</p><p><span class="qpc-hafs">﴿وَمَآ أَنزَلۡنَا﴾</span>: من الملائكةِ والآياتِ والنَّصْرِ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡفُرۡقَانِ﴾</span>: يومَ «بَدْرٍ» حينَ فَرَقَ اللهُ بينَ الحقِّ والباطلِ.</p></div>"
  8,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡعُدۡوَةِ ٱلدُّنۡيَا﴾</span>: جانبِ الوادي الأقربِ إلى «المدينة».</p><p><span class="qpc-hafs">﴿ٱلۡقُصۡوَىٰ﴾</span>: البعيدةِ عن «المدينةِ».</p><p><span class="qpc-hafs">﴿وَٱلرَّكۡبُ﴾</span>: عِيرُ التجارةِ وأصحابُها.</p><p><span class="qpc-hafs">﴿أَسۡفَلَ مِنكُمۡ﴾</span>: في مكانٍ أسفلَ من مكانِكم جهةَ ساحلِ البحرِ الأحمرِ.</p><p><span class="qpc-hafs">﴿لِّيَقۡضِيَ ٱللَّهُ أَمۡرࣰا كَانَ مَفۡعُولࣰا﴾</span>: بنَصْرِ أوليائِه وخِذْلانِ أعدائِه.</p><p><span class="qpc-hafs">﴿لِّيَهۡلِكَ مَنۡ هَلَكَ﴾</span>: ليموتَ مَن يموتُ من الكفّارِ.</p><p><span class="qpc-hafs">﴿عَنۢ بَيِّنَةࣲ﴾</span>: عن حُجَّةٍ عايَنَها.</p><p><span class="qpc-hafs">﴿وَيَحۡيَىٰ مَنۡ حَيَّ﴾</span>: ويعيشَ مَن يعيشُ مِنهُم.</p></div>"
  8,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّفَشِلۡتُمۡ﴾</span>: لَجَبُنْتُم وضَعُفتم.</p><p><span class="qpc-hafs">﴿وَلَتَنَـٰزَعۡتُمۡ﴾</span>: اختلَفْتُم.</p><p><span class="qpc-hafs">﴿فِي ٱلۡأَمۡرِ﴾</span>: في القتالِ.</p><p><span class="qpc-hafs">﴿سَلَّمَ﴾</span>: عَصَمَ من الضَّعْفِ والاختلافِ.</p></div>"
  8,44,""
  8,45,""
  8,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِيحُكُمۡ﴾</span>: قُوَّتُكم ونَصْرُكم.</p><p><span class="qpc-hafs">﴿مَعَ ٱلصَّـٰبِرِينَ﴾</span>: بالعَوْنِ والنصرِ والتأييدِ.</p></div>"
  8,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَطَرࣰا﴾</span>: كِبْرًا.</p><p><span class="qpc-hafs">﴿وَرِئَآءَ ٱلنَّاسِ﴾</span>: مراءاةً لهم وطَلَبًا للفَخْرِ.</p></div>"
  8,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَيَّنَ﴾</span>: حَسَّنَ.</p><p><span class="qpc-hafs">﴿جَارࣱ لَّكُمۡ﴾</span>: مُعينٌ وناصرٌ لكم.</p><p><span class="qpc-hafs">﴿تَرَآءَتِ ٱلۡفِئَتَانِ﴾</span>: التقى المسلمون مع الكفارِ.</p><p><span class="qpc-hafs">﴿نَكَصَ عَلَىٰ عَقِبَيۡهِ﴾</span>: رَجَعَ إلى الوراء ووَلّى هاربًا.</p><p><span class="qpc-hafs">﴿إِنِّيٓ أَرَىٰ مَا لَا تَرَوۡنَ﴾</span>: مِن الملائكةِ الذين جاؤوا لنُصْرَةِ المؤمنين.</p></div>"
  8,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُنَـٰفِقُونَ﴾</span>: جَمْعُ مُنافق، وهو: مَن يُظهِرُ الإسلامَ ويُبْطِنُ الكفرَ.</p><p><span class="qpc-hafs">﴿فِي قُلُوبِهِم مَّرَضٌ﴾</span>: ضِعافُ الإيمانِ الشاكُّون من غيرِ نِفاقٍ.</p><p><span class="qpc-hafs">﴿غَرَّ هَـٰٓؤُلَآءِ دِينُهُمۡ﴾</span>: أي: اغترَّ المسلمون بدينِهم حتى تَكَلَّفُوا قتالَ المشركين.</p><p><span class="qpc-hafs">﴿يَتَوَكَّلۡ عَلَى ٱللَّهِ﴾</span>: يُفَوِّضْ أمرَه إليه ويعتمدْ عليه.</p></div>"
  8,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَفَّى﴾</span>: يَقْبِضُ ويَنْتَزِعُ.</p><p><span class="qpc-hafs">﴿وَأَدۡبَـٰرَهُمۡ﴾</span>: ظهورَهم.</p><p><span class="qpc-hafs">﴿ٱلۡحَرِيقِ﴾</span>: المُحْرِقِ، وهو جهنَّمُ.</p></div>"
  8,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا قَدَّمَتۡ أَيۡدِيكُمۡ﴾</span>: بسبب أعمالِكم السيئةِ.</p><p><span class="qpc-hafs">﴿لَيۡسَ بِظَلَّـٰمࣲ﴾</span>: ليس بذي ظُلْمٍ.</p></div>"
  8,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَدَأۡبِ ءَالِ فِرۡعَوۡنَ﴾</span>: حالُ المشركين في الكفرِ واستحقاقِ العذابِ كحالِ آلِ فرعونَ.</p><p><span class="qpc-hafs">﴿فَأَخَذَهُمُ ٱللَّهُ﴾</span>: أنزلَ بهم عقابَه.</p></div>"
  8,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: أي: التعذيبُ على الأعمالِ السيئة.</p></div>"
  8,54,""
  8,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدَّوَآبِّ﴾</span>: جَمْعُ دابَّةٍ، وهي: ما دَبَّ على الأرضِ من خَلْقِ اللهِ.</p></div>"
  8,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰهَدتَّ﴾</span>: التزَمْتَ معهم بميثاقٍ.</p><p><span class="qpc-hafs">﴿يَنقُضُونَ﴾</span>: يُبْطِلُون.</p></div>"
  8,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِمَّا تَثۡقَفَنَّهُمۡ﴾</span>: فإن ظَفِرْتَ بهم وصادَفْتَهم.</p><p><span class="qpc-hafs">﴿فَشَرِّدۡ بِهِم﴾</span>: ففرِّقْ وخَوِّفْ بقَتْلهِم والتنكيلِ بهم.</p><p><span class="qpc-hafs">﴿مَّنۡ خَلۡفَهُمۡ﴾</span>: غيرَهم من المحاربين.</p></div>"
  8,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱنۢبِذۡ إِلَيۡهِمۡ﴾</span>: فألْقِ إليهم عَهْدَهم.</p><p><span class="qpc-hafs">﴿عَلَىٰ سَوَآءٍ﴾</span>: حتى يَسْتَوِيَ الفريقان في العِلْم بأنه لا عَهْدَ بينَهم.</p></div>"
  8,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبَقُوٓاْ﴾</span>: أفلَتُوا ونَجَوْا من الظَّفَرِ بهم.</p><p><span class="qpc-hafs">﴿لَا يُعۡجِزُونَ﴾</span>: لن يُفْلِتُوا من عذابِ اللهِ.</p></div>"
  8,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعِدُّواْ﴾</span>: وهَيِّئوا.</p><p><span class="qpc-hafs">﴿رِّبَاطِ ٱلۡخَيۡلِ﴾</span>: إعدادِها ورَبْطِها؛ انتظارًا للغَزْوِ عليها.</p><p><span class="qpc-hafs">﴿تُرۡهِبُونَ﴾</span>: تُخَوِّفُون.</p><p><span class="qpc-hafs">﴿مِن دُونِهِمۡ﴾</span>: مِن غيرِهم.</p><p><span class="qpc-hafs">﴿لَا تَعۡلَمُونَهُمُ﴾</span>: لم تَظْهَرْ لكم عداوتُهم.</p><p><span class="qpc-hafs">﴿يُوَفَّ إِلَيۡكُمۡ﴾</span>: يُخْلِفْه اللهُ لكم في الدنيا، ويَدَّخِرْ لكم ثوابَه في الآخرة.</p><p><span class="qpc-hafs">﴿لَا تُظۡلَمُونَ﴾</span>: لا تُنْقَصُون شيئًا من أجرِ الإنفاقِ.</p></div>"
  8,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَحُواْ﴾</span>: مالَ المحارِبُون.</p><p><span class="qpc-hafs">﴿لِلسَّلۡمِ﴾</span>: للمُسالمةِ وتَرْكِ الحربِ.</p><p><span class="qpc-hafs">﴿فَٱجۡنَحۡ لَهَا﴾</span>: فمِلْ إلى المصالحةِ.</p><p><span class="qpc-hafs">﴿وَتَوَكَّلۡ عَلَى ٱللَّهِ﴾</span>: اعتمِدْ عليه وفَوِّضْ أمْرَك إليه.</p></div>"
  8,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡدَعُوكَ﴾</span>: يُدَبِّرُوا إيقاعَك فيما تَكْرَهُ.</p><p><span class="qpc-hafs">﴿حَسۡبَكَ ٱللَّهُ﴾</span>: كافِيك وناصِرُك.</p></div>"
  8,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَلَّفَ﴾</span>: وجَمَعَ.</p></div>"
  8,64,""
  8,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرِّضِ﴾</span>: بالِغْ في الحَثِّ.</p><p><span class="qpc-hafs">﴿لَّا يَفۡقَهُونَ﴾</span>: لا يَعْلمون ما أعَدَّه اللهُ للمجاهدين في سبيلِه.</p></div>"
  8,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَعَ ٱلصَّـٰبِرِينَ﴾</span>: بتأييدِه ونَصْرِه.</p></div>"
  8,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُثۡخِنَ﴾</span>: يُبالِغَ في قَتْلِ الأعداءِ.</p><p><span class="qpc-hafs">﴿عَرَضَ ٱلدُّنۡيَا﴾</span>: حُطامَها، وهو: الفِداءُ من أسْرى «بدر».</p><p><span class="qpc-hafs">﴿يُرِيدُ ٱلۡـَٔاخِرَةَ﴾</span>: ثوابَها، بإظهارِ الدِّين، وما يَحْصِلُ لكم من أجْر الجهادِ.</p><p><span class="qpc-hafs">﴿عَزِيزٌ﴾</span>: قويٌّ قادرٌ لا يُقْهَرُ.</p><p><span class="qpc-hafs">﴿حَكِيمࣱ﴾</span>: ذو حِكْمةٍ في أفعالِه كلِّها.</p></div>"
  8,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبࣱ مِّنَ ٱللَّهِ﴾</span>: قَضاءٌ وحُكْمٌ منه.</p><p><span class="qpc-hafs">﴿سَبَقَ﴾</span>: بإباحةِ الغنيمةِ وفِداءِ الأسرى.</p><p><span class="qpc-hafs">﴿لَمَسَّكُمۡ﴾</span>: لَأصابَكم.</p></div>"
  8,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِمَّا غَنِمۡتُمۡ﴾</span>: مِن قِتالِ عَدُوِّكم وفِداءِ الأسرى.</p></div>"
  8,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّمَّآ أُخِذَ مِنكُمۡ﴾</span>: من المالِ بأن يُيَسِّرَ اللهُ لكم من فَضْلِه خيرًا كثيرًا.</p></div>"
  8,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خِيَانَتَكَ﴾</span>: بالغَدْرِ بك وخِداعِكَ.</p><p><span class="qpc-hafs">﴿خَانُواْ ٱللَّهَ﴾</span>: بمخالفةِ أمْرِه.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: قبلَ غزوةِ «بدرٍ».</p><p><span class="qpc-hafs">﴿فَأَمۡكَنَ مِنۡهُمۡ﴾</span>: فأقدرك الله عليهم ونَصَرَك.</p></div>"
  8,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَاجَرُواْ﴾</span>: انتقلُوا إلى دارِ الإسلام، أو بلدٍ يتمكَّنُون فيه من العبادةِ.</p><p><span class="qpc-hafs">﴿وَٱلَّذِينَ ءَاوَواْ﴾</span>: هم الأنصارُ الذين أسكنُوا النبيَّ ﷺ والمهاجرين في دُورِهم.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءُ بَعۡضࣲ﴾</span>: في النُّصْرَةِ والمعونةِ.</p><p><span class="qpc-hafs">﴿وَلَـٰيَتِهِم﴾</span>: نُصْرَتهِم.</p><p><span class="qpc-hafs">﴿ٱسۡتَنصَرُوكُمۡ﴾</span>: طلبُوا نُصْرَتَكم.</p><p><span class="qpc-hafs">﴿فِي ٱلدِّينِ﴾</span>: بأنهم من أهلِ دينِكم.</p><p><span class="qpc-hafs">﴿مِّيثَـٰقࣱ﴾</span>: عَهْدٌ مؤكَّدٌ.</p></div>"
  8,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا تَفۡعَلُوهُ﴾</span>: أي: تَوَلِّيَ المؤمنين ونُصْرتهم.</p><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: للمؤمنين عن دينِهم.</p><p><span class="qpc-hafs">﴿وَفَسَادࣱ كَبِيرࣱ﴾</span>: بالصَّدِّ عن سبيلِ اللهِ، وقوةِ الكفرِ.</p></div>"
  8,74,""
  8,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَعۡدُ﴾</span>: بعدَ السابقين إلى الإيمانِ والهجرةِ.</p><p><span class="qpc-hafs">﴿فَأُوْلَـٰٓئِكَ مِنكُمۡ﴾</span>: أي: لهم ما لكم وعليهم ما عليكم.</p><p><span class="qpc-hafs">﴿وَأُوْلُواْ ٱلۡأَرۡحَامِ﴾</span>: ذَوو القَراباتِ.</p><p><span class="qpc-hafs">﴿أَوۡلَىٰ بِبَعۡضࣲ﴾</span>: في الميراثِ من عامَّةِ المسلمين.</p><p><span class="qpc-hafs">﴿كِتَـٰبِ ٱللَّهِ﴾</span>: حُكْمِه الذي كَتَبَه في اللَّوحِ المحفوظِ.</p></div>"
