quran[29]{c,v,t}:
  48,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَحۡنَا لَكَ﴾</span>: قَضَينا لَكَ.</p><p><span class="qpc-hafs">﴿مُّبِينࣰا﴾</span>: عَظِيما.</p></div>"
  48,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣰا﴾</span>: طَرِيقًا.</p></div>"
  48,3,""
  48,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّكِينَةَ﴾</span>: الطُّمأنِينَةَ.</p></div>"
  48,5,""
  48,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَنَّ ٱلسَّوۡءِ﴾</span>: الظَّنَّ السَّيِّئَ.</p><p><span class="qpc-hafs">﴿دَآئِرَةُ ٱلسَّوۡءِ﴾</span>: الشِّدَّةُ المُحِيطَةُ الَّتِي تسُوءُهُم.</p><p><span class="qpc-hafs">﴿وَلَعَنَهُمۡ﴾</span>: وطَردَهُمْ مِن رحْمَتِهِ.</p></div>"
  48,7,""
  48,8,""
  48,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتُعَزِّرُوهُ﴾</span>: وتَنْصُروا الله بِنصْرِ دِينِهِ.</p><p><span class="qpc-hafs">﴿وَتُوَقِّرُوهُ﴾</span>: وتُعَظِّمُوا اللهَ.</p><p><span class="qpc-hafs">﴿بُكۡرَةࣰ﴾</span>: أوَّلَ النَّهارِ.</p><p><span class="qpc-hafs">﴿وَأَصِيلًا﴾</span>: آخِرَ النَّهارِ.</p></div>"
  48,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبَايِعُونَكَ﴾</span>: يُعاهِدُونَكَ على الطّاعةِ.</p><p><span class="qpc-hafs">﴿نَّكَثَ﴾</span>: نَقَضَ بَيْعَتَهُ.</p><p><span class="qpc-hafs">﴿يَنكُثُ عَلَىٰ نَفۡسِهِۦ﴾</span>: يَعُودُ وبالُ ذلِكَ عَلى نَفْسِهِ.</p></div>"
  48,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُخَلَّفُونَ﴾</span>: الَّذِينَ تَخَلَّفُوا عَنِ الخُروجِ مَعَكَ إلى مكَّةَ.</p></div>"
  48,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنقَلِبَ﴾</span>: يَرْجِعَ.</p><p><span class="qpc-hafs">﴿بُورࣰا﴾</span>: هَلْكى.</p></div>"
  48,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡتَدۡنَا﴾</span>: أعْدَدْنا.</p><p><span class="qpc-hafs">﴿سَعِيرࣰا﴾</span>: نارًا مُؤَجَّجَةً.</p></div>"
  48,14,""
  48,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغَانِمَ﴾</span>: غَنائِمِ خَيبَرَ.</p><p><span class="qpc-hafs">﴿ذَرُونَا﴾</span>: اتْرُكُونا.</p><p><span class="qpc-hafs">﴿كَلَـٰمَ ٱللَّهِ﴾</span>: وعْدَهُ لَكُم بِغنائِمِ خَيبَرَ، واخْتِصاصِها بِمَن شَهِدَ الحُدَيبِيَةَ.</p></div>"
  48,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلِي بَأۡسࣲ﴾</span>: أصْحابِ قُوَّةٍ.</p><p><span class="qpc-hafs">﴿وَإِن تَتَوَلَّوۡاْ﴾</span>: تُعْرِضُوا.</p></div>"
  48,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَجࣱ﴾</span>: إثْمٌ في تَخَلُّفِهِ عَنِ الجِهادِ.</p></div>"
  48,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبَايِعُونَكَ﴾</span>: يُعاهِدُونَكَ عَلى الطّاعِة والنُّصْرَةِ.</p><p><span class="qpc-hafs">﴿ٱلسَّكِينَةَ﴾</span>: الطُّمأنِينةَ.</p><p><span class="qpc-hafs">﴿وَأَثَـٰبَهُمۡ﴾</span>: جازاهُم.</p><p><span class="qpc-hafs">﴿فَتۡحࣰا قَرِيبࣰا﴾</span>: هو فَتْحُ «خَيْبَرَ».</p></div>"
  48,19,""
  48,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذِهِۦ﴾</span>: غَنائِمَ خَيبرَ.</p><p><span class="qpc-hafs">﴿وَكَفَّ﴾</span>: ومَنَعَ.</p></div>"
  48,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُخۡرَىٰ﴾</span>: وعَدَكُم رَبُّكُم فَتْحَ بَلْدَةٍ أُخْرى وهي مكَّةُ.</p></div>"
  48,22,""
  48,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُنَّةَ ٱللَّهِ﴾</span>: سَنَّ اللهُ ذَلِكَ سُنَّةً أي: جَعَلَهُ عادَةً لَهُ يَنْصُرُ المؤمِنينَ إذا نَصَرَوا دِينَهُ.</p></div>"
  48,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِبَطۡنِ مَكَّةَ﴾</span>: الحُدَيبِيَةِ.</p><p><span class="qpc-hafs">﴿أَظۡفَرَكُمۡ عَلَيۡهِمۡ﴾</span>: أيَّدكُم عَلَيهِم، ومَكَّنَكُم مِن رِّقابِهِم.</p></div>"
  48,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡهَدۡيَ﴾</span>: ما يُهْدى إلى الكَعْبَةِ مِنَ الأنْعامِ، أي: حَبَسُوا الهَدْيَ.</p><p><span class="qpc-hafs">﴿مَعۡكُوفًا﴾</span>: مَحْبُوسًا.</p><p><span class="qpc-hafs">﴿مَحِلَّهُۥ﴾</span>: مَكانَ حِلِّ نَحْرِه، وهو الحَرَمُ.</p><p><span class="qpc-hafs">﴿تَطَـُٔوهُمۡ﴾</span>: تُهْلِكُوهُم.</p><p><span class="qpc-hafs">﴿مَّعَرَّةُۢ﴾</span>: إثْمٌ وعَيبٌ وغَرامَةُ دِيَةٍ.</p><p><span class="qpc-hafs">﴿لَوۡ تَزَيَّلُواْ﴾</span>: لو تَمَيَّزُوا وفارَقُوا.</p></div>"
  48,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَعَلَ﴾</span>: وضَعَ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيَّةَ﴾</span>: الأَنفَةَ الَّتِي لا مُوجِبَ لَها.</p><p><span class="qpc-hafs">﴿حَمِيَّةَ ٱلۡجَـٰهِلِيَّةِ﴾</span>: الحَمِيّةَ المنْسُوبةَ إلى الجاهِليَّةِ لحَقارَتِها وشَناعَتِها.</p><p><span class="qpc-hafs">﴿سَكِينَتَهُۥ﴾</span>: الثَّباتَ والطُّمأنِينَةَ.</p><p><span class="qpc-hafs">﴿وَأَلۡزَمَهُمۡ﴾</span>: جَعَلَها لازِمةً لَهُم لا يُفارِقُونَها.</p><p><span class="qpc-hafs">﴿كَلِمَةَ ٱلتَّقۡوَىٰ﴾</span>: قولَ: لا إلَه إلّا اللهُ.</p></div>"
  48,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَدَقَ ٱللَّهُ رَسُولَهُ ٱلرُّءۡيَا﴾</span>: صَدَّقَ اللهُ رَسُولَهُ في الرُّؤيا.</p><p><span class="qpc-hafs">﴿فَتۡحࣰا قَرِيبًا﴾</span>: هو فَتْحُ خَيبرَ.</p></div>"
  48,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡهُدَىٰ﴾</span>: بِالبَيانِ الواضِحِ.</p><p><span class="qpc-hafs">﴿وَدِينِ ٱلۡحَقِّ﴾</span>: دِينِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿لِيُظۡهِرَهُۥ﴾</span>: ليُعْلِيَهُ ويُشَرِّفَهُ.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: شاهِدا.</p></div>"
  48,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِيمَاهُمۡ﴾</span>: عَلامةُ طاعَتِهِم للهِ.</p><p><span class="qpc-hafs">﴿مِّنۡ أَثَرِ ٱلسُّجُودِ﴾</span>: نُورٍ وسَمْتٍ حَسَنٍ.</p><p><span class="qpc-hafs">﴿مَثَلُهُمۡ﴾</span>: صِفَتُهُم وحالَتُهُم العجِيبَةُ.</p><p><span class="qpc-hafs">﴿شَطۡـَٔهُۥ﴾</span>: فُرُوعَهُ وفِراخَهُ.</p><p><span class="qpc-hafs">﴿فَـَٔازَرَهُۥ﴾</span>: فَقَوّى الفَرْعُ أصْلَهُ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَغۡلَظَ﴾</span>: غَلُظَ غِلَظًا شَدِيدًا في نَوعِهِ.</p><p><span class="qpc-hafs">﴿سُوقِهِۦ﴾</span>: جَمعُ ساقٍ، وهو الأصْلُ الَّذِي تَخرُجُ فِيهِ السَّنابلُ والأغْصانُ.</p></div>"
