quran[7]{c,v,t}:
  1,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسۡمِ ٱللَّهِ﴾</span>: أبتدِئُ القراءةَ مُسْتعينًا باللهِ.</p><p><span class="qpc-hafs">﴿ٱلرَّحۡمَـٰنِ﴾</span>: ذي الرَّحمةِ العامَّةِ لجميع الخَلْقِ.</p><p><span class="qpc-hafs">﴿ٱلرَّحِيمِ﴾</span>: ذي الرَّحمةِ الخاصَّةِ بِالمؤمنين.</p></div>"
  1,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَمۡدُ﴾</span>: الثَّناءُ على اللهِ بصفاتِه، وبنِعَمِه كلِّها.</p><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: جميعِ الخلْقِ.</p></div>"
  1,3,""
  1,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمِ ٱلدِّينِ﴾</span>: يومِ القيامةِ الذي يكونُ فيه الجزاءُ.</p></div>"
  1,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِيَّاكَ نَعۡبُدُ﴾</span>: نَخُصُّك بالعبادةِ.</p></div>"
  1,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصِّرَ ٰ⁠طَ ٱلۡمُسۡتَقِيمَ﴾</span>: الطَّريقَ الواضحَ، المُوصِلَ إلى رِضوانِ اللهِ، وهو الإسلامُ.</p></div>"
  1,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡعَمۡتَ عَلَيۡهِمۡ﴾</span>: مَنَنْتَ عليهم بالهدايةِ والتَّوفيقِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَغۡضُوبِ عَلَيۡهِمۡ﴾</span>: الذين عَرَفُوا الحقَّ، ولم يَعْمَلُوا به.</p><p><span class="qpc-hafs">﴿وَلَا ٱلضَّآلِّينَ﴾</span>: الذين لم يَهْتَدُوا، جَهْلًا منهم.</p></div>"
