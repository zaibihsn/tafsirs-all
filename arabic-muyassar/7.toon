quran[206]{c,v,t}:
  7,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الٓمٓصٓ﴾</span>: سبقَ شرحُ الحروفِ المقطَّعة أولَ سورة البقرة.</p></div>"
  7,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَجࣱ﴾</span>: ضِيقٌ منه لتبليغِه.</p><p><span class="qpc-hafs">﴿وَذِكۡرَىٰ﴾</span>: وتذكيرٍ.</p></div>"
  7,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أنصارًا كالشياطين والأحبارِ.</p></div>"
  7,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلَكۡنَـٰهَا﴾</span>: أرَدْنا إهلاكَها.</p><p><span class="qpc-hafs">﴿بَأۡسُنَا﴾</span>: عذابُنا.</p><p><span class="qpc-hafs">﴿بَيَـٰتًا﴾</span>: نائمين ليلًا.</p><p><span class="qpc-hafs">﴿قَآئِلُونَ﴾</span>: حالَ استراحتِهم وسطَ النهارِ.</p></div>"
  7,5,""
  7,6,""
  7,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَيۡهِم﴾</span>: على الرسُلِ والمُرْسَلِ إليهم.</p><p><span class="qpc-hafs">﴿بِعِلۡمࣲ﴾</span>: عالمِين بما يُسِرُّون، وما يُعْلِنون.</p></div>"
  7,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡوَزۡنُ يَوۡمَئِذٍ ٱلۡحَقُّ﴾</span>: وزنُ صحائفِ الأعمالِ بالميزانِ العَدْلِ.</p><p><span class="qpc-hafs">﴿ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: بثِقَلِ ما فيها من أعمالٍ حسنةٍ.</p></div>"
  7,9,""
  7,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَّنَّـٰكُمۡ﴾</span>: جَعَلْنا لكم مكانًا.</p><p><span class="qpc-hafs">﴿مَعَـٰيِشَ﴾</span>: ما تعيشُون به من مَأْكَلٍ، ومَشْرَبٍ.</p></div>"
  7,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَقۡنَـٰكُمۡ﴾</span>: خَلَقْنا أباكم آدمَ من ترابٍ.</p><p><span class="qpc-hafs">﴿صَوَّرۡنَـٰكُمۡ﴾</span>: صَوَّرْناه على الهيئةِ المفضَّلَةِ.</p></div>"
  7,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا مَنَعَكَ أَلَّا تَسۡجُدَ﴾</span>: ما مَنَعَكَ من السجودِ فأَحْوَجَك ألّا تسجدَ.</p></div>"
  7,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱهۡبِطۡ مِنۡهَا﴾</span>: فانْزِلْ من الجنةِ.</p><p><span class="qpc-hafs">﴿تَتَكَبَّرَ فِيهَا﴾</span>: تَتَعالى في الجنةِ عن أمري وطاعتي.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰغِرِينَ﴾</span>: الذَّلِيلِين الحقيرِين.</p></div>"
  7,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنظِرۡنِيٓ﴾</span>: أمْهِلْني.</p><p><span class="qpc-hafs">﴿يَوۡمِ يُبۡعَثُونَ﴾</span>: يومَ يُحيي اللهُ الخَلْقَ.</p></div>"
  7,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُنظَرِينَ﴾</span>: ممن كَتَبْتُ عليهم تأخيرَ الأجَلِ إلى النفخةِ الأولى.</p></div>"
  7,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِمَآ أَغۡوَيۡتَنِي﴾</span>: فبسببِ إضلالِكَ لي.</p><p><span class="qpc-hafs">﴿لَأَقۡعُدَنَّ لَهُمۡ﴾</span>: لَأَتَرَبَّصَنَّ في إغواءِ بني آدمَ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طَكَ ٱلۡمُسۡتَقِيمَ﴾</span>: طريقَك القويمَ، وهو الإسلامُ.</p></div>"
  7,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَـٰكِرِينَ﴾</span>: ذاكِرين نعمتَك مُثْنِين بها عليك.</p></div>"
  7,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَذۡءُومࣰا﴾</span>: ممقُوتًا مَعِيبًا.</p><p><span class="qpc-hafs">﴿مَّدۡحُورࣰا﴾</span>: مُبْعَدًا مَطْرودًا.</p></div>"
  7,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: المتجاوِزِين حُدودَ اللهِ.</p></div>"
  7,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَسۡوَسَ لَهُمَا﴾</span>: فألقى الشيطانُ لآدمَ وحواءَ وسْوَسَةً لإيقاعِهما في معصيةِ اللهِ.</p><p><span class="qpc-hafs">﴿مَا وُۥرِيَ﴾</span>: ما سُتِرَ.</p><p><span class="qpc-hafs">﴿سَوۡءَ ٰ⁠ تِهِمَا﴾</span>: عَوْراتِهما.</p><p><span class="qpc-hafs">﴿ٱلۡخَـٰلِدِينَ﴾</span>: في الجنةِ، الماكثين فيها أبدًا.</p></div>"
  7,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَاسَمَهُمَآ﴾</span>: وحَلَفَ الشيطانُ باللهِ لآدمَ وحوّاءَ.</p></div>"
  7,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَدَلَّىٰهُمَا﴾</span>: فأوقعهما وجَرَّأهما على ما أراد.</p><p><span class="qpc-hafs">﴿بِغُرُورࣲ﴾</span>: بخِداعِه.</p><p><span class="qpc-hafs">﴿وَطَفِقَا﴾</span>: وأَخَذا.</p><p><span class="qpc-hafs">﴿يَخۡصِفَانِ﴾</span>: يَلْصَقانِ على عَوْراتهِما.</p></div>"
  7,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَلَمۡنَآ أَنفُسَنَا﴾</span>: بمخالفةِ أمْرِك.</p></div>"
  7,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱهۡبِطُواْ﴾</span>: انزِلُوا من الجنةِ إلى الأرضِ.</p><p><span class="qpc-hafs">﴿وَمَتَـٰعٌ﴾</span>: ما تتمتعون به.</p><p><span class="qpc-hafs">﴿إِلَىٰ حِينࣲ﴾</span>: إلى وقتِ انقضاءِ آجالِكم.</p></div>"
  7,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُخۡرَجُونَ﴾</span>: تُبْعَثُون أحياءً من الأرض يومَ القيامةِ.</p></div>"
  7,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنزَلۡنَا﴾</span>: جَعَلْنا لكم.</p><p><span class="qpc-hafs">﴿يُوَ ٰ⁠رِي﴾</span>: يَسْتُرُ.</p><p><span class="qpc-hafs">﴿سَوۡءَ ٰ⁠ تِكُمۡ﴾</span>: عَوْراتِكم.</p><p><span class="qpc-hafs">﴿وَرِيشࣰا﴾</span>: لباسًا للزِّينةِ والتجمُّلِ.</p><p><span class="qpc-hafs">﴿وَلِبَاسُ ٱلتَّقۡوَىٰ﴾</span>: ولباسُ تقوى الله بفِعْل الأوامرِ واجتنابِ النواهي.</p></div>"
  7,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَفۡتِنَنَّكُمُ﴾</span>: لا يَخْدَعَنَّكم الشيطانُ بتزيينِ المعصيةِ.</p><p><span class="qpc-hafs">﴿لِيُرِيَهُمَا سَوۡءَ ٰ⁠ تِهِمَآ﴾</span>: لتنكشِفَ لهما عوراتُهما.</p><p><span class="qpc-hafs">﴿وَقَبِيلُهُۥ﴾</span>: ذريّةُ الشيطانِ.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أنصارًا.</p></div>"
  7,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰحِشَةࣰ﴾</span>: قَبيحًا من الفِعْلِ.</p></div>"
  7,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعدلِ.</p><p><span class="qpc-hafs">﴿وَأَقِيمُواْ وُجُوهَكُمۡ﴾</span>: وأخْلِصُوا لله العبادةَ.</p><p><span class="qpc-hafs">﴿عِندَ كُلِّ مَسۡجِدࣲ﴾</span>: في كلِّ موضعٍ من مواضعِ العبادةِ، ولا سِيَّما المساجدُ.</p><p><span class="qpc-hafs">﴿ٱلدِّينَ﴾</span>: الطاعةَ والعبادةَ.</p></div>"
  7,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ عَلَيۡهِمُ﴾</span>: ثَبَتَتْ لهم، ووَجَبَتْ عليهم.</p></div>"
  7,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زِينَتَكُمۡ﴾</span>: الزينةَ المشروعةَ من ثيابٍ ساترةٍ، ونظافةٍ، وطهارةٍ.</p><p><span class="qpc-hafs">﴿عِندَ كُلِّ مَسۡجِدࣲ﴾</span>: عند أداءِ كلِّ صلاةٍ.</p><p><span class="qpc-hafs">﴿وَلَا تُسۡرِفُوٓاْ﴾</span>: ولا تتجاوزُوا حدودَ الاعتدالِ.</p></div>"
  7,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زِينَةَ ٱللَّهِ﴾</span>: اللِّباسَ الحسنَ الذي جَعَلَه اللهُ زينةً لكم.</p><p><span class="qpc-hafs">﴿خَالِصَةࣰ﴾</span>: مخصوصةً بالمؤمنين.</p></div>"
  7,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَوَ ٰ⁠حِشَ﴾</span>: القبائحَ من الأعمالِ.</p><p><span class="qpc-hafs">﴿وَمَا بَطَنَ﴾</span>: وما كان خفيًّا.</p><p><span class="qpc-hafs">﴿وَٱلۡإِثۡمَ﴾</span>: المعاصيَ كلَّها.</p><p><span class="qpc-hafs">﴿وَٱلۡبَغۡيَ﴾</span>: الاعتداءَ على الناس.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: دليلًا وبرهانًا.</p><p><span class="qpc-hafs">﴿وَأَن تَقُولُواْ عَلَى ٱللَّهِ مَا لَا تَعۡلَمُونَ﴾</span>: وحَرَّم اللهُ أن تَنْسِبوا إليه ما لم يَشْرَعْه.</p></div>"
  7,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجَلࣱ﴾</span>: وقتٌ لحُلولِ العقوبةِ.</p><p><span class="qpc-hafs">﴿لَا يَسۡتَأۡخِرُونَ﴾</span>: لا يتأخَّرُون عنه.</p><p><span class="qpc-hafs">﴿وَلَا يَسۡتَقۡدِمُونَ﴾</span>: ولا يتقدَّمُون عليه.</p></div>"
  7,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُصُّونَ﴾</span>: يَتْلُون ويُبَيِّنُون.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِي﴾</span>: آياتِ كتابي، وأدلَّتي على صِدْقِ ما جاؤُوا به.</p></div>"
  7,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱسۡتَكۡبَرُواْ عَنۡهَآ﴾</span>: استعْلَوا عن اتِّباع دلائلِ توحيدِ اللهِ.</p></div>"
  7,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اختلَقَ.</p><p><span class="qpc-hafs">﴿نَصِيبُهُم﴾</span>: حَظُّهم من خيرٍ وشّرٍ في الدَنيا.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡكِتَـٰبِ﴾</span>: مما كُتِبَ لهم في اللَّوحِ المحفوظِ.</p><p><span class="qpc-hafs">﴿رُسُلُنَا﴾</span>: مَلَكُ الموتِ وأعوانُه.</p><p><span class="qpc-hafs">﴿يَتَوَفَّوۡنَهُمۡ﴾</span>: يقبِضُون أرواحَهم.</p><p><span class="qpc-hafs">﴿ضَلُّواْ عَنَّا﴾</span>: ذهَبُوا عنّا.</p><p><span class="qpc-hafs">﴿وَشَهِدُواْ﴾</span>: واعتَرفوا.</p></div>"
  7,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أُمَمࣲ﴾</span>: في جملةِ جماعاتٍ من أمثالِكم في الكفر.</p><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: سَبَقتْ.</p><p><span class="qpc-hafs">﴿لَّعَنَتۡ أُخۡتَهَا﴾</span>: لَعَنَتِ الجماعةُ الداخلةُ النارَ،نظيرتَها من أهلِ ملَّتِها.</p><p><span class="qpc-hafs">﴿ٱدَّارَكُواْ فِيهَا﴾</span>: اجتمعَتِ الأممُ في النار جميعًا.</p><p><span class="qpc-hafs">﴿أُخۡرَىٰهُمۡ﴾</span>: منزلةً ودخولًا، وهم الأتباعُ.</p><p><span class="qpc-hafs">﴿لِأُولَىٰهُمۡ﴾</span>: منزلةً ودخولًا، وهم الرؤساءُ والقادةُ في الضلالِ.</p><p><span class="qpc-hafs">﴿ضِعۡفࣰا﴾</span>: زائدًا على مِثْلِه مرَّةً أو مرّاتٍ.</p><p><span class="qpc-hafs">﴿لَّا تَعۡلَمُونَ﴾</span>: لا تدْرِكُون -أيها الأتباعُ- ما لكلِّ فريقٍ منكم من العذابِ.</p></div>"
  7,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا كَانَ لَكُمۡ عَلَيۡنَا مِن فَضۡلࣲ﴾</span>: نحن القادةُ متساوون معكم-أيُّها الأتباعُ- في الضَّلالِ واستحقاقِ العذابِ.</p></div>"
  7,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بحُجَجِنا وآياتِنا الدالَّةِ على وحْدانيَّتِنا.</p><p><span class="qpc-hafs">﴿وَٱسۡتَكۡبَرُواْ عَنۡهَا﴾</span>: واستعْلَوْا عن التصديقِ بها، والعملِ بَشْرعِنا.</p><p><span class="qpc-hafs">﴿لَا تُفَتَّحُ لَهُمۡ أَبۡوَ ٰ⁠بُ ٱلسَّمَآءِ﴾</span>: لا يَصْعَدُ لهم في الحياةِ إلى اللهِ عملٌ صالحٌ، ولا تُفَتَّحُ لأرواحِهم إذا ماتوا أبوابُ السماءِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ يَلِجَ﴾</span>: إلا إذا دَخَلَ.</p><p><span class="qpc-hafs">﴿سَمِّ ٱلۡخِيَاطِ﴾</span>: ثَقْبِ الإبرةِ.</p></div>"
  7,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِهَادࣱ﴾</span>: فراشٌ مِن تحتهم.</p><p><span class="qpc-hafs">﴿غَوَاشࣲ﴾</span>: أغطيةٌ من النارِ.</p></div>"
  7,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا وُسۡعَهَآ﴾</span>: إلّا ما تُطيقُ من الأعمالِ.</p></div>"
  7,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعۡنَا﴾</span>: وأذهبَ اللهُ تعالى.</p><p><span class="qpc-hafs">﴿مِّنۡ غِلࣲّ﴾</span>: من حِقْدٍ وضغائنَ كانت من بعضِهم في الدُّنيا.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهِمُ﴾</span>: من تحتِ غُرَفِهم ومنازلهِم.</p><p><span class="qpc-hafs">﴿هَدَىٰنَا لِهَـٰذَا﴾</span>: وفَّقَنا للعملِ الصالحِ.</p><p><span class="qpc-hafs">﴿أُورِثۡتُمُوهَا﴾</span>: آلَ أمرُكم إليها.</p></div>"
  7,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا وَعَدَنَا رَبُّنَا﴾</span>: على ألسنةِ رُسُلِه من إثابةِ أهلِ طاعتِه.</p><p><span class="qpc-hafs">﴿مَّا وَعَدَ رَبُّكُمۡ﴾</span>: على ألسنةِ رسُلِه من عِقابِ أهلِ معصيتِه.</p><p><span class="qpc-hafs">﴿فَأَذَّنَ مُؤَذِّنُۢ﴾</span>: فنادى منادٍ.</p><p><span class="qpc-hafs">﴿لَّعۡنَةُ ٱللَّهِ﴾</span>: غَضَبُ اللهِ وسَخَطُه.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: الذين كفرُوا، وتجاوَزُوا حدودَه.</p></div>"
  7,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَبۡغُونَهَا عِوَجࣰا﴾</span>: ويَطْلُبون أن تكونَ سبيلُ اللهِ غيرَ مستقيمةٍ.</p></div>"
  7,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَيۡنَهُمَا﴾</span>: وبينَ أصحابِ الجنةِ وأصحابِ النارِ.</p><p><span class="qpc-hafs">﴿حِجَابࣱ﴾</span>: حاجزٌ عظيمٌ يسمّى ب «الأعراف».</p><p><span class="qpc-hafs">﴿وَعَلَى ٱلۡأَعۡرَافِ رِجَالࣱ﴾</span>: وعلى أعالي ذلك السُّورِ رجالٌ استوَتْ حسناتُهم وسيئاتُهم.</p><p><span class="qpc-hafs">﴿كُلَّۢا﴾</span>: من أهلِ الجنةِ والنارِ.</p><p><span class="qpc-hafs">﴿بِسِيمَىٰهُمۡ﴾</span>: بعلاماتِهم، كبياضِ وجوهِ أهلِ الجنةِ، وسوادِ وجوهِ أهلِ النارِ.</p><p><span class="qpc-hafs">﴿يَطۡمَعُونَ﴾</span>: يَرْجُون دخولَ الجنةِ.</p></div>"
  7,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُرِفَتۡ﴾</span>: حُوِّلَتْ.</p><p><span class="qpc-hafs">﴿تِلۡقَآءَ﴾</span>: جِهةَ.</p></div>"
  7,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَآ أَغۡنَىٰ عَنكُمۡ﴾</span>: ما نَفَعكم.</p><p><span class="qpc-hafs">﴿جَمۡعُكُمۡ﴾</span>: ما كنتم تَجْمعون من الأموالِ والرجالِ.</p></div>"
  7,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهَـٰٓؤُلَآءِ﴾</span>: أي: الضعفاءُ والفقراءُ.</p><p><span class="qpc-hafs">﴿لَا يَنَالُهُمُ ٱللَّهُ بِرَحۡمَةٍ﴾</span>: لا يُدْخِلُهم الجنةَ.</p></div>"
  7,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفِيضُواْ﴾</span>: صُبُّوا بكثرةٍ.</p><p><span class="qpc-hafs">﴿رَزَقَكُمُ ٱللَّهُ﴾</span>: من الطعام.</p></div>"
  7,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱتَّخَذُواْ دِينَهُمۡ لَهۡوࣰا وَلَعِبࣰا﴾</span>: جَعَلُوا ما أمرَهم اللهُ باتِّباعِه لهوًا وباطلًا.</p><p><span class="qpc-hafs">﴿وَغَرَّتۡهُمُ﴾</span>: وخَدَعَتْهم.</p><p><span class="qpc-hafs">﴿نَنسَىٰهُمۡ﴾</span>: نُعامِلُهم معاملةَ الشيء المَنسِيِّ.</p><p><span class="qpc-hafs">﴿كَمَا نَسُواْ﴾</span>: كما تركُوا العملَ.</p><p><span class="qpc-hafs">﴿يَوۡمِهِمۡ هَـٰذَا﴾</span>: يومِ القيامةِ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا يَجۡحَدُونَ﴾</span>: يُنكرون أدلةَ اللهِ وبراهينَه مع عِلْمِهم بأنها حقٌّ.</p></div>"
  7,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِكِتَـٰبࣲ﴾</span>: بقرآنٍ أنزَلْناه إليك.</p><p><span class="qpc-hafs">﴿فَصَّلۡنَـٰهُ﴾</span>: بيَّناه أتمَّ بَيانٍ.</p></div>"
  7,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ يَنظُرُونَ﴾</span>: ما ينتظرون.</p><p><span class="qpc-hafs">﴿تَأۡوِيلَهُۥ﴾</span>: ما يَؤولُ إليه أمرُهم من العقابِ.</p><p><span class="qpc-hafs">﴿نَسُوهُ مِن قَبۡلُ﴾</span>: تَرَكُوا الإيمانَ بالقرآنِ في الدنيا.</p><p><span class="qpc-hafs">﴿أَوۡ نُرَدُّ﴾</span>: أو نُعادُ إلى الدنيا.</p><p><span class="qpc-hafs">﴿خَسِرُوٓاْ أَنفُسَهُمۡ﴾</span>: صاروا إلى الهَلاكِ بدخولِهم النارَ وخُلودِهم فيها.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: وذَهَبَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَعْبُدُونه من دونِ اللهِ.</p></div>"
  7,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: علا وارتفعَ، استواءً يَليق بجَلالِه وعَظَمَتِه.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: سريرِ المُلْكِ الذي استوى عليه الرحمنُ، وتَحْمِلُه الملائكة، وهو أعظمُ المخلوقات، وهو سَقْفُ الجنةِ.</p><p><span class="qpc-hafs">﴿يُغۡشِي ٱلَّيۡلَ ٱلنَّهَارَ﴾</span>: يُدْخِلُ سبحانَه الليلَ على النهارِ حتى يَذْهَبَ نورُه، ويُدْخِلُ النهارَ على الليل حتى يَذْهَبَ ظلامُه.</p><p><span class="qpc-hafs">﴿يَطۡلُبُهُۥ﴾</span>: كلٌّ من الليلِ والنهارِ يَطْلُبُ الآخَرَ.</p><p><span class="qpc-hafs">﴿حَثِيثࣰا﴾</span>: طَلَبًا سريعًا دائمًا.</p><p><span class="qpc-hafs">﴿مُسَخَّرَ ٰ⁠تِۭ﴾</span>: مُذَلَّلاتٍ خاضعاتٍ.</p><p><span class="qpc-hafs">﴿لَهُ ٱلۡخَلۡقُ﴾</span>: إيجادُ الأشياءِ من العَدَمِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَمۡرُ﴾</span>: التدبيرُ والتصرُّفُ في مخلوقاتِه كما يشاءُ.</p><p><span class="qpc-hafs">﴿تَبَارَكَ ٱللَّهُ﴾</span>: كَثُرَتْ بَرَكَتُه واتسعَتْ.</p></div>"
  7,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَضَرُّعࣰا﴾</span>: تَذَلُّلًا.</p><p><span class="qpc-hafs">﴿وَخُفۡيَةً﴾</span>: سِرًّا.</p><p><span class="qpc-hafs">﴿ٱلۡمُعۡتَدِينَ﴾</span>: المتجاوِزِين حدودَ ما شَرَعَه اللهُ.</p></div>"
  7,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡدَ إِصۡلَـٰحِهَا﴾</span>: ببعثةِ الرسلِ وعُمْرانِها بطاعةِ اللهِ.</p></div>"
  7,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُشۡرَۢا﴾</span>: مُبَشِّراتٍ بالمطرِ قبلَ نزولِه.</p><p><span class="qpc-hafs">﴿بَيۡنَ يَدَيۡ رَحۡمَتِهِۦ﴾</span>: أمامَ نزولِ المطرِ.</p><p><span class="qpc-hafs">﴿أَقَلَّتۡ﴾</span>: حَمَلَتْ.</p><p><span class="qpc-hafs">﴿ثِقَالࣰا﴾</span>: مُحمَّلًا بالمطرِ.</p><p><span class="qpc-hafs">﴿لِبَلَدࣲ مَّيِّتࣲ﴾</span>: لأرضٍ لا نباتَ فيها ولا مَرْعى.</p></div>"
  7,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡبَلَدُ ٱلطَّيِّبُ يَخۡرُجُ نَبَاتُهُۥ﴾</span>: مَثَلٌ ضربَه اللهُ للمؤمنِ بأنه طَيِّبٌ وعَمَلَه طيبٌ.</p><p><span class="qpc-hafs">﴿وَٱلَّذِي خَبُثَ﴾</span>: مَثَلٌ ضَرَبَه اللهُ للكافرِ بأنه خبيثٌ وعَمَلَه خبيثٌ.</p><p><span class="qpc-hafs">﴿نَكِدࣰا﴾</span>: عسِرًا رديئًا لا نَفْعَ فيه.</p><p><span class="qpc-hafs">﴿نُصَرِّفُ﴾</span>: نُبَيِّنُ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الحُجَجَ والبراهينَ.</p></div>"
  7,59,""
  7,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: أشرافُ القومِ وسادتُهم.</p><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ﴾</span>: ذَهابٍ عن الحقِّ والصوابِ.</p></div>"
  7,61,""
  7,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعۡلَمُ مِنَ ٱللَّهِ﴾</span>: وأَعْلَمُ مما أوحاه الله إليَّ من شريعتِه.</p></div>"
  7,63,""
  7,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السفينةِ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بحُجَجِنا الواضحةِ.</p><p><span class="qpc-hafs">﴿عَمِينَ﴾</span>: جَمْعُ عَمٍ، أي: لا تُبْصِرُ قلوبُهم الحقَّ والإيمان.</p></div>"
  7,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَادٍ﴾</span>: قومِ هودٍ عليه السلام، وهم قبيلةٌ من العربِ.</p></div>"
  7,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَفَاهَةࣲ﴾</span>: خِفَّةِ عقلٍ وحَماقةٍ.</p><p><span class="qpc-hafs">﴿لَنَظُنُّكَ﴾</span>: لَنُوقِنُ بأنك.</p></div>"
  7,67,""
  7,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمِينٌ﴾</span>: على ما أقولُ من وحْيِ اللهِ.</p></div>"
  7,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُلَفَآءَ﴾</span>: تَخْلُفُون في الأرض مَن قبلَكم.</p><p><span class="qpc-hafs">﴿بَصۜۡطَةࣰ﴾</span>: قوةً وضَخامةً وطُولًا.</p><p><span class="qpc-hafs">﴿ءَالَآءَ ٱللَّهِ﴾</span>: جَمْعُ إلىً، وهي نِعَمُه الكثيرةُ عليكم.</p></div>"
  7,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَذَرَ﴾</span>: ونَتْرُكَ.</p><p><span class="qpc-hafs">﴿بِمَا تَعِدُنَآ﴾</span>: بما تُخَوِّفُنا به من العذابِ.</p></div>"
  7,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِجۡسࣱ﴾</span>: عذابٌ.</p><p><span class="qpc-hafs">﴿وَغَضَبٌ﴾</span>: سُخْطٌ وانتقامٌ.</p><p><span class="qpc-hafs">﴿أَسۡمَآءࣲ سَمَّيۡتُمُوهَآ﴾</span>: أصنامٍ سَمَّيتُموها آلهةً.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣲ﴾</span>: حُجَّةٍ ومَعْذِرةٍ تعتذرون بها.</p><p><span class="qpc-hafs">﴿فَٱنتَظِرُوٓاْ﴾</span>: نزولَ عذابِ الله عليكم.</p></div>"
  7,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَطَعۡنَا دَابِرَ﴾</span>: وأهْلَك اللهُ الكفارَ من قومِ عادٍ، واستأصَلَهم بالريحِ.</p></div>"
  7,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَمُودَ﴾</span>: قومِ صالحٍ عليه السلام، وهم قبيلةٌ من العربِ.</p><p><span class="qpc-hafs">﴿بَيِّنَةࣱ﴾</span>: برهانٌ على صِدْقِ نبيِّكم.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: دليلًا على نبوَّتي.</p><p><span class="qpc-hafs">﴿فَذَرُوهَا﴾</span>: فاترُكُوها.</p><p><span class="qpc-hafs">﴿بِسُوٓءࣲ﴾</span>: بأيِّ أذى.</p></div>"
  7,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُلَفَآءَ﴾</span>: تَخْلُفُون في الأرضِ مَن قبلَكم.</p><p><span class="qpc-hafs">﴿وَبَوَّأَكُمۡ﴾</span>: ومَكَّن لكم وأَنْزَلَكم.</p><p><span class="qpc-hafs">﴿فِي ٱلۡأَرۡضِ﴾</span>: أرضِ الحِجْرِ.</p><p><span class="qpc-hafs">﴿قُصُورࣰا﴾</span>: بيوتًا عظيمةً.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡاْ﴾</span>: ولا تُفْرِطُوا في الفَساد.</p></div>"
  7,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَكۡبَرُواْ﴾</span>: استَعْلَوْا عن الإيمان.</p></div>"
  7,76,""
  7,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُواْ ٱلنَّاقَةَ﴾</span>: فنَحرُوها.</p><p><span class="qpc-hafs">﴿وَعَتَوۡاْ﴾</span>: وتجاوَزُوا الحَدَّ في الاستِكْبار.</p><p><span class="qpc-hafs">﴿بِمَا تَعِدُنَآ﴾</span>: بما تتوعَّدُنا به من العَذابِ.</p></div>"
  7,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّجۡفَةُ﴾</span>: الزَّلزلةُ الشديدةُ من الأرضِ.</p><p><span class="qpc-hafs">﴿جَـٰثِمِينَ﴾</span>: لاصِقِين بالأرضِ على رُكَبهِم ووُجوهِهم، لا حَراكَ بهم.</p></div>"
  7,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّىٰ﴾</span>: فأَعْرَضَ.</p></div>"
  7,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَـٰحِشَةَ﴾</span>: الفَعْلَةَ المُنْكَرةُ، وهي إتيانُ الرِّجالِ.</p></div>"
  7,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن دُونِ ٱلنِّسَآءِ﴾</span>: تاركين ما أحلَّه اللهُ لكم من نسائِكم.</p><p><span class="qpc-hafs">﴿مُّسۡرِفُونَ﴾</span>: متجاوِزُون ما أحلَّه اللهُ لكم إلى الحَرامِ.</p></div>"
  7,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَطَهَّرُونَ﴾</span>: يتنزَّهُون عن إتيانِ الرجالِ في أدبارِهم.</p></div>"
  7,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَـٰبِرِينَ﴾</span>: الهالِكين الباقين في العذابِ.</p></div>"
  7,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَمۡطَرۡنَا عَلَيۡهِم﴾</span>: وأرسل اللهُ على الكفارِ من قومِ لوطٍ.</p><p><span class="qpc-hafs">﴿مَّطَرࣰا﴾</span>: حجارةً متتابعةً.</p></div>"
  7,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَدۡيَنَ﴾</span>: قومِ شُعَيبٍ عليه السَّلام، وهم قبيلةٌ من العربِ.</p><p><span class="qpc-hafs">﴿بَيِّنَةࣱ﴾</span>: حُجَّةٌ ظاهرةٌ.</p><p><span class="qpc-hafs">﴿فَأَوۡفُواْ﴾</span>: فأتِمُّوا.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡخَسُواْ﴾</span>: ولا تَنْقُصُوا.</p><p><span class="qpc-hafs">﴿بَعۡدَ إِصۡلَـٰحِهَا﴾</span>: بشرائعِ الأنبياءِ، وعُمْرانِها بطاعَةِ اللهِ.</p></div>"
  7,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ﴾</span>: طريقٍ.</p><p><span class="qpc-hafs">﴿تُوعِدُونَ﴾</span>: تُخَوِّفون الناسَ بالقَتْل إن لم يُعْطُوكم أموالَهم.</p><p><span class="qpc-hafs">﴿وَتَبۡغُونَهَا عِوَجࣰا﴾</span>: وتُريدون أن تكونَ سبيلُ اللهِ مائلة وفْقَ أهوائِكم.</p></div>"
  7,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱصۡبِرُواْ﴾</span>: فانتظرُوا أيُّها المكذِّبون.</p><p><span class="qpc-hafs">﴿يَحۡكُمَ ٱللَّهُ بَيۡنَنَا﴾</span>: يَفْصِلَ بينَنا وبينكَم.</p></div>"
  7,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَكۡبَرُواْ﴾</span>: استعلَوْا عن الإيمانِ.</p><p><span class="qpc-hafs">﴿مِلَّتِنَا﴾</span>: دينِنا.</p></div>"
  7,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱفۡتَحۡ﴾</span>: احكُمْ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰتِحِينَ﴾</span>: الحاكمين.</p></div>"
  7,90,""
  7,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّجۡفَةُ﴾</span>: الزَّلزلةُ الشديدةُ من الأرضِ.</p><p><span class="qpc-hafs">﴿جَـٰثِمِينَ﴾</span>: لاصِقين بالأرضِ على رُكَبِهم ووجوهِهم، لا حَراكَ بهم.</p></div>"
  7,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَا﴾</span>: كأنّ قومَ شُعَيبٍ لم يُقيموا في ديارِهم، و يتمتَّعوا فيها.</p></div>"
  7,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّىٰ﴾</span>: فأَعرَضَ.</p><p><span class="qpc-hafs">﴿ءَاسَىٰ﴾</span>: أحْزَنُ.</p></div>"
  7,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن نَّبِيٍّ﴾</span>: أي: كذَّبه قومُه.</p><p><span class="qpc-hafs">﴿أَخَذۡنَآ﴾</span>: ابتلَينا.</p><p><span class="qpc-hafs">﴿بِٱلۡبَأۡسَآءِ﴾</span>: البؤسِ وضيقِ المعيشةِ.</p><p><span class="qpc-hafs">﴿وَٱلضَّرَّآءِ﴾</span>: ما يَضرُّ الإنسانَ في نفسِه أو معيشتِه.</p><p><span class="qpc-hafs">﴿يَضَّرَّعُونَ﴾</span>: يُظْهِرُون الخضوعَ والاستكانةَ للهِ.</p></div>"
  7,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّيِّئَةِ﴾</span>: الحالِ السيئةِ من البلاءِ والجَدْبِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَسَنَةَ﴾</span>: الحالَ الحسنةَ من الرَّخاءِ والنِّعمةِ والعافيةِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ عَفَواْ﴾</span>: حتى كَثُروا وكَثُرَتْ أموالُهم.</p><p><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُم﴾</span>: فأهلَكْناهم.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأةً.</p></div>"
  7,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱتَّقَوۡاْ﴾</span>: واجتَنَبُوا ما نهاهم اللهُ عنه.</p><p><span class="qpc-hafs">﴿بَرَكَـٰتࣲ مِّنَ ٱلسَّمَآءِ وَٱلۡأَرۡضِ﴾</span>: ما يتتابعُ عليهم من الخير من كلِّ وجْهٍ.</p></div>"
  7,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَأۡسُنَا﴾</span>: عذابُ اللهِ.</p><p><span class="qpc-hafs">﴿بَيَـٰتࣰا﴾</span>: ليلًا.</p></div>"
  7,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلۡعَبُونَ﴾</span>: يشتغلون بما لا يعودُ عليهم بفائدةٍ.</p></div>"
  7,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكۡرَ ٱللَّهِ﴾</span>: استدراجَه للمكذِّبين بما أنعمَ به عليهم، وعقوبتَهم.</p></div>"
  7,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِ﴾</span>: يتبيَّنْ.</p><p><span class="qpc-hafs">﴿يَرِثُونَ ٱلۡأَرۡضَ﴾</span>: بالسُّكنى.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ أَهۡلِهَآ﴾</span>: من بعدِ إهلاكِ أهلِها السابقين.</p><p><span class="qpc-hafs">﴿وَنَطۡبَعُ﴾</span>: ونَخْتِمُ.</p><p><span class="qpc-hafs">﴿لَا يَسۡمَعُونَ﴾</span>: الموعظةَ سماعَ منتفعٍ بها.</p></div>"
  7,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَقُصُّ﴾</span>: نَذْكُرُ.</p><p><span class="qpc-hafs">﴿أَنۢبَآئِهَا﴾</span>: أخبارِها.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالحُجَجِ الظاهرةِ الدالَّةِ على صِدْقِهم.</p><p><span class="qpc-hafs">﴿ٱلۡكَـٰفِرِينَ﴾</span>: الذين كَتَبَ اللهُ عليهم ألّا يُؤمنوا.</p></div>"
  7,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ عَهۡدࣲ﴾</span>: مِن وفاءٍ بما وصّاهم اللهُ به.</p><p><span class="qpc-hafs">﴿لَفَـٰسِقِينَ﴾</span>: لخارجينَ عن طاعةِ اللهِ وامتثالِ أمرِه.</p></div>"
  7,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بالمعجزاتِ الظاهرةِ الدالَّةِ على صِدْقِه.</p><p><span class="qpc-hafs">﴿فِرۡعَوۡنَ﴾</span>: لَقَبٌ لكلِّ مَن مَلَك مِصْرَ في القديم.</p><p><span class="qpc-hafs">﴿فَظَلَمُواْ بِهَا﴾</span>: فَجحَدُوا وكَفَروا بها.</p></div>"
  7,104,""
  7,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقِيقٌ﴾</span>: جديرٌ وحَرِيٌّ.</p><p><span class="qpc-hafs">﴿بِبَيِّنَةࣲ﴾</span>: ببُرهانٍ وحُجَّةٍ واضحةٍ على صِدْقِ ما أقولُ.</p></div>"
  7,106,""
  7,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُعۡبَانࣱ﴾</span>: حَيَّةٌ عظيمةٌ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: ظاهرةٌ لكلِّ مَن يَراها.</p></div>"
  7,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعَ يَدَهُۥ﴾</span>: وأخرجَ يدَه من فتحةِ قميصِه، أو من تحتِ إبْطِه.</p></div>"
  7,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: أشرافُ القومِ وسادَتُهم.</p></div>"
  7,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَأۡمُرُونَ﴾</span>: تُشيرون عليَّ أيها الأشرافُ.</p></div>"
  7,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡجِهۡ وَأَخَاهُ﴾</span>: أخِّرْ موسى وأخاه هارونَ، ولا تَفْصِلْ في شأنِهما الآن.</p><p><span class="qpc-hafs">﴿فِي ٱلۡمَدَآئِنِ﴾</span>: في مُدُنِ مِصْرَ وأقاليمِها.</p><p><span class="qpc-hafs">﴿حَـٰشِرِينَ﴾</span>: مَن يَحْشُرُ السَّحَرَةَ فيَجْمَعُهم إليك.</p></div>"
  7,112,""
  7,113,""
  7,114,""
  7,115,""
  7,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَحَرُوٓاْ أَعۡيُنَ ٱلنَّاسِ﴾</span>: صَرَفُوها عن حقيقةِ إدراكِها، فخُيِّلَ إلى الأبصارِ أنّ ما فعلُوه حقيقةٌ.</p><p><span class="qpc-hafs">﴿وَٱسۡتَرۡهَبُوهُمۡ﴾</span>: وأخافوا الناسَ إخافةً شديدةً.</p></div>"
  7,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلۡقَفُ﴾</span>: تبتلِعُ بسرعة.</p><p><span class="qpc-hafs">﴿مَا يَأۡفِكُونَ﴾</span>: ما يُلْقُونه من الحِبال والعِصِيِّ، ويُوهِمونَ الناسَ أنه حقٌّ.</p></div>"
  7,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَقَعَ ٱلۡحَقُّ﴾</span>: فظهر الحقُّ في أمرِ موسى عليه السلام.</p></div>"
  7,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱنقَلَبُواْ﴾</span>: وانصرفَ فرعونُ وقومُه.</p><p><span class="qpc-hafs">﴿صَـٰغِرِينَ﴾</span>: أذلّاءَ بما لَحِقَهم من الهزيمةِ والخَيبةِ.</p></div>"
  7,120,""
  7,121,""
  7,122,""
  7,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاذَنَ لَكُمۡ﴾</span>: أسْمَحَ لكم بالإيمان بما يَدْعُو إليه موسى.</p><p><span class="qpc-hafs">﴿لَمَكۡرࣱ مَّكَرۡتُمُوهُ﴾</span>: إن إيمانَكم بالله وإقرارَكم بنبوَّةِ موسى لَحيلةٌ احتَلْتُموها.</p></div>"
  7,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ خِلَـٰفࣲ﴾</span>: بقَطْع اليدِ اليمنى والرِّجلِ اليسرى، أو اليدِ اليسرى والرِّجلِ اليمنى.</p><p><span class="qpc-hafs">﴿لَأُصَلِّبَنَّكُمۡ﴾</span>: لَأُبالِغَنَّ في شَدِّ أطرافِكم وتعليقِكم على جُذوع النَّخْلِ.</p></div>"
  7,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنقَلِبُونَ﴾</span>: راجِعُون إلى اللهِ.</p></div>"
  7,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تَنقِمُ﴾</span>: ولَسْتَ تَعِيبُ منا -يا فرعونُ- وتُنْكِرُ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِ رَبِّنَا﴾</span>: بحُجَجِه وأدلَّتِه.</p><p><span class="qpc-hafs">﴿أَفۡرِغۡ﴾</span>: أنْزِلْ وأسبِغْ.</p></div>"
  7,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَذَرُ﴾</span>: أتَتْرُك.</p><p><span class="qpc-hafs">﴿لِيُفۡسِدُواْ فِي ٱلۡأَرۡضِ﴾</span>: في أرضِ مصرَ بتغييرِ دينِ الناسِ إلى عبادةِ اللهِ وحدَه.</p><p><span class="qpc-hafs">﴿وَيَذَرَكَ وَءَالِهَتَكَ﴾</span>: وقد تَرَكَك وتَرَكَ عبادةَ آلهتِك؟</p><p><span class="qpc-hafs">﴿وَنَسۡتَحۡيِۦ نِسَآءَهُمۡ﴾</span>: ونَسْتبقيهنَّ أحياءً للخدمةِ والامتهانِ.</p><p><span class="qpc-hafs">﴿قَـٰهِرُونَ﴾</span>: عالُون عليهم بقَهْرِ المُلْكِ والسلطانِ.</p></div>"
  7,128,""
  7,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن قَبۡلِ أَن تَأۡتِيَنَا﴾</span>: برسالةِ اللهِ إلينا.</p><p><span class="qpc-hafs">﴿وَمِنۢ بَعۡدِ مَا جِئۡتَنَا﴾</span>: برسالةِ اللهِ.</p><p><span class="qpc-hafs">﴿وَيَسۡتَخۡلِفَكُمۡ فِي ٱلۡأَرۡضِ﴾</span>: ويَجْعَلَكم خلفاءَ في أرضِ مصرَ بعد هَلاكِ فرعونَ وقومِه.</p></div>"
  7,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخَذۡنَآ﴾</span>: ابتَلَيْنا.</p><p><span class="qpc-hafs">﴿بِٱلسِّنِينَ﴾</span>: بالقحطِ والجَدْبِ.</p></div>"
  7,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَسَنَةُ﴾</span>: العافيةُ والرَّخاءُ والخِصْبُ.</p><p><span class="qpc-hafs">﴿سَيِّئَةࣱ﴾</span>: بلاءٌ وجَدْبٌ.</p><p><span class="qpc-hafs">﴿يَطَّيَّرُواْ﴾</span>: يتشاءمُوا.</p><p><span class="qpc-hafs">﴿طَـٰٓئِرُهُمۡ﴾</span>: ما يُصيبُهم من البلاءِ والجَدْبِ.</p><p><span class="qpc-hafs">﴿عِندَ ٱللَّهِ﴾</span>: بقضاءِ اللهِ وقَدَرِه.</p></div>"
  7,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ ءَايَةࣲ﴾</span>: من دَلالةٍ وحُجَّةٍ.</p></div>"
  7,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡقُمَّلَ﴾</span>: حشراتٌ تُفْسِدُ الثمار، وتَقْضي على الحَيَوانِ والنباتِ.</p><p><span class="qpc-hafs">﴿وَٱلدَّمَ﴾</span>: فصارَتْ مياهُ القِبْط دمًا، ولم يَجِدوا ماءً صالحًا للشُّربِ.</p><p><span class="qpc-hafs">﴿مُّفَصَّلَـٰتࣲ﴾</span>: مُفَرَّقاتٍ بعضُها في إثرِ بعضٍ.</p></div>"
  7,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَعَ﴾</span>: نَزَلَ.</p><p><span class="qpc-hafs">﴿ٱلرِّجۡزُ﴾</span>: العذابُ.</p><p><span class="qpc-hafs">﴿بِمَا عَهِدَ عِندَكَ﴾</span>: بما أوحى إليك مِن رَفْعِ العذاب بالتوبةِ.</p></div>"
  7,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنكُثُونَ﴾</span>: يَنْقُضُون عُهودَهم، ويبْقَوْن على كُفْرِهم وضلالهِم.</p></div>"
  7,136,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بحُجَجِنا، وما أرَيْناهم من المعجزاتِ على يدِ موسى.</p><p><span class="qpc-hafs">﴿غَـٰفِلِينَ﴾</span>: مُعْرِضِين.</p></div>"
  7,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُسۡتَضۡعَفُونَ﴾</span>: يُسْتَذَلُّون للخِدْمَةِ والامتهانِ.</p><p><span class="qpc-hafs">﴿مَشَـٰرِقَ ٱلۡأَرۡضِ وَمَغَـٰرِبَهَا﴾</span>: بلادَ الشامِ.</p><p><span class="qpc-hafs">﴿كَلِمَتُ رَبِّكَ ٱلۡحُسۡنَىٰ﴾</span>: ما وعَدَهم من تمكينِهم في الأرضِ ونَصْرِه إياهم على فرعونَ وقومِه.</p><p><span class="qpc-hafs">﴿يَعۡرِشُونَ﴾</span>: يَبْنُون من الأبنيةِ والقصورِ وغيرِهما.</p></div>"
  7,138,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡكُفُونَ﴾</span>: يُقيمون ويُواظِبون من أجلِ العبادةِ.</p></div>"
  7,139,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَبَّرࣱ مَّا هُمۡ فِيهِ﴾</span>: مُهْلَكٌ ما هم فيه من الدِّين الباطِل والشِّرْكِ بالله.</p></div>"
  7,140,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضَّلَكُمۡ﴾</span>: بكثرةِ الأنبياء وإهلاكِ عدوِّكم.</p><p><span class="qpc-hafs">﴿عَلَى ٱلۡعَـٰلَمِينَ﴾</span>: من أهلِ عَصْرِكم.</p></div>"
  7,141,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسُومُونَكُمۡ﴾</span>: يُذيقُونكم.</p><p><span class="qpc-hafs">﴿وَيَسۡتَحۡيُونَ نِسَآءَكُمۡ﴾</span>: ويَسْتَبْقُون نساءَكم للخِدْمَةِ والامتهانِ.</p><p><span class="qpc-hafs">﴿بَلَآءࣱ﴾</span>: اختبارٌ ونعمةٌ.</p></div>"
  7,142,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡلِحۡ﴾</span>: واحمِلْ بني إسرائيلَ على عبادةِ اللهِ وطاعتِه.</p></div>"
  7,143,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن تَرَىٰنِي﴾</span>: لن تَقْدِرَ على رؤيتي في الدنيا.</p><p><span class="qpc-hafs">﴿تَجَلَّىٰ رَبُّهُۥ لِلۡجَبَلِ﴾</span>: ظَهَرَ ربُّه للجَبَلِ على الوجهِ اللائقِ بجَلالِه.</p><p><span class="qpc-hafs">﴿دَكࣰّا﴾</span>: مُسْتويًا بالأرض.</p><p><span class="qpc-hafs">﴿وَخَرَّ﴾</span>: وسقط.</p><p><span class="qpc-hafs">﴿صَعِقࣰا﴾</span>: مَغْشِيًّا عليه؛ لعِظَمِ ما رأى.</p><p><span class="qpc-hafs">﴿أَوَّلُ ٱلۡمُؤۡمِنِينَ﴾</span>: بك من قومي.</p></div>"
  7,144,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡطَفَيۡتُكَ﴾</span>: اختَرْتُك.</p><p><span class="qpc-hafs">﴿وَبِكَلَـٰمِي﴾</span>: وبتكليمي إياك من غيرِ واسطةٍ.</p></div>"
  7,145,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡأَلۡوَاحِ﴾</span>: ألواحِ التوراةِ.</p><p><span class="qpc-hafs">﴿مِن كُلِّ شَيۡءࣲ﴾</span>: يحتاجون إليه في دينِهم، وما يُصْلِحُ معاشَهم.</p><p><span class="qpc-hafs">﴿فَخُذۡهَا بِقُوَّةࣲ﴾</span>: فخُذِ التوراةَ بجِدٍّ واجتهاد.</p><p><span class="qpc-hafs">﴿بِأَحۡسَنِهَا﴾</span>: بحَسَنِها، وكلُّها حَسَنٌ بما شَرَعَ اللهُ فيها.</p><p><span class="qpc-hafs">﴿دَارَ ٱلۡفَـٰسِقِينَ﴾</span>: مصيرَهم في الآخرة، وهي النارُ.</p></div>"
  7,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنۡ ءَايَـٰتِيَ﴾</span>: عن فَهْمِ حُجَجِ الله وأدلَّتِه وكتابِه.</p><p><span class="qpc-hafs">﴿ٱلۡغَيِّ﴾</span>: الضلالِ.</p></div>"
  7,147,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَبِطَتۡ أَعۡمَـٰلُهُمۡ﴾</span>: بطَلَتْ أعمالُهم، فلا ثوابَ عليها.</p></div>"
  7,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِهِۦ﴾</span>: مِن بعدِ ما فارَقَهم لمناجاةِ ربِّه.</p><p><span class="qpc-hafs">﴿عِجۡلࣰا جَسَدࣰا﴾</span>: معبودًا مِن ذَهَبِهم على صورةِ العجلِ بلا رُوحٍ.</p><p><span class="qpc-hafs">﴿لَّهُۥ خُوَارٌ﴾</span>: له صوتٌ يُشْبِهُ صوتَ البقرِ.</p></div>"
  7,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمَّا سُقِطَ فِيٓ أَيۡدِيهِمۡ﴾</span>: ولما نَدِمُوا على عبادةِ العجلِ عند رجوعِ موسى عليه السلام.</p></div>"
  7,150,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسِفࣰا﴾</span>: حزينًا على عبادةِ قومِه العجلَ.</p><p><span class="qpc-hafs">﴿أَعَجِلۡتُمۡ أَمۡرَ رَبِّكُمۡ﴾</span>: أستعجَلْتم مجيئي إليكم وما وصَّيتُكم به من التوحيدِ، فَعَبدْتُم العِجْلَ؟</p><p><span class="qpc-hafs">﴿فَلَا تُشۡمِتۡ﴾</span>: فلا تَسُرَّ.</p></div>"
  7,151,""
  7,152,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُفۡتَرِينَ﴾</span>: المكذِّبين المبتدِعين.</p></div>"
  7,153,""
  7,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡهَبُونَ﴾</span>: يخافون أشدَّ الخوفِ من ربِّهم.</p></div>"
  7,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّمِيقَـٰتِنَا﴾</span>: للوقتِ الذي واعَدَ اللهُ موسى أن يَلْقاه فيه؛ للتوبةِ والاعتذارِ عَمّا فعلَ سُفَهاءُ بني إسرائيل.</p><p><span class="qpc-hafs">﴿ٱلرَّجۡفَةُ﴾</span>: الزَّلزلةُ الشديدةُ.</p><p><span class="qpc-hafs">﴿ٱلسُّفَهَآءُ﴾</span>: ضِعافُ العقولِ.</p><p><span class="qpc-hafs">﴿إِنۡ هِيَ إِلَّا فِتۡنَتُكَ﴾</span>: ما عبادةُ قومي للعِجْلِ إلا ابتلاءٌ واختبارٌ.</p></div>"
  7,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱكۡتُبۡ لَنَا﴾</span>: واجعَلْنا ممَّن كَتَبْتَ له.</p><p><span class="qpc-hafs">﴿حَسَنَةࣰ﴾</span>: الصالحاتِ من الأعمالِ.</p><p><span class="qpc-hafs">﴿يَتَّقُونَ﴾</span>: يخافون اللهَ ويخشَونَ عقابَه.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بدلائلِ توحيدِنا.</p></div>"
  7,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأُمِّيَّ﴾</span>: الذي لا يقرأُ ولا يكتبُ.</p><p><span class="qpc-hafs">﴿يَجِدُونَهُۥ﴾</span>: يَجِدونَ صفتَه ونبوَّتَه.</p><p><span class="qpc-hafs">﴿ٱلۡخَبَـٰٓئِثَ﴾</span>: من المطاعمِ والمشاربِ والمناكحِ.</p><p><span class="qpc-hafs">﴿وَيَضَعُ عَنۡهُمۡ﴾</span>: ويَرْفَعُ عنهم بالتخفيفِ أو الإذهاب.</p><p><span class="qpc-hafs">﴿إِصۡرَهُمۡ وَٱلۡأَغۡلَـٰلَ ٱلَّتِي كَانَتۡ عَلَيۡهِمۡ﴾</span>: ما أُلْزِمُوا العملَ به من التكاليفِ الشاقةِ في التوراة.</p><p><span class="qpc-hafs">﴿وَعَزَّرُوهُ﴾</span>: وعَظَّموه ووَقَّرُوه.</p><p><span class="qpc-hafs">﴿ٱلنُّورَ﴾</span>: القرآنَ.</p></div>"
  7,158,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَلِمَـٰتِهِۦ﴾</span>: ما أُنْزِلَ إلى النبي ﷺ من ربِّه والنبيين من قبلِه.</p></div>"
  7,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدُونَ بِٱلۡحَقِّ﴾</span>: يستقيمون على الحقِّ، ويَدْعُون الناسَ إلى الهدايةِ.</p></div>"
  7,160,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَطَّعۡنَـٰهُمُ﴾</span>: وفَرَّقْنا قومَ موسى من بني إسرائيلَ.</p><p><span class="qpc-hafs">﴿أَسۡبَاطًا﴾</span>: جمعُ سِبْطٍ، وهو ولَدُ الوَلَدِ، والمرادُ: قبائلُ بعددِ الأسباطِ مِن ولَدِ يعقوبَ.</p><p><span class="qpc-hafs">﴿فَٱنۢبَجَسَتۡ﴾</span>: فانفجرَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡغَمَـٰمَ﴾</span>: السَّحابَ.</p><p><span class="qpc-hafs">﴿ٱلۡمَنَّ﴾</span>: شيءٌ يُشْبِهُ الصَّمْغَ، طعمُه كالعَسَل.</p><p><span class="qpc-hafs">﴿وَٱلسَّلۡوَىٰ﴾</span>: طائرٌ يُشْبِهُ السُّمانى.</p></div>"
  7,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَرۡيَةَ﴾</span>: بيتَ المَقْدِسِ:</p><p><span class="qpc-hafs">﴿حِطَّةࣱ﴾</span>: مسألتُنا حِطَّةٌ، أي: حُطَّ عنا ذنوبَنا.</p><p><span class="qpc-hafs">﴿سُجَّدࣰا﴾</span>: خاضِعين للهِ تواضُعًا.</p></div>"
  7,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِجۡزࣰا﴾</span>: عذابًا.</p></div>"
  7,163,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاضِرَةَ ٱلۡبَحۡرِ﴾</span>: قريبةً من البحرِ الأحمرِ مُشْرِفةً عليه.</p><p><span class="qpc-hafs">﴿إِذۡ يَعۡدُونَ﴾</span>: إذ يعتدي أهلُ القريةِ بصيدِ السمكِ.</p><p><span class="qpc-hafs">﴿فِي ٱلسَّبۡتِ﴾</span>: في يومِ السبتِ الذي أُمِرُوا بتعظيمِه.</p><p><span class="qpc-hafs">﴿شُرَّعࣰا﴾</span>: ظاهرةً على وجهِ البحرِ قريبةً من الشاطئ.</p><p><span class="qpc-hafs">﴿وَيَوۡمَ لَا يَسۡبِتُونَ﴾</span>: وفي سائرِ الأيام غيرِ يومِ السبتِ.</p><p><span class="qpc-hafs">﴿نَبۡلُوهُم﴾</span>: نَخْتَبِرُهم.</p></div>"
  7,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُواْ مَعۡذِرَةً﴾</span>: نَعِظُهم لنُعْذَرَ فيهم عندَ اللهِ.</p></div>"
  7,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَـِٔيسِۭ﴾</span>: أليمٍ شديدٍ.</p></div>"
  7,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَتَوۡاْ﴾</span>: تمرَّدوا وتكبَّروا.</p></div>"
  7,167,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَأَذَّنَ﴾</span>: أعلمَ.</p><p><span class="qpc-hafs">﴿لَيَبۡعَثَنَّ﴾</span>: ليُسَلِّطَنَّ.</p><p><span class="qpc-hafs">﴿يَسُومُهُمۡ﴾</span>: يُذيقُهم.</p></div>"
  7,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَطَّعۡنَـٰهُمۡ﴾</span>: وفَرَّقْنا بني إسرائيلَ.</p><p><span class="qpc-hafs">﴿وَبَلَوۡنَـٰهُم﴾</span>: واخَتَبْرناهم.</p></div>"
  7,169,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلۡفࣱ﴾</span>: مَن يَخْلُفُ غيرَه بالسُّوءِ.</p><p><span class="qpc-hafs">﴿عَرَضَ هَـٰذَا ٱلۡأَدۡنَىٰ﴾</span>: ما يَعْرِضُ لهم من متاعِ الدنيا مِن دنيءِ المكاسبِ، كالرِّشوةِ والتحريفِ.</p><p><span class="qpc-hafs">﴿عَرَضࣱ مِّثۡلُهُۥ﴾</span>: متاعٌ زائلٌ من أنواعِ الكسبِ الحرامِ.</p><p><span class="qpc-hafs">﴿مِّيثَـٰقُ ٱلۡكِتَـٰبِ﴾</span>: ما أخذه اللهُ عليهم من العهودِ في التوراةِ على العملِ بها.</p><p><span class="qpc-hafs">﴿وَدَرَسُواْ مَا فِيهِ﴾</span>: وعَلِمُوا ما في التوراةِ، فضيَّعوها وتَرَكُوا العملَ بها.</p></div>"
  7,170,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُمَسِّكُونَ﴾</span>: يتمسَّكون.</p></div>"
  7,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَتَقۡنَا﴾</span>: اقتلَعْنا ورَفَعْنا.</p><p><span class="qpc-hafs">﴿ظُلَّةࣱ﴾</span>: سَحابةٌ تُظِلُّهم.</p><p><span class="qpc-hafs">﴿وَظَنُّوٓاْ﴾</span>: وأيقَنُوا.</p><p><span class="qpc-hafs">﴿وَاقِعُۢ بِهِمۡ﴾</span>: إن لم يقبَلُوا أحكامَ التوراةِ.</p><p><span class="qpc-hafs">﴿بِقُوَّةࣲ﴾</span>: بجِدٍّ واجتهادٍ.</p><p><span class="qpc-hafs">﴿وَٱذۡكُرُواْ مَا فِيهِ﴾</span>: بالعملِ بما فيه.</p></div>"
  7,172,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخَذَ﴾</span>: استخرج.</p><p><span class="qpc-hafs">﴿وَأَشۡهَدَهُمۡ عَلَىٰٓ أَنفُسِهِمۡ﴾</span>: وقرَّرَهم -جميعًا- بتوحيدِه بما أوْدَعَه في فِطَرِهم.</p><p><span class="qpc-hafs">﴿أَن تَقُولُواْ﴾</span>: لئلا تقولوا.</p></div>"
  7,173,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَتُهۡلِكُنَا﴾</span>: أفتعذِّبُنا.</p><p><span class="qpc-hafs">﴿ٱلۡمُبۡطِلُونَ﴾</span>: الذين أبْطَلُوا أعمالهم بالإشراكِ بالله.</p></div>"
  7,174,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُفَصِّلُ﴾</span>: نبيِّنُ.</p></div>"
  7,175,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱتۡلُ﴾</span>: واقصُصْ.</p><p><span class="qpc-hafs">﴿نَبَأَ﴾</span>: خبرَ رجلٍ من بني إسرائيلَ.</p><p><span class="qpc-hafs">﴿ءَاتَيۡنَـٰهُ ءَايَـٰتِنَا﴾</span>: أتاه اللهُ علمًا ببعض الكتبِ المنزَّلَةِ.</p><p><span class="qpc-hafs">﴿فَٱنسَلَخَ مِنۡهَا﴾</span>: ثم كَفَرَ بها وجَعَلَها وراءَ ظهرِه.</p><p><span class="qpc-hafs">﴿فَأَتۡبَعَهُ ٱلشَّيۡطَـٰنُ﴾</span>: لَحِقه فأدركَه فصارَ قرينَه.</p><p><span class="qpc-hafs">﴿ٱلۡغَاوِينَ﴾</span>: الضالِّين الراسِخين في الضلالِ.</p></div>"
  7,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَرَفَعۡنَـٰهُ﴾</span>: لَرَفَعْنا قَدْرَه بالعلمِ والعملِ بها.</p><p><span class="qpc-hafs">﴿أَخۡلَدَ إِلَى ٱلۡأَرۡضِ﴾</span>: رَكَنَ إلى الدُّنيا، واطمأَنَّ بها.</p></div>"
  7,177,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَآءَ﴾</span>: قَبُحَ.</p><p><span class="qpc-hafs">﴿يَظۡلِمُونَ﴾</span>: بالتكذيب وأنواع المعاصي.</p></div>"
  7,178,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن يَهۡدِ ٱللَّهُ﴾</span>: مَن يُوَفِّقْه للإيمانِ والعَمَلِ الصالحِ.</p></div>"
  7,179,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرَأۡنَا﴾</span>: خَلَقْنا.</p><p><span class="qpc-hafs">﴿لَّا يَفۡقَهُونَ بِهَا﴾</span>: لا يفْهمون بها الحقَّ ولا يَعْقلون.</p><p><span class="qpc-hafs">﴿كَٱلۡأَنۡعَـٰمِ﴾</span>: كالبَهائمِ التي لا تفقَهُ ما يُقالُ لها، ولا تُمَيِّزُ.</p></div>"
  7,180,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱدۡعُوهُ بِهَا﴾</span>: فاطْلُبُوا من الله بأسمائِه ما تُريدون.</p><p><span class="qpc-hafs">﴿وَذَرُواْ﴾</span>: واترُكُوا.</p><p><span class="qpc-hafs">﴿يُلۡحِدُونَ فِيٓ أَسۡمَـٰٓئِهِۦ﴾</span>: يَميلون بها عَمّا جُعِلَتْ له.</p></div>"
  7,181,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدُونَ بِٱلۡحَقِّ﴾</span>: يَسْتقيمون على الحقِّ، ويَدْعُون الناسَ إلى الهدايةِ.</p><p><span class="qpc-hafs">﴿وَبِهِۦ يَعۡدِلُونَ﴾</span>: وبالحقِّ يقْضُون بينَ الناسِ.</p></div>"
  7,182,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنَسۡتَدۡرِجُهُم﴾</span>: سَنُدْنِيهم -في حالِ اغْتِرارِهم- إلى ما يُهْلِكُهم ويضاعِفُ عِقابَهم.</p></div>"
  7,183,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُمۡلِي لَهُمۡ﴾</span>: وأمْهِلُهم مدةً طويلةً.</p><p><span class="qpc-hafs">﴿مَتِينٌ﴾</span>: قويٌّ لا يُدْفَعُ.</p></div>"
  7,184,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جِنَّةٍ﴾</span>: جُنونٍ.</p></div>"
  7,185,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلَكُوتِ﴾</span>: المُلْكِ العظيمِ. (زِيدت فيه الواوُ والتاء للمبالغةِ).</p><p><span class="qpc-hafs">﴿بَعۡدَهُۥ﴾</span>: بعد القرآنِ العظيمِ.</p></div>"
  7,186,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَذَرُهُمۡ﴾</span>: ويَتْرُكُهم.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنِهِمۡ﴾</span>: ضَلالِهم وكُفْرِهم.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يتردَّدُون مُتَحَيِّرين.</p></div>"
  7,187,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُرۡسَىٰهَا﴾</span>: قيامُها.</p><p><span class="qpc-hafs">﴿لَا يُجَلِّيهَا﴾</span>: لا يُظْهِرُها.</p><p><span class="qpc-hafs">﴿ثَقُلَتۡ فِي ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: ثَقُلَ عِلْمُ قيامِ الساعةِ، وخَفِيَ على أهلِ السمواتِ والأرض.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فجأةً.</p><p><span class="qpc-hafs">﴿حَفِيٌّ عَنۡهَا﴾</span>: عالِمٌ بها، مُسْتَقْصٍ بالسؤالِ عنها.</p></div>"
  7,188,""
  7,189,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾</span>: هي آدمُ عليه السلام.</p><p><span class="qpc-hafs">﴿وَجَعَلَ مِنۡهَا﴾</span>: وخَلَقَ منها.</p><p><span class="qpc-hafs">﴿زَوۡجَهَا﴾</span>: هي حواءُ.</p><p><span class="qpc-hafs">﴿لِيَسۡكُنَ إِلَيۡهَا﴾</span>: ليأنسَ ويطمئِنَّ بها.</p><p><span class="qpc-hafs">﴿تَغَشَّىٰهَا﴾</span>: جامَعَها، والمرادُ جنسُ الزوجين مِن ذريةِ آدمَ.</p><p><span class="qpc-hafs">﴿فَمَرَّتۡ بِهِۦ﴾</span>: استمرَّ بذلك الحَمْلِ إلى تمامهِ.</p><p><span class="qpc-hafs">﴿أَثۡقَلَت﴾</span>: صارت ذات ثِقَلٍ بكِبَرِ الحَمْلِ.</p><p><span class="qpc-hafs">﴿صَـٰلِحࣰا﴾</span>: أي: خَلْقًا سَوِيًّا صالحًا.</p></div>"
  7,190,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَعَلَا﴾</span>: أي: الزوجان من ذريةِ آدمَ.</p><p><span class="qpc-hafs">﴿لَهُۥ شُرَكَآءَ﴾</span>: أي: للهِ في ذلك الوَلَدِ، كنَحْوِ تسميتِه: عبدَ العُزّى.</p></div>"
  7,191,""
  7,192,""
  7,193,""
  7,194,""
  7,195,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَهُمۡ﴾</span>: ألهذه الآلهة؟</p><p><span class="qpc-hafs">﴿يَبۡطِشُونَ﴾</span>: يأخذُون بها، فَيدْفَعُون عنكم.</p><p><span class="qpc-hafs">﴿فَلَا تُنظِرُونِ﴾</span>: فلا تُمْهلوني بعد تدبيرِ كَيْدِكم.</p></div>"
  7,196,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِـِّۧيَ﴾</span>: مُتَوَلِّي حِفْظي وجميعِ أموري.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القرآنَ العظيمَ.</p></div>"
  7,197,""
  7,198,""
  7,199,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُذِ﴾</span>: اقْبَلْ أنتَ وأمَّتُكَ.</p><p><span class="qpc-hafs">﴿ٱلۡعَفۡوَ﴾</span>: ما تيسَّرَ من أخلاقِ الناسِ وأعمالِهم.</p><p><span class="qpc-hafs">﴿بِٱلۡعُرۡفِ﴾</span>: هو كلُّ ما عُرِفَ حُسْنُه في الشَّرْعِ والعَقْلِ.</p></div>"
  7,200,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنزَغَنَّكَ﴾</span>: يُصِيبَنَّك وسْوَسَةٌ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾</span>: فاستَجِرْ به والَجأْ إليه.</p></div>"
  7,201,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱتَّقَوۡاْ﴾</span>: خافُوا اللهَ بفِعْلِ أوامرِه وتَرْكِ نواهِيه.</p><p><span class="qpc-hafs">﴿طَـٰٓئِفࣱ مِّنَ ٱلشَّيۡطَـٰنِ﴾</span>: عارضٌ من وسْوَسَتِه.</p><p><span class="qpc-hafs">﴿تَذَكَّرُواْ﴾</span>: عقابَ اللهِ وثوابَه.</p><p><span class="qpc-hafs">﴿مُّبۡصِرُونَ﴾</span>: مُنْتَهُون عن المعصيةِ على بَصيرةٍ.</p></div>"
  7,202,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِخۡوَ ٰ⁠نُهُمۡ﴾</span>: وإخوانُ الشَّياطين.</p><p><span class="qpc-hafs">﴿يَمُدُّونَهُمۡ﴾</span>: يَزيدُونهم.</p><p><span class="qpc-hafs">﴿ٱلۡغَيِّ﴾</span>: الضَّلالِ.</p><p><span class="qpc-hafs">﴿لَا يُقۡصِرُونَ﴾</span>: لا يَكُفُّون عن الإغواءِ.</p></div>"
  7,203,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةࣲ﴾</span>: بعلامةٍ دالَّةٍ على صِدْقِك.</p><p><span class="qpc-hafs">﴿ٱجۡتَبَيۡتَهَا﴾</span>: اختلَقْتَها واخترَعْتَها.</p><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: أي القرآنُ المجيدُ.</p><p><span class="qpc-hafs">﴿بَصَآئِرُ﴾</span>: جمعُ بَصيرةٍ، وهي الحُجَجُ والبراهينُ التي يُسْتَبصَرُ بها.</p><p><span class="qpc-hafs">﴿وَهُدࣰى﴾</span>: بيانٌ يَهْدي المؤمنين.</p></div>"
  7,204,""
  7,205,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَضَرُّعࣰا﴾</span>: تَذَلُّلًا وخُضوعًا.</p><p><span class="qpc-hafs">﴿وَخِيفَةࣰ﴾</span>: خائفًا منه تعالى.</p><p><span class="qpc-hafs">﴿وَدُونَ ٱلۡجَهۡرِ﴾</span>: متوسِّطًا بين الَجهْرِ والإسرارِ.</p><p><span class="qpc-hafs">﴿بِٱلۡغُدُوِّ﴾</span>: أولِ النهارِ.</p><p><span class="qpc-hafs">﴿وَٱلۡـَٔاصَالِ﴾</span>: جمعُ أصيلٍ، وهو من العَصْرِ إلى المغربِ، والمرادُ: آخرُ النهارِ.</p></div>"
  7,206,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُسَبِّحُونَهُۥ﴾</span>: يُنَزِّهُونه عن كلِّ ما لا يليقُ به.</p></div>"
