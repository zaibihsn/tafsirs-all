quran[35]{c,v,t}:
  46,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: سبق شَرْحُ الحروفِ المقطَّعةِ أوَّلَ سُورةِ البَقَرَةِ.</p></div>"
  46,2,""
  46,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَجَلࣲ مُّسَمࣰّى﴾</span>: وتَعْيِينِ ساعَةٍ مُحَدَّدَةٍ لِبَقائِهِما.</p></div>"
  46,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِرۡكࣱ﴾</span>: شِرْكَةٌ ونَصِيبٌ.</p><p><span class="qpc-hafs">﴿مِّن قَبۡلِ هَـٰذَآ﴾</span>: مِن قَبْل هذا القرآنِ.</p><p><span class="qpc-hafs">﴿أَثَـٰرَةࣲ﴾</span>: بَقِيَّةٍ تُؤْثَرُ عَنِ الأوَّلِينَ.</p></div>"
  46,5,""
  46,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَانُواْ لَهُمۡ﴾</span>: كانَتِ الأصْنامُ للعابِدِينَ.</p></div>"
  46,7,""
  46,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تَمۡلِكُونَ لِي﴾</span>: فَلا تَقْدِرُونَ على أن تَرُدُّوا عَنِّي.</p><p><span class="qpc-hafs">﴿تُفِيضُونَ﴾</span>: وتُكْثِرُونَ القَوْلَ فِيهِ، وتَخُوضُونَ وتتوسَّعُونَ.</p></div>"
  46,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِدۡعࣰا﴾</span>: أوَّلَ مَبْعُوثٍ، فَقَدْ كانَ قَبْلِي رُسُلٌ.</p></div>"
  46,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُونِي.</p><p><span class="qpc-hafs">﴿شَاهِدࣱ﴾</span>: هُوَ عَبْدُاللهِ بْنُ سَلامٍ.</p><p><span class="qpc-hafs">﴿عَلَىٰ مِثۡلِهِۦ﴾</span>: أي القُرآنِ، مِنَ المعانِي الموجُودَةِ في التَّوراةِ.</p></div>"
  46,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا سَبَقُونَآ إِلَيۡهِ﴾</span>: ما سَبَقَنا فُقَراءُ المسِلمِينَ إلى الإيمانِ.</p><p><span class="qpc-hafs">﴿إِفۡكࣱ﴾</span>: كَذِبٌ.</p></div>"
  46,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِمَامࣰا﴾</span>: يُقْتَدى بِهِ في الدِّينِ.</p><p><span class="qpc-hafs">﴿مُّصَدِّقࣱ﴾</span>: لِكِتاب مُوسى وغيرِه من كُتُب اللهِ.</p></div>"
  46,13,""
  46,14,""
  46,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُرۡهࣰا﴾</span>: مَشَقَّةً.</p><p><span class="qpc-hafs">﴿وَفِصَـٰلُهُۥ﴾</span>: وفِطامُهُ.</p><p><span class="qpc-hafs">﴿أَشُدَّهُۥ﴾</span>: نِهايةَ قُوَّتِهِ البَدَنِيَّةِ والعقْلِيَّةِ.</p><p><span class="qpc-hafs">﴿أَوۡزِعۡنِيٓ﴾</span>: ألْهِمْنِي.</p></div>"
  46,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أَصۡحَـٰبِ ٱلۡجَنَّةِ﴾</span>: في جُمْلة أصْحابِ الجنَّة.</p></div>"
  46,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُفࣲّ﴾</span>: اسْمُ فِعْلٍ مَعْناه: أتَضَجَّرُ.</p><p><span class="qpc-hafs">﴿أُخۡرَجَ﴾</span>: أُبْعَثَ بَعْدَ الموتِ.</p><p><span class="qpc-hafs">﴿خَلَتِ﴾</span>: مَضَتِ.</p><p><span class="qpc-hafs">﴿ٱلۡقُرُونُ﴾</span>: جَمْعُ قَرْنٍ وهو الأُمَّةُ الَّتي تَقارَبَ زَمانُ حياتِها أي: فماتُوا ولم يُبْعَثْ مِنهُم أحَدٌ؟</p><p><span class="qpc-hafs">﴿يَسۡتَغِيثَانِ ٱللَّهَ﴾</span>: يَطْلُبانِ عَوْنَهُ.</p><p><span class="qpc-hafs">﴿وَيۡلَكَ﴾</span>: هَلاكًا لَكَ.</p><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ﴾</span>: القِصَصُ الباطِلةُ.</p></div>"
  46,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾</span>: وجَبَ عَلَيهِمُ القَوْلُ بالعَذابِ.</p></div>"
  46,19,""
  46,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَذۡهَبۡتُمۡ﴾</span>: يقُولُ اللهُ لَهُم ذَلِكَ.</p><p><span class="qpc-hafs">﴿ٱلۡهُونِ﴾</span>: الهَوانِ والذُّلِّ.</p><p><span class="qpc-hafs">﴿تَفۡسُقُونَ﴾</span>: تَخْرُجُونَ عَن طاعَةِ اللهِ بالشِّرْكِ.</p></div>"
  46,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡأَحۡقَافِ﴾</span>: الرِّمالِ الكثِيرَةِ الَّتي لَمْ تَبْلُغْ أن تَكُونَ جَبَلًا، وتَقَعُ في جَنُوبِ الجزِيرَةِ العَرَبِيَّةِ، وهي مَنازلُ عادٍ قَومِ هُودٍ.</p><p><span class="qpc-hafs">﴿ٱلنُّذُرُ﴾</span>: جَمْعُ النَّذِيرِ وهو الرَّسُولُ.</p></div>"
  46,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَأۡفِكَنَا﴾</span>: لِتَصْرِفَنا.</p></div>"
  46,23,""
  46,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَأَوۡهُ﴾</span>: أي العذابَ.</p><p><span class="qpc-hafs">﴿عَارِضࣰا﴾</span>: كالسَّحابِ الَّذي يَعْتَرِضُ جَوَّ السَّماءِ.</p><p><span class="qpc-hafs">﴿أَوۡدِيَتِهِمۡ﴾</span>: منازِلِهم في السُّهُولِ.</p></div>"
  46,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلَّ شَيۡءِۭ﴾</span>: ما مِن شَأنِه أن تُدَمِّرَهُ مِنَ الإنْسانِ والحيوانِ والدِّيارِ.</p><p><span class="qpc-hafs">﴿مَسَـٰكِنُهُمۡ﴾</span>: أي آثارُ المساكِنِ وبقاياها.</p></div>"
  46,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيمَآ إِن مَّكَّنَّـٰكُمۡ فِيهِ﴾</span>: في الَّذِي لَم نَجْعَل لَّكُم القُدْرَةَ عَلَيهِ.</p><p><span class="qpc-hafs">﴿وَأَفۡـِٔدَةࣰ﴾</span>: عُقُولًا.</p><p><span class="qpc-hafs">﴿أَغۡنَىٰ﴾</span>: نَفَعَ.</p><p><span class="qpc-hafs">﴿يَجۡحَدُونَ﴾</span>: يُنْكِرُونَ.</p><p><span class="qpc-hafs">﴿وَحَاقَ بِهِم﴾</span>: ونَزَلَ وأَحاطَ بِهِم.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾</span>: العَذابُ الَّذِي كانُوا يَسْخَرُونَ مِنهُ.</p></div>"
  46,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَرَّفۡنَا ٱلۡـَٔايَـٰتِ﴾</span>: بيَّنّا لَهُم أنْواعَ الأَدِلَّةِ.</p></div>"
  46,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَا﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿قُرۡبَانًا﴾</span>: لِأَجْلِ التَّقَرُّبِ بِهِم إلى اللهِ، وهو مُعْتَرِضٌ بَيْنَ (ٱتَّخَذُواْ) ومَفْعُولِهِ: (ءالِهَةَۢ).</p><p><span class="qpc-hafs">﴿ضَلُّواْ عَنۡهُمۡ﴾</span>: غابُوا عَنْهُم.</p><p><span class="qpc-hafs">﴿إِفۡكُهُمۡ﴾</span>: كَذِبُهُم في زَعمِهِم أنَّ الأصْنامَ شُرَكاءُ لله.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَخْتَلِقُونَه مِن كَونِ الأصْنامِ تُقَرِّبُهُم إلى اللهِ.</p></div>"
  46,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرَفۡنَآ إِلَيۡكَ﴾</span>: أمَلْناهُم إلَيكَ وأَقْبَلْنا بِهِم نَحْوَك.</p><p><span class="qpc-hafs">﴿نَفَرࣰا﴾</span>: جَماعَةً.</p><p><span class="qpc-hafs">﴿أَنصِتُواْ﴾</span>: وجِّهُوا أسْماعَكُم إلى الكَلامِ.</p><p><span class="qpc-hafs">﴿قُضِيَ﴾</span>: فُرِغَ مِن قِراءتِه.</p><p><span class="qpc-hafs">﴿وَلَّوۡاْ﴾</span>: انْصَرفُوا.</p><p><span class="qpc-hafs">﴿مُّنذِرِينَ﴾</span>: المُنْذِرُ: المُخْبِرُ بِخَبرِ مُخِيفٍ.</p></div>"
  46,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾</span>: مُصَدِّقًا لما سَبَقَه مِن كُتُبِ اللهِ الَّتِي أنْزَلَها على رُسُلِه.</p></div>"
  46,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَاعِيَ ٱللَّهِ﴾</span>: رَسُولَ اللهِ محمَّدًا ﷺ.</p><p><span class="qpc-hafs">﴿وَيُجِرۡكُم﴾</span>: ويَمْنَعْكُم.</p></div>"
  46,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَيۡسَ بِمُعۡجِزࣲ فِي ٱلۡأَرۡضِ﴾</span>: فَلا يَفُوتُ عِقابَ الله.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءُ﴾</span>: نُصَراءُ.</p></div>"
  46,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمۡ يَعۡيَ بِخَلۡقِهِنَّ﴾</span>: ولَمْ يَعْجَزْ عَنْ خَلْقِهِنَّ.</p></div>"
  46,34,""
  46,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡعَزۡمِ مِنَ ٱلرُّسُلِ﴾</span>: هُمْ: نُوحٌ وإبراهيمُ وموسى وعِيسى ومُحَمَّدٌ عَلَيهِمُ الصَّلاةُ والسَّلامُ.</p><p><span class="qpc-hafs">﴿وَلَا تَسۡتَعۡجِل﴾</span>: الَهلاكَ.</p><p><span class="qpc-hafs">﴿لَمۡ يَلۡبَثُوٓاْ﴾</span>: لم يَمْكُثُوا.</p><p><span class="qpc-hafs">﴿بَلَـٰغࣱ﴾</span>: هَذا بَلاغٌ للنّاسِ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارِجُونَ عَنِ الإيمانِ بالإشْراكِ.</p></div>"
