quran[13]{c,v,t}:
  60,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: خُلَصاءَ وأحبّاءَ.</p><p><span class="qpc-hafs">﴿تُلۡقُونَ إِلَيۡهِم بِٱلۡمَوَدَّةِ﴾</span>: أي: فتُخْبِرُونَهُم بِأَخْبارِ الرَّسُولِ ﷺ وسَرائِر المسْلِمِينَ.</p><p><span class="qpc-hafs">﴿وَٱبۡتِغَآءَ﴾</span>: طَلَبَ.</p><p><span class="qpc-hafs">﴿تُسِرُّونَ﴾</span>: تَنْقُلُونَ إلَيهِمُ الأخْبارَ سِرًّا.</p><p><span class="qpc-hafs">﴿سَوَآءَ ٱلسَّبِيلِ﴾</span>: طَرِيقَ الحقِّ والصَّوابِ.</p></div>"
  60,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَثۡقَفُوكُمۡ﴾</span>: إن يَظْفَرْ بِكُم هَؤلاءِ الَّذِينَ تُسِرُّونَ إليهِم بالمودّةِ.</p><p><span class="qpc-hafs">﴿وَيَبۡسُطُوٓاْ إِلَيۡكُمۡ﴾</span>: ويَمُدُّوا إلَيكُم.</p><p><span class="qpc-hafs">﴿بِٱلسُّوٓءِ﴾</span>: بالقَتْلِ، والسَّبْيِ، والشَّتْمِ.</p></div>"
  60,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡحَامُكُمۡ﴾</span>: قراباتُكُم.</p><p><span class="qpc-hafs">﴿يَفۡصِلُ بَيۡنَكُمۡ﴾</span>: يَفْرُقُ اللهُ بَيْنَكُم، فيُدْخِلُ أهلَ طاعَتهِ الجَّنَةَ، وأهلَ مَعْصِيتِه النّارَ.</p></div>"
  60,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُسۡوَةٌ﴾</span>: قُدْوَةٌ</p><p><span class="qpc-hafs">﴿كَفَرۡنَا بِكُمۡ﴾</span>: أنْكَرْنا ما أنتُم عَلَيهِ مِنَ الكُفْرِ.</p><p><span class="qpc-hafs">﴿وَبَدَا﴾</span>: وظَهَر.</p><p><span class="qpc-hafs">﴿تَوَكَّلۡنَا﴾</span>: اعْتَمَدْنا.</p><p><span class="qpc-hafs">﴿أَنَبۡنَا﴾</span>: رَجَعْنا بالتَّوبَةِ</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المرْجِعُ يومَ القِيامَةِ.</p></div>"
  60,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: مَفْتُونِينَ بِتَسْلِيطِ الكُفّارِ عَلَينا.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: الَّذِي لا يُغالَبُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمُ﴾</span>: في أفْعالِهِ وأَقْوالِهِ.</p></div>"
  60,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُسۡوَةٌ﴾</span>: قُدْوَةٌ.</p><p><span class="qpc-hafs">﴿يَرۡجُواْ ٱللَّهَ﴾</span>: يَطْمَعُ في الخيرِ مِنَ اللهِ.</p><p><span class="qpc-hafs">﴿وَمَن يَتَوَلَّ﴾</span>: ومَن يُعْرضْ عَمّا أمَرهُ اللهُ بِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَنِيُّ﴾</span>: عَنْ عِبادِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيدُ﴾</span>: في ذاتِه وصِفاتِه، المحْمُودُ عَلى كُلِّ حالٍ.</p></div>"
  60,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَسَى ٱللَّهُ﴾</span>: وعَدَ اللهُ.</p></div>"
  60,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَرُّوهُمۡ﴾</span>: تُحْسِنُوا مُعامَلَتَهُم.</p><p><span class="qpc-hafs">﴿وَتُقۡسِطُوٓاْ إِلَيۡهِمۡ﴾</span>: وتَعْدِلُوا فِيهِم.</p></div>"
  60,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلدِّينِ﴾</span>: بِسَببِ الدِّينِ.</p><p><span class="qpc-hafs">﴿وَظَـٰهَرُواْ﴾</span>: وعاوَنُوا الكُفّارَ.</p><p><span class="qpc-hafs">﴿أَن تَوَلَّوۡهُمۡ﴾</span>: بالنُّصْرَةِ والمحبَّةِ.</p><p><span class="qpc-hafs">﴿وَمَن يَتَوَلَّهُمۡ﴾</span>: ومَنَ يَتَّخِذْهُم أنْصارًا عَلى المؤمِنِينَ.</p></div>"
  60,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُهَـٰجِرَ ٰ⁠تࣲ﴾</span>: مِن دارِ الكُفْرِ إلى دارِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿فَٱمۡتَحِنُوهُنَّ﴾</span>: فاخْتَبرُوا إيمانَهُنَّ.</p><p><span class="qpc-hafs">﴿وَءَاتُوهُم﴾</span>: وأعْطُوا أزواجَ اللاتِي أسْلَمْنَ.</p><p><span class="qpc-hafs">﴿مَّآ أَنفَقُواْ﴾</span>: مِثْلَ ما أعْطَوهُنَّ مِنَ المهُورِ.</p><p><span class="qpc-hafs">﴿أُجُورَهُنَّ﴾</span>: مُهُورَهُنَّ.</p><p><span class="qpc-hafs">﴿بِعِصَمِ﴾</span>: بِنِكاحِ، وأصْلُه جَمْعُ عِصْمَةٍ وهي: ما اعتُصِمَ بِهِ من العَقْدِ والسَّبَبِ.</p><p><span class="qpc-hafs">﴿ٱلۡكَوَافِرِ﴾</span>: الزَّوجاتِ الكافِراتِ.</p></div>"
  60,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاتَكُمۡ﴾</span>: فَرَرْنَ ولَحِقْنَ.</p><p><span class="qpc-hafs">﴿فَعَاقَبۡتُمۡ﴾</span>: كانَتِ العُقْبى لَكُم، وهي الغِنيمَةُ.</p></div>"
  60,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبَايِعۡنَكَ﴾</span>: يُعاهِدْنَكَ.</p><p><span class="qpc-hafs">﴿أَن لَّا يُشۡرِكۡنَ بِٱللَّهِ شَيۡـࣰٔا﴾</span>: ألّا يَجْعَلْنَ مَعَ اللهِ شَرِيكًا في عِبادَتِهِ.</p><p><span class="qpc-hafs">﴿وَلَا يَأۡتِينَ بِبُهۡتَـٰنࣲ يَفۡتَرِينَهُۥ﴾</span>: ولا يأتِينَ بِكَذِبٍ في مَولُودٍ مِن غَيرِ أزْواجِهِنَّ فيُلْحِقْنَهُ بِهِم.</p><p><span class="qpc-hafs">﴿فَبَايِعۡهُنَّ﴾</span>: فعاهِدْهُنَّ.</p></div>"
  60,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَتَوَلَّوۡاْ قَوۡمًا﴾</span>: لا تَتَّخِذُوهُم أخِلّاءَ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡـَٔاخِرَةِ﴾</span>: مِن ثَوابِ اللهِ في الآخِرَةِ، أوْ كَما يَئِسَ الكُفّارُ مِن بَعْثِ مَوْتاهُم.</p></div>"
