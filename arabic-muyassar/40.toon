quran[85]{c,v,t}:
  40,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: انْظُرْ أوَّلَ سورة البقرةِ.</p></div>"
  40,2,""
  40,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلتَّوۡبِ﴾</span>: التَّوبَةِ.</p><p><span class="qpc-hafs">﴿ذِي ٱلطَّوۡلِ﴾</span>: صاحِبِ الإنْعامِ والتفضُّلِ على عبادِهِ الطّائِعِينَ.</p><p><span class="qpc-hafs">﴿إِلَيۡهِ ٱلۡمَصِيرُ﴾</span>: إلى اللهِ مَرْجِعُكُم أيُّها الخَلْقُ.</p></div>"
  40,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا يَغۡرُرۡكَ﴾</span>: فلا يَخْدَعْكَ.</p><p><span class="qpc-hafs">﴿تَقَلُّبُهُمۡ فِي ٱلۡبِلَـٰدِ﴾</span>: تَرَدُّدُهُم وتَصَرُّفُهُم في البِلادِ بأنْواعِ التِّجاراتِ والمكاسِبِ.</p></div>"
  40,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَحۡزَابُ﴾</span>: الأُمَمُ الَّتي اجْتَمَعتْ عَلى تَكْذِيبِ رُسُلِها كَعادٍ وثَمُودَ.</p><p><span class="qpc-hafs">﴿لِيَأۡخُذُوهُ﴾</span>: لِيقْتُلُوهُ.</p><p><span class="qpc-hafs">﴿لِيُدۡحِضُواْ بِهِ﴾</span>: لِيُبْطِلُوا بِجِدالِهِم.</p><p><span class="qpc-hafs">﴿فَأَخَذۡتُهُمۡ﴾</span>: فَعاقَبْتُهُمْ.</p></div>"
  40,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّتۡ﴾</span>: وجَبَتْ وثَبَتَتْ.</p><p><span class="qpc-hafs">﴿كَلِمَتُ رَبِّكَ﴾</span>: كَلِمَةُ العذابِ وهي قولُه تَعالى: (لَأَمۡلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّن تَبِعَكَ مِنۡهُمۡ أجۡمَعِينَ).</p></div>"
  40,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَرۡشَ﴾</span>: هو سَرِيرُ المُلْكِ الَّذيِ اسْتَوى عَلَيهِ الَّرحْمنُ، وتَحْمِلُهُ الملائِكَةُ، وهُوَ أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p><p><span class="qpc-hafs">﴿وَمَنۡ حَوۡلَهُۥ﴾</span>: أي: الملائِكةُ الذين يَحُفُّونَ بالعرْشِ.</p><p><span class="qpc-hafs">﴿يُسَبِّحُونَ﴾</span>: يُنَزِّهُونَ.</p><p><span class="qpc-hafs">﴿وَقِهِمۡ﴾</span>: وجَنِّبْهُم.</p><p><span class="qpc-hafs">﴿عَذَابَ ٱلۡجَحِيمِ﴾</span>: عذابَ النّارِ.</p></div>"
  40,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتِ عَدۡنٍ﴾</span>: بساتين إقامَةٍ دائِمَةٍ.</p></div>"
  40,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِهِمُ ٱلسَّيِّـَٔاتِ﴾</span>: واصْرِفْ عَنْهُم سُوءَ عاقِبَةِ سيِّئاتِهِم.</p></div>"
  40,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَقۡتُ ٱللَّهِ﴾</span>: بُغْضُ اللهِ لَكُم.</p><p><span class="qpc-hafs">﴿مَّقۡتِكُمۡ أَنفُسَكُمۡ﴾</span>: بُغْضِكُم لِأَنْفُسِكُم الآنَ بَعْدَ أنْ أدْرَكْتُم أنّكُم تَسْتَحِقُّونَ سَخَطَ اللهِ وعَذابَهُ.</p></div>"
  40,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَتَّنَا ٱثۡنَتَيۡنِ﴾</span>: أمَتَّنا مَرَّتَينِ: حِينَ كُنّا نُطَفًا في بُطُونِ أمَّهاتِنا قَبْلَ نَفْخِ الرُّوحِ وحِينَ انْقَضى أجَلُنا في الحياةِ الدُّنيا.</p><p><span class="qpc-hafs">﴿وَأَحۡيَيۡتَنَا ٱثۡنَتَيۡنِ﴾</span>: وأَحْيَيْتَنا مَرَّتَينِ: في دارِ الدُّنيا، يَوْمَ وُلِدْنا، ويَوْمَ بُعِثْنا مِن قُبُورِنا.</p><p><span class="qpc-hafs">﴿خُرُوجࣲ﴾</span>: أي: مِنَ النّارِ.</p></div>"
  40,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَلِيِّ﴾</span>: العاِلي عَلى خَلْقِهِ ذاتًا وقُدْرَةً وقَهْرًا.</p></div>"
  40,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِهِۦ﴾</span>: دَلائِلَ عَظَمَتِه الَّتي تَظْهَرُ في هَذا العالَمِ.</p><p><span class="qpc-hafs">﴿رِزۡقࣰا﴾</span>: مَطَرًا هُوَ سَبَبُ رِزْقِكُم.</p><p><span class="qpc-hafs">﴿يُنِيبُ﴾</span>: يَرْجِعُ إلى طاعَةِ اللهِ.</p></div>"
  40,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدِّينَ﴾</span>: العِبادَةَ والدُّعاءَ.</p></div>"
  40,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَفِيعُ ٱلدَّرَجَـٰتِ﴾</span>: ارْتَفَعَتْ دَرَجاتُه ارْتِفاعًا بايَنَ بِهِ مَخْلُوقاتِهِ.</p><p><span class="qpc-hafs">﴿ٱلرُّوحَ﴾</span>: الوَحْيَ الَّذِي يَحْيَوْنَ بِهِ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ٱلتَّلَاقِ﴾</span>: يومَ القِيامةِ الَّذِي يَلْتَقِي فِيهِ الأولُونَ والآخِرُونَ.</p></div>"
  40,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَـٰرِزُونَ﴾</span>: يَظْهَرُونَ أمامَ رَبِّهِم.</p><p><span class="qpc-hafs">﴿ٱلۡقَهَّارِ﴾</span>: الَّذِي قَهَرَ جَميعَ الخَلائِقِ، فَكُلُّها تَحْتَ تَصَرُّفِهِ وتَدْبِيرِهِ فَلا تَتَحَرَّكُ ولا تَسْكُنُ إلّا بِإْذِنِهِ.</p></div>"
  40,17,""
  40,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡـَٔازِفَةِ﴾</span>: يَوْمَ القِيامَةِ القريبَ وإنِ اسْتَبْعَدُوهُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَنَاجِرِ﴾</span>: جَمْعِ حَنْجَرةٍ، وهي الحُلْقُومُ.</p><p><span class="qpc-hafs">﴿كَـٰظِمِينَ﴾</span>: مُمْتلِئِين غمًّا وحُزْنًا.</p><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: قَرِيبٍ وصاحِبٍ.</p><p><span class="qpc-hafs">﴿شَفِيعࣲ﴾</span>: يَشْفَعُ لَهُم عنْدَ رَبِّهِمِ.</p><p><span class="qpc-hafs">﴿يُطَاعُ﴾</span>: يُسْتَجابُ لَهُ.</p></div>"
  40,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَآئِنَةَ ٱلۡأَعۡيُنِ﴾</span>: ما تَخْتَلِسُهُ العُيُونُ مِن نَّظَراتٍ.</p></div>"
  40,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقۡضِي بِٱلۡحَقِّ﴾</span>: يَحْكُمُ بالعَدْلِ.</p><p><span class="qpc-hafs">﴿لَا يَقۡضُونَ بِشَيۡءٍ﴾</span>: لا يَحْكُمُونَ بِشَيءٍ؛ لأنّ هذه الآلهةَ لا تَعْلَمُ شَيئًا ولا تَقْدِرُ عَلى شَيءٍ.</p></div>"
  40,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰقِبَةُ ٱلَّذِينَ كَانُواْ مِن قَبۡلِهِمۡ﴾</span>: خاتِمةُ ومَصِيرُ الأُمَمِ السّابِقةِ قَبْلَهُم.</p><p><span class="qpc-hafs">﴿وَءَاثَارࣰا فِي ٱلۡأَرۡضِ﴾</span>: وأبْقى آثارًَا مِنهُم في الأَرْضِ يُسْتَدَلُّ بِها عَلى قُوَّتِهِم.</p><p><span class="qpc-hafs">﴿فَأَخَذَهُمُ﴾</span>: فَأَهْلَكَهُم.</p><p><span class="qpc-hafs">﴿وَاقࣲ﴾</span>: دافعٍ يَدْفَعُ عَنْهُم عَذابَ اللهِ.</p></div>"
  40,22,""
  40,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسُلۡطَـٰنࣲ﴾</span>: حُجَّةٍ.</p></div>"
  40,24,""
  40,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱسۡتَحۡيُواْ نِسَآءَهُمۡ﴾</span>: اسْتَبْقُوا نِساءَهم لِلْخِدْمَةِ والاسْتِرْقاقِ.</p><p><span class="qpc-hafs">﴿وَمَا كَيۡدُ ٱلۡكَـٰفِرِينَ إِلَّا فِي ضَلَـٰلࣲ﴾</span>: وما تَدْبِيرُ الكافِرِينَ إلا في ذَهابٍ وهَلاكٍ.</p></div>"
  40,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرُونِيٓ﴾</span>: اتْرُكُونِي.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرْضِ مِصْرَ.</p></div>"
  40,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُذۡتُ﴾</span>: لَجَأْتُ واسْتَجَرْتُ.</p></div>"
  40,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُصِبۡكُم﴾</span>: يَلْحَقْكُم.</p><p><span class="qpc-hafs">﴿يَعِدُكُمۡ﴾</span>: يَتَوَعَّدُكُم بهِ مِنَ العُقُوبَةِ.</p><p><span class="qpc-hafs">﴿مُسۡرِفࣱ﴾</span>: مُتَجاوِزٌ لِلْحَدِّ بالشِّرْكِ والقَتْلِ بِغَيْرِ حَقٍّ.</p></div>"
  40,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَـٰهِرِينَ﴾</span>: غالِبينَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرْضِ مِصْرَ.</p><p><span class="qpc-hafs">﴿فَمَن يَنصُرُنَا﴾</span>: فَمَن يَدْفَعُ عَنّا.</p><p><span class="qpc-hafs">﴿بَأۡسِ ٱللَّهِ﴾</span>: عَذابِ اللهِ.</p><p><span class="qpc-hafs">﴿مَآ أُرِيكُمۡ إِلَّا مَآ أَرَىٰ﴾</span>: ما أُرِيكُم مِّنَ الرّأيِ والنَّصِيحَةِ إلّا ما أرى لِنَفْسِي ولَكُم صَلاحًا وصَوابًا.</p><p><span class="qpc-hafs">﴿سَبِيلَ ٱلرَّشَادِ﴾</span>: طَرِيقَ الحقِّ والصَّوابِ.</p></div>"
  40,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمِ ٱلۡأَحۡزَابِ﴾</span>: يَوْمِ عَذابِ الَّذينَ تَجَمَّعُوا على أنبيائِهِم فَأَهْلكَهُم اللهُ.</p></div>"
  40,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَأۡبِ﴾</span>: عادَةِ.</p></div>"
  40,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلتَّنَادِ﴾</span>: يَومَ يُنادِي فِيه بعضُ النّاسِ بَعْضًا مِن هَوْلِ الموقِفِ.</p></div>"
  40,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُوَلُّونَ﴾</span>: تَذْهَبُونَ وتَنْصَرِفُونَ.</p><p><span class="qpc-hafs">﴿مُدۡبِرِينَ﴾</span>: ذاهِبِينَ هارِبِينَ.</p><p><span class="qpc-hafs">﴿عَاصِمࣲ﴾</span>: مانِعٍ يَمْنَعُكُم.</p></div>"
  40,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: الدَّلائِلِ الُمظْهِرَةِ أنّهُ رَسُول مِنَ اللهِ.</p><p><span class="qpc-hafs">﴿هَلَكَ﴾</span>: ماتَ.</p><p><span class="qpc-hafs">﴿مُسۡرِفࣱ﴾</span>: مُتَجاوِزٌ لِلْحَقِّ.</p><p><span class="qpc-hafs">﴿مُّرۡتَابٌ﴾</span>: شاكٌّ في وحْدانِيَّةِ اللهِ.</p></div>"
  40,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: حُجَّةٍ مَقْبُولةٍ.</p><p><span class="qpc-hafs">﴿يَطۡبَعُ ٱللَّهُ﴾</span>: يَخْتِمُ اللهُ.</p><p><span class="qpc-hafs">﴿جَبَّارࣲ﴾</span>: الَّذِي يُكْرِهُ الناسَ عَلى ما لا يُحِبُّونَ عَمَلَه لِظُلْمِهِ.</p></div>"
  40,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡحࣰا﴾</span>: بِناءً عَظِيمًا.</p><p><span class="qpc-hafs">﴿ٱلۡأَسۡبَـٰبَ﴾</span>: أبْوابَ السَّمَواتِ وما يُوصِلُنِي إلَيها.</p></div>"
  40,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدُ﴾</span>: احْتِيالُ.</p><p><span class="qpc-hafs">﴿تَبَابࣲ﴾</span>: خَسارٍ وبَوارٍ.</p></div>"
  40,38,""
  40,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعࣱ﴾</span>: تَمَتُّعٌ في مُدَّةٍ قَلِيلَةٍ.</p><p><span class="qpc-hafs">﴿ٱلۡقَرَارِ﴾</span>: الدَّوامِ في المكانِ.</p></div>"
  40,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِغَيۡرِ حِسَابࣲ﴾</span>: بَغَيرِ تَقْتِيرٍ.</p></div>"
  40,41,""
  40,42,""
  40,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حَقًّا.</p><p><span class="qpc-hafs">﴿لَيۡسَ لَهُۥ دَعۡوَةࣱ﴾</span>: لا يَمْلِكُ إجابَةَ دَعْوَةِ الدّاعِينَ.</p><p><span class="qpc-hafs">﴿مَرَدَّنَآ﴾</span>: مَصِيرَنا.</p><p><span class="qpc-hafs">﴿ٱلۡمُسۡرِفِينَ﴾</span>: المتَعَدِّينَ حُدُودَهُ بالشِّرْكِ باللهِ.</p></div>"
  40,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُفَوِّضُ أَمۡرِيٓ إِلَى ٱللَّهِ﴾</span>: وأَتَوَكَّلُ عَلى اللهِ وأَلْجَأُ إلَيهِ وأَعْتَصِمُ بِهِ.</p></div>"
  40,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيِّـَٔاتِ مَا مَكَرُواْ﴾</span>: عُقُوباتِ مَكْرِ فِرْعَونَ وآلِهِ.</p><p><span class="qpc-hafs">﴿وَحَاقَ﴾</span>: وحَلَّ.</p></div>"
  40,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُعۡرَضُونَ عَلَيۡهَا﴾</span>: يُشاهِدُونَ مَقاعِدَهُم في النّارِ.</p><p><span class="qpc-hafs">﴿غُدُوࣰّا﴾</span>: أوَّلَ النَّهارِ.</p><p><span class="qpc-hafs">﴿وَعَشِيࣰّا﴾</span>: آخِرَ النَّهارِ.</p></div>"
  40,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَحَآجُّونَ﴾</span>: يتخاصَمُونَ.</p><p><span class="qpc-hafs">﴿نَصِيبࣰا﴾</span>: قِسْطًا.</p></div>"
  40,48,""
  40,49,""
  40,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالحُجَجِ الواضِحَةِ.</p><p><span class="qpc-hafs">﴿إِلَّا فِي ضَلَـٰلٍ﴾</span>: إلّا في ضَياعٍ.</p></div>"
  40,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَوۡمَ يَقُومُ ٱلۡأَشۡهَـٰدُ﴾</span>: يَوْمَ القِيامةِ، فَيُشْهَدُ للرُّسُلِ بالتَّبْلِيغِ، وعَلى الكُفّارِ بالتَّكْذِيبِ.</p></div>"
  40,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَهُمُ ٱللَّعۡنَةُ﴾</span>: ولَهُم الطَّرْدُ مِن رحْمَةِ اللهِ.</p><p><span class="qpc-hafs">﴿سُوٓءُ ٱلدَّارِ﴾</span>: الدّارُ السَّيِّئَةُ في الآخِرَةِ وهي النّارُ.</p></div>"
  40,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التَّوراةَ.</p></div>"
  40,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: لِأصْحابِ العُقُولِ السَّلِيمةِ.</p></div>"
  40,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡعَشِيِّ﴾</span>: آخِرِ النَّهارِ.</p><p><span class="qpc-hafs">﴿وَٱلۡإِبۡكَـٰرِ﴾</span>: أوَّلِ النَّهارِ.</p></div>"
  40,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: بُرْهانٍ وحُجَّةٍ.</p></div>"
  40,57,""
  40,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُسِيٓءُ﴾</span>: مَن كَفَرَ بِاللهِ وخالفَ أمْرَهُ.</p></div>"
  40,59,""
  40,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱدۡعُونِيٓ﴾</span>: خُصُّونِي بِدُعاءِ العِبادةِ ودُعاءِ المسْأَلةِ.</p><p><span class="qpc-hafs">﴿يَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِي﴾</span>: يَتَكَبَّرُونَ عَنْ إفْرادِي بالعِبادَةِ.</p><p><span class="qpc-hafs">﴿دَاخِرِينَ﴾</span>: صاغِرِينَ ذَلِيلِينَ.</p></div>"
  40,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَسۡكُنُواْ﴾</span>: لِتَهْدَؤُوا فِيهِ مِنَ الحرَكَةِ والتَّعَبِ.</p><p><span class="qpc-hafs">﴿مُبۡصِرًا﴾</span>: مُضِيئًا يُبْصِرُ فِيهِ النّاسُ.</p></div>"
  40,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾</span>: فَكَيفَ تُصْرَفُونَ عَنِ الحقِّ والصَّوابِ فَتَعْدِلُونَ عَنِ الإيمانِ باللهِ، وتَعْبُدُونَ غَيرَه؟</p></div>"
  40,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡفَكُ﴾</span>: يُصْرَفُ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: مُعْجِزاتِهِ.</p><p><span class="qpc-hafs">﴿يَجۡحَدُونَ﴾</span>: يُكَذِّبُونَ.</p></div>"
  40,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرَارࣰا﴾</span>: مَكانَ اسْتِقْرارٍ، ويَسَّرَ لَكُم الإقامَةَ عَلَيها.</p><p><span class="qpc-hafs">﴿بِنَآءࣰ﴾</span>: سَقْفًا للأَرْضِ.</p><p><span class="qpc-hafs">﴿وَصَوَّرَكُمۡ فَأَحۡسَنَ صُوَرَكُمۡ﴾</span>: وخَلَقَكُم في أكْمَلِ هَيْئَةٍ، وأحْسَنِ تَقْويمٍ.</p><p><span class="qpc-hafs">﴿فَتَبَارَكَ ٱللَّهُ﴾</span>: فَتَكاثَر خَيْرُهُ وفَضْلُهُ وبَرَكتُهُ.</p></div>"
  40,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَيُّ﴾</span>: الموصُوفُ بالحياةِ الحقِيقِيَّةِ الكامِلةِ.</p><p><span class="qpc-hafs">﴿ٱلدِّينَ﴾</span>: الطّاعَةَ.</p></div>"
  40,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتُ﴾</span>: دَلائلُ التَّوحِيدِ.</p><p><span class="qpc-hafs">﴿أُسۡلِمَ﴾</span>: أخْضَعَ وأنقادَ بالطّاعةِ التامَّةِ.</p></div>"
  40,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّطۡفَةࣲ﴾</span>: مَنِيٍّ.</p><p><span class="qpc-hafs">﴿عَلَقَةࣲ﴾</span>: دَمٍ غَلِيظٍ أحْمَرَ.</p><p><span class="qpc-hafs">﴿لِتَبۡلُغُوٓاْ أَشُدَّكُمۡ﴾</span>: ليَتِمّ خَلْقُكُم، وتَتَكامَلَ قُواكُم ويَتَناهى شَبابُكُم.</p><p><span class="qpc-hafs">﴿شُيُوخࣰا﴾</span>: جَمْعُ شَيخ، وهو مَن بَلَغَ سِنّ الخمْسِينَ إلى آخِرِ عُمُرِهِ.</p></div>"
  40,68,""
  40,69,""
  40,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡكِتَـٰبِ﴾</span>: بالقرآنِ.</p></div>"
  40,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَغۡلَـٰلُ﴾</span>: جَمْعُ غُلٍّ، وهو القَيْدُ يُقَيَّدُ بِه، فَتُجْعَلُ العُنُقُ في وسطِه.</p><p><span class="qpc-hafs">﴿وَٱلسَّلَـٰسِلُ﴾</span>: جَمْعُ سِلْسِلةٍ، وهي مَجْمُوعُ حِلَقٍ غَلِيظَةٍ مِن حَدِيدٍ مُتَّصِلٍ بَعْضُها بِبَعْضٍ.</p><p><span class="qpc-hafs">﴿يُسۡحَبُونَ﴾</span>: يُجَرُّونَ.</p></div>"
  40,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَمِيمِ﴾</span>: الماءِ الحارِّ الَّذِي اشْتَدَّ غَلَيانُه وحَرّهُ.</p><p><span class="qpc-hafs">﴿يُسۡجَرُونَ﴾</span>: يُوقَدُ بِهِم.</p></div>"
  40,73,""
  40,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلُّواْ عَنَّا﴾</span>: غابُوا عَنْ عُيُونِنا.</p></div>"
  40,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَفۡرَحُونَ﴾</span>: تَفْرَحُونَ بِما تَقْتَرِفُونَهُ مِنَ المعاصِي والآثامِ.</p><p><span class="qpc-hafs">﴿تَمۡرَحُونَ﴾</span>: تَبْطَرُونَ وتَبغُونَ على عِبادِ اللهِ.</p></div>"
  40,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوَى ٱلۡمُتَكَبِّرِينَ﴾</span>: مَنزِلُهُم.</p></div>"
  40,77,""
  40,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةٍ﴾</span>: بِمُعْجِزَةٍ.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: بِنُزُولِ العَذابِ على الكُفّارِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُبۡطِلُونَ﴾</span>: الَّذين يَتَّبِعُونَ الباطِلَ.</p></div>"
  40,79,""
  40,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِتَبۡلُغُواْ عَلَيۡهَا حَاجَةࣰ فِي صُدُورِكُمۡ﴾</span>: ولِتَبْلُغُوا بالحَمُولَةِ على بَعْضِها، وهي الإبِلُ، حاجَةً في صُدُورِكُم مِنَ الوصُولِ إلى الأقْطارِ البعِيدةِ. والحاجةُ: النِّيَّةُ والعَزِيمَةُ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السُّفُنِ.</p></div>"
  40,81,""
  40,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاثَارࣰا فِي ٱلۡأَرۡضِ﴾</span>: وأَبْقى آثارًا في الأرضِ مِنَ الأَبْنِيَةِ والمصانِع والغِراسِ.</p><p><span class="qpc-hafs">﴿فَمَآ أَغۡنَىٰ﴾</span>: فَما أجْزَأَ وكَفى.</p></div>"
  40,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالُمعْجِزاتِ الظّاهِراتِ.</p><p><span class="qpc-hafs">﴿فَرِحُواْ بِمَا عِندَهُم مِّنَ ٱلۡعِلۡمِ﴾</span>: الُمناقِضِ لما جاءتْ به الرُّسُلُ، وقالُوا: نَحْنُ أعْلمُ مِنَ الرُّسُلِ ولَن نُّعَذِّبَ.</p><p><span class="qpc-hafs">﴿وَحَاقَ بِهِم﴾</span>: ونَزَلَ وأَحاطَ بِهم.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾</span>: ما كانُوا يَسْتَعْجِلُونَ بِهِ رسُلَهُم عَلى سَبِيلِ السُّخْرِيَةِ والاسْتِهْزاءِ، وهُوَ عَذابُ الاسْتِئْصالِ.</p></div>"
  40,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَأۡسَنَا﴾</span>: عَذابَنا.</p></div>"
  40,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُنَّتَ ٱللَّهِ ٱلَّتِي قَدۡ خَلَتۡ فِي عِبَادِهِۦ﴾</span>: طَرِيقَتَهُ الَّتِي سَنَّها في الأُمَم كلِّها ألّا ينفَعَها الإيمانُ إذا رَأَوا العَذابَ.</p><p><span class="qpc-hafs">﴿وَخَسِرَ هُنَالِكَ ٱلۡكَـٰفِرُونَ﴾</span>: وهَلَكَ عِنْدَ مَجِيءِ بأْسِ اللهِ الكافِرُونَ بِرَبِّهِم.</p></div>"
