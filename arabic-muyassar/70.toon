quran[44]{c,v,t}:
  70,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَأَلَ سَآئِلُۢ﴾</span>: دَعا داعٍ مِنَ المُشْرِكِينَ على نَفْسِهِ وقَوْمِهِ.</p><p><span class="qpc-hafs">﴿بِعَذَابࣲ﴾</span>: بِنُزُولِ العَذابِ عَلَيهِم.</p><p><span class="qpc-hafs">﴿وَاقِعࣲ﴾</span>: مُتَحَقِّقِ الوُقُوعِ.</p></div>"
  70,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَافِعࣱ﴾</span>: مانِعٌ يَمْنَعُهُ مِنَ اللهِ عَزَّ وجَلَّ.</p></div>"
  70,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِي ٱلۡمَعَارِجِ﴾</span>: صاحِبِ العُلُوِّ والفَواضِلِ.</p></div>"
  70,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَعۡرُجُ﴾</span>: تَصْعَدُ.</p><p><span class="qpc-hafs">﴿وَٱلرُّوحُ﴾</span>: جِبْرِيلُ.</p><p><span class="qpc-hafs">﴿خَمۡسِينَ أَلۡفَ سَنَةࣲ﴾</span>: أي مِن سَنَواتِ الدُّنيا عَلى الكافِرِ.</p></div>"
  70,5,""
  70,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرَوۡنَهُۥ بَعِيدࣰا﴾</span>: يَرَونَ وقُوعَ العذابِ مُسْتَحِيلًا.</p></div>"
  70,7,""
  70,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡمُهۡلِ﴾</span>: ما أُذِيب مِنَ النُّحاسِ وغَيرِهِ.</p></div>"
  70,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡعِهۡنِ﴾</span>: كالصُّوفِ.</p></div>"
  70,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَسۡـَٔلُ حَمِيمٌ حَمِيمࣰا﴾</span>: ولا يَتَفَرَّغُ قَرِيبٌ للسُّؤالِ عَنْ حالِ قَرِيبِهِ مِنَ الهَولِ والشُّغْلِ بِحالِ نَفْسِهِ.</p></div>"
  70,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبَصَّرُونَهُمۡ﴾</span>: يَرَونَهُم ويَعْرِفُونَهُم، ولا يَسْتَطِيعُ أحَدٌ أن يَنفَعَ أحَدًا.</p><p><span class="qpc-hafs">﴿يَوَدُّ﴾</span>: يَتَمَنّى.</p><p><span class="qpc-hafs">﴿لَوۡ يَفۡتَدِي﴾</span>: لو يُخَلِّصُ نَفْسَهُ بِفِدْيَةٍ.</p></div>"
  70,12,""
  70,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَصِيلَتِهِ﴾</span>: وعَشِيَرتِهِ.</p><p><span class="qpc-hafs">﴿تُـٔۡوِيهِ﴾</span>: تَضُمُّهُ، ويَنْتَمِي إلَيها في القَرابَةِ.</p></div>"
  70,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنجِيهِ﴾</span>: يُنجِيهِ الافْتِداءُ مِنَ العَذابِ.</p></div>"
  70,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: لا افْتِداءَ ولا إنْجاءَ.</p></div>"
  70,16,""
  70,17,""
  70,18,""
  70,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلُوعًا﴾</span>: شَدِيدَ الجَزَعِ والحِرْصِ.</p></div>"
  70,20,""
  70,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَيۡرُ﴾</span>: ما يَنفَعُ الإنْسانَ.</p><p><span class="qpc-hafs">﴿مَنُوعًا﴾</span>: كَثِيرَ المنْعِ للخيرِ.</p></div>"
  70,22,""
  70,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَآئِمُونَ﴾</span>: مُواظِبُونَ على أدائِها.</p></div>"
  70,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقࣱّ مَّعۡلُومࣱ﴾</span>: نَصِيبٌ مُعَيَّنٌ لِذَوِي الحاجاتِ.</p></div>"
  70,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمَحۡرُومِ﴾</span>: الَّذِي يَتَعَفَّفُ عَن سُؤالِ النّاسِ مَعَ حاجَتِهِ فَلا يَتَفَطَّن لَهُ كَثِيرٌ مِنَ النّاسِ.</p></div>"
  70,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِيَوۡمِ ٱلدِّينِ﴾</span>: بيومِ الجَزاءِ.</p></div>"
  70,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّشۡفِقُونَ﴾</span>: خائِفُونَ.</p></div>"
  70,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡرُ مَأۡمُونࣲ﴾</span>: لا يَأمَنُه أحَدٌ مِمَّنْ عَقَلَ عَنِ اللهِ أمْرَهُ إلا بِأَمانٍ مِنَ اللهِ تَبارَكَ وتَعالى.</p></div>"
  70,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِفُرُوجِهِمۡ حَـٰفِظُونَ﴾</span>: يَحْفظُونَ أنْفُسَهُم مِنَ الحَرامِ.</p></div>"
  70,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ مَا مَلَكَتۡ أَيۡمَـٰنُهُمۡ﴾</span>: النِّساءِ الإماءِ.</p><p><span class="qpc-hafs">﴿غَيۡرُ مَلُومِينَ﴾</span>: غَيرُ مؤاخَذِينَ.</p></div>"
  70,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَآءَ ذَ ٰ⁠لِكَ﴾</span>: غَيرَ الزَّوجاتِ والمملُوكاتِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَادُونَ﴾</span>: المُفْسِدُونَ.</p></div>"
  70,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِأَمَـٰنَـٰتِهِمۡ﴾</span>: لأماناتِ اللهِ وأماناتِ النّاسِ الَّتِي اؤْتُمِنُوا عَلَيها.</p><p><span class="qpc-hafs">﴿وَعَهۡدِهِمۡ﴾</span>: عُهُودِهِم مَعَ اللهِ ومَعَ العِبادِ.</p><p><span class="qpc-hafs">﴿رَ ٰ⁠عُونَ﴾</span>: حافِظُونَ.</p></div>"
  70,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِشَهَـٰدَ ٰ⁠تِهِمۡ﴾</span>: بِما عِنْدَهُم مِنَ الدَّلالةِ عَلى حَقِّ لِغَيرِهِم.</p><p><span class="qpc-hafs">﴿قَآئِمُونَ﴾</span>: يَهْتَمُّونَ بِها ويَحْفَظُونَها إلى أن تُؤَدّى.</p></div>"
  70,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَافِظُونَ﴾</span>: يعتَنُونَ باسْتِكْمالِ أرْكانِها وشُرُوطِها وأَوْقاتِها.</p></div>"
  70,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّكۡرَمُونَ﴾</span>: يُكْرَمُونَ بِحُسْنِ اللقاءِ والثَّناءِ وأَنْواعِ اللذّاتِ والمَسارِّ.</p></div>"
  70,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَالِ ٱلَّذِينَ كَفَرُواْ﴾</span>: فأيُّ شَيءٍ ثَبَتَ لَهُم؟</p><p><span class="qpc-hafs">﴿قِبَلَكَ﴾</span>: في حالِ كَونِهِم عنِدَك.</p><p><span class="qpc-hafs">﴿مُهۡطِعِينَ﴾</span>: مُسْرِعِينَ، وقَدْ مَدُّوا أعْناقَهُم إليكَ مُقْبِلِينَ عَلَيكَ.</p></div>"
  70,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِزِينَ﴾</span>: مُتَفَرِّقِينَ.</p></div>"
  70,38,""
  70,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّمَّا يَعۡلَمُونَ﴾</span>: مِن مّاءٍ مَهِينٍ كَغَيرِهِم.</p></div>"
  70,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَشَـٰرِقِ﴾</span>: مَشارِقِ الشَّمْسِ والكَواكِبِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَغَـٰرِبِ﴾</span>: مَغارِبِ الشَّمْسِ والكَواكِبِ.</p></div>"
  70,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا نَحۡنُ بِمَسۡبُوقِينَ﴾</span>: وما أحَدٌ يَفُوتُنا ويُعْجِزُنا.</p></div>"
  70,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَرۡهُمۡ﴾</span>: فاتْرُكْهُم.</p><p><span class="qpc-hafs">﴿يَخُوضُواْ﴾</span>: يَتَكلَّمُوا في باطِلِهِم عَلى غَيرِ هُدىً.</p><p><span class="qpc-hafs">﴿وَيَلۡعَبُواْ﴾</span>: في دُنْياهُم.</p></div>"
  70,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَجۡدَاثِ﴾</span>: القُبُورِ.</p><p><span class="qpc-hafs">﴿سِرَاعࣰا﴾</span>: مُسْرِعِينَ.</p><p><span class="qpc-hafs">﴿نُصُبࣲ﴾</span>: أصْنامٍ.</p><p><span class="qpc-hafs">﴿يُوفِضُونَ﴾</span>: يُهَرْوِلُونَ، ويُسْرِعُونَ أيُّهُم يَسْتَلِمُه أوَّلُ؟</p></div>"
  70,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعَةً﴾</span>: ذَلِيلةً مُنْكَسِرَةً.</p><p><span class="qpc-hafs">﴿تَرۡهَقُهُمۡ﴾</span>: تَغْشاهُم.</p><p><span class="qpc-hafs">﴿ذِلَّةࣱ﴾</span>: حَقارَةٌ ومَهانَةٌ.</p></div>"
