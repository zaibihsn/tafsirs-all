quran[17]{c,v,t}:
  86,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلطَّارِقِ﴾</span>: أقْسَمَ اللهُ سُبحانَهُ بالنَّجْمِ الَّذِي يَطْرُقُ ليلًا.</p></div>"
  86,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعْلَمَكَ؟.</p><p><span class="qpc-hafs">﴿مَا ٱلطَّارِقُ﴾</span>: ما عِظَمُ هذا النَّجمِ؟</p></div>"
  86,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّجۡمُ ٱلثَّاقِبُ﴾</span>: النَّجمُ المُضِيءُ المُتَوهِّجُ.</p></div>"
  86,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن﴾</span>: ما.</p><p><span class="qpc-hafs">﴿لَّمَّا﴾</span>: إلّا.</p><p><span class="qpc-hafs">﴿عَلَيۡهَا حَافِظࣱ﴾</span>: أُوكِلَ بها مَلَكٌ رَقِيبٌ يَحْفَظُ عَلَيها أعْمالَها.</p></div>"
  86,5,""
  86,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّآءࣲ دَافِقࣲ﴾</span>: مَنيٍّ مُنْصَبٍّ بِسُرعَةٍ في الرَّحِم.</p></div>"
  86,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّلۡبِ﴾</span>: العَمُودِ العَظْميِّ في وسَطِ الظَّهْرِ، وهو ذُو الفِقْراتِ.</p><p><span class="qpc-hafs">﴿وَٱلتَّرَآئِبِ﴾</span>: جَمْع ترِيبةٍ، وهي عظامُ الصَّدرِ الَّتِي بَينَ التَّرقُوَتَينِ والثَّديينِ.</p></div>"
  86,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَجۡعِهِۦ﴾</span>: إعادَتِهِ إلى الحياةِ بَعْدَ الموتِ.</p></div>"
  86,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُبۡلَى﴾</span>: تُخْتَبرُ.</p><p><span class="qpc-hafs">﴿ٱلسَّرَآئِرُ﴾</span>: ما يُخْفيهِ الإنسانُ مِنَ العقائِدِ والأعْمالِ.</p></div>"
  86,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُوَّةࣲ﴾</span>: يدفعُ بِها عَن نَّفْسِهِ.</p></div>"
  86,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَاتِ ٱلرَّجۡعِ﴾</span>: ذاتِ المطَرِ الَّذِي يَرْجِعُ و يَتَكَرَّرُ.</p></div>"
  86,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّدۡعِ﴾</span>: التَّشَقُّقِ بِما يَتَخلَّلُها مِن نَّباتٍ.</p></div>"
  86,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَصۡلࣱ﴾</span>: فاصِلٌ بَيْنَ الحقِّ والباطِلِ.</p></div>"
  86,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡهَزۡلِ﴾</span>: باللَّعِبِ والباطِل.</p></div>"
  86,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكِيدُونَ كَيۡدࣰا﴾</span>: يُخْفونَ قَصْدَ الضُّرِّ ويُظْهِرُونَ خِلافَه.</p></div>"
  86,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَكِيدُ كَيۡدࣰا﴾</span>: لإظْهارِ الحقِّ.</p></div>"
  86,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَهِّلِ ٱلۡكَـٰفِرِينَ﴾</span>: فأنْظِرْهُم.</p><p><span class="qpc-hafs">﴿أَمۡهِلۡهُمۡ﴾</span>: أنْظِرْهُم.</p><p><span class="qpc-hafs">﴿رُوَيۡدَۢا﴾</span>: مُهلةً غيرَ طويلةٍ.</p></div>"
