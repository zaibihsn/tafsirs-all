quran[77]{c,v,t}:
  25,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَارَكَ﴾</span>: تَكاثَرَ خَيْرُه وعَظُمَتْ بَرَكاتُه.</p><p><span class="qpc-hafs">﴿ٱلۡفُرۡقَانَ﴾</span>: القُرآنَ، الفارقَ بَيْنَ الحقِّ والَباطِلِ.</p><p><span class="qpc-hafs">﴿نَذِيرًا﴾</span>: مُخَوِّفًا.</p></div>"
  25,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَدَّرَهُۥ﴾</span>: أي: فَهَيَّأَه لِما يَصْلُحُ لَهُ ويلِيقُ بِهِ.</p></div>"
  25,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُشُورࣰا﴾</span>: بَعْثًا بَعْدَ الموتِ.</p></div>"
  25,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَآ﴾</span>: أي: القرآنُ.</p><p><span class="qpc-hafs">﴿إِفۡكٌ﴾</span>: كَذِبٌ وبُهْتانٌ.</p><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰهُ﴾</span>: اختَلَقَه وتَقَوَّلَه.</p><p><span class="qpc-hafs">﴿قَوۡمٌ ءَاخَرُونَ﴾</span>: أي: من الَّذينَ أسْلَمُوا مِن أهْلِ الكِتابِ.</p><p><span class="qpc-hafs">﴿وَزُورࣰا﴾</span>: كَذِبًا عظِيمًا.</p></div>"
  25,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: الأكاذيبُ الَّتي كَتَبها المتقدِّمُونَ.</p><p><span class="qpc-hafs">﴿ٱكۡتَتَبَهَا﴾</span>: طَلَبَ كِتابَتَها.</p><p><span class="qpc-hafs">﴿تُمۡلَىٰ عَلَيۡهِ﴾</span>: تُقْرَأُ عَلَيهِ لِيِحْفَظَها.</p></div>"
  25,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسِّرَّ﴾</span>: هو كلُّ ما يَغِيبُ ويَخْفى.</p></div>"
  25,7,""
  25,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّةࣱ﴾</span>: أي: بُسْتانٌ مُثْمِرٌ.</p><p><span class="qpc-hafs">﴿مَّسۡحُورًا﴾</span>: مَجْنُونًا، غَلَبَ السِّحرُ على عَقْلِه.</p></div>"
  25,9,""
  25,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتࣲ﴾</span>: بَساتِينَ وحَدائقَ.</p><p><span class="qpc-hafs">﴿قُصُورَۢا﴾</span>: بُيُوتًا مُشَيَّدةً.</p></div>"
  25,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعۡتَدۡنَا﴾</span>: وجَعَلْناه مُعَدًّا لهم.</p><p><span class="qpc-hafs">﴿سَعِيرًا﴾</span>: أي: نارًا مُشْتَعِلةً تُسَعَّر بهم.</p></div>"
  25,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَغَيُّظࣰا﴾</span>: صَوْتَ غَلَيانٍ وفَوَرانٍ.</p><p><span class="qpc-hafs">﴿وَزَفِيرࣰا﴾</span>: النَّفَسَ الخارِجَ مِنَ الجَوفِ بِشِدَّةٍ.</p></div>"
  25,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡهَا﴾</span>: أي: مِن جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿مُّقَرَّنِينَ﴾</span>: مُقَيَّدةً أيدِيهِم إلى أعْناقِهِم.</p><p><span class="qpc-hafs">﴿ثُبُورࣰا﴾</span>: هَلاكًا.</p></div>"
  25,14,""
  25,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَصِيرࣰا﴾</span>: ومَرْجِعًا.</p></div>"
  25,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّسۡـُٔولࣰا﴾</span>: أي: يَسْأَلُ اللهَ عِبادُه المتَّقُونَ</p></div>"
  25,17,""
  25,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَكَ﴾</span>: تَنْزِيهًا لَكَ يا رَبَّنا.</p><p><span class="qpc-hafs">﴿مَا كَانَ يَنۢبَغِي لَنَآ﴾</span>: ما كان يَحِقُّ ولا يَصِحُّ لَنا.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: المُرادُ به: آلهةٌ نَعْبُدُهُم.</p><p><span class="qpc-hafs">﴿نَسُواْ ٱلذِّكۡرَ﴾</span>: غَفَلُوا عَن دَلائِلِ الوَحْدانيَّةِ.</p><p><span class="qpc-hafs">﴿بُورࣰا﴾</span>: هالِكِينَ أو فاسِدِين.</p></div>"
  25,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡفࣰا﴾</span>: دَفْعًا.</p><p><span class="qpc-hafs">﴿يَظۡلِم﴾</span>: أي: يُشْرِكْ بِاللهِ.</p></div>"
  25,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةً﴾</span>: ابْتِلاءً واخْتِبارًا.</p></div>"
  25,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ﴾</span>: لا يخافُونَ.</p><p><span class="qpc-hafs">﴿أَوۡ نَرَىٰ﴾</span>: أي: عِيانًا.</p><p><span class="qpc-hafs">﴿ٱسۡتَكۡبَرُواْ فِيٓ أَنفُسِهِمۡ﴾</span>: أضْمَرُوا الاسْتِكْبارَ عَنِ الحَقِّ في قُلُوبِهِم.</p><p><span class="qpc-hafs">﴿وَعَتَوۡ﴾</span>: تَجاوَزُوا الحدَّ في الطُّغيانِ.</p></div>"
  25,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِجۡرࣰا مَّحۡجُورࣰا﴾</span>: حَرامًا محرَّمًا عَلَيكُمُ الجنَّةُ.</p></div>"
  25,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَبَآءࣰ﴾</span>: أي: كالهباءِ وهو ما يُرى في ضَوءِ الشَّمسِ مِن دقِيقِ الغُبارِ.</p><p><span class="qpc-hafs">﴿مَّنثُورًا﴾</span>: مُفَرَّقًا.</p></div>"
  25,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقِيلࣰا﴾</span>: مَكانًا للرّاحَةِ وقتَ القَيْلُولَةِ.</p></div>"
  25,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَشَقَّقُ ٱلسَّمَآءُ﴾</span>: تَتَفَتَّحُ السَّمَواتُ.</p><p><span class="qpc-hafs">﴿بِٱلۡغَمَـٰمِ﴾</span>: بالسَّحابِ الأبيضِ الرَّقِيقِ.</p></div>"
  25,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَسِيرࣰا﴾</span>: صَعْبًا شَدِيدًا.</p></div>"
  25,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعَضُّ ٱلظَّالِمُ عَلَىٰ يَدَيۡهِ﴾</span>: أي: تَحَسُّرًا.</p></div>"
  25,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلِيلࣰا﴾</span>: صَدِيقًا.</p></div>"
  25,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلذِّكۡرِ﴾</span>: أي: القرآنِ والإيمانِ به.</p><p><span class="qpc-hafs">﴿خَذُولࣰا﴾</span>: كثيرَ الخِذْلانِ لِمَن يُوالِيهِ، والخِذْلانُ: التَّخَلِّي عَنِ النُّصْرَةِ.</p></div>"
  25,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَهۡجُورࣰا﴾</span>: مَتْرُوكًا، تُرِكَ الإيمانُ به والعَمَلُ بِما فِيه.</p></div>"
  25,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُجۡرِمِينَ﴾</span>: أي: الكافِرِينَ والمُشْرِكِينَ.</p></div>"
  25,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿جُمۡلَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: أي: دُفْعةً واحِدَةً.</p><p><span class="qpc-hafs">﴿لِنُثَبِّتَ بِهِۦ فُؤَادَكَ﴾</span>: لنُقَوِّيَ به قَلْبَكَ.</p><p><span class="qpc-hafs">﴿وَرَتَّلۡنَـٰهُ تَرۡتِيلࣰا﴾</span>: أي: أنْزَلْناه وفرَّقْناه آيةً بعْدَ آيةٍ.</p></div>"
  25,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَثَلٍ﴾</span>: بِحُجَّةٍ أو شُبْهَةٍ.</p></div>"
  25,34,""
  25,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزِيرࣰا﴾</span>: مُعِينًا لِتَبْلِيغِ الرِّسالةِ.</p></div>"
  25,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَدَمَّرۡنَـٰهُمۡ﴾</span>: فَأَهْلَكْناهُم.</p></div>"
  25,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: عِبْرةً.</p><p><span class="qpc-hafs">﴿وَأَعۡتَدۡنَا﴾</span>: هَيَّأنا.</p></div>"
  25,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبَ ٱلرَّسِّ﴾</span>: أصْحابَ البِئْرِ.</p><p><span class="qpc-hafs">﴿وَقُرُونَۢا﴾</span>: وأُمَمًا.</p></div>"
  25,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَبۡنَا لَهُ ٱلۡأَمۡثَـٰلَ﴾</span>: بَيَّنّا لجَمِيعِ الأمَمِ الحُجَجَ، وأَزَلْنا عَنْهم الشَّبُهاتِ.</p><p><span class="qpc-hafs">﴿تَبَّرۡنَا﴾</span>: أهْلَكْنا.</p></div>"
  25,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَرۡيَةِ﴾</span>: هي «سَدُومُ» قَرْيَةُ قَومِ لُوطٍ.</p><p><span class="qpc-hafs">﴿مَطَرَ ٱلسَّوۡءِ﴾</span>: أي: بالحِجارةِ مِنَ السَّماءِ.</p><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ نُشُورࣰا﴾</span>: لا يتَوَقَّعُونَ بَعْثًا بَعْدَ الموتِ.</p></div>"
  25,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوًا﴾</span>: مُسْتَهْزَأً بِه.</p></div>"
  25,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن كَادَ﴾</span>: إنّه قارَبَ.</p></div>"
  25,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلًا﴾</span>: حَفِيظًا يَحْفَظُه مِنِ اتِّباعِ هَواهُ.</p></div>"
  25,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡأَنۡعَـٰمِ﴾</span>: كالبَهائِمِ لا يَفْهَمُونَ.</p></div>"
  25,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَدَّ ٱلظِّلَّ﴾</span>: بَسَطَه مِن طُلُوعِ الفَجْرِ إلى طُلُوعِ الشَّمسِ.</p><p><span class="qpc-hafs">﴿سَاكِنࣰا﴾</span>: ثابِتًا، لا تُزِيلُهُ الشَّمْسُ.</p><p><span class="qpc-hafs">﴿دَلِيلࣰا﴾</span>: أي: يُسْتَدَلُّ بأحْوالِ الشَّمسِ على أحْوالِ الظِّلِّ.</p></div>"
  25,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَبۡضࣰا يَسِيرࣰا﴾</span>: أي: يَتَقَلَّصُ الظِّلُّ تَدْرِيجيًّا بِقَدْرِ ارْتِفاعِ الشَّمسِ.</p></div>"
  25,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِبَاسࣰا﴾</span>: ساتِرًا بِظَلامِهِ.</p><p><span class="qpc-hafs">﴿سُبَاتࣰا﴾</span>: راحَةً لَكُم.</p><p><span class="qpc-hafs">﴿نُشُورࣰا﴾</span>: تَنْتَشِرُونَ فِيهِ لمَعاشِكُم.</p></div>"
  25,48,""
  25,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡعَـٰمࣰا﴾</span>: بَهائِمَ.</p><p><span class="qpc-hafs">﴿وَأَنَاسِيَّ﴾</span>: أُناسًا.</p></div>"
  25,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرَّفۡنَـٰهُ بَيۡنَهُمۡ﴾</span>: أنْزَلْنا المَطَرَ على أنْحاءٍ مُخْتَلِفَةٍ.</p><p><span class="qpc-hafs">﴿كُفُورࣰا﴾</span>: جُحُودًا بالنِّعمَةِ.</p></div>"
  25,51,""
  25,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَـٰهِدۡهُم بِهِۦ﴾</span>: وجاهِدِ الكُفّارَ بالقُرآنِ والبُرْهانِ.</p></div>"
  25,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرَجَ﴾</span>: خَلَطَ وأرْسَلَ.</p><p><span class="qpc-hafs">﴿عَذۡبࣱ فُرَاتࣱ﴾</span>: حُلْوٌ شَدِيدُ الحَلاوَةِ.</p><p><span class="qpc-hafs">﴿أُجَاجࣱ﴾</span>: شَدِيدُ المُلُوحَةِ.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمَا بَرۡزَخࣰا﴾</span>: حاجِزًا بين البَحْرَينِ يَمْنَعُ اخْتِلاطَ أحَدِهِما بالآخَر.</p><p><span class="qpc-hafs">﴿وَحِجۡرࣰا مَّحۡجُورࣰا﴾</span>: أي: مانِعًا حَصِينًا.</p></div>"
  25,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَآءِ﴾</span>: هو مَنِيُّ الرَّجلِ والمرْأةِ.</p><p><span class="qpc-hafs">﴿وَصِهۡرࣰا﴾</span>: القَرابَةَ النّاشِئَةَ مِنَ الزَّواجِ بَيْنَ الزَّوْجِ وأهْلِ زَوْجتِهِ.</p></div>"
  25,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ رَبِّهِۦ ظَهِيرࣰا﴾</span>: مُعِينًا للشَّيطانِ على رَبِّه.</p></div>"
  25,56,""
  25,57,""
  25,58,""
  25,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ ٱسۡتَوَىٰ﴾</span>: أي: عَلا وارْتَفَعَ كَما يَلِيقُ بِجَلالِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هو سريرُ المُلْكِ الَّذِي اسْتَوى عليه الرَّحْمَنُ وتَحْمِلُهُ الملائِكةُ، وهو أعْظَمُ المخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p></div>"
  25,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُفُورࣰا﴾</span>: تَباعُدًا عَنِ الإيمانِ.</p></div>"
  25,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَارَكَ﴾</span>: تَكاثَرَ خَيْرُه وعَظُمَتْ بَرَكاتُه.</p><p><span class="qpc-hafs">﴿بُرُوجࣰا﴾</span>: مَنازِلَ للكَواكِبِ والنُّجُومِ.</p><p><span class="qpc-hafs">﴿سِرَ ٰ⁠جࣰا﴾</span>: شَمْسًا تُضِيءُ.</p></div>"
  25,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خِلۡفَةࣰ﴾</span>: يَخْلُفُ أحدُهما الآخَرَ فَيَتَعاقَبانِ.</p><p><span class="qpc-hafs">﴿أَن يَذَّكَّرَ﴾</span>: أن يَعْتَبرَ.</p></div>"
  25,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَوۡنࣰا﴾</span>: أي: بسَكِينَةٍ وتَواضُعٍ.</p><p><span class="qpc-hafs">﴿قَالُواْ سَلَـٰمࣰا﴾</span>: أي: قالُوا قَوْلًا سَدِيدًا يَسْلَمُونَ بهِ مِنَ الأذى.</p></div>"
  25,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبِيتُونَ﴾</span>: يَقْضُونَ لَيالِيَهُم.</p></div>"
  25,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡرِفۡ﴾</span>: ادْفَعْ.</p><p><span class="qpc-hafs">﴿غَرَامًا﴾</span>: لِزامًا، يُلازِمُ صاحِبَهُ.</p></div>"
  25,66,""
  25,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمۡ يُسۡرِفُواْ﴾</span>: لم يَتَجاوَزُوا حَدَّ الاعْتِدالِ.</p><p><span class="qpc-hafs">﴿وَلَمۡ يَقۡتُرُواْ﴾</span>: ولم يُضَيِّقوا في الإنْفِاقِ.</p><p><span class="qpc-hafs">﴿قَوَامࣰا﴾</span>: وسَطًا بَيْنَ التَّبذِيرِ والتَّضْيِيقِ.</p></div>"
  25,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَدۡعُونَ﴾</span>: لا يَعْبُدُونَ.</p><p><span class="qpc-hafs">﴿أَثَامࣰا﴾</span>: عِقابًا.</p></div>"
  25,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَخۡلُدۡ فِيهِۦ﴾</span>: ويَبْقى فيه على الدَّوامِ.</p><p><span class="qpc-hafs">﴿مُهَانًا﴾</span>: ذلِيلًا حَقِيرًا.</p></div>"
  25,70,""
  25,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَابࣰا﴾</span>: توبةً.</p></div>"
  25,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلزُّورَ﴾</span>: شَهادَةً كاذِبَةً.</p><p><span class="qpc-hafs">﴿بِٱللَّغۡوِ﴾</span>: بِكُلِّ ساقِطٍ مِن قَوْلٍ أو فِعْلٍ.</p><p><span class="qpc-hafs">﴿مَرُّواْ كِرَامࣰا﴾</span>: مُكْرِمِينَ أنْفُسَهُم بالإعْراضِ عَنْهُ.</p></div>"
  25,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمۡ يَخِرُّواْ﴾</span>: لم يَسْقُطُوا ولَمْ يَقَعُوا.</p><p><span class="qpc-hafs">﴿صُمࣰّا وَعُمۡيَانࣰا﴾</span>: أي: لا يَسْمَعُونَ ولا يُبْصِرُونَ، والمعنى إنّما يَخِرُّونَ عَلَيها سامِعِينَ مُبْصِرِينَ مُنْتَفِعِينَ.</p></div>"
  25,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُرَّةَ أَعۡيُنࣲ﴾</span>: مَوْضِعَ سُرورٍ وفَرَحٍ.</p></div>"
  25,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغُرۡفَةَ﴾</span>: المرادُ منها أعلى مَنازِلِ الجنَّةِ وأَفْضَلُها.</p></div>"
  25,76,""
  25,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يَعۡبَؤُاْ بِكُمۡ﴾</span>: لا يُبالي بكُم.</p><p><span class="qpc-hafs">﴿لِزَامَۢا﴾</span>: أي: عَذابًا داِئمًا مُلازِمًا لَكُم.</p></div>"
