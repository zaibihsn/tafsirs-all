quran[129]{c,v,t}:
  9,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَرَآءَةࣱ﴾</span>: إعذارٌ وتَحَلُّلٌ من العهودِ.</p><p><span class="qpc-hafs">﴿عَـٰهَدتُّم﴾</span>: التزَمْتُم معهم بميثاقٍ.</p></div>"
  9,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسِيحُواْ﴾</span>: فسِيروا آمنين.</p><p><span class="qpc-hafs">﴿غَيۡرُ مُعۡجِزِي ٱللَّهِ﴾</span>: لن تُفْلِتُوا من عقوبةِ الله.</p><p><span class="qpc-hafs">﴿مُخۡزِي ٱلۡكَـٰفِرِينَ﴾</span>: مُذِلُّهم في الدنيا والآخرة.</p></div>"
  9,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَذَ ٰ⁠نࣱ﴾</span>: إعلامٌ وإنذارٌ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡحَجِّ ٱلۡأَكۡبَرِ﴾</span>: يومَ النَّحرِ.</p><p><span class="qpc-hafs">﴿تُبۡتُمۡ﴾</span>: رَجَعْتُم إلى الحقِّ وتَرَكْتُم الشِّركَ.</p><p><span class="qpc-hafs">﴿تَوَلَّيۡتُمۡ﴾</span>: أعْرَضْتُم.</p><p><span class="qpc-hafs">﴿وَبَشِّرِ﴾</span>: وأنذِرْ.</p></div>"
  9,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمۡ يَنقُصُوكُمۡ شَيۡـࣰٔا﴾</span>: لم يَخُونوا العهدَ ولا شروطَه.</p><p><span class="qpc-hafs">﴿وَلَمۡ يُظَـٰهِرُواْ﴾</span>: ولم يُعاونوا.</p><p><span class="qpc-hafs">﴿إِلَىٰ مُدَّتِهِمۡ﴾</span>: إلى مدةِ العهدِ المحددةِ.</p></div>"
  9,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنسَلَخَ﴾</span>: خَرَجَ وانقَضى.</p><p><span class="qpc-hafs">﴿ٱلۡأَشۡهُرُ ٱلۡحُرُمُ﴾</span>: الأشهرُ الأربعةُ التي أمَّنتم بها المشركين.</p><p><span class="qpc-hafs">﴿وَخُذُوهُمۡ﴾</span>: وأْسِروهم.</p><p><span class="qpc-hafs">﴿وَٱحۡصُرُوهُمۡ﴾</span>: اقصِدُوهم بالحِصارِ في معاقِلِهم، أو امنعُوهم من الخروجِ والتنقُّلِ في البلادِ.</p><p><span class="qpc-hafs">﴿كُلَّ مَرۡصَدࣲ﴾</span>: كلَّ طريقٍ ومَرْقَبٍ.</p><p><span class="qpc-hafs">﴿تَابُواْ﴾</span>: رَجَعُوا عن الكفر ودخلوا في الإسلام.</p><p><span class="qpc-hafs">﴿فَخَلُّواْ سَبِيلَهُمۡ﴾</span>: فاترُكوهم ولا تتعرَّضوا لهم.</p></div>"
  9,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَجَارَكَ﴾</span>: طَلَبَ جِوارَكَ، أي: حمايتَك وأمانَك.</p><p><span class="qpc-hafs">﴿فَأَجِرۡهُ﴾</span>: فأمِّنْهُ.</p><p><span class="qpc-hafs">﴿كَلَـٰمَ ٱللَّهِ﴾</span>: القرآنَ الكريمَ.</p><p><span class="qpc-hafs">﴿أَبۡلِغۡهُ مَأۡمَنَهُۥ﴾</span>: أعِدْهُ من حيثُ أتى آمِنًا.</p></div>"
  9,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡفَ يَكُونُ﴾</span>: لا يكونُ.</p><p><span class="qpc-hafs">﴿عَهۡدٌ﴾</span>: التزامٌ بميثاقٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span>: الحَرَمِ كلِّه.</p><p><span class="qpc-hafs">﴿فَمَا ٱسۡتَقَـٰمُواْ لَكُمۡ﴾</span>: فما أقاموا على الوفاءِ بعهدكم.</p></div>"
  9,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظۡهَرُواْ عَلَيۡكُمۡ﴾</span>: يَظْفَرُوا بكم ويَغْلِبوكم.</p><p><span class="qpc-hafs">﴿لَا يَرۡقُبُواْ﴾</span>: لا يُراعُوا.</p><p><span class="qpc-hafs">﴿إِلࣰّا﴾</span>: قَرابةً ولا حِلْفًا.</p><p><span class="qpc-hafs">﴿ذِمَّةࣰ﴾</span>: عَهْدًا ولا حَقًّا.</p></div>"
  9,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡتَرَوۡاْ﴾</span>: استبدَلُوا.</p><p><span class="qpc-hafs">﴿ثَمَنࣰا قَلِيلࣰا﴾</span>: عَرَضَ الدنيا الزائلَ.</p><p><span class="qpc-hafs">﴿فَصَدُّواْ عَن سَبِيلِهِۦٓ﴾</span>: فأعرضُوا عن الحقِّ، ومنعُوا غيرَهم عنه.</p><p><span class="qpc-hafs">﴿سَآءَ﴾</span>: قَبُحَ.</p></div>"
  9,10,""
  9,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُفَصِّلُ﴾</span>: نُبيِّنُ.</p></div>"
  9,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّكَثُوٓاْ﴾</span>: نَقَضُوا.</p><p><span class="qpc-hafs">﴿أَيۡمَـٰنَهُم﴾</span>: مواثيقَهم المؤكَّدةَ بالأَيْمان.</p><p><span class="qpc-hafs">﴿وَطَعَنُواْ فِي دِينِكُمۡ﴾</span>: ذَمُّوا الإسلامَ وعابُوه.</p><p><span class="qpc-hafs">﴿لَآ أَيۡمَـٰنَ لَهُمۡ﴾</span>: لا عهودَ لهم يُوَفّى بها.</p></div>"
  9,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَمُّواْ﴾</span>: وعَزَمُوا وعَمِلوا.</p><p><span class="qpc-hafs">﴿بَدَءُوكُمۡ﴾</span>: بالإيذاءِ والقتالِ.</p><p><span class="qpc-hafs">﴿أَوَّلَ مَرَّةٍ﴾</span>: أولَ الأمرِ «بمكةَ» «وببَدْرٍ» وغيرِهما.</p><p><span class="qpc-hafs">﴿أَتَخۡشَوۡنَهُمۡ﴾</span>: أتَخافُونهم، أو أتخافون ملاقاتَهم في الحربِ؟</p></div>"
  9,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُعَذِّبۡهُمُ﴾</span>: يَقْتُلْهم.</p><p><span class="qpc-hafs">﴿وَيُخۡزِهِمۡ﴾</span>: ويُذِلّهم بالهزيمةِ والأَسْرِ.</p><p><span class="qpc-hafs">﴿وَيَشۡفِ﴾</span>: يُزِلِ الغَمَّ ونحوَه.</p></div>"
  9,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡظَ قُلُوبِهِمۡ﴾</span>: غَضَبَها وما تحمِلُه من كراهةٍ للأعداءِ.</p></div>"
  9,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُتۡرَكُواْ﴾</span>: دونَ اختبارٍ وابتلاءٍ.</p><p><span class="qpc-hafs">﴿وَلِيجَةࣰ﴾</span>: بِطانةً وأولياءَ.</p></div>"
  9,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا كَانَ﴾</span>: ما صَحَّ ولا استقامَ.</p><p><span class="qpc-hafs">﴿أَن يَعۡمُرُواْ مَسَـٰجِدَ ٱللَّهِ﴾</span>: أن يَبْنُوها ويَصُونوها، أو أن يُقيموا العبادةَ فيها.</p><p><span class="qpc-hafs">﴿حَبِطَتۡ﴾</span>: بَطَلتْ.</p></div>"
  9,18,""
  9,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِقَايَةَ ٱلۡحَآجِّ﴾</span>: سَقْيَ الحُجّاجِ الماءَ.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوَفِّقُ</p><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: الكافرين.</p></div>"
  9,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَرَجَةً﴾</span>: مَنزِلَةً.</p></div>"
  9,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرِضۡوَ ٰ⁠نࣲ﴾</span>: رضا اللهِ عنهم الذي لا سُخْطَ بعدَه.</p><p><span class="qpc-hafs">﴿مُّقِيمٌ﴾</span>: دائمٌ لا يَزُولُ.</p></div>"
  9,22,""
  9,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: نصراءَ وأصدقاءَ.</p><p><span class="qpc-hafs">﴿ٱسۡتَحَبُّواْ ٱلۡكُفۡرَ﴾</span>: اختارُوه ودامُوا عليه.</p></div>"
  9,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَشِيرَتُكُمۡ﴾</span>: قبيلتُكم وذوو القَرابةِ القريبة.</p><p><span class="qpc-hafs">﴿ٱقۡتَرَفۡتُمُوهَا﴾</span>: اكتسَبْتموها.</p><p><span class="qpc-hafs">﴿كَسَادَهَا﴾</span>: عَدَمَ رَواجِها.</p><p><span class="qpc-hafs">﴿تَرۡضَوۡنَهَآ﴾</span>: تُعْجِبُكم وتميلُ أنفسُكم إليها.</p><p><span class="qpc-hafs">﴿فَتَرَبَّصُواْ﴾</span>: فانتظِرُوا.</p><p><span class="qpc-hafs">﴿بِأَمۡرِهِۦ﴾</span>: بعقابِه.</p></div>"
  9,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا رَحُبَتۡ﴾</span>: مع وُسْعِها.</p><p><span class="qpc-hafs">﴿وَلَّيۡتُم﴾</span>: فَرَرْتُم.</p><p><span class="qpc-hafs">﴿مُّدۡبِرِينَ﴾</span>: مُنْهَزِمِين، جاعِلين ظُهورَكم جهةَ عدوِّكم.</p></div>"
  9,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَكِينَتَهُۥ﴾</span>: طمأنينتَه وأَمْنَه.</p><p><span class="qpc-hafs">﴿جُنُودࣰا﴾</span>: ملائكةً.</p></div>"
  9,27,""
  9,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَجَسࣱ﴾</span>: خُبَثاءُ في عقائدِهم وأعمالِهم الشِّرْكيةِ.</p><p><span class="qpc-hafs">﴿عَامِهِمۡ هَـٰذَا﴾</span>: وهو العامُ التاسعُ من الهجرةِ.</p><p><span class="qpc-hafs">﴿عَيۡلَةࣰ﴾</span>: فَقْرًا.</p></div>"
  9,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَدِينُونَ دِينَ ٱلۡحَقِّ﴾</span>: ولا يَلْتزمون أحكامَ الإسلام الذي ارتضاه الله دِينًا للناسِ.</p><p><span class="qpc-hafs">﴿ٱلۡجِزۡيَةَ﴾</span>: ما قُدِّرَ على أهل الكِتابِ من المالِ كلَّ عامٍ؛ جزاءً لما مُنِحُوا من الأمنِ.</p><p><span class="qpc-hafs">﴿عَن يَدࣲ﴾</span>: بأيدِيهم غيرَ ممتنعين.</p><p><span class="qpc-hafs">﴿صَـٰغِرُونَ﴾</span>: خاضِعونَ أذلّاءُ.</p></div>"
  9,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُزَيۡرٌ﴾</span>: حَبْرٌ من علماءِ اليهودِ، يُعَظِّمُونه؛ لعِلْمِه وعبادتِه.</p><p><span class="qpc-hafs">﴿يُضَـٰهِـُٔونَ﴾</span>: يُشابِهُون.</p><p><span class="qpc-hafs">﴿قَـٰتَلَهُمُ ٱللَّهُ﴾</span>: دعاءٌ عليهم بالهَلاكِ.</p><p><span class="qpc-hafs">﴿أَنَّىٰ يُؤۡفَكُونَ﴾</span>: كيف يُصْرَفُون عن الحقِّ الواضحِ إلى الباطلِ؟</p></div>"
  9,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡبَارَهُمۡ﴾</span>: جَمْعُ حَبْرٍ، وهم العلماءُ من اليهودِ.</p><p><span class="qpc-hafs">﴿وَرُهۡبَـٰنَهُمۡ﴾</span>: جَمْعُ راهبٍ، وهم العُبّادُ من النَّصارى.</p><p><span class="qpc-hafs">﴿أَرۡبَابࣰا مِّن دُونِ ٱللَّهِ﴾</span>: إذ أطاعُوهم في تحريمِ ما أحلَّ اللهُ، وتحليلِ ما حَرَّمه.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسِيحَ ٱبۡنَ مَرۡيَمَ﴾</span>: واتخذ النصارى عيسى عليه السلام إلهًا فعبدُوه.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تَنَزَّه اللهُ وتَقَدَّسَ.</p></div>"
  9,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُرِيدُونَ﴾</span>: يريدُ الكفّارُ بتكذيبهِم.</p><p><span class="qpc-hafs">﴿أَن يُطۡفِـُٔواْ﴾</span>: أن يُبْطِلُوا.</p><p><span class="qpc-hafs">﴿نُورَ ٱللَّهِ﴾</span>: دينَ الإسلامِ وما فيه من الهُدى والرَّشادِ.</p><p><span class="qpc-hafs">﴿يُتِمَّ نُورَهُۥ﴾</span>: يُكْمِلَ اللهُ دينَه ويُظْهِرَه.</p></div>"
  9,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡهُدَىٰ﴾</span>: بالإيمانِ الصَّحيحِ، والعلمِ النافعِ.</p><p><span class="qpc-hafs">﴿وَدِينِ ٱلۡحَقِّ﴾</span>: دينِ الإسلامِ.</p><p><span class="qpc-hafs">﴿لِيُظۡهِرَهُۥ﴾</span>: ليُعْلِيَه.</p><p><span class="qpc-hafs">﴿عَلَى ٱلدِّينِ كُلِّهِۦ﴾</span>: على الأديانِ جميعًا.</p></div>"
  9,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَأۡكُلُونَ أَمۡوَ ٰ⁠لَ ٱلنَّاسِ﴾</span>: لَيأخُذُونها.</p><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: بغيرِ حَقٍّ كالرِّشوةِ وغيرِها.</p><p><span class="qpc-hafs">﴿وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ﴾</span>: ويمنعون الناسَ من الدخولِ في الإسلامِ، أو اتباعِ الحقِّ.</p><p><span class="qpc-hafs">﴿يَكۡنِزُونَ ٱلذَّهَبَ وَٱلۡفِضَّةَ﴾</span>: يجمعونَ الأموالَ.</p><p><span class="qpc-hafs">﴿وَلَا يُنفِقُونَهَا فِي سَبِيلِ ٱللَّهِ﴾</span>: ولايُؤَدُّون زَكاتَها، ولايُخْرِجون منها الحقوقَ الواجبةَ.</p></div>"
  9,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتُكۡوَىٰ﴾</span>: تُحْرَقُ.</p><p><span class="qpc-hafs">﴿فَذُوقُواْ مَا كُنتُمۡ تَكۡنِزُونَ﴾</span>: ذُوقوا سوءَ عاقبةِ جَمْعِكم.</p></div>"
  9,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِدَّةَ ٱلشُّهُورِ﴾</span>: أي: عَدَدَها الذي يَتَألَّفُ منه العامُ.</p><p><span class="qpc-hafs">﴿فِي كِتَـٰبِ ٱللَّهِ﴾</span>: في حُكْمِه القَدَريِّ الذي كُتب في اللَّوحِ المحفوظِ.</p><p><span class="qpc-hafs">﴿أَرۡبَعَةٌ حُرُمࣱ﴾</span>: أي: ذاتُ حُرْمَةٍ وتعظيمٍ، وهي: رَجَبٌ، وذو القِعدة، وذو الحِجَّةِ، والمُحَرَّمُ.</p><p><span class="qpc-hafs">﴿ٱلۡقَيِّمُ﴾</span>: المستقيمُ الذي لا عِوَجَ فيه.</p><p><span class="qpc-hafs">﴿فَلَا تَظۡلِمُواْ فِيهِنَّ أَنفُسَكُمۡ﴾</span>: بارتكابِ ما حَرَّمَ اللهُ؛ لعِظَمِ حُرْمتِها.</p><p><span class="qpc-hafs">﴿كَآفَّةࣰ﴾</span>: جميعًا، وفي كلِّ الشهورِ.</p><p><span class="qpc-hafs">﴿وَٱعۡلَمُوٓاْ أَنَّ ٱللَّهَ مَعَ ٱلۡمُتَّقِينَ﴾</span>: بالعَوْنِ والنَّصرِ.</p></div>"
  9,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّسِيٓءُ﴾</span>: تأخيرُ حُرْمَةِ شهرٍ إلى شهرٍ آخرَ، كما كانت تفعلُه العربُ في الجاهليةِ.</p><p><span class="qpc-hafs">﴿يُحِلُّونَهُۥ﴾</span>: أي: النسيءَ.</p><p><span class="qpc-hafs">﴿لِّيُوَاطِـُٔواْ﴾</span>: ليوافِقُوا بتحليلِ شهرٍ وتحريمِ آخرَ بَدَلَه.</p><p><span class="qpc-hafs">﴿عِدَّةَ﴾</span>: عددَ.</p><p><span class="qpc-hafs">﴿مَا حَرَّمَ ٱللَّهُ﴾</span>: من الأشهرِ، بحيث تكونُ أربعةً في العددِ.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوَفِّقُ.</p></div>"
  9,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنفِرُواْ﴾</span>: اخرُجُوا بخِفَّةٍ ونشاطٍ.</p><p><span class="qpc-hafs">﴿فِي سَبِيلِ ٱللَّهِ﴾</span>: إلى الجهادِ لإعلاءِ كلمةِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱثَّاقَلۡتُمۡ إِلَى ٱلۡأَرۡضِ﴾</span>: تباطَأْتم في الخروجِ ومِلْتُم إلى الإقامةِ في أرضِكم ومساكِنِكُم.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡـَٔاخِرَةِ﴾</span>: بدلَ نعيمِ الآخرةِ.</p><p><span class="qpc-hafs">﴿مَتَـٰعُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: ما يُتَمَتَّعُ به مِن لَذّاتِ الدنيا.</p></div>"
  9,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُعَذِّبۡكُمۡ﴾</span>: يُنْزِلْ عقوبتَه بكم.</p></div>"
  9,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا تَنصُرُوهُ﴾</span>: إن لم تَنْصُروا النبيَّ ﷺ.</p><p><span class="qpc-hafs">﴿ثَانِيَ ٱثۡنَيۡنِ﴾</span>: أحدَ اثنين، والثاني هو أبوبكرٍ الصدّيقُ رضي الله عنه.</p><p><span class="qpc-hafs">﴿ٱلۡغَارِ﴾</span>: النَّقْبِ في الَجبَلِ، وهو في جبلِ ثورٍ ب«مكةَ».</p><p><span class="qpc-hafs">﴿لِصَـٰحِبِهِۦ﴾</span>: أبي بكرٍ الصديقِ رضي الله عنه.</p><p><span class="qpc-hafs">﴿سَكِينَتَهُۥ﴾</span>: طمأنينتَه.</p><p><span class="qpc-hafs">﴿بِجُنُودࣲ﴾</span>: هم الملائكةُ، يَحْرُسُونه ويَصْرِفُون أبصارَ الكفارِ عنه.</p><p><span class="qpc-hafs">﴿كَلِمَةَ ٱلَّذِينَ كَفَرُواْ﴾</span>: أي: دعوةَ الشِّركِ والكفرِ.</p><p><span class="qpc-hafs">﴿ٱلسُّفۡلَىٰ﴾</span>: المغلوبةَ.</p><p><span class="qpc-hafs">﴿كَلِمَةُ ٱللَّهِ﴾</span>: كلمةُ التوحيدِ.</p><p><span class="qpc-hafs">﴿ٱلۡعُلۡيَا﴾</span>: الغالبةُ.</p></div>"
  9,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خِفَافࣰا﴾</span>: على الصِّفةِ التي يَخِفُّ عليكم الجهادُ فيها.</p><p><span class="qpc-hafs">﴿وَثِقَالࣰا﴾</span>: وعلى الصفةِ التي يَثْقُلُ عليكم الجهادُ فيها.</p></div>"
  9,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡ كَانَ﴾</span>: أي: ما دَعَوْتَهم إليه من الخروجِ للجهادِ.</p><p><span class="qpc-hafs">﴿عَرَضࣰا﴾</span>: مَتاعًا وغَنيمةً.</p><p><span class="qpc-hafs">﴿قَرِيبࣰا﴾</span>: سَهْلَ المأخَذِ.</p><p><span class="qpc-hafs">﴿قَاصِدࣰا﴾</span>: متوسِّطًا بَيْنَ القُرْبِ والبُعْدِ لا مَشَقَّةَ فيه.</p><p><span class="qpc-hafs">﴿ٱلشُّقَّةُ﴾</span>: المسافةُ البعيدةُ التي تُقْطَعُ بمَشَقَّةٍ.</p><p><span class="qpc-hafs">﴿يُهۡلِكُونَ أَنفُسَهُمۡ﴾</span>: بالَحلِفِ الكاذبِ والنِّفاقِ.</p></div>"
  9,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَفَا ٱللَّهُ عَنكَ﴾</span>: العَفْوُ: هو التجاوُزُ عن الخطأ وتَرْكُ المؤاخذةِ عليه.</p></div>"
  9,44,""
  9,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَـٔۡذِنُكَ﴾</span>: يَطْلُبُ الإذنَ للتخَلُّفِ عن الجهادِ.</p><p><span class="qpc-hafs">﴿وَٱرۡتَابَتۡ قُلُوبُهُمۡ﴾</span>: شَكَّتْ في الإسلامِ وشرائعِه.</p><p><span class="qpc-hafs">﴿يَتَرَدَّدُونَ﴾</span>: يتَحيَّرُون.</p></div>"
  9,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخُرُوجَ﴾</span>: مَعَك إلى الجهادِ.</p><p><span class="qpc-hafs">﴿لَأَعَدُّواْ لَهُۥ عُدَّةࣰ﴾</span>: لَتَأهَّبُوا له بإعدادِ السِّلاحِ، والزادِ، وما يُحتاجُ إليه.</p><p><span class="qpc-hafs">﴿ٱنۢبِعَاثَهُمۡ﴾</span>: خروجَهم للجهادِ.</p><p><span class="qpc-hafs">﴿فَثَبَّطَهُمۡ﴾</span>: مَنَعهم وعوَّقهم بقَضائِه وقَدَرِه.</p><p><span class="qpc-hafs">﴿ٱقۡعُدُواْ﴾</span>: تَخَلَّفُوا عن الجِهادِ.</p><p><span class="qpc-hafs">﴿مَعَ ٱلۡقَـٰعِدِينَ﴾</span>: من المرضى والضُّعَفاءِ والنِّساءِ والصِّبْيانِ.</p></div>"
  9,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَبَالࣰا﴾</span>: شرًّا وفسادًا.</p><p><span class="qpc-hafs">﴿وَلَأَوۡضَعُواْ خِلَـٰلَكُمۡ﴾</span>: أسْرَعُوا في المَشْيِ بينَكم بالنميمةِ وإفسادِ القلوبِ.</p><p><span class="qpc-hafs">﴿يَبۡغُونَكُمُ﴾</span>: يُريدُون لكم.</p><p><span class="qpc-hafs">﴿ٱلۡفِتۡنَةَ﴾</span>: ما تُفْتَنُون به؛ كي تتثاقَلُوا عن الجهادِ في سبيلِ اللهِ.</p><p><span class="qpc-hafs">﴿سَمَّـٰعُونَ لَهُمۡ﴾</span>: مَن يَسْمعون كلام المنافقين، ويُطيعونهم.</p></div>"
  9,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتَغَوُاْ﴾</span>: طلبُوا وأرادوا.</p><p><span class="qpc-hafs">﴿ٱلۡفِتۡنَةَ﴾</span>: فتنةَ المؤمنين وصَدَّهم عن دينِهم.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: من قبلِ غزوةِ «تبوكَ».</p><p><span class="qpc-hafs">﴿وَقَلَّبُواْ لَكَ ٱلۡأُمُورَ﴾</span>: أرادُوا إبطالَ ما جِئْتَ به بتحايُلِهم ومَكْرِهم.</p><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: النصرُ من عندِ اللهِ.</p><p><span class="qpc-hafs">﴿وَظَهَرَ﴾</span>: علا وغَلَبَ.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: دينُه، وهو الإسلامُ.</p></div>"
  9,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنۡهُم﴾</span>: ومن المنافقين.</p><p><span class="qpc-hafs">﴿ٱئۡذَن لِّي﴾</span>: في التخَلُّف عن الجهادِ.</p><p><span class="qpc-hafs">﴿وَلَا تَفۡتِنِّيٓ﴾</span>: لاتُوقِعْني في فتنةِ النِّساءِ حالةَ الخروجِ معك.</p><p><span class="qpc-hafs">﴿فِي ٱلۡفِتۡنَةِ﴾</span>: فتنةِ النِّفاقِ والتخلُّفِ عن الجهادِ.</p><p><span class="qpc-hafs">﴿سَقَطُواْ﴾</span>: وقعوا في الإثمِ لمخالَفَتِهم أمرَ اللهِ ورسولِه.</p></div>"
  9,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣱ﴾</span>: نصرٌ وغنيمةٌ.</p><p><span class="qpc-hafs">﴿مُصِيبَةࣱ﴾</span>: مَكْرُوهٌ من هزيمةٍ أو شدَّةٍ.</p><p><span class="qpc-hafs">﴿قَدۡ أَخَذۡنَآ أَمۡرَنَا مِن قَبۡلُ﴾</span>: قد احْتَطْنا لأنفسِنا حين تَخَلَّفْنا عن الجهادِ قبلَ هذه المصيبةِ.</p><p><span class="qpc-hafs">﴿وَيَتَوَلَّواْ﴾</span>: وينصَرِفُوا.</p></div>"
  9,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا كَتَبَ ٱللَّهُ لَنَا﴾</span>: ما قَدَّرَه علينا.</p><p><span class="qpc-hafs">﴿هُوَ مَوۡلَىٰنَا﴾</span>: ناصِرُنا ومُتَوَلِّي أمورِنا.</p><p><span class="qpc-hafs">﴿وَعَلَى ٱللَّهِ فَلۡيَتَوَكَّلِ﴾</span>: فلْيَعْتَمِدْ ولْيُفَوِّضْ أمرَه إليه.</p></div>"
  9,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ تَرَبَّصُونَ﴾</span>: ما تنتظرون أن يَقَعَ.</p><p><span class="qpc-hafs">﴿إِحۡدَى ٱلۡحُسۡنَيَيۡنِ﴾</span>: إحدى العاقبتَين: النصرَ، أوالشهادةَ في سبيلِ اللهِ.</p></div>"
  9,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَوۡعًا﴾</span>: طائعِين.</p><p><span class="qpc-hafs">﴿كَرۡهࣰا﴾</span>: كارهِين.</p><p><span class="qpc-hafs">﴿فَـٰسِقِينَ﴾</span>: خارجِين عن دينِ اللهِ.</p></div>"
  9,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُسَالَىٰ﴾</span>: متثاقلون عن الصَّلاةِ.</p></div>"
  9,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُعَذِّبَهُم بِهَا﴾</span>: بما يَلْقَون من التعبِ في جَمْعِها، وبالمصائبِ التي تقعُ فيها.</p><p><span class="qpc-hafs">﴿وَتَزۡهَقَ﴾</span>: تَخْرُجَ.</p></div>"
  9,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡرَقُونَ﴾</span>: يَخافُون.</p></div>"
  9,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلۡجَـًٔا﴾</span>: حِصْنًا ومأمَنًا يلجَؤُون إليه.</p><p><span class="qpc-hafs">﴿مَغَـٰرَ ٰ⁠تٍ﴾</span>: جَمْعُ مَغارةٍ، وهي الكَهْفُ، أو الغارُ في الجبلِ يُؤْويهم.</p><p><span class="qpc-hafs">﴿مُدَّخَلࣰا﴾</span>: مكانًا يَدْخلونه كالنَّفَقِ في الأرضِ.</p><p><span class="qpc-hafs">﴿لَّوَلَّوۡاْ﴾</span>: لَأَقْبَلُوا.</p><p><span class="qpc-hafs">﴿يَجۡمَحُونَ﴾</span>: يُسْرِعون في دخولِه لا يَمْنَعُهم شيءٌ.</p></div>"
  9,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلۡمِزُكَ﴾</span>: يَعِيبُك.</p><p><span class="qpc-hafs">﴿ٱلصَّدَقَـٰتِ﴾</span>: في قِسْمةِ أموالِ الصَّدقاتِ.</p></div>"
  9,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسۡبُنَا ٱللَّهُ﴾</span>: كافِينا.</p><p><span class="qpc-hafs">﴿إِلَى ٱللَّهِ رَ ٰ⁠غِبُونَ﴾</span>: مُحِبُّون أن يُغْنيَنا من فضلِه.</p></div>"
  9,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّدَقَـٰتُ﴾</span>: الزَّكَواتُ المفروضةُ.</p><p><span class="qpc-hafs">﴿لِلۡفُقَرَآءِ﴾</span>: للمحتاجِين الذين لا يَمْلِكُون شيئًا.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: الذين لا يَمْلِكُون ما يَكْفيهم ويَسُدُّ حاجتَهم.</p><p><span class="qpc-hafs">﴿وَٱلۡعَـٰمِلِينَ عَلَيۡهَا﴾</span>: السُّعاةُ الذين يَجْمعون الزكاةَ من أصحابِها.</p><p><span class="qpc-hafs">﴿وَٱلۡمُؤَلَّفَةِ قُلُوبُهُمۡ﴾</span>: المستمالةِ قلوبُهم إلى الإسلام كمن يُرْجى إسلامُه أو قوَّةُ إيمانِه.</p><p><span class="qpc-hafs">﴿وَفِي ٱلرِّقَابِ﴾</span>: وتُعطى الزكاةُ في عِتْقِ رقابِ العبيدِ والمكاتَبين.</p><p><span class="qpc-hafs">﴿وَٱلۡغَـٰرِمِينَ﴾</span>: الذين استدانُوا لأنفسهم، ولا قُدَرةَ لهم على الوفاءِ، أو استدانُوا لإصلاحِ ذاتِ البَيْنِ.</p><p><span class="qpc-hafs">﴿وَفِي سَبِيلِ ٱللَّهِ﴾</span>: وللغُزاةِ وللمرابطين في سبيل الله.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: المسافرِ المنقطعِ عن مالِه في سفرِه، وإن كان غنيًا في بلدِه.</p><p><span class="qpc-hafs">﴿فَرِيضَةࣰ مِّنَ ٱللَّهِ﴾</span>: هذه القِسْمةُ فَرَضَها اللهُ فريضةً وقَدَّرها.</p></div>"
  9,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُذُنࣱ﴾</span>: يستمعُ لكلِّ ما يُقالُ له ويُصَدِّقُه.</p><p><span class="qpc-hafs">﴿قُلۡ أُذُنُ خَيۡرࣲ لَّكُمۡ﴾</span>: أي: أُذُنٌ في الخيرِ والحقِّ، وفيما يجبُ سَماعُه وقَبولُه.</p><p><span class="qpc-hafs">﴿وَيُؤۡمِنُ لِلۡمُؤۡمِنِينَ﴾</span>: ويُصَدِّقُ المؤمنين فيما يُخبرونه.</p></div>"
  9,62,""
  9,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَادِدِ﴾</span>: يخالِفْ.</p></div>"
  9,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُنَبِّئُهُم﴾</span>: تُخَبِّرُهم.</p><p><span class="qpc-hafs">﴿بِمَا فِي قُلُوبِهِمۡ﴾</span>: بما يُضْمِرُونَه في قلوبِهم من الكفرِ.</p><p><span class="qpc-hafs">﴿مُخۡرِجࣱ مَّا تَحۡذَرُونَ﴾</span>: مُظْهِرٌ ما تَخافُونه من الفضيحةِ.</p></div>"
  9,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَئِن سَأَلۡتَهُمۡ﴾</span>: عَمّا قالوا من الطَّعْنِ في حَقِّك وحَقِّ أصحابِك.</p><p><span class="qpc-hafs">﴿نَخُوضُ وَنَلۡعَبُ﴾</span>: نتحَدَّثُ بكلامٍ لم نَقْصِدْ به الإساءةَ.</p></div>"
  9,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن نَّعۡفُ عَن طَآئِفَةࣲ مِّنكُمۡ﴾</span>: بالتوفيق للتوبةِ والإخلاصِ فيها.</p><p><span class="qpc-hafs">﴿نُعَذِّبۡ طَآئِفَةَۢ﴾</span>: بسبب تَرْكِ التوبةِ والإصرارِ على النِّفاقِ.</p></div>"
  9,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡضُهُم مِّنۢ بَعۡضࣲ﴾</span>: أي: مُتَشابهون في صفةِ النِّفاقِ والبُعْدِ عن الإيمانِ.</p><p><span class="qpc-hafs">﴿بِٱلۡمُنكَرِ﴾</span>: بالكفرِ والمعاصي.</p><p><span class="qpc-hafs">﴿ٱلۡمَعۡرُوفِ﴾</span>: هو كلُّ ما عُرِفَ حُسْنُه في الشَّرعِ والعَقْلِ.</p><p><span class="qpc-hafs">﴿وَيَقۡبِضُونَ أَيۡدِيَهُمۡ﴾</span>: ويُمْسِكُون عن الإنفاقِ في طاعةِ اللهِ ومَرْضاتِه.</p><p><span class="qpc-hafs">﴿نَسُواْ ٱللَّهَ﴾</span>: تَرَكُوا طاعتَه وأوامرَه.</p><p><span class="qpc-hafs">﴿فَنَسِيَهُمۡ﴾</span>: فتركَهم من رحمتِه وثوابِه.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارجُون عن الإيمانِ والطاعة.</p></div>"
  9,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسۡبُهُمۡ﴾</span>: كافِيهم؛ عقابًا على كفرِهم.</p><p><span class="qpc-hafs">﴿وَلَعَنَهُمُ ٱللَّهُ﴾</span>: طَرَدَهم مِن رحمتِه.</p><p><span class="qpc-hafs">﴿مُّقِيمࣱ﴾</span>: دائمٌ لا ينقطعُ.</p></div>"
  9,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِخَلَـٰقِهِمۡ﴾</span>: بنصيبِهم الذي قُدِّرَ لهم من مَلاذِّ الدنيا.</p><p><span class="qpc-hafs">﴿وَخُضۡتُمۡ﴾</span>: ودَخَلْتُم في الباطلِ والطَّعْنِ في الدِّينِ.</p><p><span class="qpc-hafs">﴿حَبِطَتۡ﴾</span>: بَطَلَتْ.</p></div>"
  9,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبَأُ﴾</span>: خبرُ.</p><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبِ مَدۡيَنَ﴾</span>: هم قومُ شعيبٍ عليه السلام.</p><p><span class="qpc-hafs">﴿وَٱلۡمُؤۡتَفِكَـٰتِ﴾</span>: قُرى قومِ لوطٍ عليه السلام، التي انقلبَتْ بهم، فصار عالِيها سافلَها.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالوَحْيِ والمعجزاتِ.</p><p><span class="qpc-hafs">﴿كَانُوٓاْ أَنفُسَهُمۡ يَظۡلِمُونَ﴾</span>: بتعريضِها للعقابِ؛ بسببِ كُفْرِهم.</p></div>"
  9,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءُ بَعۡضࣲ﴾</span>: أنصارُ بعضٍ.</p><p><span class="qpc-hafs">﴿عَزِيزٌ﴾</span>: لا يُعْجِزُه شيء عن إنجازِ وعْدِه بالمؤمنين، ووعيدِه بمَن عَصاه وكَفَرَ به.</p><p><span class="qpc-hafs">﴿حَكِيمࣱ﴾</span>: يَضَعُ الأمورَ في محالِّها.</p></div>"
  9,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: من تحتِ قصورِها وأشجارِها.</p><p><span class="qpc-hafs">﴿طَيِّبَةࣰ﴾</span>: حسنةَ البناءِ، طَيِّبةَ القَرارِ.</p><p><span class="qpc-hafs">﴿جَنَّـٰتِ عَدۡنࣲ﴾</span>: أي: إقامةٍ وخُلودٍ.</p><p><span class="qpc-hafs">﴿أَكۡبَرُ﴾</span>: ممّا هم فيه من أنواعِ النعيمِ.</p></div>"
  9,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱغۡلُظۡ﴾</span>: واشدُدْ في جهادِك.</p><p><span class="qpc-hafs">﴿وَمَأۡوَىٰهُمۡ﴾</span>: مصيرُهم.</p></div>"
  9,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلِمَةَ ٱلۡكُفۡرِ﴾</span>: هي استهزاؤهُم بالرسولِ عليه الصلاةُ والسلام، وبالدِّينِ.</p><p><span class="qpc-hafs">﴿وَهَمُّواْ﴾</span>: وصَمَّمَ المنافقون على قَتْلِ الرسولِ ﷺ.</p><p><span class="qpc-hafs">﴿بِمَا لَمۡ يَنَالُواْ﴾</span>: بما لم يُمَكِّنْهم اللهُ منه.</p><p><span class="qpc-hafs">﴿وَمَا نَقَمُوٓاْ﴾</span>: وما وجَدَ المنافقون شيئًا يَكْرَهُونه ويَعِيبونَه.</p><p><span class="qpc-hafs">﴿وَإِن يَتَوَلَّوۡاْ﴾</span>: يُعْرِضُوا، أو يَسْتمِرُّوا على حالِهم.</p><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: يَلي أمورَهم وينفَعُهم.</p><p><span class="qpc-hafs">﴿وَلَا نَصِيرࣲ﴾</span>: ولا ناصرٍ يَدْفَعُ عنهم ما هم فيه.</p></div>"
  9,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰهَدَ ٱللَّهَ﴾</span>: قَطَعَ على نفسِه العهدَ مع اللهِ.</p></div>"
  9,76,""
  9,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَعۡقَبَهُمۡ نِفَاقࣰا﴾</span>: فأَوْرَثَهم اللهُ جزاءَ صنيعِهم زيادةً في نفاقِهم.</p></div>"
  9,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِرَّهُمۡ﴾</span>: ما انطَوتْ عليه نفوسُهم من النِّفاق.</p><p><span class="qpc-hafs">﴿وَنَجۡوَىٰهُمۡ﴾</span>: ما يتحَدَّثون به بينهَم من الكَيْدِ والمَكْر.</p></div>"
  9,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلۡمِزُونَ ٱلۡمُطَّوِّعِينَ﴾</span>: يَعِيبُون المتصدِّقين ويَطْعَنُون في إخلاصِهم.</p><p><span class="qpc-hafs">﴿جُهۡدَهُمۡ﴾</span>: طاقَتَهم وما تَبْلُغُه قُوَّتُهم.</p></div>"
  9,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبۡعِينَ مَرَّةࣰ﴾</span>: أي: مهما كَثُرَ استغفارُك لهم وتكرَّر.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوَفِّقُ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقِينَ﴾</span>: الخارجين عن دينِ الله.</p></div>"
  9,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُخَلَّفُونَ﴾</span>: الذين تخلَّفُوا عن الجهادِ في غزوةِ «تبوكَ».</p><p><span class="qpc-hafs">﴿بِمَقۡعَدِهِمۡ﴾</span>: أي: بقُعودِهم.</p><p><span class="qpc-hafs">﴿خِلَـٰفَ رَسُولِ ٱللَّهِ﴾</span>: مخالِفِين رسولَ الله ﷺ.</p><p><span class="qpc-hafs">﴿لَا تَنفِرُواْ﴾</span>: لا تَخْرُجُوا إلى الجهادِ.</p></div>"
  9,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَلِيلࣰا﴾</span>: في الدنيا.</p><p><span class="qpc-hafs">﴿كَثِيرࣰا﴾</span>: في الآخرةِ.</p></div>"
  9,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلَ مَرَّةࣲ﴾</span>: هي غزوةُ «تبوكَ».</p><p><span class="qpc-hafs">﴿ٱلۡخَـٰلِفِينَ﴾</span>: المتخلِّفين عن الجهادِ كالنِّساءِ والصِّبيانِ.</p></div>"
  9,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَقُمۡ عَلَىٰ قَبۡرِهِۦٓ﴾</span>: لأجلِ الدَّفْنِ، أو الزيارةِ، أو الدعاءِ له.</p></div>"
  9,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يُعَذِّبَهُم بِهَا﴾</span>: بما يَلْقَون من التعب في جَمْعِها، وبالمصائبِ التي تقعُ فيها.</p><p><span class="qpc-hafs">﴿وَتَزۡهَقَ﴾</span>: تَخْرُجَ.</p></div>"
  9,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلطَّوۡلِ﴾</span>: أصحابُ الغِنى والمقدرةِ على الجهادِ.</p><p><span class="qpc-hafs">﴿ذَرۡنَا﴾</span>: اتْرُكْنا.</p></div>"
  9,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَوَالِفِ﴾</span>: جَمعُ خالِفة، ويقال للمرأةِ والرجل، والمرادُ: النِّساءُ اللاتي تخلَّفْنَ في البيوتِ، أو الرجالُ العاجزون عن القتال.</p><p><span class="qpc-hafs">﴿وَطُبِعَ﴾</span>: ختمَ اللهُ.</p></div>"
  9,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَيۡرَ ٰ⁠تُ﴾</span>: في الدنيا والآخرةِ.</p></div>"
  9,89,""
  9,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُعَذِّرُونَ﴾</span>: المعتذرون بأعذارٍ كاذبةٍ عن عدمِ الخروجِ للغَزْوِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَعۡرَابِ﴾</span>: سُكّانِ الباديةِ.</p><p><span class="qpc-hafs">﴿وَقَعَدَ﴾</span>: عن الغزوِ لغيرِ عُذْرٍ.</p></div>"
  9,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَجٌ﴾</span>: إثمٌ.</p><p><span class="qpc-hafs">﴿نَصَحُواْ﴾</span>: أخلَصُوا.</p><p><span class="qpc-hafs">﴿مِن سَبِيلࣲ﴾</span>: من طريقٍ للمؤاخذةِ.</p></div>"
  9,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَحۡمِلَهُمۡ﴾</span>: على ما يَرْكَبون عليه في الغَزْو.</p><p><span class="qpc-hafs">﴿تَوَلَّواْ﴾</span>: انْصَرَفُوا مِن عندِك.</p><p><span class="qpc-hafs">﴿حَزَنًا﴾</span>: أسَفًا على ما فاتَهم من شَرَفِ الجهادِ وثوابِه.</p></div>"
  9,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّبِيلُ﴾</span>: طريقُ العقوبةِ والمؤاخَذَةِ.</p></div>"
  9,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذَا رَجَعۡتُمۡ إِلَيۡهِمۡ﴾</span>: من الغَزْوِ.</p><p><span class="qpc-hafs">﴿لَن نُّؤۡمِنَ لَكُمۡ﴾</span>: لن نُصَدِّقَكم.</p></div>"
  9,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذَا ٱنقَلَبۡتُمۡ إِلَيۡهِمۡ﴾</span>: رَجَعْتُم إليهم من الغَزْو.</p><p><span class="qpc-hafs">﴿لِتُعۡرِضُواْ عَنۡهُمۡ﴾</span>: لتَتْرُكُوهم وتَصْفَحُوا عنهم.</p><p><span class="qpc-hafs">﴿رِجۡسࣱ﴾</span>: خبثاءُ في بَواطِنِهم واعتقاداتِهم.</p><p><span class="qpc-hafs">﴿وَمَأۡوَىٰهُمۡ﴾</span>: مصيرُهم.</p></div>"
  9,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقِينَ﴾</span>: الخارجين عن دينِ اللهِ.</p></div>"
  9,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَعۡرَابُ﴾</span>: سُكّانُ الباديةِ.</p><p><span class="qpc-hafs">﴿وَأَجۡدَرُ﴾</span>: وأحَقُّ.</p></div>"
  9,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡرَمࣰا﴾</span>: غَرامةً وخَسارةً.</p><p><span class="qpc-hafs">﴿وَيَتَرَبَّصُ﴾</span>: ينتظرُ.</p><p><span class="qpc-hafs">﴿ٱلدَّوَآئِرَ﴾</span>: جَمْعُ دائرةٍ، وهي: تَقَلُّباتُ الدَّهْرِ ومصائبُه.</p><p><span class="qpc-hafs">﴿ٱلسَّوۡءِ﴾</span>: كلُّ ما يسوءُ ويَضُرُّ.</p></div>"
  9,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَتَّخِذُ مَا يُنفِقُ﴾</span>: ويحتسِبُ ما ينفقُه في سبيلِ اللهِ.</p><p><span class="qpc-hafs">﴿قُرُبَـٰتٍ عِندَ ٱللَّهِ﴾</span>: جَمْعُ قُرْبَةٍ، وهي: ما يُتَقَرَّبُ به إلى اللهِ تعالى.</p><p><span class="qpc-hafs">﴿وَصَلَوَ ٰ⁠تِ ٱلرَّسُولِ﴾</span>: جَمْعُ صلاةٍ، وهي هنا: الدعاُء، أي: ويَجْعَلُ إنفاقَه في سبيلِ اللهِ وسيلةً إلى دعاءِ الرسولِ ﷺ له.</p></div>"
  9,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُهَـٰجِرِينَ﴾</span>: الذين هَجَرُوا قومَهم، وانتقلُوا من بلدِ الفتنةِ إلى دارِ الإسلامِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَنصَارِ﴾</span>: الذين نصرُوا النبي ﷺ، وآوَوا المهاجرين.</p><p><span class="qpc-hafs">﴿بِإِحۡسَـٰنࣲ﴾</span>: في الاعتقادِ والأقوالِ والأعمالِ.</p><p><span class="qpc-hafs">﴿تَحۡتَهَا﴾</span>: تحتَ قصورِها وأشجارِها.</p></div>"
  9,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرَدُواْ عَلَى ٱلنِّفَاقِ﴾</span>: مَهَرُوا فيه واستمَرُّوا عليه.</p><p><span class="qpc-hafs">﴿سَنُعَذِّبُهُم مَّرَّتَيۡنِ﴾</span>: الأولى: في الدنيا بفضيحتِهم، أو بأنواعِ المكارِهِ التي تنالُهم، والثانية: بعذابِ القبرِ.</p><p><span class="qpc-hafs">﴿عَذَابٍ عَظِيمࣲ﴾</span>: نارِ جهنمَ.</p></div>"
  9,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَمَلࣰا صَـٰلِحࣰا﴾</span>: ما سَبَقَ لهم من الجهادِ مع توبتِهم.</p><p><span class="qpc-hafs">﴿وَءَاخَرَ سَيِّئًا﴾</span>: تَخَلُّفَهم عن غزوةِ «تبوكَ».</p></div>"
  9,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُطَهِّرُهُمۡ﴾</span>: تُزيلُ بها أثَرَ ذنوبِهم.</p><p><span class="qpc-hafs">﴿وَتُزَكِّيهِم بِهَا﴾</span>: تُنَمِّي بها حَسَناتِهم وترفَعُهم إلى منازلِ المُخْلَصِين.</p><p><span class="qpc-hafs">﴿وَصَلِّ عَلَيۡهِمۡ﴾</span>: ادْعُ لهم واستغفِرْ.</p><p><span class="qpc-hafs">﴿سَكَنࣱ لَّهُمۡ﴾</span>: سكينةٌ لنفوسِهم وطُمَأنينةٌ لقلوبِهم.</p></div>"
  9,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَأۡخُذُ ٱلصَّدَقَـٰتِ﴾</span>: يَقْبَلُها ويُثيبُ عليها.</p></div>"
  9,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسَتُرَدُّونَ﴾</span>: ستُرْجَعُون يومَ القيامةِ.</p></div>"
  9,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُرۡجَوۡنَ لِأَمۡرِ ٱللَّهِ﴾</span>: مُؤَخَّرون لحُكمِ اللهِ فيهم.</p></div>"
  9,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِرَارࣰا﴾</span>: لأجل الضَّرَر بِالمؤمنين.</p><p><span class="qpc-hafs">﴿وَإِرۡصَادࣰا﴾</span>: انتظارًا وإعدادًا.</p><p><span class="qpc-hafs">﴿لِّمَنۡ حَارَبَ ٱللَّهَ وَرَسُولَهُۥ﴾</span>: هو أبو عامرٍ الفاسقُ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: أي: من قَبْلِ بناءِ مسجدِ الضِّرارِ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الخيرَ والإحسانَ إلى المسلمين.</p></div>"
  9,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَقُمۡ فِيهِ﴾</span>: أي للصَّلاةِ في مَسْجدِ الضِّرارِ.</p><p><span class="qpc-hafs">﴿لَّمَسۡجِدٌ أُسِّسَ عَلَى ٱلتَّقۡوَىٰ﴾</span>: هو مَسْجدُ قُباءٍ.</p><p><span class="qpc-hafs">﴿يُحِبُّونَ أَن يَتَطَهَّرُواْ﴾</span>: طهارةً حسِّيةً من النجاساتِ، ومعنويةً من الذُّنوبِ والمعاصي.</p></div>"
  9,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرِضۡوَ ٰ⁠نٍ﴾</span>: ورجاءِ مَرْضاةِ اللهِ.</p><p><span class="qpc-hafs">﴿عَلَىٰ شَفَا جُرُفٍ﴾</span>: على طَرَفِ حُفْرَةٍ، أو مكانٍ يَجْرُفُه الماءُ.</p><p><span class="qpc-hafs">﴿هَارࣲ﴾</span>: مُشْرِفٍ على السُّقوط.</p><p><span class="qpc-hafs">﴿فَٱنۡهَارَ بِهِۦ﴾</span>: فسَقَطَ المكانُ بالبُنيانِ مع بانيه.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوَفِّقُ.</p></div>"
  9,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُنۡيَـٰنُهُمُ﴾</span>: مسجدُ الضِّرارِ.</p><p><span class="qpc-hafs">﴿رِيبَةࣰ فِي قُلُوبِهِمۡ﴾</span>: شَكًّا ونفاقًا راسخًا في قلوبِهم.</p><p><span class="qpc-hafs">﴿تَقَطَّعَ قُلُوبُهُمۡ﴾</span>: تتقَطَّعَ قلوبُهم بَمْوتِهم، فالنِّفاقُ ملازمٌ لهم ماداموا أحياءً.</p></div>"
  9,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسۡتَبۡشِرُواْ﴾</span>: أظْهِرُوا السُّرورَ.</p></div>"
  9,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّـٰٓئِحُونَ﴾</span>: الصّائمون.</p></div>"
  9,113,""
  9,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّوۡعِدَةࣲ وَعَدَهَآ إِيَّاهُ﴾</span>: وهي الاستغفارُ له.</p><p><span class="qpc-hafs">﴿لَأَوَّ ٰ⁠هٌ﴾</span>: كثيرُ التضرُّعِ إلى اللهِ.</p><p><span class="qpc-hafs">﴿حَلِيمࣱ﴾</span>: صَبُورٌ على الأذى، كثيرُ الصَّفْحِ عَمَّن نالَه بمَكْروه.</p></div>"
  9,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يَتَّقُونَ﴾</span>: ما يَجِبُ عليهم اتقاؤُه من المُحَرَّماتِ.</p></div>"
  9,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: يَتَوَلّى أمورَكم وينفَعُكم.</p><p><span class="qpc-hafs">﴿وَلَا نَصِيرࣲ﴾</span>: يَنْصُرُكم ويَدْفَعُ عنكم ما أنتم فيه.</p></div>"
  9,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَاعَةِ ٱلۡعُسۡرَةِ﴾</span>: وقتِ الشِّدةِ، وهي غزوةُ «تبوكَ».</p><p><span class="qpc-hafs">﴿يَزِيغُ قُلُوبُ﴾</span>: تميلُ إلى التخَلُّفِ عن الجهادِ.</p><p><span class="qpc-hafs">﴿بِهِمۡ رَءُوفࣱ﴾</span>: كثيرُ الرأفةِ والرحمةِ بهم في عاجِلِهم وآجِلِهم.</p></div>"
  9,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَلَى ٱلثَّلَـٰثَةِ﴾</span>: أي: وتابَ على الثلاثةِ، وهم: كَعْبُ بنُ مالك، وهِلالُ ابنُ أميةَ، ومُرارةُ بنُ الرَّبِيعِ.</p><p><span class="qpc-hafs">﴿خُلِّفُواْ﴾</span>: تَخَلَّفوا عن الجهادِ في غزوةِ «تبوكَ».</p><p><span class="qpc-hafs">﴿بِمَا رَحُبَتۡ﴾</span>: أي: مع سَعَتِها؛ ندمًا بسبب تَخَلُّفِهم عن الغزوِ.</p><p><span class="qpc-hafs">﴿وَظَنُّوٓاْ﴾</span>: أيقنوا.</p><p><span class="qpc-hafs">﴿ثُمَّ تَابَ عَلَيۡهِمۡ﴾</span>: وفَّقهم اللهُ للتوبةِ.</p><p><span class="qpc-hafs">﴿لِيَتُوبُوٓاْ﴾</span>: ليستمِرُّوا على التوبةِ ويثبتُوا عليها.</p></div>"
  9,119,""
  9,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا كَانَ لِأَهۡلِ ٱلۡمَدِينَةِ﴾</span>: أي: ليس لهم.</p><p><span class="qpc-hafs">﴿وَلَا يَرۡغَبُواْ بِأَنفُسِهِمۡ عَن نَّفۡسِهِۦ﴾</span>: لا يَرْضَوْا لها بالراحة، ورسولُ الله ﷺ في تعبٍ ومشقةٍ.</p><p><span class="qpc-hafs">﴿ظَمَأࣱ﴾</span>: عَطَشٌ.</p><p><span class="qpc-hafs">﴿وَلَا نَصَبࣱ﴾</span>: تَعَبٌ.</p><p><span class="qpc-hafs">﴿وَلَا مَخۡمَصَةࣱ﴾</span>: جُوعٌ شديدٌ.</p><p><span class="qpc-hafs">﴿مَوۡطِئࣰا﴾</span>: مكانًا.</p><p><span class="qpc-hafs">﴿يَغِيظُ﴾</span>: يُغْضِبُ.</p><p><span class="qpc-hafs">﴿نَّيۡلًا﴾</span>: بقَتْلٍ، أو أسْرٍ، أو جِراحَةٍ، أو غنيمةٍ ونحوِها.</p></div>"
  9,121,""
  9,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَا﴾</span>: فهَلّا.</p><p><span class="qpc-hafs">﴿نَفَرَ﴾</span>: خَرَج للغزوِ والجهادِ.</p></div>"
  9,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلُونَكُم﴾</span>: يجاوِرُونكم.</p><p><span class="qpc-hafs">﴿غِلۡظَةࣰ﴾</span>: شدَّةً.</p></div>"
  9,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمِنۡهُم﴾</span>: فمِنَ المنافقين.</p><p><span class="qpc-hafs">﴿يَسۡتَبۡشِرُونَ﴾</span>: يَفْرحُون بفضلِ اللهِ عليهم.</p></div>"
  9,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرَضࣱ﴾</span>: شكٌّ ونِفاقٌ.</p><p><span class="qpc-hafs">﴿رِجۡسًا إِلَىٰ رِجۡسِهِمۡ﴾</span>: نِفاقًا وكُفْرًا إلى كُفْرِهم.</p></div>"
  9,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُفۡتَنُونَ﴾</span>: يُبْتلَوْن بأنواعِ البَلاءِ.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَذَّكَّرُونَ﴾</span>: لا يَتَّعِظُون بما نَزَلَ بهم.</p></div>"
  9,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّظَرَ بَعۡضُهُمۡ إِلَىٰ بَعۡضٍ﴾</span>: تغامَزَ المنافقون بالعيونِ؛ إنكارًا لنزولِ السورةِ، وغيظًا لما فيها من بيانِ عيوبِهم.</p><p><span class="qpc-hafs">﴿هَلۡ يَرَىٰكُم مِّنۡ أَحَدࣲ﴾</span>: يُريدون الهروبَ من مجلسِ النبيِّ ﷺ.</p><p><span class="qpc-hafs">﴿صَرَفَ ٱللَّهُ قُلُوبَهُم﴾</span>: عن الإيمانِ.</p><p><span class="qpc-hafs">﴿لَّا يَفۡقَهُونَ﴾</span>: لا يَفْهَمونَ لعَدَمِ تَدَبُّرِهم وإنصافِهم.</p></div>"
  9,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ أَنفُسِكُمۡ﴾</span>: من قومِكم.</p><p><span class="qpc-hafs">﴿عَزِيزٌ عَلَيۡهِ﴾</span>: ما تَلْقَوْن من المكروهِ والمشقَّةِ.</p><p><span class="qpc-hafs">﴿رَءُوفࣱ﴾</span>: عظيمُ الرحمةِ شفيقٌ.</p></div>"
  9,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا.</p><p><span class="qpc-hafs">﴿حَسۡبِيَ ٱللَّهُ﴾</span>: يكفيني اللهُ.</p><p><span class="qpc-hafs">﴿عَلَيۡهِ تَوَكَّلۡتُ﴾</span>: اعتمَدْتُ عليه وفوَّضْتُ جميعَ أموري إليه.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: سريرِ المُلك الذي استوى عليه الرحمنُ، وتحمِلُه الملائكةُ، وهو أعظمُ المخلوقاتِ، وهو سَقْفُ الجنةِ.</p></div>"
