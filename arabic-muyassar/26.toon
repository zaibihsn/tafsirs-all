quran[227]{c,v,t}:
  26,1,""
  26,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبِ﴾</span>: القرآنِ.</p></div>"
  26,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَـٰخِعࣱ نَّفۡسَكَ﴾</span>: مُهْلِكُها غَمًّا وحُزْنًا.</p></div>"
  26,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: مُعْجِزَةً.</p><p><span class="qpc-hafs">﴿خَـٰضِعِينَ﴾</span>: مُنْقادِينَ بالكُرْهِ مِنهُم.</p></div>"
  26,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُحۡدَثٍ﴾</span>: أي: مُجَدَّدٍ إنْزالُه.</p></div>"
  26,6,""
  26,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَرَوۡاْ﴾</span>: أوَلَم يَنْظُرُوا.</p><p><span class="qpc-hafs">﴿زَوۡجࣲ كَرِيمٍ﴾</span>: صِنْفٍ حَسَنٍ كَثِيرِ النَّفْعِ.</p></div>"
  26,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: لَدَلالةً واضِحَةً.</p></div>"
  26,9,""
  26,10,""
  26,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَا يَتَّقُونَ﴾</span>: ألا يَخافُونَ عِقابَ اللهِ تعالى؟</p></div>"
  26,12,""
  26,13,""
  26,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَنۢبࣱ﴾</span>: وهو قَتْلُ القِبْطِيِّ.</p></div>"
  26,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بِمُعْجزاتِنا وحُجَجِنا.</p><p><span class="qpc-hafs">﴿إِنَّا مَعَكُم﴾</span>: أي: بالعِلْمِ والحِفْظِ والنُّصْرَةِ.</p></div>"
  26,16,""
  26,17,""
  26,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ نُرَبِّكَ﴾</span>: ألم نَرْعَكَ.</p><p><span class="qpc-hafs">﴿وَلِيدࣰا﴾</span>: صَغِيرًا.</p></div>"
  26,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعۡلَتَكَ﴾</span>: أي: قَتْلَ القِبْطِيِّ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡكَـٰفِرِينَ﴾</span>: أي: من الجاحِدِينَ لِنِعْمَتِي.</p></div>"
  26,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلضَّآلِّينَ﴾</span>: مِنَ المُخْطِئِينَ لا المتعَمِّدِينَ.</p></div>"
  26,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُكۡمࣰا﴾</span>: أي: نُبُوَّةً وحِكْمَةً.</p></div>"
  26,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمُنُّهَا عَلَيَّ﴾</span>: تَعُدُّها نِعْمَةً مِنكَ عليّ.</p><p><span class="qpc-hafs">﴿عَبَّدتَّ﴾</span>: جَعَلْتَهُم عَبِيدًا تَذْبَحُ مَن تَشاءُ وتَتْرُكُ مَن تَشاءُ مِن أبْنائِهِم وتَسْتَبْقِي نِساءَهُم لِلْخِدْمَةِ والامْتِهانِ.</p></div>"
  26,23,""
  26,24,""
  26,25,""
  26,26,""
  26,27,""
  26,28,""
  26,29,""
  26,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِشَيۡءࣲ مُّبِينࣲ﴾</span>: أي: بِبُرْهانٍ قاطِعٍ.</p></div>"
  26,31,""
  26,32,""
  26,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيۡضَآءُ﴾</span>: أي: مِن غَيرِ مَرَضٍ ولا بَرَصٍ.</p></div>"
  26,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلۡمَلَإِ﴾</span>: لأشْرافِ قَوْمِهِ.</p><p><span class="qpc-hafs">﴿لَسَـٰحِرٌ عَلِيمࣱ﴾</span>: أي: ساحِرٌ ماهِرٌ.</p></div>"
  26,35,""
  26,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡجِهۡ﴾</span>: أخِّرْهُ.</p><p><span class="qpc-hafs">﴿ٱلۡمَدَآئِنِ﴾</span>: المُدُنِ.</p><p><span class="qpc-hafs">﴿حَـٰشِرِينَ﴾</span>: جامِعِينَ للسَّحَرةِ.</p></div>"
  26,37,""
  26,38,""
  26,39,""
  26,40,""
  26,41,""
  26,42,""
  26,43,""
  26,44,""
  26,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلۡقَفُ﴾</span>: تَبْتَلِعُ بِسُرْعَةٍ.</p><p><span class="qpc-hafs">﴿مَا يَأۡفِكُونَ﴾</span>: ما يَكْذِبُونَهُ ويُمَوِّهُونَهُ.</p></div>"
  26,46,""
  26,47,""
  26,48,""
  26,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ خِلَـٰفࣲ﴾</span>: أي: بِقَطْعِ اليَدِ اليُمْنى والرِّجْلِ اليُسْرى أو عَكْسِ ذَلِك.</p><p><span class="qpc-hafs">﴿وَلَأُصَلِّبَنَّكُمۡ﴾</span>: ولَأُبالِغَنَّ في شَدِّ أطْرافِكُم ورَبْطِ أجْسادِكُم على جُذُوعِ النَّخْلِ.</p></div>"
  26,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا ضَيۡرَ﴾</span>: لا ضَرَرَ عَلَينا فِيما يُصِيبُنا.</p><p><span class="qpc-hafs">﴿مُنقَلِبُونَ﴾</span>: راجِعُونَ.</p></div>"
  26,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلَ ٱلۡمُؤۡمِنِينَ﴾</span>: أي: مِن قَومِ فِرْعَونَ.</p></div>"
  26,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡ أَسۡرِ بِعِبَادِيٓ﴾</span>: أي: اخْرُجْ بِهِم لَيْلًا.</p><p><span class="qpc-hafs">﴿مُّتَّبَعُونَ﴾</span>: يَتَّبِعُكُم فِرْعَونُ وجُنُودُه.</p></div>"
  26,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَدَآئِنِ﴾</span>: المُدُنِ.</p><p><span class="qpc-hafs">﴿حَـٰشِرِينَ﴾</span>: جامِعِينَ لِلْجَيشِ.</p></div>"
  26,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَشِرۡذِمَةࣱ﴾</span>: لَطائِفَةٌ حَقِيرَةٌ قَلِيلةُ العَدَدِ.</p></div>"
  26,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَا لَغَآئِظُونَ﴾</span>: لَمُغْضِبُونا بِخُرُوجِهِم مِن غَيْرِ إذْنٍ مِنّا.</p></div>"
  26,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَـٰذِرُونَ﴾</span>: مُتَيَقِّظُونَ.</p></div>"
  26,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتࣲ﴾</span>: بَساتِينَ.</p></div>"
  26,58,""
  26,59,""
  26,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّشۡرِقِينَ﴾</span>: وقْتَ شُرُوقِ الشَّمْسِ.</p></div>"
  26,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَمۡعَانِ﴾</span>: جَمْعُ مُوسى وهُم بنُو إسْرائيلَ، وجَمْعُ فِرْعَونَ وهم القِبْطُ.</p><p><span class="qpc-hafs">﴿لَمُدۡرَكُونَ﴾</span>: لَمُلحَقُون من قِبَلِ فِرْعَونَ وجُنُودِهِ.</p></div>"
  26,62,""
  26,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱنفَلَقَ﴾</span>: أي: انْشَقَّ البَحْرُ إلى اثْنَي عَشْرَ طَرِيقًا.</p><p><span class="qpc-hafs">﴿فِرۡقࣲ﴾</span>: قِطْعةٍ من البحْرِ مُرْتَفِعَةٍ.</p><p><span class="qpc-hafs">﴿كَٱلطَّوۡدِ﴾</span>: كالجَبَلِ المُتَطاوِلِ في السَّماءِ.</p></div>"
  26,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَزۡلَفۡنَا﴾</span>: وقَرَّبْنا.</p><p><span class="qpc-hafs">﴿ثَمَّ﴾</span>: هُناك.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔاخَرِينَ﴾</span>: وهم فِرْعَونُ وقَوْمُه.</p></div>"
  26,65,""
  26,66,""
  26,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: لَعِبرةً عَجِيبةً.</p></div>"
  26,68,""
  26,69,""
  26,70,""
  26,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهَا عَـٰكِفِينَ﴾</span>: على عِبادتِها مُقِيمِينَ على الدَّوامِ.</p></div>"
  26,72,""
  26,73,""
  26,74,""
  26,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَرَءَيۡتُم﴾</span>: هَل تأمَّلْتُم ما أنْتُم عَلَيه؟</p></div>"
  26,76,""
  26,77,""
  26,78,""
  26,79,""
  26,80,""
  26,81,""
  26,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلدِّينِ﴾</span>: يومَ الجَزاءِ.</p></div>"
  26,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُكۡمࣰا﴾</span>: عِلْمًا وفَهْمًا.</p></div>"
  26,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِسَانَ صِدۡقࣲ﴾</span>: ثَناءً حَسَنًا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡـَٔاخِرِينَ﴾</span>: أي: في الَّذينَ يأتُونَ بَعْدِي إلى يومِ القِيامَةِ.</p></div>"
  26,85,""
  26,86,""
  26,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُخۡزِنِي﴾</span>: ولا تَفْضَحْنِي.</p></div>"
  26,88,""
  26,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِقَلۡبࣲ سَلِيمࣲ﴾</span>: أي: مِنَ النِّفاقِ والكُفْرِ.</p></div>"
  26,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُزۡلِفَتِ﴾</span>: قُرِّبَتْ.</p></div>"
  26,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبُرِّزَتِ﴾</span>: أُظْهِرَتْ.</p><p><span class="qpc-hafs">﴿لِلۡغَاوِينَ﴾</span>: للضّالِينَ عَن طَرِيقِ الهِدايةِ.</p></div>"
  26,92,""
  26,93,""
  26,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكُبۡكِبُواْ فِيهَا﴾</span>: أُلْقُوا في جَهَنَّمَ على وُجُوهِهِم مرَّةً بَعْدَ مَرَّةٍ إلى أنِ اسْتَقرُّوا في قَعْرِها.</p></div>"
  26,95,""
  26,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡتَصِمُونَ﴾</span>: يَتَنازَعُون.</p></div>"
  26,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن كُنَّا﴾</span>: إنَّنا كُنّا.</p></div>"
  26,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُسَوِّيكُم بِرَبِّ ٱلۡعَـٰلَمِينَ﴾</span>: نَجْعَلُكُم مِثْلَ رَبِّ العالَمِينَ.</p></div>"
  26,99,""
  26,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَـٰفِعِينَ﴾</span>: فَيُخَلِّصُونا مِنَ العَذابِ.</p></div>"
  26,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: قَرِيبٍ ومُشْفِقٍ.</p></div>"
  26,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّةࣰ﴾</span>: رَجْعَةً إلى الدُّنيا.</p></div>"
  26,103,""
  26,104,""
  26,105,""
  26,106,""
  26,107,""
  26,108,""
  26,109,""
  26,110,""
  26,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡذَلُونَ﴾</span>: أي: أسافلُ النّاسِ وأَراذِلُهم.</p></div>"
  26,112,""
  26,113,""
  26,114,""
  26,115,""
  26,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَرۡجُومِينَ﴾</span>: مِنَ المقْتُولِينَ رَمْيًا بالحِجارَةِ.</p></div>"
  26,117,""
  26,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱفۡتَحۡ﴾</span>: فاحْكُمْ.</p></div>"
  26,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَشۡحُونِ﴾</span>: المَمْلُوءِ بالنّاسِ والدَّوابِّ والمتاعِ.</p></div>"
  26,120,""
  26,121,""
  26,122,""
  26,123,""
  26,124,""
  26,125,""
  26,126,""
  26,127,""
  26,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِيعٍ﴾</span>: مكانٍ مُرْتَفِعٍ.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: بِناءً شامِخًا.</p></div>"
  26,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَصَانِعَ﴾</span>: حُصُونًا أو قُصُورًا.</p><p><span class="qpc-hafs">﴿تَخۡلُدُونَ﴾</span>: أي: تَبْقَونَ في الدُّنيا ولا تَمُوتُونَ.</p></div>"
  26,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَطَشۡتُم﴾</span>: أخَذْتُم بِعُنْفٍ.</p><p><span class="qpc-hafs">﴿جَبَّارِينَ﴾</span>: قاهِرِينَ ظالِمِين.</p></div>"
  26,131,""
  26,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَدَّكُم﴾</span>: أنْعَمَ عليكُم وأَعْطاكُم.</p></div>"
  26,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَنۡعَـٰمࣲ﴾</span>: مِنَ الإبِلِ والبَقَرِ والغَنَمِ.</p></div>"
  26,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَنَّـٰتࣲ﴾</span>: حَدائِقَ وبَساتِينَ.</p></div>"
  26,135,""
  26,136,""
  26,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنۡ هَـٰذَآ﴾</span>: ما هَذا.</p><p><span class="qpc-hafs">﴿خُلُقُ ٱلۡأَوَّلِينَ﴾</span>: دِينُ الأوَّلِينَ وعاداتُهُم.</p></div>"
  26,138,""
  26,139,""
  26,140,""
  26,141,""
  26,142,""
  26,143,""
  26,144,""
  26,145,""
  26,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا هَـٰهُنَآ﴾</span>: أي: في الدُّنيا.</p></div>"
  26,147,""
  26,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَلۡعُهَا﴾</span>: ثَمَرُها.</p><p><span class="qpc-hafs">﴿هَضِيمࣱ﴾</span>: مُنْكَسِرٌ مِن لِينِهِ ورُطُوبَتِه.</p></div>"
  26,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰرِهِينَ﴾</span>: ماهِرِين بنَحْتِها.</p></div>"
  26,150,""
  26,151,""
  26,152,""
  26,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُسَحَّرِينَ﴾</span>: مِنَ المغْلُوبِ على عُقُولِهِم بِكَثْرَةِ السِّحرِ.</p></div>"
  26,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةٍ﴾</span>: بِحُجَّةٍ واضِحَةٍ.</p></div>"
  26,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهَا شِرۡبࣱ﴾</span>: لها نَصِيبٌ مِنَ الماءِ.</p></div>"
  26,156,""
  26,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُوهَا﴾</span>: فَنَحَرُوها.</p></div>"
  26,158,""
  26,159,""
  26,160,""
  26,161,""
  26,162,""
  26,163,""
  26,164,""
  26,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَأۡتُونَ ٱلذُّكۡرَانَ﴾</span>: أتَنْكِحُونَ الرِّجالَ؟</p></div>"
  26,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَذَرُونَ﴾</span>: وتَتْرُكُونَ.</p><p><span class="qpc-hafs">﴿عَادُونَ﴾</span>: مُتَجاوِزُونَ ما أباحَهُ اللهُ لَكُم مِنَ الحَلالِ إلى الحَرامِ.</p></div>"
  26,167,""
  26,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنَ ٱلۡقَالِينَ﴾</span>: مِنَ المُبْغِضِينَ أشَدَّ البُغْضِ.</p></div>"
  26,169,""
  26,170,""
  26,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡغَـٰبِرِينَ﴾</span>: في الباقِينَ في العذابِ والهلاكِ.</p></div>"
  26,172,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَمَّرۡنَا﴾</span>: أهْلَكْنا.</p></div>"
  26,173,""
  26,174,""
  26,175,""
  26,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ لۡـَٔيۡكَةِ﴾</span>: أصْحابُ الشَّجَرِ المُلْتَفِّ.</p></div>"
  26,177,""
  26,178,""
  26,179,""
  26,180,""
  26,181,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُخۡسِرِينَ﴾</span>: مِنَ النّاقِصِينَ للحُقُوقِ بالتَّطفِيفِ.</p></div>"
  26,182,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطَاسِ﴾</span>: بالميزانِ.</p></div>"
  26,183,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَبۡخَسُواْ﴾</span>: ولا تَنْقُصُوا.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡاْ﴾</span>: ولا تُفْسِدُوا أشَدَّ الإفْسادِ.</p></div>"
  26,184,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِينَ﴾</span>: والخَلائِقَ من الأُمَمِ المتقدِّمةِ.</p></div>"
  26,185,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُسَحَّرِينَ﴾</span>: مِنَ المغلُوبِ على عُقُولِهِم بِكَثْرَةِ السِّحْرِ.</p></div>"
  26,186,""
  26,187,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِسَفࣰا﴾</span>: قِطَعَ عَذابٍ.</p></div>"
  26,188,""
  26,189,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمِ ٱلظُّلَّةِ﴾</span>: أي: أظَلَّتْهُم سَحابَةٌ، ثُمَّ أمْطَرَتْهُم نارًَا.</p></div>"
  26,190,""
  26,191,""
  26,192,""
  26,193,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرُّوحُ ٱلۡأَمِينُ﴾</span>: جِبْرِيلُ عَلَيهِ السَّلامُ.</p></div>"
  26,194,""
  26,195,""
  26,196,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّهُۥ﴾</span>: وإنَّ ذِكْرَ هَذا القُرآنِ.</p><p><span class="qpc-hafs">﴿زُبُرِ ٱلۡأَوَّلِينَ﴾</span>: كُتُبِ الرُّسُلِ السّابِقِينَ.</p></div>"
  26,197,""
  26,198,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَعۡجَمِينَ﴾</span>: الَّذِينَ لا يتكَلَّمُونَ باللغةِ العَربيةِ.</p></div>"
  26,199,""
  26,200,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَكۡنَـٰهُ﴾</span>: أدْخَلْناه.</p></div>"
  26,201,""
  26,202,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأَةً.</p></div>"
  26,203,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنظَرُونَ﴾</span>: مُمْهَلُون لِنُؤمِنَ.</p></div>"
  26,204,""
  26,205,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّتَّعۡنَـٰهُمۡ سِنِينَ﴾</span>: أي: طَوَّلْنا لَهُم أعْمارَهُم.</p></div>"
  26,206,""
  26,207,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَآ أَغۡنَىٰ عَنۡهُم﴾</span>: أي: لم يَنْفَعْهُم.</p></div>"
  26,208,""
  26,209,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرَىٰ﴾</span>: أي: تَذْكِيرٌ وتَنْبِيهٌ.</p></div>"
  26,210,""
  26,211,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يَنۢبَغِي لَهُمۡ﴾</span>: ولا يَصِحُّ مِنهُم.</p></div>"
  26,212,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَعۡزُولُونَ﴾</span>: لمحْجُوُبونَ.</p></div>"
  26,213,""
  26,214,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَشِيرَتَكَ﴾</span>: قَبِيلَتَكَ.</p></div>"
  26,215,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱخۡفِضۡ جَنَاحَكَ﴾</span>: ألِنْ جانِبَكَ وتَواضَعْ.</p></div>"
  26,216,""
  26,217,""
  26,218,""
  26,219,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَقَلُّبَكَ﴾</span>: وتَصرُّفَكَ أو تَقَلُّبَكَ في الرُّكُوعِ والسُّجُودِ والقِيامِ.</p></div>"
  26,220,""
  26,221,""
  26,222,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَّاكٍ﴾</span>: كَذّابٍ.</p><p><span class="qpc-hafs">﴿أَثِيمࣲ﴾</span>: كَثِيرِ الآثامِ.</p></div>"
  26,223,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُلۡقُونَ ٱلسَّمۡعَ﴾</span>: يُلْقُونَ ما سَمِعُوه مِنَ السَّماءِ إلى الكُهّانِ.</p></div>"
  26,224,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَاوُۥنَ﴾</span>: الضّالُّونَ عَنِ الحقِّ.</p></div>"
  26,225,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلِّ وَادࣲ﴾</span>: كلِّ فَنٍّ مِن فُنُونِ الكَذِبِ.</p><p><span class="qpc-hafs">﴿يَهِيمُونَ﴾</span>: يخُوضُونَ.</p></div>"
  26,226,""
  26,227,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنقَلِبُونَ﴾</span>: يَرْجِعُونَ إليهِ.</p></div>"
