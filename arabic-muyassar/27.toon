quran[93]{c,v,t}:
  27,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طسٓ﴾</span>: تَقَدَّمَ الكلامُ على مِثْلِه أوَّلَ سُورَةِ البقرةِ.</p></div>"
  27,2,""
  27,3,""
  27,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يَتَرَدَّدُونَ ويَتَحَيَّرُونَ.</p></div>"
  27,5,""
  27,6,""
  27,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَانَسۡتُ﴾</span>: أبْصَرْتُ ما يُؤْنِسُ.</p><p><span class="qpc-hafs">﴿بِشِهَابࣲ قَبَسࣲ﴾</span>: بِشُعْلَةِ نارٍ مَقْبُوسَةٍ، أي: مأخُوذَةٍ.</p><p><span class="qpc-hafs">﴿تَصۡطَلُونَ﴾</span>: تَسْتَدْفِئُونَ بِها.</p></div>"
  27,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُورِكَ مَن فِي ٱلنَّارِ﴾</span>: أي: إنّ اللهَ باركَ مَن فِي النّارِ ومَن حَولَها مِنَ الملائِكَةِ.</p></div>"
  27,9,""
  27,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَهۡتَزُّ﴾</span>: تَتَحَرَّكُ بخِفَّةٍ.</p><p><span class="qpc-hafs">﴿جَآنࣱّ﴾</span>: حَيَّةٌ خَفِيفَةٌ في سُرْعَةِ حَرَكَتِها.</p><p><span class="qpc-hafs">﴿وَلَّىٰ﴾</span>: هرَبَ.</p><p><span class="qpc-hafs">﴿وَلَمۡ يُعَقِّبۡ﴾</span>: لم يَرْجِعْ.</p></div>"
  27,11,""
  27,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي جَيۡبِكَ﴾</span>: في فَتْحَةِ قَمِيصِكَ الَّتي يُدْخَلُ منها الرَّأسُ.</p><p><span class="qpc-hafs">﴿مِنۡ غَيۡرِ سُوٓءࣲ﴾</span>: مِن غَيرِ بَرَصٍ ولا مَرَضٍ.</p><p><span class="qpc-hafs">﴿فِي تِسۡعِ ءَايَـٰتٍ﴾</span>: وهي: اليدُ، والعَصا، والسِّنونَ، ونَقْصُ الثَّمراتِ، والطُّوفانُ، والجَرادُ، والقُمَّلُ، والضَّفادِعُ، والدَّمُ.</p></div>"
  27,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُبۡصِرَةࣰ﴾</span>: واضِحَةً هادِيةً.</p></div>"
  27,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَحَدُواْ بِهَا﴾</span>: أنْكَرُوها بألْسِنَتِهِم.</p><p><span class="qpc-hafs">﴿وَعُلُوࣰّا﴾</span>: تَرَفُّعًا واسْتِكْبارًا عَنِ الإيمانِ بِها.</p></div>"
  27,15,""
  27,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوَرِثَ سُلَيۡمَـٰنُ دَاوُۥدَ﴾</span>: أي: نُبوَّتَه وعِلْمَه ومُلْكَه.</p><p><span class="qpc-hafs">﴿مَنطِقَ ٱلطَّيۡرِ﴾</span>: فَهْمَ أغْراضِه كلِّها مِن أصْواتِه.</p><p><span class="qpc-hafs">﴿وَأُوتِينَا﴾</span>: وأُعْطِينا.</p></div>"
  27,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحُشِرَ﴾</span>: وجُمِعَ.</p><p><span class="qpc-hafs">﴿فَهُمۡ يُوزَعُونَ﴾</span>: فهم يُكَفُّونَ عَنِ التَّفرُّقِ، فكان على كُلِّ جِنْسٍ مَن يَرُدُّ أوَّلَهم على آخِرِهم كي يقِفُوا ويسِيرُوا مُنْتَظِمِينَ.</p></div>"
  27,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَحۡطِمَنَّكُمۡ﴾</span>: أي: لا تُمَكِّنوهُم مِن قَتْلِكُم وإهْلاكِكُم.</p></div>"
  27,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡزِعۡنِيٓ﴾</span>: ألْهِمْنِي ووَفِّقْنِي.</p></div>"
  27,20,""
  27,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنࣲ مُّبِينࣲ﴾</span>: بِحُجَّةٍ تُبيِّنُ عُذْرَه في غِيابِه.</p></div>"
  27,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحَطتُ﴾</span>: عَلِمْتُ الأمرَ مِن جَميعِ جِهاتِهِ.</p><p><span class="qpc-hafs">﴿وَجِئۡتُكَ﴾</span>: بَلَدٍ باليمنِ سُمِّي باسْمِ «سَبأِ بنِ يَشْجُبَ»،ويقَعُ شَرْقَ صَنْعاء ويُسَمّى الآنَ «مَأْرِبًا».</p></div>"
  27,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَهَا عَرۡشٌ﴾</span>: أي: سَرِيرُ المُلْكِ، تَجْلِسُ عليه لإدارةِ مُلْكِها.</p></div>"
  27,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَصَدَّهُمۡ﴾</span>: فَصَرَفَهُم.</p></div>"
  27,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَبۡءَ﴾</span>: المخْبوُءَ المسْتُورَ.</p></div>"
  27,26,""
  27,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنَنظُرُ﴾</span>: أي: سَنَتَأَمَّلُ.</p></div>"
  27,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّ عَنۡهُمۡ﴾</span>: تَنَحَّ عَنْهُم.</p></div>"
  27,29,""
  27,30,""
  27,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَّا تَعۡلُواْ﴾</span>: ألّا تَتَكَبَّرُوا عليَّ.</p></div>"
  27,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰٓأَيُّهَا ٱلۡمَلَؤُاْ﴾</span>: يا أيُّها الأشْرافُ.</p><p><span class="qpc-hafs">﴿أَفۡتُونِي﴾</span>: أشِيرُوا عَليَّ.</p><p><span class="qpc-hafs">﴿قَاطِعَةً أَمۡرًا﴾</span>: مُبْرِمَةً أمْرًا.</p><p><span class="qpc-hafs">﴿تَشۡهَدُونِ﴾</span>: تَحْضُرُونِ.</p></div>"
  27,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُوْلُواْ بَأۡسࣲ﴾</span>: أصْحابُ نَجْدةٍ وبَلاءٍ في الحرْبِ.</p></div>"
  27,34,""
  27,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنَاظِرَةُۢ﴾</span>: فمُنتَظِرةٌ.</p></div>"
  27,36,""
  27,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا قِبَلَ لَهُم بِهَا﴾</span>: لا طاقَةَ لَهُم بِمُقاوَمَتِها.</p><p><span class="qpc-hafs">﴿صَـٰغِرُونَ﴾</span>: ذَلِيلُونَ مُهانُونَ.</p></div>"
  27,38,""
  27,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِفۡرِيتࣱ﴾</span>: مارِدٌ قويٌّ شَدِيدٌ.</p></div>"
  27,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَرۡتَدَّ﴾</span>: أن يَرْجِعَ.</p><p><span class="qpc-hafs">﴿طَرۡفُكَ﴾</span>: نَظَرُكَ.</p><p><span class="qpc-hafs">﴿لِيَبۡلُوَنِيٓ﴾</span>: لِيَخْتَبِرَنِي.</p><p><span class="qpc-hafs">﴿أَمۡ أَكۡفُرُ﴾</span>: أي: بِتَرْكِ شُكْرِ النِّعْمةِ.</p></div>"
  27,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَكِّرُواْ﴾</span>: غيِّرُوا.</p></div>"
  27,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُوتِينَا ٱلۡعِلۡمَ﴾</span>: وأُعْطِينا العِلْمَ بِاللهِ وبِقُدْرَتِه.</p></div>"
  27,43,""
  27,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّرۡحَ﴾</span>: القَصْرَ.</p><p><span class="qpc-hafs">﴿حَسِبَتۡهُ لُجَّةࣰ﴾</span>: ظنَّتْهُ ماءً تتردَّدُ أمْواجُه.</p><p><span class="qpc-hafs">﴿مُّمَرَّدࣱ﴾</span>: أمْلَسُ.</p><p><span class="qpc-hafs">﴿مِّن قَوَارِيرَ﴾</span>: مِن زُجاجٍ صافٍ شَفّافٍ.</p></div>"
  27,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡتَصِمُونَ﴾</span>: يَتَنازَعُونَ.</p></div>"
  27,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلسَّيِّئَةِ قَبۡلَ ٱلۡحَسَنَةِ﴾</span>: أي: بالكُفْرِ قَبْلَ الإيمانِ.</p></div>"
  27,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱطَّيَّرۡنَا بِكَ﴾</span>: تَشاءَمْنا بِكَ، لأنّنا أُصِبْنا بالشَّدائِدِ.</p><p><span class="qpc-hafs">﴿طَـٰٓئِرُكُمۡ﴾</span>: شُؤْمُكُم.</p><p><span class="qpc-hafs">﴿عِندَ ٱللَّهِ﴾</span>: أي: قَدَّرَهُ اللهُ عَلَيكُم.</p><p><span class="qpc-hafs">﴿تُفۡتَنُونَ﴾</span>: تُمتَحَنُونَ وتُخْتَبرُونَ.</p></div>"
  27,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَهۡطࣲ﴾</span>: رِجالٍ مِن أبْناءِ الأشْرافِ.</p></div>"
  27,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَقَاسَمُواْ بِٱللَّهِ﴾</span>: تحالَفُوا باللهِ.</p><p><span class="qpc-hafs">﴿لَنُبَيِّتَنَّهُۥ﴾</span>: لَنَأْتِيَنَّهُ بَغْتَةً في الليلِ، فَنْقتُلَهُ.</p><p><span class="qpc-hafs">﴿مَا شَهِدۡنَا﴾</span>: ما حَضَرْنا.</p></div>"
  27,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَكَرُواْ﴾</span>: دبَّرُوا الشَّرَّ بِحِيلَةٍ.</p></div>"
  27,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَمَّرۡنَـٰهُمۡ﴾</span>: أهْلكْناهُم.</p></div>"
  27,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَاوِيَةَۢ﴾</span>: خالِيةً خَرِبةً.</p></div>"
  27,53,""
  27,54,""
  27,55,""
  27,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَطَهَّرُونَ﴾</span>: يَتَنَزَّهُونَ مِن إتْيانِ الرِّجالِ.</p></div>"
  27,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡغَـٰبِرِينَ﴾</span>: مِنَ الباقِينَ في العَذابِ والهَلاكِ.</p></div>"
  27,58,""
  27,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡطَفَىٰٓ﴾</span>: اخْتارَ.</p></div>"
  27,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَدَآئِقَ ذَاتَ بَهۡجَةࣲ﴾</span>: بَساتِينَ ذاتَ مَنظَرٍ حَسَنٍ.</p><p><span class="qpc-hafs">﴿يَعۡدِلُونَ﴾</span>: يَنْحَرِفُونَ عَن طَرِيقِ الحقِّ إلى طَرِيقِ الباطِلِ وهو الشِّركُ.</p></div>"
  27,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرَارࣰا﴾</span>: مُسْتَقَرًّا.</p><p><span class="qpc-hafs">﴿خِلَـٰلَهَآ﴾</span>: وسَطَها.</p><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿ٱلۡبَحۡرَيۡنِ﴾</span>: العَذْبِ والمِلْحِ.</p><p><span class="qpc-hafs">﴿حَاجِزًا﴾</span>: فاصِلًا يَمْنَعُ اخْتِلاطَهُما.</p></div>"
  27,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُضۡطَرَّ﴾</span>: الَّذي أصابَه بَلاءٌ وشِدَّةٌ.</p><p><span class="qpc-hafs">﴿خُلَفَآءَ﴾</span>: أي: تَخْلُفُونَ مَن سَبَقَكُم في الأرضِ.</p></div>"
  27,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُشۡرَۢا﴾</span>: تُبَشِّرُ بالمَطَرِ.</p></div>"
  27,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡدَؤُاْ ٱلۡخَلۡقَ﴾</span>: يُنْشِئُه.</p><p><span class="qpc-hafs">﴿بُرۡهَـٰنَكُمۡ﴾</span>: حُجَّتَكُم.</p></div>"
  27,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّانَ يُبۡعَثُونَ﴾</span>: مَتى يُبْعثُونَ مِن قُبُورِهِم.</p></div>"
  27,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلِ ٱدَّ ٰ⁠رَكَ عِلۡمُهُمۡ فِي ٱلۡـَٔاخِرَةِ﴾</span>: بَلْ تَكامَلَ علمُهُم بِها عِنْدَما بُعِثُوا يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿فِي شَكࣲّ مِّنۡهَا﴾</span>: أي: مِنَ الآخِرةِ في الدُّنيا.</p><p><span class="qpc-hafs">﴿عَمُونَ﴾</span>: أي: غافِلُونَ، فَقُلُوبُهُم عَمْياءُ.</p></div>"
  27,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمُخۡرَجُونَ﴾</span>: لمَبْعُوثُونَ مِن قُبُورِنا.</p></div>"
  27,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: الأكاذيبُ الَّتي كَتَبها المتقدِّمُونَ.</p></div>"
  27,69,""
  27,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡقࣲ﴾</span>: حَرَجٍ وضِيقِ صَدْرٍ.</p></div>"
  27,71,""
  27,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَدِفَ لَكُم﴾</span>: لَحِقَكُم، أو اقْتَرَبَ لَكُم.</p></div>"
  27,73,""
  27,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تُكِنُّ﴾</span>: ما تُخْفِي.</p><p><span class="qpc-hafs">﴿وَمَا يُعۡلِنُونَ﴾</span>: وما يُظْهِرُونَ.</p></div>"
  27,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَآئِبَةࣲ﴾</span>: هو ما يَغيبُ ويَخْفى عَلى الخَلْقِ.</p><p><span class="qpc-hafs">﴿مُّبِينٍ﴾</span>: واضِحٍ.</p></div>"
  27,76,""
  27,77,""
  27,78,""
  27,79,""
  27,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُدۡبِرِينَ﴾</span>: مُعْرِضِينَ.</p></div>"
  27,81,""
  27,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَعَ ٱلۡقَوۡلُ﴾</span>: أي: وجَبَ العَذابُ.</p><p><span class="qpc-hafs">﴿دَآبَّةࣰ﴾</span>: هي مِن أشْراطِ السّاعةِ الكُبْرى.</p><p><span class="qpc-hafs">﴿تُكَلِّمُهُمۡ﴾</span>: تُحدِّثُهُم.</p><p><span class="qpc-hafs">﴿لَا يُوقِنُونَ﴾</span>: لا يُصَدِّقُونَ.</p></div>"
  27,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحۡشُرُ﴾</span>: نَجْمَعُ.</p><p><span class="qpc-hafs">﴿فَهُمۡ يُوزَعُونَ﴾</span>: فهم يُكَفُّونَ عَنِ التَّفَرُّقِ، فكان على كُلِّ جِنْسٍ مَن يَرُدُّ أوَّلَهم على آخِرِهِم ثُمَّ يُساقُون جميعًا.</p></div>"
  27,84,""
  27,85,""
  27,86,""
  27,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الَّذي يُنفَخُ فيهِ للبَعْثِ.</p><p><span class="qpc-hafs">﴿فَفَزِعَ﴾</span>: خافَ خَوْفًا شَدِيدًا مِن هَوْلِ النَّفخَةِ.</p><p><span class="qpc-hafs">﴿دَ ٰ⁠خِرِينَ﴾</span>: صاغِرِينَ مُطِيعِينَ.</p></div>"
  27,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَحۡسَبُهَا جَامِدَةࣰ﴾</span>: تَظُنُّها ثابِتةً في أماكِنِها.</p><p><span class="qpc-hafs">﴿مَرَّ ٱلسَّحَابِ﴾</span>: مِثْلَ السَّحابِ الَّذي تُسَيِّرُه الرِّياحُ.</p></div>"
  27,89,""
  27,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكُبَّتۡ وُجُوهُهُمۡ فِي ٱلنَّارِ﴾</span>: أي: أُلقُوا على وُجُوهِهِم فِيها.</p></div>"
  27,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَّمَهَا﴾</span>: جَعَلها حَرَمًا آمِنًا لا يُسْفَكُ فيها دَمٌ.</p></div>"
  27,92,""
  27,93,""
