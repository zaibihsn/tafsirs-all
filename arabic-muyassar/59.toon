quran[24]{c,v,t}:
  59,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبَّحَ﴾</span>: نَزَّهَ.</p></div>"
  59,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ كَفَرُواْ﴾</span>: هُم بنُو النَّضِيرِ مِنَ اليهُودِ.</p><p><span class="qpc-hafs">﴿دِيَـٰرِهِمۡ﴾</span>: مَساكِنِهِم الَّتِي جاوَرُوا بِها المسْلِمِينَ حَوْلَ «المدينةِ».</p><p><span class="qpc-hafs">﴿لِأَوَّلِ ٱلۡحَشۡرِ﴾</span>: عِنْدَ أوَّلِ جَمْعِهِم لِلْخُرُوجِ مِن جَزِيرةِ العَرَبِ.</p><p><span class="qpc-hafs">﴿مَّانِعَتُهُمۡ﴾</span>: تَدْفَعُ عَنْهُم.</p><p><span class="qpc-hafs">﴿فَأَتَىٰهُمُ ٱللَّهُ﴾</span>: فَجاءَهُم أمْرُ اللهِ.</p><p><span class="qpc-hafs">﴿مِنۡ حَيۡثُ لَمۡ يَحۡتَسِبُواْ﴾</span>: مِن مَكانٍ لم يَظُنُّوهُ.</p><p><span class="qpc-hafs">﴿وَقَذَفَ﴾</span>: وجَعَل.</p><p><span class="qpc-hafs">﴿ٱلرُّعۡبَ﴾</span>: الخَوْفَ والفَزَعَ الشَّدِيدَ.</p><p><span class="qpc-hafs">﴿فَٱعۡتَبِرُواْ﴾</span>: فاتَّعِظُوا.</p><p><span class="qpc-hafs">﴿يَـٰٓأُوْلِي ٱلۡأَبۡصَـٰرِ﴾</span>: أصْحابَ البَصائِر السَّلِيمَةِ، والعُقُولِ الرّاجِحَةِ.</p></div>"
  59,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَلَآءَ﴾</span>: الخُرُوجَ مِنَ الوطنِ بِنِيَّةِ عَدَمِ العَوْدِ.</p></div>"
  59,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَآقُّواْ﴾</span>: خالفُوا.</p></div>"
  59,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّينَةٍ﴾</span>: نَخْلَةٍ ذاتِ ثَمَرٍ طَيِّبٍ.</p><p><span class="qpc-hafs">﴿أُصُولِهَا﴾</span>: قَواعِدِها، والمرادُ: سُوقُ النَّخْلِ.</p><p><span class="qpc-hafs">﴿وَلِيُخۡزِيَ﴾</span>: ولِيُهِينَ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقِينَ﴾</span>: الكافِرِينَ، وهُمْ يَهُودُ بَنِي النَّضِيرِ.</p></div>"
  59,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَفَآءَ ٱللَّهُ عَلَىٰ رَسُولِهِۦ﴾</span>: وما أعطاهُ اللهُ لِرَسُولِه مما يَظْفَرُ بِهِ الجيشُ مِن عَدُوِّهِم.</p><p><span class="qpc-hafs">﴿فَمَآ أَوۡجَفۡتُمۡ﴾</span>: فَما أرْكَضْتُم للإغارَةِ، وأَوْجَفَهُ: حَمَلَهُ عَلى السَّيرِ السَّرِيعِ.</p><p><span class="qpc-hafs">﴿رِكَابࣲ﴾</span>: الإبِلِ الَّتِي تُرْكَبُ.</p></div>"
  59,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقُرَىٰ﴾</span>: قُرىً فُتِحَتْ في عَهْدِ الرَّسُولِ ﷺ.</p><p><span class="qpc-hafs">﴿فَلِلَّهِ وَلِلرَّسُولِ﴾</span>: أي يُصْرَفُ في مصالِحِ المسْلِمِينَ.</p><p><span class="qpc-hafs">﴿وَلِذِي ٱلۡقُرۡبَىٰ﴾</span>: ولِذِي قَرابَةِ رَسُولِ اللهِ ﷺ، وهم بنُو هاشِم، وبنُو المطَّلِبِ.</p><p><span class="qpc-hafs">﴿وَٱلۡيَتَـٰمَىٰ﴾</span>: الأَطْفالِ الَّذِين ماتَ آباؤُهم، وهم دُونَ سِنِّ البُلُوغِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: هم أهلُ الحاجةِ الَّذِينَ لا يَمْلِكُونَ ما يَسُدُّ حاجَتَهَم.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: هو الغريبُ المسافِر الَّذِي نَفِدَتْ نَفَقَتُهُ.</p><p><span class="qpc-hafs">﴿دُولَةَۢ بَيۡنَ ٱلۡأَغۡنِيَآءِ﴾</span>: مُداوَلَةً يَتَداولُه الأَغْنِياءُ ويتعاقَبُونَ في التَّصَرُّفِ فِيهِ.</p></div>"
  59,8,""
  59,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَوَّءُو﴾</span>: اسْتَوطَنُوا وتَمَكَّنُوا.</p><p><span class="qpc-hafs">﴿ٱلدَّارَ﴾</span>: المدِينَةَ، وهي دارُ الهِجْرَةِ.</p><p><span class="qpc-hafs">﴿حَاجَةࣰ﴾</span>: حَسَدًا.</p><p><span class="qpc-hafs">﴿مِّمَّآ أُوتُواْ﴾</span>: مِمّا أُعْطِي المهاجِرُونَ من فَيْءِ بَنِي النَّضِيرِ.</p><p><span class="qpc-hafs">﴿وَيُؤۡثِرُونَ عَلَىٰٓ أَنفُسِهِمۡ﴾</span>: ويُقَدِّمُونَ غيرَهُم مِنَ المهاجِرِينَ وذَوِي الحاجةِ عَلى أنْفُسِهِم.</p><p><span class="qpc-hafs">﴿خَصَاصَةࣱ﴾</span>: شِدَّةُ احْتِياجٍ.</p><p><span class="qpc-hafs">﴿وَمَن يُوقَ﴾</span>: ومَن سَلَّمَهُ اللهُ فمُنِعَ.</p><p><span class="qpc-hafs">﴿شُحَّ نَفۡسِهِۦ﴾</span>: بُخْلَها مَعَ حِرْصِها.</p><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ بِمَطْلُوبِهِم.</p></div>"
  59,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غِلࣰّا﴾</span>: حَسَدًا وحِقْدًَا.</p></div>"
  59,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ كَفَرُواْ مِنۡ أَهۡلِ ٱلۡكِتَـٰبِ﴾</span>: هم بَنُو النَّضِيرِ.</p><p><span class="qpc-hafs">﴿وَلَا نُطِيعُ فِيكُمۡ﴾</span>: أي في ضُرِّكُم.</p></div>"
  59,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَئِن نَّصَرُوهُمۡ﴾</span>: ولئِنْ أرادُوا نُصْرَتَهُم.</p><p><span class="qpc-hafs">﴿ثُمَّ لَا يُنصَرُونَ﴾</span>: أي لا يَغْلِبُونَ.</p></div>"
  59,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَهۡبَةࣰ﴾</span>: خَوْفًا.</p></div>"
  59,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّحَصَّنَةٍ﴾</span>: ممنُوعَةٍ بأسْوارٍ أو خَنادِقَ مِمَّن يُرِيدُ أخْذَها.</p><p><span class="qpc-hafs">﴿جُدُرِۭ﴾</span>: حِيطانٍ.</p><p><span class="qpc-hafs">﴿بَأۡسُهُم﴾</span>: قوَّتُهُم.</p><p><span class="qpc-hafs">﴿شَتَّىٰ﴾</span>: مُتَفَرِّقَةٌ</p></div>"
  59,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَالَ أَمۡرِهِمۡ﴾</span>: سُوءَ عاقِبَةِ كُفْرِهِم وعَداوَتِهِم لِلرَّسُولِ ﷺ.</p></div>"
  59,16,""
  59,17,""
  59,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا قَدَّمَتۡ﴾</span>: أي: مِنَ الأعْمالِ.</p><p><span class="qpc-hafs">﴿لِغَدࣲ﴾</span>: يومِ القِيامةِ.</p></div>"
  59,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَسُواْ ٱللَّهَ﴾</span>: تَرَكُوا أداءَ حَقِّ اللهِ الَّذِي أوْجَبَهُ عَلَيهِم.</p><p><span class="qpc-hafs">﴿فَأَنسَىٰهُمۡ أَنفُسَهُمۡ﴾</span>: مِمّا يُنَجِّيهِم مِنَ عَذابِ يَوْمِ القِيامةِ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارجُونَ عَن طاعَةِ اللهِ ورَسُولِهِ.</p></div>"
  59,20,""
  59,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعࣰا﴾</span>: خاضِعًا مُتَذَلِّلًا.</p><p><span class="qpc-hafs">﴿مُّتَصَدِّعࣰا﴾</span>: مُتَشَقِّقًا.</p><p><span class="qpc-hafs">﴿نَضۡرِبُهَا﴾</span>: نُوَضِّحُها.</p></div>"
  59,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰلِمُ ٱلۡغَيۡبِ وَٱلشَّهَـٰدَةِ﴾</span>: يَعْلَمُ ما غابَ وما حَضَرَ.</p></div>"
  59,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلِكُ﴾</span>: المالِكُ لجمِيعِ الأشْياءِ، المتَصَرِّفُ فِيها بِلا مُمانَعَةٍ ولا مُدافَعَةٍ.</p><p><span class="qpc-hafs">﴿ٱلۡقُدُّوسُ﴾</span>: المُنَزَّهُ عَن كُلِّ نَقْصٍ.</p><p><span class="qpc-hafs">﴿ٱلسَّلَـٰمُ﴾</span>: الَّذِي سَلِمَ مِن كُلِّ عيبٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمُؤۡمِنُ﴾</span>: المصَدِّقُ رُسُلَه وأنبياءَه بِما أرْسَلَهُم بِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُهَيۡمِنُ﴾</span>: الرَّقِيبُ على خَلْقِهِ في أعمالِهِم.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: الَّذِي لا يُغالَبُ.</p><p><span class="qpc-hafs">﴿ٱلۡجَبَّارُ﴾</span>: الَّذِي قَهَرَ جَميعَ العِبادِ، وأَذْعَنُوا لَهُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُتَكَبِّرُ﴾</span>: الَّذِي له الكبرياءُ والعَظَمَةُ.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَ ٱللَّهِ﴾</span>: تنَزَّهَ اللهُ.</p></div>"
  59,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَـٰلِقُ﴾</span>: المقَدِّرُ لِلْخَلْقِ.</p><p><span class="qpc-hafs">﴿ٱلۡبَارِئُ﴾</span>: المنْشِئُ لِلْخَلْقِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُصَوِّرُ﴾</span>: صَوَّر خَلْقَهُ كَيفَ يَشاءُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: الشَّدِيدُ الانتِقامِ مِن أعدائِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمُ﴾</span>: في تَدْبِيرِه أُمُورَ خَلْقِه.</p></div>"
