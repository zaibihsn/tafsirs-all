quran[123]{c,v,t}:
  11,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُحۡكِمَتۡ ءَايَـٰتُهُۥ﴾</span>: جُعِلَتْ مُحْكَمَةً مُتقنةً، لا نَقْصَ فيها ولا عَيْبَ.</p><p><span class="qpc-hafs">﴿فُصِّلَتۡ﴾</span>: بُيِّنَتْ فيها الأحكامُ والقِصصُ والمواعظُ.</p></div>"
  11,2,""
  11,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّتَـٰعًا حَسَنًا﴾</span>: بطِيبِ الحياةِ وسَعَةِ الرِّزقِ.</p><p><span class="qpc-hafs">﴿إِلَىٰٓ أَجَلࣲ مُّسَمࣰّى﴾</span>: إلى وقتِ انقضاءِ آجالِكم.</p><p><span class="qpc-hafs">﴿فَضۡلَهُۥ﴾</span>: جزاءَ فَضْلِه في الدُّنيا والآخرةِ.</p><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: تُعْرِضُوا.</p></div>"
  11,4,""
  11,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَثۡنُونَ صُدُورَهُمۡ﴾</span>: يَطْوُونها على الكفرِ والعَداوةِ.</p><p><span class="qpc-hafs">﴿يَسۡتَغۡشُونَ ثِيَابَهُمۡ﴾</span>: يَتَغَطَّوْن بها.</p></div>"
  11,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَآبَّةࣲ﴾</span>: كلُّ حَيَوانٍ يَمْشي -على هيئتهِ- على الأرضِ.</p><p><span class="qpc-hafs">﴿مُسۡتَقَرَّهَا﴾</span>: مكانَ استقرارِها في حياتِها وبعدَ مَماتِها.</p><p><span class="qpc-hafs">﴿وَمُسۡتَوۡدَعَهَا﴾</span>: موضعَ استيداعِها بعد موتِها.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣲ مُّبِينࣲ﴾</span>: واضحٍ، وهو اللَّوحُ المحفوظُ.</p></div>"
  11,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَرۡشُهُۥ﴾</span>: العرشُ: سريرُ المُلْكِ الذي استوى عليه الرحمنُ، وتحمِلُه الملائكةُ، وهو أعظمُ المخلوقاتِ، وهو سَقْفُ الجنَّةِ.</p><p><span class="qpc-hafs">﴿لِيَبۡلُوَكُمۡ﴾</span>: لِيَخْتَبِرَكم.</p><p><span class="qpc-hafs">﴿أَحۡسَنُ عَمَلࣰا﴾</span>: أعْمَلُ بطاعةِ اللهِ وأَوْرَعُ عن مَحارمِه.</p></div>"
  11,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣲ مَّعۡدُودَةࣲ﴾</span>: وقتٍ معلومٍ.</p><p><span class="qpc-hafs">﴿وَحَاقَ﴾</span>: أحاطَ.</p></div>"
  11,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَّا رَحۡمَةࣰ﴾</span>: نِعْمةً مِن نِعَمِنا الكثيرةِ.</p><p><span class="qpc-hafs">﴿نَزَعۡنَـٰهَا مِنۡهُ﴾</span>: سَلَبْناها منه.</p><p><span class="qpc-hafs">﴿لَيَـُٔوسࣱ﴾</span>: شديدُ اليأسِ من رحمةِ اللهِ.</p><p><span class="qpc-hafs">﴿كَفُورࣱ﴾</span>: كثيرُ الجُحودِ للنِّعَمِ.</p></div>"
  11,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَّآءَ مَسَّتۡهُ﴾</span>: بَلْوى أصابَتْه.</p><p><span class="qpc-hafs">﴿ٱلسَّيِّـَٔاتُ﴾</span>: المصائبُ والشَّدائدُ.</p><p><span class="qpc-hafs">﴿لَفَرِحࣱ﴾</span>: بَطِرٌ بالنِّعْمةِ مُغْتَرٌّ بها.</p><p><span class="qpc-hafs">﴿فَخُورٌ﴾</span>: كثيرُ التعاظُمِ على الناسِ.</p></div>"
  11,11,""
  11,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡضَ مَا يُوحَىٰٓ إِلَيۡكَ﴾</span>: ما يَشُقُّ على المشركين سماعُه، ويُثيرُ غضَبَهم.</p><p><span class="qpc-hafs">﴿أَن يَقُولُواْ﴾</span>: خشيةَ أن يقولوا على وجهِ التكذيبِ والاستهزاءِ.</p><p><span class="qpc-hafs">﴿لَوۡلَآ﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿وَكِيلٌ﴾</span>: حفيظٌ يُدَبِّرُ جميعَ شؤونِ خَلْقهِ.</p></div>"
  11,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰهُ﴾</span>: أتى به مِن عندِ نفسِه.</p><p><span class="qpc-hafs">﴿مُفۡتَرَيَـٰتࣲ﴾</span>: مُخْتَلَقاتٍ من عندِ أنفسِكم.</p><p><span class="qpc-hafs">﴿وَٱدۡعُواْ مَنِ ٱسۡتَطَعۡتُم﴾</span>: واستعينُوا بمَن أمكنكم الاستعانةُ به.</p></div>"
  11,14,""
  11,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُوَفِّ إِلَيۡهِمۡ أَعۡمَـٰلَهُمۡ﴾</span>: نُعْطِهم جزاءَ أعمالِهم في الدنيا.</p><p><span class="qpc-hafs">﴿لَا يُبۡخَسُونَ﴾</span>: لا يُنْقَصُون شيئًا ممّا قُسِمَ لهم.</p></div>"
  11,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَبِطَ﴾</span>: بَطَلَ في الآخرةِ نَفْعُ ما عَمِلوه.</p></div>"
  11,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَةࣲ مِّن رَّبِّهِۦ﴾</span>: حُجَّةٍ وبَصيرةٍ من اللهِ.</p><p><span class="qpc-hafs">﴿وَيَتۡلُوهُ﴾</span>: يَتْبَعُه ويُقَوِّيه.</p><p><span class="qpc-hafs">﴿شَاهِدࣱ مِّنۡهُ﴾</span>: يَشْهَدُ على كَوْنِ القرآنِ من عندِ اللهِ.</p><p><span class="qpc-hafs">﴿كِتَـٰبُ مُوسَىٰٓ﴾</span>: التوراةُ.</p><p><span class="qpc-hafs">﴿إِمَامࣰا﴾</span>: يُؤتَمُّ به في الدِّين، ويُقْتدى به.</p><p><span class="qpc-hafs">﴿وَرَحۡمَةً﴾</span>: نِعْمَةً عظيمةً من اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَحۡزَابِ﴾</span>: الكفارِ الذين جَمَعهم تكذيبُ رسولِ اللهِ عليه الصلاة والسلام، وكَيْدُهم له.</p><p><span class="qpc-hafs">﴿مِرۡيَةࣲ مِّنۡهُ﴾</span>: شَكٍّ من تنزيلِ القرآنِ من اللهِ.</p></div>"
  11,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُعۡرَضُونَ عَلَىٰ رَبِّهِمۡ﴾</span>: سيُعْرَضون على اللهِ في موقفِ الحسابِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَشۡهَـٰدُ﴾</span>: جَمْعُ شاهِدٍ، وهم: الملائكةُ والأنبياءُ والمؤمنون.</p><p><span class="qpc-hafs">﴿لَعۡنَةُ ٱللَّهِ﴾</span>: غَضَبُه وسُخْطُه.</p></div>"
  11,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصُدُّونَ﴾</span>: يَمْنَعُون الناسَ.</p><p><span class="qpc-hafs">﴿سَبِيلِ ٱللَّهِ﴾</span>: الطريقِ المُوصِلَةِ إليه، وهي دينُ الإسلامِ.</p><p><span class="qpc-hafs">﴿وَيَبۡغُونَهَا عِوَجࣰا﴾</span>: ويُريدون أن تكونَ سبيلُ اللهِ مائلةً وفْقَ أهوائِهم.</p></div>"
  11,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعۡجِزِينَ﴾</span>: فائتين من عذابِ اللهِ بالهَرَبِ.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أنصارٍ.</p></div>"
  11,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: ذَهَبَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَكْذِبُون على اللهِ من ادِّعاءِ الشفعاءِ، الذين يَتَوَهَّمُون شفاعتَهم.</p></div>"
  11,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حقًا، أو لا مَحالةَ.</p></div>"
  11,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَخۡبَتُوٓاْ إِلَىٰ رَبِّهِمۡ﴾</span>: أنابُوا إليه وخَضَعُوا له.</p></div>"
  11,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَرِيقَيۡنِ﴾</span>: فريقَي الكُفْرِ والإيمانِ.</p></div>"
  11,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَذِيرࣱ مُّبِينٌ﴾</span>: بَيِّنُ الإنذارِ بما أُرْسِلْتُ به.</p></div>"
  11,26,""
  11,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: الأشرافُ والسّادةُ.</p><p><span class="qpc-hafs">﴿أَرَاذِلُنَا﴾</span>: سَفَلَةُ الناسِ منا وفُقَراؤُنا.</p><p><span class="qpc-hafs">﴿بَادِيَ ٱلرَّأۡيِ﴾</span>: أي: اتّبعُوك من غيرِ تفكيرٍ ولا رَوِيَّةٍ.</p></div>"
  11,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُوني.</p><p><span class="qpc-hafs">﴿بَيِّنَةࣲ﴾</span>: حُجَّةٍ وبرهانٍ، تَشْهَدُ بالنبوَّةِ.</p><p><span class="qpc-hafs">﴿وَءَاتَىٰنِي رَحۡمَةࣰ مِّنۡ عِندِهِۦ﴾</span>: وهي الرِّسالةُ.</p><p><span class="qpc-hafs">﴿فَعُمِّيَتۡ﴾</span>: أُخْفِيَتْ.</p></div>"
  11,29,""
  11,30,""
  11,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَزَآئِنُ ٱللَّهِ﴾</span>: خزائنُ رزقِه، وما لا يَصِلُ إليه عِلْمُ الناسِ.</p><p><span class="qpc-hafs">﴿تَزۡدَرِيٓ أَعۡيُنُكُمۡ﴾</span>: تَسْتَحْقِرُهم وتَسْتهينُ بهم.</p><p><span class="qpc-hafs">﴿خَيۡرًا﴾</span>: توفيقًا وإيمانًا وأجرًا.</p></div>"
  11,32,""
  11,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُعۡجِزِينَ﴾</span>: بفائتين من عذابِ اللهِ بالهَرَبِ.</p></div>"
  11,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغۡوِيَكُمۡ﴾</span>: يُضِلَّكم.</p></div>"
  11,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَلَيَّ إِجۡرَامِي﴾</span>: فعَلَيَّ إثمي وعُقوبتُه.</p><p><span class="qpc-hafs">﴿مِّمَّا تُجۡرِمُونَ﴾</span>: ممّا تَقْترفونه من الكفرِ والتكذيب.</p></div>"
  11,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تَبۡتَئِسۡ﴾</span>: لا تَحْزَنْ.</p></div>"
  11,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السَّفينةَ.</p><p><span class="qpc-hafs">﴿بِأَعۡيُنِنَا﴾</span>: بمَرْأى مِنّا وأنت في حِفْظِنا.</p><p><span class="qpc-hafs">﴿وَوَحۡيِنَا﴾</span>: وبأَمْرِنا لك ومَعُونَتِنا.</p><p><span class="qpc-hafs">﴿وَلَا تُخَـٰطِبۡنِي فِي ٱلَّذِينَ ظَلَمُوٓاْ﴾</span>: لا تَطْلُبْ مني إمهالَهم.</p></div>"
  11,38,""
  11,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخۡزِيهِ﴾</span>: يُهينُه ويُذِلُّه.</p><p><span class="qpc-hafs">﴿وَيَحِلُّ عَلَيۡهِ﴾</span>: ويَنْزِلُ به.</p><p><span class="qpc-hafs">﴿عَذَابࣱ مُّقِيمٌ﴾</span>: دائمٌ لا ينقطِعُ، وهو النارُ.</p></div>"
  11,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَارَ ٱلتَّنُّورُ﴾</span>: ونَبَعَ الماءُ بقوَّةٍ من المكانِ الذي يُخْبَزُ فيه.</p><p><span class="qpc-hafs">﴿مِن كُلࣲّ زَوۡجَيۡنِ ٱثۡنَيۡنِ﴾</span>: من كلِّ نوعٍ من أنواعِ الحيَواناتِ ذكرًا وأنثى.</p><p><span class="qpc-hafs">﴿إِلَّا مَن سَبَقَ عَلَيۡهِ ٱلۡقَوۡلُ﴾</span>: إلّا مَن تَقَدَّمَ حُكْمُ اللهِ عليه بأنه من المُغْرَقين.</p></div>"
  11,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَجۡرٜىٰهَا﴾</span>: جَرْيُها على وجهِ الماء.</p><p><span class="qpc-hafs">﴿وَمُرۡسَىٰهَآ﴾</span>: ومُنْتَهى سَيْرِها.</p></div>"
  11,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَعۡزِلࣲ﴾</span>: مكانٍ عَزَلَ نفسَه فيه عن المؤمنين.</p></div>"
  11,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَـَٔاوِيٓ﴾</span>: سألتجِئُ وأتحَصَّنُ.</p><p><span class="qpc-hafs">﴿لَا عَاصِمَ﴾</span>: لا مانعَ ولا حافِظَ.</p></div>"
  11,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَقۡلِعِي﴾</span>: أمْسِكِي عن إنزالِ المطرِ.</p><p><span class="qpc-hafs">﴿وَغِيضَ ٱلۡمَآءُ﴾</span>: نَقَصَ وغارَ في الأرضِ.</p><p><span class="qpc-hafs">﴿وَقُضِيَ ٱلۡأَمۡرُ﴾</span>: تَمَّ حُكْمُ اللهِ بإهلاكِ قومِ نوحٍ.</p><p><span class="qpc-hafs">﴿وَٱسۡتَوَتۡ عَلَى ٱلۡجُودِيِّ﴾</span>: استقرَّتِ السفينةُ على جَبَلِ الجوديِّ.</p><p><span class="qpc-hafs">﴿بُعۡدࣰا﴾</span>: هَلاكًا.</p></div>"
  11,45,""
  11,46,""
  11,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعُوذُ بِكَ﴾</span>: أعتصِمُ وأستجيرُ بك.</p></div>"
  11,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسَلَـٰمࣲ مِّنَّا﴾</span>: بأمانٍ وسَلامةٍ منّا.</p><p><span class="qpc-hafs">﴿وَبَرَكَـٰتٍ عَلَيۡكَ﴾</span>: خيراتٍ ونِعَمٍ دائمةٍ عليك.</p><p><span class="qpc-hafs">﴿وَأُمَمࣱ سَنُمَتِّعُهُمۡ﴾</span>: وهم الكفارُ.</p></div>"
  11,49,""
  11,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَادٍ﴾</span>: قومِ هودٍ عليه السلام، وهم قبيلةٌ من العَرَبِ.</p><p><span class="qpc-hafs">﴿مُفۡتَرُونَ﴾</span>: كاذِبُون في إشراكِكم باللهِ.</p></div>"
  11,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَرَنِيٓ﴾</span>: خَلَقَني.</p></div>"
  11,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّمَآءَ﴾</span>: المطرَ.</p><p><span class="qpc-hafs">﴿مِّدۡرَارࣰا﴾</span>: كثيرًا مُتتابعًا من غيرِ إضْرارٍ.</p><p><span class="qpc-hafs">﴿وَلَا تَتَوَلَّوۡاْ﴾</span>: لا تُعْرِضُوا عَمّا دَعَوْتُكم إليه.</p></div>"
  11,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِبَيِّنَةࣲ﴾</span>: بحُجَّةٍ واضحةٍ.</p><p><span class="qpc-hafs">﴿عَن قَوۡلِكَ﴾</span>: من أجلِ قولِك.</p></div>"
  11,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن نَّقُولُ﴾</span>: ما نقولُ.</p><p><span class="qpc-hafs">﴿ٱعۡتَرَىٰكَ﴾</span>: أصابَكَ.</p><p><span class="qpc-hafs">﴿بِسُوٓءࣲ﴾</span>: بجُنونٍ؛ لنَهْيِك عن عبادتِها.</p></div>"
  11,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكِيدُونِي﴾</span>: فاجتهِدُوا في إلحاقِ الضَّرَرِ بي.</p><p><span class="qpc-hafs">﴿لَا تُنظِرُونِ﴾</span>: لا تُمْهِلُوني بما تُريدون كيدَه.</p></div>"
  11,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَكَّلۡتُ عَلَى ٱللَّهِ﴾</span>: فَوَّضْتُ أمري إليه، واعتمَدْتُ عليه.</p><p><span class="qpc-hafs">﴿دَآبَّةٍ﴾</span>: كلُّ حَيَوانٍ يَمْشِي -على هيئتِه- على الأرضِ.</p><p><span class="qpc-hafs">﴿ءَاخِذُۢ بِنَاصِيَتِهَآ﴾</span>: مالِكُها وقادرٌ عليها.</p></div>"
  11,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسۡتَخۡلِفُ رَبِّي قَوۡمًا غَيۡرَكُمۡ﴾</span>: يأتي بقومٍ آخَرين بَعْدَكم.</p><p><span class="qpc-hafs">﴿حَفِيظࣱ﴾</span>: رقيبٌ مُهَيْمِنٌ.</p></div>"
  11,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَ أَمۡرُنَا﴾</span>: أي: بهَلاكِ قومِ هودٍ.</p><p><span class="qpc-hafs">﴿غَلِيظࣲ﴾</span>: شديدٍ، وهو الرِّيحُ الباردةُ التي أُهلِكَتْ بها عادٌ.</p></div>"
  11,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَبَّارٍ﴾</span>: متكبِّرٍ.</p><p><span class="qpc-hafs">﴿عَنِيدࣲ﴾</span>: لا يَقْبَلُ الحقَّ ولا يَتْبَعُه.</p></div>"
  11,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعۡنَةࣰ﴾</span>: سُخْطًا من اللهِ، وبُعْدًا من رحمتِه.</p><p><span class="qpc-hafs">﴿بُعۡدࣰا﴾</span>: هَلاكًا.</p></div>"
  11,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَمُودَ﴾</span>: قومِ صالحٍ عليه السلامُ، وهم قبيلةٌ من العَرَبِ.</p><p><span class="qpc-hafs">﴿أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ﴾</span>: ابتدأ خَلْقَكم منها.</p><p><span class="qpc-hafs">﴿وَٱسۡتَعۡمَرَكُمۡ فِيهَا﴾</span>: جَعَلَكم عُمّارَها وسكّانَها.</p></div>"
  11,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرۡجُوࣰّا﴾</span>: نرجو أن تكونَ فينا سَيِّدًا مُطاعًا.</p><p><span class="qpc-hafs">﴿مُرِيبࣲ﴾</span>: مُوقِعٍ في القلقِ وعَدَمِ الاطمئنانِ.</p></div>"
  11,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِروني.</p><p><span class="qpc-hafs">﴿بَيِّنَةࣲ مِّن رَّبِّي﴾</span>: حُجَّةٍ وبُرْهانٍ منه.</p><p><span class="qpc-hafs">﴿رَحۡمَةࣰ﴾</span>: أي: النبوَّةَ والحِكْمةَ.</p><p><span class="qpc-hafs">﴿تَخۡسِيرࣲ﴾</span>: إيقاعٍ في الخُسْرانِ وإبعادٍ عن الخير.</p></div>"
  11,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: علامةً دالَّةً على صِدْقي.</p><p><span class="qpc-hafs">﴿فَذَرُوهَا﴾</span>: فاترُكوها.</p><p><span class="qpc-hafs">﴿بِسُوٓءࣲ﴾</span>: بأيِّ أذى.</p></div>"
  11,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُوهَا﴾</span>: فنَحَرُوا الناقةَ.</p><p><span class="qpc-hafs">﴿تَمَتَّعُواْ فِي دَارِكُمۡ﴾</span>: استَمْتِعُوا بالعيشِ في بلدِكم.</p></div>"
  11,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَ أَمۡرُنَا﴾</span>: أي: بهَلاكِ قومِ صالحٍ.</p><p><span class="qpc-hafs">﴿خِزۡيِ﴾</span>: ذُلِّ ومَهانَةِ.</p></div>"
  11,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّيۡحَةُ﴾</span>: الصوتُ الشديدُ المُهلِكُ.</p><p><span class="qpc-hafs">﴿جَـٰثِمِينَ﴾</span>: لاصِقِين بالأرضِ على رُكَبهِم ووُجوهِهم لا حَراكَ بهم.</p></div>"
  11,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَآ﴾</span>: كأنّ قومَ صالحٍ لم يُقيموا في ديارِهم ويَتمتَّعُوا فيها.</p><p><span class="qpc-hafs">﴿بُعۡدࣰا﴾</span>: هَلاكًا.</p></div>"
  11,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُسُلُنَآ﴾</span>: الملائكةُ.</p><p><span class="qpc-hafs">﴿بِٱلۡبُشۡرَىٰ﴾</span>: ببِشارَتِه بالولَدِ.</p><p><span class="qpc-hafs">﴿حَنِيذࣲ﴾</span>: مَشْويٍّ في النارِ، أو على حِجارةٍ مُحمّاةٍ بها.</p></div>"
  11,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَكِرَهُمۡ﴾</span>: أنكرَ عَدَمَ أكلِهم.</p><p><span class="qpc-hafs">﴿وَأَوۡجَسَ مِنۡهُمۡ خِيفَةࣰ﴾</span>: أحَسَّ في نفسِه خوْفًا منهم.</p></div>"
  11,71,""
  11,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰوَيۡلَتَىٰٓ﴾</span>: كلمةٌ أرادَتْ بها التعجُّبَ.</p><p><span class="qpc-hafs">﴿بَعۡلِي﴾</span>: زوجي.</p><p><span class="qpc-hafs">﴿شَيۡخًا﴾</span>: كبيرًا في السِّن.</p></div>"
  11,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمِيدࣱ﴾</span>: محمودٌ في صفاتِه وأفعالِه.</p><p><span class="qpc-hafs">﴿مَّجِيدࣱ﴾</span>: ذو شَرَفٍ وكَرَمٍ، أو كثيرُ الخيرِ والإحسانِ.</p></div>"
  11,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّوۡعُ﴾</span>: الخوفُ.</p></div>"
  11,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَحَلِيمٌ﴾</span>: صَبُورٌ على الأذى، كثيرُ الصَّفْحِ عَمَّن ناله بمَكْروهٍ.</p><p><span class="qpc-hafs">﴿أَوَّ ٰ⁠هࣱ﴾</span>: كثيرُ التضرُّعِ إلى اللهِ.</p><p><span class="qpc-hafs">﴿مُّنِيبࣱ﴾</span>: رَجّاعٌ إلى اللهِ في أمورِه كلِّها.</p></div>"
  11,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَ أَمۡرُ رَبِّكَ﴾</span>: أي: بهَلاكِ قومِ لوطٍ.</p></div>"
  11,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِيٓءَ بِهِمۡ﴾</span>: ساءَه حُضورُهم وأحْزَنَه.</p><p><span class="qpc-hafs">﴿وَضَاقَ بِهِمۡ ذَرۡعࣰا﴾</span>: ضَعُفَتْ طاقَتُه عن تَدْبيرِ خَلاصِهم.</p><p><span class="qpc-hafs">﴿عَصِيبࣱ﴾</span>: شديدٌ شَرُّه وبلاؤُه.</p></div>"
  11,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُهۡرَعُونَ﴾</span>: يُسْرِعُون المشيَ إليه؛ لطَلَبِ الفاحشةِ.</p><p><span class="qpc-hafs">﴿هَـٰٓؤُلَآءِ بَنَاتِي﴾</span>: نساؤُكم بناتي فتزوَّجُوهنَّ.</p><p><span class="qpc-hafs">﴿وَلَا تُخۡزُونِ﴾</span>: لا تَفْضَحُوني ولا تُهينوني.</p><p><span class="qpc-hafs">﴿رَّشِيدࣱ﴾</span>: حَسَنُ التقديرِ للأمورِ.</p></div>"
  11,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ حَقࣲّ﴾</span>: من حاجةٍ أو رغبةٍ.</p></div>"
  11,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡ أَنَّ لِي بِكُمۡ قُوَّةً﴾</span>: لو وجَدْتُ مُعِينًا منكم لَمَنعْتُكم من أضيافي.</p><p><span class="qpc-hafs">﴿أَوۡ ءَاوِيٓ إِلَىٰ رُكۡنࣲ شَدِيدࣲ﴾</span>: أو ألجأُ إلى عشيرةٍ قويَّة تمنعني منكم.</p></div>"
  11,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَسۡرِ بِأَهۡلِكَ﴾</span>: فاخرُجْ أنتَ وأهلُك المؤمنون.</p><p><span class="qpc-hafs">﴿بِقِطۡعࣲ مِّنَ ٱلَّيۡلِ﴾</span>: بآخِر الليلِ.</p><p><span class="qpc-hafs">﴿إِلَّا ٱمۡرَأَتَكَ﴾</span>: فلا تَسْرِ بها.</p></div>"
  11,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَ أَمۡرُنَا﴾</span>: أي: بهلاكِ قومِ لوطٍ.</p><p><span class="qpc-hafs">﴿جَعَلۡنَا عَـٰلِيَهَا سَافِلَهَا﴾</span>: جَعَلْنا عاليَ قُراهم سافِلَها فقَلَبْناها عليهم.</p><p><span class="qpc-hafs">﴿وَأَمۡطَرۡنَا﴾</span>: أرْسَلْنا.</p><p><span class="qpc-hafs">﴿سِجِّيلࣲ﴾</span>: من طِينٍ مُتَحَجِّر.</p><p><span class="qpc-hafs">﴿مَّنضُودࣲ﴾</span>: مُتتابعٍ في النزولِ.</p></div>"
  11,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّسَوَّمَةً عِندَ رَبِّكَ﴾</span>: مُعَلَّمَةً عند الله بعَلامةٍ تميِّزُها.</p></div>"
  11,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَدۡيَنَ﴾</span>: قومِ شُعيبٍ عليه السلام، وهم قبيلةٌ من العربِ.</p><p><span class="qpc-hafs">﴿يَوۡمࣲ مُّحِيطࣲ﴾</span>: لا يَفْلِتُ فيه أحدٌ من العذاب.</p></div>"
  11,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡفُواْ﴾</span>: أتِمُّوا.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعدلِ من غيرِ زيادةٍ ولا نقصٍ.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡخَسُواْ﴾</span>: ولا تَنْقُصُوا.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡاْ﴾</span>: ولا تُفْرِطُوا في الفسادِ.</p></div>"
  11,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَقِيَّتُ ٱللَّهِ خَيۡرࣱ لَّكُمۡ﴾</span>: ما أبقى اللهُ لكم من الحَلالِ فيه بَرَكَةٌ وخيرٌ لكم.</p><p><span class="qpc-hafs">﴿بِحَفِيظࣲ﴾</span>: برقيبٍ أُحْصِي أعمالَكم.</p></div>"
  11,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَلِيمُ﴾</span>: العاقلُ المتأنِّي.</p><p><span class="qpc-hafs">﴿ٱلرَّشِيدُ﴾</span>: الحَسَنُ التدبيرِ في المالِ.</p></div>"
  11,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَةࣲ﴾</span>: حُجَّةٍ واضحةٍ.</p><p><span class="qpc-hafs">﴿حَسَنࣰا﴾</span>: واسعًا حلالًا.</p><p><span class="qpc-hafs">﴿وَمَا تَوۡفِيقِيٓ﴾</span>: وما هدايتي إلى إصابةِ الحقِّ والإصلاحِ.</p><p><span class="qpc-hafs">﴿تَوَكَّلۡتُ﴾</span>: اعتمَدْتُ وفوَّضْتُ أمري.</p><p><span class="qpc-hafs">﴿وَإِلَيۡهِ أُنِيبُ﴾</span>: أرْجِعُ في كلِّ أموري.</p></div>"
  11,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَجۡرِمَنَّكُمۡ شِقَاقِيٓ﴾</span>: لا تَحْمِلَنَّكم مُعاداتي.</p><p><span class="qpc-hafs">﴿وَمَا قَوۡمُ لُوطࣲ مِّنكُم بِبَعِيدࣲ﴾</span>: أي: وما إهلاكُهم بزمانٍ ولا مكانٍ بعيدٍ منكم.</p></div>"
  11,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَدُودࣱ﴾</span>: كثيرُ المودَّةِ والمحبَّةِ لِمَن تابَ إليه وأنابَ.</p></div>"
  11,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا نَفۡقَهُ﴾</span>: لا نَفْهَمُ ولا نُدْرِكُ.</p><p><span class="qpc-hafs">﴿رَهۡطُكَ﴾</span>: عشيرتُك الأقربون.</p><p><span class="qpc-hafs">﴿لَرَجَمۡنَـٰكَ﴾</span>: لَقَتَلْناك رَجْمًا بالحجارةِ.</p></div>"
  11,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱتَّخَذۡتُمُوهُ وَرَآءَكُمۡ ظِهۡرِيًّا﴾</span>: نَبَذْتُم أمرَ اللهِ وراءَ ظُهورِكم، فلم تَمْتثلُوا له.</p><p><span class="qpc-hafs">﴿مُحِيطࣱ﴾</span>: لا يَخْفى عليه شيءٌ من أقوالِكم وأفعالِكم.</p></div>"
  11,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ مَكَانَتِكُمۡ﴾</span>: حالتِكم التي أنتم عليها من الكفر.</p><p><span class="qpc-hafs">﴿يُخۡزِيهِ﴾</span>: يُهينُه ويُذِلُّه.</p><p><span class="qpc-hafs">﴿وَٱرۡتَقِبُوٓاْ﴾</span>: وانتظِرُوا عاقبةَ أمرِكم.</p><p><span class="qpc-hafs">﴿رَقِيبࣱ﴾</span>: مُنتظِرٌ.</p></div>"
  11,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَ أَمۡرُنَا﴾</span>: أي: بهَلاكِ قومِ شُعيبٍ.</p><p><span class="qpc-hafs">﴿ٱلصَّيۡحَةُ﴾</span>: وهي الصوتُ الشديدُ المُهلِكُ.</p><p><span class="qpc-hafs">﴿جَـٰثِمِينَ﴾</span>: لاصِقين بالأرض على رُكَبِهم ووجوهِهم لاحَراكَ بهم.</p></div>"
  11,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَآ﴾</span>: كأنّ قومَ شعيبٍ لم يُقيموا في ديارهم ويتمتَّعوا فيها.</p><p><span class="qpc-hafs">﴿بُعۡدࣰا﴾</span>: هَلاكًا.</p></div>"
  11,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بالتوراةِ، وبما أعْطَيْناه من أدلَّةٍ على توحيدِنا.</p><p><span class="qpc-hafs">﴿وَسُلۡطَـٰنࣲ مُّبِينٍ﴾</span>: حُجَّةٍ بينةٍ على صِدْقِه.</p></div>"
  11,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَلَإِيْهِۦ﴾</span>: أشرافِ قومهِ وسادتِهم.</p><p><span class="qpc-hafs">﴿بِرَشِيدࣲ﴾</span>: مُصيبٍ للحقِّ وللطريقِ السَّديدِ.</p></div>"
  11,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقۡدُمُ قَوۡمَهُۥ﴾</span>: يتقدَّمُهم.</p><p><span class="qpc-hafs">﴿فَأَوۡرَدَهُمُ ٱلنَّارَ﴾</span>: فأدخَلَهم فيها.</p><p><span class="qpc-hafs">﴿ٱلۡوِرۡدُ ٱلۡمَوۡرُودُ﴾</span>: المَدْخَلُ الذي يَدْخُلونه، وهو النارُ.</p></div>"
  11,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُتۡبِعُواْ﴾</span>: أُلْحِقُوا.</p><p><span class="qpc-hafs">﴿فِي هَـٰذِهِۦ﴾</span>: أي: الدنيا.</p><p><span class="qpc-hafs">﴿لَعۡنَةࣰ﴾</span>: إبعادًا عن اللهِ.</p><p><span class="qpc-hafs">﴿ٱلرِّفۡدُ ٱلۡمَرۡفُودُ﴾</span>: العطاءُ المعطى لهم، وهو لعنةُ الدنيا والآخرةِ.</p></div>"
  11,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَقُصُّهُۥ عَلَيۡكَ﴾</span>: نُخْبِرُك به.</p><p><span class="qpc-hafs">﴿قَآئِمࣱ﴾</span>: له آثارٌ باقية.</p><p><span class="qpc-hafs">﴿وَحَصِيدࣱ﴾</span>: ما لا أثَر له.</p></div>"
  11,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَآ أَغۡنَتۡ عَنۡهُمۡ﴾</span>: فما نَفَعَتْهم.</p><p><span class="qpc-hafs">﴿جَآءَ أَمۡرُ رَبِّكَ﴾</span>: أي: بهَلاكِهم.</p><p><span class="qpc-hafs">﴿غَيۡرَ تَتۡبِيبࣲ﴾</span>: غيرَ تَخْسيرٍ وإهلاكٍ.</p></div>"
  11,102,""
  11,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: لَعِبْرَةً وعِظةً.</p></div>"
  11,104,""
  11,105,""
  11,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَفِيرࣱ﴾</span>: إخراجُ النَّفَسِ من الصَّدْرِ؛ من شِدَّةِ الحُزْنِ.</p><p><span class="qpc-hafs">﴿وَشَهِيقٌ﴾</span>: رَدُّ النَّفَسِ إلى الصَّدْرِ مع طولٍ فيه.</p></div>"
  11,107,""
  11,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡرَ مَجۡذُوذࣲ﴾</span>: غيرَ مقطوعٍ عنهم.</p></div>"
  11,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِرۡيَةࣲ﴾</span>: شَكٍّ.</p></div>"
  11,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التوراةَ.</p><p><span class="qpc-hafs">﴿كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾</span>: وهي حُكْمُه بتأخيرِ عذابِ الخَلْقِ إلى يومِ القيامةِ.</p><p><span class="qpc-hafs">﴿مُرِيبࣲ﴾</span>: مُوقِعٍ في القَلَقِ وعدمِ الاطمئنانِ.</p></div>"
  11,111,""
  11,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَطۡغَوۡاْ﴾</span>: ولا تتجاوَزُوا حدودَ اللهِ.</p></div>"
  11,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَرۡكَنُوٓاْ﴾</span>: ولا تَمِيلُوا بمَوَدَّةٍ.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أنصارٍ.</p></div>"
  11,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزُلَفࣰا مِّنَ ٱلَّيۡلِ﴾</span>: جَمْعُ زُلْفَة، أي: ساعاتٍ من أوَّلِه.</p></div>"
  11,115,""
  11,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَا﴾</span>: فهَلّا.</p><p><span class="qpc-hafs">﴿ٱلۡقُرُونِ﴾</span>: جَمْعُ قَرْنٍ، وهم القومُ المقتَرنون في زمانٍ واحدٍ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ بَقِيَّةࣲ﴾</span>: أصحابُ خيرٍ وصلاحٍ.</p><p><span class="qpc-hafs">﴿مَآ أُتۡرِفُواْ فِيهِ﴾</span>: ما مُتِّعُوا فيه من لذّاتِ الدُّنيا ونعيمِها.</p></div>"
  11,117,""
  11,118,""
  11,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَمَّتۡ﴾</span>: وجَبَتْ.</p><p><span class="qpc-hafs">﴿كَلِمَةُ رَبِّكَ﴾</span>: حُكْمُه وقضاؤُه.</p><p><span class="qpc-hafs">﴿ٱلۡجِنَّةِ﴾</span>: الجِنِّ.</p></div>"
  11,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّقُصُّ عَلَيۡكَ﴾</span>: نُخْبِرُك ونُبيِّنُ لك.</p><p><span class="qpc-hafs">﴿نُثَبِّتُ﴾</span>: نُقَوِّي ونُطَمْئِنُ.</p></div>"
  11,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَانَتِكُمۡ﴾</span>: حالتِكم التي أنتم عليها من الكفرِ.</p></div>"
  11,122,""
  11,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِلَّهِ غَيۡبُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: عِلْمُ جميعِ ما هو غائبٌ عن العبادِ فيهما.</p><p><span class="qpc-hafs">﴿وَتَوَكَّلۡ عَلَيۡهِ﴾</span>: اعتمِدْ وفَوِّضْ أمْرَك إليه وحدَه.</p></div>"
