quran[120]{c,v,t}:
  5,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡفُواْ بِٱلۡعُقُودِ﴾</span>: أتِمُّوا عهودَ اللهِ الموَثَّقَةَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَنۡعَـٰمِ﴾</span>: الإبِلِ، والبَقَرِ، والغَنَمِ.</p><p><span class="qpc-hafs">﴿إِلَّا مَا يُتۡلَىٰ عَلَيۡكُمۡ﴾</span>: إلا ما نَصَّ الله على تحريمِه كالميتةِ، ولحمِ الخِنْزيرِ.</p><p><span class="qpc-hafs">﴿غَيۡرَ مُحِلِّي ٱلصَّيۡدِ﴾</span>: أُحِلَّتْ لكم الأنعامُ حالَ تحريمِ الصيدِ عليكم.</p><p><span class="qpc-hafs">﴿وَأَنتُمۡ حُرُمٌ﴾</span>: بدخولِكم في الإحرامِ بالحجِّ أوالعُمرةِ.</p></div>"
  5,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُحِلُّواْ﴾</span>: لا يَقَعْ منكم الإخلالُ.</p><p><span class="qpc-hafs">﴿شَعَـٰٓئِرَ ٱللَّهِ﴾</span>: جَمْعُ شَعيرةٍ، وهي حُرُماتُه، ومعالمُه.</p><p><span class="qpc-hafs">﴿وَلَا ٱلشَّهۡرَ ٱلۡحَرَامَ﴾</span>: لا تَسْتَحِلُّوا القتالَ في الأشهرِ الحُرُم وهي: ذو القِعْدةِ وذو الحِجَّةِ والمحرمُ ورَجَبٌ.</p><p><span class="qpc-hafs">﴿وَلَا ٱلۡهَدۡيَ﴾</span>: ولا تَسْتَحِلُّوا أن تأخذُوا ما أهداه المرءُ من الأنعامِ إلى بيتِ اللهِ، أو تَحُولُوا بينَه وبينَ المكانِ الذي يُهدى إليه.</p><p><span class="qpc-hafs">﴿وَلَا ٱلۡقَلَـٰٓئِدَ﴾</span>: بأن تُؤْخَذَ غَصْبًا، و هي ضفائرُ صوفٍ يَضَعُونها في رَقَبَةِ البَهيمةِ علامةً على أنها هَدْيٌ.</p><p><span class="qpc-hafs">﴿وَلَآ ءَآمِّينَ ٱلۡبَيۡتَ ٱلۡحَرَامَ﴾</span>: ولا تَسْتَحِلُّوا قتالَ قاصدي البيتِ الحرامِ.</p><p><span class="qpc-hafs">﴿حَلَلۡتُمۡ﴾</span>: من إحرامِكم.</p><p><span class="qpc-hafs">﴿وَلَا يَجۡرِمَنَّكُمۡ﴾</span>: ولا يَحْمِلَنَّكم.</p><p><span class="qpc-hafs">﴿شَنَـَٔانُ﴾</span>: بُغْضُ.</p><p><span class="qpc-hafs">﴿أَن صَدُّوكُمۡ﴾</span>: لأَجْل صَدِّهم إياكم.</p><p><span class="qpc-hafs">﴿ٱلۡبِرِّ﴾</span>: العمل بِما أمَرَ اللهُ بالعملِ به.</p><p><span class="qpc-hafs">﴿وَٱلتَّقۡوَىٰ﴾</span>: اجتنابِ ما أمرَ اللهُ باجتنابِه.</p><p><span class="qpc-hafs">﴿ٱلۡإِثۡمِ﴾</span>: هوكلُّ فِعْلٍ أو قولٍ يُوجِبُ الذَّنْبَ.</p><p><span class="qpc-hafs">﴿وَٱلۡعُدۡوَ ٰ⁠نِ﴾</span>: التعَدِّي على الناسِ بما فيه ظُلْمٌ.</p></div>"
  5,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَيۡتَةُ﴾</span>: الحيَوانُ الذي تُفارِقُه الحياةُ من دونِ ذَبْحٍ.</p><p><span class="qpc-hafs">﴿وَٱلدَّمُ﴾</span>: أي: السائلُ.</p><p><span class="qpc-hafs">﴿وَمَآ أُهِلَّ لِغَيۡرِ ٱللَّهِ﴾</span>: ما ذُكِرَ عليه غيرُ اسمِ اللهِ عند الذَّبْحِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمُنۡخَنِقَةُ﴾</span>: التي حُبِسَ نَفَسُها حتى ماتَتْ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَوۡقُوذَةُ﴾</span>: التي ضُرِبَتْ بعصا أو حَجَرٍ حتى ماتَتْ.</p><p><span class="qpc-hafs">﴿وَٱلۡمُتَرَدِّيَةُ﴾</span>: التي سَقطَتْ من مكانٍ عالٍ، فماتَتْ.</p><p><span class="qpc-hafs">﴿وَٱلنَّطِيحَةُ﴾</span>: التي نَطَحَتْها شاةٌ أو بقرةٌ، فماتَتْ.</p><p><span class="qpc-hafs">﴿ٱلسَّبُعُ﴾</span>: كالأسدِ والنَّمِرِ.</p><p><span class="qpc-hafs">﴿ذَكَّيۡتُمۡ﴾</span>: ذَبَحْتُم قبلَ أن يموتَ، فهو حَلالٌ.</p><p><span class="qpc-hafs">﴿ٱلنُّصُبِ﴾</span>: حجارةٍ كان المشركونَ يذْبحون عليها في الجاهليةِ تَقَرُّبًا إلى الأصنامِ.</p><p><span class="qpc-hafs">﴿وَأَن تَسۡتَقۡسِمُواْ بِٱلۡأَزۡلَـٰمِ﴾</span>: القِداحِ التي كانوا يَطْلُبون بها عِلْمَ ما قُسِمَ لهم.</p><p><span class="qpc-hafs">﴿فِسۡقٌ﴾</span>: خُروجٌ عن طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡيَوۡمَ﴾</span>: يومَ فتحِ مكةَ في السنةِ الثامنةِ من الهجرة.</p><p><span class="qpc-hafs">﴿نِعۡمَتِي﴾</span>: بإكمالِ الدين، وفتحِ مكةَ، وقَهْرِ الكُفّارِ.</p><p><span class="qpc-hafs">﴿مَخۡمَصَةٍ﴾</span>: مَجاعةٍ.</p><p><span class="qpc-hafs">﴿مُتَجَانِفࣲ﴾</span>: مائلٍ.</p><p><span class="qpc-hafs">﴿لِّإِثۡمࣲ﴾</span>: حَرامٍ.</p></div>"
  5,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا عَلَّمۡتُم﴾</span>: أي: صَيْدُ ما دَرَّبْتُموه من الكِلابِ ونحوِها.</p><p><span class="qpc-hafs">﴿مُكَلِّبِينَ﴾</span>: جَمْعُ مُكَلِّبٍ، وهو مُعَلِّمُ الكِلابِ طريقةَ الاصطيادِ.</p></div>"
  5,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمُحۡصَنَـٰتُ﴾</span>: أي: ونكاحُ الحَرائرِ من النساءِ المؤمناتِ.</p><p><span class="qpc-hafs">﴿أُجُورَهُنَّ﴾</span>: مُهورَهُنَّ.</p><p><span class="qpc-hafs">﴿مُحۡصِنِينَ﴾</span>: أعِفّاءَ.</p><p><span class="qpc-hafs">﴿غَيۡرَ مُسَـٰفِحِينَ﴾</span>: غيرمرتكبين للزِّنى.</p><p><span class="qpc-hafs">﴿أَخۡدَانࣲ﴾</span>: عشيقاتٍ يَزْنُون بهنَّ سِرًّا.</p><p><span class="qpc-hafs">﴿حَبِطَ﴾</span>: بَطَلَ.</p></div>"
  5,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذَا قُمۡتُمۡ﴾</span>: إذا أرَدْتُم القيامَ، وأنتم على غير طُهْرٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمَرَافِقِ﴾</span>: جمعُ مِرْفَقٍ، وهو المِفْصَلُ الذي بينَ الذِّراعِ والعَضُدِ.</p><p><span class="qpc-hafs">﴿وَأَرۡجُلَكُمۡ﴾</span>: واغسِلُوا أرجُلَكم.</p><p><span class="qpc-hafs">﴿إِلَى ٱلۡكَعۡبَيۡنِ﴾</span>: هما العَظْمان البارِزان عند مُلْتقى السّاقِ بالقَدَمِ.</p><p><span class="qpc-hafs">﴿فَٱطَّهَّرُواْ﴾</span>: بالاغتسالِ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡغَآئِطِ﴾</span>: من قَضاءِ الحاجةِ.</p><p><span class="qpc-hafs">﴿لَـٰمَسۡتُمُ ٱلنِّسَآءَ﴾</span>: جامَعْتُموهُنَّ.</p><p><span class="qpc-hafs">﴿فَتَيَمَّمُواْ صَعِيدࣰا﴾</span>: فاضرِبُوا بأيدِيكم وجهَ الأرضِ.</p><p><span class="qpc-hafs">﴿حَرَجࣲ﴾</span>: ضِيقٍ.</p></div>"
  5,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعۡمَةَ ٱللَّهِ عَلَيۡكُمۡ﴾</span>: بهدايتِكم للإسلامِ.</p><p><span class="qpc-hafs">﴿وَمِيثَـٰقَهُ﴾</span>: وعَهْدَه الذي أخَذَه عليكم حين بايَعْتم الرسولَ ﷺ على السَّمْعِ والطاعةِ.</p></div>"
  5,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوَّ ٰ⁠مِينَ﴾</span>: أي بالحقِّ ابتغاءَ وجهِ اللهِ.</p><p><span class="qpc-hafs">﴿شُهَدَآءَ بِٱلۡقِسۡطِ﴾</span>: تَشْهَدون بالعدلِ.</p><p><span class="qpc-hafs">﴿وَلَا يَجۡرِمَنَّكُمۡ﴾</span>: ولا يَحْمِلَنَّكم.</p><p><span class="qpc-hafs">﴿شَنَـَٔانُ﴾</span>: عَداوةُ.</p></div>"
  5,9,""
  5,10,""
  5,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَمَّ﴾</span>: عَزَمَ.</p><p><span class="qpc-hafs">﴿أَن يَبۡسُطُوٓاْ إِلَيۡكُمۡ أَيۡدِيَهُمۡ﴾</span>: أنَ يبْطِشَ يهودُ بني النَّضِيرِ بكم، يومَ سار إليهم الرسولُ ﷺ ونَفَرٌ من أصحابِه في شأنٍ معهم.</p><p><span class="qpc-hafs">﴿فَكَفَّ﴾</span>: فصَرَفَ.</p></div>"
  5,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَ﴾</span>: العهدَ المؤكَّدَ بالوفاءِ به.</p><p><span class="qpc-hafs">﴿ٱثۡنَيۡ عَشَرَ نَقِيبࣰا﴾</span>: عَريفًا من كبارِ القومِ، بعَددِ فروعِهم، يأخُذُون عليهم العهدَ.</p><p><span class="qpc-hafs">﴿وَعَزَّرۡتُمُوهُمۡ﴾</span>: ونَصَرْتُموهم، وعَظَّمتُموهم.</p><p><span class="qpc-hafs">﴿وَأَقۡرَضۡتُمُ ٱللَّهَ﴾</span>: وأنْفَقْتم في سبيلهِ.</p><p><span class="qpc-hafs">﴿ضَلَّ سَوَآءَ ٱلسَّبِيلِ﴾</span>: أخطأ وسَطَ طريقِ الحقِّ.</p></div>"
  5,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِمَا﴾</span>: فبسببِ.</p><p><span class="qpc-hafs">﴿لَعَنَّـٰهُمۡ﴾</span>: طَرَدْناهم مِن رحمتِنا.</p><p><span class="qpc-hafs">﴿قَـٰسِيَةࣰ﴾</span>: غليظةً لا تَعِي خيرًا.</p><p><span class="qpc-hafs">﴿ٱلۡكَلِمَ﴾</span>: التوراةَ.</p><p><span class="qpc-hafs">﴿وَنَسُواْ حَظࣰّا﴾</span>: تَرَكُوا قَدْرًا مِمّا أُمِرُوا به.</p><p><span class="qpc-hafs">﴿وَلَا تَزَالُ تَطَّلِعُ عَلَىٰ خَآئِنَةࣲ مِّنۡهُمۡ﴾</span>: ولا تزال  أيها الرسولُ  تَقِفُ من اليهودِ على خيانةٍ، وغَدْرٍ.</p></div>"
  5,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَهُمۡ﴾</span>: العهدَ المؤكَّدَ على طاعتي</p><p><span class="qpc-hafs">﴿فَأَغۡرَيۡنَا﴾</span>: فأَلْقَيْنا.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمُ﴾</span>: بينَ النصارى، فكلُّ فِرْقَةٍ تُعادي صاحبتَها.</p></div>"
  5,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَسُولُنَا﴾</span>: محمدٌ ﷺ.</p><p><span class="qpc-hafs">﴿مِّمَّا كُنتُمۡ تُخۡفُونَ﴾</span>: كالرَّجْمِ للزّاني.</p><p><span class="qpc-hafs">﴿وَيَعۡفُواْ عَن كَثِيرࣲ﴾</span>: ممّا تُخْفُونه، فيَتْرُكُ بيانَه.</p><p><span class="qpc-hafs">﴿نُورࣱ﴾</span>: محمدٌ ﷺ.</p><p><span class="qpc-hafs">﴿وَكِتَـٰبࣱ﴾</span>: القرآنُ الكريمُ.</p></div>"
  5,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبُلَ ٱلسَّلَـٰمِ﴾</span>: طريقَ اللهِ الذي شَرَعَه.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: طريقٍ لاعِوَجَ فيه.</p></div>"
  5,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَن يَمۡلِكُ مِنَ ٱللَّهِ شَيۡـًٔا﴾</span>: فمَنِ الذي يَقْدِرُ أن يمنعَ من أمْرِ اللهِ؟</p></div>"
  5,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحۡنُ أَبۡنَـٰٓؤُاْ ٱللَّهِ﴾</span>: فقالت اليهودُ: عزيرٌ ابنُ اللهِ، وقالت النصارى: المسيحُ ابنُ اللهِ.</p><p><span class="qpc-hafs">﴿أَنتُم بَشَرࣱ﴾</span>: أنتم خَلْقٌ مثلُ سائرِ بني آدمَ يحاسبُهم على أعمالهم.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ.</p></div>"
  5,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَسُولُنَا﴾</span>: محمدٌ ﷺ</p><p><span class="qpc-hafs">﴿عَلَىٰ فَتۡرَةࣲ مِّنَ ٱلرُّسُلِ﴾</span>: على انقطاعٍ من الرسلِ مُدّةً من الزمانِ.</p><p><span class="qpc-hafs">﴿أَن تَقُولُواْ﴾</span>: لئلّا تقُولوا.</p></div>"
  5,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلَكُم مُّلُوكࣰا﴾</span>: وجْهُ الامتنانِ كثرةُ الملوكِ والأنبياءِ فيهم، أو أنكم تملكون أمرَكم بعد أن كنتم مملوكين لفرعونَ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡعَـٰلَمِينَ﴾</span>: عالَمِي زمانِكم.</p></div>"
  5,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضَ ٱلۡمُقَدَّسَةَ﴾</span>: المطهَّرَةَ المباركةَ، وهي بيتُ المَقْدِسِ وما حولَها.</p><p><span class="qpc-hafs">﴿وَلَا تَرۡتَدُّواْ عَلَىٰٓ أَدۡبَارِكُمۡ﴾</span>: ولا تَرْجِعُوا عن قتالِ الأشدّاء.</p></div>"
  5,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَبَّارِينَ﴾</span>: أشدّاءَ، لاطاقَةَ لنا بحَرْبِهم.</p></div>"
  5,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخَافُونَ﴾</span>: أي: اللهَ.</p><p><span class="qpc-hafs">﴿ٱدۡخُلُواْ عَلَيۡهِمُ ٱلۡبَابَ﴾</span>: ادخُلوا على هؤلاءِ الأشدّاءِ بابَ مدينتِهم.</p></div>"
  5,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن نَّدۡخُلَهَآ﴾</span>: لن نَدْخُلَ مدينةَ الجبّارين.</p></div>"
  5,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَآ أَمۡلِكُ﴾</span>: لا أقْدِرُ أن أحملَ أحدًا على ما أُحِبُّ.</p><p><span class="qpc-hafs">﴿فَٱفۡرُقۡ﴾</span>: فاقضِ</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقِينَ﴾</span>: الخارجينَ عن طاعةِ اللهِ.</p></div>"
  5,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّهَا﴾</span>: الأرضَ المقدسةَ.</p><p><span class="qpc-hafs">﴿فَلَا تَأۡسَ﴾</span>: فلاتحزَنْ.</p></div>"
  5,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡنَيۡ ءَادَمَ﴾</span>: قابيلَ، وهابيلَ.</p><p><span class="qpc-hafs">﴿قَرَّبَا قُرۡبَانࣰا﴾</span>: قَدَّما ما يُتَقَرَّبُ به إلى اللهِ.</p><p><span class="qpc-hafs">﴿أَحَدِهِمَا﴾</span>: هابيل.</p></div>"
  5,28,""
  5,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبُوٓأَ بِإِثۡمِي﴾</span>: تَرْجِعَ حاملًا ذَنْبَ قَتْلي.</p><p><span class="qpc-hafs">﴿وَإِثۡمِكَ﴾</span>: الذي صار عليك بذنوبِك من قَبْلِ قَتْلي.</p></div>"
  5,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَوَّعَتۡ﴾</span>: فشَجَّعَتْ.</p></div>"
  5,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡحَثُ﴾</span>: يَحْفِرُ حُفْرَةً.</p><p><span class="qpc-hafs">﴿سَوۡءَةَ﴾</span>: ما تسوءُ رؤيتُه، وهو الجَسَدُ المتغيِّرُ.</p><p><span class="qpc-hafs">﴿فَأُوَ ٰ⁠رِيَ﴾</span>: فأَسْتُرَ.</p></div>"
  5,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ أَجۡلِ ذَ ٰ⁠لِكَ﴾</span>: بسببِ جنايةِ القَتْلِ.</p><p><span class="qpc-hafs">﴿بِغَيۡرِ نَفۡسٍ﴾</span>: تُوجِبُ القِصاصَ.</p><p><span class="qpc-hafs">﴿فَسَادࣲ﴾</span>: مُوجِبٍ للقَتْلِ.</p><p><span class="qpc-hafs">﴿لَمُسۡرِفُونَ﴾</span>: لمتجاوِزُون حُدودَ الله.</p></div>"
  5,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ يُصَلَّبُوٓاْ﴾</span>: بأن يُشَدَّ الجاني على خَشَبةٍ.</p><p><span class="qpc-hafs">﴿مِّنۡ خِلَـٰفٍ﴾</span>: بقَطْعِ يُمنى اليدَيْن مع يُسْرى الرِّجْلَين، أو يُسرى اليدين مع يُمنى الرِّجْلَين.</p><p><span class="qpc-hafs">﴿أَوۡ يُنفَوۡاْ﴾</span>: أو يُنْفَوا إلى بلدٍ غيرِ بلدِهم، ويُحْبَسُوا.</p><p><span class="qpc-hafs">﴿خِزۡيࣱ﴾</span>: ذُلٌّ.</p></div>"
  5,34,""
  5,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَسِيلَةَ﴾</span>: مايُتَقَرَّبُ به إلى اللهِ بطاعتِه.</p></div>"
  5,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِثۡلَهُۥ﴾</span>: ومَلكُوا مِثْلَه.</p></div>"
  5,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّقِيمࣱ﴾</span>: دائمٌ.</p></div>"
  5,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَكَـٰلࣰا﴾</span>: عقوبةً.</p></div>"
  5,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظُلۡمِهِۦ﴾</span>: سَرِقَتِه.</p></div>"
  5,40,""
  5,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡكُفۡرِ﴾</span>: في إنكارِ نبوَّتِك.</p><p><span class="qpc-hafs">﴿ءَامَنَّا بِأَفۡوَ ٰ⁠هِهِمۡ﴾</span>: هم المنافقون.</p><p><span class="qpc-hafs">﴿وَمِنَ ٱلَّذِينَ هَادُواْ﴾</span>: لا يَحْزُنْك تَسَرُّعُ اليهودِ إلى إنكارِ نبوَّتِكِ.</p><p><span class="qpc-hafs">﴿لِلۡكَذِبِ﴾</span>: مايفْتَريه أحبارُ اليهودِ.</p><p><span class="qpc-hafs">﴿لَمۡ يَأۡتُوكَ﴾</span>: لم يَحْضُروا مجلسَك تَكَبُّرًا.</p><p><span class="qpc-hafs">﴿ٱلۡكَلِمَ﴾</span>: التوراةَ، هي جمعُ «كلمة».</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ مَوَاضِعِهِۦ﴾</span>: من بعدِ ما عَقَلُوه موضوعًا في مواضِعِه.</p><p><span class="qpc-hafs">﴿أُوتِيتُمۡ هَـٰذَا﴾</span>: إنْ جاءكم محمدٌ ﷺ بما يُوافِقُ الحكمَ الذي بَدَّ لْناه من أحكامِ التوراةِ.</p><p><span class="qpc-hafs">﴿فِتۡنَتَهُۥ﴾</span>: ضَلالتَه.</p><p><span class="qpc-hafs">﴿فَلَن تَمۡلِكَ﴾</span>: فلن تستطيعَ دَفْعَ ذلك.</p><p><span class="qpc-hafs">﴿خِزۡيࣱ﴾</span>: ذُلٌّ.</p></div>"
  5,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلسُّحۡتِ﴾</span>: للمال الحَرامِ كالرَّشوة.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعدلِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُقۡسِطِينَ﴾</span>: العادِلين.</p></div>"
  5,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَلَّوۡنَ مِنۢ بَعۡدِ ذَ ٰ⁠لِكَ﴾</span>: من بعدِ حُكْمِك إذا لم يُرْضِهم.</p></div>"
  5,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡلَمُواْ﴾</span>: انقادُوا لحُكْمِ اللهِ.</p><p><span class="qpc-hafs">﴿لِلَّذِينَ هَادُواْ﴾</span>: اليهودِ.</p><p><span class="qpc-hafs">﴿وَٱلرَّبَّـٰنِيُّونَ﴾</span>: والعُبّادُ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَحۡبَارُ﴾</span>: والعلماء.</p><p><span class="qpc-hafs">﴿ٱسۡتُحۡفِظُواْ﴾</span>: اسْتُودِعُوا عِلْمَه.</p><p><span class="qpc-hafs">﴿وَكَانُواْ عَلَيۡهِ شُهَدَآءَ﴾</span>: أي: الربّانيُّون والأحبارُ شهداءُ لمحمدٍ ﷺ بأنه نبيٌّ يَقْضي بالحقِّ.</p><p><span class="qpc-hafs">﴿وَلَا تَشۡتَرُواْ بِـَٔايَـٰتِي ثَمَنࣰا قَلِيلࣰا﴾</span>: ولا تأخُذُوا بتَرْكِ حُكمي مُقابِلًا حقيرًا.</p></div>"
  5,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلنَّفۡسِ﴾</span>: تُقْتَلُ بالنفسِ.</p><p><span class="qpc-hafs">﴿وَٱلۡجُرُوحَ قِصَاصࣱ﴾</span>: يُقْتَصُّ في الجُروحِ.</p><p><span class="qpc-hafs">﴿تَصَدَّقَ بِهِۦ﴾</span>: تجاوَزَ عن حَقِّه.</p><p><span class="qpc-hafs">﴿كَفَّارَةࣱ﴾</span>: تكفيرٌ لذنوبهِ.</p></div>"
  5,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَفَّيۡنَا﴾</span>: وأتْبَعْنا.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ ءَاثَـٰرِهِم﴾</span>: على آثارِ النبيِّين.</p><p><span class="qpc-hafs">﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾</span>: مصدِّقًا للتوراةِ، عاملًا بمافيها ممّالم يَنْسَخْه كتابُه الإنجيلُ.</p></div>"
  5,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارجون عن طاعةِ اللهِ.</p></div>"
  5,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَيۡكَ﴾</span>: إلى محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾</span>: أنزَلْناه بتصديقِ ماقبلَه.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡكِتَـٰبِ﴾</span>: من الكُتُبِ.</p><p><span class="qpc-hafs">﴿وَمُهَيۡمِنًا عَلَيۡهِ﴾</span>: وشاهِدًا بصحةِ الكتبِ المنزَّلَةِ، ورقيبًا عليها، وحافظًا لما فِيها.</p><p><span class="qpc-hafs">﴿لِكُلࣲّ﴾</span>: لكلِّ أمةٍ.</p><p><span class="qpc-hafs">﴿شِرۡعَةࣰ﴾</span>: شريعةً.</p><p><span class="qpc-hafs">﴿وَمِنۡهَاجࣰا﴾</span>: وطريقًا واضحًا. وهذا قبلَ نَسْخِ الشَّرائعِ السابقةِ بالقرآنِ، وأمّا بعدَه فلا مِنهاجَ إلا ما جاءَ به.</p><p><span class="qpc-hafs">﴿لَجَعَلَكُمۡ﴾</span>: لَجعَلَ شرائعَكم.</p><p><span class="qpc-hafs">﴿لِّيَبۡلُوَكُمۡ﴾</span>: شاءَ الابتلاءَليختبرَكم، فيتميَّزَ المطيعُ من العاصي.</p><p><span class="qpc-hafs">﴿فَٱسۡتَبِقُواْ﴾</span>: فسارِعُوا.</p></div>"
  5,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡتِنُوكَ﴾</span>: يَصْرِفُوك، فلا تعمَلَ بما فيه.</p><p><span class="qpc-hafs">﴿فَإِن تَوَلَّوۡاْ﴾</span>: فإن أعْرَضُوا عَمّا تَحْكُمُ به</p><p><span class="qpc-hafs">﴿بِبَعۡضِ ذُنُوبِهِمۡ﴾</span>: بسببِ ذنوبٍ اكتسبوها.</p></div>"
  5,50,""
  5,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أنصارًا على أهلِ الإيمان.</p><p><span class="qpc-hafs">﴿بَعۡضُهُمۡ أَوۡلِيَآءُ بَعۡضࣲ﴾</span>: بعضُ اليهودِ أولياءُ بعضهم الآخَرِ، وكذا النَّصارى.</p></div>"
  5,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرَضࣱ﴾</span>: نفاقٌ، وشكٌّ.</p><p><span class="qpc-hafs">﴿يُسَـٰرِعُونَ فِيهِمۡ﴾</span>: يبادِرُون في مُوالاةِ اليهودِ.</p><p><span class="qpc-hafs">﴿دَآئِرَةࣱ﴾</span>: مايَدُور من المَكارهِ، فينتصرُ اليهودُ، فينالون منّا.</p><p><span class="qpc-hafs">﴿بِٱلۡفَتۡحِ﴾</span>: فتحِ مكة.</p><p><span class="qpc-hafs">﴿مَآ أَسَرُّواْ﴾</span>: ما أضمَرُوه من موالاةِ الكافرين.</p></div>"
  5,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: بأغلظِ الأَيْمانِ.</p><p><span class="qpc-hafs">﴿حَبِطَتۡ﴾</span>: بَطَلَتْ، فلاثَوابَ لها.</p></div>"
  5,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَذِلَّةٍ﴾</span>: رُحماءَ.</p><p><span class="qpc-hafs">﴿أَعِزَّةٍ﴾</span>: أشدّاءَ.</p></div>"
  5,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيُّكُمُ﴾</span>: ناصرُكم.</p><p><span class="qpc-hafs">﴿رَ ٰ⁠كِعُونَ﴾</span>: خاضِعُون للهِ.</p></div>"
  5,56,""
  5,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوࣰا﴾</span>: سُخْرِيَّةً واستهزاءً.</p></div>"
  5,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَعۡقِلُونَ﴾</span>: أي: حقيقةَ العبادةِ.</p></div>"
  5,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّ أَكۡثَرَكُمۡ فَـٰسِقُونَ﴾</span>: وإيمانَنا بأنّ أكثرَكم خارجون عن طاعةِ اللهِ.</p></div>"
  5,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثُوبَةً﴾</span>: جزاءً.</p><p><span class="qpc-hafs">﴿وَعَبَدَ﴾</span>: ومَن عَبَدَ.</p><p><span class="qpc-hafs">﴿ٱلطَّـٰغُوتَ﴾</span>: كلُّ مَن عُبِدَ من دونِ اللهِ.</p><p><span class="qpc-hafs">﴿شَرࣱّ مَّكَانࣰا﴾</span>: ساء مكانُهم في الآخرة.</p><p><span class="qpc-hafs">﴿سَوَآءِ ٱلسَّبِيلِ﴾</span>: الطريقِ الصحيحِ.</p></div>"
  5,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءُوكُمۡ﴾</span>: هم أناسٌ من اليهود جاؤُوكم بالكفرِ.</p></div>"
  5,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡإِثۡمِ﴾</span>: الكفرِ.</p><p><span class="qpc-hafs">﴿ٱلسُّحۡتَ﴾</span>: الحَرامَ كالرَّشوةِ.</p></div>"
  5,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ٱلرَّبَّـٰنِيُّونَ﴾</span>: أئمتُهم.</p><p><span class="qpc-hafs">﴿وَٱلۡأَحۡبَارُ﴾</span>: علماؤُهم.</p></div>"
  5,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡلُولَةٌ﴾</span>: مَحْبوسةٌ عن فِعْلِ الخيرِ.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنࣰا﴾</span>: غُلُوًّا في إنكارِ ما عَلِمُوا صِحَّتَه مِن نبوَّةِ محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمُ﴾</span>: بين طوائفِ اليهودِ.</p></div>"
  5,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكَفَّرۡنَا﴾</span>: لَمَحَوْنا.</p></div>"
  5,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن فَوۡقِهِمۡ﴾</span>: لَأَنْزَلَ عليهم المطرَ، فتنبُتُ لهم به الأرضُ.</p><p><span class="qpc-hafs">﴿وَمِن تَحۡتِ أَرۡجُلِهِم﴾</span>: مما تُخْرِجُه الأرض من بَرَكَتِها.</p><p><span class="qpc-hafs">﴿مُّقۡتَصِدَةࣱ﴾</span>: معتدلةٌ، ليسَتْ غاليةً.</p></div>"
  5,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡصِمُكَ﴾</span>: يَحْفَظُك، فلا تُنالُ بسوءٍ.</p></div>"
  5,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَسۡتُمۡ عَلَىٰ شَيۡءٍ﴾</span>: لَسْتُمْ على حَظٍّ من الدِّين يُعْتَدُّ به.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنࣰا وَكُفۡرࣰا﴾</span>: تَجَبُّرًا وجُحودًا.</p><p><span class="qpc-hafs">﴿فَلَا تَأۡسَ﴾</span>: فلا تَحْزَنْ.</p></div>"
  5,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلصَّـٰبِـُٔونَ﴾</span>: أي: كذلك، وهم قومٌ باقون على فِطْرتِهم، ولادِينَ مقرَّرٌلهم.</p></div>"
  5,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَ﴾</span>: العهدَ المؤكَّدَ.</p></div>"
  5,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَسِبُوٓاْ أَلَّا تَكُونَ فِتۡنَةࣱ﴾</span>: وظنَّ هؤلاء اليهودُ ألّا يقعَ عليهم من اللهِ ابتلاءٌ بالشدائدِ.</p></div>"
  5,72,""
  5,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَالِثُ ثَلَـٰثَةࣲ﴾</span>: الأبُ، والابنُ، وروحُ القُدُسِ.</p></div>"
  5,74,""
  5,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: تَقَدَّمَتْ.</p><p><span class="qpc-hafs">﴿يَأۡكُلَانِ ٱلطَّعَامَ﴾</span>: يحتاجان إليه كسائرِ البَشَرِ، وليس هذا شأنَ الربِّ.</p><p><span class="qpc-hafs">﴿يُؤۡفَكُونَ﴾</span>: يُصْرَفون عن الحقِّ الذي بَيَّنتُه لهم.</p></div>"
  5,76,""
  5,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَغۡلُواْ﴾</span>: لا تتجاوزُوا الحقَّ.</p><p><span class="qpc-hafs">﴿قَوۡمࣲ﴾</span>: هم اليهودُ.</p><p><span class="qpc-hafs">﴿سَوَآءِ ٱلسَّبِيلِ﴾</span>: قَصْدِ الطَّريقِ.</p></div>"
  5,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لُعِنَ﴾</span>: طُرِدَ من رحمةِ اللهِ.</p></div>"
  5,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَتَنَاهَوۡنَ﴾</span>: لا ينتَهُون، ولا يَنْهى بعضُهم بعضًا.</p></div>"
  5,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن سَخِطَ ٱللَّهُ عَلَيۡهِمۡ﴾</span>: ما قَدَّمَتْ لهم أنفسُهم هو سَخَطُ اللهِ عليهم.</p></div>"
  5,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰسِقُونَ﴾</span>: خارجُون عن طاعةِ اللهِ.</p></div>"
  5,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ قَالُوٓاْ﴾</span>: هم وفْدُ نَصارى الحبشةِ، وقد دَخَلُوا في الإسلامِ.</p><p><span class="qpc-hafs">﴿رُهۡبَانࣰا﴾</span>: مُتَعَبِّدين.</p></div>"
  5,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّـٰهِدِينَ﴾</span>: الذين يَشْهَدُون لأنبيائِك يومَ القيامةِ أنهم قد بَلَّغُوا أمَمهم رسالاتِك.</p></div>"
  5,84,""
  5,85,""
  5,86,""
  5,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَعۡتَدُوٓاْ﴾</span>: ولا تتجاوَزُوا حدودَ ما حَرَّم اللهُ.</p></div>"
  5,88,""
  5,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱللَّغۡوِ﴾</span>: بما لا تَقْصِدُون عَقْدَه.</p><p><span class="qpc-hafs">﴿عَقَّدتُّمُ﴾</span>: بما أوْجَبْتُموه على أنفسِكم.</p><p><span class="qpc-hafs">﴿مِنۡ أَوۡسَطِ﴾</span>: ممّا تعتادُونه من غير إسرافٍ أو تَقْتيرٍ.</p><p><span class="qpc-hafs">﴿وَٱحۡفَظُوٓاْ أَيۡمَـٰنَكُمۡ﴾</span>: باجتنابِ المسارعةِ إلى الحَلْفِ، والحِنْثِ به.</p></div>"
  5,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَيۡسِرُ﴾</span>: القِمارُ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَنصَابُ﴾</span>: الحجارةُ التي يَذْبَحُون عندها تعظيمًا لها.</p><p><span class="qpc-hafs">﴿وَٱلۡأَزۡلَـٰمُ﴾</span>: القِداحُ التي يَسْتَقْسِمُون بها قبلَ الشُّروعِ في شيءٍ.</p><p><span class="qpc-hafs">﴿رِجۡسࣱ﴾</span>: إثمٌ وقَذَرٌ.</p></div>"
  5,91,""
  5,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّيۡتُمۡ﴾</span>: أعْرَضْتُم.</p></div>"
  5,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُنَاحࣱ﴾</span>: حَرَجٌ في شُرْبِهم الخمرَ قبلَ تحريمِها.</p></div>"
  5,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَبۡلُوَنَّكُمُ﴾</span>: لَيختبرَنَّكم.</p><p><span class="qpc-hafs">﴿لِيَعۡلَمَ ٱللَّهُ﴾</span>: عِلْمًا ظاهرًا للخَلْقِ.</p><p><span class="qpc-hafs">﴿ٱعۡتَدَىٰ﴾</span>: تجاوزَ حدودَ اللهِ.</p></div>"
  5,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُرُمࣱ﴾</span>: مُحْرِمُون بحَجٍّ أو عُمْرَةٍ.</p><p><span class="qpc-hafs">﴿مِّثۡلُ مَا قَتَلَ مِنَ ٱلنَّعَمِ﴾</span>: يَذْبَحُ مثلَ ذلك الصيدِ من بهيمةِ الأنعامِ: الإبلِ، أو البقرِ، أو الغنمِ.</p><p><span class="qpc-hafs">﴿ٱلۡكَعۡبَةِ﴾</span>: الحَرَمِ.</p><p><span class="qpc-hafs">﴿طَعَامُ مَسَـٰكِينَ﴾</span>: يَشْتري بقيمةِ المِثْل من النَّعَمِ طعامًا يُهديه لفقراءِ الحَرَمِ.</p><p><span class="qpc-hafs">﴿عَدۡلُ ذَ ٰ⁠لِكَ﴾</span>: ما عادَلَه من غيرِ جِنْسِه، فيصومُ بدَلَ الإطعامِ يومًا عن كل نصفِ صاعٍ. والجاني مُخَيَّرٌ بين الأنواعِ المذكورة.</p><p><span class="qpc-hafs">﴿وَبَالَ أَمۡرِهِۦ﴾</span>: عاقبةَ فِعْلهِ.</p><p><span class="qpc-hafs">﴿سَلَفَ﴾</span>: مضى قبلَ التحريمِ.</p></div>"
  5,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَحۡرِ﴾</span>: هوكلُّ ماءٍ فيه صَيْدٌ.</p><p><span class="qpc-hafs">﴿وَطَعَامُهُۥ﴾</span>: ماقَذَفَ به البحرُ، وطَفا عليه ميتًا.</p><p><span class="qpc-hafs">﴿مَتَـٰعࣰا لَّكُمۡ﴾</span>: منفعةً وقُوتًا للمُقيمين منكم.</p><p><span class="qpc-hafs">﴿وَلِلسَّيَّارَةِ﴾</span>: جَمْعُ سَيّار، وهو المسافرُ.</p><p><span class="qpc-hafs">﴿حُرُمࣰا﴾</span>: مُحْرِمين بحَجٍ أو عُمرةٍ.</p></div>"
  5,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِيَـٰمࣰا لِّلنَّاسِ﴾</span>: صَلاحًا لدينهم، وقِوامًا لأمرِهم، وأمْنًا لمَن تَوَجَّه إليها.</p><p><span class="qpc-hafs">﴿وَٱلشَّهۡرَ ٱلۡحَرَامَ﴾</span>: وهي الأشهُر التي حَرَّمَ اللهُ فيها القتالَ، وهي: ذو القِعدةِ وذو الحِجَّةِ والمحرمُ ورَجَبٌ، يدفَعُ اللهُ بعضَ الناس عن بعضٍ بها.</p><p><span class="qpc-hafs">﴿وَٱلۡهَدۡيَ﴾</span>: مايُهدى إلى الحَرَم من بهيمةِ الأنعام.</p><p><span class="qpc-hafs">﴿وَٱلۡقَلَـٰٓئِدَ﴾</span>: ماقُلِّد إشعارًا بأنه يُقْصَدُ به النُّسُكُ، وهي ضَفائرُ صُوفٍ يَضَعُونها في رَقَبَةِ البَهيمةِ.</p></div>"
  5,98,""
  5,99,""
  5,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَبِيثُ وَٱلطَّيِّبُ﴾</span>: كلُّ ما يَتَّصِفُ بوَصْفِ الخُبْثِ والطَّيبِ من الأشخاصِ، والأعمالِ، والأقوالِ.</p><p><span class="qpc-hafs">﴿يَـٰٓأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: يا أصحابَ العقولِ السِّليمةِ.</p></div>"
  5,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَسۡـَٔلُواْ عَنۡ أَشۡيَآءَ﴾</span>: عَمّالاحاجةَ لكم بالسؤالِ عنه.</p><p><span class="qpc-hafs">﴿تُبۡدَ لَكُمۡ﴾</span>: (الثانية): تَظْهَرْ لكم بجوابِ النبيِّ ﷺ، أو بما يَنْزِلُ به الوحيُ، فيكونُ ذلك سببًا للتكاليفِ الشاقّةِ.</p><p><span class="qpc-hafs">﴿عَفَا ٱللَّهُ عَنۡهَا﴾</span>: عمّا سَلَفَ من مَسْألَتِكم.</p></div>"
  5,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ أَصۡبَحُواْ بِهَا كَـٰفِرِينَ﴾</span>: فلمّا أُمِرُوا بها جَحَدُوها.</p></div>"
  5,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا جَعَلَ ٱللَّهُ﴾</span>: ما شَرَعَ اللهُ للمشركين ما ابتدَعُوه في بهيمةِ الأنعامِ من تَرْكِ الانتفاعِ بها، وتَرْكِها للأصنامِ.</p><p><span class="qpc-hafs">﴿مِنۢ بَحِيرَةࣲ﴾</span>: هي التي تُشَقُّ أُذُنُها إذا ولَدَتْ عددًا من البُطونِ، أو التي لا يَحْلُبها أحدٌ من الناسِ.</p><p><span class="qpc-hafs">﴿وَلَا سَآئِبَةࣲ﴾</span>: هي التي تُترك للأصنام إثْر نَذْرٍ.</p><p><span class="qpc-hafs">﴿وَلَا وَصِيلَةࣲ﴾</span>: هي التي تتصلُ وِلادتُها بأنثى بعد أنثى.</p><p><span class="qpc-hafs">﴿وَلَا حَامࣲ﴾</span>: هو الذَّكَرُ من الإبِلِ إذا نُتِجَ مِن صُلْبِه عددٌ من الإبِلِ، أو الذي يُعفى من الحَمْلِ.</p></div>"
  5,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسۡبُنَا﴾</span>: كافينا.</p></div>"
  5,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَيۡكُمۡ أَنفُسَكُمۡ﴾</span>: ألْزِمُوا أنفسَكم بطاعةِ اللهِ.</p></div>"
  5,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهَـٰدَةُ بَيۡنِكُمۡ﴾</span>: فليَشْهَدْ على الوصيةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَوۡتُ﴾</span>: علاماتُ الموتِ.</p><p><span class="qpc-hafs">﴿ذَوَا عَدۡلࣲ﴾</span>: ذوا رُشْدٍ وأمانةٍ.</p><p><span class="qpc-hafs">﴿غَيۡرِكُمۡ﴾</span>: من غيرِ المسلمين عند الحاجةِ في السفرِ للوصيةِ.</p><p><span class="qpc-hafs">﴿تَحۡبِسُونَهُمَا﴾</span>: تَسْتَوْقِفونهما.</p><p><span class="qpc-hafs">﴿ٱلصَّلَوٰةِ﴾</span>: صلاةِ العصرِ.</p><p><span class="qpc-hafs">﴿إِنِ ٱرۡتَبۡتُمۡ﴾</span>: في شَهادتِهما، فإن صَدَّقْتُموهما فلا حاجةَ إلى القَسَم، وليس على شهودِ المسلمين إقسامٌ.</p><p><span class="qpc-hafs">﴿لَا نَشۡتَرِي بِهِۦ ثَمَنࣰا﴾</span>: لا نأخُذُ عِوَضًا من الدُّنيا، ولا نُحابي أحدًا.</p><p><span class="qpc-hafs">﴿وَلَوۡ كَانَ ذَا قُرۡبَىٰ﴾</span>: ولو كانَ المشهودُ له قريبًا.</p></div>"
  5,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنۡ عُثِرَ عَلَىٰٓ أَنَّهُمَا ٱسۡتَحَقَّآ إِثۡمࣰا﴾</span>: إنْ ظَهَرَ لأولياءِ الميتِ أنّ الشاهدَين الكافرَين قد أثِما بالخيانةِ في الشهادةِ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلَّذِينَ ٱسۡتَحَقَّ عَلَيۡهِمُ ٱلۡأَوۡلَيَـٰنِ﴾</span>: أي: الأَجْدران من الذين وجَبَ عليهم أن يكونا أقربَ أولياءِ الميتِ إليه.</p><p><span class="qpc-hafs">﴿وَمَا ٱعۡتَدَيۡنَآ﴾</span>: وما تجاوَزْنا الحقَّ في أيْمانِنا.</p></div>"
  5,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ أَدۡنَىٰٓ أَن يَأۡتُواْ بِٱلشَّهَـٰدَةِ عَلَىٰ وَجۡهِهَآ﴾</span>: ذلك الحكمُ عند الارتيابِ في الشاهدَين الكافرَين من الحَلْفِ أقربُ إلى أن يأتُوا بالشهادة على حقيقتِها.</p><p><span class="qpc-hafs">﴿أَوۡ يَخَافُوٓاْ أَن تُرَدَّ أَيۡمَـٰنُۢ بَعۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: أو خَشْيَةَ أن تُرَدَّ اليمينُ الكاذبةُ من قِبَلِ أصحابِ الحقِّ الذين يَحْلِفُون بما يتضَمَّنُ كَذِبَ الكافرين.</p></div>"
  5,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَاذَآ أُجِبۡتُمۡ﴾</span>: ماذا أجابَتْكم أممكُم؟</p><p><span class="qpc-hafs">﴿لَا عِلۡمَ لَنَآ﴾</span>: لا نعلمُ ما في صدورِهم، وما أحدَثُوا بعدنا.</p></div>"
  5,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعۡمَتِي عَلَيۡكَ﴾</span>: إذ خَلَقْتُك من غيرِ أبٍ.</p><p><span class="qpc-hafs">﴿وَعَلَىٰ وَ ٰ⁠لِدَتِكَ﴾</span>: إذ رَفَعْتُ شأنَها، وبَرَّأتُها مما نُسِبَ إليها.</p><p><span class="qpc-hafs">﴿بِرُوحِ ٱلۡقُدُسِ﴾</span>: جبريلَ.</p><p><span class="qpc-hafs">﴿فِي ٱلۡمَهۡدِ﴾</span>: وأنت رضيعٌ قبل أوانِ الكلامِ.</p><p><span class="qpc-hafs">﴿وَكَهۡلࣰا﴾</span>: وكبيرًا، لا يتفاوَتُ كلامُك في الحالَين.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: وعَلَّمْتُك الكتابةَ.</p><p><span class="qpc-hafs">﴿وَٱلۡحِكۡمَةَ﴾</span>: قوةَ الفهمِ، والإدراكِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَكۡمَهَ﴾</span>: مَن وُلِدَ أعمى.</p><p><span class="qpc-hafs">﴿تُخۡرِجُ ٱلۡمَوۡتَىٰ﴾</span>: من قُبورِهم أحياءً.</p><p><span class="qpc-hafs">﴿كَفَفۡتُ بَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ﴾</span>: مَنَعْتُهم حين هَمُّوا بقَتْلِكَ.</p></div>"
  5,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَوَارِيِّـۧنَ﴾</span>: خُلَصاءِ عيسى عليه السلام.</p></div>"
  5,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلشَّـٰهِدِينَ﴾</span>: على هذه الآيةِ، فتكونُ حُجّةً لك.</p></div>"
  5,113,""
  5,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَكُونُ لَنَا عِيدࣰا﴾</span>: نَتَّخِذُ يومَ نُزُولِها عيدًا لنا، فنُعَظِّمُه.</p><p><span class="qpc-hafs">﴿لِّأَوَّلِنَا وَءَاخِرِنَا﴾</span>: لنا ولمَن بعدَنا من عَقِبِنا.</p><p><span class="qpc-hafs">﴿وَءَايَةࣰ﴾</span>: وعلامةً على صِدْقِك.</p></div>"
  5,115,""
  5,116,""
  5,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: رقيبًا.</p><p><span class="qpc-hafs">﴿تَوَفَّيۡتَنِي﴾</span>: وفَّيْتَ أجلي على الأرضِ ورَفَعْتَني إلى السماءِ حيًّا.</p></div>"
  5,118,""
  5,119,""
  5,120,""
