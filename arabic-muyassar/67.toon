quran[30]{c,v,t}:
  67,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَـٰرَكَ ٱلَّذِي﴾</span>: تَكاثَرَ خَيرُ اللهِ وبِرُّهُ عَلى جَمِيعِ خَلْقِهِ.</p><p><span class="qpc-hafs">﴿بِيَدِهِ ٱلۡمُلۡكُ﴾</span>: التَّصَرُّفُ في مُلْكِ الدُّنيا والآخِرَةِ.</p></div>"
  67,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَبۡلُوَكُمۡ﴾</span>: لِيَخْتَبِرَكُم.</p></div>"
  67,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طِبَاقࣰا﴾</span>: مُتَناسِقَةً.</p><p><span class="qpc-hafs">﴿تَفَـٰوُتࣲ﴾</span>: اخْتِلافٍ وتَبايُنٍ.</p><p><span class="qpc-hafs">﴿فَٱرۡجِعِ ٱلۡبَصَرَ﴾</span>: فَأَعِدِ النَّظَرَ.</p><p><span class="qpc-hafs">﴿فُطُورࣲ﴾</span>: شُقُوقٍ أو صُدُوعٍ.</p></div>"
  67,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّتَيۡنِ﴾</span>: مَرَّةً بَعْدَ مَرَّةٍ.</p><p><span class="qpc-hafs">﴿يَنقَلِبۡ﴾</span>: يَرْجِعْ.</p><p><span class="qpc-hafs">﴿خَاسِئࣰا﴾</span>: ذَلِيلًا صاغِرًا.</p><p><span class="qpc-hafs">﴿حَسِيرࣱ﴾</span>: مُتْعَبٌ كَلِيلٌ.</p></div>"
  67,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدُّنۡيَا﴾</span>: القَرِيبةَ.</p><p><span class="qpc-hafs">﴿بِمَصَـٰبِيحَ﴾</span>: بِنُجُومٍ عَظِيمَةٍ مُضِيئةٍ.</p><p><span class="qpc-hafs">﴿رُجُومࣰا﴾</span>: شُهُبًا مُحْرِقَةً.</p><p><span class="qpc-hafs">﴿لِّلشَّيَـٰطِينِ﴾</span>: لِمُسْتَرِقِي السَّمْعِ مِنَ الشَّياطِينِ.</p><p><span class="qpc-hafs">﴿ٱلسَّعِيرِ﴾</span>: النّارِ المُوقَدَةِ.</p></div>"
  67,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: وساءَ المَرْجِعُ لهم جَهَنَّمُ.</p></div>"
  67,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُلۡقُواْ﴾</span>: طُرِحُوا.</p><p><span class="qpc-hafs">﴿شَهِيقࣰا﴾</span>: صَوْتًا شَدِيدًا مُنْكَرًا.</p><p><span class="qpc-hafs">﴿تَفُورُ﴾</span>: تَغْلِي غَلَيانًا شَدِيدًا.</p></div>"
  67,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمَيَّزُ﴾</span>: تَتَمَزَّقُ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡغَيۡظِ﴾</span>: مِن شِدَّةِ غَضَبِها عَلى الكُفّارِ.</p><p><span class="qpc-hafs">﴿أُلۡقِيَ﴾</span>: طُرِحِ.</p><p><span class="qpc-hafs">﴿فَوۡجࣱ﴾</span>: جَماعةٌ مِنَ النّاسِ.</p><p><span class="qpc-hafs">﴿خَزَنَتُهَآ﴾</span>: الملائِكةُ المُوكَّلُونَ بأَمْرِها.</p><p><span class="qpc-hafs">﴿نَذِيرࣱ﴾</span>: رَسُولٌ يُحَذِّرُكُم مِن هَذا العَذابِ.</p></div>"
  67,9,""
  67,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَسۡمَعُ﴾</span>: سَماعَ مَن يَطْلُبُ الحقَّ.</p><p><span class="qpc-hafs">﴿نَعۡقِلُ﴾</span>: نُفَكِّرُ فِيما نُدْعى إلَيهِ.</p><p><span class="qpc-hafs">﴿ٱلسَّعِيرِ﴾</span>: النّارِ المُوقَدَةِ.</p></div>"
  67,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسُحۡقࣰا﴾</span>: فَبُعْدًا عَن رَّحَمَةِ اللهِ.</p></div>"
  67,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡغَيۡبِ﴾</span>: وهُمْ غائِبُونَ عَنْ أعْيُنِ النّاسِ، وقَبْلَ مُعايَنَةِ العَذابِ.</p><p><span class="qpc-hafs">﴿وَأَجۡرࣱ﴾</span>: ثَوابٌ.</p></div>"
  67,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسِرُّواْ﴾</span>: وأَخْفُوا.</p><p><span class="qpc-hafs">﴿أَوِ ٱجۡهَرُواْ بِهِۦٓ﴾</span>: أعْلِنُوهُ.</p><p><span class="qpc-hafs">﴿بِذَاتِ ٱلصُّدُورِ﴾</span>: بِما يَتَرَدَّدُ في النَّفْسِ مِنَ الخواطِرِ والنِّياتِ.</p></div>"
  67,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡلَمُ﴾</span>: اللهُ.</p><p><span class="qpc-hafs">﴿مَنۡ خَلَقَ﴾</span>: المخلُوقِينَ.</p><p><span class="qpc-hafs">﴿ٱللَّطِيفُ﴾</span>: العالِمُ خَبايا الأُمُورِ والمُدَبِّرُ لَها بِرِفْقٍ وحِكْمَةٍ.</p><p><span class="qpc-hafs">﴿ٱلۡخَبِيرُ﴾</span>: العَلِيمُ بِباطِنِ أمرِهِم.</p></div>"
  67,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَلُولࣰا﴾</span>: سَهْلةً مُمَهَّدَةً تَسْتَقِرُّونَ عَلَيها.</p><p><span class="qpc-hafs">﴿مَنَاكِبِهَا﴾</span>: نواحِيها وجَوانِبِها.</p><p><span class="qpc-hafs">﴿ٱلنُّشُورُ﴾</span>: البَعْثُ مِن قُبُورِكُم لِلْحِسابِ.</p></div>"
  67,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَأَمِنتُم﴾</span>: هَلْ أمِنتُم؟</p><p><span class="qpc-hafs">﴿مَّن فِي ٱلسَّمَآءِ﴾</span>: الَّذِي فَوقَ السَّماءِ.</p><p><span class="qpc-hafs">﴿يَخۡسِفَ بِكُمُ ٱلۡأَرۡضَ﴾</span>: يَقْلِبَ ظاهِرَ الأرضِ باطِنًا، وباطِنَها ظاهِرًا مُصاحِبةً لِذَواتِكم.</p><p><span class="qpc-hafs">﴿تَمُورُ﴾</span>: تَضْطَرِبُ بِكُم حَتّى تَهْلِكُوا.</p></div>"
  67,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاصِبࣰا﴾</span>: رِيحًا تَرْجُمُكُم بالحِجارةِ الصَّغِيرةِ.</p><p><span class="qpc-hafs">﴿نَذِيرِ﴾</span>: تَحْذِيرِي لَكُم.</p></div>"
  67,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَكِيرِ﴾</span>: إنْكارِي عَلَيهِم بإنْزِالِ العَذابِ بِهِم.</p></div>"
  67,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَـٰٓفَّـٰتࣲ﴾</span>: باسِطاتٍ أجْنِحَتَها عِنْدَ طَيَرانِها في الهواءِ.</p><p><span class="qpc-hafs">﴿وَيَقۡبِضۡنَ﴾</span>: ويَضْمُمْنَ أجْنِحَتَها.</p></div>"
  67,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَّنۡ هَـٰذَا﴾</span>: بَلْ مَن هَذا.</p><p><span class="qpc-hafs">﴿جُندࣱ لَّكُمۡ﴾</span>: حِزْبٌ لَكُم.</p><p><span class="qpc-hafs">﴿مِّن دُونِ ٱلرَّحۡمَـٰنِ﴾</span>: مِن غَيْرِ الرَّحمنِ.</p><p><span class="qpc-hafs">﴿إِنِ﴾</span>: ما.</p><p><span class="qpc-hafs">﴿غُرُورٍ﴾</span>: خِداعٍ وضَلالٍ مِنَ الشَّيطانِ.</p></div>"
  67,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّجُّواْ﴾</span>: اسْتَمَرُّوا في طُغْيانِهِم وكُفْرِهِم.</p><p><span class="qpc-hafs">﴿عُتُوࣲّ﴾</span>: مُعانَدَةٍ واسْتِكْبارٍ</p><p><span class="qpc-hafs">﴿وَنُفُورٍ﴾</span>: فِرارٍ مِنَ الحقِّ.</p></div>"
  67,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُكِبًّا﴾</span>: ساقِطًا عَلى وجْهِهِ.</p><p><span class="qpc-hafs">﴿أَهۡدَىٰٓ﴾</span>: أشَدُّ اسْتِقامةً عَلى الطَّرِيقةِ.</p><p><span class="qpc-hafs">﴿سَوِيًّا﴾</span>: مُسْتَوِيًا.</p></div>"
  67,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنشَأَكُمۡ﴾</span>: أوْجَدَكُم مِن العَدَمِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَفۡـِٔدَةَ﴾</span>: القُلُوبَ.</p></div>"
  67,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرَأَكُمۡ﴾</span>: خَلَقَكُم ونَشَرَكُم.</p><p><span class="qpc-hafs">﴿تُحۡشَرُونَ﴾</span>: تُجْمَعُونَ لِلْحِسابِ والجَزاءِ.</p></div>"
  67,25,""
  67,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَذِيرࣱ﴾</span>: مُخَوِّفٌ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: أُبَيِّنُ لَكُمُ الشَّرائِعَ.</p></div>"
  67,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُلۡفَةࣰ﴾</span>: قَرِيبًا مِنهُم.</p><p><span class="qpc-hafs">﴿سِيٓـَٔتۡ﴾</span>: ظَهَرَتْ الذِّلَّةُ والكآبةُ.</p><p><span class="qpc-hafs">﴿بِهِۦ تَدَّعُونَ﴾</span>: تَطْلُبُونَ تَعْجِيلَه في الدُّنيا.</p></div>"
  67,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُوني.</p><p><span class="qpc-hafs">﴿أَهۡلَكَنِيَ﴾</span>: أماتَنِي.</p><p><span class="qpc-hafs">﴿يُجِيرُ﴾</span>: يَحْمِي ويَمْنَعُ.</p></div>"
  67,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَامَنَّا بِهِۦ﴾</span>: صَدَّقْنا بِهِ وعَمِلْنا بِشَرْعِهِ.</p><p><span class="qpc-hafs">﴿تَوَكَّلۡنَا﴾</span>: اعْتَمَدْنا في كُلِّ أُمُورِنا.</p><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ﴾</span>: بُعْدٍ عَن صِراطِ اللهِ المُسْتَقِيمِ.</p></div>"
  67,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُونِي.</p><p><span class="qpc-hafs">﴿أَصۡبَحَ﴾</span>: صارَ.</p><p><span class="qpc-hafs">﴿غَوۡرࣰا﴾</span>: ذاهِبًا في الأرضِ لا تصِلُونَ إلَيهِ.</p><p><span class="qpc-hafs">﴿مَّعِينِۭ﴾</span>: جارٍ على وجْهِ الأَرْضِ تَراهُ العُيُونُ.</p></div>"
