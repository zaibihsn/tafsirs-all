quran[128]{c,v,t}:
  16,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَىٰٓ﴾</span>: قَرُبَ ودَنا.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: عقابُه للمُشْركين، أو القيامةُ.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تنزيهًا لله.</p></div>"
  16,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلرُّوحِ﴾</span>: بالوَحْي؛ الذي فيه الحياةُ التامَّةُ.</p><p><span class="qpc-hafs">﴿مِنۡ عِبَادِهِۦٓ﴾</span>: الذين اختصَّهم بالرسالة.</p><p><span class="qpc-hafs">﴿أَنذِرُوٓاْ﴾</span>: خَوِّفُوا.</p></div>"
  16,3,""
  16,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّطۡفَةࣲ﴾</span>: ماءِ الحياةِ، وهو المَنِيُّ.</p><p><span class="qpc-hafs">﴿خَصِيمࣱ﴾</span>: شديدُ الخصومةِ والمجادَلةِ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: بيِّنُ الخُصومةِ واضحُها.</p></div>"
  16,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَنۡعَـٰمَ﴾</span>: هي الإبِلُ والبَقَرُ والغنم.</p><p><span class="qpc-hafs">﴿دِفۡءࣱ﴾</span>: ما تَسْتَدْفِئُون به مِن صوفِها ووَبَرِها وشَعْرِها.</p></div>"
  16,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمَالٌ﴾</span>: زينةٌ تَسُرُّكم.</p><p><span class="qpc-hafs">﴿تُرِيحُونَ﴾</span>: تَرُدُّونها في المساء إلى حَظائرِها.</p><p><span class="qpc-hafs">﴿تَسۡرَحُونَ﴾</span>: تُخْرِجُونها في الصَّباح إلى مَراعِيها.</p></div>"
  16,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَثۡقَالَكُمۡ﴾</span>: أمتعتَكم الثقيلةَ.</p><p><span class="qpc-hafs">﴿بِشِقِّ ٱلۡأَنفُسِ﴾</span>: بجُهْدٍ شديدٍ ومشَقَّةٍ زائدةٍ عليها.</p></div>"
  16,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزِينَةࣰ﴾</span>: لتتزيَّنُوا بها حالَ ركوبِها، وحالَ جَمالِ منظرها.</p></div>"
  16,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَصۡدُ ٱلسَّبِيلِ﴾</span>: بيانُ الطَّريقِ المستقيمِ، وهو الإسلامُ.</p><p><span class="qpc-hafs">﴿جَآئِرࣱ﴾</span>: مائلٌ عن الاستقامةِ، وهو ما خالَفَ الإسلامَ.</p></div>"
  16,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُسِيمُونَ﴾</span>: تَرعَوْن دَوابَّكم.</p></div>"
  16,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: دلالةً واضحةً.</p></div>"
  16,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسَخَّرَ لَكُمُ﴾</span>: ذلَّلَ لمنافعِكم.</p></div>"
  16,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرَأَ﴾</span>: خَلَقَ.</p></div>"
  16,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَحۡمࣰا طَرِيࣰّا﴾</span>: هو السَّمَكُ.</p><p><span class="qpc-hafs">﴿حِلۡيَةࣰ﴾</span>: ما تتحَلّى به النِّساءُ وتَتَزَيَّنُ، كاللؤلؤِ والمَرْجانِ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p><p><span class="qpc-hafs">﴿مَوَاخِرَ فِيهِ﴾</span>: تَشُقُّ الماءَ بجَرْيِها فيه ذَهابًا ورُجوعًا.</p></div>"
  16,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جبالًا ثوابِتَ.</p><p><span class="qpc-hafs">﴿أَن تَمِيدَ بِكُمۡ﴾</span>: حتى لا تَمِيلَ بكم وتضطربَ.</p><p><span class="qpc-hafs">﴿وَسُبُلࣰا﴾</span>: طُرُقًا.</p><p><span class="qpc-hafs">﴿تَهۡتَدُونَ﴾</span>: إلى مقاصِدِكم.</p></div>"
  16,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَلَـٰمَـٰتࣲ﴾</span>: معالمَ تَسْتَدِلُّون بها على الطُّرُقِ نهارًا.</p></div>"
  16,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَمَن يَخۡلُقُ﴾</span>: وهو اللهُ تعالى.</p><p><span class="qpc-hafs">﴿كَمَن لَّا يَخۡلُقُ﴾</span>: أتَجْعَلُونه في استحقاقِ العبادةِ كالآلهةِ المزعومةِ التي لا تملِك شيئًا؟</p></div>"
  16,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعۡمَةَ ٱللَّهِ﴾</span>: نِعَمَه عليكم.</p><p><span class="qpc-hafs">﴿لَا تُحۡصُوهَآ﴾</span>: لا تُطيقوا حَصْرَها ولا القيامَ بشُكْرها؛ لكثرتِها وتَنَوُّعِها.</p></div>"
  16,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تُسِرُّونَ﴾</span>: ما تُخْفُونَه من أقوالِكم وأعمالِكم.</p></div>"
  16,20,""
  16,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّانَ﴾</span>: وقتَ.</p><p><span class="qpc-hafs">﴿يُبۡعَثُونَ﴾</span>: يُحْيَوْن مِن قُبورِهم.</p></div>"
  16,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلُوبُهُم مُّنكِرَةࣱ﴾</span>: جاحدةٌ وحدانيةَ اللهِ.</p></div>"
  16,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حَقًّا، أو لا مَحالةَ.</p></div>"
  16,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: جَمْعُ أُسْطورة، وهي: ما سُطِّرَ في كتب السابقينَ من الأخبارِ المكذوبةِ.</p></div>"
  16,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡزَارَهُمۡ﴾</span>: آثامَ ضلالِهم.</p><p><span class="qpc-hafs">﴿مَا يَزِرُونَ﴾</span>: ما يَحْمِلُونه من آثامٍ.</p></div>"
  16,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَرَ﴾</span>: دَبَّرَ في حِيلةٍ وخَفاءٍ.</p><p><span class="qpc-hafs">﴿فَأَتَى ٱللَّهُ بُنۡيَـٰنَهُم﴾</span>: أهْلكَه وأفْناه.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡقَوَاعِدِ﴾</span>: من أساسِه.</p><p><span class="qpc-hafs">﴿فَخَرَّ﴾</span>: سَقَطَ.</p><p><span class="qpc-hafs">﴿حَيۡثُ لَا يَشۡعُرُونَ﴾</span>: من مَأْمَنِهم، ومن جهةٍ لا تَخْطُرُ ببالِهم.</p></div>"
  16,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخۡزِيهِمۡ﴾</span>: يُذِلُّهم اللهُ ويُهينُهم بالعذابِ.</p><p><span class="qpc-hafs">﴿شُرَكَآءِيَ﴾</span>: الآلهةُ التي عَبَدْتُموها من دوني.</p><p><span class="qpc-hafs">﴿تُشَـٰٓقُّونَ فِيهِمۡ﴾</span>: تُخاصِمُون وتُعادُون الأنبياءَ وأتباعَهم في شأنهم.</p><p><span class="qpc-hafs">﴿ٱلۡخِزۡيَ﴾</span>: الذُّلَّ والهَوانَ.</p><p><span class="qpc-hafs">﴿وَٱلسُّوٓءَ﴾</span>: العذابَ.</p></div>"
  16,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰٓئِكَةُ﴾</span>: تَقْبِضُ أرواحَهم.</p><p><span class="qpc-hafs">﴿فَأَلۡقَوُاْ ٱلسَّلَمَ﴾</span>: استَسْلَمُوا لأمرِ اللهِ حين رَأَوا الموتَ.</p></div>"
  16,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوَى ٱلۡمُتَكَبِّرِينَ﴾</span>: مَأْواهم ومَقَرُّهم.</p></div>"
  16,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣱ﴾</span>: مَكْرُمَةٌ من اللهِ بالعيشِ الهنيءِ والرِّزقِ الواسعِ.</p></div>"
  16,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: جناتُ إقامةٍ.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: من تحتِ قُصورِها وأشجارِها.</p></div>"
  16,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَيِّبِينَ﴾</span>: طاهِرين زاكِيَةً أفعالُهم وأقوالُهم.</p><p><span class="qpc-hafs">﴿سَلَـٰمٌ عَلَيۡكُمُ﴾</span>: تحيةٌ خاصةٌ بكم، وسَلِمْتُم من كلِّ آفةٍ.</p></div>"
  16,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ يَنظُرُونَ﴾</span>: ما ينتظِرُ الكفارُ.</p><p><span class="qpc-hafs">﴿تَأۡتِيَهُمُ ٱلۡمَلَـٰٓئِكَةُ﴾</span>: لقَبْضِ أرواحِهم.</p><p><span class="qpc-hafs">﴿أَمۡرُ رَبِّكَ﴾</span>: عذابُ الاستئصالِ في الدنيا، أو القيامةُ التي فيها عذابُهم.</p></div>"
  16,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَاقَ﴾</span>: نَزَلَ وأحاطَ.</p></div>"
  16,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ فَعَلَ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾</span>: بمِثْلِ هذا الاحتجاجِ الباطلِ احتجَّ الكفارُ السابقون.</p></div>"
  16,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّـٰغُوتَ﴾</span>: كلَّ معبودٍ باطلٍ، كالشيطانِ والأوثانِ والأمواتِ، وكلَّ داعٍ إلى ضَلالٍ.</p><p><span class="qpc-hafs">﴿حَقَّتۡ﴾</span>: وجَبَتْ.</p></div>"
  16,37,""
  16,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: غايةَ اجتهادِهم بالأيمانِ المؤكَّدةِ.</p></div>"
  16,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُبَيِّنَ لَهُمُ﴾</span>: أي: يَبْعَثُ اللهُ جميعَ العبادِ؛ ليُظْهِرَ لهم حقيقةَ البعثِ.</p></div>"
  16,40,""
  16,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنُبَوِّئَنَّهُمۡ﴾</span>: لَنُنْزِلَنَّهم.</p><p><span class="qpc-hafs">﴿حَسَنَةࣰ﴾</span>: دارًا حسنةً، أو رزقًا واسعًا وعَيْشًا هنيئًا.</p></div>"
  16,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَكَّلُونَ﴾</span>: يعتمدون عليه ويُفَوِّضُون أمرَهم إليه.</p></div>"
  16,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلَ ٱلذِّكۡرِ﴾</span>: العلماءَ من أهلِ الكتبِ السابقةِ.</p></div>"
  16,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: وأرسَلْنا الرسلَ بالمعجزاتِ الواضحةِ الدالَّةِ على صِدْقِهم.</p><p><span class="qpc-hafs">﴿وَٱلزُّبُرِ﴾</span>: وبالكتبِ المنزَّلةِ، المتضمِّنةِ للشرائعِ.</p><p><span class="qpc-hafs">﴿ٱلذِّكۡرَ﴾</span>: القرآنَ؛ لما فيه من الموعظةِ والتنبيهِ.</p></div>"
  16,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَرُواْ ٱلسَّيِّـَٔاتِ﴾</span>: دبَّروا المكايدَ بخَفاءٍ، وأشركوا مع اللهِ.</p><p><span class="qpc-hafs">﴿يَخۡسِفَ﴾</span>: يُغيِّبَ.</p></div>"
  16,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَقَلُّبِهِمۡ﴾</span>: أسفارِهم وتصرُّفِهم في أمورِهم.</p><p><span class="qpc-hafs">﴿بِمُعۡجِزِينَ﴾</span>: بفائتين اللهَ بالفِرارِ من عَذابِه.</p></div>"
  16,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ تَخَوُّفࣲ﴾</span>: على تَنَقُّصٍ شيئًا فشيئًا في الأموالِ والأنفسِ والثمراتِ حتى يَهْلِكُوا، أو على مخافَةٍ من العَذابِ.</p></div>"
  16,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن شَيۡءࣲ﴾</span>: أي: له ظِلٌّ، كالجبالِ والشجَرِ.</p><p><span class="qpc-hafs">﴿يَتَفَيَّؤُاْ ظِلَـٰلُهُ﴾</span>: يَميلُ ظِلُّ الأشياءِ وينتقلُ من جانبٍ إلى آخَر.</p><p><span class="qpc-hafs">﴿سُجَّدࣰا لِّلَّهِ﴾</span>: مُنْقادةً خاضعةً لعَظَمَةِ رِّبها، وتسخيرِه.</p><p><span class="qpc-hafs">﴿دَ ٰ⁠خِرُونَ﴾</span>: أذلّاءُ مُنقادُون لحُكم الله تعالى.</p></div>"
  16,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡجُدُ﴾</span>: سجودَ طاعةٍ وعبادةٍ، أو سُجودَ تسخيرٍ وخضوعٍ.</p><p><span class="qpc-hafs">﴿دَآبَّةࣲ﴾</span>: كلِّ حَيَوانٍ يمشي -على هيئته- على الأرضِ.</p></div>"
  16,50,""
  16,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَتَّخِذُوٓاْ﴾</span>: لا تَعْبُدوا.</p><p><span class="qpc-hafs">﴿فَٱرۡهَبُونِ﴾</span>: خافونِ دونَ غيري.</p></div>"
  16,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَهُ ٱلدِّينُ﴾</span>: وللهِ وحدَه العبادةُ والإخلاصُ.</p><p><span class="qpc-hafs">﴿وَاصِبًا﴾</span>: دائمًا، أو واجبًا لازمًا.</p></div>"
  16,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَسَّكُمُ﴾</span>: أصابكم.</p><p><span class="qpc-hafs">﴿ٱلضُّرُّ﴾</span>: سوءُ الحالِ بنَقْصٍ في الأموالِ أو الأنفسِ أو الثمراتِ.</p><p><span class="qpc-hafs">﴿تَجۡـَٔرُونَ﴾</span>: ترفعونَ أصواتَكم بالدُّعاءِ والاستغاثةِ.</p></div>"
  16,54,""
  16,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَآ ءَاتَيۡنَـٰهُمۡ﴾</span>: من النِّعَمِ.</p><p><span class="qpc-hafs">﴿فَتَمَتَّعُواْ﴾</span>: عِيشُوا في أمْنٍ وسلامةٍ، والتَذُّوا بالدنيا، والمرادُ التهديدُ.</p></div>"
  16,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَجۡعَلُونَ﴾</span>: ويجعلُ المشركون على وجْهِ التقرُّبِ.</p><p><span class="qpc-hafs">﴿لِمَا لَا يَعۡلَمُونَ﴾</span>: لآلهتِهم التي لا عِلْمَ لها، ولا تنفعُ ولا تَضُرُّ.</p><p><span class="qpc-hafs">﴿تَفۡتَرُونَ﴾</span>: تَكْذِبُون على الله من الباطِلِ.</p></div>"
  16,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يَشۡتَهُونَ﴾</span>: ما يُحِبُّون من البنين.</p></div>"
  16,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَظِيمࣱ﴾</span>: ممتلِئٌ غَمًّا وحُزْنًا وغَضَبًا.</p></div>"
  16,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَ ٰ⁠رَىٰ مِنَ ٱلۡقَوۡمِ﴾</span>: يَسْتَخْفي من قومِه؟</p><p><span class="qpc-hafs">﴿أَيُمۡسِكُهُۥ﴾</span>: أيُبقي مَوْلُودَه الأنثى حيًا.</p><p><span class="qpc-hafs">﴿هُونٍ﴾</span>: ذُلٍّ وهَوانٍ.</p><p><span class="qpc-hafs">﴿يَدُسُّهُۥ﴾</span>: يُخْفِيه، فَيدْفِنُه حيًّا حتى يموتَ.</p></div>"
  16,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثَلُ ٱلسَّوۡءِ﴾</span>: الصِّفةُ القبيحةُ من كراهةِ البناتِ، والجهلِ، والكفرِ باللهِ.</p><p><span class="qpc-hafs">﴿وَلِلَّهِ ٱلۡمَثَلُ ٱلۡأَعۡلَىٰ﴾</span>: الصفةُ العُليا من استحقاقِ العبوديةِ، والكمالِ، والجلالِ، والغنى، والجودِ.</p></div>"
  16,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجَلࣲ مُّسَمࣰّى﴾</span>: وقتٍ محدَّدٍ هو نهايةُ آجالِهم.</p><p><span class="qpc-hafs">﴿وَلَا يَسۡتَقۡدِمُونَ﴾</span>: لا يَتَقَدَّمون عليه.</p></div>"
  16,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يَكۡرَهُونَ﴾</span>: ما لا يُحبون نِسْبتَه إلى أنفسِهم من البناتِ.</p><p><span class="qpc-hafs">﴿وَتَصِفُ﴾</span>: تقولُ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: حُسْنَ العاقبةِ.</p><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حقًّا، أو لا مَحالةَ.</p><p><span class="qpc-hafs">﴿مُّفۡرَطُونَ﴾</span>: مَتْرُوكون مَنسِيُّون فيها أبدًا.</p></div>"
  16,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَزَيَّنَ﴾</span>: حَسَّنَ.</p><p><span class="qpc-hafs">﴿وَلِيُّهُمُ ٱلۡيَوۡمَ﴾</span>: مُتَوَلٍّ إغواءَهم في الدنيا.</p></div>"
  16,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القرآنَ العظيمَ.</p><p><span class="qpc-hafs">﴿لِتُبَيِّنَ لَهُمُ﴾</span>: لتُوَضِّحَ للناسِ.</p></div>"
  16,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: دليلًا وحُجَّةً على قُدرةِ الله.</p></div>"
  16,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَنۡعَـٰمِ﴾</span>: وهي: الإبِلُ والبَقَرُ والغَنَمُ.</p><p><span class="qpc-hafs">﴿لَعِبۡرَةࣰ﴾</span>: لعِظَةً.</p><p><span class="qpc-hafs">﴿فَرۡثࣲ﴾</span>: خُلاصةِ المأكول في الكَرِشِ والأمعاءِ.</p><p><span class="qpc-hafs">﴿خَالِصࣰا﴾</span>: مُصَفّى من جميعِ الشوائبِ.</p><p><span class="qpc-hafs">﴿سَآئِغࣰا﴾</span>: سهلَ المُرورِ في الحَلْقِ، هنيئًا.</p></div>"
  16,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَكَرࣰا﴾</span>: خَمْرًا (وهذا امتنانٌ قبلَ التحريمِ).</p></div>"
  16,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَوۡحَىٰ﴾</span>: وألْهَمَ.</p><p><span class="qpc-hafs">﴿وَمِمَّا يَعۡرِشُونَ﴾</span>: وفيما يَبْنيه الناسُ من البيوتِ والخَلايا.</p></div>"
  16,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبُلَ رَبِّكِ﴾</span>: طُرُقَه التي ألْهَمكِ؛ لامتصاصِ ما في أزهارِ الثمار.</p><p><span class="qpc-hafs">﴿ذُلُلࣰا﴾</span>: مُذَلَّلةً لكِ لا عُسْرَ فيها.</p><p><span class="qpc-hafs">﴿شَرَابࣱ﴾</span>: هو العَسَلُ.</p></div>"
  16,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَفَّىٰكُمۡ﴾</span>: يُميتكُم عندَ نهايةِ أعمارِكم.</p><p><span class="qpc-hafs">﴿أَرۡذَلِ ٱلۡعُمُرِ﴾</span>: أردَئهِ وأحقَرِه، وهو وقتُ الهَرَمِ.</p></div>"
  16,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهُمۡ فِيهِ سَوَآءٌ﴾</span>: فهم لا يَرْضَوْن بالتساوي في الرزقِ، فكيف رَضُوا أن يَجْعلوا للهِ شركاءَ من عبيدِه؟</p></div>"
  16,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَفَدَةࣰ﴾</span>: جَمْعَ حَفِيدٍ، أي: أولادَ الأولادِ، أو أعوانًا وخَدَمًا.</p></div>"
  16,73,""
  16,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تَضۡرِبُواْ لِلَّهِ ٱلۡأَمۡثَالَ﴾</span>: لا تَجْعَلُوا للهِ أشباهًا مماثِلين له مِن خَلْقِه، تُشْرِكُونهم معه في العبادةِ.</p></div>"
  16,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ يَسۡتَوُۥنَ﴾</span>: لا، فكذلك اللهُ المالكُ مع عبيدِه، فكيف تُسَوُّون بينَهما؟</p></div>"
  16,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبۡكَمُ﴾</span>: أخْرَسُ منذُ ولادَتِه.</p><p><span class="qpc-hafs">﴿كَلٌّ﴾</span>: عِبْءٌ يعتَمِدُ على غيرِه في معيشَتِه.</p><p><span class="qpc-hafs">﴿مَوۡلَىٰهُ﴾</span>: مَن يلي أمرَه ويَعُولُه.</p><p><span class="qpc-hafs">﴿بِٱلۡعَدۡلِ﴾</span>: بالحقِّ وعبادةِ اللهِ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ﴾</span>: طريقٍ.</p></div>"
  16,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡبُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: عِلْمُ ما غابَ فيهما.</p><p><span class="qpc-hafs">﴿كَلَمۡحِ ٱلۡبَصَرِ﴾</span>: كنَظْرَةٍ سريعةٍ بالبَصَرِ.</p></div>"
  16,78,""
  16,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسَخَّرَ ٰ⁠تࣲ﴾</span>: مُذَلَّلاتٍ للطَّيَرانِ.</p></div>"
  16,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَكَنࣰا﴾</span>: مَسْكَنًا واستقرارًا لكم.</p><p><span class="qpc-hafs">﴿بُيُوتࣰا﴾</span>: كالخِيام.</p><p><span class="qpc-hafs">﴿تَسۡتَخِفُّونَهَا﴾</span>: تَجِدُونها خفيفةَ الحَمْلِ والنَّقْلِ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ظَعۡنِكُمۡ﴾</span>: وقتَ سَفَرِكم.</p><p><span class="qpc-hafs">﴿وَمِنۡ أَصۡوَافِهَا﴾</span>: أي: أصوافِ الضَّأنِ.</p><p><span class="qpc-hafs">﴿وَأَوۡبَارِهَا﴾</span>: أي: أوبارِ الإبِل، وهو ما يَعْلُو أجسادَها.</p><p><span class="qpc-hafs">﴿وَأَشۡعَارِهَآ﴾</span>: أي: أشعارِ المَعْزِ.</p><p><span class="qpc-hafs">﴿أَثَـٰثࣰا﴾</span>: مَتاعًا لبيوتِكم، كالأغطيةِ والفُرُشِ.</p><p><span class="qpc-hafs">﴿وَمَتَـٰعًا﴾</span>: ما تتمتَّعُون وتنتفِعُون به.</p><p><span class="qpc-hafs">﴿إِلَىٰ حِينࣲ﴾</span>: إلى وقتٍ محدَّدٍ في الدنيا.</p></div>"
  16,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظِلَـٰلࣰا﴾</span>: ما تَسْتظِلُّون به من شدَّةِ الحرِّ.</p><p><span class="qpc-hafs">﴿أَكۡنَـٰنࣰا﴾</span>: أماكنَ وِقايةٍ وسِتْرٍ، كالكهوفِ.</p><p><span class="qpc-hafs">﴿سَرَ ٰ⁠بِيلَ﴾</span>: كلَّ ما يُلْبَس من ثيابٍ أو دُروعٍ.</p><p><span class="qpc-hafs">﴿بَأۡسَكُمۡ﴾</span>: الشدَّةَ في حروبِكم، كالطَّعْنِ والضَّرْبِ والشَّظايا.</p><p><span class="qpc-hafs">﴿تُسۡلِمُونَ﴾</span>: تَنقادُون وتَخْضَعُون لأمرِ اللهِ وحُكْمِه.</p></div>"
  16,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا.</p><p><span class="qpc-hafs">﴿ٱلۡمُبِينُ﴾</span>: الواضحُ.</p></div>"
  16,83,""
  16,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: هو رسولُهم يَشْهَدُ على مَن آمَنَ منهم، وعلى مَن كَفَرَ.</p><p><span class="qpc-hafs">﴿لَا يُؤۡذَنُ لِلَّذِينَ كَفَرُواْ﴾</span>: بالاعتذار عَمّا وقَعَ منهم.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يُسۡتَعۡتَبُونَ﴾</span>: لا يُطْلَبُ منهم العُتْبى، أي: الرجوعُ إلى ما يُرْضي اللهَ من التوبةِ والعملِ الصّالحِ.</p></div>"
  16,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنظَرُونَ﴾</span>: يُمْهَلُون ويُؤَخَّرون عنه.</p></div>"
  16,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُرَكَآءَهُمۡ﴾</span>: آلهتَهم المزعومةَ.</p><p><span class="qpc-hafs">﴿نَدۡعُواْ﴾</span>: نعبدُ.</p><p><span class="qpc-hafs">﴿فَأَلۡقَوۡاْ إِلَيۡهِمُ ٱلۡقَوۡلَ﴾</span>: رَدَّتِ الآلهةُ على عابدِيها قائلين.</p></div>"
  16,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَلۡقَوۡاْ إِلَى ٱللَّهِ يَوۡمَئِذٍ ٱلسَّلَمَ﴾</span>: أظهرَ المشركونَ خُضوعَهم وانقيادَهم للهِ يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: غابَ وضاعَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يختلِقُونَه مِن الأكاذيبِ.</p></div>"
  16,88,""
  16,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدًا عَلَىٰ هَـٰٓؤُلَآءِ﴾</span>: تَشْهَدُ على أمَّتِك أنكَ بَلَّغْتَهم رسالةَ ربِّك.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القرآنَ.</p><p><span class="qpc-hafs">﴿تِبۡيَـٰنࣰا﴾</span>: بَيانًا وتوضيحًا.</p><p><span class="qpc-hafs">﴿لِّكُلِّ شَيۡءࣲ﴾</span>: مما يَحْتاجُ إليه الناسُ من أمورِ الشريعةِ.</p></div>"
  16,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡعَدۡلِ﴾</span>: بالتوسُّطِ والإنصافِ في الأمور.</p><p><span class="qpc-hafs">﴿وَٱلۡإِحۡسَـٰنِ﴾</span>: كمالِ العملِ وإتقانِه، وإيصالِ النفعِ إلى الخَلْقِ.</p><p><span class="qpc-hafs">﴿وَإِيتَآيِٕ ذِي ٱلۡقُرۡبَىٰ﴾</span>: إعطاءِ القَرابةِ حَقَّهم من الصِّلةِ والبِرِّ.</p><p><span class="qpc-hafs">﴿ٱلۡفَحۡشَآءِ﴾</span>: ما عَظُمَ قُبْحُه من الذنوبِ قولًا أو فعلًا.</p><p><span class="qpc-hafs">﴿وَٱلۡبَغۡيِ﴾</span>: ظُلْمِ الناسِ وتجاوُزِ الحَدِّ في الاستعلاءِ والتعدِّي عليهم.</p></div>"
  16,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِعَهۡدِ ٱللَّهِ﴾</span>: ما يَلْتَزِمُه المسلمُ باختيارِه بينَه وبينَ اللهِ، أو بينَ الناسِ.</p><p><span class="qpc-hafs">﴿وَلَا تَنقُضُواْ ٱلۡأَيۡمَـٰنَ﴾</span>: لا تُبْطِلُوها وتَتْرُكُوا العَمَلَ بمُقْتضاها.</p><p><span class="qpc-hafs">﴿كَفِيلًا﴾</span>: رَقيبًا أو ضامِنًا.</p></div>"
  16,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَزۡلَهَا﴾</span>: ما فَتَلَتْه من صُوفٍ ونحوِه.</p><p><span class="qpc-hafs">﴿أَنكَـٰثࣰا﴾</span>: جَمْعُ نِكْثٍ، وهو: ما حُلَّ فَتْلُه؛ ليُغْزَلَ ثانيةً.</p><p><span class="qpc-hafs">﴿دَخَلَۢا بَيۡنَكُمۡ﴾</span>: خديعةً ومُنْكَرًا بينَكم.</p><p><span class="qpc-hafs">﴿أَرۡبَىٰ مِنۡ أُمَّةٍ﴾</span>: أكثرَ عَددًَا وأوفرَ مالًا من الجماعة التي عاهَدْتموها.</p><p><span class="qpc-hafs">﴿يَبۡلُوكُمُ ٱللَّهُ﴾</span>: يختبرُكم بالوفاءِ بِالعهودِ وعَدَمِ نَقْضِها.</p></div>"
  16,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: أهلَ دينٍ واحدٍ، وهو الإسلامُ.</p><p><span class="qpc-hafs">﴿وَيَهۡدِي﴾</span>: يُوَفِّقُ إلى الهدايةِ.</p></div>"
  16,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَزِلَّ قَدَمُۢ﴾</span>: فتنحَرِفَ أقدامُكم عن محَجَّةِ الحقِّ.</p><p><span class="qpc-hafs">﴿ثُبُوتِهَا﴾</span>: استقامتِها عليه.</p><p><span class="qpc-hafs">﴿ٱلسُّوٓءَ﴾</span>: ما يَسُوءُكم من العذابِ في الدنيا.</p></div>"
  16,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَشۡتَرُواْ﴾</span>: لا تَسْتبدلوا.</p></div>"
  16,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنفَدُ﴾</span>: يزولُ ويَفْنى.</p><p><span class="qpc-hafs">﴿بَاقࣲ﴾</span>: لا يزولُ ولا يَفْنى.</p></div>"
  16,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَيِّبَةࣰ﴾</span>: سعيدةً في الدنيا، يصاحِبُها القناعة بما قَسَمهُ اللهُ وقَدَّره.</p></div>"
  16,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِذَا قَرَأۡتَ﴾</span>: أي: فإذا أرَدْتَ أن تَقْرَأَ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾</span>: فالتجِئْ واستَجِرْ به.</p><p><span class="qpc-hafs">﴿ٱلرَّجِيمِ﴾</span>: المَرْجُومِ، أي: المَطْرودِ من رحمةِ اللهِ.</p></div>"
  16,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٌ﴾</span>: تَسَلُّطٌ واستيلاءٌ.</p><p><span class="qpc-hafs">﴿يَتَوَكَّلُونَ﴾</span>: يَعْتمدون عليه ويُفَوِّضُون أمرَهم إليه.</p></div>"
  16,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَلَّوۡنَهُۥ﴾</span>: يَتِّخِذُونه مُعِينًا لهم ويُطيعونه.</p><p><span class="qpc-hafs">﴿هُم بِهِۦ﴾</span>: بسببِ الشيطانِ وإغوائِه إيّاهم.</p></div>"
  16,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدَّلۡنَآ ءَايَةࣰ﴾</span>: أزَلْناها، أو أنْزَلْنا غيرَها.</p><p><span class="qpc-hafs">﴿مُفۡتَرِۭ﴾</span>: كَذّابٌ تَختَلِقُ الباطِلَ على اللهِ مِن عندِك.</p></div>"
  16,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُوحُ ٱلۡقُدُسِ﴾</span>: جبريلُ عليه السلامُ.</p></div>"
  16,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّسَانُ﴾</span>: لُغةُ وكلامُ.</p><p><span class="qpc-hafs">﴿يُلۡحِدُونَ إِلَيۡهِ﴾</span>: يَنْسِبُون إليه التعليمَ.</p><p><span class="qpc-hafs">﴿أَعۡجَمِيࣱّ﴾</span>: لا يُفْصِحُ عن مُرادِه.</p><p><span class="qpc-hafs">﴿مُّبِينٌ﴾</span>: في غايةِ الوضوحِ والبيانِ.</p></div>"
  16,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَهۡدِيهِمُ ٱللَّهُ﴾</span>: لا يُوَفِّقُهم للإيمانِ؛ لعِلْمِه بعدَمِ قَبولِهم له.</p></div>"
  16,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡتَرِي﴾</span>: يَخْتِلقُ.</p></div>"
  16,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن كَفَرَ بِٱللَّهِ﴾</span>: فهم الكاذبون حقًّا، وعليهم غَضَبٌ من الله.</p><p><span class="qpc-hafs">﴿أُكۡرِهَ﴾</span>: أُرْغِمَ على النُّطْقِ بالكفرِ فَتَلفَّظَ به؛ خَوْفًا من هَلاكِه.</p><p><span class="qpc-hafs">﴿شَرَحَ بِٱلۡكُفۡرِ صَدۡرࣰا﴾</span>: اعتَقَدَه وطابَتْ نفسُه به.</p></div>"
  16,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَحَبُّواْ ٱلۡحَيَوٰةَ﴾</span>: اختارُوها وفَضَّلُوها.</p></div>"
  16,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَبَعَ﴾</span>: خَتَم.</p></div>"
  16,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حقًّا، أو لا مَحالةَ.</p></div>"
  16,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُتِنُواْ﴾</span>: اختُبِرُوا بتعذيبِهم، وتَلَفَّظُوا بالكُفرِ.</p></div>"
  16,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُجَـٰدِلُ عَن نَّفۡسِهَا﴾</span>: تُخاصِمُ عن ذاتِها، وتسعى في خَلاصِها.</p><p><span class="qpc-hafs">﴿وَتُوَفَّىٰ﴾</span>: تُعْطى وافيًا كامِلًا.</p></div>"
  16,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرۡيَةࣰ﴾</span>: أي: مكةَ.</p><p><span class="qpc-hafs">﴿رَغَدࣰا﴾</span>: واسعًا كثيرًا، أو هنيئًا سهلًا.</p><p><span class="qpc-hafs">﴿لِبَاسَ ٱلۡجُوعِ وَٱلۡخَوۡفِ﴾</span>: ما غَشِيَها من صُنوفِ البَلاءِ وإحاطَتِه بها كاللِّباس.</p></div>"
  16,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡهُمۡ﴾</span>: من جنسِهم، يَعْرِفُون نَسَبَه وأمانتَه.</p></div>"
  16,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱشۡكُرُواْ نِعۡمَتَ ٱللَّهِ﴾</span>: بالاعترافِ بها، واستعمالِها في طاعَتِه.</p></div>"
  16,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَيۡتَةَ﴾</span>: ما لم يُذْبَحْ بطريقةٍ شَرْعِيَّةٍ من الحَيَوانِ.</p><p><span class="qpc-hafs">﴿وَٱلدَّمَ﴾</span>: أي: المُراقَ من الذَّبِيحةِ.</p><p><span class="qpc-hafs">﴿وَمَآ أُهِلَّ لِغَيۡرِ ٱللَّهِ بِهِۦ﴾</span>: ما ذُكِرَ عليه غيرُ اسمِ اللهِ عندَ ذَبْحِه.</p><p><span class="qpc-hafs">﴿فَمَنِ ٱضۡطُرَّ﴾</span>: فمَن ألجأَتْه الضَّرورةُ إلى أكْلِ شيءٍ من هذه المُحَرَّماتِ.</p><p><span class="qpc-hafs">﴿غَيۡرَ بَاغࣲ﴾</span>: غيرَ طالبٍ للمُحَرَّمِ وهو يَجِدُ غيرَه، أو غيرَ طالبٍ بأَكْلِه التلذُّذَ، أو غيرَ ظالمٍ لمضطرٍ آخرَ يُؤدِّي إلى هَلاكِه.</p><p><span class="qpc-hafs">﴿وَلَا عَادࣲ﴾</span>: ولا متجاوزٍ ما يَسُدُّ جَوْعتَه.</p></div>"
  16,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَا تَصِفُ أَلۡسِنَتُكُمُ﴾</span>: لمجرَّدِ وصْفِ ألسنتِكُم للشيء دونَ دليلٍ.</p><p><span class="qpc-hafs">﴿لِّتَفۡتَرُواْ﴾</span>: تختَلِقُوا.</p></div>"
  16,117,""
  16,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ هَادُواْ﴾</span>: اليهودِ.</p></div>"
  16,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسُّوٓءَ﴾</span>: الذُّنوبَ والمعاصِيَ.</p><p><span class="qpc-hafs">﴿بِجَهَـٰلَةࣲ﴾</span>: بِجَهْلٍ منهم لعاقبتِها وإيجابِها سَخَطَ اللهِ.</p><p><span class="qpc-hafs">﴿وَأَصۡلَحُوٓاْ﴾</span>: استقامُوا بعد تَوْبَتِهم.</p></div>"
  16,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ﴾</span>: إمامًا قُدْوةً جامعًا لخِصالِ الخيرِ.</p><p><span class="qpc-hafs">﴿قَانِتࣰا لِّلَّهِ﴾</span>: مُطيعًا خاضِعًا له.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن الأديانِ الباطلةِ إلى الدِّينِ الحقِ.</p></div>"
  16,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱجۡتَبَىٰهُ﴾</span>: اختاره اللهُ لرسالتِه.</p><p><span class="qpc-hafs">﴿وَهَدَىٰهُ﴾</span>: أرْشَدَه ووَفَّقه.</p></div>"
  16,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣰ﴾</span>: نِعْمةً حسنةً، كالثَّناءِ الجميلِ عليه إلى يومِ القيامة، والاقتداءِ به.</p></div>"
  16,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِلَّةَ إِبۡرَ ٰ⁠هِيمَ﴾</span>: شريعتَه، وهي الإسلامُ.</p></div>"
  16,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُعِلَ ٱلسَّبۡتُ﴾</span>: فُرِضَ تَعْظِيمُه والتفرُّغُ للعبادةِ فيه.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱخۡتَلَفُواْ فِيهِ﴾</span>: هم اليهودُ، حيث أمَرَهم نبيُّهم بتعظيمِ يومِ الجُمُعَةِ، فاختاروا السَّبْتَ.</p></div>"
  16,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحِكۡمَةِ﴾</span>: بالطريقةِ الحَكِيمةِ وفْقَ شَرْعِ اللهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَوۡعِظَةِ ٱلۡحَسَنَةِ﴾</span>: بالتذكيرِ المناسِبِ للأشخاصِ والأحوالِ.</p></div>"
  16,126,""
  16,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡقࣲ﴾</span>: حَرَجٍ وغَمٍّ.</p></div>"
  16,128,""
