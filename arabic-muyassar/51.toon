quran[60]{c,v,t}:
  51,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلذَّ ٰ⁠رِيَـٰتِ﴾</span>: الرِّياحِ المُثِيراتِ للتُّرابِ.</p></div>"
  51,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡحَـٰمِلَـٰتِ﴾</span>: فالسُّحُبِ الحامِلاتِ.</p><p><span class="qpc-hafs">﴿وِقۡرࣰا﴾</span>: ثِقَلًا عَظِيمًا مِنَ الماءِ.</p></div>"
  51,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡجَـٰرِيَـٰتِ﴾</span>: فالسُّفُنِ الجارِياتِ في البِحارِ.</p><p><span class="qpc-hafs">﴿يُسۡرࣰا﴾</span>: جَرْيًا ذا يُسْرٍ وسُهُولةٍ.</p></div>"
  51,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡمُقَسِّمَـٰتِ﴾</span>: فالملائِكةِ المُقَسِّماتِ.</p><p><span class="qpc-hafs">﴿أَمۡرًا﴾</span>: أمْرَ اللهِ في خَلْقِهِ.</p></div>"
  51,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَصَادِقࣱ﴾</span>: لَكائِنٌ حقٌّ يَقِينٌ.</p></div>"
  51,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدِّينَ﴾</span>: الحِسابَ.</p><p><span class="qpc-hafs">﴿لَوَ ٰ⁠قِعࣱ﴾</span>: لَكائِنٌ لا مَحالةَ.</p></div>"
  51,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَاتِ ٱلۡحُبُكِ﴾</span>: ذاتِ الخَلْقِ الحَسَنِ.</p></div>"
  51,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّخۡتَلِفࣲ﴾</span>: مُضْطَرِبٍ.</p></div>"
  51,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡفَكُ﴾</span>: يُصْرَفُ.</p></div>"
  51,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُتِلَ﴾</span>: لُعِنَ.</p><p><span class="qpc-hafs">﴿ٱلۡخَرَّ ٰ⁠صُونَ﴾</span>: الكَذّابُونَ الظّانُّونَ غيرَ الحقِّ.</p></div>"
  51,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَمۡرَةࣲ﴾</span>: لُجَّةِ مِنَ الكُفْرِ.</p><p><span class="qpc-hafs">﴿سَاهُونَ﴾</span>: غافِلُونَ.</p></div>"
  51,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّانَ﴾</span>: مَتى.</p><p><span class="qpc-hafs">﴿يَوۡمُ ٱلدِّينِ﴾</span>: يومُ الجَزاءِ.</p></div>"
  51,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُفۡتَنُونَ﴾</span>: يُعَذَّبُونَ بالإحْرِاقِ بالنّارِ.</p></div>"
  51,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَتَكُمۡ﴾</span>: عَذابَكُم.</p></div>"
  51,15,""
  51,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاخِذِينَ﴾</span>: قابِلينَ على وجْهِ الرِّضا.</p><p><span class="qpc-hafs">﴿ءَاتَىٰهُمۡ﴾</span>: أعْطاهُم.</p><p><span class="qpc-hafs">﴿مُحۡسِنِينَ﴾</span>: فاعِلِينَ الحَسَناتِ والطّاعاتِ.</p></div>"
  51,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡجَعُونَ﴾</span>: يَنامُونَ.</p></div>"
  51,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبِٱلۡأَسۡحَارِ﴾</span>: جَمْعُ سَحَر، وهُو آخِرُ الليلِ.</p></div>"
  51,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقࣱّ﴾</span>: واجِبٌ ثابِتٌ.</p><p><span class="qpc-hafs">﴿لِّلسَّآئِلِ﴾</span>: الَّذِي يُظْهِرُ فَقْرَهُ فَيسْأَلُ النّاسَ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَحۡرُومِ﴾</span>: الفَقِيرِ الُمتَعَفِّفِ.</p></div>"
  51,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّلۡمُوقِنِينَ﴾</span>: لِأَهْلِ اليقِينِ بِأنّ اللهَ ورَسُولَه حَقٌّ.</p></div>"
  51,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفِيٓ أَنفُسِكُمۡ﴾</span>: وفي خَلْقِ أنْفُسِكُم دَلائِلُ وعِبَرٌ.</p></div>"
  51,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِزۡقُكُمۡ﴾</span>: مادَّةُ رِزْقِكُم مِنَ الأمْطارِ وما قَدَّرَهُ اللهُ.</p><p><span class="qpc-hafs">﴿وَمَا تُوعَدُونَ﴾</span>: مِنَ الجَزاءِ في الدُّنيا والآخِرةِ.</p></div>"
  51,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّثۡلَ مَآ أَنَّكُمۡ تَنطِقُونَ﴾</span>: فَتَحَقَّقَ الوعِيدُ مِثْلَ نُطْقِكُم الَّذِي لا تَشُكُّونَ فِيهِ.</p></div>"
  51,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡفِ إِبۡرَ ٰ⁠هِيمَ﴾</span>: هُم مِن الملائِكةِ.</p></div>"
  51,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَـٰمࣰا﴾</span>: سَلَّمنا سَلاما.</p><p><span class="qpc-hafs">﴿سَلَـٰمࣱ﴾</span>: أمْرِي سَلامٌ لَكُم.</p><p><span class="qpc-hafs">﴿مُّنكَرُونَ﴾</span>: لا أعْرِفُهُم.</p></div>"
  51,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَاغَ﴾</span>: فَمال خِفْيَةً.</p></div>"
  51,27,""
  51,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَوۡجَسَ﴾</span>: أحَسَّ في نَفْسِهِ.</p><p><span class="qpc-hafs">﴿بِغُلَـٰمٍ عَلِيمࣲ﴾</span>: هو إسْحاقُ عَلَيهِ السَّلامُ.</p></div>"
  51,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرَّةࣲ﴾</span>: صَيْحَةٍ.</p><p><span class="qpc-hafs">﴿فَصَكَّتۡ﴾</span>: فَلَطَمَتْ.</p><p><span class="qpc-hafs">﴿عَقِيمࣱ﴾</span>: لا تَحْمِلُ.</p></div>"
  51,30,""
  51,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا خَطۡبُكُمۡ﴾</span>: فَما شَأنُكُم؟</p></div>"
  51,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوۡمࣲ مُّجۡرِمِينَ﴾</span>: هُم قَومُ لُوطٍ عَلَيهِ السَّلامُ.</p></div>"
  51,33,""
  51,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّسَوَّمَةً﴾</span>: عَلَيها عَلامةٌ، وكَلُّ حَجَرٍ عَلَيهِ اسْمُ صاحِبِهِ.</p><p><span class="qpc-hafs">﴿لِلۡمُسۡرِفِينَ﴾</span>: للمُفَرِّطِينَ بِكُفْرِهِم وشِيُوعِ الفاحِشَةِ فِيهِم.</p></div>"
  51,35,""
  51,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيۡتࣲ﴾</span>: بيتِ لُوطٍ عَلَيهِ السَّلامُ.</p></div>"
  51,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرَكۡنَا﴾</span>: أبْقينا.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: أثَرًا مِن العَذابِ والخَرابِ يُتَّعظُ بِها.</p></div>"
  51,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنࣲ﴾</span>: بِحُجَّةٍ.</p></div>"
  51,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّىٰ﴾</span>: فَأَعْرَضَ.</p><p><span class="qpc-hafs">﴿بِرُكۡنِهِۦ﴾</span>: بِقُوَّتِهِ وجانِبِهِ.</p></div>"
  51,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُ﴾</span>: فَأَهْلَكْناهُ.</p><p><span class="qpc-hafs">﴿فَنَبَذۡنَـٰهُمۡ﴾</span>: فَطَرحْناهُم.</p><p><span class="qpc-hafs">﴿ٱلۡيَمِّ﴾</span>: البَحْرِ.</p><p><span class="qpc-hafs">﴿مُلِيمࣱ﴾</span>: مُسْتَوْجِبٌ العِقابَ، آتٍ بِما يَلُومُهُ اللهُ عَلَيهِ.</p></div>"
  51,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَقِيمَ﴾</span>: التي لا بَرَكَةَ فِيها ولا تَأْتِي بِخَيرٍ.</p></div>"
  51,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تَذَرُ﴾</span>: ما تَدَعُ.</p><p><span class="qpc-hafs">﴿كَٱلرَّمِيمِ﴾</span>: العَظْمِ الَّذِي بَلِي فَتَفَتَّتَ.</p></div>"
  51,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمَتَّعُواْ﴾</span>: مُباحٌ لكُم أن تَتَمَتَّعُوا بِنِعَمِ الدُّنيا الزّائِلةِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ حِينࣲ﴾</span>: إلى آجالِكُم.</p></div>"
  51,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَتَوۡاْ﴾</span>: تَكَبَّرُوا فَأَعْرَضُوا.</p><p><span class="qpc-hafs">﴿فَأَخَذَتۡهُمُ﴾</span>: فَأَصابَتْهُم.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰعِقَةُ﴾</span>: الصَّيحَةُ العَظِيمَةُ الُمهْلِكَةُ.</p><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: إلى عُقُوبَتِهِم بأَعْيُنِهِم فَيَكُونُ أشَدَّ للعُقُوبَةِ.</p></div>"
  51,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِيَامࣲ﴾</span>: نُهُوضٍ ودِفاعٍ.</p></div>"
  51,46,""
  51,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَنَيۡنَـٰهَا﴾</span>: خَلَقْناها وجَعَلْناها سَقْفًا لِلأَرْضِ.</p><p><span class="qpc-hafs">﴿بِأَيۡيْدࣲ﴾</span>: بِقُوِّةٍ.</p><p><span class="qpc-hafs">﴿لَمُوسِعُونَ﴾</span>: لَمُقْتَدِرُونَ، مِن أوْسَعَ إذا كانَ ذا وُسْعٍ وهي القُدْرَةُ.</p></div>"
  51,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَشۡنَـٰهَا﴾</span>: جَعَلْناها فِراشًا لاسْتِقْرارِ الخَلْقِ عَلَيها.</p><p><span class="qpc-hafs">﴿ٱلۡمَـٰهِدُونَ﴾</span>: المُوطِّئُونَ الَمُهَيِّئُونَ.</p></div>"
  51,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَوۡجَيۡنِ﴾</span>: صِنْفَينِ ذَكَرًا وأُنْثى.</p></div>"
  51,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَفِرُّوٓاْ﴾</span>: فارِقُوا الشِّرْكَ المُسَبِّبَ لِعَذابِكُم.</p></div>"
  51,51,""
  51,52,""
  51,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَوَاصَوۡاْ﴾</span>: هَلْ أوصْىَ بَعْضُهُم بَعْضًا؟</p><p><span class="qpc-hafs">﴿طَاغُونَ﴾</span>: مُتَعَدُّونَ، طُغاةٌ عَنْ أمْرِ رَبِّهِم.</p></div>"
  51,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ﴾</span>: فأَعْرِضْ عَنْهُم.</p><p><span class="qpc-hafs">﴿فَمَآ أَنتَ بِمَلُومࣲ﴾</span>: فَلَيسَ عَلَيكَ لَوْمٌ في ذَنْبِهِم.</p></div>"
  51,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلذِّكۡرَىٰ﴾</span>: التَّذْكِيرَ والمَوعِظَةَ.</p></div>"
  51,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَعۡبُدُونِ﴾</span>: إرادَةَ أن يَعْبُدُونِي إرادَةً شَرْعِيَّةً دِينِيَّةً، وقَدْ تَقَعُ العِبادة وقَدْ لا تَقَعُ.</p></div>"
  51,57,""
  51,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَتِينُ﴾</span>: الشَّدِيدُ الكامِلُ في قُوَّتِهِ.</p></div>"
  51,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَنُوبࣰا﴾</span>: حَظًّا ونَصِيبًا.</p></div>"
  51,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: عَذابٌ وهَلاكٌ.</p></div>"
