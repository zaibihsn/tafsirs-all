quran[135]{c,v,t}:
  20,1,""
  20,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَشۡقَىٰٓ﴾</span>: لِتَتْعبَ بفَرْطِ تأسُّفِكَ على كُفْرِهِم.</p></div>"
  20,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَذۡكِرَةࣰ﴾</span>: عِظَةً وعِبْرةً.</p></div>"
  20,4,""
  20,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هو سَرِيَرُ المُلْكِ الذي اسْتَوى عَلَيه الرحمنُ، وتَحمِلُه الملائِكةُ، وهو أعْظَمُ المخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: عَلا وارْتَفَعَ، اسْتِواءً يلِيقُ بِجَلالِه وعَظَمَتِه.</p></div>"
  20,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تَحۡتَ ٱلثَّرَىٰ﴾</span>: باطِنِ الأَرْضِ.</p></div>"
  20,7,""
  20,8,""
  20,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَدِيثُ مُوسَىٰٓ﴾</span>: خبرُ مُوسى بن عِمْرانَ عليه الصَّلاةُ والسَّلامُ، لمّا رَجَعَ مِن مَدْيَنَ إلى مِصْرَ.</p></div>"
  20,10,""
  20,11,""
  20,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طُوࣰى﴾</span>: اسْمِ الوادِي الُمقَدَّسِ.</p></div>"
  20,13,""
  20,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِذِكۡرِيٓ﴾</span>: لِتَذْكُرَني فِيها.</p></div>"
  20,15,""
  20,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا يَصُدَّنَّكَ﴾</span>: فلا يَصْرِفَنَّكَ.</p><p><span class="qpc-hafs">﴿فَتَرۡدَىٰ﴾</span>: فَتَهْلَكَ.</p></div>"
  20,17,""
  20,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَوَكَّؤُاْ عَلَيۡهَا﴾</span>: أعْتَمِدُ عَلَيها في المَشْيِ.</p><p><span class="qpc-hafs">﴿وَأَهُشُّ بِهَا﴾</span>: وأَهُزُّ بِها الشَّجَرَ لِيَسْقُطَ مِنه الوَرَقُ.</p><p><span class="qpc-hafs">﴿مَـَٔارِبُ﴾</span>: حاجاتٌ ومَنافعُ.</p></div>"
  20,19,""
  20,20,""
  20,21,""
  20,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَىٰ جَنَاحِكَ﴾</span>: جَنبِك تَحْتَ العَضُدِ.</p><p><span class="qpc-hafs">﴿مِنۡ غَيۡرِ سُوٓءٍ﴾</span>: مِن غَيرِ مَرَضٍ ولا بَرَصٍ.</p></div>"
  20,23,""
  20,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: تَجاوَزَ حَدَّه بالتَّمَرُّدِ على ربِّه.</p></div>"
  20,25,""
  20,26,""
  20,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱحۡلُلۡ عُقۡدَةࣰ مِّن لِّسَانِي﴾</span>: وأَطْلِقْ عَنْ لِساني العُقْدَةَ التي فِيه.</p></div>"
  20,28,""
  20,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزِيرࣰا﴾</span>: مُعِينًا في إبْلاغِ رِسالتِكَ.</p></div>"
  20,30,""
  20,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡدُدۡ بِهِۦٓ أَزۡرِي﴾</span>: قَوِّني به وشُدَّ به ظَهْري.</p></div>"
  20,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أَمۡرِي﴾</span>: في النُّبوَّةِ وتَبْلِيغِ الرِّسالةِ.</p></div>"
  20,33,""
  20,34,""
  20,35,""
  20,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوتِيتَ سُؤۡلَكَ﴾</span>: أُعطِيتَ كلَّ ما سألتَ.</p></div>"
  20,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدۡ مَنَنَّا عَلَيۡكَ﴾</span>: ولَقَدْ أنْعَمْنا عَلَيكَ.</p><p><span class="qpc-hafs">﴿مَرَّةً أُخۡرَىٰٓ﴾</span>: نِعْمَةً أُخْرى بإنْجائِكَ مِن بَطْشِ فِرْعَونَ وجُنُودِه حِينَ كُنْتَ رَضِيعًا.</p></div>"
  20,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡحَيۡنَآ﴾</span>: ألْهَمْنا.</p></div>"
  20,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱقۡذِفِيهِ﴾</span>: ضَعِيه.</p><p><span class="qpc-hafs">﴿ٱلتَّابُوتِ﴾</span>: الصُّنْدُوقِ الخَشَبِيِّ.</p><p><span class="qpc-hafs">﴿فَٱقۡذِفِيهِ فِي ٱلۡيَمِّ﴾</span>: فاطْرَحِيه في النِّيلِ.</p><p><span class="qpc-hafs">﴿وَأَلۡقَيۡتُ عَلَيۡكَ مَحَبَّةࣰ مِّنِّي﴾</span>: أي: أحْبَبْتُك، فَصِرْتَ بِذَلكَ مَحْبُوبًا بَيْنَ العِبادِ.</p><p><span class="qpc-hafs">﴿وَلِتُصۡنَعَ عَلَىٰ عَيۡنِيٓ﴾</span>: ولِتُرَبّى بِمَرأىً مِنِّي.</p></div>"
  20,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡ تَقَرَّ عَيۡنُهَا﴾</span>: كي تُسَرَّ أُمُّ مُوسى بِسَلامةِ ولَدِها ورُجُوعِه إليها.</p><p><span class="qpc-hafs">﴿وَفَتَنَّـٰكَ﴾</span>: وابْتَلَيناك.</p><p><span class="qpc-hafs">﴿عَلَىٰ قَدَرࣲ﴾</span>: عَلى مَوْعِدٍ مُوافِقٍ للوقْتِ الُمقدَّرِ في عِلْمِ اللهِ تَعالى.</p></div>"
  20,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡطَنَعۡتُكَ لِنَفۡسِي﴾</span>: هَيَّأْتُكَ لِتَبْلِيغِ الرِّسالةِ عَنِّي.</p></div>"
  20,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَنِيَا﴾</span>: ولا تَضْعُفا.</p></div>"
  20,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: جاوَزَ الحَدَّ في الكُفْرِ والظُّلْمِ.</p></div>"
  20,44,""
  20,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَفۡرُطَ عَلَيۡنَآ﴾</span>: أن يُعاجِلَنا ويُبادِرَ بالعُقُوبَةِ.</p><p><span class="qpc-hafs">﴿أَوۡ أَن يَطۡغَىٰ﴾</span>: أو أن يَتَمَرَّدَ على الحقِّ فلا يَقْبَلَه.</p></div>"
  20,46,""
  20,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُعَذِّبۡهُمۡ﴾</span>: أي: ولا تُعَذِّبْهم بِذَبْحِ أبْنائِهِم واسْتِحْياءِ بَناتِهِم وتَكْلِيفِهِم بِما لا يُطِيقُونَ مِنَ الأَعْمالِ.</p></div>"
  20,48,""
  20,49,""
  20,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلۡقَهُۥ﴾</span>: أي: صورتَه اللائِقَةَ بخاصَّتِه ومَنفَعَتِه.</p></div>"
  20,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا بَالُ ٱلۡقُرُونِ ٱلۡأُولَىٰ﴾</span>: فما شأنُ الأممِ السّابِقَةِ؟</p></div>"
  20,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي كِتَـٰبࣲ﴾</span>: وهو اللَّوحُ الَمحْفُوظُ.</p><p><span class="qpc-hafs">﴿لَّا يَضِلُّ رَبِّي﴾</span>: أي: لا يُخْطِئُ ربِّي في أفْعالِه وأَحْكامِه.</p><p><span class="qpc-hafs">﴿وَلَا يَنسَى﴾</span>: أيَّ شيءٍ ممّا عَلِمه مِنها.</p></div>"
  20,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَهۡدࣰا﴾</span>: أي: مُيَسَّرةً للانْتِفاعِ بِها، فَصارَتْ كالفِراشِ والِمْهادِ لكلِّ واحدٍ مِنكُم.</p><p><span class="qpc-hafs">﴿وَسَلَكَ لَكُمۡ فِيهَا سُبُلࣰا﴾</span>: وجَعَل لَكُم فِيها طُرُقًا كَثِيرَةً.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا مِّن نَّبَاتࣲ شَتَّىٰ﴾</span>: أنْواعًا مُخْتَلِفَةً مِنَ النَّباتِ.</p></div>"
  20,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلنُّهَىٰ﴾</span>: لِذَوي العُقُولِ السَّلِيمَةِ.</p></div>"
  20,55,""
  20,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِنَا﴾</span>: أدلَّتَنا وحُجَجَنا.</p><p><span class="qpc-hafs">﴿وَأَبَىٰ﴾</span>: وامْتَنَعَ عَن قَبُولِ الحَقِّ.</p></div>"
  20,57,""
  20,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَانࣰا سُوࣰى﴾</span>: في مَكانٍ مُعْتَدِلٍ مُسْتَوٍ بَيْنَنا وبَيْنَكَ.</p></div>"
  20,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمُ ٱلزِّينَةِ﴾</span>: يومُ العيدِ حِينَ يتزيَّنُ الناسُ.</p><p><span class="qpc-hafs">﴿وَأَن يُحۡشَرَ﴾</span>: وأن يُجْمَعَ.</p></div>"
  20,60,""
  20,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَفۡتَرُواْ﴾</span>: لا تَخْتَلِقُوا.</p><p><span class="qpc-hafs">﴿فَيُسۡحِتَكُم﴾</span>:. فَيَسْتَأْصِلَكُم ويُبِيدَكُمْ.</p><p><span class="qpc-hafs">﴿خَابَ﴾</span>: خَسِرَ وهَلَكَ.</p></div>"
  20,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَسَرُّواْ ٱلنَّجۡوَىٰ﴾</span>: تَحادَثَ السَّحَرةُ سِرًّا في خَفاءٍ.</p></div>"
  20,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِطَرِيقَتِكُمُ ٱلۡمُثۡلَىٰ﴾</span>: بِطَرِيقةِ السِّحْرِ العظيمةِ التي أنْتُم عَلَيها.</p></div>"
  20,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَجۡمِعُواْ كَيۡدَكُمۡ﴾</span>: فأَحْكِمُوا مَكْرَكُم، ولا تَجْعَلُوهُ مُتَفَرِّقًا.</p><p><span class="qpc-hafs">﴿مَنِ ٱسۡتَعۡلَىٰ﴾</span>: مَن عَلا عَلى صاحِبِه فَغَلَبَهُ وقَهَرَهُ.</p></div>"
  20,65,""
  20,66,""
  20,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَوۡجَسَ﴾</span>: فَأَضْمَرَ.</p><p><span class="qpc-hafs">﴿خِيفَةࣰ﴾</span>: خَوْفًا.</p></div>"
  20,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنتَ ٱلۡأَعۡلَىٰ﴾</span>: أنتَ الغالِبُ على هَؤلاءِ السَّحَرةِ.</p></div>"
  20,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلۡقَفۡ﴾</span>: تَبْتَلِعْ بِسُرْعَةٍ.</p><p><span class="qpc-hafs">﴿وَلَا يُفۡلِحُ ٱلسَّاحِرُ﴾</span>: ولا يَظْفَرَ السَّحرةُ بِبُغْيتِهِم.</p></div>"
  20,70,""
  20,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خِلَـٰفࣲ﴾</span>: مُخالِفًا بينها: يدًا مِن جِهَةٍ ورِجْلًا مِنَ الجِهَةِ الأخْرى.</p><p><span class="qpc-hafs">﴿وَلَأُصَلِّبَنَّكُمۡ﴾</span>: ولَأُبالِغَنّ في شَدِّ أطْرافِكَم ورَبْطِ أجْسادِكُم.</p><p><span class="qpc-hafs">﴿فِي جُذُوعِ ٱلنَّخۡلِ﴾</span>: على جُذُوعِ النَّخْلِ.</p><p><span class="qpc-hafs">﴿وَأَبۡقَىٰ﴾</span>: وأَدْوَمُ، لا يَنْقَطِعُ.</p></div>"
  20,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن نُّؤۡثِرَكَ﴾</span>: لن نُفَضِّلَكَ.</p></div>"
  20,73,""
  20,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُجۡرِمࣰا﴾</span>: كافِرًا.</p><p><span class="qpc-hafs">﴿لَا يَمُوتُ فِيهَا وَلَا يَحۡيَىٰ﴾</span>: أي: لا يمُوتُ فيها فَيَسْتَرِيحَ، ولا يحيا حياةً يتلذَّذُ بِها.</p></div>"
  20,75,""
  20,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: جَنّاتُ إقامَةٍ دائمةٍ.</p><p><span class="qpc-hafs">﴿مَن تَزَكَّىٰ﴾</span>: مَن تَطهَّرَ مِنَ الكُفْرِ والمَعاصِي.</p></div>"
  20,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡ أَسۡرِ﴾</span>: أنِ اخْرُجْ ليلًا بِعِبادِي.</p><p><span class="qpc-hafs">﴿فَٱضۡرِبۡ لَهُمۡ﴾</span>: فاجْعَلْ لهم.</p><p><span class="qpc-hafs">﴿يَبَسࣰا﴾</span>: يابسًا لا ماءٌ فِيها ولا طِينٌ.</p><p><span class="qpc-hafs">﴿لَّا تَخَـٰفُ دَرَكࣰا﴾</span>: لا تخافُ مِن فِرْعَونَ وجُنُودِهِ أن يَلْحَقَ بكُم فيُدْرِكَكُم.</p><p><span class="qpc-hafs">﴿وَلَا تَخۡشَىٰ﴾</span>: ولا تَخْشى مِنَ الغَرَقِ في البَحْرِ.</p></div>"
  20,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَغَشِيَهُم مِّنَ ٱلۡيَمِّ مَا غَشِيَهُمۡ﴾</span>: فَغَمَرَهُم مِن مّاءِ البَحْرِ ما لا يَعْلَمُ كُنهَه إلّا اللهُ.</p></div>"
  20,79,""
  20,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَنَّ﴾</span>: شيءٌ يُشْبِهُ الصَّمْغَ، طَعْمُه كالعَسَلِ.</p><p><span class="qpc-hafs">﴿وَٱلسَّلۡوَىٰ﴾</span>: طَيرٌ يُشْبِهُ السُّمانى.</p></div>"
  20,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَطۡغَوۡاْ فِيهِ﴾</span>: ولا تَحْمِلنَّكُم العافيةُ والسَّعَةُ في الرِّزقِ على تَجاوُزِ الحدِّ في العِصْيانِ.</p><p><span class="qpc-hafs">﴿فَيَحِلَّ عَلَيۡكُمۡ﴾</span>: فيَنْزِلَ بِكُم.</p><p><span class="qpc-hafs">﴿هَوَىٰ﴾</span>: هَلَكَ وخَسِرَ.</p></div>"
  20,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ ٱهۡتَدَىٰ﴾</span>: ثُمَّ التَزَمَ الهِدايةَ واسْتَقامَ عَلَيها.</p></div>"
  20,83,""
  20,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰٓ أَثَرِي﴾</span>: خَلْفي سَوفَ يَلْحَقُون بِي.</p><p><span class="qpc-hafs">﴿لِتَرۡضَىٰ﴾</span>: لِتَزْدادَ عَنِّي رِضًا.</p></div>"
  20,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدۡ فَتَنَّا﴾</span>: قد ابتلينا.</p><p><span class="qpc-hafs">﴿وَأَضَلَّهُمُ﴾</span>: دَعاهُم إلى الضَّلالَةِ التي هِيَ عِبادةُ العِجْلِ.</p><p><span class="qpc-hafs">﴿ٱلسَّامِرِيُّ﴾</span>: مَنسُوبٌ إلى «قبيلةِ السّامِرَة» قيل: كان إسْرائِيليًا، وقيل: كانَ قِبْطيًا.</p></div>"
  20,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسِفࣰا﴾</span>: حَزِينًا كَئِيبًا.</p><p><span class="qpc-hafs">﴿وَعۡدًا حَسَنًا﴾</span>: أي: بإنزالِ التَّوراةِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَهۡدُ﴾</span>: الزَّمانُ.</p><p><span class="qpc-hafs">﴿فَأَخۡلَفۡتُم مَّوۡعِدِي﴾</span>: خالفْتُم ما وعَدْتُّمُونِي مِن عِبادَةِ اللهِ وحْدَه.</p></div>"
  20,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَلۡكِنَا﴾</span>: باخْتِيارِنا.</p><p><span class="qpc-hafs">﴿أَوۡزَارࣰا﴾</span>: أثْقالًا.</p><p><span class="qpc-hafs">﴿مِّن زِينَةِ ٱلۡقَوۡمِ﴾</span>: مِن حُلِيِّ قومِ فِرْعَونَ.</p><p><span class="qpc-hafs">﴿فَقَذَفۡنَـٰهَا﴾</span>: فَأَلْقَينا الحُلِيَّ في النّارِ.</p><p><span class="qpc-hafs">﴿فَكَذَ ٰ⁠لِكَ أَلۡقَى ٱلسَّامِرِيُّ﴾</span>: أي: فَكَذَلِك ألْقى السّامِريُّ ما كان مَعَهُ مِن تُرْبَةِ حافِرِ فَرَسِ جِبْريلَ عليه السَّلامُ.</p></div>"
  20,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِجۡلࣰا جَسَدࣰا﴾</span>: مَعْبُودًا مِن ذَهَبِهِم على صُورَةِ العِجْلِ بلا رُوحٍ.</p><p><span class="qpc-hafs">﴿لَّهُۥ خُوَارࣱ﴾</span>: له صَوْتٌ يُشْبِهُ صوتَ البَقَرِ.</p><p><span class="qpc-hafs">﴿فَنَسِيَ﴾</span>: فَغَفَلَ عنه مُوسى نِسْيانًا.</p></div>"
  20,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَّا يَرۡجِعُ إِلَيۡهِمۡ قَوۡلࣰا﴾</span>: لا يُكَلِّمُهم ولا يَرُدُّ عَلِيهِم جَوابًا.</p></div>"
  20,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُتِنتُم بِهِۦ﴾</span>: بِهَذا العِجْلِ.</p></div>"
  20,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن نَّبۡرَحَ عَلَيۡهِ عَـٰكِفِينَ﴾</span>: لَن نَزالَ مُقيمِينَ على عِبادَةِ العِجْل.</p></div>"
  20,92,""
  20,93,""
  20,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمۡ تَرۡقُبۡ قَوۡلِي﴾</span>: ولَمْ تَعْمَلْ بوَصِيَّتِي لَكَ فِيهِم.</p></div>"
  20,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا خَطۡبُكَ﴾</span>: أي: ما الَّذِي حَمَلَكَ على ما صَنَعْتَ؟</p></div>"
  20,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَبَضۡتُ قَبۡضَةࣰ﴾</span>: فَأَخَذْتُ بِكَفِّي تُرابًا.</p><p><span class="qpc-hafs">﴿مِّنۡ أَثَرِ ٱلرَّسُولِ﴾</span>: مِن أثَرِ حافِرِ فرسِ جِبْرِيلَ عليهِ السلامُ.</p><p><span class="qpc-hafs">﴿فَنَبَذۡتُهَا﴾</span>: فألقيتُ حَفْنَةَ التُّرابِ على الحُليِّ التي صُنِعَ منها العِجلُ.</p><p><span class="qpc-hafs">﴿سَوَّلَتۡ لِي نَفۡسِي﴾</span>: زَيَّنَتْ لي نَفْسِي ما صَنَعْتُ.</p></div>"
  20,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا مِسَاسَ﴾</span>: أي لا يَمَسَّكَ أحدٌ، ولا تَمَسَّ أحدًا في الدُّنيا، فَتَعِيشَ مَنبُوذًا.</p><p><span class="qpc-hafs">﴿لَكَ مَوۡعِدࣰا﴾</span>: أي: في الآخرةِ لِعِقابِك.</p><p><span class="qpc-hafs">﴿لَّن تُخۡلَفَهُۥ﴾</span>: لَن يُخْلِفَكَ اللهُ إيّاهُ.</p><p><span class="qpc-hafs">﴿ظَلۡتَ عَلَيۡهِ عَاكِفࣰا﴾</span>: أقمتَ مواظِبًا على عبادتِه.</p><p><span class="qpc-hafs">﴿ثُمَّ لَنَنسِفَنَّهُۥ﴾</span>: ثم لنَذْرُوَنَّه حَتّى لا يَبْقى منه أثَرٌ.</p><p><span class="qpc-hafs">﴿ٱلۡيَمِّ﴾</span>: البَحرِ.</p></div>"
  20,98,""
  20,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرࣰا﴾</span>: القرآنَ؛ لِما فيه مِنَ التَّذْكِيرِ.</p></div>"
  20,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وِزۡرًا﴾</span>: إثمًا عَظِيمًا.</p></div>"
  20,101,""
  20,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الذي يُنفَخُ فيه للبعثِ.</p><p><span class="qpc-hafs">﴿وَنَحۡشُرُ﴾</span>: نَسُوقُ.</p><p><span class="qpc-hafs">﴿زُرۡقࣰا﴾</span>: زُرْقَ العُيونِ والأجْسادِ من هَوْلِ المصيبة.</p></div>"
  20,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَخَـٰفَتُونَ بَيۡنَهُمۡ﴾</span>: يَتَسارُّونَ فِيما بَيْنَهم.</p></div>"
  20,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡثَلُهُمۡ طَرِيقَةً﴾</span>: أعْلَمُهم وأَكْمَلُهم رأيًا.</p></div>"
  20,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنسِفُهَا رَبِّي نَسۡفࣰا﴾</span>: يَقْلعُها رَبي مِن أُصُولِها فَتَتَطايرُ كالصُّوفِ المنفُوشِ.</p></div>"
  20,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَيَذَرُهَا﴾</span>: فَيَتْرُكُ الأرضَ.</p><p><span class="qpc-hafs">﴿قَاعࣰا﴾</span>: أرْضًا لا نَباتٌ فيها ولا بناءٌ.</p><p><span class="qpc-hafs">﴿صَفۡصَفࣰا﴾</span>: مَلْساءَ مُسْتَوِيَةً.</p></div>"
  20,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِوَجࣰا﴾</span>: مَيْلًا.</p><p><span class="qpc-hafs">﴿وَلَآ أَمۡتࣰا﴾</span>: ولا ارْتفِاعًا ولا انْخِفاضًا.</p></div>"
  20,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا عِوَجَ﴾</span>: لا مَحِيدَ لهم من اتِّباعِ داعِي اللهِ إلى المَحْشَرِ.</p><p><span class="qpc-hafs">﴿هَمۡسࣰا﴾</span>: صَوْتًا خَفِيًّا.</p></div>"
  20,109,""
  20,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا بَيۡنَ أَيۡدِيهِمۡ﴾</span>: أي: مِن أمْرِ القِيامةِ.</p><p><span class="qpc-hafs">﴿وَمَا خَلۡفَهُمۡ﴾</span>: أي: مِن أمْرِ الدُّنْيا.</p></div>"
  20,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَنَتِ﴾</span>: ذلَّتْ وخَضَعَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡقَيُّومِ﴾</span>: الدّائِمِ القَيّامِ بِتَدْبِيرِ الخَلْقِ وحِفْظِهِم.</p><p><span class="qpc-hafs">﴿خَابَ﴾</span>: خَسِرَ وهَلَكَ.</p><p><span class="qpc-hafs">﴿ظُلۡمࣰا﴾</span>: شِرْكًا باللهِ.</p></div>"
  20,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظُلۡمࣰا وَلَا هَضۡمࣰا﴾</span>: ظُلْمًا بِزيادةِ سَيِّئاتِه في الآخِرةِ، ولا هَضْمًا بِنَقْصِ حَسَناتِه فيها.</p></div>"
  20,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ يُحۡدِثُ لَهُمۡ ذِكۡرࣰا﴾</span>: أي: يُحدِثُ فِيهم هذا القرآنُ تَذَكُّرًا واعْتِبارًا.</p></div>"
  20,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ﴾</span>: لا تُسارِعْ بِقِراءتِه.</p><p><span class="qpc-hafs">﴿مِن قَبۡلِ أَن يُقۡضَىٰٓ إِلَيۡكَ وَحۡيُهُۥ﴾</span>: من قَبْلِ أن يَفرغَ جبريلُ ويُتِمَّ إليك الوحيَ.</p></div>"
  20,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَهِدۡنَآ إِلَىٰٓ ءَادَمَ﴾</span>: وصَّيناهُ، أو أوحينا إليه.</p><p><span class="qpc-hafs">﴿عَزۡمࣰا﴾</span>: قوَّةً في الإرادةِ يَحْفَظُ بها ما أُمِرَ به.</p></div>"
  20,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبَىٰ﴾</span>: امْتَنَعَ مِنَ السُّجُودِ اسْتِكْبارًا.</p></div>"
  20,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَشۡقَىٰٓ﴾</span>: فتعانيَ المتاعِبَ والمشاقَّ في الدُّنيا.</p></div>"
  20,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَّا تَجُوعَ فِيهَا﴾</span>: أي: لا يُصِيبَكَ في الجنَّةِ جُوعٌ.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡرَىٰ﴾</span>: أي: لا تَعْرى فيها عن الملابِسِ.</p></div>"
  20,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَظۡمَؤُاْ فِيهَا﴾</span>: لا يُصِيبُكَ في الجنَّةِ عَطَشٌ.</p><p><span class="qpc-hafs">﴿وَلَا تَضۡحَىٰ﴾</span>: ولا يُصيبُك حرُّ شَمْسٍ.</p></div>"
  20,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرَةِ ٱلۡخُلۡدِ﴾</span>: هي الشجرةُ التي مَن أكَلَ مِنها لم يَمُتْ.</p><p><span class="qpc-hafs">﴿لَّا يَبۡلَىٰ﴾</span>: لا يَنْقَطِعُ.</p></div>"
  20,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَدَتۡ لَهُمَا سَوۡءَ ٰ⁠ تُهُمَا﴾</span>: فانْكَشَفَتْ لِآدَمَ وحَوّاءَ عَوْراتُهما.</p><p><span class="qpc-hafs">﴿وَطَفِقَا يَخۡصِفَانِ﴾</span>: وجَعلا يَلْصَقان.</p><p><span class="qpc-hafs">﴿فَغَوَىٰ﴾</span>: فَضَلَّ طَريقَ الصَّوابِ.</p></div>"
  20,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱجۡتَبَـٰهُ﴾</span>: اصْطَفاه.</p></div>"
  20,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱهۡبِطَا﴾</span>: انْزِلا مِنَ الجَنَّةِ إلى الأرضِ.</p><p><span class="qpc-hafs">﴿فَلَا يَضِلُّ﴾</span>: أي: عَن طَرِيقِ الهِدايةِ.</p><p><span class="qpc-hafs">﴿وَلَا يَشۡقَىٰ﴾</span>: لا يَشْقى في الآخرةِ بعِقابِ اللهِ.</p></div>"
  20,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرِي﴾</span>: أي: عَن ذِكْرِي الَّذِي أُذَكِّرهُ بِهِ مِن قُرآنٍ وغَيْرِهِ.</p><p><span class="qpc-hafs">﴿ضَنكࣰا﴾</span>: ضَيِّقةً شاقَّةً في حَياتِه وقَبْرِه.</p></div>"
  20,125,""
  20,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنَسِيتَهَا﴾</span>: أي: بِتَرْكِ الإيمانِ بها.</p><p><span class="qpc-hafs">﴿تُنسَىٰ﴾</span>: تُتْرَكُ في النّارِ.</p></div>"
  20,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنۡ أَسۡرَفَ﴾</span>: تَجاوَزَ حدودَ ما شَرَعَ اللهُ.</p><p><span class="qpc-hafs">﴿وَأَبۡقَىٰٓ﴾</span>: أدْوَمُ مِن عذابِ الدُّنيا، فلا يَنْقَطِعُ.</p></div>"
  20,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِ لَهُمۡ﴾</span>: أي: يَدُلَّهم على طَريقِ الرَّشادِ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡقُرُونِ﴾</span>: مِنَ الأُمَمِ الماضيةِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَعِبَرًا وعِظاتٍ.</p><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلنُّهَىٰ﴾</span>: لأصْحابِ العقولِ السَّلِيمةِ.</p></div>"
  20,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكَانَ لِزَامࣰا﴾</span>: لَلازَمَهم الهَلاكُ عاجِلًا؛ بسببِ كُفْرِهم.</p></div>"
  20,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَانَآيِٕ ٱلَّيۡلِ﴾</span>: ساعاتِ الليلِ.</p><p><span class="qpc-hafs">﴿تَرۡضَىٰ﴾</span>: أي: تُثابُ على عَمَلِك بما يُرضِيكَ.</p></div>"
  20,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَمُدَّنَّ عَيۡنَيۡكَ﴾</span>: لا تُكَرِّرِ النَّظَرَ إلى المُشْرِكِينَ مُسْتَحْسِنًا.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا مِّنۡهُمۡ﴾</span>: أصْنافًا مِن الكفّارِ.</p><p><span class="qpc-hafs">﴿زَهۡرَةَ ٱلۡحَيَوٰةِ﴾</span>: زينتَها وبَهْجَتَها التي لا تَدُومُ.</p><p><span class="qpc-hafs">﴿لِنَفۡتِنَهُمۡ﴾</span>: لِنَبْتليَهم.</p></div>"
  20,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡطَبِرۡ عَلَيۡهَا﴾</span>: داوِمْ على إقامةِ الصَّلاةِ بِصَبْرٍ.</p></div>"
  20,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةࣲ﴾</span>: بِمُعْجِزَةٍ.</p><p><span class="qpc-hafs">﴿بَيِّنَةُ مَا فِي ٱلصُّحُفِ ٱلۡأُولَىٰ﴾</span>: أي: هذا القرآنُ مصدِّقٌ لما في الكُتُبِ السّابِقَةِ مِنَ الحقِّ.</p></div>"
  20,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قَبۡلِهِۦ﴾</span>: أي: من قبْلِ أن نُرسِلَ إليهم رَسُولًا.</p><p><span class="qpc-hafs">﴿أَن نَّذِلَّ وَنَخۡزَىٰ﴾</span>: أن يُصيَبنا ذُلٌّ وخِزيٌ بعذابِكَ في الدُّنيا والآخِرةِ.</p></div>"
  20,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلࣱّ مُّتَرَبِّصࣱ﴾</span>: كلٌّ مِنّا ومِنكُم منتظِرٌ دوائرَ الزمانِ.</p><p><span class="qpc-hafs">﴿فَتَرَبَّصُواْ﴾</span>: فانْتَظِرُوا.</p></div>"
