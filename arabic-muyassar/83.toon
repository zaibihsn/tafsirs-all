quran[36]{c,v,t}:
  83,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: عذابٌ شَدِيدٌ.</p><p><span class="qpc-hafs">﴿لِّلۡمُطَفِّفِينَ﴾</span>: وهُمُ الَّذِينَ يَبْخَسُونَ المِكْيالَ والِميزانَ.</p></div>"
  83,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ إِذَا ٱكۡتَالُواْ عَلَى ٱلنَّاسِ﴾</span>: الَّذِينَ إذا اشْتَرَوا مِنَ النّاسِ مَكِيلًا أو مَوزُونًا.</p><p><span class="qpc-hafs">﴿يَسۡتَوۡفُونَ﴾</span>: يَطْلُبُونَ وفاءَ نَصِيبِهِم.</p></div>"
  83,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذَا كَالُوهُمۡ﴾</span>: وإذا باعُوا النّاس مَكِيلا.</p><p><span class="qpc-hafs">﴿وَّزَنُوهُمۡ﴾</span>: باعُوا النّاسَ مَوزُونًا.</p><p><span class="qpc-hafs">﴿يُخۡسِرُونَ﴾</span>: يَنْقُصُونَ في المِكيالِ والِميزانِ.</p></div>"
  83,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظُنُّ﴾</span>: يَعْتَقِدُ.</p></div>"
  83,5,""
  83,6,""
  83,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: ليسَ الأَمْرُ كَما يَظُنُّ هَؤُلِاءِ الكُفّارُ، أنّهم غَيرُ مَبْعُوثِينَ.</p><p><span class="qpc-hafs">﴿كِتَـٰبَ ٱلۡفُجَّارِ﴾</span>: صَحِيفةَ أعْمالِ المُشْرِكِينَ.</p><p><span class="qpc-hafs">﴿لَفِي سِجِّينࣲ﴾</span>: أسْفَلِ الأرْضِ السّابِعَةِ.</p></div>"
  83,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعْلَمكَ؟</p></div>"
  83,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرۡقُومࣱ﴾</span>: مَكْتُوبٌ كِتابَةً بَيِّنةً.</p></div>"
  83,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: عذابٌ شَدِيدٌ.</p></div>"
  83,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِيَوۡمِ ٱلدِّينِ﴾</span>: بُوقُوعِ يَومِ الجَزاءِ.</p></div>"
  83,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعۡتَدٍ﴾</span>: ظالِمٍ.</p><p><span class="qpc-hafs">﴿أَثِيمٍ﴾</span>: كَثِيرِ الإثْمِ.</p></div>"
  83,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: أباطِيلُ السّابِقِينَ.</p></div>"
  83,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُواْ يَكۡسِبُونَ﴾</span>: غَطّى عَلى قُلُوبِهِم كَثْرَةُ ما يَرْتَكِبُونَهُ مِنَ الذُّنُوبِ.</p></div>"
  83,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَن رَّبِّهِمۡ﴾</span>: عَن رُّؤْيَةِ رَبِّهِم -جَلَّ وعَلا-.</p><p><span class="qpc-hafs">﴿لَّمَحۡجُوبُونَ﴾</span>: لَمَمْنُوعُونَ.</p></div>"
  83,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَصَالُواْ ٱلۡجَحِيمِ﴾</span>: لَداخِلُو النّارِ.</p></div>"
  83,17,""
  83,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: حَقًّا.</p><p><span class="qpc-hafs">﴿كِتَـٰبَ﴾</span>: صَحائِفَ أعْمالِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَبۡرَارِ﴾</span>: الأَتْقِياءِ.</p><p><span class="qpc-hafs">﴿لَفِي عِلِّيِّينَ﴾</span>: لَفِي المراتِبِ العالِيَةِ في الجنَّةِ.</p></div>"
  83,19,""
  83,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبࣱ مَّرۡقُومࣱ﴾</span>: مَكْتُوبٌ كِتابَةً بَيِّنةً.</p></div>"
  83,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَشۡهَدُهُ﴾</span>: يَطَّلِعُ عَلَيهِ.</p></div>"
  83,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَبۡرَارَ﴾</span>: أهْلَ الصِّدْقِ والطّاعَةِ.</p><p><span class="qpc-hafs">﴿لَفِي نَعِيمٍ﴾</span>: لَفِي الجنَّةِ يَتَنَعَّمُونَ.</p></div>"
  83,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرَآئِكِ﴾</span>: الأَسِرَّةِ.</p><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: يَنْظُرُونَ إلى رَبِّهِم، وإلى ما أعَدَّ لَهُم مِن خَيراتٍ.</p></div>"
  83,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَضۡرَةَ ٱلنَّعِيمِ﴾</span>: بَهْجَةَ النَّعِيمِ وحُسْنَه.</p></div>"
  83,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَّحِيقࣲ﴾</span>: خَمْرٍ صافِيةٍ.</p><p><span class="qpc-hafs">﴿مَّخۡتُومٍ﴾</span>: مُحْكَمٍ إناؤُها.</p></div>"
  83,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خِتَـٰمُهُۥ﴾</span>: آخِرُهُ.</p><p><span class="qpc-hafs">﴿مِسۡكࣱ﴾</span>: رائِحَةُ مِسْكٍ.</p><p><span class="qpc-hafs">﴿فَلۡيَتَنَافَسِ ٱلۡمُتَنَـٰفِسُونَ﴾</span>: فَليَتَسابَقِ المُتَسابِقُونَ.</p></div>"
  83,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِزَاجُهُۥ مِن تَسۡنِيمٍ﴾</span>: وخَلْطُه مِن عَينٍ في الجنَّةِ تُعْرَفُ ب«تَسْنِيمٍ».</p></div>"
  83,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَشۡرَبُ بِهَا﴾</span>: مِنها.</p><p><span class="qpc-hafs">﴿ٱلۡمُقَرَّبُونَ﴾</span>: الملائكةُ المُقرَّبُونَ مِنَ اللهِ.</p></div>"
  83,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجۡرَمُواْ﴾</span>: ارْتَكَبُوا الإثمَ العَظِيمَ، وهو الشِّرْكُ.</p><p><span class="qpc-hafs">﴿يَضۡحَكُونَ﴾</span>: يَهْزَؤُونَ.</p></div>"
  83,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَغَامَزُونَ﴾</span>: يُشِيرُونَ بأطْرافِ العُيُونِ سُخْرِيَةً بِهم.</p></div>"
  83,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذَا ٱنقَلَبُوٓاْ﴾</span>: رَجَعُوا.</p><p><span class="qpc-hafs">﴿فَكِهِينَ﴾</span>: مُتَفَكِّهِينَ بالسُّخْرِيَةِ مِنَ المؤُمِنِينَ.</p></div>"
  83,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَأَوۡهُمۡ﴾</span>: رَأى هَؤُلاءِ الكُفّارُ أصْحابَ مُحَمَّدٍ ﷺ.</p></div>"
  83,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَـٰفِظِينَ﴾</span>: رُقَباءَ عَلى أصْحابِ مُحَمَّدٍ ﷺ.</p></div>"
  83,34,""
  83,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرَآئِكِ﴾</span>: المجالِسِ الفاخِرَةِ.</p><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: يَنْظُرُ المؤمِنُونَ إلى ما أعْطاهُم اللهُ مِنَ الكَرامةِ والنَّعِيم في الجنَّةِ.</p></div>"
  83,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ ثُوِّبَ ٱلۡكُفَّارُ﴾</span>: هل جُوزِي الكُفّارُ مِن جِنْسِ أعمالِهِم؟</p></div>"
