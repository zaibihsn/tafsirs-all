quran[40]{c,v,t}:
  78,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَمَّ﴾</span>: عَنْ أيِّ شَيءٍ.</p><p><span class="qpc-hafs">﴿يَتَسَآءَلُونَ﴾</span>: يَسْأَلُ بعضُ كُفّارِ قُريشٍ بَعْضًا.</p></div>"
  78,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّبَإِ ٱلۡعَظِيمِ﴾</span>: الخبرِ العَظِيمِ الشَّأنِ، وهو القُرآنُ العَظِيمُ الَّذي يُنْبِئُ عَنِ البَعْثِ.</p></div>"
  78,3,""
  78,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمْرُ كَما يَزْعُمُ هَؤلاءِ المشْرِكُونَ.</p><p><span class="qpc-hafs">﴿سَيَعۡلَمُونَ﴾</span>: أي: عاقبةَ تَكْذِيبِهِم.</p></div>"
  78,5,""
  78,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِهَـٰدࣰا﴾</span>: مُمَهَّدَةً لَكُم كالفِراشِ.</p></div>"
  78,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡتَادࣰا﴾</span>: رَواسِيَ.</p></div>"
  78,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا﴾</span>: أصْنافًا ذَكَرًا وأُنْثى.</p></div>"
  78,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبَاتࣰا﴾</span>: راحةً لأبدانِكُم، وتَسْكُنونَ؟</p></div>"
  78,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِبَاسࣰا﴾</span>: تَلْبَسُكُم ظُلْمَتُهُ، كَما يَسْتُرُ الثَّوبُ لابِسَهُ.</p></div>"
  78,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَعَاشࣰا﴾</span>: تَنتَشِرُونَ فِيهَ لِمصالِحِكُم.</p></div>"
  78,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبۡعࣰا﴾</span>: سَبْعَ سَمَواتٍ.</p><p><span class="qpc-hafs">﴿شِدَادࣰا﴾</span>: مَتِينَةَ البِناءِ، مُحْكَمةَ الخَلْقِ والإنْشاءِ.</p></div>"
  78,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِرَاجࣰا﴾</span>: شَمْسًا.</p><p><span class="qpc-hafs">﴿وَهَّاجࣰا﴾</span>: وقّادًا مُضِيئًا.</p></div>"
  78,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُعۡصِرَ ٰ⁠تِ﴾</span>: السُّحُبِ المُمْطِرَةِ.</p><p><span class="qpc-hafs">﴿ثَجَّاجࣰا﴾</span>: منصَبًّا بِكَثْرِةٍ.</p></div>"
  78,15,""
  78,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلۡفَافًا﴾</span>: مُلْتَفَّةً بعْضُها بِبَعْضٍ.</p></div>"
  78,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡفَصۡلِ﴾</span>: بينَ الخلْقِ، وهوَ يومُ القِيامَةِ.</p><p><span class="qpc-hafs">﴿مِيقَـٰتࣰا﴾</span>: وقْتًا ومِيعادًا مُحَدَّدًا للأولِينَ والآخِرِينَ.</p></div>"
  78,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنفَخُ فِي ٱلصُّورِ﴾</span>: يَنفُخُ المَلَكُ في «القَرْنِ» إيذانًا بالبَعْثِ.</p><p><span class="qpc-hafs">﴿أَفۡوَاجࣰا﴾</span>: أُمَمًا، كلُّ أُمَّةٍ مع إمامِهِم.</p></div>"
  78,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفُتِحَتِ﴾</span>: شُقِّقَتْ وصُدِّعتْ.</p><p><span class="qpc-hafs">﴿أَبۡوَ ٰ⁠بࣰا﴾</span>: ذاتَ أبوابٍ كَثِيرةٍ.</p></div>"
  78,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسُيِّرَتِ ٱلۡجِبَالُ﴾</span>: ونُسِفَتِ الجِبالُ.</p><p><span class="qpc-hafs">﴿سَرَابًا﴾</span>: يَظُنُّ مَن يَراهُ مِن بُعْدٍ ماءً، وهو في الحقِيقَةِ هَباءٌ.</p></div>"
  78,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِرۡصَادࣰا﴾</span>: تَرْقُبُ مَن يجتازُها.</p></div>"
  78,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّلطَّـٰغِينَ﴾</span>: للكافِرِينَ الَّذِينَ طَغَوا.</p><p><span class="qpc-hafs">﴿مَـَٔابࣰا﴾</span>: مَرْجِعًا.</p></div>"
  78,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّـٰبِثِينَ﴾</span>: ماكِثِينَ.</p><p><span class="qpc-hafs">﴿أَحۡقَابࣰا﴾</span>: دُهُورًا مُتَعاقِبةً لا تَنْقَطِعُ.</p></div>"
  78,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَذُوقُونَ﴾</span>: لا يُحِسُّونَ.</p><p><span class="qpc-hafs">﴿بَرۡدࣰا﴾</span>: نَسِيمًا باردًا.</p><p><span class="qpc-hafs">﴿شَرَابًا﴾</span>: ماءً يُرْوي.</p></div>"
  78,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمِيمࣰا﴾</span>: ماءً حارًّا.</p><p><span class="qpc-hafs">﴿وَغَسَّاقࣰا﴾</span>: وصَدِيدَ أهْلِ النّارِ.</p></div>"
  78,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وِفَاقًا﴾</span>: مُوافِقًا لأَعْمالِهِم.</p></div>"
  78,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ حِسَابࣰا﴾</span>: لا يَتَوَقَّعُونَ وُقُوعَ الجَزاءِ يَومَ القِيامَةِ.</p></div>"
  78,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بِما جاءَتْهُم بِهِ الرُّسُلُ.</p></div>"
  78,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبࣰا﴾</span>: كَتَبْناهُ في اللَّوحِ المَحْفُوظِ.</p></div>"
  78,30,""
  78,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَفَازًا﴾</span>: فَوْزًا بِدُخُولِهِم الجنَّةَ.</p></div>"
  78,32,""
  78,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَوَاعِبَ﴾</span>: نَواهِدَ، أثْداؤُهنَّ مُرْتَفِعَةٌ لم تَتَدَلَّ.</p><p><span class="qpc-hafs">﴿أَتۡرَابࣰا﴾</span>: مُسْتَوِياتٍ في سِنٍّ واحِدةٍ.</p></div>"
  78,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دِهَاقࣰا﴾</span>: مَمْلُوءةً خَمْرًا.</p></div>"
  78,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَسۡمَعُونَ فِيهَا لَغۡوࣰا﴾</span>: باطِلًا مِنَ القول.</p><p><span class="qpc-hafs">﴿وَلَا كِذَّ ٰ⁠بࣰا﴾</span>: ولا تَكْذِيبًا.</p></div>"
  78,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِسَابࣰا﴾</span>: كَثِيرًا كافيًا لَهُم.</p></div>"
  78,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَمۡلِكُونَ مِنۡهُ خِطَابࣰا﴾</span>: لا يَسْتَطِيعُونَ خِطابًا يُبَلِّغُونَهُ إلى اللهِ.</p></div>"
  78,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرُّوحُ﴾</span>: جِبْريِلُ.</p><p><span class="qpc-hafs">﴿صَفࣰّا﴾</span>: مُصْطَفِّينَ.</p><p><span class="qpc-hafs">﴿صَوَابࣰا﴾</span>: حَقًّا وسَدادًا.</p></div>"
  78,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡيَوۡمُ ٱلۡحَقُّ﴾</span>: الثابِتُ الَّذِي لا رَيْبَ في وُقُوعِهِ.</p><p><span class="qpc-hafs">﴿مَـَٔابًا﴾</span>: مَرْجِعًا.</p></div>"
  78,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنذَرۡنَـٰكُمۡ﴾</span>: حَذَّرْناكُم.</p><p><span class="qpc-hafs">﴿مَا قَدَّمَتۡ يَدَاهُ﴾</span>: ما عَمِلَ من خِيرٍ أو شَرٍّ.</p><p><span class="qpc-hafs">﴿يَـٰلَيۡتَنِي كُنتُ تُرَ ٰ⁠بَۢا﴾</span>: فلم أُبْعَثْ.</p></div>"
