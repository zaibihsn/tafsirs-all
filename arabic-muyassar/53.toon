quran[62]{c,v,t}:
  53,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَوَىٰ﴾</span>: غابَ.</p></div>"
  53,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَوَىٰ﴾</span>: خَرَجَ عنِ الرَّشادِ.</p></div>"
  53,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡهَوَىٰٓ﴾</span>: ما تَمِيلُ إلَيهِ النَّفْسُ مِن غَيرِ دَلِيلٍ.</p></div>"
  53,4,""
  53,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَدِيدُ ٱلۡقُوَىٰ﴾</span>: مَلَكٌ شَدِيدُ القُوَّةِ.</p></div>"
  53,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِرَّةࣲ﴾</span>: مَنظَرٍ حَسَنٍ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَوَىٰ﴾</span>: عَلى صُورَتِهِ الحقِيقِيَّةِ للرَّسولِ ﷺ.</p></div>"
  53,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ﴾</span>: أُفُقِ الشَّمسِ عِنْدَ مَطْلَعِها.</p></div>"
  53,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَدَلَّىٰ﴾</span>: فَزادَ في القُرْبِ.</p></div>"
  53,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَابَ قَوۡسَيۡنِ﴾</span>: مِقْدارَ قَوسَينِ.</p></div>"
  53,10,""
  53,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُؤَادُ﴾</span>: قَلْبُه.</p></div>"
  53,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَتُمَـٰرُونَهُۥ﴾</span>: أتُكَذِّبُونَ مُحَمَّدًا ﷺ فَتُجادِلُونَه عَلى ما يَراهُ مِن آياتِ رَبِّهِ؟</p></div>"
  53,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَءَاهُ﴾</span>: رَأى مُحَمّدٌ ﷺ جِبْرِيلَ.</p><p><span class="qpc-hafs">﴿نَزۡلَةً﴾</span>: مَرَّةً.</p></div>"
  53,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِدۡرَةِ ٱلۡمُنتَهَىٰ﴾</span>: شَجَرةِ نَبْقٍ في السَّماءِ السّابِعةِ، يَنْتَهي إلَيها ما يُعْرَجُ بِهِ مِنَ الأَرْضِ، وما يُهْبَطُ بِه مِن فَوْقِها.</p></div>"
  53,15,""
  53,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغۡشَى ٱلسِّدۡرَةَ﴾</span>: يُغَطِّيها ويَسْتُرُها.</p></div>"
  53,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَاغَ﴾</span>: مالَ.</p><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: جاوَزَ ما أُمِرَ برُؤْيَتِهِ.</p></div>"
  53,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِ﴾</span>: دَلائلِ عَظَمةِ اللهِ.</p></div>"
  53,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّـٰتَ وَٱلۡعُزَّىٰ ۞ وَمَنَوٰةَ﴾</span>: هي أصْنامٌ اتَّخَذَها العَربُ آلِهَةً.</p><p><span class="qpc-hafs">﴿ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰٓ﴾</span>: صِفَتا تأكيدٍ لمناةٍ.</p></div>"
  53,20,""
  53,21,""
  53,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِيزَىٰٓ﴾</span>: جائِرةٌ.</p></div>"
  53,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: حُجَّةٍ.</p><p><span class="qpc-hafs">﴿تَهۡوَى﴾</span>: تَشْتَهِيهِ وتَمِيلُ إلَيهِ.</p></div>"
  53,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمَنَّىٰ﴾</span>: اشْتَهى.</p></div>"
  53,25,""
  53,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَم مِّن مَّلَكࣲ﴾</span>: وكَثِيرٍ مِنَ الملائِكَةِ.</p></div>"
  53,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡمِيَةَ ٱلۡأُنثَىٰ﴾</span>: صِفَةَ الأُنْثى، وهي أن يُقالَ لَها: بِنْتٌ.</p></div>"
  53,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّنَّ﴾</span>: التَّوهُّمَ الباطِلَ.</p><p><span class="qpc-hafs">﴿لَا يُغۡنِي﴾</span>: لا يُجدِي ولا يَقُومُ مَقامَ الحَقِّ.</p></div>"
  53,29,""
  53,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَبۡلَغُهُم مِّنَ ٱلۡعِلۡمِ﴾</span>: مُنْتَهى عِلْمِهِم، لا عِلْمَ لَهُم فَوْقَهُ؛ والمرادُ ظَنُّهُم الفاسِدُ.</p></div>"
  53,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحُسۡنَى﴾</span>: بالجنَّةِ.</p></div>"
  53,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّمَمَ﴾</span>: الذُّنُوبَ الصِّغارَ الَّتِي لا يُصِرُّ صاحِبُها عَلَيها، أو يُلِمُّ بِها على وجْهِ النُّدْرَةِ.</p><p><span class="qpc-hafs">﴿أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ﴾</span>: خَلَقَ أباكُم آدمَ مِن تُرابٍ.</p><p><span class="qpc-hafs">﴿فَلَا تُزَكُّوٓاْ أَنفُسَكُمۡ﴾</span>: فَتَمْدَحُوها بالتَّقْوى.</p></div>"
  53,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span>: أعْرَضَ عَن طاعَةِ اللهِ.</p></div>"
  53,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَكۡدَىٰٓ﴾</span>: تَوَقَّفَ عَنِ العَطاءِ.</p></div>"
  53,35,""
  53,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُحُفِ مُوسَىٰ﴾</span>: هي أسْفارُ التَّوراةِ.</p></div>"
  53,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِبۡرَ ٰ⁠هِيمَ﴾</span>: وصُحُفِ إبراهِيمَ التي سُجِّل فيها ما أوْحى اللهُ إليهِ.</p><p><span class="qpc-hafs">﴿وَفَّىٰٓ﴾</span>: بَلَّغَ ما أُرْسِلَ بِه.</p></div>"
  53,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَّا تَزِرُ﴾</span>: أي لا تَحْمِلُ ولا تُؤاخَذُ.</p><p><span class="qpc-hafs">﴿وَازِرَةࣱ﴾</span>: حاملةُ إثْمٍ.</p></div>"
  53,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّيۡسَ لِلۡإِنسَـٰنِ إِلَّا مَا سَعَىٰ﴾</span>: لا يَحْصُلُ للإنسانِ مِنَ الأجْرِ إلّا ما كَسَبَ هُوَ لِنَفْسِهِ بِسَعْيِهِ.</p></div>"
  53,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَعۡيَهُۥ﴾</span>: عَمَلَه واكْتِسابَه.</p><p><span class="qpc-hafs">﴿يُرَىٰ﴾</span>: يُشاهَدُ عِنْدَ الحسابِ.</p></div>"
  53,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُجۡزَىٰهُ﴾</span>: يُجزى الإنسانُ عَلى سَعْيِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَوۡفَىٰ﴾</span>: التامَّ الكامِلَ.</p></div>"
  53,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُنتَهَىٰ﴾</span>: انْتِهاءَ جَمِيعِ خَلْقِهِ ورُجُوعَهُم إلى حُكْمِهِ في الآخِرةِ.</p></div>"
  53,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَضۡحَكَ وَأَبۡكَىٰ﴾</span>: خَلَقَ في الإنْسانِ قُوَّتَي الضَّحِكِ والبُكاءِ وأَسْبابَهُما مِن سُرورٍ وحُزْنٍ.</p></div>"
  53,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَاتَ وَأَحۡيَا﴾</span>: انْفَرَدَ بالإماتَةِ والإحْياءِ.</p></div>"
  53,45,""
  53,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّطۡفَةٍ﴾</span>: ماءٍ قَلِيلٍ.</p><p><span class="qpc-hafs">﴿تُمۡنَىٰ﴾</span>: تُصَبُّ في الرَّحِمِ وتُقْذَفُ.</p></div>"
  53,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّشۡأَةَ﴾</span>: الخَلقَ.</p><p><span class="qpc-hafs">﴿ٱلۡأُخۡرَىٰ﴾</span>: الأخِيَرةَ الَّتِي لا نَشْأَةَ بَعْدَها.</p></div>"
  53,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَقۡنَىٰ﴾</span>: أرضى الَّذِي أغْناهُ.</p></div>"
  53,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشِّعۡرَىٰ﴾</span>: نَجْمٍ مُضِيءٍ كانَ يَعْبُدُهُ بَعْضُ أهْل الجاهِلِيَّةِ.</p></div>"
  53,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَادًا ٱلۡأُولَىٰ﴾</span>: قَوْمَ نَبِيِّ اللهِ هُودٍ عَلَيهِ السَّلامُ، وهي أوَّلُ العرَبِ البائِدةِ.</p></div>"
  53,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَثَمُودَاْ﴾</span>: قَوْمَ نَبِيِّ اللهِ صالِحٍ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿فَمَآ أَبۡقَىٰ﴾</span>: فَما تَرَكَها بَلْ أهْلَكَها.</p></div>"
  53,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَطۡغَىٰ﴾</span>: أشَدَّ طَغْيانًا وتَمَرُّدًا على اللهِ.</p></div>"
  53,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمُؤۡتَفِكَةَ﴾</span>: هي القُرى المَخْسُوفُ بِها، المقلوبُ أعلاها أسفلها، وهي قُرى قَوْمِ لُوطٍ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿أَهۡوَىٰ﴾</span>: أسْقَطَ، فَجَعَلَها هاوِيَةً.</p></div>"
  53,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَغَشَّىٰهَا مَا غَشَّىٰ﴾</span>: فَأَلْبَسَها ما ألْبَسَها مِنَ الحِجارَةِ المُتَتابِعَةِ النّازِلَةِ عَلَيهِم.</p></div>"
  53,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَالَآءِ﴾</span>: نِعَمِ، جَمْعُ إلىً.</p><p><span class="qpc-hafs">﴿تَتَمَارَىٰ﴾</span>: تَتَشَكَّكُ.</p></div>"
  53,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: الَّذِي أنْذَرْتُكُم بِهِ مِنَ الوقائِعِ.</p><p><span class="qpc-hafs">﴿نَذِيرࣱ﴾</span>: إنْذارٌ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰٓ﴾</span>: الَّتي أنْذَرْتُها الأُمَمَ الَّتي قَبْلَكُم.</p></div>"
  53,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَزِفَتِ﴾</span>: قَرُبَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔازِفَةُ﴾</span>: القِيامَةُ.</p></div>"
  53,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ﴾</span>: لا يَعْلَمُ بوَقْتِ وُقُوعِها إلّا اللهُ.</p></div>"
  53,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا ٱلۡحَدِيثِ﴾</span>: القرآنِ.</p><p><span class="qpc-hafs">﴿تَعۡجَبُونَ﴾</span>: مِن أن يَكُونَ صَحِيحًا.</p></div>"
  53,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَضۡحَكُونَ﴾</span>: مِنهُ سُخْرِيَةً واسْتِهْزاءً.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡكُونَ﴾</span>: خَوْفًا مِن وعِيدِهِ.</p></div>"
  53,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَـٰمِدُونَ﴾</span>: لاهُونَ مُعْرِضُونَ عَنْهُ.</p></div>"
  53,62,""
