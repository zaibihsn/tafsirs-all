quran[110]{c,v,t}:
  18,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِوَجَا﴾</span>: اختِلافًا، ولا اختِلالًا فيِ ألفاظِه ولا فيِ معانيه.</p></div>"
  18,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَيِّمࣰا﴾</span>: مستقيمًا معتدلًا، لا إفراطَ فيه ولا تفريطَ.</p><p><span class="qpc-hafs">﴿بَأۡسࣰا شَدِيدࣰا﴾</span>: عقوبةً عاجلةً في الدنيا وآجِلَةً في الآخرةِ.</p><p><span class="qpc-hafs">﴿أَجۡرًا حَسَنࣰا﴾</span>: ثوابًا جزيلًا، هو الجنةُ.</p></div>"
  18,3,""
  18,4,""
  18,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَبُرَتۡ﴾</span>: عَظُمَتْ في الشَّناعَةِ والقُبْحِ.</p></div>"
  18,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَـٰخِعࣱ نَّفۡسَكَ﴾</span>: مُهْلِكُها ومُجْهِدُها.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ ءَاثَـٰرِهِمۡ﴾</span>: بعدَ تَوَلِّي قومِك عنك.</p><p><span class="qpc-hafs">﴿ٱلۡحَدِيثِ﴾</span>: القرآنِ.</p><p><span class="qpc-hafs">﴿أَسَفًا﴾</span>: حُزْنًا وغَضَبًا؛ لحِرْصِك على إيمانهم.</p></div>"
  18,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِنَبۡلُوَهُمۡ﴾</span>: لِنَخْتَبِرَهم.</p></div>"
  18,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَعِيدࣰا﴾</span>: تُرابًا.</p><p><span class="qpc-hafs">﴿جُرُزًا﴾</span>: لا نباتَ فيه.</p></div>"
  18,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكَهۡفِ﴾</span>: النَّقْبِ المتَّسِعِ في الجبل، وهو أكبرُ من المغارة.</p><p><span class="qpc-hafs">﴿وَٱلرَّقِيمِ﴾</span>: اللَّوْحِ الذي كُتِبَتْ فيه أسماءُ أهلِ الكهفِ.</p></div>"
  18,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَى ٱلۡفِتۡيَةُ إِلَى ٱلۡكَهۡفِ﴾</span>: لجَؤُوا إليه؛ لعبادةِ اللهِ، وفِرارًا بدِينهم.</p><p><span class="qpc-hafs">﴿وَهَيِّئۡ﴾</span>: يَسِّرْ.</p><p><span class="qpc-hafs">﴿رَشَدࣰا﴾</span>: اهتداءً إلى الحق، وسَدادًا في العمل.</p></div>"
  18,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضَرَبۡنَا عَلَىٰٓ ءَاذَانِهِمۡ﴾</span>: أنَمْناهم نومًا عميقًا؛ بحيث لا يَسْمعون.</p></div>"
  18,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعَثۡنَـٰهُمۡ﴾</span>: أيقَظْناهم مِن نومِهم.</p><p><span class="qpc-hafs">﴿ٱلۡحِزۡبَيۡنِ﴾</span>: الفريقَين المختلفَين في مُدَّةِ بقائِهم في الكهفِ.</p><p><span class="qpc-hafs">﴿أَمَدࣰا﴾</span>: غايةً ومُدَّة.</p></div>"
  18,13,""
  18,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَبَطۡنَا عَلَىٰ قُلُوبِهِمۡ﴾</span>: قَوَّيْناها بالصَّبْرِ والتثبيتِ على الحقِّ.</p><p><span class="qpc-hafs">﴿شَطَطًا﴾</span>: قولًا بعيدًا مجانِبًا للحقِّ.</p></div>"
  18,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنِۭ بَيِّنࣲ﴾</span>: دليلٍ واضحٍ.</p><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اختَلَقَ.</p><p><span class="qpc-hafs">﴿كَذِبࣰا﴾</span>: بنسبةِ الشريكِ إلى اللهِ تعالى.</p></div>"
  18,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱعۡتَزَلۡتُمُوهُمۡ﴾</span>: فارَقْتُم قومَكم؛ فِرارًا بدِينِكم.</p><p><span class="qpc-hafs">﴿فَأۡوُۥٓاْ﴾</span>: الجَؤُوا.</p><p><span class="qpc-hafs">﴿يَنشُرۡ﴾</span>: يَبْسُطْ ويُوَسِّعْ.</p><p><span class="qpc-hafs">﴿وَيُهَيِّئۡ﴾</span>: يُيَسِّرْ.</p><p><span class="qpc-hafs">﴿مِّرۡفَقࣰا﴾</span>: ما تنتفعون به من أسبابِ العيشِ.</p></div>"
  18,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَّزَ ٰ⁠وَرُ﴾</span>: تميلُ.</p><p><span class="qpc-hafs">﴿ذَاتَ ٱلۡيَمِينِ﴾</span>: جهةَ يمينِ الكهفِ.</p><p><span class="qpc-hafs">﴿تَّقۡرِضُهُمۡ﴾</span>: تَتْرُكُهم وتتجاوَزُهم.</p><p><span class="qpc-hafs">﴿فَجۡوَةࣲ مِّنۡهُ﴾</span>: مُتَّسَعٍ من الكهفِ وفَضائِه، فلا يتأَذَّون من جَوِّه، أو من حرارةِ الشمس، ويأتيهم الهواءُ النافعُ.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِ ٱللَّهِ﴾</span>: دلائلِ قُدرتِه.</p><p><span class="qpc-hafs">﴿يَهۡدِ ٱللَّهُ﴾</span>: يوفِّقه.</p><p><span class="qpc-hafs">﴿وَلِيࣰّا﴾</span>: مُعِينًا وناصِرًا.</p></div>"
  18,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُقُودࣱ﴾</span>: نِيامٌ.</p><p><span class="qpc-hafs">﴿بِٱلۡوَصِيدِ﴾</span>: بفِناءِ الكَهْفِ، كأنه يَحْرُسُهم.</p><p><span class="qpc-hafs">﴿رُعۡبࣰا﴾</span>: خَوفًا وفَزَعًا.</p></div>"
  18,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ﴾</span>: وكما أنَمْناهم وحَفِظْناهم مدةً طويلة.</p><p><span class="qpc-hafs">﴿بَعَثۡنَـٰهُمۡ﴾</span>: أيْقَظْناهم من نومِهم كما كانوا.</p><p><span class="qpc-hafs">﴿بِوَرِقِكُمۡ﴾</span>: بنقُودِكم الفِضِّيَّةِ.</p><p><span class="qpc-hafs">﴿أَيُّهَآ﴾</span>: أيُّ أهلِ المدينةِ.</p><p><span class="qpc-hafs">﴿أَزۡكَىٰ طَعَامࣰا﴾</span>: أحَلُّ وأطيبُ.</p><p><span class="qpc-hafs">﴿وَلۡيَتَلَطَّفۡ﴾</span>: وليتكلَّفِ اللُّطْفَ والرِّفْقَ في المعاملةِ، حتى لا ينكشِفَ أمرُنا.</p></div>"
  18,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظۡهَرُواْ عَلَيۡكُمۡ﴾</span>: يَطَّلِعُوا على مكانِكم ويَعْلَمُوا به.</p><p><span class="qpc-hafs">﴿يَرۡجُمُوكُمۡ﴾</span>: يَقْتُلوكم بالرَّجْمِ بالحجارةِ.</p><p><span class="qpc-hafs">﴿مِلَّتِهِمۡ﴾</span>: دينِهم الباطلِ.</p></div>"
  18,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ﴾</span>: وكما أنَمْناهم السنينَ الطِّوالَ، ثم أيْقَظْناهم بعدَها.</p><p><span class="qpc-hafs">﴿أَعۡثَرۡنَا عَلَيۡهِمۡ﴾</span>: أطْلَعْنا عليهم أهلَ زمانِهم.</p><p><span class="qpc-hafs">﴿وَعۡدَ ٱللَّهِ﴾</span>: بالبعثِ.</p><p><span class="qpc-hafs">﴿أَمۡرَهُمۡ﴾</span>: في أمرِ القِيامةِ، فمِن مُقِرٍّ لها وجاحِدٍ، أو في أمْرِ الفِتْيَةِ المؤمنين وما اطَّلعوا عليه مِن أحوالِهم.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ غَلَبُواْ عَلَىٰٓ أَمۡرِهِمۡ﴾</span>: أصحابُ الكلمةِ والنفوذِ.</p></div>"
  18,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَجۡمَۢا بِٱلۡغَيۡبِ﴾</span>: قولًا بلا عِلْمٍ ولا اطِّلاعٍ.</p><p><span class="qpc-hafs">﴿بِعِدَّتِهِم﴾</span>: بعَدَدِهم.</p><p><span class="qpc-hafs">﴿فَلَا تُمَارِ فِيهِمۡ﴾</span>: فلا تجادِلْ في شأنِ أصحابِ الكهفِ وعَدَدِهم أحدًا من الخائضين فيه.</p><p><span class="qpc-hafs">﴿إِلَّا مِرَآءࣰ ظَـٰهِرࣰا﴾</span>: إلا جِدالًا واضحًا بذِكْرِ ما قَصَصْنا عليك مِن شأنِهم دونَ زيادةٍ.</p></div>"
  18,23,""
  18,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱذۡكُر رَّبَّكَ﴾</span>: بقولِ: إنْ شاء الله.</p><p><span class="qpc-hafs">﴿يَهۡدِيَنِ﴾</span>: يُوَفِّقَني.</p><p><span class="qpc-hafs">﴿مِنۡ هَـٰذَا﴾</span>: من قصةِ أصحابِ الكهفِ في الدِّلالةِ على نُبَوَّتي.</p><p><span class="qpc-hafs">﴿رَشَدࣰا﴾</span>: هدايةً ودَلالة للناسِ على ذلك.</p></div>"
  18,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَبِثُواْ فِي كَهۡفِهِمۡ﴾</span>: ومَكَثَ الفِتْيانُ فيه نِيامًا.</p></div>"
  18,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبۡصِرۡ بِهِۦ وَأَسۡمِعۡ﴾</span>: ما أبصَرَ اللهَ وأسمَعَه بكلِّ موجودٍ، فهو لا يَغِيبُ عنه شيء!</p><p><span class="qpc-hafs">﴿مَا لَهُم﴾</span>: ليس للخَلْقِ.</p><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: مُعينٍ وناصرٍ.</p><p><span class="qpc-hafs">﴿حُكۡمِهِۦٓ﴾</span>: قَضائِه وتشريعِه.</p></div>"
  18,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُلۡتَحَدࣰا﴾</span>: مَلْجَأً ومَلاذًا.</p></div>"
  18,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡبِرۡ نَفۡسَكَ﴾</span>: احبِسْها في طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿بِٱلۡغَدَوٰةِ وَٱلۡعَشِيِّ﴾</span>: أولِ النهار وآخرِه، والمرادُ دوامُ العبادةِ.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡدُ عَيۡنَاكَ عَنۡهُمۡ﴾</span>: لا تَصْرِفْ نَظَرَكَ عنهم إلى غيرِهِم.</p><p><span class="qpc-hafs">﴿أَغۡفَلۡنَا قَلۡبَهُۥ﴾</span>: جَعَلْناه غافلًا.</p><p><span class="qpc-hafs">﴿فُرُطࣰا﴾</span>: ضَياعًا وهَلاكًا ومُتَجاوِزًا فيه الاعتدالَ.</p></div>"
  18,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: ما جئتكُم به هو الحقُّ.</p><p><span class="qpc-hafs">﴿فَمَن شَآءَ فَلۡيُؤۡمِن وَمَن شَآءَ فَلۡيَكۡفُرۡ﴾</span>: تهديدٌ ووعيدٌ لمن اختارَ الكفرَ بعد بيانِ الحقِّ ووُضوحِه.</p><p><span class="qpc-hafs">﴿سُرَادِقُهَا﴾</span>: سُورُها المحيطُ بها.</p><p><span class="qpc-hafs">﴿كَٱلۡمُهۡلِ﴾</span>: ماءٌ غليظٌ كالمُنْصَهِر من المعادنِ، أو كعَكَرِ الزيتِ، بَلَغَ منتهى الحَرارةِ.</p><p><span class="qpc-hafs">﴿مُرۡتَفَقًا﴾</span>: منزِلًا ومُقامًا.</p></div>"
  18,30,""
  18,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: جِنانُ إقامةٍ دائمةٍ.</p><p><span class="qpc-hafs">﴿يُحَلَّوۡنَ﴾</span>: يُزَيَّنُون.</p><p><span class="qpc-hafs">﴿سُندُسࣲ﴾</span>: رقيقِ الحَريرِ.</p><p><span class="qpc-hafs">﴿وَإِسۡتَبۡرَقࣲ﴾</span>: ما غَلُظَ من الحريرِ وثَخُنَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرَآئِكِ﴾</span>: الأَسِرَّةِ المزيَّنَةِ بفاخِرِ السَّتائرِ.</p></div>"
  18,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱضۡرِبۡ لَهُم﴾</span>: واذكُرْ للمؤمنين والكافرين المستكبرِين وأَوْرِدْ لهم.</p><p><span class="qpc-hafs">﴿جَنَّتَيۡنِ﴾</span>: حديقتَين.</p><p><span class="qpc-hafs">﴿وَحَفَفۡنَـٰهُمَا بِنَخۡلࣲ﴾</span>: جَعَلْنا النَّخْلَ محيطًا بكلٍّ منهما.</p></div>"
  18,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاتَتۡ أُكُلَهَا﴾</span>: أثمرَتْ ثمرَها الذي يُؤْكَلُ.</p><p><span class="qpc-hafs">﴿وَلَمۡ تَظۡلِم مِّنۡهُ﴾</span>: ولم تَنْقُصْ من إثمارها عَبْرَ السنينَ.</p></div>"
  18,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهُۥ ثَمَرࣱ﴾</span>: لصاحبِ البستانينِ أنواعٌ من المال سِوى حديقتَيه.</p><p><span class="qpc-hafs">﴿نَفَرࣰا﴾</span>: أولادًا وخَدَمًا وأعوانًا.</p></div>"
  18,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَالِمࣱ لِّنَفۡسِهِۦ﴾</span>: كافرٌ بالبعثِ، مُعْجَبٌ بمالِه.</p><p><span class="qpc-hafs">﴿تَبِيدَ﴾</span>: تَهْلِكَ وتَفْنى.</p></div>"
  18,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَآئِمَةࣰ﴾</span>: كائنةً وواقعةً.</p><p><span class="qpc-hafs">﴿مُنقَلَبࣰا﴾</span>: مَرْجِعًا وعاقبةً.</p></div>"
  18,37,""
  18,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّـٰكِنَّا۠﴾</span>: لكنْ أنا أقولُ.</p></div>"
  18,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوۡلَآ﴾</span>: وهَلّا.</p></div>"
  18,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُسۡبَانࣰا﴾</span>: جَمْعُ حُسْبانَةٍ، وهو العذابُ كالصَّواعِقِ.</p><p><span class="qpc-hafs">﴿صَعِيدࣰا﴾</span>: أرضًا أو ترابًا.</p><p><span class="qpc-hafs">﴿زَلَقًا﴾</span>: لا نَباتَ فيها، ومَلْساءُ لا تَثْبُتُ عليها قَدَمٌ. والمرادُ أنها عَدِيمةُ النَّفْعِ.</p></div>"
  18,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَوۡرࣰا﴾</span>: غائِرًا ذاهبًا في أسفلِ الأرضِ.</p></div>"
  18,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُحِيطَ بِثَمَرِهِۦ﴾</span>: وأُهلِكَتْ أموالُ الكافرِ بما فيها حديقتاه، كما تَوَقَّعَ المؤمنُ.</p><p><span class="qpc-hafs">﴿يُقَلِّبُ كَفَّيۡهِ﴾</span>: دَلالةً على نَدَمِه وأَسَفِه وحَسْرَتِه.</p><p><span class="qpc-hafs">﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾</span>: متهدِّمةٌ سَقَطَ بعضُها على بعضٍ، خاليةٌ مما كان فيها.</p></div>"
  18,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِئَةࣱ﴾</span>: جماعةٌ ممَّنِ افتَخَرَ بهم.</p><p><span class="qpc-hafs">﴿وَمَا كَانَ مُنتَصِرًا﴾</span>: ما كان ممتنعًا بنفسِه وقوَّتِه عندَ انتقامِ اللهِ منه.</p></div>"
  18,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُنَالِكَ﴾</span>: في مثلِ هذه الشَّدائدِ، أو يومِ القيامةِ.</p><p><span class="qpc-hafs">﴿ٱلۡوَلَـٰيَةُ لِلَّهِ﴾</span>: النُّصْرَةُ للهِ وحدَه لا يَقْدِرُ عليها غيرُه.</p><p><span class="qpc-hafs">﴿عُقۡبࣰا﴾</span>: عاقبةً لمَن تَوَلّاهم.</p></div>"
  18,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱضۡرِبۡ لَهُم﴾</span>: اذكُرْ للناسِ وأَوْرِدْ.</p><p><span class="qpc-hafs">﴿مَّثَلَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: صِفَتَها في زينتِها، وتَقَلُّبَها وسُرْعَةَ زوالِها.</p><p><span class="qpc-hafs">﴿هَشِيمࣰا﴾</span>: يابسًا مُتَكَسِّرًا، بعد خُضْرَتِه ونَضارَتِه.</p><p><span class="qpc-hafs">﴿تَذۡرُوهُ ٱلرِّيَـٰحُ﴾</span>: تُذْهِبُه وتُفَرِّقُه إلى كلِّ جهةٍ.</p><p><span class="qpc-hafs">﴿مُّقۡتَدِرًا﴾</span>: كاملَ القُدْرةِ على كلِّ شيءٍ.</p></div>"
  18,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زِينَةُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: فيهما جَمالٌ ونَفْعٌ وقوَّةٌ.</p><p><span class="qpc-hafs">﴿وَٱلۡبَـٰقِيَـٰتُ ٱلصَّـٰلِحَـٰتُ﴾</span>: الأعمالُ الصالحةُ بما فيها: التسبيحُ، والتحميدُ، والتكبيرُ، والتهليلُ.</p><p><span class="qpc-hafs">﴿أَمَلࣰا﴾</span>: ما كان يأمُلُه صاحبُها في الدُّنيا عندَ اللهِ في الآخِرة.</p></div>"
  18,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُسَيِّرُ ٱلۡجِبَالَ﴾</span>: نُزيلُها عن أماكنِها، ونُسَيِّرها في الجوِّ كالسَّحابِ.</p><p><span class="qpc-hafs">﴿بَارِزَةࣰ﴾</span>: ظاهرةً للأَعْيُنِ لا يَسْتُرها شيءٌ.</p><p><span class="qpc-hafs">﴿وَحَشَرۡنَـٰهُمۡ﴾</span>: جَمَعْنا الأوَّلِين والآخِرين لموقفِ الحسابِ.</p><p><span class="qpc-hafs">﴿نُغَادِرۡ﴾</span>: نَتْرُكْ.</p></div>"
  18,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَفࣰّا﴾</span>: مُصْطَفِّين جميعًا لا يَغِيبُ أحدٌ منهم.</p><p><span class="qpc-hafs">﴿كَمَا خَلَقۡنَـٰكُمۡ أَوَّلَ مَرَّةِۭ﴾</span>: مِثْلَ خَلْقِنا الأولِ لكم: فُرادى، حُفاةَ الأقدامِ، عُراةَ الأجسامِ، غيرَ مَخْتُونين.</p><p><span class="qpc-hafs">﴿بَلۡ زَعَمۡتُمۡ﴾</span>: يا مُنْكِري البَعْثِ.</p><p><span class="qpc-hafs">﴿مَّوۡعِدࣰا﴾</span>: لبَعْثِكم ومُجازاتِكم على أعمالِكم.</p></div>"
  18,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبُ﴾</span>: صحائفُ أعمالِ العبادِ.</p><p><span class="qpc-hafs">﴿مُشۡفِقِينَ﴾</span>: خائفين.</p><p><span class="qpc-hafs">﴿يَـٰوَيۡلَتَنَا﴾</span>: يا هَلاكَنا، نداءٌ منهم على أنفسِهم بالخُسْرانِ والهَلاكِ.</p><p><span class="qpc-hafs">﴿لَا يُغَادِرُ﴾</span>: لا يَتْرُك.</p><p><span class="qpc-hafs">﴿أَحۡصَىٰهَا﴾</span>: عَدَّها وأثْبتَها.</p></div>"
  18,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡجُدُواْ لِـَٔادَمَ﴾</span>: تحيةً وإكرامًا له وإظهارًا لفَضْلِه، لا عبادةً.</p><p><span class="qpc-hafs">﴿فَفَسَقَ عَنۡ أَمۡرِ رَبِّهِۦٓ﴾</span>: خَرَجَ عن طاعةِ ربِّه بتَرْكِ السُّجودِ؛ تَكَبُّرًا.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أعوانًا.</p></div>"
  18,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّآ أَشۡهَدتُّهُمۡ﴾</span>: أي: إبليسَ وذريتَه.</p><p><span class="qpc-hafs">﴿عَضُدࣰا﴾</span>: أعوانًا وأنصارًا في شأنٍ من شؤوني.</p></div>"
  18,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَدَعَوۡهُمۡ﴾</span>: استغاثُوا بهم.</p><p><span class="qpc-hafs">﴿مَّوۡبِقࣰا﴾</span>: مَهْلِكًا في جَهَنَّمَ يَهْلِكُون فيه.</p></div>"
  18,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَظَنُّوٓاْ﴾</span>: أيقَنوا.</p><p><span class="qpc-hafs">﴿مُّوَاقِعُوهَا﴾</span>: واقِعُونَ فيها وداخِلُوها.</p><p><span class="qpc-hafs">﴿مَصۡرِفࣰا﴾</span>: مكانًا يَنْصَرِفُون ويَلْجَؤُون إليه.</p></div>"
  18,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرَّفۡنَا﴾</span>: بَيَّنّا ونوَّعْنا بأساليبَ مختلفةٍ.</p><p><span class="qpc-hafs">﴿كُلِّ مَثَلࣲ﴾</span>: كلِّ معنى يَحْصُلُ الاتِّعاظُ به.</p><p><span class="qpc-hafs">﴿جَدَلࣰا﴾</span>: خُصومةً في الباطل.</p></div>"
  18,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُنَّةُ ٱلۡأَوَّلِينَ﴾</span>: سُنَّةُ اللهِ في إهلاكِ السابقين بالاستئصال.</p><p><span class="qpc-hafs">﴿قُبُلࣰا﴾</span>: صُنوفًا وأنواعًا، أو مَوُاجَهَةً ومقابَلَةً.</p></div>"
  18,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُدۡحِضُواْ بِهِ﴾</span>: ليُزِيلُوا بجِدالِهم وباطِلِهم.</p><p><span class="qpc-hafs">﴿هُزُوࣰا﴾</span>: استهزاءً وسُخْريَةً.</p></div>"
  18,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكِنَّةً﴾</span>: أغطيةً مانعةً.</p><p><span class="qpc-hafs">﴿أَن يَفۡقَهُوهُ﴾</span>: لِئلّا يَفْهَمُوا القرآنَ؛ عُقوبةً لهم.</p><p><span class="qpc-hafs">﴿وَقۡرࣰا﴾</span>: ثِقَلًا في السَّمعِ.</p></div>"
  18,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّوۡعِدࣱ﴾</span>: أي: مُقَدَّرٌ لعذابهِم.</p></div>"
  18,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتِلۡكَ ٱلۡقُرَىٰٓ﴾</span>: مِنَ الأممِ السابقةِ.</p><p><span class="qpc-hafs">﴿لِمَهۡلِكِهِم﴾</span>: لهَلاكِهم.</p></div>"
  18,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِفَتَىٰهُ﴾</span>: تلميذِه وخادِمِه يُوشَعَ بنِ نونٍ.</p><p><span class="qpc-hafs">﴿لَآ أَبۡرَحُ﴾</span>: لا أزال أسِيرُ.</p><p><span class="qpc-hafs">﴿مَجۡمَعَ ٱلۡبَحۡرَيۡنِ﴾</span>: مُلتقاهما.</p><p><span class="qpc-hafs">﴿أَمۡضِيَ حُقُبࣰا﴾</span>: أسيرُ زمنًا طويلًا.</p></div>"
  18,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡبَحۡرِ سَرَبࣰا﴾</span>: طريقًا فيه، كالشَّقِّ في الأرضِ.</p></div>"
  18,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَاوَزَا﴾</span>: فارَقا مكانَهما.</p><p><span class="qpc-hafs">﴿غَدَآءَنَا﴾</span>: طعامَنا أوَّلَ النهارِ.</p><p><span class="qpc-hafs">﴿نَصَبࣰا﴾</span>: تَعَبًا.</p></div>"
  18,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتَ﴾</span>: أتَذْكُرُ؟</p><p><span class="qpc-hafs">﴿إِذۡ أَوَيۡنَآ إِلَى ٱلصَّخۡرَةِ﴾</span>: حين لَجَأْنا إليها للراحةِ.</p><p><span class="qpc-hafs">﴿سَبِيلَهُۥ﴾</span>: طريقَه.</p><p><span class="qpc-hafs">﴿عَجَبࣰا﴾</span>: يُتعَجَّبُ منه.</p></div>"
  18,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبۡغِ﴾</span>: نَطْلبُه، وهو علامةٌ على مكانِ العبدِ الصّالحِ.</p><p><span class="qpc-hafs">﴿فَٱرۡتَدَّا﴾</span>: رَجَعا.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ ءَاثَارِهِمَا﴾</span>: على طريقِهما الذي جاءا منه.</p><p><span class="qpc-hafs">﴿قَصَصࣰا﴾</span>: يَتْبَعان آثارَ مسيرِهما، حتى وصَلا إلى الصَّخْرةِ.</p></div>"
  18,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبۡدࣰا مِّنۡ عِبَادِنَآ﴾</span>: هو الخَضِرُ، وهو نبيٌّ توفّاه الله.</p><p><span class="qpc-hafs">﴿رَحۡمَةࣰ﴾</span>: نبوَّةً.</p></div>"
  18,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُشۡدࣰا﴾</span>: إصابةً للحقِّ وصَوابًا أسترشِدُ به.</p></div>"
  18,67,""
  18,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُبۡرࣰا﴾</span>: عِلْمًا ومعرفةً بحقيقتِه.</p></div>"
  18,69,""
  18,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَن شَيۡءٍ﴾</span>: أي: تُنْكِرُه عليَّ في عِلْمِكَ.</p><p><span class="qpc-hafs">﴿أُحۡدِثَ لَكَ مِنۡهُ ذِكۡرࣰا﴾</span>: أبتدِئُكَ ببيانِه وتَوْضيحِ ما خَفِيَ عليك.</p></div>"
  18,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱنطَلَقَا﴾</span>: فسار موسى والخَضِرُ يَمْشِيان على الساحلِ.</p><p><span class="qpc-hafs">﴿شَيۡـًٔا إِمۡرࣰا﴾</span>: أمرًا عظيمًا مُنْكَرًا.</p></div>"
  18,72,""
  18,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُرۡهِقۡنِي﴾</span>: لا تُحَمِّلني وتُكَلِّفني.</p><p><span class="qpc-hafs">﴿مِنۡ أَمۡرِي عُسۡرࣰا﴾</span>: في صُحْبتي إياك وتَعَلُّمي منك مشقَّةً.</p></div>"
  18,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَكِيَّةَۢ﴾</span>: نقيةً طاهرةً لم تبلُغْ حَدَّ التكليفِ.</p><p><span class="qpc-hafs">﴿بِغَيۡرِ نَفۡسࣲ﴾</span>: بغيرِ حَقٍّ من قِصاصٍ عليها.</p><p><span class="qpc-hafs">﴿نُّكۡرࣰا﴾</span>: مُنْكَرًا عظيمًا.</p></div>"
  18,75,""
  18,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن لَّدُنِّي عُذۡرࣰا﴾</span>: إلى الغايةِ التي أعْذُرُكَ في فِراقي بسببِها.</p></div>"
  18,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَطۡعَمَآ أَهۡلَهَا﴾</span>: طَلَبا من أهلِ القريةِ الطعامَ على وجْهِ الضِّيافَةِ.</p><p><span class="qpc-hafs">﴿فَأَبَوۡاْ﴾</span>: امتنعُوا.</p><p><span class="qpc-hafs">﴿يُرِيدُ﴾</span>: يَقْرُبُ ويُوشِكُ.</p><p><span class="qpc-hafs">﴿أَن يَنقَضَّ﴾</span>: أن يسقطَ؛ بسببِ مَيَلانِه.</p><p><span class="qpc-hafs">﴿فَأَقَامَهُۥ﴾</span>: سوّاه الخَضرُ وعَدَّلَ ميلَه.</p></div>"
  18,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَأُنَبِّئُكَ﴾</span>: سأُخْبِرُكَ.</p><p><span class="qpc-hafs">﴿بِتَأۡوِيلِ﴾</span>: بحقيقةِ مَقْصِدي من أفعالي.</p></div>"
  18,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَسَـٰكِينَ﴾</span>: محتاجِين لا يملِكُون ما يَكْفيهم ويَسُدُّ حاجتَهم.</p><p><span class="qpc-hafs">﴿أَعِيبَهَا﴾</span>: أُحْدِثَ فيها عَيْبًا بخَرْقِها.</p><p><span class="qpc-hafs">﴿وَرَآءَهُم﴾</span>: أمامَهم.</p><p><span class="qpc-hafs">﴿كُلَّ سَفِينَةٍ﴾</span>: صالحةٍ غيرِ مَعِيبةٍ.</p><p><span class="qpc-hafs">﴿غَصۡبࣰا﴾</span>: قَهْرًا وظُلْمًا.</p></div>"
  18,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُرۡهِقَهُمَا﴾</span>: يَدْفَعَ والدَيه إلى تجاوُزِ حدودِ اللهِ والكفرِ.</p></div>"
  18,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَكَوٰةࣰ﴾</span>: دِينًا وصَلاحًا.</p><p><span class="qpc-hafs">﴿رُحۡمࣰا﴾</span>: رحمةً بوالدَيه وبِرًّا بهما.</p></div>"
  18,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَنزࣱ﴾</span>: مالٌ مَدْفونٌ من الذَّهَبِ والفِضَّةِ.</p><p><span class="qpc-hafs">﴿يَبۡلُغَآ أَشُدَّهُمَا﴾</span>: قوَّتَهما وكمالَ عَقْلِهما.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ تَأۡوِيلُ﴾</span>: الذي بَيَّنْتُ لك أسبابَه هو مآلُ تلك الأمورِ.</p></div>"
  18,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسۡـَٔلُونَكَ﴾</span>: أي: كفارُ قريشٍ بتَلْقينٍ من اليهود.</p><p><span class="qpc-hafs">﴿ذِي ٱلۡقَرۡنَيۡنِ﴾</span>: عبدٌ صالحٌ مَلَّكه اللهُ الأرضَ، وأعطاه العِلْمَ والحكمةَ، حتى بَلَغَ سلطانُه المشرقَ والمغربَ، فسُمِّيَ ذا القَرْنين، فكأنه حاز قَرْنَي الدنيا.</p><p><span class="qpc-hafs">﴿ذِكۡرًا﴾</span>: خَبَرًا تتذكَّرون به.</p></div>"
  18,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَّنَّا لَهُۥ﴾</span>: سَهَّلْنا لَه التَّصَرُّفَ كَيفَ شاءَ.</p><p><span class="qpc-hafs">﴿سَبَبࣰا﴾</span>: طَرِيقًا يُوصِلُه إلى مُرادِهِ.</p></div>"
  18,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَتۡبَعَ﴾</span>: سَلَك وسارَ.</p><p><span class="qpc-hafs">﴿سَبَبًا﴾</span>: طريقًا نَحْوَ الغَرْبِ.</p></div>"
  18,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡرِبَ ٱلشَّمۡسِ﴾</span>: مَوْضِعَ غُرُوبِها، وهُوَ نِهايةُ الأَرْضِ مِنَ الغَرْبِ.</p><p><span class="qpc-hafs">﴿عَيۡنٍ﴾</span>: نَبْعٍ جارِيةٍ بالماءِ أو غيرِه.</p><p><span class="qpc-hafs">﴿حَمِئَةࣲ﴾</span>: ذاتِ طينٍ أسْودَ.</p><p><span class="qpc-hafs">﴿تُعَذِّبَ﴾</span>: بالقتلِ أو غيرِه إنْ لم يُؤمِنُوا.</p><p><span class="qpc-hafs">﴿حُسۡنࣰا﴾</span>: بِدعوتِهم إلى الهُدى والرَّشادِ.</p></div>"
  18,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَلَمَ﴾</span>: نفسَه بكُفْرِه بِرَبِّه.</p><p><span class="qpc-hafs">﴿نُّكۡرࣰا﴾</span>: مُنْكَرًا عَظِيمًا في جَهَنَّمَ.</p></div>"
  18,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الجنَّةُ.</p><p><span class="qpc-hafs">﴿يُسۡرࣰا﴾</span>: سَهْلًا لا مَشَقَّةَ فِيه.</p></div>"
  18,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبَبًا﴾</span>: طَرِيقًا نَحْوَ الشَّرْقِ.</p></div>"
  18,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَطۡلِعَ ٱلشَّمۡسِ﴾</span>: مَوْضِعَ طُلُوعِها، وهُوَ نِهايةُ الأرْضِ مِنَ الشَّرْقِ.</p><p><span class="qpc-hafs">﴿سِتۡرࣰا﴾</span>: ساترًا مِنَ البِناء أوْ الأَشْجار.</p></div>"
  18,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: كما وصَفْنا أمْرَ ذِي القَرنْيَنِ مِن بُلُوغِه المَغْرِبَ والمشْرِقَ.</p><p><span class="qpc-hafs">﴿خُبۡرࣰا﴾</span>: عِلْمًا ومَعْرِفةً.</p></div>"
  18,92,""
  18,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّدَّيۡنِ﴾</span>: الجَبَلَينِ.</p></div>"
  18,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَأۡجُوجَ وَمَأۡجُوجَ﴾</span>: أُمَّتانِ عظِيمتان مِن بَنِي آدَمَ مَوْجُودتانِ.</p><p><span class="qpc-hafs">﴿خَرۡجًا﴾</span>: نَصِيبًا وأجْرًا مِنَ المالِ.</p><p><span class="qpc-hafs">﴿سَدࣰّا﴾</span>: حاجِزًا.</p></div>"
  18,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَدۡمًا﴾</span>: حاجِزًا قَوِيًّا.</p></div>"
  18,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُبَرَ ٱلۡحَدِيدِ﴾</span>: قِطَعَه الكَبيرةَ.</p><p><span class="qpc-hafs">﴿ٱلصَّدَفَيۡنِ﴾</span>: جانِبَي الجبَلَينِ.</p><p><span class="qpc-hafs">﴿أُفۡرِغۡ﴾</span>: أصُبَّ.</p><p><span class="qpc-hafs">﴿قِطۡرࣰا﴾</span>: نُحاسًا مُذابًا.</p></div>"
  18,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظۡهَرُوهُ﴾</span>: يَعْلُوه ويَصْعَدُوا إليه.</p><p><span class="qpc-hafs">﴿نَقۡبࣰا﴾</span>: ثَقْبًا؛ لِصَلابَتِه وسَماكَتِه.</p></div>"
  18,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعۡدُ رَبِّي﴾</span>: وعْدُ رَبِّي بِخُرُوجِ يأجُوجَ ومَأجُوجَ.</p><p><span class="qpc-hafs">﴿دَكَّآءَ﴾</span>: مُنْهَدِمًا مُسْتَويًا بالأَرض.</p></div>"
  18,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَمُوجُ﴾</span>: يضْطَرِبُ ويَخْتَلِطُ بَعْضُهم في بَعْضٍ.</p><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الذي يُنْفَخُ فيه للبعثِ.</p></div>"
  18,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَرَضۡنَا﴾</span>: أبْرَزْنا.</p></div>"
  18,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غِطَآءٍ﴾</span>: سِتْرٍ وحِجابٍ.</p><p><span class="qpc-hafs">﴿ذِكۡرِي﴾</span>: هُو القرآنُ والآياتُ الكونيةُ.</p><p><span class="qpc-hafs">﴿لَا يَسۡتَطِيعُونَ سَمۡعًا﴾</span>: لا يُطِيقُونَ سَماعَ الحُجَجِ والبَراهِينِ بُغْضًا وعِنادًا.</p></div>"
  18,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن دُونِيٓ أَوۡلِيَآءَ﴾</span>: مِن غيرِي آلهةً.</p><p><span class="qpc-hafs">﴿أَعۡتَدۡنَا﴾</span>: أعْدَدْنا وأحْضَرْنا.</p><p><span class="qpc-hafs">﴿نُزُلࣰا﴾</span>: مَنزِلًا مُعَدًّا لهم.</p></div>"
  18,103,""
  18,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَّ سَعۡيُهُمۡ﴾</span>: ضاعَ عَمَلُهم.</p><p><span class="qpc-hafs">﴿يَحۡسَبُونَ أَنَّهُمۡ يُحۡسِنُونَ صُنۡعًا﴾</span>: يَظُنُّونَ أنّهم مُحْسِنُونَ في أعْمالِهم.</p></div>"
  18,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَبِطَتۡ﴾</span>: فبَطَلَتْ.</p><p><span class="qpc-hafs">﴿وَزۡنࣰا﴾</span>: قَدْرًا وثِقَلًا.</p></div>"
  18,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوًا﴾</span>: مُسْتَهْزَأً بِهما.</p></div>"
  18,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ ٱلۡفِرۡدَوۡسِ﴾</span>: أعلى مَناِزلِ الجنِّةِ وأَوْسَطُها، وهي أفْضَلُها.</p><p><span class="qpc-hafs">﴿نُزُلًا﴾</span>: مَنزِلًا مُعدًّا لهم.</p></div>"
  18,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَبۡغُونَ﴾</span>: لا يُرِيدُونَ.</p></div>"
  18,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِدَادࣰا﴾</span>: حِبْرًا للأقْلامِ.</p><p><span class="qpc-hafs">﴿لَنَفِدَ﴾</span>: لَفَنِيَ.</p><p><span class="qpc-hafs">﴿كَلِمَـٰتُ رَبِّي﴾</span>: عِلْمُه وحِكَمُه وما أوْحاه إلى ملائِكَتِه ورُسُلِه.</p><p><span class="qpc-hafs">﴿مَدَدࣰا﴾</span>: زِيادةً.</p></div>"
  18,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡجُواْ﴾</span>: يخافُ عذابَ ربِّه، ويَرْجُو ثَوابَه يومَ لِقائِه.</p></div>"
