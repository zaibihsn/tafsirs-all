quran[99]{c,v,t}:
  15,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبِينࣲ﴾</span>: واضحٍ في معانِيه وأحكامِه.</p></div>"
  15,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُّبَمَا﴾</span>: أي: رُبَّ شيءٍ، وهو حرفٌ يَدُلُّ على أنّ ما بعدَه قليلُ الحصولِ.</p><p><span class="qpc-hafs">﴿يَوَدُّ﴾</span>: يتمنّى.</p></div>"
  15,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرۡهُمۡ﴾</span>: اترُكْ أيُّها الرسولُ الكفارَ.</p><p><span class="qpc-hafs">﴿وَيَتَمَتَّعُواْ﴾</span>: يَسْتَمْتِعُوا بعيشِهم في الحياةِ الدنيا.</p><p><span class="qpc-hafs">﴿وَيُلۡهِهِمُ﴾</span>: يَشْغَلْهم.</p><p><span class="qpc-hafs">﴿ٱلۡأَمَلُ﴾</span>: رجاءُ البقاءِ في الدُّنيا والطمعِ فيها.</p></div>"
  15,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَابࣱ﴾</span>: أجَلٌ.</p><p><span class="qpc-hafs">﴿مَّعۡلُومࣱ﴾</span>: مُقَدَّرٌ ومُحَدَّدٌ لإهلاكِها.</p></div>"
  15,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يَسۡتَـٔۡخِرُونَ﴾</span>: لا يتأخَّرُون عن موعدِ هلاكِهم.</p></div>"
  15,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلذِّكۡرُ﴾</span>: القرآنُ.</p></div>"
  15,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّوۡ مَا﴾</span>: هَلّا، حَضُّوه على هذا الفِعْلِ؛ لتشهدَ الملائكةُ على صِدْقِه.</p></div>"
  15,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالعذابِ الذي قدَّره اللهُ.</p><p><span class="qpc-hafs">﴿مُّنظَرِينَ﴾</span>: مُؤَخَّرِين ومُمْهَلِين.</p></div>"
  15,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَحَـٰفِظُونَ﴾</span>: نتكَفَّلُ بحِفْظِه من الزيادةِ أو النقصِ أو التحريفِ أو التبديلِ.</p></div>"
  15,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِيَعِ ٱلۡأَوَّلِينَ﴾</span>: فِرَقِ الأمم السابقةِ.</p></div>"
  15,11,""
  15,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: كما أدخَلْنا التكذيبَ والاستهزاءَ في قلوبِ الأممِ السابقةِ.</p><p><span class="qpc-hafs">﴿نَسۡلُكُهُۥ﴾</span>: نُدْخِلُه.</p></div>"
  15,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ.</p><p><span class="qpc-hafs">﴿سُنَّةُ ٱلۡأَوَّلِينَ﴾</span>: ما جَرى به قضاءُ الله وحُكْمُه من إهلاكِ المكذِّبين.</p></div>"
  15,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡرُجُونَ﴾</span>: يَصْعَدُون، فيَرَوْن عجائبَ مَلَكوتِ اللهِ.</p></div>"
  15,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُكِّرَتۡ﴾</span>: سُدَّتْ ومُنِعَتْ عن الإبصارِ.</p></div>"
  15,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُرُوجࣰا﴾</span>: منازلَ للكواكبِ السيّارةِ تَنْزِلُ بها.</p></div>"
  15,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَّجِيمٍ﴾</span>: مَرْجومٍ، أي: مَطْرودٍ من رحمةِ اللهِ.</p></div>"
  15,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَرَقَ ٱلسَّمۡعَ﴾</span>: خَطِفَ المسموعَ من كلامِ الملأِ الأعلى.</p><p><span class="qpc-hafs">﴿فَأَتۡبَعَهُۥ﴾</span>: لَحِقَه.</p><p><span class="qpc-hafs">﴿شِهَابࣱ﴾</span>: شُعْلَةُ نارٍ تُرى هابطةً من السماءِ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: منيرٌ واضحٌ.</p></div>"
  15,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ مَدَدۡنَـٰهَا﴾</span>: بَسَطَها اللهُ، وهَيَّأها للاستقرار والعيشِ فيها.</p><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جِبالًا تُثَبِّتُها.</p><p><span class="qpc-hafs">﴿مَّوۡزُونࣲ﴾</span>: مُقَدَّرٍ بمقدارٍ معيَّنٍ.</p></div>"
  15,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَعَـٰيِشَ﴾</span>: ما تَعيشُون به من الأرزاقِ.</p></div>"
  15,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِندَنَا خَزَآئِنُهُۥ﴾</span>: قادِرُون على إيجادِه وتدبيرِه والإنعامِ به من جميعِ الأصنافِ.</p><p><span class="qpc-hafs">﴿بِقَدَرࣲ مَّعۡلُومࣲ﴾</span>: بمقدارٍ مُحَدَّدٍ.</p></div>"
  15,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوَ ٰ⁠قِحَ﴾</span>: حَواملَ للسَّحابِ ولِلَقاحِ الشجَرِ، أو مُلقِّحاتٍ للسَّحابِ وللأشجارِ.</p><p><span class="qpc-hafs">﴿وَمَآ أَنتُمۡ لَهُۥ بِخَـٰزِنِينَ﴾</span>: لَسْتم بقادرين على حِفْظِ الماءِ وادِّخاره.</p></div>"
  15,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَ ٰ⁠رِثُونَ﴾</span>: للأرضِ ومَن عليها؛ لأنه سبحانه هو الباقي بعد فَناءِ الخَلْقِ.</p></div>"
  15,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُسۡتَقۡدِمِينَ﴾</span>: الذين ماتُوا من لَدُنْ آدمَ عليه السَّلامُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُسۡتَـٔۡخِرِينَ﴾</span>: الأحياءَ، ومَن سيأتي إلى يوم القيامة.</p></div>"
  15,25,""
  15,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَلۡصَـٰلࣲ﴾</span>: طينٍ يابسٍ غيرِ مطبوخٍ، يُسْمَعُ له صَلْصَلةٌ، أي: صوتٌ حين النَّقْرِ عليه.</p><p><span class="qpc-hafs">﴿حَمَإࣲ﴾</span>: طينٍ أسودَ.</p><p><span class="qpc-hafs">﴿مَّسۡنُونࣲ﴾</span>: متغيِّرِ اللونِ والرائحةِ، أو مُصَوَّرٍ صورةَ إنسانٍ.</p></div>"
  15,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡجَآنَّ﴾</span>: أبا الجنِّ، وهو إبليسُ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: من قَبْلِ خَلْقِ آدمَ.</p><p><span class="qpc-hafs">﴿نَّارِ ٱلسَّمُومِ﴾</span>: نارٍ شديدةِ الحرارةِ لا دُخانَ لها.</p></div>"
  15,28,""
  15,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَّيۡتُهُۥ﴾</span>: أكمَلْتُ صورتَه، وأتممتُ خَلْقَه.</p><p><span class="qpc-hafs">﴿مِن رُّوحِي﴾</span>: ما به حياتُه بأمري، فصارَ بَشَرًا.</p><p><span class="qpc-hafs">﴿سَـٰجِدِينَ﴾</span>: سجودَ تحيةٍ وتكريمٍ.</p></div>"
  15,30,""
  15,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبَىٰٓ﴾</span>: امتنعَ.</p></div>"
  15,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا لَكَ﴾</span>: ما مَنعَكَ.</p></div>"
  15,33,""
  15,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَجِيمࣱ﴾</span>: مَرْجُومٌ، أي: مَطْرودٌ من رحمةِ اللهِ.</p></div>"
  15,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّعۡنَةَ﴾</span>: غَضَبَ اللهِ وسُخْطَه، والبعدَ من رحمتِه.</p><p><span class="qpc-hafs">﴿ٱلدِّينِ﴾</span>: الجزاءِ والحِسابِ.</p></div>"
  15,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنظِرۡنِيٓ﴾</span>: أخِّرْني وأمْهِلْني.</p></div>"
  15,37,""
  15,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَقۡتِ ٱلۡمَعۡلُومِ﴾</span>: حين تموتُ الخلائقُ، وهو النَّفْخَةُ الأولى.</p></div>"
  15,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَآ أَغۡوَيۡتَنِي﴾</span>: فبسببِ إضلالِك لي.</p><p><span class="qpc-hafs">﴿لَأُزَيِّنَنَّ لَهُمۡ﴾</span>: لَأُحَسِّنَنَّ لذريَّةِ آدمَ المعاصيَ.</p><p><span class="qpc-hafs">﴿وَلَأُغۡوِيَنَّهُمۡ﴾</span>: لَأَحْمِلنَّهم على تَرْكِ الهدى والرَّشادِ.</p></div>"
  15,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُخۡلَصِينَ﴾</span>: المختارِين من عبادِك لطاعتِك.</p></div>"
  15,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طٌ عَلَيَّ﴾</span>: طريقٌ حقٌّ عليَّ أن أُراعِيَه.</p></div>"
  15,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٌ﴾</span>: تَسَلُّطٌ.</p><p><span class="qpc-hafs">﴿ٱلۡغَاوِينَ﴾</span>: الضالِّين والمُشْركين.</p></div>"
  15,43,""
  15,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُزۡءࣱ مَّقۡسُومٌ﴾</span>: نصيبٌ معيَّنٌ مَتميِّزٌ عن غيرِه بحسَبِ أعمالِهم.</p></div>"
  15,45,""
  15,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسَلَـٰمٍ﴾</span>: سالمين من كلِّ سوءٍ.</p></div>"
  15,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعۡنَا﴾</span>: أذْهَبَ الله تعالى.</p><p><span class="qpc-hafs">﴿غِلٍّ﴾</span>: حِقْدٍ وعَداوةٍ كانَتْ من بعضِهم في الدُّنيا.</p><p><span class="qpc-hafs">﴿مُّتَقَـٰبِلِينَ﴾</span>: تتقابلُ وُجوهُهم؛ لمِا هم فيه من المحبةِ والتواصُلِ.</p></div>"
  15,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصَبࣱ﴾</span>: تَعَبٌ وإعياءٌ.</p></div>"
  15,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبِّئۡ﴾</span>: أخْبِرْ.</p></div>"
  15,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَلِيمُ﴾</span>: المؤلمُ الموجِعُ.</p></div>"
  15,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡفِ إِبۡرَ ٰ⁠هِيمَ﴾</span>: ضيوفِه عليه السلامُ من الملائكةِ الكرامِ.</p></div>"
  15,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجِلُونَ﴾</span>: خائفون فَزِعُون.</p></div>"
  15,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلِيمࣲ﴾</span>: ذي عِلْمٍ كثيرٍ، وهو إسحاقُ.</p></div>"
  15,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰٓ أَن مَّسَّنِيَ ٱلۡكِبَرُ﴾</span>: مع حالةِ كِبَرِ السِّنِّ.</p></div>"
  15,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالخبرِ اليقينِ الذي لا شَكَّ فيه.</p><p><span class="qpc-hafs">﴿ٱلۡقَـٰنِطِينَ﴾</span>: اليائسين من الوَلَدِ.</p></div>"
  15,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلضَّآلُّونَ﴾</span>: البعيدون عن الحقِّ والصَّوابِ.</p></div>"
  15,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا خَطۡبُكُمۡ﴾</span>: ما أمْرُكم الخطيرُ الذي جِئْتُم من أجلِه؟</p></div>"
  15,58,""
  15,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّآ ءَالَ لُوطٍ﴾</span>: إلّا لوطًا وأهلَه المؤمنين به.</p></div>"
  15,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّرۡنَآ﴾</span>: قَضَيْنا وحَكَمْنا بأمرِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَـٰبِرِينَ﴾</span>: الباقين في العذابِ.</p></div>"
  15,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَالَ لُوطٍ﴾</span>: أي: لوطًا عليه السلامُ.</p></div>"
  15,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوۡمࣱ مُّنكَرُونَ﴾</span>: لا أعْرِفُكم.</p></div>"
  15,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِ يَمۡتَرُونَ﴾</span>: يَشُكُّون في نزول العذاب بهم.</p></div>"
  15,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالخبرِ اليقينِ الذي لا شَكَّ فيه.</p></div>"
  15,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَسۡرِ بِأَهۡلِكَ﴾</span>: فاخرُجْ أنت وأهلُك المؤمنون.</p><p><span class="qpc-hafs">﴿بِقِطۡعࣲ مِّنَ ٱلَّيۡلِ﴾</span>: بآخِر الليلِ.</p><p><span class="qpc-hafs">﴿وَٱتَّبِعۡ أَدۡبَـٰرَهُمۡ﴾</span>: وسِرْ أنت وراءهم؛ لئلا يَتَخَلَّفَ منهم أحدٌ فيَهْلِكَ.</p></div>"
  15,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَضَيۡنَآ إِلَيۡهِ﴾</span>: أوْحَيْنا إلى لوطٍ.</p><p><span class="qpc-hafs">﴿دَابِرَ هَـٰٓؤُلَآءِ مَقۡطُوعࣱ﴾</span>: آخرَهم، والمرادُ: جميعُ قومِك مُهْلَكون، لايبقى منهم أحدٌ.</p><p><span class="qpc-hafs">﴿مُّصۡبِحِينَ﴾</span>: وقتَ الصباحِ.</p></div>"
  15,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَبۡشِرُونَ﴾</span>: يُظْهِرُون سرورَهم؛ طَمَعًا في فِعْل الفاحِشَةِ.</p></div>"
  15,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡفِي﴾</span>: ضُيوفي.</p><p><span class="qpc-hafs">﴿فَلَا تَفۡضَحُونِ﴾</span>: لا تُظْهروا ما يُوجبُ العارَ لي.</p></div>"
  15,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُخۡزُونِ﴾</span>: لا تُوقعوني في الذُّل والهَوانِ؛ بإيذائِكم لضيوفي.</p></div>"
  15,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنِ ٱلۡعَـٰلَمِينَ﴾</span>: عن ضيافَةِ أحدٍ من الناسِ أو حمايتهِ.</p></div>"
  15,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰٓؤُلَآءِ بَنَاتِيٓ﴾</span>: نساؤُكم بناتي فتزوَّجوهنَّ.</p></div>"
  15,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعَمۡرُكَ﴾</span>: قَسَمٌ من اللهِ بحياةِ النبيِّ عليه الصلاة والسلام؛ تشريفًا له.</p><p><span class="qpc-hafs">﴿سَكۡرَتِهِمۡ﴾</span>: ضَلالَتِهم وشِدَّةِ محبَّتِهم الفاحشةَ التي أزالَتْ عقولَهم.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يترَدَّدُون مُتَحَيِّرين.</p></div>"
  15,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّيۡحَةُ﴾</span>: الصوتُ الشديدُ المُهْلِكُ.</p><p><span class="qpc-hafs">﴿مُشۡرِقِينَ﴾</span>: وقتَ شُروقِ الشمسِ.</p></div>"
  15,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَمۡطَرۡنَا﴾</span>: أرسَلْنا.</p><p><span class="qpc-hafs">﴿سِجِّيلٍ﴾</span>: طينٍ مُتَحَجِّرِ.</p></div>"
  15,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَدلائلَ وعِظاتٍ.</p><p><span class="qpc-hafs">﴿لِّلۡمُتَوَسِّمِينَ﴾</span>: الناظرين المُعْتَبِرين.</p></div>"
  15,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّهَا﴾</span>: قُرى قومِ لوطٍ.</p><p><span class="qpc-hafs">﴿لَبِسَبِيلࣲ﴾</span>: طريقٍ.</p><p><span class="qpc-hafs">﴿مُّقِيمٍ﴾</span>: ثابتٍ واضحٍ، يَمُرُّ بها الناسُ ويَرَوْن آثارَها.</p></div>"
  15,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: لَدلالةً وعِبْرَةً.</p></div>"
  15,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡأَيۡكَةِ﴾</span>: سكانُ مِنطَقَةِ الشجرِ الكثيرِ المُلتفِّ، وهم قومُ شعيبٍ عليه السلام.</p></div>"
  15,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّهُمَا﴾</span>: قرى قومِ لوطٍ، ومساكنَ قومِ شعيبٍ.</p><p><span class="qpc-hafs">﴿لَبِإِمَامࣲ مُّبِينࣲ﴾</span>: طريقٍ واضحٍ، يَأْتمُّ به أهلُ القوافل، ويَسْلُكونه في سَفَرهم.</p></div>"
  15,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡحِجۡرِ﴾</span>: سكانُ وادٍ بين المدينةِ والشّامِ، وهم ثمودُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُرۡسَلِينَ﴾</span>: أي: صالحًا؛ لأنّ مَن كذَّبَ نبيًّا فقد كَذَّبهم جميعًا.</p></div>"
  15,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِنَا﴾</span>: أدلَّتَنا وحُجَجَنا الدالَّهَ على صِدْقِ نبيِّهم، ومنها الناقةُ.</p><p><span class="qpc-hafs">﴿مُعۡرِضِينَ﴾</span>: صادِّين عنها، لا يتفكرون.</p></div>"
  15,82,""
  15,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّيۡحَةُ﴾</span>: الصوتُ الشديدُ المُهلِكُ.</p><p><span class="qpc-hafs">﴿مُصۡبِحِينَ﴾</span>: وقتَ الصَّباحِ.</p></div>"
  15,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَآ أَغۡنَىٰ﴾</span>: ما دَفَعَ عنهم العذابَ.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ يَكۡسِبُونَ﴾</span>: ما حَصَّلُوه من بناءِ البيوتِ والحُصونِ في الجبالِ، وجَمْعِ الأموالِ.</p></div>"
  15,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّفۡحَ ٱلۡجَمِيلَ﴾</span>: أي: الحَسَنَ، الذي لا أذِيَّةَ فيه.</p></div>"
  15,86,""
  15,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبۡعࣰا مِّنَ ٱلۡمَثَانِي﴾</span>: الفاتحةَ، وهي سبعُ آياتٍ تتكرَّر في كلِّ صلاةٍ.</p></div>"
  15,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَمُدَّنَّ عَيۡنَيۡكَ﴾</span>: لا تَطْمَحْ ببصَرِك.</p><p><span class="qpc-hafs">﴿إِلَىٰ مَا مَتَّعۡنَا بِهِۦٓ﴾</span>: إلى ما عندَ غيرِك من حُطامِ الدنيا وزِينتِها.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا﴾</span>: أصنافًا.</p><p><span class="qpc-hafs">﴿وَٱخۡفِضۡ جَنَاحَكَ﴾</span>: وتواضَعْ وأَلِنْ جانبَك.</p></div>"
  15,89,""
  15,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَآ أَنزَلۡنَا﴾</span>: أُنذِرُكم عذابَ اللهِ كما أنزلَه.</p><p><span class="qpc-hafs">﴿ٱلۡمُقۡتَسِمِينَ﴾</span>: اليهودِ والنصارى وغيرِهم الذين قسَّمُوا القرآنَ، فآمنوا ببعضِه وكفرُوا ببعضٍ.</p></div>"
  15,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِضِينَ﴾</span>: أجزاءً وأقسامًا؛ ليوافِقَ أهواءَهم.</p></div>"
  15,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَسۡـَٔلَنَّهُمۡ﴾</span>: سُؤالَ توبيخٍ، فلَنُحاسِبَنَّهم ولَنَجْزِيَنَّهم.</p></div>"
  15,93,""
  15,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱصۡدَعۡ بِمَا تُؤۡمَرُ﴾</span>: اجهَرْ بدعوةِ الحقِّ وأظْهِرْها.</p></div>"
  15,95,""
  15,96,""
  15,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَضِيقُ صَدۡرُكَ﴾</span>: يَنْقَبِضُ ألمًا وحُزْنًا.</p></div>"
  15,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّـٰجِدِينَ﴾</span>: المُصَلِّين العابِدين.</p></div>"
  15,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡيَقِينُ﴾</span>: الموتُ، المتيقَّنُ حُدوثُه.</p></div>"
