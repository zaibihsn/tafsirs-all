quran[75]{c,v,t}:
  39,1,""
  39,2,""
  39,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدِّينُ ٱلۡخَالِصُ﴾</span>: الطّاعَةُ التّامَّةُ السّالِمَةُ مِنَ الشِّرْكِ.</p><p><span class="qpc-hafs">﴿زُلۡفَىٰٓ﴾</span>: قُرْبى.</p></div>"
  39,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّٱصۡطَفَىٰ﴾</span>: لاخْتارَ.</p><p><span class="qpc-hafs">﴿ٱلۡقَهَّارُ﴾</span>: الَّذي قَهَرَ خَلْقَه بِقُدْرَتِهِ، فَكُلُّ شَيءٍ لَهُ مُتَذَلِّلٌ خاضِعٌ.</p></div>"
  39,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُكَوِّرُ ٱلَّيۡلَ عَلَى ٱلنَّهَارِ﴾</span>: يُدْخِلُ الليلَ على النَّهارِ.</p><p><span class="qpc-hafs">﴿وَيُكَوِّرُ ٱلنَّهَارَ عَلَى ٱلَّيۡلِ﴾</span>: يُدْخِلُ النَّهارَ على الليلِ.</p><p><span class="qpc-hafs">﴿وَسَخَّرَ﴾</span>: ذَلَّل.</p><p><span class="qpc-hafs">﴿لِأَجَلࣲ مُّسَمًّى﴾</span>: إلى حِينِ قِيامِ السّاعةِ.</p></div>"
  39,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾</span>: آدَمَ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿وَأَنزَلَ﴾</span>: خَلَقَ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡأَنۡعَـٰمِ ثَمَـٰنِيَةَ أَزۡوَ ٰ⁠جࣲ﴾</span>: ثمانيةَ أنْواعٍ ذَكَرًا وأُنْثى مِنَ الإبِلِ والبَقَرِ والضَّأنِ والَمعْزِ.</p><p><span class="qpc-hafs">﴿خَلۡقࣰا مِّنۢ بَعۡدِ خَلۡقࣲ﴾</span>: طَوْرًا بَعْدَ طَورِ مِنَ الخَلْقِ.</p><p><span class="qpc-hafs">﴿ظُلُمَـٰتࣲ ثَلَـٰثࣲ﴾</span>: ظُلُماتِ البَطْنِ والرَّحِمِ والَمشِيمَةِ.</p><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُصۡرَفُونَ﴾</span>: فَكَيفَ تَعْدِلُونَ عَنْ عِبادَةِ رَبِّكُم إلى عِبادَةِ غَيْرِه؟</p></div>"
  39,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَزِرُ وَازِرَةࣱ وِزۡرَ أُخۡرَىٰ﴾</span>: ولا تُؤْخَذُ نَفْسٌ بإثْمِ غَيْرِها.</p><p><span class="qpc-hafs">﴿بِذَاتِ ٱلصُّدُورِ﴾</span>: بأسْرارِ النُّفُوسِ وما تُخْفِيهِ.</p></div>"
  39,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنِيبًا﴾</span>: تائِبًا إليِهِ.</p><p><span class="qpc-hafs">﴿خَوَّلَهُۥ﴾</span>: مَنَحَه.</p><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: شُرَكاءَ.</p><p><span class="qpc-hafs">﴿تَمَتَّعۡ بِكُفۡرِكَ قَلِيلًا﴾</span>: تَمَتَّعْ بالسَّلامَةِ مِنَ العَذابِ زَمَنًا قَلِيلًا.</p></div>"
  39,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَـٰنِتٌ﴾</span>: عابدٌ لِرَبِّهِ، طائِعٌ لَهُ.</p><p><span class="qpc-hafs">﴿ءَانَآءَ﴾</span>: ساعاتِ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾</span>: أصْحابُ العُقُولِ السَّلِيمَةِ.</p></div>"
  39,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣱ﴾</span>: في الدُّنيا بالعافِيةِ، وفي الآخِرةِ بالجنَّةِ.</p><p><span class="qpc-hafs">﴿بِغَيۡرِ حِسَابࣲ﴾</span>: مِن غَيْرِ حَدٍّ ولا مِقْدارٍ.</p></div>"
  39,11,""
  39,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلَ ٱلۡمُسۡلِمِينَ﴾</span>: أوَّلَ مَن أسْلَمَ مِن أُمَّتِي.</p></div>"
  39,13,""
  39,14,""
  39,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱعۡبُدُواْ مَا شِئۡتُم﴾</span>: صِيغَةُ أمْرٍ على جِهَةِ التَّهْدِيدِ.</p></div>"
  39,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظُلَلࣱ﴾</span>: جَمْعُ ظُلَّةٍ قِطَعُ عَذابٍ كالسَّحابِ العظِيمِ.</p><p><span class="qpc-hafs">﴿عِبَادَهُۥ﴾</span>: كُلَّ عَبْدٍ مِنَ النّاسِ مِن مُّؤْمِنٍ وكافِرٍ.</p></div>"
  39,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّـٰغُوتَ﴾</span>: كُلَّ ما عُبِدَ مِن دُونِ اللهِ مِن شَيطانٍ وغَيرِهِ.</p><p><span class="qpc-hafs">﴿وَأَنَابُوٓاْ﴾</span>: وتابُوا.</p></div>"
  39,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡسَنَهُۥٓ﴾</span>: أرْشَدَهُ، وأَحْسَنُ الكَلامِ كَلامُ اللهِ ثُمَّ كَلامُ رَسُولِهِ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾</span>: أصْحابُ العُقُولِ السَّليمَةِ.</p></div>"
  39,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ﴾</span>: وجَبَ.</p></div>"
  39,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غُرَفࣱ﴾</span>: منازِلُ عالِيةٌ في الجنُّةِ.</p></div>"
  39,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّمَآءِ﴾</span>: السَّحابِ.</p><p><span class="qpc-hafs">﴿مَآءࣰ﴾</span>: مَطَرًا.</p><p><span class="qpc-hafs">﴿فَسَلَكَهُۥ﴾</span>: فأدْخَلَه.</p><p><span class="qpc-hafs">﴿يَنَـٰبِيعَ﴾</span>: جَمْعُ يَنْبُوعٍ وهو العينُ الكَثِيرةُ النَّبعِ التي لا يَنضُبُ ماؤُها.</p><p><span class="qpc-hafs">﴿يَهِيجُ﴾</span>: يَيْبَسُ بَعْدَ خُضْرتِهِ ونَضارَتِهِ.</p><p><span class="qpc-hafs">﴿حُطَـٰمًا﴾</span>: مُتَكَسِّرًا مُتَفَتِّتًا.</p><p><span class="qpc-hafs">﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: لِأَصْحابِ العُقُول السَّلِيمَةِ.</p></div>"
  39,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَرَحَ ٱللَّهُ صَدۡرَهُۥ لِلۡإِسۡلَـٰمِ﴾</span>: وسَّعَ اللهُ صدْرَهُ بالإيمانِ بِهِ والإسْلامِ.</p><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: فَهَلاكٌ.</p><p><span class="qpc-hafs">﴿لِّلۡقَـٰسِيَةِ قُلُوبُهُم مِّن ذِكۡرِ ٱللَّهِ﴾</span>: الَّذينَ غَلُظَتْ قُلُوبُهُم وأَعْرَضَتْ عَن ذِكْرِ اللهِ.</p></div>"
  39,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡسَنَ ٱلۡحَدِيثِ﴾</span>: القرآنَ العَظِيمَ.</p><p><span class="qpc-hafs">﴿مُّتَشَـٰبِهࣰا﴾</span>: يُشْبِهُ بَعْضُه بَعْضًا في الحُسْنِ والإحْكامِ وعَدَمِ الاخْتِلافِ.</p><p><span class="qpc-hafs">﴿مَّثَانِيَ﴾</span>: تُثَنّى فيه وتُكَرَّرُ القِصَصُ والأَحْكامُ والحُجَجُ والبَيِّناتُ.</p><p><span class="qpc-hafs">﴿تَقۡشَعِرُّ﴾</span>: تَتَقَبَّضُ وتَتَغَيَّرُ بِسَبَبِ الخوفِ.</p><p><span class="qpc-hafs">﴿تَلِينُ﴾</span>: تَطْمئِنُّ وتَسْكُنُ.</p></div>"
  39,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَمَن يَتَّقِي بِوَجۡهِهِۦ سُوٓءَ ٱلۡعَذَابِ﴾</span>: أفمن يُلْقى في النّارِ مكْتُوفًا فلا يَقْدِرُ أن يَتَّقِيَ النّارَ إلا بِوجْهِهِ كَمَن هُو مُنَعَّمٌ في الجنَّةِ؟</p></div>"
  39,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ حَيۡثُ لَا يَشۡعُرُونَ﴾</span>: مِنَ الموضِعِ الَّذي لا يعلَمُونَ بِمَجِيءِ العَذابِ مِنهُ.</p></div>"
  39,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخِزۡيَ﴾</span>: العَذابَ والهَوانَ.</p></div>"
  39,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَبۡنَا﴾</span>: ذَكَرْنا ووَصَفْنا.</p><p><span class="qpc-hafs">﴿مَثَلࣲ﴾</span>: نَبَأٍ عَظِيمٍ يَدْعُو إلى الاعْتِبارِ ويَسْتَوجِبُ الإيمانَ.</p></div>"
  39,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡرَ ذِي عِوَجࣲ﴾</span>: لا لَبْسَ فِيهِ ولا اخْتِلافَ.</p></div>"
  39,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَّجُلࣰا فِيهِ شُرَكَآءُ﴾</span>: عَبْدًا مَمْلُوكًا لِشُرَكاءَ.</p><p><span class="qpc-hafs">﴿مُتَشَـٰكِسُونَ﴾</span>: متنازِعُونَ، سَيِّئةٌ أخْلاقُهُم.</p><p><span class="qpc-hafs">﴿سَلَمࣰا لِّرَجُلٍ﴾</span>: خالِصًا لِرَجُلٍ واحِدٍ.</p><p><span class="qpc-hafs">﴿مَثَلًا﴾</span>: حالًَا.</p></div>"
  39,30,""
  39,31,""
  39,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَنۡ أَظۡلَمُ﴾</span>: لا أحَدَ أظْلَمُ.</p><p><span class="qpc-hafs">﴿بِٱلصِّدۡقِ﴾</span>: بالقرآنِ.</p><p><span class="qpc-hafs">﴿مَثۡوࣰى﴾</span>: مأوىً ومَسْكَنٌ.</p></div>"
  39,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلصِّدۡقِ﴾</span>: لا إلَهَ إلّا اللهُ.</p><p><span class="qpc-hafs">﴿وَصَدَّقَ بِهِۦٓ﴾</span>: مَن آمَنَ بالقُرْآنِ مِن نَّبِيِّ اللهِ وأَتْباعِهِ.</p></div>"
  39,34,""
  39,35,""
  39,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِكَافٍ عَبۡدَهُۥ﴾</span>: حامِي رَسُولِهِ مُحَمَّدٍ ﷺ.</p><p><span class="qpc-hafs">﴿مِن دُونِهِۦ﴾</span>: بالَّذِينَ يَعْبُدُونَ مِن دُونِهِ وهُمُ الأَصْنامُ.</p><p><span class="qpc-hafs">﴿مِن دُونِهِۦ﴾</span>: آلهَتِهِم الَّذين يَزْعُمُون أنها سَتُؤْذِيكَ.</p></div>"
  39,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَن يَهۡدِ ٱللَّهُ﴾</span>: ومَن يُوفِّقْه اللهُ للإيمانِ بهِ والعملِ بِكِتابِهِ.</p></div>"
  39,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُمۡسِكَـٰتُ رَحۡمَتِهِۦ﴾</span>: حابِساتُ رَحْمَتِهَ.</p><p><span class="qpc-hafs">﴿حَسۡبِيَ ٱللَّهُ﴾</span>: كافيَّ اللهُ.</p><p><span class="qpc-hafs">﴿يَتَوَكَّلُ﴾</span>: يَعْتَمِدُ ويُفَوِّضُ أمْرَهُ.</p></div>"
  39,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱعۡمَلُواْ عَلَىٰ مَكَانَتِكُمۡ﴾</span>: اعْمَلُوا على حالَتِكُم الَّتِي رَضَيتُمُوها لِأَنْفُسِكُم.</p></div>"
  39,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخۡزِيهِ﴾</span>: يُهينُهُ.</p><p><span class="qpc-hafs">﴿مُّقِيمٌ﴾</span>: دائِمٌ.</p></div>"
  39,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلِنَفۡسِهِۦ﴾</span>: فَنَفْعُ هِدايتِهِ لِنَفْسِهِ.</p><p><span class="qpc-hafs">﴿يَضِلُّ عَلَيۡهَا﴾</span>: يَعُودُ ضَرَرُ ضَلالِهِ عَلى نَفْسِهِ.</p><p><span class="qpc-hafs">﴿بِوَكِيلٍ﴾</span>: بِحَفِيظٍ ومَسْؤُولٍ عَنْ أعْمالِهِم.</p></div>"
  39,42,""
  39,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُفَعَآءَ﴾</span>: جَمْعُ شَفِيعٍ وهو الَّذِي يَطْلُبُ مِن غَيْرِه قَضاءَ حاجةِ شَخْصٍ آخَرَ، والمرادُ، واللهُ أعلمُ، ما يعبُدُونَه مِن دُونِ اللهِ.</p></div>"
  39,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُل لِّلَّهِ ٱلشَّفَـٰعَةُ﴾</span>: لِأَنَّ شَفاعةَ غَيرِهِ مَوقُوفَةٌ على إذْنِهِ سُبحانَه للشّافِعِ ورِضاهُ عَنِ المشْفُوعِ لَهُ، فلا تُطْلَبُ مِن هؤلاءِ الآلِهَةِ.</p></div>"
  39,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡمَأَزَّتۡ﴾</span>: نَفَرَتْ.</p><p><span class="qpc-hafs">﴿مِن دُونِهِۦٓ﴾</span>: وهُمُ الأَصْنامُ والأَوْثانُ والأَوْلِياءُ.</p></div>"
  39,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاطِرَ﴾</span>: هُوَ الخالِقُ والُمبْدِعُ عَلى غَيرِ مِثالٍ.</p><p><span class="qpc-hafs">﴿تَحۡكُمُ﴾</span>: تَفْصِلُ وتَقْضِي.</p></div>"
  39,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَدَا﴾</span>: وظَهَرَ.</p><p><span class="qpc-hafs">﴿يَحۡتَسِبُونَ﴾</span>: يَظُنُونَ أنَّهُ واقِعٌ بِهِم.</p></div>"
  39,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَاقَ بِهِم﴾</span>: ونَزَلَ وأَحاطَ بِهِم.</p></div>"
  39,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَوَّلۡنَـٰهُ﴾</span>: أعْطَيناهُ تَفَضُّلًا مِنّا.</p><p><span class="qpc-hafs">﴿عَلَىٰ عِلۡمِۭ﴾</span>: عَلى خَيرٍ عِنْدِي.</p><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: بَلْوى يَبْتَلِي اللهُ بِها عِبادَهُ لِيَنْظُرَ مَن يَشْكُرُهُ مِمَّنْ يَكْفُرُهُ.</p></div>"
  39,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَآ أَغۡنَىٰ عَنۡهُم﴾</span>: ما دَفَعَ عَنْهُمُ العَذابَ.</p></div>"
  39,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيِّـَٔاتُ مَا كَسَبُواْ﴾</span>: جَزاءُ سَيِّئاتِهِم وهو العَذابُ.</p><p><span class="qpc-hafs">﴿وَمَا هُم بِمُعۡجِزِينَ﴾</span>: وماهُمْ بِفائِتِينَ اللهَ ولا سابِقِيهِ.</p></div>"
  39,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: ويُضَيِّقُ.</p></div>"
  39,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡرَفُواْ عَلَىٰٓ أَنفُسِهِمۡ﴾</span>: تَمادَوا في المَعاصِي والكَبائِر.</p><p><span class="qpc-hafs">﴿لَا تَقۡنَطُواْ﴾</span>: لا تَيْئَسُوا.</p></div>"
  39,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنِيبُوٓاْ﴾</span>: ارْجِعُوا إلى رَبِّكُم بالتَّوبَةِ والطّاعةِ.</p><p><span class="qpc-hafs">﴿وَأَسۡلِمُواْ لَهُۥ﴾</span>: واخْضَعُوا لَهُ بالطّاعةِ والإقْرارِ بَتَوْحِيدِهِ وإخْلاصِ العِبادةِ لَهُ.</p><p><span class="qpc-hafs">﴿لَا تُنصَرُونَ﴾</span>: لا تُمنَعُونَ.</p></div>"
  39,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡسَنَ مَآ أُنزِلَ إِلَيۡكُم مِّن رَّبِّكُم﴾</span>: هو القُرآنُ العظِيمُ، وفِيهِ الخبرُ والأمْرُ بالحَسَنِ والأَحْسَنِ، ومُقْتَضاهُ فِيهِ حَسَنٌ وأَحْسَنُ، وإن كانَ في نَفْسِه أحْسَنَ الحَدِيثِ.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأةً.</p></div>"
  39,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن تَقُولَ﴾</span>: لِئَلّا تَقُولَ.</p><p><span class="qpc-hafs">﴿يَـٰحَسۡرَتَى﴾</span>: يا نَدَمِي؛ اغْتِمامًا عَلى ما فاتَ.</p><p><span class="qpc-hafs">﴿مَا فَرَّطتُ﴾</span>: ما ضَيَّعْتُ في الدُّنيا مِنَ العَمَلِ بِما أمَرَنِي اللهُ بِه.</p><p><span class="qpc-hafs">﴿فِي جَنۢبِ ٱللَّهِ﴾</span>: في طاعَتِهِ.</p><p><span class="qpc-hafs">﴿ٱلسَّـٰخِرِينَ﴾</span>: المُسْتَهْزِئِينَ بِأمْرِ اللهِ وكِتابِهِ ورَسُولِهِ والمؤُمِنِينَ.</p></div>"
  39,57,""
  39,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّةࣰ﴾</span>: رَجْعَةً إلى الحياةِ الدُّنيا.</p></div>"
  39,59,""
  39,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوࣰى﴾</span>: مأوىً ومَسْكَنٌ.</p></div>"
  39,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَفَازَتِهِمۡ﴾</span>: بِسَبِبِ فَوْزِهِم بالأَعْمالِ الصّالِحَةِ.</p><p><span class="qpc-hafs">﴿ٱلسُّوٓءُ﴾</span>: أذى جَهَنَّمَ.</p></div>"
  39,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلࣱ﴾</span>: حَفِيظٌ يُدَبِّرُ جَمِيعَ شَؤُونِ خَلْقِهِ.</p></div>"
  39,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقَالِيدُ﴾</span>: مَفاتِيحُ خَزائِن.</p></div>"
  39,64,""
  39,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَحۡبَطَنَّ﴾</span>: لَيَبْطُلَنَّ.</p></div>"
  39,66,""
  39,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا قَدَرُواْ ٱللَّهَ حَقَّ قَدۡرِهِۦ﴾</span>: ما عَظَّمُوا اللهَ حَقَّ تعظِيمِهِ إذْ عَبَدُوا مَعَهُ غَيرَهُ.</p><p><span class="qpc-hafs">﴿قَبۡضَتُهُۥ﴾</span>: في قَبْضَتِه عَلى ما يَلِيقُ بِه.</p></div>"
  39,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: الَقْرنِ الَّذِي يُنْفخُ فِيهِ.</p><p><span class="qpc-hafs">﴿فَصَعِقَ﴾</span>: فَماتَ مِنَ الفَزَعِ وشِدَّةِ الصَّوْتِ.</p><p><span class="qpc-hafs">﴿أُخۡرَىٰ﴾</span>: هي نَفْخَةُ البَعْثِ.</p><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: يُبْصِرُونَ، لِكَمالِ حياتِهِم.</p></div>"
  39,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَشۡرَقَتِ﴾</span>: أضاءَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضُ﴾</span>: أرْضُ القِيامَةِ.</p><p><span class="qpc-hafs">﴿وَوُضِعَ ٱلۡكِتَـٰبُ﴾</span>: ونَشَرَتِ الملائِكةُ صَحِيفَةَ كُلِّ فَرْدٍ.</p><p><span class="qpc-hafs">﴿وَٱلشُّهَدَآءِ﴾</span>: هُمُ الَّذِينَ يَشْهَدُونَ على النّاسِ بأعْمالِهِم.</p></div>"
  39,70,""
  39,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسِيقَ﴾</span>: وحُثَّ الكافِرُونَ على السَّيرِ بِعْنْفٍ.</p><p><span class="qpc-hafs">﴿زُمَرًا﴾</span>: جماعاتٍ مُتَفَرِّقةً، بَعْضُهُم عَلى إثْرِ بَعْضٍ.</p><p><span class="qpc-hafs">﴿حَقَّتۡ﴾</span>: وجَبَتْ.</p><p><span class="qpc-hafs">﴿كَلِمَةُ ٱلۡعَذَابِ﴾</span>: قَضاءُ اللهِ بالعَذابِ.</p></div>"
  39,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِئۡسَ﴾</span>: فَقَبُحَ.</p><p><span class="qpc-hafs">﴿مَثۡوَى﴾</span>: مَصِيرُ.</p></div>"
  39,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسِيقَ﴾</span>: وحُثَّ المتَّقُونَ عَلى السَّيرِ مُكَرَّمِينَ.</p><p><span class="qpc-hafs">﴿زُمَرًا﴾</span>: جماعاتٍ مُتَفَرِّقةً، بعضُهم على إثْرِ بَعْضٍ.</p><p><span class="qpc-hafs">﴿طِبۡتُمۡ﴾</span>: طابَتْ أحْوالُكُم.</p></div>"
  39,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضَ﴾</span>: أرْضَ الجنَّةِ.</p><p><span class="qpc-hafs">﴿نَتَبَوَّأُ﴾</span>: نَنْزِلُ.</p></div>"
  39,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَآفِّينَ﴾</span>: مُحِيطِينَ بجَوانِبِ العَرْشِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هو سَرِيرُ الُملْكِ الَّذي اسْتَوى عَلَيهِ الَّرحمنُ، وتَحْمِلُهُ الملائِكَةُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p><p><span class="qpc-hafs">﴿يُسَبِّحُونَ﴾</span>: يُنَزِّهُونَ.</p></div>"
