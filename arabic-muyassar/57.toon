quran[29]{c,v,t}:
  57,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبَّحَ لِلَّهِ﴾</span>: نَزَّهَهُ عِنِ السُّوءِ ومَجَّدَهُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: الَّذِي لا يُغْلَبُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمُ﴾</span>: الَّذِي يَضَعُ الأَفْعالَ حِيثُ يَلِيقُ بِها.</p></div>"
  57,2,""
  57,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَوَّلُ﴾</span>: الَّذِي ليسَ قَبْلَهُ شَيءٌ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔاخِرُ﴾</span>: الَّذِي لَيسَ بَعْدَه شَيءٌ.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰهِرُ﴾</span>: الَّذِي لَيسَ فَوْقَه شَيءٌ.</p><p><span class="qpc-hafs">﴿ٱلۡبَاطِنُ﴾</span>: الَّذِي لَيسَ دُونَهُ شَيءٌ.</p></div>"
  57,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: عَلا وارْتَفَعَ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: سَرير المُلْكِ الَّذِي تَحْمِلُه الملائِكَةُ، واسْتَوىَ عَليهِ الرَّحمنُ، وهو أعْظَمُ المخلُوقاتِ، وهو سَقْفُ جَنَّةِ الفِرْدَوسِ.</p><p><span class="qpc-hafs">﴿يَلِجُ فِي ٱلۡأَرۡضِ﴾</span>: يَدْخُلُ مِن حَبٍّ ومَطَرٍ وغَيرِ ذَلِكَ.</p><p><span class="qpc-hafs">﴿يَعۡرُجُ فِيهَا﴾</span>: يَصْعَدُ مِنَ الملائِكةِ والأرْواحِ والأَدْعِيَةِ والأَعْمالِ.</p><p><span class="qpc-hafs">﴿مَعَكُمۡ﴾</span>: بِعِلْمِهِ.</p></div>"
  57,5,""
  57,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُولِجُ ٱلَّيۡلَ فِي ٱلنَّهَارِ﴾</span>: يُدْخِلُ ما نَقَصَ مِن ساعاتِ الليل في النَّهارِ فَيَزِيدُ النَّهارَ.</p><p><span class="qpc-hafs">﴿وَيُولِجُ ٱلنَّهَارَ فِي ٱلَّيۡلِ﴾</span>: ويُدْخِلُ ما نَقَصَ من ساعاتِ النَّهارِ في الليلِ فَيَزيدُ الليلَ.</p><p><span class="qpc-hafs">﴿بِذَاتِ ٱلصُّدُورِ﴾</span>: بما فِي صُدُورِ خَلْقِهِ.</p></div>"
  57,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَعَلَكُم مُّسۡتَخۡلَفِينَ﴾</span>: جَعَلَها في أيْدِيكُم، واسْتَخْلَفَكُم عَلَيها.</p></div>"
  57,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَكُمۡ﴾</span>: عَهْدَكُم المؤَكَّدَ.</p></div>"
  57,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظُّلُمَـٰتِ﴾</span>: ظُلُماتِ الكُفْرِ.</p><p><span class="qpc-hafs">﴿ٱلنُّورِ﴾</span>: نُور الإيمانِ.</p><p><span class="qpc-hafs">﴿لَرَءُوفࣱ﴾</span>: لَرَحِيمٌ بِهِم أشَدَّ رَحْمةٍ.</p></div>"
  57,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لَكُمۡ أَلَّا تُنفِقُواْ﴾</span>: أيُّ شَيءٍ يَمْنَعُكُم مِنَ الإنْفاقِ؟</p><p><span class="qpc-hafs">﴿مِيرَ ٰ⁠ثُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: مُلْكُ السَّمَواتِ والأرْضِ، وسَيَنْتَقِلُ إلى مالِكِه الحقِيقِي.</p><p><span class="qpc-hafs">﴿ٱلۡفَتۡحِ﴾</span>: فَتْحِ مَكَّةَ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الجنَّةَ.</p></div>"
  57,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُقۡرِضُ ٱللَّهَ﴾</span>: يُنْفِقُ مُخْلِصًا عَمَلَهُ للهِ.</p></div>"
  57,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡعَىٰ نُورُهُم﴾</span>: يُضِيءُ لَهُم نُورُ عَمَلِهِم عَلى الصِّراطِ عَلى قَدْرِ أعْمالِهِم.</p></div>"
  57,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنظُرُونَا﴾</span>: انْتَظِرُونا، وتَريَّثُوا في سَيرِكُم حتى نَلْحَقَ بِكُم.</p><p><span class="qpc-hafs">﴿نَقۡتَبِسۡ﴾</span>: نَأْخُذْ.</p><p><span class="qpc-hafs">﴿قِيلَ﴾</span>: القائِلُ: المؤمِنُونَ.</p><p><span class="qpc-hafs">﴿ٱرۡجِعُواْ وَرَآءَكُمۡ﴾</span>: ارْجِعُوا إلى المكانِ الَّذِي قَبَسْتُم فِيهِ النُّورَ.</p><p><span class="qpc-hafs">﴿فَٱلۡتَمِسُواْ﴾</span>: فاطْلُبُوا.</p><p><span class="qpc-hafs">﴿فَضُرِبَ بَيۡنَهُم﴾</span>: فَوُضِعَ بَيْنَ المؤمِنينَ والمنافِقِينَ.</p><p><span class="qpc-hafs">﴿بِسُورࣲ﴾</span>: بِجِدارٍ مُحِيطٍ مُرْتَفِعٍ.</p><p><span class="qpc-hafs">﴿بَاطِنُهُۥ﴾</span>: داخِلُهُ.</p><p><span class="qpc-hafs">﴿وَظَـٰهِرُهُۥ﴾</span>: خارِجُهُ.</p><p><span class="qpc-hafs">﴿مِن قِبَلِهِ﴾</span>: في جِهَتِهِ المقابِلَةِ الَّتِي فِيها المنافِقُونَ.</p></div>"
  57,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنتُمۡ أَنفُسَكُمۡ﴾</span>: آثمْتُمُوها، وأَهْلَكْتُمُوها بالنِّفاقِ.</p><p><span class="qpc-hafs">﴿وَتَرَبَّصۡتُمۡ﴾</span>: وانْتَظَرْتُم بالنَّبِي الموتَ وبِالمؤمِنِينَ الدَّوائِرَ.</p><p><span class="qpc-hafs">﴿وَٱرۡتَبۡتُمۡ﴾</span>: شَكَكْتُم في التَّوحِيدِ ونُبُوَّةِ محمَّدٍ ﷺ.</p><p><span class="qpc-hafs">﴿وَغَرَّتۡكُمُ﴾</span>: خَدَعَتْكُم.</p><p><span class="qpc-hafs">﴿ٱلۡأَمَانِيُّ﴾</span>: ما تُمَنُّونَ بِهِ أنْفُسَكُم مِنَ الأباطِيلِ.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: الموتُ.</p><p><span class="qpc-hafs">﴿ٱلۡغَرُورُ﴾</span>: الشَّيطانُ.</p></div>"
  57,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِدۡيَةࣱ﴾</span>: عِوَضٌ تَتَخَلّصُونَ بِهِ مِنَ العذابِ.</p><p><span class="qpc-hafs">﴿مَأۡوَىٰكُمُ﴾</span>: مَصِيرُكُم الَّذِي تَخْلُدُونَ فِيهِ.</p><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: وساءَ مَرْجِعُ مَن صارَ إلى النّارِ.</p></div>"
  57,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ يَأۡنِ﴾</span>: ألَمْ يَأْتِ الوَقْتُ؟</p><p><span class="qpc-hafs">﴿تَخۡشَعَ﴾</span>: تَرِقَّ وتَلِينَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَمَدُ﴾</span>: الزَّمانُ أو الغايَةُ، وبُعْدُ عَهْدِهِم بالأنبياءِ والصّالِحِينَ.</p></div>"
  57,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضَ﴾</span>: الميْتَةَ الَّتِي لا تُنْبِتُ شَيئًا.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَا﴾</span>: بَعْدَ يُبْسِها لاحْتِباسِ الماءِ عَنْها.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الدَّلائِلَ والحُجَجَ.</p><p><span class="qpc-hafs">﴿لَعَلَّكُمۡ تَعۡقِلُونَ﴾</span>: رَجاءَ أن تَعْقِلُوا.</p></div>"
  57,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُصَّدِّقِينَ﴾</span>: المتَصَدِّقِينَ مِن أمْوالِهِم.</p><p><span class="qpc-hafs">﴿وَأَقۡرَضُواْ ٱللَّهَ قَرۡضًا﴾</span>: أنْفَقُوا في سَبِيلِ اللهِ نَفَقاتٍ طَيِّبةً بِها نُفُوسُهُم.</p></div>"
  57,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصِّدِّيقُونَ﴾</span>: الَّذِينَ كَمُلَ تَصْدِيقُهُم بِما جاءَتْ بِهِ الرُّسُلُ، اعتِقادًا وقَوْلًا وعَمَلًا.</p><p><span class="qpc-hafs">﴿وَٱلشُّهَدَآءُ﴾</span>: هُمُ القَتْلى في سَبِيلِ اللهِ، والَّذِينَ يَشْهَدُونَ عَلى الأُمَمِ السّابِقَةِ.</p></div>"
  57,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَثَلِ غَيۡثٍ﴾</span>: كَحالِ القَطْرِ.</p><p><span class="qpc-hafs">﴿ٱلۡكُفَّارَ﴾</span>: الزُّرّاعَ، لِأنّ الزّارِعَ يَسْتُرُ ما يَزْرَعُهُ بِتُرابِ الأرْضِ.</p><p><span class="qpc-hafs">﴿يَهِيجُ﴾</span>: يَيْبَسُ.</p><p><span class="qpc-hafs">﴿مُصۡفَرࣰّا﴾</span>: تَحَوَّلَ لونُه إلى الصُّفْرةِ.</p><p><span class="qpc-hafs">﴿حُطَـٰمࣰا﴾</span>: مُتَهَشِّمًا مُتَكَسِّرًا.</p><p><span class="qpc-hafs">﴿مَتَـٰعُ ٱلۡغُرُورِ﴾</span>: تَمتُّعٌ يَنْخَدِعُ بِهِ أهْلُهُ.</p></div>"
  57,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡفِرَةࣲ﴾</span>: أسبابِ المغفِرَةِ مِنَ التَّوبَةِ والابْتِعادِ عَنِ المعاصِي.</p></div>"
  57,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبࣲ﴾</span>: اللوحِ المحفُوظِ.</p><p><span class="qpc-hafs">﴿نَّبۡرَأَهَآ﴾</span>: نَخْلُقَ الخَلِيقَةَ.</p></div>"
  57,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَأۡسَوۡاْ﴾</span>: تَحْزَنُوا.</p><p><span class="qpc-hafs">﴿تَفۡرَحُواْ﴾</span>: فَرَحَ بَطَرٍ وأَشَرٍ.</p><p><span class="qpc-hafs">﴿مُخۡتَالࣲ﴾</span>: مُتَكَبِّرٍ.</p></div>"
  57,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡخَلُونَ﴾</span>: بأمْوالِهمِ.</p><p><span class="qpc-hafs">﴿يَتَوَلَّ﴾</span>: يُعْرِضْ عَن طاعَةِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَنِيُّ﴾</span>: عَنْ خَلْقِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيدُ﴾</span>: المحمُودُ على أوصافِهِ الكامِلةِ.</p></div>"
  57,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالحُجَجِ الواضِحاتِ.</p><p><span class="qpc-hafs">﴿لِيَقُومَ ٱلنَّاسُ بِٱلۡقِسۡطِ﴾</span>: لِيَتَعامَلَ النّاسُ بَيْنَهُم بالعَدلِ.</p><p><span class="qpc-hafs">﴿بَأۡسࣱ﴾</span>: قُوَّةٌ.</p><p><span class="qpc-hafs">﴿عَزِيزࣱ﴾</span>: لا يُغْلَبُ.</p></div>"
  57,26,""
  57,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَفَّيۡنَا﴾</span>: أتْبَعْنا.</p><p><span class="qpc-hafs">﴿رَأۡفَةࣰ﴾</span>: لِينًا.</p><p><span class="qpc-hafs">﴿وَرَهۡبَانِيَّةً﴾</span>: وابْتَدَعُوا رَهْبانِيَّةً بالغُلُوِّ في العِبادةِ.</p><p><span class="qpc-hafs">﴿مَا كَتَبۡنَـٰهَا﴾</span>: ما فَرَضْناها.</p><p><span class="qpc-hafs">﴿إِلَّا ٱبۡتِغَآءَ رِضۡوَ ٰ⁠نِ ٱللَّهِ﴾</span>: التَزَمُوا بالرَّهْبانِيَّةِ المُبْتدَعَةِ يَطْلُبُونَ بِذَلِكَ رِضا اللهِ.</p><p><span class="qpc-hafs">﴿فَمَا رَعَوۡهَا حَقَّ رِعَايَتِهَا﴾</span>: فما قامُوا بِها حَقَّ القيامِ.</p></div>"
  57,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِفۡلَيۡنِ﴾</span>: ضعْفَينِ.</p><p><span class="qpc-hafs">﴿تَمۡشُونَ بِهِۦ﴾</span>: تَهْتَدُونَ بِهِ.</p></div>"
  57,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّئَلَّا يَعۡلَمَ﴾</span>: لِيعلَمَ.</p><p><span class="qpc-hafs">﴿ٱلۡفَضۡلِ ٱلۡعَظِيمِ﴾</span>: الإحْسانِ والعَطاءِ الكَثِيرِ الواسِعِ.</p></div>"
