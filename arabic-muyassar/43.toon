quran[89]{c,v,t}:
  43,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: سَبَقَ الكَلامُ على الحُرُوفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البَقَرةِ.</p></div>"
  43,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡكِتَـٰبِ﴾</span>: القُرآنِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُبِينِ﴾</span>: الواضِح لَفْظًا ومَعْنىً.</p></div>"
  43,3,""
  43,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمِّ ٱلۡكِتَـٰبِ﴾</span>: اللَّوحِ المحْفُوظِ.</p><p><span class="qpc-hafs">﴿لَعَلِيٌّ﴾</span>: رَفِيعٌ.</p><p><span class="qpc-hafs">﴿حَكِيمٌ﴾</span>: مُحْكَمٌ لا اخْتِلافَ فِيهِ ولا تَناقُضَ.</p></div>"
  43,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ﴾</span>: أفَنُعْرِضُ عَنْكُم ونَتْرُكُ إنْزالَ القُرآنِ إلَيكُم.</p><p><span class="qpc-hafs">﴿صَفۡحًا﴾</span>: أي: إعْراضًا.</p><p><span class="qpc-hafs">﴿مُّسۡرِفِينَ﴾</span>: مُتَجاوِزِينَ الحدَّ في الإعْراضِ عَنِ القُرآنِ.</p></div>"
  43,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَمۡ﴾</span>: كَثِيرًا.</p><p><span class="qpc-hafs">﴿ٱلۡأَوَّلِينَ﴾</span>: القُرُونِ الَّتي مَضَتْ.</p></div>"
  43,7,""
  43,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَطۡشࣰا﴾</span>: قُوَّةً وبأسًا.</p><p><span class="qpc-hafs">﴿مَثَلُ﴾</span>: عُقُوبةُ.</p></div>"
  43,9,""
  43,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَهۡدࣰا﴾</span>: فِراشًا وبِساطًا.</p><p><span class="qpc-hafs">﴿سُبُلࣰا﴾</span>: طُرُقًا لِمَعاشِكُم ومَتاجِرِكُم.</p></div>"
  43,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَآءَۢ﴾</span>: مَطَرًا.</p><p><span class="qpc-hafs">﴿بِقَدَرࣲ﴾</span>: بِمِقْدارِ الحاجَةِ.</p><p><span class="qpc-hafs">﴿فَأَنشَرۡنَا﴾</span>: فَأَحْيَيْنا.</p><p><span class="qpc-hafs">﴿بَلۡدَةࣰ﴾</span>: قِطْعَةً واسِعَةً مِنَ الأرْضِ.</p><p><span class="qpc-hafs">﴿مَّيۡتࣰا﴾</span>: مُقْفِرًا مِنَ النَّباتِ والزَّرْعِ.</p><p><span class="qpc-hafs">﴿تُخۡرَجُونَ﴾</span>: تُبْعَثُونَ يومَ القيامةِ.</p></div>"
  43,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَزۡوَ ٰ⁠جَ﴾</span>: الأصْنافَ مِن حَيوانٍ ونَباتٍ ذُكُورًا وإناثًا.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السُّفُنِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَنۡعَـٰمِ﴾</span>: البَهائِمِ كالإبِلِ والخيلِ والبِغالِ والحمِيرِ.</p></div>"
  43,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَخَّرَ﴾</span>: ذَلَّلَ وطَوَّعَ.</p><p><span class="qpc-hafs">﴿مُقۡرِنِينَ﴾</span>: مُطِيقِينَ.</p></div>"
  43,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمُنقَلِبُونَ﴾</span>: راجِعُونَ.</p></div>"
  43,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُزۡءًا﴾</span>: نَصِيبًا.</p></div>"
  43,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمِ﴾</span>: بَلِ.</p><p><span class="qpc-hafs">﴿ٱتَّخَذَ﴾</span>: أتَزْعُمُونَ أنَّ الله اتَّخَذَ.</p><p><span class="qpc-hafs">﴿وَأَصۡفَىٰكُم﴾</span>: وأَخْلَصَكُم.</p></div>"
  43,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَبَ﴾</span>: جَعَلَ.</p><p><span class="qpc-hafs">﴿مَثَلࣰا﴾</span>: شبيهًا.</p><p><span class="qpc-hafs">﴿ظَلَّ﴾</span>: صارَ.</p><p><span class="qpc-hafs">﴿كَظِيمٌ﴾</span>: حَزِينٌ مملُوءٌ بالهَمِّ والكَرْبِ.</p></div>"
  43,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنَشَّؤُاْ﴾</span>: يُرَبّى.</p><p><span class="qpc-hafs">﴿ٱلۡحِلۡيَةِ﴾</span>: الزِّينةِ.</p><p><span class="qpc-hafs">﴿ٱلۡخِصَامِ﴾</span>: الِجدالِ.</p></div>"
  43,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَشَهِدُواْ خَلۡقَهُمۡ﴾</span>: أحَضَرُوا حِينَ خَلْقِهِم؟</p></div>"
  43,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡرُصُونَ﴾</span>: يَكْذِبُونَ.</p></div>"
  43,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسۡتَمۡسِكُونَ﴾</span>: يَعْمَلُونَ به ويَدِينُونَ بما فِيهِ.</p></div>"
  43,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣲ﴾</span>: طَرِيقةٍ ودِينٍ.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ ءَاثَـٰرِهِم﴾</span>: وراءَهُم.</p><p><span class="qpc-hafs">﴿مُّهۡتَدُونَ﴾</span>: مُتَّبِعُونَ.</p></div>"
  43,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتۡرَفُوهَآ﴾</span>: الرُّؤَساءُ الَّذيِنَ أطْغَتْهُم النِّعْمَةُ.</p></div>"
  43,24,""
  43,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱنتَقَمۡنَا مِنۡهُمۡ﴾</span>: عاقَبْناهُم على ذُنُوبِهِم.</p><p><span class="qpc-hafs">﴿عَـٰقِبَةُ﴾</span>: آخِرُ أمْرٍ.</p></div>"
  43,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَرَآءࣱ﴾</span>: بَرِيءٌ.</p></div>"
  43,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَرَنِي﴾</span>: خَلَقَنِي.</p><p><span class="qpc-hafs">﴿سَيَهۡدِينِ﴾</span>: سَيُوَفِّقُنِي لاتِّباعِ سَبِيلِ الرُّشْدِ.</p></div>"
  43,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلَهَا كَلِمَةَۢ بَاقِيَةࣰ﴾</span>: وجَعَلَ إبْراهِيمُ كَلِمةَ التَّوحِيدِ قَوْلًا باقِيًا على مَرِّ الزَّمانِ.</p><p><span class="qpc-hafs">﴿عَقِبِهِۦ﴾</span>: ولَدِهِ مِن بَعْدِهِ.</p></div>"
  43,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَّعۡتُ﴾</span>: أجْزَلْتُ النِّعمَةَ ولَمْ أُعاجِلْ بالعُقُوبَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: القُرَآنُ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: يُبَيِّنُ لَهُم مّا يَحْتاجُونَ إلَيهِ مِن أُمُورِ دِينِهِم.</p></div>"
  43,30,""
  43,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ٱلۡقَرۡيَتَيۡنِ﴾</span>: مَكَّةَ والطّائِفِ.</p></div>"
  43,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَحۡمَتَ رَبِّكَ﴾</span>: النُّبُوَّةُ.</p><p><span class="qpc-hafs">﴿سُخۡرِيࣰّا﴾</span>: مُذَلَّلًا في شُؤُونِ المعاشِ.</p><p><span class="qpc-hafs">﴿وَرَحۡمَتُ رَبِّكَ﴾</span>: النُّبُوَّةُ.</p><p><span class="qpc-hafs">﴿مِّمَّا يَجۡمَعُونَ﴾</span>: مِنَ الأمْوالِ.</p></div>"
  43,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: جماعَةً واحِدَةً، كُلُّهُم كُفّارٌ.</p><p><span class="qpc-hafs">﴿وَمَعَارِجَ﴾</span>: وسَلالِمَ.</p><p><span class="qpc-hafs">﴿يَظۡهَرُونَ﴾</span>: يَصْعَدُونَ.</p></div>"
  43,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسُرُرًا﴾</span>: جَمْعُ سَرِيرٍ، وهو ككرْسِيٍّ واسِعٍ يُمْكِنُ الاضْطِجاعُ عَلَيهِ.</p><p><span class="qpc-hafs">﴿يَتَّكِـُٔونَ﴾</span>: يَجْلِسُونَ عَلَيها مُعْتَمِدِينَ على مَرافِقِهِم.</p></div>"
  43,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزُخۡرُفࣰا﴾</span>: وجَعَلْنا لهم ذَهَبًا.</p></div>"
  43,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعۡشُ﴾</span>: يُعرِضْ.</p><p><span class="qpc-hafs">﴿ذِكۡرِ ٱلرَّحۡمَـٰنِ﴾</span>: القرآن.</p><p><span class="qpc-hafs">﴿نُقَيِّضۡ﴾</span>: نَجْعَلْ.</p><p><span class="qpc-hafs">﴿قَرِينࣱ﴾</span>: مُلازِمٌ ومُصاحِبٌ.</p></div>"
  43,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّبِيلِ﴾</span>: طَرِيقِ الحقِّ</p></div>"
  43,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰلَيۡتَ﴾</span>: ودِدْتُّ وتمنَّيتُ.</p><p><span class="qpc-hafs">﴿بُعۡدَ ٱلۡمَشۡرِقَيۡنِ﴾</span>: بُعْدَ ما بَينَ المشْرِقِ والمغْرِبِ.</p></div>"
  43,39,""
  43,40,""
  43,41,""
  43,42,""
  43,43,""
  43,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَذِكۡرࣱ﴾</span>: لَشَرَفٌ.</p></div>"
  43,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنۡ أَرۡسَلۡنَا﴾</span>: أتْباعَ مَن أرْسَلْنا، وهُم مُّؤمِنُو أهْلِ الكِتابِ.</p></div>"
  43,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بِحُجَجِنا.</p><p><span class="qpc-hafs">﴿وَمَلَإِيْهِۦ﴾</span>: عُظَماءِ قَومِهِ.</p></div>"
  43,47,""
  43,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ أُخۡتِهَا﴾</span>: مِنَ الَّتِي قَبْلَها.</p></div>"
  43,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّاحِرُ﴾</span>: العالِمُ، ولَمْ يَكُنِ السِّحْرُ صِفَةَ ذَمٍّ عِنْدَ فِرْعَونَ ومَلَئِهِ.</p></div>"
  43,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنكُثُونَ﴾</span>: يغْدِرُونَ ويَنْقُضُونَ ما عاهَدُوا عليهِ أنْفُسَهُم.</p></div>"
  43,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن تَحۡتِيٓ﴾</span>: مِن تَحْتِ قُصُورِي.</p></div>"
  43,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ﴾</span>: بَلْ.</p><p><span class="qpc-hafs">﴿مَهِينࣱ﴾</span>: ضَعِيفٌ حَقِيرٌ.</p><p><span class="qpc-hafs">﴿يُبِينُ﴾</span>: أي: يُبِين الكَلامَ.</p></div>"
  43,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَآ﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿مُقۡتَرِنِينَ﴾</span>: مُتَتابِعِينَ.</p></div>"
  43,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ﴾</span>: حَمَلَ قَومَه عَلى خفَّةِ العَقْل.</p></div>"
  43,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاسَفُونَا﴾</span>: أغْضَبُونا.</p><p><span class="qpc-hafs">﴿ٱنتَقَمۡنَا مِنۡهُمۡ﴾</span>: عاقَبْناهُم عَلى ذُنُوبِهم.</p></div>"
  43,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَفࣰا﴾</span>: قَوْمًا تَقَدَّمُوا لِيتَّعِظَ بِهِمُ الآخَرُونَ.</p><p><span class="qpc-hafs">﴿وَمَثَلࣰا﴾</span>: عِبْرةً وعِظَةً.</p></div>"
  43,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضُرِبَ ٱبۡنُ مَرۡيَمَ مَثَلًا﴾</span>: ضَرَبَ المشركُونَ نَبِيَّ اللهِ عِيسى مَثَلًا لِآلِهَتِهِم وشَبَّهُوهُ بِها في دُخُولِ النّارِ.</p><p><span class="qpc-hafs">﴿يَصِدُّونَ﴾</span>: يَصِيحُونَ فَرَحًا وسُرُورًا.</p></div>"
  43,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَصِمُونَ﴾</span>: شِدِيدُو التَّمَسُكِ بالخُصُومَةِ مَعَ ظُهُورِ الحقِّ عِنْدَهُم.</p></div>"
  43,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثَلࣰا لِّبَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ﴾</span>: عِبْرةً لَهُم يَعْرِفُونَ بِهِ قُدْرَةَ اللهِ عَلى ما يُرِيدُ؛ إذْ خَلَقَهُ مِن غَيرِ أبٍ.</p></div>"
  43,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنكُم﴾</span>: بَدَلًا مِنكُم.</p><p><span class="qpc-hafs">﴿يَخۡلُفُونَ﴾</span>: يَخْلُفُ بَعْضُهُم بَعْضًا بَدَلًا مِن بنِي آدمَ.</p></div>"
  43,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّهُۥ﴾</span>: وإنّ نُزولَ عِيسى عَلَيهِ السَّلامُ في آخِرِ الزَّمانِ.</p><p><span class="qpc-hafs">﴿لَعِلۡمࣱ﴾</span>: لَدَلِيلٌ وعَلامةٌ.</p><p><span class="qpc-hafs">﴿فَلَا تَمۡتَرُنَّ﴾</span>: فَلا تَشُكُّوا أنّها واقِعةٌ.</p></div>"
  43,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: بَيِّنُ العَداوَةِ.</p></div>"
  43,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالأدِلَّةِ الواضِحاتِ.</p><p><span class="qpc-hafs">﴿بِٱلۡحِكۡمَةِ﴾</span>: بالنُّبُوَّةِ.</p></div>"
  43,64,""
  43,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَحۡزَابُ﴾</span>: الفِرَقُ مِنَ النَّصارى.</p><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: فَهَلاكٌ وعَذابٌ ألِيمٌ.</p></div>"
  43,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: يَنْتَظِرُونَ.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأةً.</p></div>"
  43,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَخِلَّآءُ﴾</span>: الأصْدِقاءُ.</p></div>"
  43,68,""
  43,69,""
  43,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَزۡوَ ٰ⁠جُكُمۡ﴾</span>: وقُرَناؤُكُم المؤمِنُونَ.</p><p><span class="qpc-hafs">﴿تُحۡبَرُونَ﴾</span>: تُنَعَّمُونَ وتُسَرُّونَ.</p></div>"
  43,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِصِحَافࣲ﴾</span>: بآنِيةٍ يُؤْكَلُ فِيها.</p><p><span class="qpc-hafs">﴿وَأَكۡوَابࣲ﴾</span>: آنِيَةٍ للشُّرْبِ.</p><p><span class="qpc-hafs">﴿وَتَلَذُّ﴾</span>: وتَجِدُ فِيها ما يَسُرُّها.</p></div>"
  43,72,""
  43,73,""
  43,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُجۡرِمِينَ﴾</span>: الكافِرينَ.</p></div>"
  43,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُفَتَّرُ﴾</span>: لا يُخَفَّفُ.</p><p><span class="qpc-hafs">﴿مُبۡلِسُونَ﴾</span>: آيِسُونَ مِن رَّحْمَةِ اللهِ.</p></div>"
  43,76,""
  43,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰمَـٰلِكُ﴾</span>: هو اسْمُ خازِنِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿لِيَقۡضِ عَلَيۡنَا رَبُّكَ﴾</span>: لِيُمِتْنا ربُّكَ.</p><p><span class="qpc-hafs">﴿مَّـٰكِثُونَ﴾</span>: مُقِيمُونَ في العذابِ.</p></div>"
  43,78,""
  43,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ﴾</span>: بَلْ.</p><p><span class="qpc-hafs">﴿أَبۡرَمُوٓاْ﴾</span>: أحْكَمُوا.</p><p><span class="qpc-hafs">﴿مُبۡرِمُونَ﴾</span>: مُحْكِمُونَ أمْرًا في مُجازاتِهم بِالنَّكالِ والعَذابِ.</p></div>"
  43,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِرَّهُمۡ﴾</span>: ما يُخْفُونَه مِن غَيرِهِم.</p><p><span class="qpc-hafs">﴿وَنَجۡوَىٰهُم﴾</span>: الحدِيثَ الَّذِي يَتَسارُّونَ بِهِ فِيما بَينَهُم.</p><p><span class="qpc-hafs">﴿وَرُسُلُنَا﴾</span>: الملائِكَةُ الحَفَظَةُ.</p></div>"
  43,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَا۠ أَوَّلُ ٱلۡعَـٰبِدِينَ﴾</span>: أوَّلُ عابِدِيهِ بِذلكَ مِنكُم، ولَكِنَّهُ لا ولَدَ لَهُ، فأَنا أعْبُدُهُ بِأنّه لا ولَدَ لَهُ.</p></div>"
  43,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَ﴾</span>: تنْزِيهًا وتَقْدِيسًا.</p><p><span class="qpc-hafs">﴿يَصِفُونَ﴾</span>: يَكْذِبُونَ.</p></div>"
  43,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخُوضُواْ﴾</span>: يَتَحَدَّثُوا بالباطِل على غيرِ هُدىً.</p></div>"
  43,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلسَّمَآءِ إِلَـٰهࣱ وَفِي ٱلۡأَرۡضِ إِلَـٰهࣱ﴾</span>: مَعْبُودٌ في السَّماءِ وفي الأَرْضِ.</p></div>"
  43,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَبَارَكَ﴾</span>: كَثُرَ خَيْرُهُ.</p><p><span class="qpc-hafs">﴿تُرۡجَعُونَ﴾</span>: تُرَدُّونَ بَعْدَ مَماتِكُم.</p></div>"
  43,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّفَـٰعَةَ﴾</span>: طَلَبَ قَضاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المشْفُوعِ عِنْدَهُ مِنَ التَّجاوُزِ عَنِ السَّيئاتِ والزَّلّاتِ وغَيرِها.</p></div>"
  43,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾</span>: كَيْفَ يُصْرَفُونَ عَنْ عِبادَةِ الله؟</p></div>"
  43,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِيلِهِۦ﴾</span>: وعِنْدَ اللهِ عِلْمُ قولِ الرَّسُولِ ﷺ.</p></div>"
  43,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱصۡفَحۡ﴾</span>: فَأَعْرِضْ.</p><p><span class="qpc-hafs">﴿سَلَـٰمࣱ﴾</span>: سَلامُ مُتارَكَةٍ ومُفارَقَةٍ لِلْجاهِلِينَ.</p></div>"
