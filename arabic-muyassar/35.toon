quran[45]{c,v,t}:
  35,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاطِرِ﴾</span>: مُبْدِعٍ عَلى غَيرِ مِثالٍ سَبَقَ.</p><p><span class="qpc-hafs">﴿أُوْلِيٓ أَجۡنِحَةࣲ﴾</span>: أصْحابَ أجْنِحَةٍ.</p></div>"
  35,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يَفۡتَحِ﴾</span>: أي: ما يُرسِلْ ويُعْطِ.</p><p><span class="qpc-hafs">﴿رَّحۡمَةࣲ﴾</span>: نِعْمَةٍ.</p><p><span class="qpc-hafs">﴿مُمۡسِكَ﴾</span>: مانِعَ.</p><p><span class="qpc-hafs">﴿مُرۡسِلَ﴾</span>: مُعْطِيَ.</p></div>"
  35,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾</span>: فَكَيفَ تُصْرَفُونَ عَن تَوحِيدِهِ؟.</p></div>"
  35,4,""
  35,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعۡدَ ٱللَّهِ﴾</span>: أي: بالبعْثِ والثَّوابِ والعِقابِ.</p><p><span class="qpc-hafs">﴿حَقࣱّ﴾</span>: ثابِتٌ وكائِنٌ لا محالةَ.</p><p><span class="qpc-hafs">﴿فَلَا تَغُرَّنَّكُمُ﴾</span>: فَلا تَخْدَعَنَّكُم.</p><p><span class="qpc-hafs">﴿ٱلۡغَرُورُ﴾</span>: الشَّيطانُ.</p></div>"
  35,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِزۡبَهُۥ﴾</span>: أي: أتْباعَهُ.</p><p><span class="qpc-hafs">﴿ٱلسَّعِيرِ﴾</span>: النّارِ الموقَدَةِ.</p></div>"
  35,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجۡرࣱ كَبِيرٌ﴾</span>: وهو الجنَّةُ.</p></div>"
  35,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُيِّنَ لَهُۥ﴾</span>: أي: حَسَّنَ له الشَّيطانُ.</p><p><span class="qpc-hafs">﴿سُوٓءُ عَمَلِهِۦ﴾</span>: عَمَلُه السَّيِّئُ والقبيحُ.</p><p><span class="qpc-hafs">﴿فَلَا تَذۡهَبۡ نَفۡسُكَ عَلَيۡهِمۡ حَسَرَ ٰ⁠تٍ﴾</span>: فلا تُهِلكْ نفسَك حُزْنًا على كُفْرِهِم.</p></div>"
  35,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتُثِيرُ﴾</span>: فَتُحَرِّكُ.</p><p><span class="qpc-hafs">﴿مَّيِّتࣲ﴾</span>: جَدْب.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَا﴾</span>: بَعْدَ يُبْسِها وجَفافِها.</p><p><span class="qpc-hafs">﴿ٱلنُّشُورُ﴾</span>: بَعْثُ الموتى مِن قُبُورِهِم للجزاءِ.</p></div>"
  35,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡعَدُ﴾</span>: يَرْتَقِي.</p><p><span class="qpc-hafs">﴿ٱلۡكَلِمُ ٱلطَّيِّبُ﴾</span>: الكلامُ الطَّيِّبُ مِن ذِكْرٍ ودُعاءٍ وتِلاوَةٍ.</p><p><span class="qpc-hafs">﴿يَرۡفَعُهُۥ﴾</span>: أي: يَرفَعُه اللهُ إلَيهِ ويَقْبَلُه.</p><p><span class="qpc-hafs">﴿يَمۡكُرُونَ ٱلسَّيِّـَٔاتِ﴾</span>: أي: يَمْكُرُونَ المكَراتِ السَّيِّئاتِ، وهي مَذْكُورةٌ في قوله تعالى:</p><p><span class="qpc-hafs">﴿وَإِذۡ يَمۡكُرُ بِكَ ٱلَّذِينَ كَفَرُواْ لِيُثۡبِتُوكَ أَوۡ يَقۡتُلُوكَ أَوۡ يُخۡرِجُوكَ﴾</span>: [الأنفال: ٣٠].</p><p><span class="qpc-hafs">﴿يَبُورُ﴾</span>: يَفسُدُ ويَبْطُلُ.</p></div>"
  35,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن نُّطۡفَةࣲ﴾</span>: هي مَنِيُّ الرجلِ يَقْذِفُه في رَحِمِ امْرَأَتِه.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا﴾</span>: ذُكُورًا وإناثًا تَزَوَّجَ بعضُهم بَعْضًا.</p><p><span class="qpc-hafs">﴿لَا تَضَعُ﴾</span>: لاتَلِدُ.</p><p><span class="qpc-hafs">﴿مُّعَمَّرࣲ﴾</span>: طَوِيلِ العُمُرِ.</p></div>"
  35,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُرَاتࣱ﴾</span>: حُلْوٌ شَدِيدُ الحَلاوَةِ.</p><p><span class="qpc-hafs">﴿سَآئِغࣱ شَرَابُهُۥ﴾</span>: سَهْلٌ مُرُورُهُ في الحَلْقِ.</p><p><span class="qpc-hafs">﴿أُجَاجࣱ﴾</span>: شَدِيدُ المُلوحَةِ.</p><p><span class="qpc-hafs">﴿لَحۡمࣰا طَرِيࣰّا﴾</span>: هو السَّمَكُ.</p><p><span class="qpc-hafs">﴿حِلۡيَةࣰ﴾</span>: هي اللُّؤلُؤُ والمَرْجانُ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p><p><span class="qpc-hafs">﴿مَوَاخِرَ﴾</span>: جوارِيَ تَشُقُّ الماءَ شَقًّا.</p><p><span class="qpc-hafs">﴿لِتَبۡتَغُواْ﴾</span>: لِتَطْلُبُوا.</p></div>"
  35,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُولِجُ﴾</span>: يُدخِلُ.</p><p><span class="qpc-hafs">﴿لِأَجَلࣲ مُّسَمࣰّى﴾</span>: لِوقْتٍ مَعْلُومٍ.</p><p><span class="qpc-hafs">﴿قِطۡمِيرٍ﴾</span>: القِشْرَةِ الرَّقيقَةِ على نَواةِ التَّمْرَةِ.</p></div>"
  35,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُنَبِّئُكَ﴾</span>: ولا يُخْبِرُكَ.</p></div>"
  35,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُقَرَآءُ﴾</span>: المحْتاجُونَ.</p></div>"
  35,16,""
  35,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِعَزِيزࣲ﴾</span>: بمُمْتَنِعٍ.</p></div>"
  35,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَزِرُ﴾</span>: لا تَحْمِلُ.</p><p><span class="qpc-hafs">﴿وَازِرَةࣱ﴾</span>: أي: نفسٌ مُذْنِبَةٌ.</p><p><span class="qpc-hafs">﴿مُثۡقَلَةٌ﴾</span>: أي: نَفْسٌ أثْقَلَتْها الذُّنوبُ.</p><p><span class="qpc-hafs">﴿حِمۡلِهَا﴾</span>: ذُنُوبِها التي أثْقَلَتْها.</p><p><span class="qpc-hafs">﴿يَخۡشَوۡنَ﴾</span>: يخافُونَ.</p><p><span class="qpc-hafs">﴿تَزَكَّىٰ﴾</span>: تَطَهَّرَ مِنَ الشِّرْكِ والمعاصِي.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المرْجِعُ.</p></div>"
  35,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَعۡمَىٰ﴾</span>: مَن فَقَدَ بَصَرَه، والمُرادُ بِه هُنا الكافِرُ لأنّهُ عَمِيَ عَن دِينِ الحقِّ.</p></div>"
  35,20,""
  35,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَرُورُ﴾</span>: الرِّيحُ الحارَّةُ.</p></div>"
  35,22,""
  35,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَذِيرٌ﴾</span>: رَسُولٌ مُنْذِرٌ مِن عَذابِ اللهِ.</p></div>"
  35,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَشِيرࣰا وَنَذِيرࣰا﴾</span>: بَشِيرًا لِأَهْلِ الطّاعةِ ونَذَيرًا لِأَهْلِ المعْصِيةِ.</p><p><span class="qpc-hafs">﴿نَذِيرࣱ﴾</span>: نَبِيٌّ مُنْذِرٌ مِن عَذابِ اللهِ.</p></div>"
  35,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالمعْجِزاتِ الواضِحةِ.</p><p><span class="qpc-hafs">﴿وَبِٱلزُّبُرِ﴾</span>: بالكُتُبِ التي فيها مَواعِظُ.</p><p><span class="qpc-hafs">﴿وَبِٱلۡكِتَـٰبِ ٱلۡمُنِيرِ﴾</span>: الكُتُبِ الَّتي أنارَتْ طَرِيقَ الشَّرْعِ والهِدايَةِ، ومْنِها القرآنُ الكريمُ.</p></div>"
  35,26,""
  35,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُدَدُۢ﴾</span>: جَمْعُ جُدَّةٍ، وهي الطَّرِيقَةُ والخِطَّةُ في الشَّيءِ تكونُ واضِحةً فِيهِ.</p><p><span class="qpc-hafs">﴿وَغَرَابِيبُ﴾</span>: جمع غِرْبِيبٍ، وهو شَديدُ السَّوادِ يُشْبِهُ لَونُه لَونَ الغُرابِ.</p></div>"
  35,28,""
  35,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّن تَبُورَ﴾</span>: لَن تَكْسُدَ، ولَن تَهْلِكَ.</p></div>"
  35,30,""
  35,31,""
  35,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱصۡطَفَيۡنَا﴾</span>: الَّذِيِنَ اخْتَرْناهُم.</p><p><span class="qpc-hafs">﴿ظَالِمࣱ لِّنَفۡسِهِۦ﴾</span>: أي: بِأن وقَعَ في بَعْضِ المعاصِي.</p><p><span class="qpc-hafs">﴿مُّقۡتَصِدࣱ﴾</span>: أي: بِأَداءِ الواجِباتِ واجْتِنابِ المُحَرَّماتِ.</p><p><span class="qpc-hafs">﴿سَابِقُۢ بِٱلۡخَيۡرَ ٰ⁠تِ﴾</span>: أي: مُسارعٌ مُجْتَهِدٌ في الأعْمالِ الصّالحةِ فَرْضِها ونَفْلِها.</p></div>"
  35,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَلَّوۡنَ﴾</span>: يُزيَّنُونَ بالحِلْيةَ.</p><p><span class="qpc-hafs">﴿أَسَاوِرَ﴾</span>: مُفْرَدُه سِوارٌ: وهو ما يُلْبَسُ في اليدِ مِنَ الحُلِيِّ ويُحِيطُ بالمِعْصَمِ.</p><p><span class="qpc-hafs">﴿حَرِيرࣱ﴾</span>: ثِيابٌ رَقِيقَةٌ.</p></div>"
  35,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَزَنَ﴾</span>: أي: كُلَّ ما يُحْزِنُ ويُغِمُّ.</p></div>"
  35,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحَلَّنَا﴾</span>: أنزَلنا.</p><p><span class="qpc-hafs">﴿دَارَ ٱلۡمُقَامَةِ﴾</span>: دارَ الإقامةِ الدّائمةِ، وهي الجنَّةُ.</p><p><span class="qpc-hafs">﴿نَصَبࣱ﴾</span>: تَعَبٌ ومَشَقَّةٌ.</p><p><span class="qpc-hafs">﴿لُغُوبࣱ﴾</span>: إعياءٌ مِنَ التَّعَبِ وفُتُورٌ.</p></div>"
  35,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُقۡضَىٰ عَلَيۡهِمۡ﴾</span>: أي: بالموتِ.</p><p><span class="qpc-hafs">﴿كَفُورࣲ﴾</span>: مُتَمادٍ في الكُفْرِ مُصِرٍّ عليه.</p></div>"
  35,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡطَرِخُونَ﴾</span>: يَصْرُخُونَ بِشِدَّةٍ مُسْتَغِيثِينَ.</p><p><span class="qpc-hafs">﴿مَّا يَتَذَكَّرُ فِيهِ مَن تَذَكَّرَ﴾</span>: أي: مِثْلُه كافٍ للاتِّعاظِ لِمنْ أرادَ أن يَتَّعِظَ فِيهِ.</p><p><span class="qpc-hafs">﴿ٱلنَّذِيرُ﴾</span>: وهو الرَّسولُ ﷺ.</p></div>"
  35,38,""
  35,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَـٰٓئِفَ﴾</span>: يَخْلُفُ بَعْضُكُم بَعْضًا.</p><p><span class="qpc-hafs">﴿مَقۡتࣰا﴾</span>: بُغْضًا وغَضَبًا.</p><p><span class="qpc-hafs">﴿خَسَارࣰا﴾</span>: هَلاكًا وخُسْرانًا.</p></div>"
  35,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ شُرَكَآءَكُمُ﴾</span>: أخْبرُونِي عَن شُركائِكُم.</p><p><span class="qpc-hafs">﴿ءَاتَيۡنَـٰهُمۡ﴾</span>: أعْطَيناهُم.</p><p><span class="qpc-hafs">﴿غُرُورًا﴾</span>: خِداعًا.</p></div>"
  35,41,""
  35,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: مُجْتَهِدِينَ فِيها بالحَلِفِ بأغْلَظِها.</p><p><span class="qpc-hafs">﴿نُفُورًا﴾</span>: بُعْدًا عَنِ الحقِّ وفِرارًا مِنه.</p></div>"
  35,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَحِيقُ﴾</span>: لا يُحِيطُ ولا يَنْزِلُ.</p><p><span class="qpc-hafs">﴿ٱلۡمَكۡرُ ٱلسَّيِّئُ﴾</span>: أي: وبالُ مَكْرِهِم السَّيِّئِ.</p><p><span class="qpc-hafs">﴿سُنَّتَ ٱلۡأَوَّلِينَ﴾</span>: طَرِيقَةَ اللهِ فِيهِم وعادَتَهُ بِتَعْذِيبِهِم لِتكْذِيبِهِم.</p></div>"
  35,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُعۡجِزَهُۥ﴾</span>: لِيَفُوتَه.</p></div>"
  35,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤَاخِذُ﴾</span>: يُعاقِبُ.</p><p><span class="qpc-hafs">﴿يُؤَخِّرُهُمۡ﴾</span>: يُمْهِلُهُم.</p></div>"
