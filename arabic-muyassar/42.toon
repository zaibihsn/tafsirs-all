quran[53]{c,v,t}:
  42,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ عٓسٓقٓ﴾</span>: سَبَقَ الكَلامُ عَلى الحروفِ المقطَّعةِ في أوَّلِ سُورةِ البقرةِ.</p></div>"
  42,2,""
  42,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: القويُّ الَّذِي لا يُعْجِزُهُ شَيءٌ أرادَهُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمُ﴾</span>: الَّذِي لا يَدْخُلُ تَدْبِيرَهُ خَلَلٌ ولا زَلَلٌ.</p></div>"
  42,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَلِيُّ﴾</span>: العالي بِذاتِهِ وقُدْرَتِهِ وقَهْرِهِ.</p></div>"
  42,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَفَطَّرۡنَ﴾</span>: يَتَشَقَّقْنَ.</p><p><span class="qpc-hafs">﴿مِن فَوۡقِهِنَّ﴾</span>: مِن أعْلاهُنَّ مِن عَظَمِةِ اللهِ وجَلالِهِ.</p><p><span class="qpc-hafs">﴿يُسَبِّحُونَ﴾</span>: يُنَزِّهُونَ اللهَ عَمّا لا يَلِيقُ بِهِ قائِلِينَ: سُبَحانَ اللهِ.</p><p><span class="qpc-hafs">﴿وَيَسۡتَغۡفِرُونَ لِمَن فِي ٱلۡأَرۡضِ﴾</span>: ويَطْلُبُونَ مِن رَبِّهِم أن يَسْتُرَ ذُنُوبَ أهْلِ الأَرْضِ مِنَ المُؤمِنِين.</p></div>"
  42,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن دُونِهِۦٓ﴾</span>: غَيرَ اللهِ.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: مَعْبُودِينَ يَتَوَلَّونَهُم بالمحبَّةِ والتَّعظِيمِ.</p><p><span class="qpc-hafs">﴿ٱللَّهُ حَفِيظٌ عَلَيۡهِمۡ﴾</span>: يُحْصِي عَلَيهِم أعْمالَهُم فَيُجازِيهِم بِها يَومَ القِيامةِ.</p><p><span class="qpc-hafs">﴿وَمَآ أَنتَ عَلَيۡهِم بِوَكِيلࣲ﴾</span>: ولَسْتَ مُوَكَّلًا بِحِفْظِ أعمالِهِم وإنّما أنتَ مُنْذِرٌ.</p></div>"
  42,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ﴾</span>: مِثْلَ ذَلِكَ الإيجادِ.</p><p><span class="qpc-hafs">﴿لِّتُنذِرَ أُمَّ ٱلۡقُرَىٰ﴾</span>: لتُخَوِّفَ أهْلَ مَكَّةَ العَذابَ.</p><p><span class="qpc-hafs">﴿وَمَنۡ حَوۡلَهَا﴾</span>: وتُنْذِرَ مَن حَولَ مَكَّةَ مِن سائِر الناسِ العَذابَ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡجَمۡعِ﴾</span>: يومَ القِيامةِ، وسُمِّيَ بيومِ الجمْعِ لاجْتِماعِ الخلائقِ فِيهِ.</p><p><span class="qpc-hafs">﴿لَا رَيۡبَ فِيهِ﴾</span>: لا شَكَّ فِيه.</p><p><span class="qpc-hafs">﴿ٱلسَّعِيرِ﴾</span>: النّارِ الموقَدةِ على أهْلِها.</p></div>"
  42,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: أهْلَ دِينٍ واحِدٍ.</p><p><span class="qpc-hafs">﴿وَٱلظَّـٰلِمُونَ﴾</span>: والكافِرُونَ بِاللهِ.</p><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: قَرِيبٍ مُحِبٍّ يَتَوَلّاهُم بِنَفْعِهِ.</p><p><span class="qpc-hafs">﴿نَصِيرٍ﴾</span>: ناصِرٍ يَمْنَعُهم مِن عِقابِ اللهِ حِينَ يُعاقِبُهُم.</p></div>"
  42,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمِ ٱتَّخَذُواْ﴾</span>: بَل اتَّخَذُوا.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: مَعْبودِينَ يَتَوَلَّونَهُم بالمحَبَّةِ والتَّعْظِيمِ ويَطْلُبُونَ مِنهُم النَّفْعَ والنُّصْرَةَ.</p><p><span class="qpc-hafs">﴿ٱلۡوَلِيُّ﴾</span>: النّاصِرُ المُعِينُ الَّذِي تَنْفَعُ وِلايتُهُ، يَتَوَلّاهُ عَبْدُهُ بالعِبادَةِ والطّاعَةِ، ويَتَوَلّى عِبادَهُ المؤمِنِينَ بِهدايَتِهِم وإعانَتِهِم، ويَتَولّى عُمُومَ خَلْقِهِ بَتَدْبِيرِهِ ونُفُوذِ القَدَرِ فِيهِم.</p></div>"
  42,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَيۡهِ تَوَكَّلۡتُ﴾</span>: اعتمدت على الله بقلبي في جَلْبِ المنافِعِ ودَفْعِ المضارِّ.</p><p><span class="qpc-hafs">﴿وَإِلَيۡهِ أُنِيبُ﴾</span>: أرْجِعُ إلى اللهِ في جَمِيعِ أُمُوريِ.</p></div>"
  42,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاطِرُ﴾</span>: خالِقُ ومُبْدِعُ.</p><p><span class="qpc-hafs">﴿وَمِنَ ٱلۡأَنۡعَـٰمِ أَزۡوَ ٰ⁠جࣰا﴾</span>: وجَعَلَ مِنَ الأنْعامِ أزْواجًا ذُكُورًا وإناثًا.</p><p><span class="qpc-hafs">﴿يَذۡرَؤُكُمۡ فِيهِ﴾</span>: يُكَثِّرُكُم بسَبِبِ هَذا التَّزاوُجِ بِالتَّوالُدِ نَسْلًا بَعْدَ نسْلٍ.</p><p><span class="qpc-hafs">﴿لَيۡسَ كَمِثۡلِهِۦ شَيۡءࣱ﴾</span>: لا يُماثِلُهُ شَيءٌ مِن مَّخلُوقاتِهِ لا في ذاتِهِ ولا في صِفاتِهِ ولا في أسْمائِهِ ولا في أفْعالِهِ، لانْفِرادِهِ وتَوَحُّدِهِ بِالكَمالِ مِن كُلِّ وجْهٍ.</p><p><span class="qpc-hafs">﴿وَهُوَ ٱلسَّمِيعُ﴾</span>: لجَمِيعِ الأصْواتِ.</p><p><span class="qpc-hafs">﴿ٱلۡبَصِيرُ﴾</span>:: لِأَعْمالِ الخلْقِ لا يَخْفى عَلَيهِ شَيءٌ مِنها.</p></div>"
  42,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقَالِيدُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: مَفاتِيحُ خَزائِنِ السَّمواتِ والأرْضِ.</p><p><span class="qpc-hafs">﴿يَبۡسُطُ﴾</span>: يُوسِّعُ.</p><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: ويُضَيِّقُ.</p></div>"
  42,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَرَعَ﴾</span>: بَيَّنَ ووَضِّحَ.</p><p><span class="qpc-hafs">﴿أَنۡ أَقِيمُواْ ٱلدِّينَ﴾</span>: التَّوحِيدَ.</p><p><span class="qpc-hafs">﴿كَبُرَ﴾</span>: عَظُمَ.</p><p><span class="qpc-hafs">﴿يَجۡتَبِيٓ إِلَيۡهِ﴾</span>: يَصْطَفِي إلى التَّوحِيدِ.</p><p><span class="qpc-hafs">﴿وَيَهۡدِيٓ﴾</span>: ويُوَفِّقُ للعَمَلِ بِطاعَتِهِ.</p><p><span class="qpc-hafs">﴿يُنِيبُ﴾</span>: يَرْجِعُ عَنِ الكُفْرِ ويَحْرِصُ على الخيرِ.</p></div>"
  42,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَغۡيَۢا بَيۡنَهُمۡ﴾</span>: تجاوُزًا للحَدِّ واعْتِداءً مِن بَعْضِهم علىِ بَعْضٍ.</p><p><span class="qpc-hafs">﴿كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾</span>: بتأخِيرِ العذابِ عَنْهُم.</p><p><span class="qpc-hafs">﴿أَجَلࣲ مُّسَمࣰّى﴾</span>: يَومِ القِيامَةِ.</p><p><span class="qpc-hafs">﴿لَّقُضِيَ بَيۡنَهُمۡ﴾</span>: لفُصِلَ بينَهُم بِتَعْجِيلِ عَذابِ الكافِريِنَ مِنهُم في الدُّنيا.</p><p><span class="qpc-hafs">﴿مُرِيبࣲ﴾</span>: مُوقِعٍ في الرِّيَبةِ والاخْتِلافِ المَذْمُومِ.</p></div>"
  42,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلِذَ ٰ⁠لِكَ﴾</span>: فإلى ذَلِك الدِّينِ القيِّمِ.</p><p><span class="qpc-hafs">﴿مِن كِتَـٰبࣲ﴾</span>: مِنَ الكُتُب.</p><p><span class="qpc-hafs">﴿لَا حُجَّةَ﴾</span>: لا خُصُومةَ ولا جِدالَ بَعْدَ تَبَيُّنِ الحقِّ.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المرجِعُ.</p></div>"
  42,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَآجُّونَ﴾</span>: يُجادِلُونَ في دِينِ اللهِ بالإبْطالِ وفِتْنَةِ النّاسِ عَنْهُ.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ مَا ٱسۡتُجِيبَ لَهُۥ﴾</span>: مِن بَعْدِ ما اسْتَجابَ النّاسُ لمحمَّدٍ ﷺ وأَسْلَمُوا.</p><p><span class="qpc-hafs">﴿حُجَّتُهُمۡ دَاحِضَةٌ﴾</span>: مُجادَلَتُهُم باطِلةٌ.</p></div>"
  42,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالصِّدقِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمِيزَانَ﴾</span>: العَدْلَ.</p><p><span class="qpc-hafs">﴿وَمَا يُدۡرِيكَ﴾</span>: وأيَّ شَيءٍ يُعْلِمُكَ؟</p></div>"
  42,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُشۡفِقُونَ مِنۡهَا﴾</span>: خائِفُونَ مِن قِيامِها.</p><p><span class="qpc-hafs">﴿يُمَارُونَ﴾</span>: يُخاصِمُونَ ويُجادِلُونَ.</p></div>"
  42,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَطِيفُۢ بِعِبَادِهِۦ﴾</span>: رَفِيقٌ بالِغُ الرَّأْفةِ بِعبادِهِ المؤْمِنِينَ.</p></div>"
  42,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرۡثَ ٱلۡـَٔاخِرَةِ﴾</span>: عَمَلًا لِأَجْلِ الآخِرةِ.</p><p><span class="qpc-hafs">﴿حَرۡثِهِۦ﴾</span>: عَمَلِهِ الحَسَنِ.</p><p><span class="qpc-hafs">﴿وَمَن كَانَ يُرِيدُ حَرۡثَ ٱلدُّنۡيَا﴾</span>: ومَن كانَ يُريدُ بِعَمَلِهِ الدُّنيا، لا يَسْعى إلا لَها، وهُوَ الكافرُ بالآخِرةِ.</p><p><span class="qpc-hafs">﴿نُؤۡتِهِۦ مِنۡهَا﴾</span>: نُعْطِه مِنَ الدُّنيا ما قَسَمْناهُ له مِن مُّدَةِ حياةٍ وعافِيةٍ ورزْقٍ.</p></div>"
  42,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَرَعُواْ لَهُم﴾</span>: ابْتَدَعُوا لَهُم.</p><p><span class="qpc-hafs">﴿كَلِمَةُ ٱلۡفَصۡلِ﴾</span>: القَضاءُ السّابقُ بأنّ الجَزاءَ يومَ القِيامَةِ.</p><p><span class="qpc-hafs">﴿لَقُضِيَ بَيۡنَهُمۡ﴾</span>: لفُرِغَ مِنَ الحُكْمِ بَينَكُم وبَينَهُم بِتَعْجِيلِ العَذابِ لَهُم في الدُّنيا.</p><p><span class="qpc-hafs">﴿وَإِنَّ ٱلظَّـٰلِمِينَ﴾</span>: وإنَّ الكافِرِينَ باللهِ.</p><p><span class="qpc-hafs">﴿أَلِيمࣱ﴾</span>: مُوجِعٌ.</p></div>"
  42,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: الكافِرينَ.</p><p><span class="qpc-hafs">﴿مُشۡفِقِينَ﴾</span>: خائِفِينَ.</p><p><span class="qpc-hafs">﴿وَهُوَ وَاقِعُۢ بِهِمۡ﴾</span>: والعَذابُ نازلٌ بِهِم.</p><p><span class="qpc-hafs">﴿رَوۡضَاتِ ٱلۡجَنَّاتِ﴾</span>: بَساتِينِ الجَّناتِ، وأنْزَهِها.</p></div>"
  42,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّآ أَسۡـَٔلُكُمۡ عَلَيۡهِ أَجۡرًا﴾</span>: لا أسْأَلُكُم عَلى ما أدْعُوكُم إلَيهِ مِنَ الحقِّ عِوَضًا مِن أمْوالِكُم.</p><p><span class="qpc-hafs">﴿إِلَّا ٱلۡمَوَدَّةَ فِي ٱلۡقُرۡبَىٰ﴾</span>: إلّا أن تَوَدُّوني في قَرابتِي مِنكُم، وتَصِلُوا الرَّحِمَ التِّي بينِي وبَينَكُم.</p><p><span class="qpc-hafs">﴿وَمَن يَقۡتَرِفۡ﴾</span>: ومَن يَكْتَسِبْ.</p><p><span class="qpc-hafs">﴿نَّزِدۡ لَهُۥ فِيهَا حُسۡنًا﴾</span>: نُضاعِفْ لَهُ تِلْكَ الحَسَنَةَ.</p><p><span class="qpc-hafs">﴿غَفُورࣱ﴾</span>: ساتِرٌ عُيُوبَ عِبادِهِ.</p><p><span class="qpc-hafs">﴿شَكُورٌ﴾</span>: كَثِيرُ الشُّكْرِ للمُطِيعِينَ.</p></div>"
  42,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ﴾</span>: بَلْ.</p><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اخْتَلَقَ.</p><p><span class="qpc-hafs">﴿يَخۡتِمۡ﴾</span>: يَطْبَعْ.</p><p><span class="qpc-hafs">﴿وَيَمۡحُ﴾</span>: ويُزِيلُ.</p><p><span class="qpc-hafs">﴿بِكَلِمَـٰتِهِۦٓ﴾</span>: الَّتي لا تَتَبَدَّلُ ولا تَتَغَيَّرُ، وبِوعْدِهِ الصّادِقِ الَّذِي لا يَتَخَلَّفُ.</p><p><span class="qpc-hafs">﴿بِذَاتِ ٱلصُّدُورِ﴾</span>: بِما في قُلُوبِ العبادِ.</p></div>"
  42,25,""
  42,26,""
  42,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَسَطَ﴾</span>: وسَّعَ.</p><p><span class="qpc-hafs">﴿لَبَغَوۡاْ﴾</span>: لَطَغى بَعْضُهُم عَلى بَعْضٍ.</p><p><span class="qpc-hafs">﴿بِقَدَرࣲ﴾</span>: بمِقْدار.</p></div>"
  42,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَيۡثَ﴾</span>: المطرَ.</p><p><span class="qpc-hafs">﴿قَنَطُواْ﴾</span>: يَئِسُوا مِن نُّزُولِهِ.</p><p><span class="qpc-hafs">﴿رَحۡمَتَهُۥ﴾</span>: المطرَ.</p><p><span class="qpc-hafs">﴿ٱلۡوَلِيُّ﴾</span>: الَّذِي يَتَولى عِبادَهُ بإحْسانِهِ وفَضْلِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيدُ﴾</span>: المحْمُودُ.</p></div>"
  42,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَثَّ﴾</span>: نَشَرَ وفَرَّقَ.</p><p><span class="qpc-hafs">﴿دَآبَّةࣲ﴾</span>: اسْم لِكُلِّ ذِي رُوحٍ لا يطِيرُ بِجَناحَيْهِ، لِدَبِيبِهِ عَلى الأرْضِ.</p></div>"
  42,30,""
  42,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُعۡجِزِينَ﴾</span>: بَفائِتِينَ اللهَ.</p><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: يَتَوَلىَّ أُمُورَكُم، فَيُوصِلُ لَكُم المنافِعَ.</p><p><span class="qpc-hafs">﴿نَصِيرࣲ﴾</span>: يَدْفَعُ عَنْكُمُ المضارِّ.</p></div>"
  42,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَوَارِ﴾</span>: السُّفُنُ العَظِيمَةُ الَّتي تَجِري في البَحْرِ.</p><p><span class="qpc-hafs">﴿كَٱلۡأَعۡلَـٰمِ﴾</span>: كالجبالِ.</p></div>"
  42,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَوَاكِدَ﴾</span>: سَواكِنَ لا تَجْرِي.</p></div>"
  42,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُوبِقۡهُنَّ﴾</span>: يُغْرِقْهُنَّ.</p></div>"
  42,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّحِيصࣲ﴾</span>: مَلْجأٍ.</p></div>"
  42,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَتَـٰعُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: فهو مَتاعٌ لَكُم، سرْعانَ ما يَزُولُ.</p></div>"
  42,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡفَوَ ٰ⁠حِشَ﴾</span>: ما فَحُشَ وقَبُحَ مِن أنْواعِ المعاصِي.</p><p><span class="qpc-hafs">﴿يَغۡفِرُونَ﴾</span>: يَصْفَحُونَ عن عُقُوبِة المُسِيءِ إلَيهِم.</p></div>"
  42,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَجَابُواْ لِرَبِّهِمۡ﴾</span>: آمنُوا باللهِ وقَبِلُوا شَرْعَه.</p><p><span class="qpc-hafs">﴿وَأَمۡرُهُمۡ شُورَىٰ بَيۡنَهُمۡ﴾</span>: ويتَشاوَرُونَ في جَمِيعِ أُمُورِهِم ولا يَعْجَلونَ.</p></div>"
  42,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَغۡيُ﴾</span>: الظُّلْمُ.</p><p><span class="qpc-hafs">﴿يَنتَصِرُونَ﴾</span>: يَنْتقِمُونَ مِمَّن ظَلَمَهُم بِمِثْلِ ظُلْمِهِ.</p></div>"
  42,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَزَ ٰ⁠ٓؤُاْ سَيِّئَةࣲ سَيِّئَةࣱ مِّثۡلُهَا﴾</span>: وجَزاءُ سيئةِ المُسِيءِ عُقُوبَتُهُ بِسَيِّئَةٍ مِثْلِها مِن غَيرِ زِيادةٍ.</p></div>"
  42,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبِيلٍ﴾</span>: مُؤاخَذَةٍ.</p></div>"
  42,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَبۡغُونَ﴾</span>: ويَتَجاوَزُونَ الحدَّ الَّذي أُبيحَ لهُم إلى ما لم يُؤذَنْ لَهُم فِيهِ.</p><p><span class="qpc-hafs">﴿أَلِيمࣱ﴾</span>: مُوجِعٌ.</p></div>"
  42,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَغَفَرَ﴾</span>: قابَلَ الإساءَةَ بالعَفْوِ.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: الصَّبْرَ والمغْفِرَةَ.</p><p><span class="qpc-hafs">﴿عَزۡمِ ٱلۡأُمُورِ﴾</span>: مُحْكَمِها ومُتْقَنِها الَّذِي تُحْمَدُ عاقِبَتُهُ.</p></div>"
  42,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: ناصرٍ يَهْديِهِ سَبِيلَ الرَّشادِ.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: الكافِرِينَ باللهِ.</p><p><span class="qpc-hafs">﴿مَرَدࣲّ﴾</span>: رُجُوعٍ إلى الدُّنيا؛ لِنَسْتَدِركَ الإيمانَ والعَمَلَ الصّالِحَ.</p></div>"
  42,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعِينَ مِنَ ٱلذُّلِّ﴾</span>: خاضِعِينَ بِسَبَبِ الذُّلِّ.</p><p><span class="qpc-hafs">﴿طَرۡفٍ خَفِيࣲّ﴾</span>: عَيْنٍ ذَلِيلةٍ مِنَ الخَوْفِ والهَوانِ.</p><p><span class="qpc-hafs">﴿مُّقِيمࣲ﴾</span>: دائِمٍ.</p></div>"
  42,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أعْوانٍ ونُصَراءَ.</p><p><span class="qpc-hafs">﴿يَنصُرُونَهُم﴾</span>: يَمْنَعُونَهُم مِن عَذابِ اللهِ.</p><p><span class="qpc-hafs">﴿وَمَن يُضۡلِلِ ٱللَّهُ﴾</span>: ومَن يَخْذُلْه اللهُ عَن طَرِيقِ الحقِّ.</p><p><span class="qpc-hafs">﴿سَبِيلٍ﴾</span>: طَرِيقٍ يَصِل بِهِ إلى الحقِّ والنَّجاةِ.</p></div>"
  42,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَجِيبُواْ لِرَبِّكُم﴾</span>: أجِيبُوا داعيَ اللهِ وآمِنُوا بِه.</p><p><span class="qpc-hafs">﴿لَّا مَرَدَّ لَهُۥ﴾</span>: لا شَيءَ يَرُدُّ مَجِيئَهُ إذا جاء اللهُ بِهِ.</p><p><span class="qpc-hafs">﴿مَّلۡجَإࣲ﴾</span>: مَعْقِل تَحْتَرِزُونَ فِيهِ مِن عَذابِ اللهِ.</p><p><span class="qpc-hafs">﴿نَّكِيرࣲ﴾</span>: إنْكارٍ وتَغْيِيرٍ.</p></div>"
  42,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَحۡمَةࣰ﴾</span>: غِنىً وسَعةً وغَيرَ ذَلِكَ.</p><p><span class="qpc-hafs">﴿سَيِّئَةُۢ﴾</span>: مُصِيَبةٌ تَسُوءُهُم في أجْسادِهِم أوْ نُفُوسِهِم.</p><p><span class="qpc-hafs">﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾</span>: بما أسْلفَتْ مِنَ المعاصِي.</p><p><span class="qpc-hafs">﴿كَفُورࣱ﴾</span>: جَحُودٌ نِعَمَ رَبِّه لا يَذْكُرُ إلا المصائِبَ.</p></div>"
  42,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهَبُ﴾</span>: يُعْطِي.</p></div>"
  42,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُزَوِّجُهُمۡ﴾</span>: يُنَوِّعُهُم.</p><p><span class="qpc-hafs">﴿عَقِيمًا﴾</span>: لا يُولَدُ له.</p></div>"
  42,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلِيٌّ﴾</span>: عالٍ بِذاتِه وأسْمائِهِ وصِفاتِه وأفعالِه.</p></div>"
  42,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُوحࣰا﴾</span>: قُرآنًا.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبُ﴾</span>: الكُتُبُ السّابِقَةُ.</p><p><span class="qpc-hafs">﴿لَتَهۡدِيٓ﴾</span>: لَتَدُلُّ وتُرْشِدُ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: هُوَ الإسْلامُ.</p></div>"
  42,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَصِيرُ﴾</span>: تَرْجِعُ.</p></div>"
