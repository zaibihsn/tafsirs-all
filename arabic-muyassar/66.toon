quran[12]{c,v,t}:
  66,1,""
  66,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَحِلَّةَ أَيۡمَـٰنِكُمۡ﴾</span>: تَحْلِيلَ قَسَمِكُم بأَداءِ الكَفّارَةِ عَنْها، وهي إطْعامُ عَشْرَةِ مَساكِينَ أوْ كِسْوتُهُم أو تَحْرِيرُ رَقَبَةٍ، فَمَن لَمْ يَجِدْ فَصِيامُ ثَلاثَةِ أيّامٍ.</p><p><span class="qpc-hafs">﴿مَوۡلَىٰكُمۡ﴾</span>: ناصِرُكُم ومُتَوَلّي أُمُورِكُم.</p></div>"
  66,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَظۡهَرَهُ ٱللَّهُ﴾</span>: وأَطْلَعَهُ اللهُ عَلى إفْشائِها سِرَّهُ.</p><p><span class="qpc-hafs">﴿عَرَّفَ بَعۡضَهُۥ﴾</span>: أعْلَمَ حَفْصَةَ بَعْضَ ما أخْبرَتْ بِهِ.</p></div>"
  66,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَغَتۡ﴾</span>: مالَتْ.</p><p><span class="qpc-hafs">﴿وَإِن تَظَـٰهَرَا عَلَيۡهِ﴾</span>: وإن تَعاوَنا عَلَيهِ بِما يَسُوءُهُ.</p><p><span class="qpc-hafs">﴿مَوۡلَىٰهُ﴾</span>: وليُّهُ وناصِرُهُ.</p><p><span class="qpc-hafs">﴿ظَهِيرٌ﴾</span>: أعْوانٌ لَهُ عَلى مَن يُعادُونَهُ.</p></div>"
  66,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسۡلِمَـٰتࣲ﴾</span>: خاضِعاتٍ للهِ بالطّاعةِ.</p><p><span class="qpc-hafs">﴿قَـٰنِتَـٰتࣲ﴾</span>: مُطِيعاتٍ للهِ.</p><p><span class="qpc-hafs">﴿سَـٰٓئِحَـٰتࣲ﴾</span>: صائِماتٍ.</p></div>"
  66,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُوٓاْ﴾</span>: احْفَظُوا.</p><p><span class="qpc-hafs">﴿لَّا يَعۡصُونَ﴾</span>: لا يخالِفُونَ.</p></div>"
  66,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَعۡتَذِرُواْ﴾</span>: لا تْلتَمِسُوا الأَعْذارَ.</p></div>"
  66,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُوبُوٓاْ﴾</span>: ارْجِعُوا عَن ذُنُوبِكُم.</p><p><span class="qpc-hafs">﴿تَوۡبَةࣰ نَّصُوحًا﴾</span>: رُجُوعًا لا مَعْصِيَةَ بَعْدَهُ.</p><p><span class="qpc-hafs">﴿عَسَىٰ رَبُّكُمۡ﴾</span>: يَتَحَقَّقُ رَجاؤُكُم بِوَعْدِ ربِّكُم.</p><p><span class="qpc-hafs">﴿يُكَفِّرَ﴾</span>: يَمْحُوَ.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: من تَحْتِ قُصُورِها وأَشْجارِها.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: لا يَلْحِقُ بِهِم هَوانًا وذُلًّا بِسَبَبِ العَذابِ، بَلْ يُعْلي شَأْنَهُم.</p><p><span class="qpc-hafs">﴿يَسۡعَىٰ﴾</span>: يسِيرُ.</p><p><span class="qpc-hafs">﴿بَيۡنَ أَيۡدِيهِمۡ﴾</span>: أمامَهُم.</p><p><span class="qpc-hafs">﴿أَتۡمِمۡ﴾</span>: أدِمْ، أو زِدْ.</p></div>"
  66,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱغۡلُظۡ عَلَيۡهِمۡ﴾</span>: واسْتَعْمِلْ مَعَهُم الشِّدَّةَ في جِهادِهِم.</p><p><span class="qpc-hafs">﴿وَمَأۡوَىٰهُمۡ﴾</span>: ومَسْكَنُهُم الَّذِي يصيرُونَ إلَيهِ في الآخِرَةِ.</p><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: وقَبُحَ ذَلِكَ المَرْجِعُ الَّذِي يَرْجِعُونَ إلَيهِ.</p></div>"
  66,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَخَانَتَاهُمَا﴾</span>: أي في الدِّين بالكُفْرِ.</p><p><span class="qpc-hafs">﴿فَلَمۡ يُغۡنِيَا﴾</span>: فَلَمْ يَدْفَعا.</p></div>"
  66,11,""
  66,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡصَنَتۡ﴾</span>: حَفِظَتْ.</p><p><span class="qpc-hafs">﴿فَنَفَخۡنَا﴾</span>: أمَرْنا جِبْرِيلَ أن يَنْفُخَ في جَيْبِ قَمِيصِها.</p><p><span class="qpc-hafs">﴿ٱلۡقَـٰنِتِينَ﴾</span>: المُطِيعِينَ للهِ.</p></div>"
