quran[64]{c,v,t}:
  24,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَرَضۡنَـٰهَا﴾</span>: أوْجَبْنا أحْكامَ هذه السُّورةِ عَلَيكُم.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِۭ بَيِّنَـٰتࣲ﴾</span>: دَلالاتٍ واضِحاتٍ.</p></div>"
  24,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱجۡلِدُواْ﴾</span>: فاضربُوا بالسَّوطِ.</p><p><span class="qpc-hafs">﴿رَأۡفَةࣱ﴾</span>: رَحْمَةٌ ورِقَّةٌ.</p><p><span class="qpc-hafs">﴿وَلۡيَشۡهَدۡ﴾</span>: ولْيَحْضُرْ.</p></div>"
  24,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحُرِّمَ ذَ ٰ⁠لِكَ﴾</span>: أي: نكاحُ الزِّانِيةِ حتى تَتَوْبَ أوْ حُرِّم الزِّنى نَفْسُه.</p></div>"
  24,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡمُونَ﴾</span>: يَقْذِفُونَ بالزِّنى.</p><p><span class="qpc-hafs">﴿ٱلۡمُحۡصَنَـٰتِ﴾</span>: النِّساءَ الحرائِرَ العَفِيفاتِ، وكذلك الرِّجالُ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارِجُونَ عَن طاعَةِ اللهِ.</p></div>"
  24,5,""
  24,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡمُونَ أَزۡوَ ٰ⁠جَهُمۡ﴾</span>: يَقْذِفُونَ زَوْجاتِهم بالزِّنى.</p><p><span class="qpc-hafs">﴿لَمِنَ ٱلصَّـٰدِقِينَ﴾</span>: أي: في قَذْفِه زَوْجَتَه بالزِّنى.</p></div>"
  24,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡخَـٰمِسَةُ﴾</span>: أي: الشَّهادَةُ الخامِسَةُ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡكَـٰذِبِينَ﴾</span>: أي: في قَذْفِه زَوْجتَه بالزِّنى.</p></div>"
  24,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَدۡرَؤُاْ عَنۡهَا﴾</span>: ويَدْفَعُ عَنِ الزَّوجَةِ المَقْذُوفَةِ.</p></div>"
  24,9,""
  24,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَّابٌ﴾</span>: كثِيرُ القَبُولِ لِتَوْبَةِ مَن تابَ إليهِ مِن عِبادِهِ.</p><p><span class="qpc-hafs">﴿حَكِيمٌ﴾</span>: أي: في شَرائِعِه وأَحْكامِه، فلم يُنْزِلْ بالكاذِبِ مِن المتَلاعِنَينِ ما دَعا به على نَفْسِه.</p></div>"
  24,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡإِفۡكِ﴾</span>: أقْبحِ الكَذِبِ وأفْحَشِه، وهو اتِّهامُ أمِّ المؤمنينَ عائِشَةَ رضي اللهُ عَنَها بالفاحِشةِ.</p><p><span class="qpc-hafs">﴿عُصۡبَةࣱ مِّنكُمۡ﴾</span>: جَماعةٌ مُنْتَسِبُونَ إليكُم.</p><p><span class="qpc-hafs">﴿مَّا ٱكۡتَسَبَ﴾</span>: جَزاءُ ما ارْتَكَبَ.</p><p><span class="qpc-hafs">﴿تَوَلَّىٰ كِبۡرَهُۥ﴾</span>: تَحَمَّلَ مُعْظَمَ الإفْكِ، وهو عبدُ اللهِ بنُ أُبيِّ بنِ سَلُولٍ كبيرُ المنافِقِيِنَ.</p></div>"
  24,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّوۡلَآ﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿إِفۡكࣱ مُّبِينࣱ﴾</span>: بُهْتانٌ واضِحٌ.</p></div>"
  24,13,""
  24,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَسَّكُمۡ﴾</span>: لَأصابَكُم.</p><p><span class="qpc-hafs">﴿فِي مَآ أَفَضۡتُمۡ فِيهِ﴾</span>: بِسَبَبِ ماخُضْتُم فيه مِن حَدِيثِ الإفْكِ.</p></div>"
  24,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذۡ تَلَقَّوۡنَهُۥ﴾</span>: حِينَ تَتَلَقَّفُونَ حَدِيثَ الإفْكِ وتَتَناقَلُونَه.</p><p><span class="qpc-hafs">﴿وَتَحۡسَبُونَهُۥ هَيِّنࣰا﴾</span>: وتَظُنُّونَ تَلَقِّيَ الإفْكِ شَيئًا سَهْلًا لا يَلْحَقُكُم فيه إثْمٌ.</p></div>"
  24,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يَكُونُ لَنَآ﴾</span>: ما يَحِلُّ لَنا ولا يَنْبَغِي.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَكَ﴾</span>: تَنْزِيهًا لكَ يا رَبِّ.</p><p><span class="qpc-hafs">﴿بُهۡتَـٰنٌ﴾</span>: افْتِراءٌ وكَذِبٌ.</p></div>"
  24,17,""
  24,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: آياتِ القرآنِ المشْتَمِلَةَ على الأحْكامِ والمَواعِظِ.</p></div>"
  24,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَشِيعَ﴾</span>: تَنْتَشِرَ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰحِشَةُ﴾</span>: الزِّنى وكلُّ قولٍ سيِّئٍ.</p></div>"
  24,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوۡلَا فَضۡلُ ٱللَّهِ﴾</span>: أي: لولا فَضْلُ اللهِ لَعاجَلَ مَن خالَفَ أمْرَه بالعُقُوبَةِ.</p><p><span class="qpc-hafs">﴿رَءُوفࣱ﴾</span>: كَثِيرُ الرَّأْفَةِ والمَحَبَّةِ لِعِبادِه.</p><p><span class="qpc-hafs">﴿رَّحِيمࣱ﴾</span>: بِعِبادِه فَيَتَقَدَّمُ إلَيِهم بِمِثْلِ هذا الإعْذارِ والإنْذارِ.</p></div>"
  24,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾</span>: طُرُقَه وآثارَه.</p><p><span class="qpc-hafs">﴿بِٱلۡفَحۡشَآءِ﴾</span>: ما عَظُمَ قُبْحُه مِنَ الذُّنوب.</p><p><span class="qpc-hafs">﴿وَٱلۡمُنكَرِ﴾</span>: ما يُنْكِرُه الشَّرعُ أو يَكرَهُه.</p><p><span class="qpc-hafs">﴿مَا زَكَىٰ﴾</span>: ما طَهُرَ، ولا تَطَهَّرَ مِن دَنَسِ الذُّنُوبِ</p><p><span class="qpc-hafs">﴿يُزَكِّي﴾</span>: يُطَهِّرُ.</p></div>"
  24,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَأۡتَلِ﴾</span>: ولا يَحْلِفْ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡفَضۡلِ﴾</span>: أصْحابُ الفَضَلِ في الدِّينِ.</p><p><span class="qpc-hafs">﴿وَٱلسَّعَةِ﴾</span>: الغِنى في المالِ.</p><p><span class="qpc-hafs">﴿أَن يُؤۡتُوٓاْ﴾</span>: أي: يَحْلِفُونَ على ألّا يُعْطُوا.</p><p><span class="qpc-hafs">﴿أُوْلِي ٱلۡقُرۡبَىٰ﴾</span>: أصْحابَ القَرابَةِ.</p><p><span class="qpc-hafs">﴿وَلۡيَعۡفُواْ﴾</span>: أي: ولْيَتَجاوزُوا عَن ذَنْبِهِم وإساءَتِهِم.</p><p><span class="qpc-hafs">﴿وَلۡيَصۡفَحُوٓاْ﴾</span>: أي: بالإعْراضِ عَن مُّؤاخَذَتِهِم.</p></div>"
  24,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡمُونَ﴾</span>: يَقْذِفُون بالزِّنى.</p><p><span class="qpc-hafs">﴿ٱلۡمُحۡصَنَـٰتِ﴾</span>: العفِيفاتِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَـٰفِلَـٰتِ﴾</span>: اللّاتي لا تَخْطُرُ بِبالِهنَّ الفاحِشَةُ.</p></div>"
  24,24,""
  24,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دِينَهُمُ ٱلۡحَقَّ﴾</span>: جَزاءَهم الثّابِتَ لهم بالعَدْلِ.</p></div>"
  24,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِمَّا يَقُولُونَ﴾</span>: أي: مِنِ اتِّهامِهِم.</p></div>"
  24,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَتَّىٰ تَسۡتَأۡنِسُواْ﴾</span>: حتى تَسْتأذِنُوا.</p></div>"
  24,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ أَزۡكَىٰ لَكُمۡ﴾</span>: الرُّجُوعُ أْطَهرُ لكُم.</p></div>"
  24,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُنَاحٌ﴾</span>: حَرَجٌ.</p><p><span class="qpc-hafs">﴿غَيۡرَ مَسۡكُونَةࣲ﴾</span>: ليسَتْ مُخَصَّصَةً لِسَكَنِ أُناسٍ مُعَيَّنِينَ كالفَنادِقِ والمساجِدِ.</p><p><span class="qpc-hafs">﴿مَتَـٰعࣱ لَّكُمۡ﴾</span>: مَنفَعَةٌ ومَصْلَحَةٌ لكُم.</p></div>"
  24,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغُضُّواْ مِنۡ أَبۡصَـٰرِهِمۡ﴾</span>: يَخْفِضُوا نَظَرَهُم إلى المُحَرَّماتِ.</p><p><span class="qpc-hafs">﴿أَزۡكَىٰ﴾</span>: أطَهرُ.</p></div>"
  24,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُبۡدِينَ﴾</span>: ولا يُظْهِرْنَ.</p><p><span class="qpc-hafs">﴿زِينَتَهُنَّ﴾</span>: مواضِعَ زينَتِهنَّ مِنَ الجَسَدِ.</p><p><span class="qpc-hafs">﴿إِلَّا مَا ظَهَرَ مِنۡهَا﴾</span>: مِنَ الثِّيابِ الظّاهِرَةِ التي جَرَتِ العادَةُ بِلُبسِها.</p><p><span class="qpc-hafs">﴿عَلَىٰ جُيُوبِهِنَّ﴾</span>: أي: على فَتَحات ثِيابِهِنَّ مِن جِهَةِ صُدُورِهِنَّ.</p><p><span class="qpc-hafs">﴿لِبُعُولَتِهِنَّ﴾</span>: لأزْواجِهِنَّ.</p><p><span class="qpc-hafs">﴿أَوۡ نِسَآئِهِنَّ﴾</span>: مِنَ المسْلِماتِ المخْتَصّاتِ بهِنَّ بالصُّحْبَةِ أو الخِدْمَةِ.</p><p><span class="qpc-hafs">﴿مَا مَلَكَتۡ أَيۡمَـٰنُهُنَّ﴾</span>: أي: مِنَ العَبِيدِ والإماءِ.</p><p><span class="qpc-hafs">﴿غَيۡرِ أُوْلِي ٱلۡإِرۡبَةِ﴾</span>: الَّذينَ لا حاجةَ لهم في النِّساءِ.</p><p><span class="qpc-hafs">﴿أَوِ ٱلطِّفۡلِ﴾</span>: أي: الأطْفالِ.</p><p><span class="qpc-hafs">﴿لَمۡ يَظۡهَرُواْ﴾</span>: لم يَطَّلِعُوا ولم يَبْلُغُوا حَدَّ الشَّهْوةِ.</p></div>"
  24,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَيَـٰمَىٰ﴾</span>: الَّذينَ لا أزْواجَ لَهُم مِنَ الأحْرارِ والحرائِر.</p></div>"
  24,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلۡيَسۡتَعۡفِفِ﴾</span>: ولْيطْلُب العِفَّةَ عَنِ الزِّنى والحَرامِ.</p><p><span class="qpc-hafs">﴿لَا يَجِدُونَ نِكَاحًا﴾</span>: أي: لا يَجِدُونَ قُدْرَةً مالِيَّةً على النِّكاحِ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: أي: المُكاتَبَةَ، وهي أن يكاتِبَ الرَّجلُ عبدَه على مالٍ يُؤَدِّيهِ مُنَجَّمًا، فإذا أدّاه فهو حُرٌّ.</p><p><span class="qpc-hafs">﴿مِمَّا مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾</span>: مِن عَبيدِكُم وإمائِكُم.</p><p><span class="qpc-hafs">﴿فَكَاتِبُوهُمۡ﴾</span>: أي: فاكْتُبُوا مَعَهُم عَقْدَ مُكاتَبَةٍ.</p><p><span class="qpc-hafs">﴿فَتَيَـٰتِكُمۡ﴾</span>: إماءَكُم وجَوارِيَكُم.</p><p><span class="qpc-hafs">﴿ٱلۡبِغَآءِ﴾</span>: الزِّنى.</p><p><span class="qpc-hafs">﴿تَحَصُّنࣰا﴾</span>: تَعَفُّفًا.</p><p><span class="qpc-hafs">﴿غَفُورࣱ رَّحِيمࣱ﴾</span>: أي: لمن أُكرِهَتْ على الزِّنى، وبَقِيَ الإثْمُ على مَن أكْرَهَها.</p></div>"
  24,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتࣲ مُّبَيِّنَـٰتࣲ﴾</span>: آياتِ القرآنِ المفصَّلاتِ.</p><p><span class="qpc-hafs">﴿خَلَوۡاْ﴾</span>: مَضَوا.</p></div>"
  24,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمِشۡكَوٰةࣲ﴾</span>: الِمشْكاةُ: الكَوَّة في الحائِطِ غيرُ النّافِذَةِ.</p><p><span class="qpc-hafs">﴿مِصۡبَاحٌ﴾</span>: سِراجٌ.</p><p><span class="qpc-hafs">﴿زُجَاجَةٍ﴾</span>: قِنْدِيلٍ مِنَ الزُّجاجِ صافٍ أزْهَرَ.</p><p><span class="qpc-hafs">﴿كَوۡكَبࣱ دُرِّيࣱّ﴾</span>: نَجْمٌ مُضِيءٌ كالدُّرِّ في صَفائِه وإشْراقِه.</p><p><span class="qpc-hafs">﴿لَّا شَرۡقِيَّةࣲ وَلَا غَرۡبِيَّةࣲ﴾</span>: أي: بَلْ هِيَ في موقِعٍ مُتَوَسِّطٍ بينَ الشَّرقِ والغَرْبِ، فَتَتَعَرَّضُ للشَّمسِ طوالَ النَّهارِ.</p></div>"
  24,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُيُوتٍ﴾</span>: مَساجِدَ.</p><p><span class="qpc-hafs">﴿أَذِنَ﴾</span>: أمَرَ وقَضى.</p><p><span class="qpc-hafs">﴿تُرۡفَعَ﴾</span>: تُبْنىَ وتُعَظَّمَ.</p><p><span class="qpc-hafs">﴿بِٱلۡغُدُوِّ وَٱلۡـَٔاصَالِ﴾</span>: أوَّلِ النَّهار وآخِرِه.</p></div>"
  24,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا تُلۡهِيهِمۡ﴾</span>: لا تشْغَلُهُم.</p><p><span class="qpc-hafs">﴿تَتَقَلَّبُ﴾</span>: تَضْطَربُ وتَتَحَوَّلُ.</p></div>"
  24,38,""
  24,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَسَرَابِۭ﴾</span>: السَّرابُ: ما يُرى ظُهرًا في المفاوِزِ من لَمَعانِ الشَّمْسِ عِنْدَ اشْتِدادِ الحرِّ، يَظُنُّه العَطْشانُ ماءً.</p><p><span class="qpc-hafs">﴿بِقِيعَةࣲ﴾</span>: جَمْعِ «قاعٍ» وهو المستَوي مِنَ الأرضِ.</p></div>"
  24,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لُّجِّيࣲّ﴾</span>: عَمِيقٍ كَثِيرِ الماءِ.</p><p><span class="qpc-hafs">﴿يَغۡشَىٰهُ﴾</span>: يَعْلوُ ويُغَطِّي.</p><p><span class="qpc-hafs">﴿يَدَهُۥ لَمۡ يَكَدۡ يَرَىٰهَا﴾</span>: لم يُقارِبْ رُؤيتَها مِن شِدَّةِ الظُّلُماتِ.</p></div>"
  24,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَـٰٓفَّـٰتࣲ﴾</span>: باسِطاتٍ أجْنِحَتَها في الهَواءِ.</p><p><span class="qpc-hafs">﴿صَلَاتَهُۥ﴾</span>: أي: المُصَلِّي مِنهُم عَلِم صَلاتَه.</p><p><span class="qpc-hafs">﴿وَتَسۡبِيحَهُۥ﴾</span>: أي: المُسَبِّحُ مِنهم عَلِمَ تَسْبِيحَهُ.</p></div>"
  24,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ بعد الموتِ.</p></div>"
  24,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُزۡجِي﴾</span>: يَسُوقُ بِرِفْقٍ.</p><p><span class="qpc-hafs">﴿يُؤَلِّفُ﴾</span>: يَجْمَعُ.</p><p><span class="qpc-hafs">﴿رُكَامࣰا﴾</span>: مُجْتَمِعًا ومُتَراكِمًا بَعْضُهَ فَوْقَ بَعْضٍ.</p><p><span class="qpc-hafs">﴿ٱلۡوَدۡقَ﴾</span>: المَطَرَ.</p><p><span class="qpc-hafs">﴿مِنۡ خِلَـٰلِهِۦ﴾</span>: مِن مَّخارِجِ السَّحابِ.</p><p><span class="qpc-hafs">﴿مِن جِبَالࣲ﴾</span>: أي: مِثلِ جبالٍ في عَظَمَتِه.</p><p><span class="qpc-hafs">﴿سَنَا بَرۡقِهِۦ﴾</span>: ضَوءُ بَرْقِه ولمَعانُه.</p></div>"
  24,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلۡأَبۡصَـٰرِ﴾</span>: لأصْحابِ العُقُولِ السَّلِيمةِ.</p></div>"
  24,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ بَطۡنِهِۦ﴾</span>: كالحيّاتِ ونحوِها.</p><p><span class="qpc-hafs">﴿عَلَىٰ رِجۡلَيۡنِ﴾</span>: كالإنْسانِ.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ أَرۡبَعࣲ﴾</span>: كالبهائِمِ ونحوِها.</p></div>"
  24,46,""
  24,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَلَّىٰ﴾</span>: يُعرِضُ.</p></div>"
  24,48,""
  24,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهُمُ ٱلۡحَقُّ﴾</span>: أي: في قَضاءِ النَّبيِّ ﷺ وحُكْمِهِ.</p><p><span class="qpc-hafs">﴿مُذۡعِنِينَ﴾</span>: مُسْرِعِينَ مُنْقادِينَ.</p></div>"
  24,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرَضٌ﴾</span>: أي: مِنَ النِّفاقِ.</p><p><span class="qpc-hafs">﴿ٱرۡتَابُوٓاْ﴾</span>: شَكُّوا.</p><p><span class="qpc-hafs">﴿أَن يَحِيفَ﴾</span>: أن يَجُورَ.</p></div>"
  24,51,""
  24,52,""
  24,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: أي: بأَيمانٍ مُغَلَّظَةٍ.</p><p><span class="qpc-hafs">﴿لَيَخۡرُجُنَّ﴾</span>: أي: لِلْجِهادِ.</p></div>"
  24,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِن تَوَلَّوۡاْ﴾</span>: فَإن تُعْرِضُوا.</p><p><span class="qpc-hafs">﴿مَا حُمِّلَ﴾</span>: ما أُمِرَ به مِن تَبْلِيغِ الرِّسالَةِ.</p><p><span class="qpc-hafs">﴿مَّا حُمِّلۡتُمۡ﴾</span>: ما أُمِرْتُم بِه مِنَ الطّاعةِ والانْقِيادِ.</p><p><span class="qpc-hafs">﴿ٱلۡبَلَـٰغُ ٱلۡمُبِينُ﴾</span>: التَّبْلِيغُ الواضِحُ.</p></div>"
  24,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَسۡتَخۡلِفَنَّهُمۡ﴾</span>: أي: لَيَجْعَلَنَّهم خُلَفاءَ.</p><p><span class="qpc-hafs">﴿وَلَيُمَكِّنَنَّ لَهُمۡ﴾</span>: ولَيُثَبِّتَنَّ لَهُم.</p><p><span class="qpc-hafs">﴿دِينَهُمُ﴾</span>: وهو دينُ الإسلامِ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارِجُونَ عَن طاعَةِ اللهِ.</p></div>"
  24,56,""
  24,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعۡجِزِينَ﴾</span>: فائتِينَ مِن عَذابِ اللهِ.</p><p><span class="qpc-hafs">﴿وَمَأۡوَىٰهُمُ﴾</span>: ومَرْجِعُهُم.</p><p><span class="qpc-hafs">﴿وَلَبِئۡسَ﴾</span>: وقَبُحَ.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المرجِعُ.</p></div>"
  24,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾</span>: هُمُ العبيدُ والإماءُ.</p><p><span class="qpc-hafs">﴿ٱلۡحُلُمَ﴾</span>: أي: سِنَّ الاحْتِلامِ.</p><p><span class="qpc-hafs">﴿ثَلَـٰثُ عَوۡرَ ٰ⁠تࣲ لَّكُمۡ﴾</span>: أي: ثلاثةُ أوقاتٍ يَخْتَلُّ فيها السِّتْرُ ويَقِلُّ.</p><p><span class="qpc-hafs">﴿جُنَاحُۢ﴾</span>: حَرَجٌ.</p><p><span class="qpc-hafs">﴿طَوَّ ٰ⁠فُونَ﴾</span>: أي: كَثِيرُو التَّطْوافِ والتَّردُّدِ عَلَيكُم لِلْخِدْمَةِ وقَضاءِ المصالِحِ.</p><p><span class="qpc-hafs">﴿يُبَيِّنُ﴾</span>: يُوضِّحُ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: أي: آياتِ القُرآنِ الدّالَّةَ على الأحْكامِ.</p></div>"
  24,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُلُمَ﴾</span>: سِنَّ الاحْتِلامِ والبُلُوغِ.</p></div>"
  24,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡقَوَ ٰ⁠عِدُ مِنَ ٱلنِّسَآءِ﴾</span>: العَجائِزُ اللّاتي قَعَدْنَ عَنِ الحَيضِ والاسْتِمْتاعِ لِكِبَرِهِنَّ.</p><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ نِكَاحࣰا﴾</span>: لا يَطْمَعْنَ فيه.</p><p><span class="qpc-hafs">﴿مُتَبَرِّجَـٰتِۭ﴾</span>: مُظْهِراتٍ.</p><p><span class="qpc-hafs">﴿وَأَن يَسۡتَعۡفِفۡنَ﴾</span>: وأن يَتْرُكْنَ وضْعَ الثِّيابِ لِطَلَبِ العِفَّةِ.</p></div>"
  24,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَجࣱ﴾</span>: إثْمٌ.</p><p><span class="qpc-hafs">﴿أَوۡ مَا مَلَكۡتُم مَّفَاتِحَهُۥٓ﴾</span>: أي: البُيوتِ الَّتي تَمْلِكُونَ التَّصرُّفَ فِيها بإذِنِ أرْبابِها.</p><p><span class="qpc-hafs">﴿أَشۡتَاتࣰا﴾</span>: مُتَفَرِّقِينَ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: أي: آياتِ القرآنِ الدّالَّةَ على الأحْكامِ.</p></div>"
  24,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡرࣲ جَامِعࣲ﴾</span>: أمرٍ مُهِمٍّ يَجِبُ اجْتِماعُهُم لَهُ.</p><p><span class="qpc-hafs">﴿لِبَعۡضِ شَأۡنِهِمۡ﴾</span>: أي: لِبَعْضِ أُمُورِهِم.</p></div>"
  24,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دُعَآءَ ٱلرَّسُولِ﴾</span>: دَعْوتَهُ لَكُم لِلاجْتِماعِ، أو نِداءَكُم لَهُ ﷺ.</p><p><span class="qpc-hafs">﴿يَتَسَلَّلُونَ﴾</span>: يَخْرُجُونَ خِفْيةً مِن غِيرِ إذْنٍ.</p><p><span class="qpc-hafs">﴿لِوَاذࣰا﴾</span>: أي: مُسْتَترِينَ بعضُهم بِبَعْضٍ عنْدَ الخُروجِ.</p><p><span class="qpc-hafs">﴿فِتۡنَةٌ﴾</span>: بَلاءٌ ومِحْنَةٌ في الدُّنْيا.</p></div>"
  24,64,""
