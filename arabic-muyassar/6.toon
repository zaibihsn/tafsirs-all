quran[165]{c,v,t}:
  6,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلَ ٱلظُّلُمَـٰتِ وَٱلنُّورَ﴾</span>: وخَلَقَ سَوادَ الليلِ، وضياءَ النهارِ.</p><p><span class="qpc-hafs">﴿يَعۡدِلُونَ﴾</span>: يُشْرِكُون.</p></div>"
  6,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَقَكُم﴾</span>: خَلَقَ أباكم آدمَ.</p><p><span class="qpc-hafs">﴿قَضَىٰٓ أَجَلࣰا﴾</span>: قَدَّر مُدَّةَ بقائِكم في الدنيا.</p><p><span class="qpc-hafs">﴿وَأَجَلࣱ مُّسَمًّى عِندَهُۥ﴾</span>: وقَدَّر أجلًا محدَّدًا هو يومُ القِيامةِ.</p><p><span class="qpc-hafs">﴿تَمۡتَرُونَ﴾</span>: تَشُكُّون في أمرِ الساعةِ.</p></div>"
  6,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِرَّكُمۡ وَجَهۡرَكُمۡ﴾</span>: ما تُخْفُونه، وما تُعْلِنُونه.</p><p><span class="qpc-hafs">﴿مَا تَكۡسِبُونَ﴾</span>: جميعَ أعمالِكم.</p></div>"
  6,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ ءَايَةࣲ﴾</span>: من دليلٍ على أنّ اللهَ حقُّ.</p></div>"
  6,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۢبَـٰٓؤُاْ مَا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾</span>: أخبارُ ما استَهْزَؤُوا به، وهو القرآنُ، أو محمدٌ ﷺ.</p></div>"
  6,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قَرۡنࣲ﴾</span>: من أمةٍ مُكَذِّبَةٍ.</p><p><span class="qpc-hafs">﴿مَا لَمۡ نُمَكِّن لَّكُمۡ﴾</span>: ما لم نُعْطِكم، كطُولِ الأعمارِ، وقوةِ الأبدانِ.</p><p><span class="qpc-hafs">﴿مِّدۡرَارࣰا﴾</span>: مطرًا كثيرًا.</p><p><span class="qpc-hafs">﴿قَرۡنًا ءَاخَرِينَ﴾</span>: أممًا أخرى.</p></div>"
  6,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبࣰا فِي قِرۡطَاسࣲ﴾</span>: كتابًا مكتوبًا في صحيفةٍ.</p></div>"
  6,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلَكࣰا﴾</span>: أي: لِيُصَدِّقَه، ويُنْذِرَ معه.</p><p><span class="qpc-hafs">﴿لَّقُضِيَ ٱلۡأَمۡرُ﴾</span>: بإهلاكِهم، والمعاجَلَةِ بعقوبتِهم.</p><p><span class="qpc-hafs">﴿لَا يُنظَرُونَ﴾</span>: لا يُمْهَلُون للتوبةِ.</p></div>"
  6,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوۡ جَعَلۡنَـٰهُ﴾</span>: ولو جَعَلْنا الرسولَ المُرْسَلَ إلى النبيِّ ﷺ.</p><p><span class="qpc-hafs">﴿وَلَلَبَسۡنَا عَلَيۡهِم مَّا يَلۡبِسُونَ﴾</span>: ولَكان الأمرُ مختلِطًا عليهم بسببِ ما لَبَسُوه على أنفسِهم.</p></div>"
  6,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَاقَ﴾</span>: فَنَزَل وأحاطَ.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾</span>: هو العذابُ الذي كانوا يستنكرونه.</p></div>"
  6,11,""
  6,12,""
  6,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا سَكَنَ﴾</span>: ما استقرَّ.</p></div>"
  6,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيࣰّا﴾</span>: مَعْبُودًا.</p><p><span class="qpc-hafs">﴿فَاطِرِ﴾</span>: خالقِ.</p><p><span class="qpc-hafs">﴿أَسۡلَمَ﴾</span>: انقادَ، واستسلمَ</p></div>"
  6,15,""
  6,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّن يُصۡرَفۡ عَنۡهُ﴾</span>: أي: العذابُ.</p></div>"
  6,17,""
  6,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَاهِرُ﴾</span>: الغالِبُ.</p></div>"
  6,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۢ بَلَغَ﴾</span>: كلَّ مَن بَلَغَه.</p></div>"
  6,20,""
  6,21,""
  6,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيۡنَ شُرَكَآؤُكُمُ﴾</span>: أين آلهتُكم لينفعُوكُم؟</p></div>"
  6,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَتُهُمۡ﴾</span>: جوابُهم حين يُخْتَبَرُون بهذا السؤالِ.</p></div>"
  6,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم﴾</span>: وغابَ عنهم.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ يَفۡتَرُونَ﴾</span>: ما كانوا يعتقدونه مِن نَفْعِ آلهتِهم له.</p></div>"
  6,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكِنَّةً﴾</span>: أغْطِيةً فلا تفقهُ القرآنَ فِقْهَ انتفاعٍ به.</p><p><span class="qpc-hafs">﴿وَقۡرࣰا﴾</span>: ثِقَلًا، وصَمَمًا.</p><p><span class="qpc-hafs">﴿يُجَـٰدِلُونَكَ﴾</span>: يُخاصِمُونك.</p><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ﴾</span>: ما سَطَّرُوه من الأباطيلِ.</p></div>"
  6,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنۡهَوۡنَ عَنۡهُ﴾</span>: يَنْهَون الناسَ عن اتِّباع محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿وَيَنۡـَٔوۡنَ عَنۡهُ﴾</span>: ويَبْتَعِدُون عنه.</p></div>"
  6,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُقِفُواْ﴾</span>: حُبِسُوا.</p><p><span class="qpc-hafs">﴿نُرَدُّ﴾</span>: إلى الدُّنيا.</p></div>"
  6,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدَا﴾</span>: ظَهَرَ.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ يُخۡفُونَ﴾</span>: أي: عن أتْباعهِم من أمْرِ البعثِ، وصِدْقِ الرُّسُلِ.</p><p><span class="qpc-hafs">﴿لَكَـٰذِبُونَ﴾</span>: في أنهم لو عادُوا إلى الدنيا لآمَنوا.</p></div>"
  6,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَبۡعُوثِينَ﴾</span>: بعد الموتِ.</p></div>"
  6,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُقِفُواْ﴾</span>: حُبِسوا.</p><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: أي: البعثُ الذي كنتم تُنْكِرونه.</p></div>"
  6,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّاعَةُ﴾</span>: يومُ القيامةِ.</p><p><span class="qpc-hafs">﴿عَلَىٰ مَا فَرَّطۡنَا فِيهَا﴾</span>: على ما قَدَّمْناه في حياتِنا الدُّنيا.</p><p><span class="qpc-hafs">﴿أَوۡزَارَهُمۡ﴾</span>: ذنوبَهم.</p><p><span class="qpc-hafs">﴿يَزِرُونَ﴾</span>: يَحْمِلون.</p></div>"
  6,32,""
  6,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُكَذِّبُونَكَ﴾</span>: في قَرارةِ أنفسِهم، بل يعتقدون صِدْقَك.</p></div>"
  6,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِكَلِمَـٰتِ ٱللَّهِ﴾</span>: لِآياتِه التي وعَدَ فيها النبيَّ ﷺ بالنصرِ.</p></div>"
  6,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَفَقࣰا﴾</span>: مَنفَذًا، وسَرَبًا.</p><p><span class="qpc-hafs">﴿سُلَّمࣰا﴾</span>: دَرَجًا تَرْتقي عليه.</p><p><span class="qpc-hafs">﴿فَتَأۡتِيَهُم بِـَٔايَةࣲ﴾</span>: بغيرِما جِئْنا به.</p></div>"
  6,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡمَعُونَ﴾</span>: سَماعَ تَفَهُّمٍ لِما تَقْتَضيه العقولُ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَوۡتَىٰ﴾</span>: هم الكفارُ.</p></div>"
  6,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: علامةٌ تَدُلُّ على صِدْقِه، وتَضْطَرُّهُمْ إلى الإيمانِ.</p><p><span class="qpc-hafs">﴿لَا يَعۡلَمُونَ﴾</span>: أي: إنّ الإنزالَ يكونُ وفْقَ حِكْمَتِه تعالى.</p></div>"
  6,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَمٌ﴾</span>: جماعاتٌ متجانِسَةٌ في الخَلْقِ والرِّزقِ.</p><p><span class="qpc-hafs">﴿مَّا فَرَّطۡنَا﴾</span>: ما أغفَلْنا.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبِ﴾</span>: اللوحِ المحفوظِ.</p></div>"
  6,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُمࣱّ﴾</span>: لا يَسْمَعُون ما ينفَعُهم.</p><p><span class="qpc-hafs">﴿وَبُكۡمࣱ﴾</span>: لا يتكلَّمُون بالحقِّ.</p><p><span class="qpc-hafs">﴿فِي ٱلظُّلُمَـٰتِ﴾</span>: في ظلماتِ الكفرِ، والحَيْرةِ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ﴾</span>: طريقٍ.</p></div>"
  6,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتَكُمۡ﴾</span>: أخْبرُوني.</p><p><span class="qpc-hafs">﴿عَذَابُ ٱللَّهِ﴾</span>: في الدُّنيا.</p><p><span class="qpc-hafs">﴿إِن كُنتُمۡ صَـٰدِقِينَ﴾</span>: أي: في أنّ آلهتَكُم تنفَعُ، أو تضرُّ.</p></div>"
  6,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَنسَوۡنَ مَا تُشۡرِكُونَ﴾</span>: وتَتْرُكون آلهتَكم.</p></div>"
  6,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَأۡسَآءِ﴾</span>: في الأموالِ.</p><p><span class="qpc-hafs">﴿وَٱلضَّرَّآءِ﴾</span>: في الأبدانِ.</p><p><span class="qpc-hafs">﴿يَتَضَرَّعُونَ﴾</span>: يَتَذَلَّلُون لربِّهم.</p></div>"
  6,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَآ﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿بَأۡسُنَا﴾</span>: بَلاؤُنا.</p></div>"
  6,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبۡوَ ٰ⁠بَ كُلِّ شَيۡءٍ﴾</span>: من الخيرِ كالرزقِ والعافيةِ، استدراجًا منّا.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجأة.</p><p><span class="qpc-hafs">﴿مُّبۡلِسُونَ﴾</span>: يائِسون من كلِّ خيرٍ.</p></div>"
  6,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقُطِعَ دَابِرُ ٱلۡقَوۡمِ﴾</span>: فاسْتُؤصِلُوا جميعًا.</p></div>"
  6,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَخَتَمَ عَلَىٰ قُلُوبِكُم﴾</span>: وطَبَعَ عليها.</p><p><span class="qpc-hafs">﴿بِهِ﴾</span>: بذلك المأخوذِ منكم.</p><p><span class="qpc-hafs">﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾</span>: نَجِيءُ بالحُجَجِ على وجوهٍ متعددةٍ.</p><p><span class="qpc-hafs">﴿يَصۡدِفُونَ﴾</span>: يُعْرِضُون.</p></div>"
  6,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَغۡتَةً﴾</span>: من غيرِ مُقَدِّماتٍ.</p><p><span class="qpc-hafs">﴿جَهۡرَةً﴾</span>: بعد مُقَدِّماتٍ تَدُلُّ عليه.</p></div>"
  6,48,""
  6,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡسُقُونَ﴾</span>: يَخْرُجُون عن طاعةِ اللهِ.</p></div>"
  6,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَعۡلَمُ ٱلۡغَيۡبَ﴾</span>: أي: فأُخْبِرَكم بما سيكونُ مستقبلًا.</p><p><span class="qpc-hafs">﴿ٱلۡأَعۡمَىٰ وَٱلۡبَصِيرُ﴾</span>: الضالُّ والمهتدي.</p></div>"
  6,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنذِرۡ بِهِ﴾</span>: وأعْلِمْ، وخَوِّفْ -أيها الرسولُ- بالقرآنِ.</p><p><span class="qpc-hafs">﴿وَلِيࣱّ﴾</span>: ناصرٌ يَنْصُرُهم.</p><p><span class="qpc-hafs">﴿وَلَا شَفِيعࣱ﴾</span>: يَشْفَعُ لهم من دونِ اللهِ.</p></div>"
  6,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَطۡرُدِ ٱلَّذِينَ﴾</span>: ولا تُبْعِدْ عن مَجالسِك الضُّعفاءَ؛ موافَقَةً لمن طَلَبَ منك.</p><p><span class="qpc-hafs">﴿بِٱلۡغَدَوٰةِ وَٱلۡعَشِيِّ﴾</span>: أولِ النهار، وآخرِه.</p></div>"
  6,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنَّا﴾</span>: ابتَلَيْنا عبادَنا باختلافِ حظوظِهم في الرِّزْقِ والُخلُقِ، اختبارًا منا.</p><p><span class="qpc-hafs">﴿لِّيَقُولُوٓاْ﴾</span>: ليقولَ الكافرون الأغنياءُ.</p><p><span class="qpc-hafs">﴿أَهَـٰٓؤُلَآءِ﴾</span>: الضعفاءُ من المسلمين.</p><p><span class="qpc-hafs">﴿مَنَّ ٱللَّهُ عَلَيۡهِم﴾</span>: أي: بالهدايةِ دونَنا.</p></div>"
  6,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يُؤۡمِنُونَ﴾</span>: يُصَدِّقُون.</p><p><span class="qpc-hafs">﴿بِجَهَـٰلَةࣲ﴾</span>: أي: منه لعاقبتِها.</p></div>"
  6,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِتَسۡتَبِينَ سَبِيلُ﴾</span>: ولتظهَرَ طريقُ.</p></div>"
  6,56,""
  6,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَةࣲ﴾</span>: بَصيرةٍ، ويقينٍ.</p><p><span class="qpc-hafs">﴿وَكَذَّبۡتُم بِهِۦ﴾</span>: بالحقِّ الذي جاءني من الله.</p><p><span class="qpc-hafs">﴿مَا تَسۡتَعۡجِلُونَ بِهِۦٓ﴾</span>: من العذابِ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰصِلِينَ﴾</span>: بين الحقِّ والباطلِ.</p></div>"
  6,58,""
  6,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَفَاتِحُ ٱلۡغَيۡبِ﴾</span>: خزائنُ الغيبِ تُخَزَّنُ فيها، كعِلْمِ الساعةِ وعِلْمِ ما يَسْتَعْجِلُه الكفّارُ من العذابِ.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣲ مُّبِينࣲ﴾</span>: هو اللَّوحُ المحفوظُ الذي لا لَبْسَ فيه.</p></div>"
  6,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَفَّىٰكُم﴾</span>: في أثناءِ نومِكم، فيَقْبِضُ نفوسَكم التي بها تُمَيِّزُون.</p><p><span class="qpc-hafs">﴿جَرَحۡتُم﴾</span>: كسَبْتُم بجَوارِ حِكم من الخيرِ والشرِّ.</p><p><span class="qpc-hafs">﴿يَبۡعَثُكُمۡ﴾</span>: باليقظةِ من النومِ.</p><p><span class="qpc-hafs">﴿فِيهِ﴾</span>: في النهارِ.</p><p><span class="qpc-hafs">﴿لِيُقۡضَىٰٓ أَجَلࣱ مُّسَمࣰّى﴾</span>: لتُقْضى آجالُكم المحدَّدةُ في الدنيا.</p></div>"
  6,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَفَظَةً﴾</span>: ملائكةً يَحْفَظُون أعمالَكم ورِزْقَكم وأَجَلَكم.</p><p><span class="qpc-hafs">﴿رُسُلُنَا﴾</span>: من الملائكةِ المُكَلَّفين بذلك.</p><p><span class="qpc-hafs">﴿لَا يُفَرِّطُونَ﴾</span>: لا يُضَيِّعُون ما أُمِرُوا به.</p></div>"
  6,62,""
  6,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَضَرُّعࣰا﴾</span>: دعاءَ تَذَلُّلٍ جَهْرًا.</p></div>"
  6,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرۡبࣲ﴾</span>: شِدَّةٍ وغَمّ.</p></div>"
  6,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن فَوۡقِكُمۡ﴾</span>: كالطُّوفان.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِ أَرۡجُلِكُمۡ﴾</span>: كالزِّلزالِ.</p><p><span class="qpc-hafs">﴿يَلۡبِسَكُمۡ شِيَعࣰا﴾</span>: يَخْلِطَ أمْرَكم عليكم، فتكونوا فِرَقًا متناحِرَةً يَتَشَيَّعُ بعضُها لبعضٍ.</p><p><span class="qpc-hafs">﴿وَيُذِيقَ بَعۡضَكُم بَأۡسَ بَعۡضٍ﴾</span>: يَقْتلَ بعضُكم بعضًا.</p><p><span class="qpc-hafs">﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾</span>: نَجيءُ بالحُجَجِ على وجوهٍ متعددةٍ.</p></div>"
  6,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِهِۦ﴾</span>: بالقرآنِ، أو العذابِ.</p><p><span class="qpc-hafs">﴿بِوَكِيلࣲ﴾</span>: بحفيظٍ على أعمالِكم حتى أُجازيَكم بها.</p></div>"
  6,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّكُلِّ نَبَإࣲ مُّسۡتَقَرࣱّ﴾</span>: لكلِّ شيءٍ وقْتٌ يَقَعُ فيه.</p></div>"
  6,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخُوضُونَ﴾</span>: بالاستهزاءِ والباطلِ.</p><p><span class="qpc-hafs">﴿وَإِمَّا يُنسِيَنَّكَ﴾</span>: وإنْ أنساك.</p><p><span class="qpc-hafs">﴿ٱلذِّكۡرَىٰ﴾</span>: تَذَكُّرِك.</p></div>"
  6,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ حِسَابِهِم مِّن شَيۡءࣲ﴾</span>: ليس على المؤمنين شيءٌ من حِسابِ اللهِ على استهزاءِ المشركين.</p><p><span class="qpc-hafs">﴿وَلَـٰكِن ذِكۡرَىٰ﴾</span>: ولكنْ على المؤمنين أن يُذَكِّروا المشركين ليُمْسِكوا عن الخوضِ.</p></div>"
  6,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَذَرِ﴾</span>: واتْرُك.</p><p><span class="qpc-hafs">﴿بِهِۦٓ﴾</span>: بالقرآن.</p><p><span class="qpc-hafs">﴿أَن تُبۡسَلَ نَفۡسُۢ﴾</span>: لكيلا تُحْبَسَ، وتُفْضَحَ.</p><p><span class="qpc-hafs">﴿وَلِيࣱّ﴾</span>: ناصرٌ.</p><p><span class="qpc-hafs">﴿وَلَا شَفِيعࣱ﴾</span>: يَشْفَعُ لها في الآخرة.</p><p><span class="qpc-hafs">﴿وَإِن تَعۡدِلۡ كُلَّ عَدۡلࣲ﴾</span>: وإن تَفْتَدِ بأيِّ فداءٍ.</p><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: شديدِ الحرارةِ، وهو ما يَسِيلُ من صديدِهم.</p></div>"
  6,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُرَدُّ عَلَىٰٓ أَعۡقَابِنَا﴾</span>: ونَرْجِعُ إلى الضَّلالةِ.</p><p><span class="qpc-hafs">﴿ٱسۡتَهۡوَتۡهُ﴾</span>: هَوَتْ به، وأضَلَّتْه.</p><p><span class="qpc-hafs">﴿لِنُسۡلِمَ﴾</span>: لنَنْقادَ، ونُخْلِصَ.</p></div>"
  6,72,""
  6,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الذي يُنفَخُ فيه للبعثِ.</p><p><span class="qpc-hafs">﴿وَٱلشَّهَـٰدَةِ﴾</span>: وما تُشاهِدُونه.</p></div>"
  6,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبِينࣲ﴾</span>: واضحٍ.</p></div>"
  6,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ نُرِيٓ﴾</span>: كما أرَيْناه الحقَّ نُرِيه.</p><p><span class="qpc-hafs">﴿مَلَكُوتَ﴾</span>: المُلْكَ العظيمَ.</p><p><span class="qpc-hafs">﴿ٱلۡمُوقِنِينَ﴾</span>: الراسِخين في الإيمان.</p></div>"
  6,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّ﴾</span>: أظلمَ.</p><p><span class="qpc-hafs">﴿هَـٰذَا رَبِّي﴾</span>: حَكى ما يعتقدونه لأَجْلِ إلْزامِهم الحُجَّةَ.</p><p><span class="qpc-hafs">﴿أَفَلَ﴾</span>: غابَ.</p></div>"
  6,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَازِغࣰا﴾</span>: طالعًا.</p></div>"
  6,78,""
  6,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَّهۡتُ وَجۡهِيَ﴾</span>: قَصَدْتُ بعبادتي.</p><p><span class="qpc-hafs">﴿فَطَرَ﴾</span>: خَلَقَ.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن الشِّرْكِ.</p></div>"
  6,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَآجَّهُۥ قَوۡمُهُۥ﴾</span>: وجادَلَه قومُه.</p><p><span class="qpc-hafs">﴿وَلَآ أَخَافُ مَا تُشۡرِكُونَ بِهِۦٓ﴾</span>: لاأخافُ آلهتَكم، فلن تَضُرَّني.</p></div>"
  6,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً بيِّنةً.</p><p><span class="qpc-hafs">﴿بِٱلۡأَمۡنِ﴾</span>: أي: من عذابِ اللهِ.</p></div>"
  6,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلۡبِسُوٓاْ﴾</span>: يَخْلِطُوا.</p><p><span class="qpc-hafs">﴿بِظُلۡمٍ﴾</span>: بشِرْكٍ.</p></div>"
  6,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتِلۡكَ حُجَّتُنَآ﴾</span>: وتلك البراهينُ التي أوْرَدَها إبراهيمُ.</p></div>"
  6,84,""
  6,85,""
  6,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: من أهلِ زمانِهم.</p></div>"
  6,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱجۡتَبَيۡنَـٰهُمۡ﴾</span>: واختَرْناهم.</p></div>"
  6,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَحَبِطَ﴾</span>: لَبَطَلَ.</p></div>"
  6,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡحُكۡمَ﴾</span>: والعِلْمَ.</p><p><span class="qpc-hafs">﴿هَـٰٓؤُلَآءِ﴾</span>: أهلُ مكةَ.</p><p><span class="qpc-hafs">﴿وَكَّلۡنَا بِهَا﴾</span>: ألْزَمْنا بالإيمانِ بها.</p></div>"
  6,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلَـٰٓئِكَ﴾</span>: أي: الأنبياءُ.</p><p><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا ذِكۡرَىٰ﴾</span>: ما القرآنُ إلا تذكيرٌ.</p></div>"
  6,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا قَدَرُواْ ٱللَّهَ حَقَّ قَدۡرِهِۦٓ﴾</span>: وما عَرَفَ هؤلاء المشركون رَبَّهم حَقَّ مَعْرفَتِه.</p><p><span class="qpc-hafs">﴿تَجۡعَلُونَهُۥ قَرَاطِيسَ﴾</span>: تكتبون عنه دفاترَ وكتبًا مُقَطَّعةً؛ فيَتِمُّ لكم ما تُريدونه من التحريفِ.</p><p><span class="qpc-hafs">﴿خَوۡضِهِمۡ﴾</span>: باطِلِهم.</p></div>"
  6,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيۡنَ يَدَيۡهِ﴾</span>: ماتَقَدَّمَه من الكتبِ السماويةِ.</p><p><span class="qpc-hafs">﴿أُمَّ ٱلۡقُرَىٰ﴾</span>: مكةَ.</p></div>"
  6,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَمَرَ ٰ⁠تِ ٱلۡمَوۡتِ﴾</span>: أهوالِه وشدائدِه.</p><p><span class="qpc-hafs">﴿بَاسِطُوٓاْ أَيۡدِيهِمۡ﴾</span>: لقَبْضِ أرواحِ الكفّارِ، وتَعْذ يبهم.</p><p><span class="qpc-hafs">﴿أَخۡرِجُوٓاْ أَنفُسَكُمُ﴾</span>: يقولون لهم: أخْرِجُوا أنفسَكم إلينا.</p><p><span class="qpc-hafs">﴿ٱلۡهُونِ﴾</span>: الهَوانِ والذُّلِّ.</p></div>"
  6,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا خَوَّلۡنَـٰكُمۡ﴾</span>: ما مَكَّنّاكم فيه من الدنيا، كالأموالِ والأولادِ، فلم تَنْتَفعوا.</p><p><span class="qpc-hafs">﴿أَنَّهُمۡ فِيكُمۡ شُرَكَـٰٓؤُاْ﴾</span>: شركاءُ للهِ يَسْتحقون العبادةَ.</p><p><span class="qpc-hafs">﴿بَيۡنَكُمۡ﴾</span>: تَواصُلُكم الذي كان بينَكم في الحياةِ الدنيا.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: ذهبَ، وغابَ.</p></div>"
  6,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَالِقُ ٱلۡحَبِّ﴾</span>: يَشُقُّه، فيَخْرُجُ منه الزَّرع.</p><p><span class="qpc-hafs">﴿وَٱلنَّوَىٰ﴾</span>: جَمْعِ النَّواة، وهي البِذْرةُ.</p><p><span class="qpc-hafs">﴿يُخۡرِجُ ٱلۡحَيَّ مِنَ ٱلۡمَيِّتِ﴾</span>: كالإنسانِ من النُّطفةِ.</p><p><span class="qpc-hafs">﴿وَمُخۡرِجُ ٱلۡمَيِّتِ مِنَ ٱلۡحَيِّ﴾</span>: كالنُّطفةِ من الإنسانِ.</p><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾</span>: فكيف تُصْرَفون عن الحقِّ، وتَعْبُدُون مع الله غيرَه؟</p></div>"
  6,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَالِقُ ٱلۡإِصۡبَاحِ﴾</span>: يَشُقُّ ضياءَ الصَّباحِ من ظلامِ الليلِ.</p><p><span class="qpc-hafs">﴿حُسۡبَانࣰا﴾</span>: جَعَلَهُما محلَّ حسابٍ لمصالحِ العباد، وأَجْراهما بحِسابٍ مُقَدَّرٍ.</p></div>"
  6,97,""
  6,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾</span>: آدمَ عليه السلام.</p><p><span class="qpc-hafs">﴿فَمُسۡتَقَرࣱّ﴾</span>: هي أرحامُ النساءِ.</p><p><span class="qpc-hafs">﴿وَمُسۡتَوۡدَعࣱ﴾</span>: هي أصلابُ الرجالِ.</p></div>"
  6,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَخۡرَجۡنَا مِنۡهُ﴾</span>: من النَّباتِ.</p><p><span class="qpc-hafs">﴿خَضِرࣰا﴾</span>: زَرْعًا، وشَجَرًا أخضرَ.</p><p><span class="qpc-hafs">﴿مُّتَرَاكِبࣰا﴾</span>: يَرْكَبُ بعضُه بعضًا كسَنابلِ القَمْحِ.</p><p><span class="qpc-hafs">﴿مِن طَلۡعِهَا﴾</span>: الطَّلْعُ: ما تنشأُ فيه عناقيدُ الرُّطَبِ.</p><p><span class="qpc-hafs">﴿قِنۡوَانࣱ﴾</span>: جمعُ قِنْو، وهو عُنقودُ النَّخْلِ.</p><p><span class="qpc-hafs">﴿دَانِيَةࣱ﴾</span>: قريبةٌ إلى الأرض.</p><p><span class="qpc-hafs">﴿مُشۡتَبِهࣰا﴾</span>: في المنظرِ.</p><p><span class="qpc-hafs">﴿وَغَيۡرَ مُتَشَـٰبِهٍ﴾</span>: في الطَّعْمِ.</p><p><span class="qpc-hafs">﴿ٱنظُرُوٓاْ﴾</span>: فَكِّرُوا في قُدْرَةِ خالقهِ.</p><p><span class="qpc-hafs">﴿وَيَنۡعِهِۦٓ﴾</span>: ونُضْجِه.</p></div>"
  6,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَخَرَقُواْ﴾</span>: واختَلَقُوا، ونَسَبُوا.</p></div>"
  6,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدِيعُ﴾</span>: مُبْدِعٌ على غيرِ مثالٍ سَبَقَ.</p><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: كيف؟</p></div>"
  6,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلࣱ﴾</span>: رقيبٌ مُدَبِّرٌ لأمورِ خَلْقِه.</p></div>"
  6,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا تُدۡرِكُهُ﴾</span>: لا تُحيطُ به، ولا تَبْلُغُ كُنْهَ حَقيقتِه.</p></div>"
  6,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَصَآئِرُ﴾</span>: براهينُ واضحةٌ.</p><p><span class="qpc-hafs">﴿فَعَلَيۡهَا﴾</span>: فعلى نفسِه يعودُ وبالُ ذلك.</p><p><span class="qpc-hafs">﴿بِحَفِيظࣲ﴾</span>: أُحْصِي أعمالَكم، بل أنا مُبَلِّغٌ.</p></div>"
  6,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾</span>: نُبَيِّنُ البراهينَ، والحُجَجَ.</p><p><span class="qpc-hafs">﴿وَلِيَقُولُواْ دَرَسۡتَ﴾</span>: أي: لتقومَ الحُجَّةُ عليهم، وليقولوا: تَعَلَّمْتَ من أهلِ الكتابِ.</p></div>"
  6,106,""
  6,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَفِيظࣰا﴾</span>: رقيبًا تحفَظُ أقوالَهم وأعمالَهم.</p><p><span class="qpc-hafs">﴿بِوَكِيلࣲ﴾</span>: مُوَكَّلٍ على أمورِهم.</p></div>"
  6,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يَدۡعُونَ مِن دُونِ ٱللَّهِ﴾</span>: هم الأصنامُ.</p><p><span class="qpc-hafs">﴿عَدۡوَۢا﴾</span>: اعتداءً.</p><p><span class="qpc-hafs">﴿زَيَّنَّا﴾</span>: حَسَّنّا.</p></div>"
  6,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: بأيمانٍ مُؤَكَّدةٍ.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: معجزةٌ خارقةٌ:</p><p><span class="qpc-hafs">﴿وَمَا يُشۡعِرُكُمۡ﴾</span>: وما يُدْريكم.</p><p><span class="qpc-hafs">﴿أَنَّهَآ﴾</span>: لعلَّ المعجزاتِ.</p></div>"
  6,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُقَلِّبُ أَفۡـِٔدَتَهُمۡ﴾</span>: فنَحُولُ بينَهم وبينَ الإيمانِ.</p><p><span class="qpc-hafs">﴿فِي طُغۡيَـٰنِهِمۡ﴾</span>: في تَمَرُّدِهم.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يَتَحَيَّرون، فلا يَهْتَدُون إلى الحقِّ.</p></div>"
  6,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَشَرۡنَا﴾</span>: وجَمَعْنا.</p><p><span class="qpc-hafs">﴿قُبُلࣰا﴾</span>: فعايَنُوه مُواجَهةً.</p></div>"
  6,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَيَـٰطِينَ ٱلۡإِنسِ﴾</span>: هم المَرَدَةُ العُتاةُ من الإنسِ.</p><p><span class="qpc-hafs">﴿زُخۡرُفَ ٱلۡقَوۡلِ﴾</span>: هو القولُ المُزَيَّنُ.</p><p><span class="qpc-hafs">﴿غُرُورࣰا﴾</span>: ليَغْتَرَّ به سامِعُه.</p><p><span class="qpc-hafs">﴿وَمَا يَفۡتَرُونَ﴾</span>: وما يَخْتَلِقُونه من كَذِبٍ.</p></div>"
  6,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِتَصۡغَىٰٓ إِلَيۡهِ﴾</span>: ولتَمِيلَ إلى القولِ المُزَيَّنِ.</p><p><span class="qpc-hafs">﴿وَلِيَقۡتَرِفُواْ﴾</span>: ولِيكْتَسِبُوا من الأعمالِ السيئةِ.</p></div>"
  6,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبۡتَغِي﴾</span>: أطْلُبُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُمۡتَرِينَ﴾</span>: الشّاكِّين.</p></div>"
  6,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلِمَتُ رَبِّكَ﴾</span>: القرآنُ الكريمُ.</p><p><span class="qpc-hafs">﴿لَّا مُبَدِّلَ لِكَلِمَـٰتِهِۦ﴾</span>: لا أحدَ مُغَيِّرٌ لما حَكَمَ به.</p></div>"
  6,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡرُصُونَ﴾</span>: يظنُّون، يَكْذِبُون.</p></div>"
  6,117,""
  6,118,""
  6,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لَكُمۡ أَلَّا﴾</span>: وأيُّ شيءٍ يَمْنَعُكم؟</p></div>"
  6,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَـٰهِرَ ٱلۡإِثۡمِ وَبَاطِنَهُۥٓ﴾</span>: عَلانِيَتُه وسِرُّه.</p><p><span class="qpc-hafs">﴿يَقۡتَرِفُونَ﴾</span>: يكتسِبُون.</p></div>"
  6,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَفِسۡقࣱ﴾</span>: لَخُروجٌ عن طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿لَيُوحُونَ﴾</span>: لَيُوَسْوِسُون لهم بما يخالِفُ الحقَّ.</p><p><span class="qpc-hafs">﴿لِيُجَـٰدِلُوكُمۡ﴾</span>: ليُثيروا الشبهاتِ لمجادَلَتِكم.</p></div>"
  6,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَيۡتࣰا﴾</span>: في الضلالةِ.</p><p><span class="qpc-hafs">﴿زُيِّنَ﴾</span>: حُسِّنَ.</p></div>"
  6,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكَـٰبِرَ مُجۡرِمِيهَا﴾</span>: رُؤَساءَها وعُظماءَها.</p><p><span class="qpc-hafs">﴿لِيَمۡكُرُواْ فِيهَا﴾</span>: بالصَّدِّ عن دينِ اللهِ.</p><p><span class="qpc-hafs">﴿وَمَا يَمۡكُرُونَ إِلَّا بِأَنفُسِهِمۡ﴾</span>: وبالُ مَكْرِهم عائدٌ عليهم.</p></div>"
  6,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡلَمُ حَيۡثُ يَجۡعَلُ رِسَالَتَهُۥ﴾</span>: أعلمُ بمَن يَسْتحِقُّ أن يجعلَه رسولًا، فدَعُوا طَلَبَ ماليسَ مِن شأنِكم.</p><p><span class="qpc-hafs">﴿صَغَارٌ﴾</span>: ذلٌّ، وهَوانٌ.</p></div>"
  6,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَجࣰا﴾</span>: شديدَ الضِّيقِ.</p><p><span class="qpc-hafs">﴿يَصَّعَّدُ﴾</span>: يتكَلَّفُ ما لا يُطيقُ من الصُّعود.</p><p><span class="qpc-hafs">﴿ٱلرِّجۡسَ﴾</span>: الشيطانَ.</p></div>"
  6,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طُ رَبِّكَ﴾</span>: الإسلاُم.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: البراهينَ.</p></div>"
  6,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَارُ ٱلسَّلَـٰمِ﴾</span>: دارُ السَّلامةِ من المكروه، وهي الجنةُ.</p><p><span class="qpc-hafs">﴿وَلِيُّهُم﴾</span>: ناصِرُهم.</p></div>"
  6,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَحۡشُرُهُمۡ﴾</span>: أي: جميعَ الثَّقَلَيْن من الجنِّ والإنسِ.</p><p><span class="qpc-hafs">﴿ٱسۡتَكۡثَرۡتُم مِّنَ ٱلۡإِنسِ﴾</span>: بإضلالهِم، وصَدِّهم عن سبيلِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱسۡتَمۡتَعَ بَعۡضُنَا بِبَعۡضࣲ﴾</span>: استمتاعُ الجنِّ بالإنس: تَلَذُّذهم باتِّباع الإنسِ لهم، واستمتاعُ الإنس بالجن: قَبولُهم تحسينَ المعاصي منهم، فوقَعُوا فيها، وتَلَذَّ ذُوا بها.</p><p><span class="qpc-hafs">﴿وَبَلَغۡنَآ أَجَلَنَا﴾</span>: بانقضاءِ حياتِنا الدنيا، ووُصولِنا إلى دارِ الجَزاءِ.</p><p><span class="qpc-hafs">﴿مَثۡوَىٰكُمۡ﴾</span>: موضعُ مَقامِكم.</p><p><span class="qpc-hafs">﴿إِلَّا مَا شَآءَ ٱللَّهُ﴾</span>: أي: شاءَ عَدَمَ خُلودِه، من عُصاةِ المُوَحِّدِين.</p></div>"
  6,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُوَلِّي بَعۡضَ ٱلظَّـٰلِمِينَ بَعۡضَۢا﴾</span>: نُسَلِّط بعضَ الظّالمين من الإنسِ على بعضٍ في الدنيا.</p></div>"
  6,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُسُلࣱ مِّنكُمۡ﴾</span>: الرسُلُ هم من الإنسِ، ورسُلُ الجِنِّ هم الذين يُنْذِرُون قومَهم.</p><p><span class="qpc-hafs">﴿وَغَرَّتۡهُمُ﴾</span>: وخَدَعَتْهم زِينتُها، فاطمأنُّوا إليها.</p></div>"
  6,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِظُلۡمࣲ﴾</span>: بسببِ ظُلْمِ مَن يَظْلِمُ.</p><p><span class="qpc-hafs">﴿وَأَهۡلُهَا غَـٰفِلُونَ﴾</span>: أي: لا يُهلِكُهم إلا بعد إرسالِ الرسل، وارتفاعِ الغفلةِ عنهم بذلك، وتَحَقُّقِ الإنذارِ.</p></div>"
  6,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَرَجَـٰتࣱ﴾</span>: مراتبُ.</p></div>"
  6,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَآ أَنشَأَكُم مِّن ذُرِّيَّةِ قَوۡمٍ ءَاخَرِينَ﴾</span>: أحْدَثَكم من نَسْلِ خَلْقٍ آخرين كانوا قبلَكم.</p></div>"
  6,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُعۡجِزِينَ﴾</span>: بفائتين عَمّا هو نازلٌ بكم.</p></div>"
  6,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكَانَتِكُمۡ﴾</span>: طريقتِكم، فاثبُتُوا عليها.</p><p><span class="qpc-hafs">﴿عَـٰقِبَةُ ٱلدَّارِ﴾</span>: الجنةُ.</p></div>"
  6,136,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرَأَ﴾</span>: خَلَقَ.</p><p><span class="qpc-hafs">﴿ٱلۡحَرۡثِ﴾</span>: ثمراتِ الزَّرْعِ.</p><p><span class="qpc-hafs">﴿لِشُرَكَآئِنَا﴾</span>: للأصنامِ التي يعبُدونها.</p></div>"
  6,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَتۡلَ أَوۡلَـٰدِهِمۡ﴾</span>: وهو دَفْنُ البناتِ وهُنَّ أحياءٌ.</p><p><span class="qpc-hafs">﴿شُرَكَآؤُهُمۡ﴾</span>: رؤساؤُهم، وشياطينُهم.</p><p><span class="qpc-hafs">﴿لِيُرۡدُوهُمۡ﴾</span>: ليُهْلِكُوهم.</p><p><span class="qpc-hafs">﴿وَلِيَلۡبِسُواْ﴾</span>: ولِيَخْلِطُوا.</p></div>"
  6,138,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَرۡثٌ﴾</span>: وزَرْعٌ.</p><p><span class="qpc-hafs">﴿حِجۡرࣱ﴾</span>: ممنوعةٌ، فهي لأصنامِهم.</p><p><span class="qpc-hafs">﴿حُرِّمَتۡ﴾</span>: فلا يركبونَها.</p></div>"
  6,139,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَالِصَةࣱ﴾</span>: حلالٌ.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جِنَا﴾</span>: نسائِنا.</p><p><span class="qpc-hafs">﴿شُرَكَآءُ﴾</span>: يأكلُ منه الذكورُ والإناثُ.</p><p><span class="qpc-hafs">﴿وَصۡفَهُمۡ﴾</span>: جزاءَ وصْفِهم.</p></div>"
  6,140,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَفَهَۢا﴾</span>: طَيشًا.</p><p><span class="qpc-hafs">﴿مَا رَزَقَهُمُ﴾</span>: من الأنعام.</p></div>"
  6,141,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتࣲ مَّعۡرُوشَـٰتࣲ﴾</span>: بساتينَ مرفوعاتٍ عن الأرض كالعِنَبِ.</p><p><span class="qpc-hafs">﴿وَغَيۡرَ مَعۡرُوشَـٰتࣲ﴾</span>: قائمةً على سُوقِها كالنَّخْلِ، أوما خَرَج في البَرِّ.</p><p><span class="qpc-hafs">﴿مُتَشَـٰبِهࣰا﴾</span>: في المنظرِ.</p><p><span class="qpc-hafs">﴿وَغَيۡرَ مُتَشَـٰبِهࣲ﴾</span>: في الطَّعْمِ.</p><p><span class="qpc-hafs">﴿وَءَاتُواْ حَقَّهُۥ﴾</span>: بالزَّكاةِ والصدقات.</p></div>"
  6,142,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمُولَةࣰ﴾</span>: مُهَيَّأً للحَمْلِ عليه.</p><p><span class="qpc-hafs">﴿وَفَرۡشࣰا﴾</span>: صِغارَ الأنعامِ.</p></div>"
  6,143,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَمَـٰنِيَةَ أَزۡوَ ٰ⁠جࣲ﴾</span>: هذه الأنعامُ ثمانيةُ أصنافٍ، أربعةٌ منها في الغنم، وهي: الضَّأْنُ ذُكورًا وإناثًا، والمَعْزُ ذكورًا وإناثًا، وأربعةٌ في الإبِلِ والبقَرِ، ذكورًا وإناثًا.</p><p><span class="qpc-hafs">﴿أَمَّا ٱشۡتَمَلَتۡ عَلَيۡهِ﴾</span>: أي: هل حَرَّمَ ما اشتملت عليه؟ فإن كان التحريمُ منه فإن ذلك يَسْتَلْزِم ُ تحريمَ الجميعِ، فلماذا حَلَّلُوا بعضَها، وحَرَّمُوا بعضَها الآخر؟</p></div>"
  6,144,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُهَدَآءَ﴾</span>: حاضِرين.</p></div>"
  6,145,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُحَرَّمًا﴾</span>: أي: طعامًا محرَّمًا.</p><p><span class="qpc-hafs">﴿عَلَىٰ طَاعِمࣲ يَطۡعَمُهُۥٓ﴾</span>: على مَن يأكلُه.</p><p><span class="qpc-hafs">﴿مَّسۡفُوحًا﴾</span>: جاريًا.</p><p><span class="qpc-hafs">﴿رِجۡسٌ﴾</span>: نَجَسٌ.</p><p><span class="qpc-hafs">﴿أُهِلَّ لِغَيۡرِ ٱللَّهِ بِهِۦ﴾</span>: هو المذبوحُ الذي ذُكِرَ عليه اسمُ غيرِ اللهِ.</p><p><span class="qpc-hafs">﴿فَمَنِ ٱضۡطُرَّ﴾</span>: إلى الأَكْلِ من هذه المحرَّماتِ.</p><p><span class="qpc-hafs">﴿غَيۡرَ بَاغࣲ﴾</span>: غيرَ طالبٍ بأَكْلِه التلذُّذَ.</p><p><span class="qpc-hafs">﴿وَلَا عَادࣲ﴾</span>: ولا متجاوزٍ حَدَّ الضَّرورةِ.</p></div>"
  6,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا مَا حَمَلَتۡ ظُهُورُهُمَآ﴾</span>: إلا الشَّحْمَ المخالِطَ لظُهورِهما.</p><p><span class="qpc-hafs">﴿أَوِ ٱلۡحَوَايَآ﴾</span>: أو المخالِطَ للأمعاءِ.</p><p><span class="qpc-hafs">﴿بِبَغۡيِهِمۡ﴾</span>: بأعمالهِم السيئةِ.</p></div>"
  6,147,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُرَدُّ بَأۡسُهُۥ﴾</span>: ولا يُدْفَعُ عِقابُه إنْ أنْزَلَه بهم.</p></div>"
  6,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا حَرَّمۡنَا مِن شَيۡءࣲ﴾</span>: أي: لو شاءَ ما حَرَّمْنا على أنفسِنا شيئًا من الأنعام.</p><p><span class="qpc-hafs">﴿بَأۡسَنَا﴾</span>: عقابَنا.</p><p><span class="qpc-hafs">﴿تَخۡرُصُونَ﴾</span>: تَتَوَهَّمون، وتظنون.</p></div>"
  6,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُجَّةُ ٱلۡبَـٰلِغَةُ﴾</span>: هي القاطِعَةُ لشُبَهِهِم، وهذه الحُجَّةُ هي الرُّسُلُ، وما جاؤُوا به من كُتُبٍ، ومعجزاتٍ.</p></div>"
  6,150,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلُمَّ﴾</span>: هاتُوا.</p><p><span class="qpc-hafs">﴿حَرَّمَ هَـٰذَا﴾</span>: حَرَّم ماحَرَّمْتُم من الأنعام.</p><p><span class="qpc-hafs">﴿فَلَا تَشۡهَدۡ﴾</span>: لأنّ شهادتَهم باطلةٌ.</p><p><span class="qpc-hafs">﴿يَعۡدِلُونَ﴾</span>: يُشْرِكون.</p></div>"
  6,151,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِمۡلَـٰقࣲ﴾</span>: فَقْرٍ.</p><p><span class="qpc-hafs">﴿مَا ظَهَرَ﴾</span>: ما أُعْلِنَ منها.</p><p><span class="qpc-hafs">﴿وَمَا بَطَنَ﴾</span>: ما خَفِيَ منها.</p></div>"
  6,152,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلَّتِي هِيَ أَحۡسَنُ﴾</span>: بما يُصْلِحُ مالَه، وينتفعُ به.</p><p><span class="qpc-hafs">﴿يَبۡلُغَ أَشُدَّهُۥ﴾</span>: وهو سِنُّ البُلوغِ مع الرُّشْدِ، فادفعُوا إليه ماله.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعدلِ.</p><p><span class="qpc-hafs">﴿وُسۡعَهَا﴾</span>: طاقَتَها.</p><p><span class="qpc-hafs">﴿وَبِعَهۡدِ ٱللَّهِ أَوۡفُواْ﴾</span>: بما عَهِدَ به إليكم من الالتزامِ بشرعِه.</p></div>"
  6,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا صِرَ ٰ⁠طِي﴾</span>: الإسلامُ طريقي.</p><p><span class="qpc-hafs">﴿ٱلسُّبُلَ﴾</span>: طُرُقَ الضَّلالِ والبِدَعِ.</p><p><span class="qpc-hafs">﴿فَتَفَرَّقَ بِكُمۡ﴾</span>: فتميلَ بكم.</p></div>"
  6,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمَامًا عَلَى ٱلَّذِيٓ أَحۡسَنَ﴾</span>: تمامًا لنِعْمَتِه على المُحْسنين من مِلَّتِه.</p></div>"
  6,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَـٰذَا﴾</span>: أي: القرآنُ.</p></div>"
  6,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن تَقُولُوٓاْ﴾</span>: لئلّا تقولُوا أيها الكفارُ.</p><p><span class="qpc-hafs">﴿طَآئِفَتَيۡنِ﴾</span>: اليهودِ والنصارى.</p><p><span class="qpc-hafs">﴿وَإِن كُنَّا﴾</span>: وإنّنا كنّا.</p><p><span class="qpc-hafs">﴿دِرَاسَتِهِمۡ﴾</span>: تلاوةِ كتبِهم بلُغاتها.</p><p><span class="qpc-hafs">﴿لَغَـٰفِلِينَ﴾</span>: لاندْري ما فيها.</p></div>"
  6,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡدَىٰ مِنۡهُمۡ﴾</span>: أشَدَّ استقامةً على الحقِّ.</p><p><span class="qpc-hafs">﴿وَصَدَفَ﴾</span>: أعرَضَ.</p></div>"
  6,158,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: ينتظر المُعْرِضون.</p><p><span class="qpc-hafs">﴿ٱلۡمَلَـٰٓئِكَةُ﴾</span>: المختصُّون بقَبْضِ الأرواحِ.</p><p><span class="qpc-hafs">﴿يَأۡتِيَ رَبُّكَ﴾</span>: للفَصْل بين عبادِه يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿بَعۡضُ ءَايَـٰتِ رَبِّكَ﴾</span>: بعضُ علاماتِ السّاعةِ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: من قبلِ إتيانِ هذه الآياتِ.</p><p><span class="qpc-hafs">﴿خَيۡرࣰا﴾</span>: عملًا صالحًا.</p></div>"
  6,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَّقُواْ دِينَهُمۡ﴾</span>: جَعَلُوه متفرِّقًا، فأخذوا ببعضِه، وتركوا بعضَه.</p><p><span class="qpc-hafs">﴿شِيَعࣰا﴾</span>: فِرَقًا وأحزابًا.</p></div>"
  6,160,""
  6,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: طريقٍ لا عِوَجَ فيه، وهو الإسلامُ.</p><p><span class="qpc-hafs">﴿قِيَمࣰا﴾</span>: يقومُ بأمْرِ الدنيا والآخرةِ.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا إلى الحقِّ.</p></div>"
  6,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُسُكِي﴾</span>: وذَبْحي للأنعام.</p><p><span class="qpc-hafs">﴿وَمَحۡيَايَ﴾</span>: ما أعمَلُه في حياتي.</p><p><span class="qpc-hafs">﴿وَمَمَاتِي﴾</span>: ما يُقَدِّره عليّ في الموتِ.</p></div>"
  6,163,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلُ ٱلۡمُسۡلِمِينَ﴾</span>: أولُ مَن انقادَ للهِ من هذه الأمةِ.</p></div>"
  6,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبۡغِي﴾</span>: أطْلُبُ.</p><p><span class="qpc-hafs">﴿وَلَا تَكۡسِبُ كُلُّ نَفۡسٍ إِلَّا عَلَيۡهَا﴾</span>: لا يُؤاخَذُ ممّا أتَتْ به من الذَّنبِ سِواها.</p><p><span class="qpc-hafs">﴿وَلَا تَزِرُ وَازِرَةࣱ وِزۡرَ أُخۡرَىٰ﴾</span>: ولا تَحْمِلُ نفسٌ آثمةٌ إثمَ نفسٍ أخرى.</p></div>"
  6,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَـٰٓئِفَ﴾</span>: خُلَفاءَ الأممِ الماضيةِ.</p><p><span class="qpc-hafs">﴿وَرَفَعَ بَعۡضَكُمۡ فَوۡقَ بَعۡضࣲ﴾</span>: في الرِّزقِ والقوةِ وغيرِهما.</p><p><span class="qpc-hafs">﴿دَرَجَـٰتࣲ﴾</span>: مراتبَ.</p><p><span class="qpc-hafs">﴿لِّيَبۡلُوَكُمۡ﴾</span>: ليختبرَكم.</p><p><span class="qpc-hafs">﴿فِي مَآ ءَاتَىٰكُمۡ﴾</span>: أي: من نِعَمِه.</p></div>"
