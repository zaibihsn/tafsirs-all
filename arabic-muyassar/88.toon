quran[26]{c,v,t}:
  88,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ﴾</span>: قَدْ.</p><p><span class="qpc-hafs">﴿ٱلۡغَـٰشِيَةِ﴾</span>: القِيامةِ الَّتِي تَغْشى النّاسَ بأهْوالِها.</p></div>"
  88,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوهࣱ﴾</span>: وُجُوهُ الكُفّارِ.</p><p><span class="qpc-hafs">﴿خَـٰشِعَةٌ﴾</span>: ذَلِيلةٌ بالعذابِ.</p></div>"
  88,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَامِلَةࣱ﴾</span>: مُجْهَدَةٌ بالعَمَلِ.</p><p><span class="qpc-hafs">﴿نَّاصِبَةࣱ﴾</span>: مُتْعَبَةٌ.</p></div>"
  88,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَصۡلَىٰ﴾</span>: تُقاسِي نارًا.</p><p><span class="qpc-hafs">﴿حَامِيَةࣰ﴾</span>: شَدِيدَة التَّوَهُّجِ.</p></div>"
  88,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَانِيَةࣲ﴾</span>: بَلَغَتْ مُنْتَهى الحرارةِ.</p></div>"
  88,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرِيعࣲ﴾</span>: نَبْتٍ ذي شَوْكٍ لاصِقٍ بالأرْضِ.</p></div>"
  88,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُغۡنِي مِن جُوعࣲ﴾</span>: ولا يَسُدُّ جُوعَهُ.</p></div>"
  88,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوهࣱ﴾</span>: وُجُوهُ المؤمِنينَ.</p><p><span class="qpc-hafs">﴿نَّاعِمَةࣱ﴾</span>: ذاتُ نِعْمَةٍ وكَرامةٍ.</p></div>"
  88,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّسَعۡيِهَا﴾</span>: لِعَمَلِها الَّذِي عَمِلَتْهُ في الدُّنيا.</p><p><span class="qpc-hafs">﴿رَاضِيَةࣱ﴾</span>: في الآخِرَةِ حِينَ أُعْطِيَتِ الجنَّةَ بِعَمَلِها.</p></div>"
  88,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَالِيَةࣲ﴾</span>: رَفِيعةِ المكانِ والمكانةِ.</p></div>"
  88,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـٰغِيَةࣰ﴾</span>: كَلِمةَ لَغْوٍ.</p></div>"
  88,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَارِيَةࣱ﴾</span>: تَتَدَفَّقُ مِياهُها.</p></div>"
  88,13,""
  88,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّوۡضُوعَةࣱ﴾</span>: مُعَدَّةٌ للشّارِبِينَ.</p></div>"
  88,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَمَارِقُ﴾</span>: ووَسائِدُ ومَرافِقُ.</p><p><span class="qpc-hafs">﴿مَصۡفُوفَةࣱ﴾</span>: بَعضُها بِجَنبِ بَعْضٍ.</p></div>"
  88,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزَرَابِيُّ﴾</span>: وبُسُطٌ.</p><p><span class="qpc-hafs">﴿مَبۡثُوثَةٌ﴾</span>: كَثِيرةٌ مَفْرُوشَةٌ.</p></div>"
  88,17,""
  88,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡفَ رُفِعَتۡ﴾</span>: عَنِ الأرْضِ بِلا عَمَدٍ؟</p></div>"
  88,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُصِبَتۡ﴾</span>: رُفِعتْ حتّى كانتْ بارزةً على وجْهِ الأرضِ.</p></div>"
  88,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُطِحَتۡ﴾</span>: بُسِطَتْ و مُهِّدتْ.</p></div>"
  88,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَكِّرۡ﴾</span>: فَعِظْ.</p><p><span class="qpc-hafs">﴿مُذَكِّرࣱ﴾</span>: واعِظٌ.</p></div>"
  88,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُصَيۡطِرٍ﴾</span>: بِمُسَلَّطٍ، فَتُكْرِهَهُم على الإيمانِ.</p></div>"
  88,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span>: أعْرَضَ وأصَرَّ عَلى الكُفْرِ.</p></div>"
  88,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَذَابَ ٱلۡأَكۡبَرَ﴾</span>: النّارَ.</p></div>"
  88,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِيَابَهُمۡ﴾</span>: مَرْجِعَهُم بَعْدَ الموتِ.</p></div>"
  88,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِسَابَهُم﴾</span>: جَزاءَهُم.</p></div>"
