quran[55]{c,v,t}:
  54,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّاعَةُ﴾</span>: القِيامَةُ.</p><p><span class="qpc-hafs">﴿وَٱنشَقَّ﴾</span>: انْفَلَقَ فِلْقَتَينِ.</p></div>"
  54,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: بُرْهانًا عَلى صِدْقِ الرَّسُولِ مُحَمَّدٍ ﷺ.</p><p><span class="qpc-hafs">﴿مُّسۡتَمِرࣱّ﴾</span>: ذاهِبٌ مُضْمَحِلٌّ لا دَوامَ لَهُ.</p></div>"
  54,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡوَآءَهُمۡ﴾</span>: ما تُحِبُّهُ أنفُسُهُم مِنَ الضَّلالِ والتَّكْذِيبِ.</p><p><span class="qpc-hafs">﴿أَمۡرࣲ﴾</span>: مِن خَيرٍ أوْ شَرٍّ.</p><p><span class="qpc-hafs">﴿مُّسۡتَقِرࣱّ﴾</span>: واقِعٌ بأَهْلِهِ يَوْمَ القِيامَةِ.</p></div>"
  54,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُزۡدَجَرٌ﴾</span>: كِفايَةٌ لِرَدْعِهم.</p></div>"
  54,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِكۡمَةُۢ﴾</span>: هَذا القُرْآنُ فِيهِ حِكْمَةٌ عَظِيمةٌ.</p><p><span class="qpc-hafs">﴿بَـٰلِغَةࣱ﴾</span>: بالِغَةٌ غايَتَها.</p><p><span class="qpc-hafs">﴿فَمَا﴾</span>: فأيُّ شَيءٍ.</p><p><span class="qpc-hafs">﴿تُغۡنِ﴾</span>: تَدْفَعُ أوْ تَنْفَعُ.</p><p><span class="qpc-hafs">﴿ٱلنُّذُرُ﴾</span>: الإنْذاراتُ.</p></div>"
  54,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّ﴾</span>: فَأَعْرِضْ.</p><p><span class="qpc-hafs">﴿ٱلدَّاعِ﴾</span>: المَلَكُ بنَفْخِهِ في «القَرْنِ».</p><p><span class="qpc-hafs">﴿نُّكُرٍ﴾</span>: فَظِيعٍ مُنْكَرٍ وهو موقِفُ الحِسابِ.</p></div>"
  54,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُشَّعًا﴾</span>: ذَلِيلَةً.</p><p><span class="qpc-hafs">﴿ٱلۡأَجۡدَاثِ﴾</span>: القُبُورِ.</p><p><span class="qpc-hafs">﴿مُّنتَشِرࣱ﴾</span>: مُنْبَثٌّ عَلى وجْهِ الأرْضِ.</p></div>"
  54,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّهۡطِعِينَ﴾</span>: مُسْرِعِينَ مادِّينَ أعْناقَهُم.</p><p><span class="qpc-hafs">﴿ٱلدَّاعِ﴾</span>: صوتِ المَلَكِ.</p><p><span class="qpc-hafs">﴿عَسِرࣱ﴾</span>: شَدِيدُ الهَوْلِ.</p></div>"
  54,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱزۡدُجِرَ﴾</span>: وانْتَهَرُوهُ مُتَوَعِّدِينَ إيّاهُ بأنْواعِ الأَذى.</p></div>"
  54,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡلُوبࣱ﴾</span>: ضَعِيفٌ عَن مُقاوَمةِ هَؤُلاءِ.</p><p><span class="qpc-hafs">﴿فَٱنتَصِرۡ﴾</span>: لِي بِعِقابٍ مِن عِنْدِكَ.</p></div>"
  54,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّنۡهَمِرࣲ﴾</span>: كَثِيرٍ مُتَدَفِّقٍ.</p></div>"
  54,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَجَّرۡنَا﴾</span>: وشَقَقْنا.</p><p><span class="qpc-hafs">﴿عُيُونࣰا﴾</span>: مِن عُيُونٍ مُتَفَجِّرَةٍ بالماءِ.</p><p><span class="qpc-hafs">﴿فَٱلۡتَقَى ٱلۡمَآءُ﴾</span>: فالتَقى ماءُ السَّماءِ وماءُ الأرْضِ.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ أَمۡرࣲ قَدۡ قُدِرَ﴾</span>: عَلى إهْلاكِهِم الَّذِي قَدَّرَهُ اللهُ لَهُم.</p></div>"
  54,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَاتِ أَلۡوَ ٰ⁠حࣲ﴾</span>: سَفِيَنةٍ ذاتِ ألْواحٍ.</p><p><span class="qpc-hafs">﴿وَدُسُرࣲ﴾</span>: ومَسامِيرَ شُدَّتْ بِها.</p></div>"
  54,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَعۡيُنِنَا﴾</span>: بِمَرْأىً مِنّا وحِفْظٍ.</p></div>"
  54,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَد تَّرَكۡنَـٰهَآ﴾</span>: ولَقَدْ أبْقَينا قِصَّةَ نُوحٍ.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: عِبْرةً.</p><p><span class="qpc-hafs">﴿مُّدَّكِرࣲ﴾</span>: مُتَّعِظٍ.</p></div>"
  54,16,""
  54,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسَّرۡنَا﴾</span>: سَهَّلْنا.</p><p><span class="qpc-hafs">﴿لِلذِّكۡرِ﴾</span>: لِلتِّلاوَةِ والحِفْظِ والفَهْمِ والتَّدَبُّرِ.</p></div>"
  54,18,""
  54,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡصَرࣰا﴾</span>: شَدِيدَةَ البَرْدِ والصَّوتِ.</p><p><span class="qpc-hafs">﴿نَحۡسࣲ﴾</span>: شُؤْمٍ.</p><p><span class="qpc-hafs">﴿مُّسۡتَمِرࣲّ﴾</span>: اسْتَمَرَّ بِهِمُ العَذابُ إلى أن وافى بِهِمْ جَهَنَّمَ.</p></div>"
  54,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنزِعُ ٱلنَّاسَ﴾</span>: تَقَلَعُ النّاسَ مِنَ الأرْضِ، فتَصْرَعُهم عَلى رُؤوسِهِم، فَتَنْدَقُّ رِقابُهُم وتَنْفَصِلُ عَنْ أجْسامِهِم.</p><p><span class="qpc-hafs">﴿أَعۡجَازُ﴾</span>: أُصُولُ.</p><p><span class="qpc-hafs">﴿مُّنقَعِرࣲ﴾</span>: مُنْقَلِعٍ.</p></div>"
  54,21,""
  54,22,""
  54,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلنُّذُرِ﴾</span>: بالآياتِ الَّتِي أُنْذِرُوا بِها.</p></div>"
  54,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ﴾</span>: بُعْدٍ عَنِ الصَّوابِ.</p><p><span class="qpc-hafs">﴿وَسُعُرٍ﴾</span>: جُنُونٍ.</p></div>"
  54,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَءُلۡقِيَ﴾</span>: أأُنْزِلَ.</p><p><span class="qpc-hafs">﴿ٱلذِّكۡرُ﴾</span>: الوَحْيُ والقُرآنُ.</p><p><span class="qpc-hafs">﴿أَشِرࣱ﴾</span>: صاحِبُ بَطَرٍ وتَكَبُّرٍ.</p></div>"
  54,26,""
  54,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُرۡسِلُواْ﴾</span>: مُخْرِجُو.</p><p><span class="qpc-hafs">﴿فَٱرۡتَقِبۡهُمۡ﴾</span>: اخْتِبارًا.</p><p><span class="qpc-hafs">﴿فَٱرۡتَقِبۡهُمۡ﴾</span>: فانْتَظِرْ ما يَحُلُّ عَلَيهِم مِنَ العَذابِ.</p><p><span class="qpc-hafs">﴿وَٱصۡطَبِر﴾</span>: واصْبِرْ عَلى الأَذى الَّذِي يُصِيبُكَ مِنَ المدْعُوِّينَ.</p></div>"
  54,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَبِّئۡهُمۡ﴾</span>: وأَخْبِرْهُم.</p><p><span class="qpc-hafs">﴿قِسۡمَةُۢ﴾</span>: مَقْسُومٌ.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمۡ﴾</span>: بَيْنَ ثَمُودَ والنّاقَةِ.</p><p><span class="qpc-hafs">﴿كُلُّ شِرۡبࣲ﴾</span>: كُلُّ نَصِيبٍ مِن الشَّرابِ.</p><p><span class="qpc-hafs">﴿مُّحۡتَضَرࣱ﴾</span>: يَحْضُرُهُ صاحِبُهُ ويَسْتَحِقُّهُ.</p></div>"
  54,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَعَاطَىٰ﴾</span>: فَتَناوَلَ النّاقَةَ بِيَدِهِ لِيَعْقِرَها.</p><p><span class="qpc-hafs">﴿فَعَقَرَ﴾</span>: فَقَتَلَ.</p></div>"
  54,30,""
  54,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَهَشِيمِ﴾</span>: كالشَّجَرِ اليابِسِ الَّذِي يَسْقُطُ ويَتَناثَرُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُحۡتَظِرِ﴾</span>: الَّذِي يُرِيدُ أن يَعْمَلَ سِياجًا لِحِفْظِ المواشِي فَيَحْتَطِبَ لِذَلِكَ.</p></div>"
  54,32,""
  54,33,""
  54,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاصِبًا﴾</span>: رِيحًا شَدِيدَةً تَرْمِيهِم بِحِجارَةٍ.</p><p><span class="qpc-hafs">﴿بِسَحَرࣲ﴾</span>: في آخِرِ الليلِ.</p></div>"
  54,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَجۡزِي﴾</span>: نُثِيبُ.</p><p><span class="qpc-hafs">﴿مَن شَكَرَ﴾</span>: مَن آمَنَ بِاللهِ ووَحّدَهُ.</p></div>"
  54,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدۡ أَنذَرَهُم﴾</span>: خَوَّفَهُم.</p><p><span class="qpc-hafs">﴿بَطۡشَتَنَا﴾</span>: بَأْسَنا وعَذابَنا.</p><p><span class="qpc-hafs">﴿فَتَمَارَوۡاْ﴾</span>: فَشَكُّوا.</p><p><span class="qpc-hafs">﴿بِٱلنُّذُرِ﴾</span>: بالإنْذارِ.</p></div>"
  54,37,""
  54,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَبَّحَهُم بُكۡرَةً﴾</span>: جاءَهُم وقْتَ الصَّباحِ.</p><p><span class="qpc-hafs">﴿مُّسۡتَقِرࣱّ﴾</span>: نازلٌ بِهم.</p></div>"
  54,39,""
  54,40,""
  54,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَالَ فِرۡعَوۡنَ﴾</span>: أتْباعَ فِرْعَونَ.</p><p><span class="qpc-hafs">﴿ٱلنُّذُرُ﴾</span>: الإنْذارُ تِلْو الإنْذارِ مِن مُوسى عَلَيهِ السَّلامُ بالعُقُوبةِ عَلى كُفْرِهِم.</p></div>"
  54,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بِأَدلَّتِنا الدّالّةِ عَلى وحْدانِيَّتِنا ونُبُوَّةِ أنْبِيائِنا.</p><p><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُمۡ﴾</span>: فَعاقَبْناهُم.</p><p><span class="qpc-hafs">﴿عَزِيزࣲ﴾</span>: لا يُغالَبُ.</p><p><span class="qpc-hafs">﴿مُّقۡتَدِرٍ﴾</span>: قادِرٍ عَلى هَلاكِكُم.</p></div>"
  54,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكُفَّارُكُمۡ﴾</span>: يا مَعْشَرَ العَرَبِ.</p><p><span class="qpc-hafs">﴿بَرَآءَةࣱ﴾</span>: مِنَ العذابِ ألّا يُصِيبَكُم ما أصابَهُم.</p><p><span class="qpc-hafs">﴿ٱلزُّبُرِ﴾</span>: الكُتُبِ المنَزَّلةِ عَلى الأنبياءِ المُتقَدِّمِينَ.</p></div>"
  54,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمِيعࣱ﴾</span>: نَحْنَ يَدٌ واحِدَةٌ عَلى مَن خالَفَنا.</p><p><span class="qpc-hafs">﴿مُّنتَصِرࣱ﴾</span>: نَغْلِبُ غَيرَنا.</p></div>"
  54,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَمۡعُ﴾</span>: جَمْعُ كُفّارِ مَكَّةَ أمامَ المُؤمِنِينَ.</p></div>"
  54,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَدۡهَىٰ﴾</span>: أفْظَعُ وأَعْظَمُ.</p><p><span class="qpc-hafs">﴿وَأَمَرُّ﴾</span>: أشدُّ مَرارَةً مِنَ القَتْلِ والأَسْرِ.</p></div>"
  54,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ﴾</span>: تِيهٍ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿وَسُعُرࣲ﴾</span>: جُنُونٍ أو نارٍ تَسْتَعِرُ عَلَيهِم.</p></div>"
  54,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُسۡحَبُونَ﴾</span>: يُجَرُّونَ.</p><p><span class="qpc-hafs">﴿مَسَّ سَقَرَ﴾</span>: شِدَّةَ عَذابِ جَهَنَّمَ.</p></div>"
  54,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِقَدَرࣲ﴾</span>: بمِقَدارٍ قَدَّرْناهُ، وسَبَق عِلْمُنا بِهِ، وكِتابَتُنا لَهُ في اللَّوحِ المَحْفُوظِ.</p></div>"
  54,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَ ٰ⁠حِدَةࣱ﴾</span>: قَوْلَةٌ واحِدَةٌ، وهي «كُنْ».</p><p><span class="qpc-hafs">﴿كَلَمۡحِۭ بِٱلۡبَصَرِ﴾</span>: فَيُوجَدُ في أقْصَرِ وقْتٍ.</p></div>"
  54,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَشۡيَاعَكُمۡ﴾</span>: أشْباهَكُم في الكُفْرِ مِنَ الأُمَمِ السّابِقَةِ.</p><p><span class="qpc-hafs">﴿مُّدَّكِرࣲ﴾</span>: مُتَّعِظٍ.</p></div>"
  54,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلزُّبُرِ﴾</span>: الكُتَبِ الَّتِي كَتَبَتْها الحَفَظَةُ.</p></div>"
  54,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّسۡتَطَرٌ﴾</span>: مُسَطَّرٌ في صَحائِفِهم.</p></div>"
  54,54,""
  54,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقۡعَدِ صِدۡقٍ﴾</span>: مَجْلِسِ حَقٍّ.</p><p><span class="qpc-hafs">﴿مَلِيكࣲ﴾</span>: اللهِ الملِكِ العَظِيمِ.</p><p><span class="qpc-hafs">﴿مُّقۡتَدِرِۭ﴾</span>: عَظِيمِ القُدْرَةِ.</p></div>"
