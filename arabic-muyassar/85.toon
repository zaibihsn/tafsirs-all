quran[22]{c,v,t}:
  85,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَاتِ ٱلۡبُرُوجِ﴾</span>: ذاتِ المنازِل.</p></div>"
  85,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡيَوۡمِ ٱلۡمَوۡعُودِ﴾</span>: أقَسَم اللهُ تَعالى بِاليَومِ الَّذِي وعَدَ اللهُ الخلْقَ أن يَجْمَعَهُم فِيهِ.</p></div>"
  85,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَاهِدࣲ﴾</span>: الرائِي، أو الُمخْبِرِ بِحَقٍّ.</p><p><span class="qpc-hafs">﴿وَمَشۡهُودࣲ﴾</span>: المَرئي، أو المشهود عليه بحق.</p></div>"
  85,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُتِلَ﴾</span>: لُعِنَ.</p><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡأُخۡدُودِ﴾</span>: الَّذِين شَقُّوا في الأرضِ شَقًّا عَظِيمًا؛ لِتَعذِيبِ المؤمِنِينَ.</p></div>"
  85,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَقُودِ﴾</span>: ما تُوقَدُ بِهِ النّارُ مِن حَطَبٍ ونَحوِهِ.</p></div>"
  85,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذۡ هُمۡ﴾</span>: هَؤُلاءِ الكُفّارُ مِن أصحابِ الأُخْدُودِ.</p><p><span class="qpc-hafs">﴿عَلَيۡهَا﴾</span>: عَلى حافَةِ النّارِ الَّتِي في الأُخْدُودِ.</p></div>"
  85,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُهُودࣱ﴾</span>: حُضُورٌ.</p></div>"
  85,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا نَقَمُواْ﴾</span>: وما أنْكَرُوا عَلَيهِم.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزِ﴾</span>: الشَّدِيدِ في انْتِقامِهِ مِمَّن انْتَقَمَ مِنهُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيدِ﴾</span>: الَمحْمودِ في أقْوالِهِ وأَفْعالِهِ.</p></div>"
  85,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدٌ﴾</span>: مُطَّلِعٌ لا يَخْفى عَلَيهِ شَيءٌ.</p></div>"
  85,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنُواْ﴾</span>: حَرَّقُوا.</p></div>"
  85,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: مِن تَحْتِ قُصُورِها وأَشْجارِها.</p></div>"
  85,12,""
  85,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبۡدِئُ﴾</span>: يَبْدَأُ الخَلْقَ.</p><p><span class="qpc-hafs">﴿وَيُعِيدُ﴾</span>: الخَلْقَ لِلْحِسابِ.</p></div>"
  85,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَفُورُ﴾</span>: لمِن تابَ.</p><p><span class="qpc-hafs">﴿ٱلۡوَدُودُ﴾</span>: كَثِيرُ المحَبَّةِ لأوليائِهِ.</p></div>"
  85,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُو ٱلۡعَرۡشِ﴾</span>: صاحِبُ العرْشِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَجِيدُ﴾</span>: الَّذِي بَلَغَ المُنْتَهى في الفَضلِ.</p></div>"
  85,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَّالࣱ لِّمَا يُرِيدُ﴾</span>: لا يَمْتَنِعُ عَلَيهِ شَيءٌ يُريدُهُ.</p></div>"
  85,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَدِيثُ ٱلۡجُنُودِ﴾</span>: خَبَرُ الجُمُوعِ الكافِرةِ المُكَذِّبةِ لأَنْبِيائِها.</p></div>"
  85,18,""
  85,19,""
  85,20,""
  85,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّجِيدࣱ﴾</span>: عَظِيمٌ كَرِيمٌ.</p></div>"
  85,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي لَوۡحࣲ مَّحۡفُوظِۭ﴾</span>: لا ينالُه تَبْدِيلٌ ولا تَحْرِيفٌ.</p></div>"
