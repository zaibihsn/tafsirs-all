quran[88]{c,v,t}:
  28,1,""
  28,2,""
  28,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّبَإِ مُوسَىٰ﴾</span>: خَبَرِ مُوسى.</p><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالصِّدْقِ.</p></div>"
  28,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَا﴾</span>: تَجَبَّرَ وتكَبَّرَ.</p><p><span class="qpc-hafs">﴿شِيَعࣰا﴾</span>: طَوائِفَ مُتَفَرِّقةً.</p><p><span class="qpc-hafs">﴿وَيَسۡتَحۡيِۦ نِسَآءَهُمۡ﴾</span>: أي: يَسْتَبْقِيهِنَّ للخِدْمَةِ والامْتِهانِ.</p></div>"
  28,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن نَّمُنَّ﴾</span>: أن نَتَفَضَّلَ.</p><p><span class="qpc-hafs">﴿أَئِمَّةࣰ﴾</span>: قادَةً في الخيرِ.</p><p><span class="qpc-hafs">﴿ٱلۡوَ ٰ⁠رِثِينَ﴾</span>: أي: ورِثُوا أرضَ مِصْرَ بَعْدَ هَلاكِ فِرْعَونَ وقَومِهِ.</p></div>"
  28,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُمَكِّنَ﴾</span>: ونُثَبِّتَ لهم.</p><p><span class="qpc-hafs">﴿يَحۡذَرُونَ﴾</span>: يَخافُونَ.</p></div>"
  28,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَوۡحَيۡنَآ﴾</span>: وألْهَمْنا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡيَمِّ﴾</span>: في نَهْرِ النِّيلِ.</p></div>"
  28,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡتَقَطَهُۥٓ﴾</span>: فأخَذَهُ.</p><p><span class="qpc-hafs">﴿لِيَكُونَ﴾</span>: أي: في المآلِ والعاقِبَةِ.</p></div>"
  28,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُرَّتُ عَيۡنࣲ﴾</span>: مَصْدرُ سُرورٍ وسَعادةٍ تَقَرُّ العَينُ بِهِ.</p></div>"
  28,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُؤَادُ﴾</span>: قَلْبُ.</p><p><span class="qpc-hafs">﴿فَـٰرِغًا﴾</span>: خالِيًا مِن كلِّ شَيءٍ، ليمْلَأَه هَمُّ مُوسى وذِكْرُه.</p><p><span class="qpc-hafs">﴿لَتُبۡدِي بِهِۦ﴾</span>: لَتُظْهِرُ أنَّ مُوسى ابْنُها.</p><p><span class="qpc-hafs">﴿أَن رَّبَطۡنَا﴾</span>: أن ثبَّتناها بالصَّبرِ والثَّباتِ.</p></div>"
  28,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُصِّيهِ﴾</span>: اتَّبعِي أثَرَ مُوسى وتَعَرَّفي خَبَرَه.</p><p><span class="qpc-hafs">﴿عَن جُنُبࣲ﴾</span>: عن بُعدٍ.</p></div>"
  28,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَرَّمۡنَا عَلَيۡهِ﴾</span>: أي: مَنَعْناهُ مِن قَبُولِ الرَّضاعَةِ.</p><p><span class="qpc-hafs">﴿يَكۡفُلُونَهُۥ﴾</span>: يقُومُونَ بإرْضاعِه وتَرْبِيَتِهِ.</p><p><span class="qpc-hafs">﴿نَـٰصِحُونَ﴾</span>: مُشْفِقُونَ.</p></div>"
  28,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡ تَقَرَّ عَيۡنُهَا﴾</span>: كَي تُسَرَّ أمُّ مُوسى بِسَلامَةِ ولَدِها ورُجُوعِهِ إليها.</p></div>"
  28,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَشُدَّهُۥ وَٱسۡتَوَىٰٓ﴾</span>: أي: مُنْتَهى قُوَّتِه، وتكامَلَ عَقْلُه.</p><p><span class="qpc-hafs">﴿ءَاتَيۡنَـٰهُ حُكۡمࣰا وَعِلۡمࣰا﴾</span>: أعْطَيناه حِكْمَةً وفَهْمًا ومَعْرِفَةً بالدِّينِ.</p></div>"
  28,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ حِينِ غَفۡلَةࣲ﴾</span>: وقْتِ غَفْلَةِ أهْلِها.</p><p><span class="qpc-hafs">﴿فَٱسۡتَغَـٰثَهُ﴾</span>: فَطَلَبَ الغَوثَ والنَّصْرَ مِن مُوسى عَلَيهِ الصَّلاةُ والسَّلامُ.</p><p><span class="qpc-hafs">﴿مِن شِيعَتِهِۦ﴾</span>: أي: مِن بَنِي إسْرائِيلَ قَومِ مُوسى عَلَيهِ الصَّلاةُ والسَّلامُ.</p><p><span class="qpc-hafs">﴿ٱلَّذِي مِنۡ عَدُوِّهِۦ﴾</span>: أي: القِبْطِيِّ الَّذي كان مِن قَومِ فِرْعَونَ.</p><p><span class="qpc-hafs">﴿فَوَكَزَهُۥ﴾</span>: ضَرَبَه مُوسى بجُمْعِ كَفِّه.</p><p><span class="qpc-hafs">﴿فَقَضَىٰ عَلَيۡهِ﴾</span>: قَتَلَه.</p></div>"
  28,16,""
  28,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَهِيرࣰا﴾</span>: مُعِينًا.</p></div>"
  28,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَرَقَّبُ﴾</span>: يَتَوَقَّعُ المكْرُوهَ ويُراقِبُ ما يَحْدُثُ.</p><p><span class="qpc-hafs">﴿يَسۡتَصۡرِخُهُۥ﴾</span>: يَطْلُبُ مِنهُ النَّصْرَ.</p><p><span class="qpc-hafs">﴿لَغَوِيࣱّ﴾</span>: لَشَدِيدُ الضَّلالِ وسُوءِ النَّظرِ.</p></div>"
  28,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَبۡطِشَ﴾</span>: أن يَأْخُذَ بقوَّةٍ وعُنْفٍ.</p></div>"
  28,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَقۡصَا ٱلۡمَدِينَةِ﴾</span>: آخِرِ المدينةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَلَأَ﴾</span>: أشْرافَ القَومِ.</p><p><span class="qpc-hafs">﴿يَأۡتَمِرُونَ﴾</span>: يَتَشاورُونَ في شَأْنِكَ.</p><p><span class="qpc-hafs">﴿ٱلنَّـٰصِحِينَ﴾</span>: المُشْفِقِينَ.</p></div>"
  28,21,""
  28,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تِلۡقَآءَ مَدۡيَنَ﴾</span>: جِهَةَ مَدْيَنَ.</p><p><span class="qpc-hafs">﴿سَوَآءَ ٱلسَّبِيلِ﴾</span>: أي: الطَّرِيقَ المُسْتَويَ إلى مَدْيَنَ.</p></div>"
  28,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَدَ﴾</span>: بَلَغَ.</p><p><span class="qpc-hafs">﴿أُمَّةࣰ﴾</span>: جَماعةً.</p><p><span class="qpc-hafs">﴿تَذُودَانِ﴾</span>: تَحبِسانِ غَنَمَهُما عَنِ الماءِ.</p><p><span class="qpc-hafs">﴿مَا خَطۡبُكُمَا﴾</span>: ما شَأْنُكما؟</p><p><span class="qpc-hafs">﴿يُصۡدِرَ ٱلرِّعَآءُ﴾</span>: يَنْصَرِفَ الرُّعاةُ بِمَواشِيهِم عَنِ الماءِ.</p></div>"
  28,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّىٰٓ إِلَى ٱلظِّلِّ﴾</span>: رَجَعَ إليه.</p></div>"
  28,25,""
  28,26,""
  28,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَأۡجُرَنِي﴾</span>: تَكُونَ لي أجِيرًا في رَعْيِ الغَنَمِ.</p><p><span class="qpc-hafs">﴿حِجَجࣲ﴾</span>: سِنِينَ.</p></div>"
  28,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّمَا ٱلۡأَجَلَيۡنِ﴾</span>: أيَّ المُدَّتَينِ.</p><p><span class="qpc-hafs">﴿قَضَيۡتُ﴾</span>: وفَّيتُ به وأتْمَمْتُه.</p><p><span class="qpc-hafs">﴿فَلَا عُدۡوَ ٰ⁠نَعَلَيَّ﴾</span>: لا اعْتِداءَ ولا ظُلْمَ عليّ بالمطالَبَةِ بأكْثَرَ مِنه.</p><p><span class="qpc-hafs">﴿وَكِيلࣱ﴾</span>: شاهِدٌ وحَفِيظٌ.</p></div>"
  28,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَجَلَ﴾</span>: المُدَّةَ المُتَّفَقَ عَلَيها وهي عَشْرُ سِنِينَ.</p><p><span class="qpc-hafs">﴿ءَانَسَ﴾</span>: أبصَرَ ما يُؤْنِسُ.</p><p><span class="qpc-hafs">﴿جَذۡوَةࣲ﴾</span>: جَمْرَةٍ وشُعْلَةٍ.</p><p><span class="qpc-hafs">﴿تَصۡطَلُونَ﴾</span>: تَسْتَدْفِئُونَ بِها.</p></div>"
  28,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَـٰطِيِٕ﴾</span>: جانِبِ.</p><p><span class="qpc-hafs">﴿ٱلۡبُقۡعَةِ﴾</span>: القِطْعَةِ مِنَ الأرْضِ.</p></div>"
  28,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَهۡتَزُّ﴾</span>: تتحرَّكُ بخِفَّةٍ.</p><p><span class="qpc-hafs">﴿جَآنࣱّ﴾</span>: حَيَّةٌ خَفِيفَةٌ في سُرْعَةِ حرَكَتِها.</p><p><span class="qpc-hafs">﴿وَلَّىٰ﴾</span>: هَرَبَ.</p><p><span class="qpc-hafs">﴿وَلَمۡ يُعَقِّبۡ﴾</span>: لم يَرْجِعْ.</p><p><span class="qpc-hafs">﴿أَقۡبِلۡ﴾</span>: تَقَدَّمْ.</p></div>"
  28,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡلُكۡ﴾</span>: أدْخِلْ.</p><p><span class="qpc-hafs">﴿فِي جَيۡبِكَ﴾</span>: في فَتْحَةِ قَمِيصِكَ الَّتِي يُدْخَلُ مِنها الرَّأسُ.</p><p><span class="qpc-hafs">﴿مِنۡ غَيۡرِ سُوٓءࣲ﴾</span>: مِن غَيرِ مَرَضٍ ولا بَرَصٍ.</p><p><span class="qpc-hafs">﴿جَنَاحَكَ﴾</span>: يَدَكَ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلرَّهۡبِ﴾</span>: لِتَأْمَنَ مِنَ الخَوْفِ.</p><p><span class="qpc-hafs">﴿وَمَلَإِيْهِۦٓ﴾</span>: أشْرافِ قومهِ.</p></div>"
  28,33,""
  28,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِدۡءࣰا﴾</span>: مُعِينًا.</p></div>"
  28,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنَشُدُّ عَضُدَكَ﴾</span>: سَنُقَوِّيكَ ونُعِينُكَ.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً أو مَهابَةً في قُلُوبِ الأعْداءِ.</p></div>"
  28,36,""
  28,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰقِبَةُ ٱلدَّارِ﴾</span>: العاقِبةُ المحْمُودَةُ في الدّارِ الآخِرَةِ.</p></div>"
  28,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: الأشْرافُ مِن قَومِه.</p><p><span class="qpc-hafs">﴿فَأَوۡقِدۡ﴾</span>: فَأَشْعِلْ.</p><p><span class="qpc-hafs">﴿صَرۡحࣰا﴾</span>: قَصْرًا.</p><p><span class="qpc-hafs">﴿أَطَّلِعُ﴾</span>: أنظُرُ.</p></div>"
  28,39,""
  28,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنَبَذۡنَـٰهُمۡ فِي ٱلۡيَمِّ﴾</span>: فَطَرَحْناهُمْ في البَحْرِ، فَأَغْرَقَنْاهُم.</p></div>"
  28,41,""
  28,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنَ ٱلۡمَقۡبُوحِينَ﴾</span>: مِنَ المذْمُومِينَ والمُبْعَدِينَ مِن كُلِّ خَيْرٍ.</p></div>"
  28,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقُرُونَ ٱلۡأُولَىٰ﴾</span>: الأُمَمَ الماضِيَةَ.</p></div>"
  28,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَضَيۡنَآ إِلَىٰ مُوسَى﴾</span>: عَهِدْنا إليهِ وكَلَّفْناهُ.</p><p><span class="qpc-hafs">﴿ٱلۡأَمۡرَ﴾</span>: أي: أمْرَ الرِّسالَةِ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلشَّـٰهِدِينَ﴾</span>: مِنَ الحاضِرِينَ في ذلك الوقتِ.</p></div>"
  28,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنشَأۡنَا﴾</span>: خَلَقْنا.</p><p><span class="qpc-hafs">﴿قُرُونࣰا﴾</span>: أُمَمًا.</p><p><span class="qpc-hafs">﴿فَتَطَاوَلَ عَلَيۡهِمُ ٱلۡعُمُرُ﴾</span>: امْتَدَّ عَلَيهِمُ الزَّمانُ.</p><p><span class="qpc-hafs">﴿ثَاوِيࣰا﴾</span>: مُقِيمًا.</p></div>"
  28,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطُّورِ﴾</span>: جَبَلِ طُورِ سَيناءَ.</p></div>"
  28,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾</span>: أي: بِسَبَبِ أعْمالِهِم السَّيِّئَةِ.</p></div>"
  28,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوتِيَ﴾</span>: أُعْطِيَ.</p><p><span class="qpc-hafs">﴿سِحۡرَانِ﴾</span>: أي: التَّوراةُ والقرآنُ حَسَبَ زَعْمِهِم، أو هُما ذَوا سِحْرٍ، أي: مُوسى ومُحَمَّدٌ  عليهما الصَّلاةُ والسَّلامُ  حَسَبَ زَعْمِهِم.</p></div>"
  28,49,""
  28,50,""
  28,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَّلۡنَا لَهُمُ ٱلۡقَوۡلَ﴾</span>: أي: نَزَّلْنا عَلَيهِم القرآنَ يَتْبَعُ بَعْضُهُ بَعْضًا.</p></div>"
  28,52,""
  28,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسۡلِمِينَ﴾</span>: أي: مُخْلِصِينَ للهِ بالتوحيدِ.</p></div>"
  28,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَدۡرَءُونَ﴾</span>: يَدْفَعُونَ.</p></div>"
  28,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّغۡوَ﴾</span>: السّاقِطَ مِنَ القَوْلِ.</p><p><span class="qpc-hafs">﴿لَا نَبۡتَغِي﴾</span>: لا نُرِيدُ ولا نُحِبُّ.</p></div>"
  28,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَهۡدِي﴾</span>: أي: هِدايةَ توفِيقٍ.</p></div>"
  28,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُتَخَطَّفۡ﴾</span>: نُخْتلَسْ ونُسْتَلَبْ قَتْلًا وأسْرًا.</p><p><span class="qpc-hafs">﴿أَوَ لَمۡ نُمَكِّن لَّهُمۡ حَرَمًا ءَامِنࣰا﴾</span>: أولم نَجْعَلْهُم يَنْعَمُونَ بالأمْنِ والتَّمكِينِ في البلدِ الحرامِ.</p><p><span class="qpc-hafs">﴿يُجۡبَىٰٓ إِلَيۡهِ﴾</span>: يُجْلَبُ إليه.</p></div>"
  28,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَمۡ﴾</span>: كَثِيرًا.</p><p><span class="qpc-hafs">﴿بَطِرَتۡ مَعِيشَتَهَا﴾</span>: طَغَتْ وكَفَرتْ نِعْمَةَ العَيشِ بالرَّغَدِ.</p><p><span class="qpc-hafs">﴿ٱلۡوَ ٰ⁠رِثِينَ﴾</span>: أي: للعِباد بَعْدَ إهْلاكِهم.</p></div>"
  28,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أُمِّهَا﴾</span>: وهي مَكَّة المكَرَّمةُ، وتُعْرَفُ بأمِّ القُرى.</p></div>"
  28,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أُوتِيتُم﴾</span>: وما أُعْطِيتُم.</p></div>"
  28,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعۡدًا حَسَنࣰا﴾</span>: أي: بِدُخُولِ الجنَّةِ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُحۡضَرِينَ﴾</span>: أي: مِمَّن أُحْضِرُوا لِلْحِسابِ والعَذابِ.</p></div>"
  28,62,""
  28,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾</span>: وجَبَ لهم العَذابُ.</p><p><span class="qpc-hafs">﴿أَغۡوَيۡنَآ﴾</span>: أضْلَلْنا.</p><p><span class="qpc-hafs">﴿تَبَرَّأۡنَآ﴾</span>: أي: مِن عِبادتِهم إيّانا.</p></div>"
  28,64,""
  28,65,""
  28,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَمِيَتۡ عَلَيۡهِمُ ٱلۡأَنۢبَآءُ﴾</span>: فَخَفِيَتْ عَلَيهِمُ الأَخْبارُ الَّتي كانُوا يَحْتَجُّونَ بِها.</p></div>"
  28,67,""
  28,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخِيَرَةُ﴾</span>: الاخْتِيارُ.</p></div>"
  28,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تُكِنُّ﴾</span>: ما تُخْفِي.</p></div>"
  28,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأُولَىٰ﴾</span>: الحَياةِ الأُولى هي الدُّنيا.</p><p><span class="qpc-hafs">﴿وَٱلۡـَٔاخِرَةِ﴾</span>: الدّارِ الآخرةِ.</p></div>"
  28,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أي: أخْبِرُونِي.</p><p><span class="qpc-hafs">﴿سَرۡمَدًا﴾</span>: دائِمًا مُسْتَمِرًّا.</p><p><span class="qpc-hafs">﴿بِضِيَآءٍ﴾</span>: بنُورٍ.</p></div>"
  28,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡكُنُونَ فِيهِ﴾</span>: تَسْتَقِرُّونَ فِيه مِنَ التَّعَبِ.</p></div>"
  28,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَسۡكُنُواْ فِيهِ﴾</span>: لِتَسْتَقِرُّوا في اللَّيلِ وتَرْتاحَ أبْدانُكُم.</p><p><span class="qpc-hafs">﴿لِتَبۡتَغُواْ مِن فَضۡلِهِۦ﴾</span>: لِتطْلُبُوا وتَلْتَمِسُوا مِن رِزْقِهِ.</p></div>"
  28,74,""
  28,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعۡنَا﴾</span>: وأَخْرَجْنا.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: وهو نَبِيُّ كُلِّ أُمَّةٍ.</p><p><span class="qpc-hafs">﴿هَاتُواْ بُرۡهَـٰنَكُمۡ﴾</span>: أحْضِرُوا حُجَّتَكُم.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَخْتَلِقُونَ.</p></div>"
  28,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَغَىٰ عَلَيۡهِمۡ﴾</span>: تَكَبَّرَ عَلَيهِم.</p><p><span class="qpc-hafs">﴿وَءَاتَيۡنَـٰهُ﴾</span>: وأعْطَيناهُ.</p><p><span class="qpc-hafs">﴿ٱلۡكُنُوزِ﴾</span>: الأمْوالِ المدَّخَرَةِ في الخَزائِنِ.</p><p><span class="qpc-hafs">﴿لَتَنُوٓأُ بِٱلۡعُصۡبَةِ﴾</span>: لَتُثْقِلُ الجَماعَةَ الكَثِيرَةَ.</p><p><span class="qpc-hafs">﴿أُوْلِي ٱلۡقُوَّةِ﴾</span>: أصْحابِ القُوَّةِ، الأقْوِياءِ.</p><p><span class="qpc-hafs">﴿لَا تَفۡرَحۡ﴾</span>: لا تَبْطَرْ فَرَحًا بِكَثْرَةِ المالِ.</p></div>"
  28,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱبۡتَغِ﴾</span>: والتَمِسْ.</p><p><span class="qpc-hafs">﴿ءَاتَىٰكَ﴾</span>: أعْطاكَ.</p><p><span class="qpc-hafs">﴿وَلَا تَنسَ نَصِيبَكَ﴾</span>: ولا تَترُكْ حَظَّكَ مِنَ الدُّنيا.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡغِ﴾</span>: ولا تَلْتمِسْ.</p></div>"
  28,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوتِيتُهُۥ﴾</span>: أُعْطِيتُ هَذا المالَ.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡقُرُونِ﴾</span>: مِنَ الأُمَمِ.</p></div>"
  28,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوتِيَ﴾</span>: أُعطِيَ.</p><p><span class="qpc-hafs">﴿لَذُو حَظٍّ﴾</span>: لَصاحِبُ نَصِيبٍ.</p></div>"
  28,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوتُواْ﴾</span>: أُعطُوا.</p><p><span class="qpc-hafs">﴿وَيۡلَكُمۡ﴾</span>: زَجْرٌ لهم عَنْ هَذا التَّمَنِّي.</p><p><span class="qpc-hafs">﴿وَلَا يُلَقَّىٰهَآ﴾</span>: أي: لا يُعطى تِلْكَ الخَصْلَةَ أوِ الجنَّةَ.</p></div>"
  28,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَخَسَفۡنَا بِهِۦ﴾</span>: أي: فَجَعَلْنا الأرضَ تَبْتَلِعُهُ وهو حَيٌّ.</p><p><span class="qpc-hafs">﴿فِئَةࣲ﴾</span>: جَماعَةٍ.</p></div>"
  28,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡكَأَنَّ﴾</span>: كَلِمَةُ تَندُّمٍ وتَفَجُّعٍ، أي: ألمْ تَعْلَمْ.</p><p><span class="qpc-hafs">﴿يَبۡسُطُ﴾</span>: يُوسِّعُ.</p><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: يُضَيِّقُ.</p><p><span class="qpc-hafs">﴿مَّنَّ﴾</span>: أنْعَمَ.</p><p><span class="qpc-hafs">﴿وَيۡكَأَنَّهُۥ﴾</span>: ألَمْ تَعْلَمْ.</p></div>"
  28,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُلُوࣰّا﴾</span>: تَكَبُّرًا.</p><p><span class="qpc-hafs">﴿وَٱلۡعَـٰقِبَةُ﴾</span>: أي: العاقِبةُ المحْمُودَةُ، وهي الجنَّةُ.</p></div>"
  28,84,""
  28,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَضَ﴾</span>: أي: أنْزَلَ وأَوْجَبَ عَلَيكَ العَمَلَ بِمُقْتَضاه.</p><p><span class="qpc-hafs">﴿لَرَآدُّكَ﴾</span>: لَمُرْجِعُكَ.</p><p><span class="qpc-hafs">﴿إِلَىٰ مَعَادࣲ﴾</span>: المرادُ بِهِ هُنا «مَكَّةُ».</p><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينࣲ﴾</span>: انحِرافٍ واضِحٍ.</p></div>"
  28,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡجُوٓاْ﴾</span>: تَتَوَقَّعُ وتَنْتَظِرُ.</p><p><span class="qpc-hafs">﴿أَن يُلۡقَىٰٓ﴾</span>: أي: أن يُنزَّلَ.</p><p><span class="qpc-hafs">﴿ظَهِيرࣰا﴾</span>: مُعِينًا.</p></div>"
  28,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَصُدُّنَّكَ﴾</span>: ولا يَصْرِفُنَّكَ.</p></div>"
  28,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا وَجۡهَهُۥ﴾</span>: إلّا إيّاهُ، أو إلّا ما أُرِيدَ به وجْهُه.</p><p><span class="qpc-hafs">﴿ٱلۡحُكۡمُ﴾</span>: القَضاءُ النّافِذُ، يَقْضِي بما شاءَ.</p></div>"
