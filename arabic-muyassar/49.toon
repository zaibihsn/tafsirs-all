quran[18]{c,v,t}:
  49,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُقَدِّمُواْ﴾</span>: لا تَقْطَعُوا أمرًْا دُونَ اللهِ ورَسُولِهِ.</p></div>"
  49,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن تَحۡبَطَ﴾</span>: خَشْيَة أن تَبْطُلَ.</p><p><span class="qpc-hafs">﴿لَا تَشۡعُرُونَ﴾</span>: لا تُحِسُّونَ.</p></div>"
  49,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغُضُّونَ﴾</span>: يَخْفِضُونَ.</p><p><span class="qpc-hafs">﴿ٱمۡتَحَنَ﴾</span>: اخْتَبَرَ.</p></div>"
  49,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُجُرَ ٰ⁠تِ﴾</span>: غُرَفِ النَّبِيِّ ﷺ.</p></div>"
  49,5,""
  49,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاسِقُۢ﴾</span>: خارِجٌ عَن طاعَة اللهِ ورَسُولِهِ بارْتِكابِ الكبائِرِ.</p><p><span class="qpc-hafs">﴿بِنَبَإࣲ﴾</span>: بأيِّ خَبَرٍ.</p><p><span class="qpc-hafs">﴿فَتَبَيَّنُوٓاْ﴾</span>: فَتَبَيَّنُوا الحقَّ مِن غَيرِ جِهَةِ الفاسِقِ.</p><p><span class="qpc-hafs">﴿أَن تُصِيبُواْ﴾</span>: خَشْيةَ أن تُصِيبُوا بضُرٍّ.</p><p><span class="qpc-hafs">﴿بِجَهَـٰلَةࣲ﴾</span>: مُتَلَبّسِينَ بِعَدَمِ العِلمِ.</p><p><span class="qpc-hafs">﴿فَتُصۡبِحُواْ﴾</span>: فتَصِيرُوا.</p></div>"
  49,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعَنِتُّمۡ﴾</span>: لَوَقَعْتُم في مَشَقَّةٍ وضَرَرٍ وإثْمٍ.</p><p><span class="qpc-hafs">﴿ٱلرَّ ٰ⁠شِدُونَ﴾</span>: المُسْتَقِيمُونَ عَلى طَرِيقِ الحقِّ.</p></div>"
  49,8,""
  49,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَغَتۡ﴾</span>: اعْتَدَتْ، ولم تَقْبَلِ الصُّلْحَ.</p><p><span class="qpc-hafs">﴿تَفِيٓءَ﴾</span>: تَرْجِعَ.</p><p><span class="qpc-hafs">﴿وَأَقۡسِطُوٓاْ﴾</span>: واعْدِلُوا.</p><p><span class="qpc-hafs">﴿ٱلۡمُقۡسِطِينَ﴾</span>: العادِلِينَ.</p></div>"
  49,10,""
  49,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡخَرۡ﴾</span>: يَهْزَأْ.</p><p><span class="qpc-hafs">﴿وَلَا تَلۡمِزُوٓاْ أَنفُسَكُمۡ﴾</span>: ولا يِعِبْ بَّعْضُكُم بَعْضا.</p><p><span class="qpc-hafs">﴿وَلَا تَنَابَزُواْ﴾</span>: ولا يَدْعُ بعضُكُم بَعْضًا.</p><p><span class="qpc-hafs">﴿بِٱلۡأَلۡقَـٰبِ﴾</span>: بِما يَكْرَهُ مِنَ الألقابِ.</p><p><span class="qpc-hafs">﴿ٱلِٱسۡمُ﴾</span>: الذِّكْرُ والتَّسمِيَةُ.</p><p><span class="qpc-hafs">﴿ٱلۡفُسُوقُ﴾</span>: ما ذُكِرَ مِنَ السُّخْرِيَةِ واللَّمْزِ والتنابُزِ بالألقابِ.</p></div>"
  49,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَجَسَّسُواْ﴾</span>: ولا تُفَتِّشُوا عَنْ عَوْراتِ المُسْلِمِينَ، وتَبْحَثُوا عَنْ أخْبارِهِم.</p><p><span class="qpc-hafs">﴿وَلَا يَغۡتَب بَّعۡضُكُم بَعۡضًا﴾</span>: ولا يَذْكُرْ بَعْضُكُم بَعْضًا بِما يَكْرَهُ في غَيبَتِهِ.</p></div>"
  49,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُعُوبࣰا﴾</span>: نَسَبًا بِعِيدًا، وهي أكْثَرُ مِنَ القبائِل.</p><p><span class="qpc-hafs">﴿وَقَبَآئِلَ﴾</span>: نَسَبًا قَرِيبا، وهي تَدْخُل تَحْتَ الشُّعوبِ.</p><p><span class="qpc-hafs">﴿لِتَعَارَفُوٓاْ﴾</span>: لِيَعْرِفَ بَعْضُكُم بَعْضًا.</p><p><span class="qpc-hafs">﴿أَكۡرَمَكُمۡ﴾</span>: أشْرَفَكُم.</p></div>"
  49,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَعۡرَابُ﴾</span>: هُمْ في الأَصْلِ سُكّانُ البادِيةِ مِنَ العَرَبِ، والمرادُ هُنا أعْرابُ بَنِي أسَدِ بن خُزَيْمَةَ.</p><p><span class="qpc-hafs">﴿لَا يَلِتۡكُم﴾</span>: لا يَنْقُصْكُمُ.</p></div>"
  49,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمۡ يَرۡتَابُواْ﴾</span>: لَمْ يَشُكُّوا.</p></div>"
  49,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتُعَلِّمُونَ ٱللَّهَ بِدِينِكُمۡ﴾</span>: أتُخْبِرُونَهُ بِطاعَتِكُم؟</p></div>"
  49,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا تَمُنُّواْ﴾</span>: لا تَذْكُرُوا إنْعامَكُم.</p></div>"
  49,18,""
