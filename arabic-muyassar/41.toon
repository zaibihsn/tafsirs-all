quran[54]{c,v,t}:
  41,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: سَبَقَ الكَلامُ عَلى الحرُوفِ المقطَّعةِ في أوَّلِ سُورةِ البقرةِ.</p></div>"
  41,2,""
  41,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُصِّلَتۡ﴾</span>: بُيِّنتْ، أو نُوِّعَتْ.</p></div>"
  41,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسۡمَعُونَ﴾</span>: لَهُ سَماعَ قَبُولٍ وإجابَةٍ.</p></div>"
  41,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكِنَّةࣲ﴾</span>: أغْطية تَمْنَعُنا من فَهْم ما تَدْعُوننا إليه.</p><p><span class="qpc-hafs">﴿وَقۡرࣱ﴾</span>: ثِقَلٌ وصَمَمٌ، يمْنَعُنا مِنَ السَّمْعِ.</p><p><span class="qpc-hafs">﴿حِجَابࣱ﴾</span>: ساتِرٌ يَحْجُبُنا عَنْ إجابَةِ دَعْوَتِكَ.</p></div>"
  41,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسۡتَقِيمُوٓاْ إِلَيۡهِ﴾</span>: فاسْلُكُوا الطَّريقَ الُموصِلَ إلَيهِ.</p><p><span class="qpc-hafs">﴿وَوَيۡلࣱ﴾</span>: هَلاكٌ وعَذابٌ.</p></div>"
  41,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُؤۡتُونَ ٱلزَّكَوٰةَ﴾</span>: لا يُؤَدُّونَ الصَّدَقةَ إلى مُسْتَحِقِّيها.</p></div>"
  41,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡرُ مَمۡنُونࣲ﴾</span>: غَيرُ مَنقُوصٍ ولا مَحْسُوبٍ ليُمَنَّ بِهِ، بَلْ هُوَ خالٍ مِنَ المَنِّ والأَذى.</p></div>"
  41,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: شُرَكاءَ.</p></div>"
  41,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿وَبَـٰرَكَ فِيهَا﴾</span>: أدامَ خَيرَها، وأَنْبَتَ شَجَرَها.</p><p><span class="qpc-hafs">﴿وَقَدَّرَ﴾</span>: وقَسَّمَ.</p><p><span class="qpc-hafs">﴿أَقۡوَ ٰ⁠تَهَا﴾</span>: أرْزاقَ أهْلِها، وما يُصْلِحُهُم مِنَ المعاشِ.</p><p><span class="qpc-hafs">﴿فِيٓ أَرۡبَعَةِ أَيَّامࣲ﴾</span>: أي: في تَتمَّةِ الأيامِ الأرْبَعَةِ.</p><p><span class="qpc-hafs">﴿سَوَآءࣰ﴾</span>: مُسْتَوِيَةً مُهَيَّأةً.</p><p><span class="qpc-hafs">﴿لِّلسَّآئِلِينَ﴾</span>: لِلْمُحْتاجِينَ إليها مِنَ البَشَرِ، أو لِمن يَطْلُبُ مَعْرِفَةَ ذَلكَ.</p></div>"
  41,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰٓ﴾</span>: ارْتَفَعَ.</p><p><span class="qpc-hafs">﴿دُخَانࣱ﴾</span>: بُخارٌ مُرْتَفِعٌ.</p><p><span class="qpc-hafs">﴿ٱئۡتِيَا﴾</span>: انْقادا لِأَمْرِي.</p><p><span class="qpc-hafs">﴿طَوۡعًا أَوۡ كَرۡهࣰا﴾</span>: مُخْتارَتَينِ أو مُجْبَرتَين.</p><p><span class="qpc-hafs">﴿طَآئِعِينَ﴾</span>: مُذْعِنِينَ لَكَ، ليسَ لَنا إرادَةٌ تُخالِفُ إرادتَكَ.</p></div>"
  41,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَضَىٰهُنَّ﴾</span>: فأَوْجَدَهُنَّ وفَرَغَ من خَلْقِهنَّ.</p><p><span class="qpc-hafs">﴿وَأَوۡحَىٰ فِي كُلِّ سَمَآءٍ أَمۡرَهَا﴾</span>: وألقى في كل سماءٍ من السمواتِ السبعِ ما أراد من الأمورِ التي بها قِوامُها وصَلاحُها.</p><p><span class="qpc-hafs">﴿بِمَصَـٰبِيحَ﴾</span>: بالنجومِ المضيئةِ.</p><p><span class="qpc-hafs">﴿وَحِفۡظࣰا﴾</span>: وزَيَّنّاها حِفْظًا لها من الشياطينِ الذين يَسْتَرِقون السَّمْعَ.</p></div>"
  41,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنذَرۡتُكُمۡ﴾</span>: خَوَّفْتُكُمْ.</p><p><span class="qpc-hafs">﴿صَـٰعِقَةࣰ﴾</span>: وقْعَةَ عذابٍ يَسْتأصِلُكم.</p></div>"
  41,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَيۡنِ أَيۡدِيهِمۡ وَمِنۡ خَلۡفِهِمۡ﴾</span>: يَتْبَعُ بعضُهم بعضًا واتصلَتْ نِذارتُهم.</p></div>"
  41,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: الُمعْجزات.</p></div>"
  41,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡصَرࣰا﴾</span>: شديدةَ البُرودةِ والصوتِ.</p><p><span class="qpc-hafs">﴿نَّحِسَاتࣲ﴾</span>: مَشْؤوماتٍ عليهم.</p><p><span class="qpc-hafs">﴿ٱلۡخِزۡيِ﴾</span>: الهَوانِ والهلاكِ.</p></div>"
  41,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهَدَيۡنَـٰهُمۡ﴾</span>: بيَّنّا لهم طُرُقَ الخيرِ والشرِّ.</p><p><span class="qpc-hafs">﴿ٱلۡعَمَىٰ﴾</span>: الكفرَ.</p><p><span class="qpc-hafs">﴿فَأَخَذَتۡهُمۡ﴾</span>: فأهلكَتْهُم.</p><p><span class="qpc-hafs">﴿صَـٰعِقَةُ﴾</span>: مُهْلِكَةُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَذَابِ ٱلۡهُونِ﴾</span>: الذي معه هَوانٌ وإذلالٌ.</p></div>"
  41,18,""
  41,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحۡشَرُ﴾</span>: يُجْمَعُ.</p><p><span class="qpc-hafs">﴿يُوزَعُونَ﴾</span>: تَرُدُّ زبانيةُ العذابِ أوَّلَهم على آخِرِهم؛ ليجتمِعُوا جميعًا.</p></div>"
  41,20,""
  41,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلَ مَرَّةࣲ﴾</span>: الخَلْقَ الأَوَّلَ ولَمْ تَكُونُوا شيئًا.</p></div>"
  41,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡتَتِرُونَ﴾</span>: تَسْتَخْفُونَ عِنْدَ ارْتِكابِكُم المعاصِيَ في الدُّنيا.</p><p><span class="qpc-hafs">﴿أَن يَشۡهَدَ﴾</span>: مَخافَةَ أن يَشْهَدَ.</p></div>"
  41,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡدَىٰكُمۡ﴾</span>: أهْلَكَكُم، فَأَوْرَدَكُم النّارَ.</p><p><span class="qpc-hafs">﴿ٱلۡخَـٰسِرِينَ﴾</span>: الهالِكِينَ.</p></div>"
  41,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوࣰى﴾</span>: مَأْوىً.</p><p><span class="qpc-hafs">﴿يَسۡتَعۡتِبُواْ﴾</span>: يَسْأَلُوا العُتْبى وهي الرَّجْعَةُ لَهُم إلى الَّذِي يُحِبُّونَ بِتَخْفِيفِ العَذابِ عَنْهُم.</p><p><span class="qpc-hafs">﴿ٱلۡمُعۡتَبِينَ﴾</span>: الَّذِينَ يُقْبَلُ عُذْرُهُم ويُجابُونَ إلى ما طَلَبُوا.</p></div>"
  41,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَيَّضۡنَا﴾</span>: هَيَّأنا وأَعْدَدْنا.</p><p><span class="qpc-hafs">﴿قُرَنَآءَ﴾</span>: نُظَراءَ مُلازِمِينَ مِن شَياطِينِ الإنْسِ والجِنِّ.</p><p><span class="qpc-hafs">﴿فَزَيَّنُواْ﴾</span>: فَحَسّنُوا.</p><p><span class="qpc-hafs">﴿مَّا بَيۡنَ أَيۡدِيهِمۡ﴾</span>: مِن أمْرِ الدُّنيا حتّى آثَرُوها على الآخِرةِ.</p><p><span class="qpc-hafs">﴿وَمَا خَلۡفَهُمۡ﴾</span>: ما بَعْدَ مَماتِهم وذَلكَ بالتَّكْذِيبِ بالَمعادِ.</p><p><span class="qpc-hafs">﴿وَحَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾</span>: وجَبَ لَهُم العَذابُ.</p><p><span class="qpc-hafs">﴿فِيٓ أُمَمࣲ﴾</span>: في جُمْلةِ أُمَمٍ كافِرةٍ.</p><p><span class="qpc-hafs">﴿قَدۡ خَلَتۡ﴾</span>: مَضَتْ.</p></div>"
  41,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡغَوۡاْ﴾</span>: وأْتُوا فِيهِ بالتَّخْلِيطِ والصَّفِيرِ عِنْدَ قِراءتِهِ.</p></div>"
  41,27,""
  41,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَارُ ٱلۡخُلۡدِ﴾</span>: دارُ الإقامةِ الدّائِمَةِ.</p><p><span class="qpc-hafs">﴿يَجۡحَدُونَ﴾</span>: يَكْفُرُونَ.</p></div>"
  41,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَسۡفَلِينَ﴾</span>: أشَدَّ عَذابًا مِنّا.</p></div>"
  41,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَقَـٰمُواْ﴾</span>: سَلَكُوا الطَّريقَ القَوِيمَ، وأَدَّوا فَرائِضَ اللهِ.</p><p><span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيۡهِمُ ٱلۡمَلَـٰٓئِكَةُ﴾</span>: أي: عِنْدَ نُزُولِ الموتِ بِهِم مُطَمْئِنَةً.</p><p><span class="qpc-hafs">﴿أَلَّا تَخَافُواْ﴾</span>: تَقُولُ لَهُم: لا تخافُوا مِنَ الموتِ وما بَعْدَهُ.</p><p><span class="qpc-hafs">﴿وَلَا تَحۡزَنُواْ﴾</span>: عَلى ما تُخَلِّفُونَه وراءَكُم مِن أُمَورِ الدُّنيا.</p><p><span class="qpc-hafs">﴿وَأَبۡشِرُواْ﴾</span>: وسُرُّوا.</p></div>"
  41,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآؤُكُمۡ﴾</span>: أنْصارُكُم وأَحِبّاؤُكُم.</p><p><span class="qpc-hafs">﴿تَدَّعُونَ﴾</span>: تَتَمَنَّونَ.</p></div>"
  41,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُزُلࣰا﴾</span>: ضِيافَةً وتَكْرِمَةً.</p></div>"
  41,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۡ أَحۡسَنُ قَوۡلࣰا﴾</span>: لا أحَدَ أحْسَنُ قَولًا.</p><p><span class="qpc-hafs">﴿دَعَآ إِلَى ٱللَّهِ﴾</span>: دَعا إلى تَوْحِيدِ اللهِ وعِبادَتِه وحْدَهُ.</p></div>"
  41,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَسَنَةُ﴾</span>: الصَّبرُ والحِلْمُ والعَفْوُ.</p><p><span class="qpc-hafs">﴿ٱلسَّيِّئَةُ﴾</span>: الغَضَبُ والجَهْلُ والإساءَةُ.</p><p><span class="qpc-hafs">﴿ٱدۡفَعۡ بِٱلَّتِي هِيَ أَحۡسَنُ﴾</span>: ادْفَعْ -أيُّها الرَّسُولُ- بِعَفْوِكَ وحِلْمِكَ وإحْسانِكَ مَن أساءَ إليكَ.</p><p><span class="qpc-hafs">﴿وَلِيٌّ﴾</span>: مُحِبٌّ مُناصِرٌ.</p><p><span class="qpc-hafs">﴿حَمِيمࣱ﴾</span>: قَرِيبٌ مُشْفِقٌ.</p></div>"
  41,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُلَقَّىٰهَآ﴾</span>: وما يُعْطى ويُوفَّقُ لهذهِ الَمنْزِلَةِ الحمِيدَةِ.</p><p><span class="qpc-hafs">﴿حَظٍّ﴾</span>: نَصِيبٍ.</p></div>"
  41,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِمَّا يَنزَغَنَّكَ مِنَ ٱلشَّيۡطَـٰنِ نَزۡغࣱ﴾</span>: وإمّا يُلْقِيَنَّ الشَّيطانُ في نَفْسِكَ وسْوَسَةً مِن حدِيثِ النَّفْسِ تَحْمِلُكَ عَلى مُجازاةِ الُمسِيءِ بالإساءَةِ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾</span>: فاسْتَجِرْ بِاللهِ واعْتَصِمْ بِهِ.</p></div>"
  41,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنۡ ءَايَـٰتِهِ﴾</span>: ومِن حُجَجِ اللهِ عَلى خَلقِهِ، ودَلائِلِهِ عَلى وحْدانِيَّتهِ وكَمالِ قُدْرَتِهِ.</p></div>"
  41,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلَّذِينَ عِندَ رَبِّكَ﴾</span>: هُمُ الملائِكَةُ.</p><p><span class="qpc-hafs">﴿لَا يَسۡـَٔمُونَ﴾</span>: لا يَفْتُرُونَ ولا يَمَلُّونَ.</p></div>"
  41,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعَةࣰ﴾</span>: يابِسَةً مُسْتَكِينَةً لا نَباتَ فِيها.</p><p><span class="qpc-hafs">﴿ٱهۡتَزَّتۡ﴾</span>: تَحَرَّكَتْ وتَشَقَّقَتْ بالنَّباتِ.</p><p><span class="qpc-hafs">﴿وَرَبَتۡ﴾</span>: وانْتَفَخَتْ وعَلَتْ.</p></div>"
  41,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُلۡحِدُونَ﴾</span>: يَمِيلُونَ عَنِ الحَقِّ إنْكارًا لَهُ.</p><p><span class="qpc-hafs">﴿ٱعۡمَلُواْ مَا شِئۡتُمۡ﴾</span>: وعِيدٌ في صِيغَةِ الأمْر.</p></div>"
  41,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلذِّكۡرِ﴾</span>: بالقرآنِ.</p></div>"
  41,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَـٰطِلُ﴾</span>: الشَّيطانُ وأيُّ أمْرٍ يُبْطِلُ شَيئًا مِنهُ.</p><p><span class="qpc-hafs">﴿مِنۢ بَيۡنِ يَدَيۡهِ وَلَا مِنۡ خَلۡفِهِۦ﴾</span>: مِن أيِّ جِهَةٍ مِن جِهاتِهِ، فهو مَحْفُوظٌ بِحِفْظِ اللهِ.</p><p><span class="qpc-hafs">﴿حَكِيمٍ﴾</span>: ذِي حِكْمَةٍ.</p><p><span class="qpc-hafs">﴿حَمِيدࣲ﴾</span>: مَحْمُودٍ عَلى نِعَمِهِ عَلى الخَلْقِ وعَلى ما لَهُ مِن صِفاتِ الكَمالِ.</p></div>"
  41,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يُقَالُ لَكَ﴾</span>: لا يقُولُ لَكَ المشرِكُونَ.</p></div>"
  41,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡجَمِيࣰّا﴾</span>: عَلى غَيرِ لُغَةِ العَرَبِ.</p><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿فُصِّلَتۡ ءَايَـٰتُهُۥٓ﴾</span>: بُيِّنتْ آياتُه فَنَفْقَهَهُ ونَعْلَمَهُ.</p><p><span class="qpc-hafs">﴿ءَا۬عۡجَمِيࣱّ وَعَرَبِيࣱّ﴾</span>: أأَعْجَمِيٌّ هَذا القُرآنُ، ولِسانُ الَّذِي أُنْزِل عَليهِ عَرَبيٌّ؟</p><p><span class="qpc-hafs">﴿هُدࣰى﴾</span>: بَيانٌ لِلْحَقِّ.</p><p><span class="qpc-hafs">﴿وَشِفَآءࣱ﴾</span>: مِنَ الجَهْلِ والأمْراضِ.</p><p><span class="qpc-hafs">﴿وَقۡرࣱ﴾</span>: ثِقَلٌ وصَمَمٌ.</p><p><span class="qpc-hafs">﴿وَهُوَ عَلَيۡهِمۡ عَمًى﴾</span>: عَمِيَتْ قُلُوبُهُم عَنِ القُرآنِ فَلا يَهْتَدُونَ بِهِ.</p><p><span class="qpc-hafs">﴿أُوْلَـٰٓئِكَ يُنَادَوۡنَ مِن مَّكَانِۭ بَعِيدࣲ﴾</span>: كَأنّ أُولئِكَ المشرِكِينَ يَسْمَعُونَ صَوْتًا مِن بَعِيدٍ، ولا يَفْهَمُونَ مَعانِيَهُ.</p></div>"
  41,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التَّوراةَ.</p><p><span class="qpc-hafs">﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾</span>: بِتَأْجِيلِ العَذابِ عَن قَومِكَ.</p><p><span class="qpc-hafs">﴿لَقُضِيَ بَيۡنَهُمۡ﴾</span>: لَفُصِلَ بينهم بإهْلاكِ الكافِرينَ في الحالِ.</p><p><span class="qpc-hafs">﴿وَإِنَّهُمۡ لَفِي شَكࣲّ مِّنۡهُ﴾</span>: وإنّ الفريقَ المُبْطِلَ مِنهُم لَفِي شَكٍّ مما قالُوا في التَّوراةِ.</p><p><span class="qpc-hafs">﴿مُرِيبࣲ﴾</span>: مُوقِعٍ في قَلَقِ النَّفْسِ وعَدَمِ طُمَأنِينتِها؛ لأنّهُم قالُوهُ ظنًّا بِغَيرِ حُجَّةٍ.</p></div>"
  41,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَلَيۡهَا﴾</span>: فَعَلى نَفْسِهِ جَنى.</p><p><span class="qpc-hafs">﴿بِظَلَّـٰمࣲ﴾</span>: بِذِي ظُلْمٍ.</p></div>"
  41,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَيۡهِ يُرَدُّ﴾</span>: إلى اللهِ وحْدَهُ يُرجَعُ.</p><p><span class="qpc-hafs">﴿مِّنۡ أَكۡمَامِهَا﴾</span>: مِن أوْعِيَتِها. مُفْرَدُها: كِمٌّ.</p><p><span class="qpc-hafs">﴿ءَاذَنَّـٰكَ﴾</span>: أعْلَمناكَ.</p><p><span class="qpc-hafs">﴿مَا مِنَّا مِن شَهِيدࣲ﴾</span>: يَشْهَدُ أنّ لَكَ شَريكًا.</p></div>"
  41,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم﴾</span>: وذَهَبَ عَنِ المشْرِكِينَ.</p><p><span class="qpc-hafs">﴿وَظَنُّواْ﴾</span>: أيقَنُوا.</p><p><span class="qpc-hafs">﴿مَّحِيصࣲ﴾</span>: مَلْجَأٍ مِن عَذابِ اللهِ.</p></div>"
  41,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَسۡـَٔمُ﴾</span>: لا يَمَلُّ.</p><p><span class="qpc-hafs">﴿ٱلۡإِنسَـٰنُ﴾</span>: المُرادُ هُنا الكافرُ بِاللهِ.</p><p><span class="qpc-hafs">﴿مِن دُعَآءِ ٱلۡخَيۡرِ﴾</span>: مِن سُؤالِهِ رَبَّهُ أن يَمُدَّهُ بالمالِ والصِّحَّةِ.</p><p><span class="qpc-hafs">﴿وَإِن مَّسَّهُ﴾</span>: وإنْ أصابَه.</p><p><span class="qpc-hafs">﴿ٱلشَّرُّ﴾</span>: فَقْرٌ ومَرَضٌ.</p><p><span class="qpc-hafs">﴿فَيَـُٔوسࣱ﴾</span>: مُبالِغٌ في اعْتِقادِ عَدَمِ حُصُولِ الخيرِ لَهُ.</p><p><span class="qpc-hafs">﴿قَنُوطࣱ﴾</span>: شَدِيد اليأسِ.</p></div>"
  41,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَّآءَ﴾</span>: شدَّةٍ وبَلاءٍ.</p><p><span class="qpc-hafs">﴿هَـٰذَا لِي﴾</span>: أسْتَحِقُّه على اللهِ لأنّه راضٍ عَنِّي.</p><p><span class="qpc-hafs">﴿لَلۡحُسۡنَىٰ﴾</span>: الجنَّةِ.</p><p><span class="qpc-hafs">﴿غَلِيظࣲ﴾</span>: شَدِيدٍ، وهو خُلُودُهُم في النّارِ.</p></div>"
  41,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَـَٔابِجَانِبِهِۦ﴾</span>: تَباعَدَ عَن شُكْرِ نِعْمَةِ اللهِ وطاعَتِهِ.</p><p><span class="qpc-hafs">﴿عَرِيضࣲ﴾</span>: كَثِيرٍ.</p></div>"
  41,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُونِي.</p><p><span class="qpc-hafs">﴿مَنۡ أَضَلُّ﴾</span>: لا أحَد أشَدُّ ذَهابًا عَن قَصْدِ السَّبيلِ.</p><p><span class="qpc-hafs">﴿فِي شِقَاقِۭ﴾</span>: في خِلافٍ وفِراقٍ لأمر الله.</p><p><span class="qpc-hafs">﴿بَعِيدࣲ﴾</span>: واسِع المسافَةِ مِنَ الرَّشادِ.</p></div>"
  41,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِنَا﴾</span>: مِنَ الفُتُوحاتِ وظُهُورِ الإسْلامِ عَلى الأقاليمِ وسائِرِ الأدْيانِ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔافَاقِ﴾</span>: أقْطارِ السَّمَواتِ والأرْضِ.</p><p><span class="qpc-hafs">﴿وَفِيٓ أَنفُسِهِمۡ﴾</span>: مِن لطِيفِ الصَّنْعَةِ وبدِيعِ الحِكْمةِ.</p><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَكۡفِ بِرَبِّكَ﴾</span>: أو لم يَكْفِ ربُّكَ شاهِدًا عَلى صِدْقِكَ وصِدْقِ ما أُنزِلَ إليكَ.</p></div>"
  41,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِرۡيَةࣲ مِّن لِّقَآءِ رَبِّهِمۡ﴾</span>: شَكٍّ عَظِيمٍ مِنَ البعثِ بَعْدَ المماتِ.</p><p><span class="qpc-hafs">﴿مُّحِيطُۢ﴾</span>: أحاطَ بِكُلِّ شَيءٍ عِلْمًا.</p></div>"
