quran[83]{c,v,t}:
  36,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يسٓ﴾</span>: سَبَقَ الكلامُ على الحروفِ المُقَطَّعَةِ في أوَّلِ سُورةِ البقرةِ.</p></div>"
  36,2,""
  36,3,""
  36,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: طَرِيقٍ مُعْتَدِلٍ وهو الإسْلامُ.</p></div>"
  36,5,""
  36,6,""
  36,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ ٱلۡقَوۡلُ﴾</span>: وجَبَ القولُ أي: العذابُ.</p></div>"
  36,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَغۡلَـٰلࣰا﴾</span>: قُيُودًا تَشُدُّ أيدِيَهُم إلى أعناقِهِم تَحتَ أذقانِهم.</p><p><span class="qpc-hafs">﴿مُّقۡمَحُونَ﴾</span>: رافِعُونَ رؤوسَهم غاضُّونَ أبْصارَهُم.</p></div>"
  36,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَدࣰّا﴾</span>: حاجِزًا ومانِعًا.</p><p><span class="qpc-hafs">﴿فَأَغۡشَيۡنَـٰهُمۡ﴾</span>: غَطَّينا أبْصارَهُم.</p></div>"
  36,10,""
  36,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجۡرࣲ كَرِيمٍ﴾</span>: أجْرٍ حَسَنٍ، وهو دخولُ الجنّةِ.</p></div>"
  36,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُحۡيِ ٱلۡمَوۡتَىٰ﴾</span>: نَبْعَثُهُم بَعْدَ الموتِ.</p><p><span class="qpc-hafs">﴿وَءَاثَـٰرَهُمۡ﴾</span>: أي: ما أبْقَوهُ مِنَ الحسَناتِ الَّتي لايَنْقَطِعُ نَفْعُها بَعْدَ الموتِ.</p><p><span class="qpc-hafs">﴿إِمَامࣲ مُّبِينࣲ﴾</span>: كِتابٍ واضِحٍ، وهو اللَّوحُ المحفُوظُ.</p></div>"
  36,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبَ ٱلۡقَرۡيَةِ﴾</span>: أهْلَ القَرْيَةِ، وهي «أنْطاكِيَةُ».</p></div>"
  36,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَزَّزۡنَا بِثَالِثࣲ﴾</span>: أي: قوَّيناهُما بِرَسُولٍ ثالِثٍ.</p></div>"
  36,15,""
  36,16,""
  36,17,""
  36,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَطَيَّرۡنَا بِكُمۡ﴾</span>: تَشاءَمْنا بِكُم.</p><p><span class="qpc-hafs">﴿لَنَرۡجُمَنَّكُمۡ﴾</span>: لَنَقْتُلَنَّكُم رَمْيًا بالِحجارَةِ.</p></div>"
  36,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَـٰٓئِرُكُم مَّعَكُمۡ﴾</span>: شُؤْمُكُم مَعَكُم، الذي هو كُفْرُكُم وشِرْكُكُم.</p></div>"
  36,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَقۡصَا ٱلۡمَدِينَةِ﴾</span>: مِن مَّكانٍ بَعِيدٍ فِيها.</p></div>"
  36,21,""
  36,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَرَنِي﴾</span>: خَلَقَنِي.</p></div>"
  36,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُنقِذُونِ﴾</span>: لا يُنَجُّونَنِي مِمّا أنافِيه.</p></div>"
  36,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينٍ﴾</span>: خَطَأٍ ظاهِرٍ.</p></div>"
  36,25,""
  36,26,""
  36,27,""
  36,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُندࣲ﴾</span>: جَيشٍ.</p></div>"
  36,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَيۡحَةࣰ﴾</span>: صَوْتًا مُهلِكًا مِنَ السَّماءِ.</p><p><span class="qpc-hafs">﴿خَـٰمِدُونَ﴾</span>: مَيِّتُونَ لا حَراكَ فِيهِم.</p></div>"
  36,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَهۡزِءُونَ﴾</span>: يَسْخَرُونَ.</p></div>"
  36,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنَ ٱلۡقُرُونِ﴾</span>: مِنَ الأُمَمِ الخالِيةِ.</p></div>"
  36,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُحۡضَرُونَ﴾</span>: نُحْضِرُهُم للحسابِ والجزاءِ.</p></div>"
  36,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَايَةࣱ لَّهُمُ﴾</span>: دَلالةٌ لَهُم.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضُ ٱلۡمَيۡتَةُ﴾</span>: هي الَّتي لا نَباتَ فِيها.</p><p><span class="qpc-hafs">﴿أَحۡيَيۡنَـٰهَا﴾</span>: أي: بإنْزالِ المطرِ عَلَيها وإخراجِ النَّباتِ منها.</p></div>"
  36,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتࣲ﴾</span>: بَساتِينَ.</p><p><span class="qpc-hafs">﴿فَجَّرۡنَا﴾</span>: شَقَقْنا.</p></div>"
  36,35,""
  36,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَزۡوَ ٰ⁠جَ﴾</span>: الأَصْنافَ والأَنْواعَ.</p></div>"
  36,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣱ لَّهُمُ﴾</span>: علامةٌ لَهُم.</p><p><span class="qpc-hafs">﴿نَسۡلَخُ مِنۡهُ﴾</span>: نَنْزِعُ مِنهُ.</p></div>"
  36,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمُسۡتَقَرࣲّ لَّهَا﴾</span>: مُسْتَقَرُّها تَحْتَ العَرْشِ، كما جاء في الحديثِ المتَّفقِ عَلَيه.</p></div>"
  36,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنَازِلَ﴾</span>: مسافات، وهي ثمانيةٌ وعِشْرُونَ مَنزِلًا.</p><p><span class="qpc-hafs">﴿كَٱلۡعُرۡجُونِ ٱلۡقَدِيمِ﴾</span>: كالعِذْقِ اليابسِ المتَقَوِّسِ.</p></div>"
  36,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن تُدۡرِكَ﴾</span>: أن تَلْحَقَ.</p><p><span class="qpc-hafs">﴿فَلَكࣲ﴾</span>: مَدارٍ.</p><p><span class="qpc-hafs">﴿يَسۡبَحُونَ﴾</span>: يَدُورُونَ في فَلَكِ السَّماءِ بانْبِساطٍ وسُهُولَةٍ.</p></div>"
  36,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣱ لَّهُمۡ﴾</span>: دليلٌ لَهُم.</p><p><span class="qpc-hafs">﴿ٱلۡمَشۡحُونِ﴾</span>: الممْلُوءِ.</p></div>"
  36,42,""
  36,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرِيخَ لَهُمۡ﴾</span>: مُغِيثَ لَهُم.</p><p><span class="qpc-hafs">﴿يُنقَذُونَ﴾</span>: يُخَلَّصُونَ مِنَ الغَرَقِ.</p></div>"
  36,44,""
  36,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا بَيۡنَ أَيۡدِيكُمۡ﴾</span>: مِنَ الآخرةِ وأهْوالِها.</p><p><span class="qpc-hafs">﴿وَمَا خَلۡفَكُمۡ﴾</span>: مِن أحْوالِ الدُّنيا وعِقابِها.</p></div>"
  36,46,""
  36,47,""
  36,48,""
  36,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: ينتظِرُونَ.</p><p><span class="qpc-hafs">﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: هي نَفْخَةُ الفَزَعِ عِنْدَ قِيامِ السّاعةِ.</p><p><span class="qpc-hafs">﴿يَخِصِّمُونَ﴾</span>: يَخْتَصِمُونَ في شُؤونِ حياتِهم غافِلينَ عَن يَوْمِ القيامةِ.</p></div>"
  36,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوۡصِيَةࣰ﴾</span>: وصِيَّةً.</p></div>"
  36,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: «القَرْنِ» الذي يُنفَخُ فيه للبعث.</p><p><span class="qpc-hafs">﴿ٱلۡأَجۡدَاثِ﴾</span>: القُبُورِ.</p><p><span class="qpc-hafs">﴿يَنسِلُونَ﴾</span>: يُسْرِعُونَ في الخُرُوجِ.</p></div>"
  36,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰوَيۡلَنَا﴾</span>: يا هَلاكَنا.</p><p><span class="qpc-hafs">﴿مَنۢ بَعَثَنَا﴾</span>: مَن أحْيانا؟</p><p><span class="qpc-hafs">﴿مِن مَّرۡقَدِنَاۜ﴾</span>: مِن قُبُورِنا.</p></div>"
  36,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: نَفْخَةً واحِدَةً.</p><p><span class="qpc-hafs">﴿مُحۡضَرُونَ﴾</span>: نُحْضِرُهم للحِسابِ والجَزاءِ.</p></div>"
  36,54,""
  36,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي شُغُلࣲ﴾</span>: في نَعِيمٍ عَظِيمٍ يُلْهِيهِم عمّا سِواه.</p><p><span class="qpc-hafs">﴿فَـٰكِهُونَ﴾</span>: مُتَلَذِّذُونَ.</p></div>"
  36,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرَآئِكِ﴾</span>: الأَسِرَّةِ المزَيَّنةِ.</p></div>"
  36,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يَدَّعُونَ﴾</span>: ما يَشْتَهُونَ.</p></div>"
  36,58,""
  36,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱمۡتَـٰزُواْ﴾</span>: تميَّزُوا، وانفرِدُوا عَنِ المؤمِنِينَ.</p></div>"
  36,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡهَدۡ إِلَيۡكُمۡ﴾</span>: أُوصِكُم وأُبَلِّغْكُم.</p></div>"
  36,61,""
  36,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جِبِلࣰّا﴾</span>: خَلْقًا.</p></div>"
  36,63,""
  36,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡلَوۡهَا﴾</span>: ادخُلُوا جَهَنَّمَ وقاسُوا حَرَّها.</p></div>"
  36,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَخۡتِمُ﴾</span>: نَطْبَعُ.</p></div>"
  36,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَطَمَسۡنَا عَلَىٰٓ أَعۡيُنِهِمۡ﴾</span>: لصَيرَّناها مَمْسُوحَةً لا يُرى لها شِقٌّ ولا جَفْنٌ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَبَقُواْ ٱلصِّرَ ٰ⁠طَ﴾</span>: بادَرُوا إليه.</p><p><span class="qpc-hafs">﴿فَأَنَّىٰ يُبۡصِرُونَ﴾</span>: فكيفَ يُبْصِرُونَ وقد طُمِسَتْ أبْصارُهُم؟</p></div>"
  36,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَسَخۡنَـٰهُمۡ عَلَىٰ مَكَانَتِهِمۡ﴾</span>: لَغَيَّرْنا خَلْقَهم في المكانِ الَّذي هم فيهِ.</p><p><span class="qpc-hafs">﴿مُضِيࣰّا﴾</span>: أي: ذَهابًا إلى الأمامِ.</p></div>"
  36,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّعَمِّرۡهُ﴾</span>: نُطِلْ عُمُرَه.</p><p><span class="qpc-hafs">﴿نُنَكِّسۡهُ فِي ٱلۡخَلۡقِ﴾</span>: نَرُدَّه إلى أرْذَلِ العُمُرِ وأَضْعَفِه.</p></div>"
  36,69,""
  36,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَحِقَّ ٱلۡقَوۡلُ﴾</span>: أي: تَجِبَ كلمةُ العذابِ.</p></div>"
  36,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّمَّا عَمِلَتۡ أَيۡدِينَآ﴾</span>: أي: مما أبْدَعْناهُ وعَمِلْناهُ.</p><p><span class="qpc-hafs">﴿لَهَا مَـٰلِكُونَ﴾</span>: مالِكُونَ أمْرَها، يَتَصَرَّفُونَ بِها كيفَ شاؤُوا.</p></div>"
  36,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَلَّلۡنَـٰهَا﴾</span>: سَخَّرْناها لَهُم.</p><p><span class="qpc-hafs">﴿رَكُوبُهُمۡ﴾</span>: مَرْكُوبُهم الّذي يَرْكَبُونَه.</p></div>"
  36,73,""
  36,74,""
  36,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُمۡ لَهُمۡ جُندࣱ مُّحۡضَرُونَ﴾</span>: والحالُ أنَّ هذه الآلهةَ قَدْ أُحْضِرَتْ مُجْتَمِعَةً لِتُعايِنَ عذابَ عابِديِها، وهي لا تَسْتَطِيعُ نَصْرَهُم.</p></div>"
  36,76,""
  36,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن نُّطۡفَةࣲ﴾</span>: هي مَنِيُّ الرَّجُلِ يقْذِفُه في رَحمِ امْرَأتِه.</p><p><span class="qpc-hafs">﴿خَصِيمࣱ﴾</span>: كثيرُ الخُصُومَةِ بالباطلِ.</p></div>"
  36,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَمِيمࣱ﴾</span>: باليةٌ مُتفَتِّتةٌ.</p></div>"
  36,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنشَأَهَآ﴾</span>: خَلَقَها.</p></div>"
  36,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡهُ تُوقِدُونَ﴾</span>: تَقْدَحُونَ منه.</p></div>"
  36,81,""
  36,82,""
  36,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلَكُوتُ﴾</span>: هو المُلْكُ التّامُّ للأشياءِ كلِّها.</p></div>"
