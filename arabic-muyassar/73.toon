quran[20]{c,v,t}:
  73,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُزَّمِّلُ﴾</span>: المتَغَطِّي بِثِيابِهِ.</p></div>"
  73,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُمِ ٱلَّيۡلَ﴾</span>: قُمْ لِلصَّلاةِ في الليلِ.</p><p><span class="qpc-hafs">﴿إِلَّا قَلِيلࣰا﴾</span>: إلا يسِيرًا مِنهُ.</p></div>"
  73,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِّصۡفَهُۥٓ﴾</span>: قُمْ نِصْفَ الليلِ.</p><p><span class="qpc-hafs">﴿أَوِ ٱنقُصۡ مِنۡهُ قَلِيلًا﴾</span>: أوِ انْقُصْ مِنَ النِّصْفِ قَلِيلا حتّى تَصِلَ إلى الثُلُثِّ.</p></div>"
  73,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ زِدۡ عَلَيۡهِ﴾</span>: أوْ زِدْ عَلى النِّصْفِ حتّى تَصِلَ إلى الثُلُثَينِ.</p><p><span class="qpc-hafs">﴿وَرَتِّلِ ٱلۡقُرۡءَانَ تَرۡتِيلًا﴾</span>: واقْرَأ القُرآنَ بتُؤَدَةٍ مُبَيِّنًا الحُرُوفَ والوُقُوفَ.</p></div>"
  73,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنُلۡقِي عَلَيۡكَ﴾</span>: سَنُنْزِلُ عَلَيكَ -أيُّها النَّبِيُّ-.</p><p><span class="qpc-hafs">﴿قَوۡلࣰا ثَقِيلًا﴾</span>: قُرآنًا عَظِيمًا مُشْتَمِلًا عَلى الأَوامِرِ والنَّواهِي والأَحْكامِ الشَّرعِيَّةِ.</p></div>"
  73,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَاشِئَةَ ٱلَّيۡلِ﴾</span>: العِبادةَ الَّتِي تَنْشَأُ في جَوْفِ الليلِ.</p><p><span class="qpc-hafs">﴿أَشَدُّ وَطۡـࣰٔا﴾</span>: أشَدُّ تأثِيرًا في القَلْبِ.</p><p><span class="qpc-hafs">﴿وَأَقۡوَمُ قِيلًا﴾</span>: وأَبْيَنُ قَوْلًا لِفَراغِ القَلْبِ مِن مَّشاغِل الدُّنيا.</p></div>"
  73,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبۡحࣰا طَوِيلࣰا﴾</span>: تَصَرُّفًا في مَصالِحِكَ، واشْتِغالًا بالرِّسالَةِ.</p></div>"
  73,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَبَتَّلۡ إِلَيۡهِ تَبۡتِيلࣰا﴾</span>: وانْقَطِعْ إلَيهِ انْقِطاعًا تامًّا في عِبادَتِكَ.</p></div>"
  73,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱتَّخِذۡهُ وَكِيلࣰا﴾</span>: فاعْتَمِدْ عَلَيهِ، وفَوِّضْ أُمُورَكَ إلَيه.</p></div>"
  73,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱهۡجُرۡهُمۡ هَجۡرࣰا جَمِيلࣰا﴾</span>: وأعْرِضْ عَنْهُم، واتْرُكِ الانْتِقامَ مِنهُم.</p></div>"
  73,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَذَرۡنِي وَٱلۡمُكَذِّبِينَ﴾</span>: دَعْنِي -أيُّها الرَّسُولُ- وهَؤُلاءِ المكَذِّبِينَ بآياتي.</p><p><span class="qpc-hafs">﴿أُوْلِي ٱلنَّعۡمَةِ﴾</span>: أصْحابَ النَّعِيمِ والتَّرَفِ في الدُّنيا.</p><p><span class="qpc-hafs">﴿وَمَهِّلۡهُمۡ قَلِيلًا﴾</span>: وأَخِّرْهُم زَمَنًا قَلِيلًا حتّى يَبْلُغَ الكِتابُ أجَلَه بِعَذابِهِم.</p></div>"
  73,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ لَدَيۡنَآ﴾</span>: أي في الآخِرَةِ.</p><p><span class="qpc-hafs">﴿أَنكَالࣰا﴾</span>: قُيُودًا ثَقِيلَةً.</p><p><span class="qpc-hafs">﴿وَجَحِيمࣰا﴾</span>: ونارًا مُسْتَعِرَةً.</p></div>"
  73,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَطَعَامࣰا ذَا غُصَّةࣲ﴾</span>: وطَعامًا كَرِيهًا ينشَبُ في الحُلُوقِ غَيَر مُسْتَساغٍ.</p></div>"
  73,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡجُفُ﴾</span>: تَضْطَرِبُ وتَتَزَلْزَلُ.</p><p><span class="qpc-hafs">﴿كَثِيبࣰا﴾</span>: تَلًّا مِنَ الرَّملِ.</p><p><span class="qpc-hafs">﴿مَّهِيلًا﴾</span>: سائِلًا مُنْهالًا مُتَناثِرًا.</p></div>"
  73,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَـٰهِدًا عَلَيۡكُمۡ﴾</span>: بِما صَدَرَ مِنكُم مِنَ الكُفْرِ والعِصْيانِ.</p></div>"
  73,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَصَىٰ فِرۡعَوۡنُ ٱلرَّسُولَ﴾</span>: فَكذَّبَ فِرْعَونُ بِمُوسى، ولَمْ يُؤْمِن بِرِسالَتِهِ.</p><p><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُ﴾</span>: فَأَهْلكْناهُ.</p><p><span class="qpc-hafs">﴿وَبِيلࣰا﴾</span>: شَدِيدًا.</p></div>"
  73,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَيۡفَ تَتَّقُونَ﴾</span>: فَكَيفَ تَقُونَ أنْفُسَكُم عذابَ يومِ القِيامَة.</p><p><span class="qpc-hafs">﴿يَجۡعَلُ ٱلۡوِلۡدَ ٰ⁠نَ شِيبًا﴾</span>: يَشِيبُ فِيهِ الوِلْدانُ الصِّغارُ؛ مِن شِدَّةِ هَوْلِه وكَرْبِهِ؟</p></div>"
  73,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّمَآءُ مُنفَطِرُۢ بِهِۦ﴾</span>: السَّماءُ مُتَصَدِّعَةٌ في ذَلِكَ اليَوْمِ؛ لِشِدَّةِ هَوْلِهِ.</p><p><span class="qpc-hafs">﴿بِهِۦ﴾</span>: أي: باللهِ، وهو نَظِيرُ قَوْلِهِ تَعالى:</p><p><span class="qpc-hafs">﴿وَيَوۡمَ تَشَقَّقُ ٱلسَّمَآءُ بِٱلۡغَمَـٰمِ﴾</span>:.</p><p><span class="qpc-hafs">﴿مَفۡعُولًا﴾</span>: واقِعًا لا مَحالَةَ.</p></div>"
  73,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَذۡكِرَةࣱ﴾</span>: عِظَةٌ وعِبْرَةٌ للنّاسِ.</p><p><span class="qpc-hafs">﴿ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلًا﴾</span>: اتَّخَذَ الطّاعةَ والتَّقْوى طَرِيقًا تُوصِلُه إلى رِضْوانِ رَبِهِ.</p></div>"
  73,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَقُومُ﴾</span>: للتَّهجُّدِ مِنَ الليلِ.</p><p><span class="qpc-hafs">﴿أَدۡنَىٰ مِن ثُلُثَيِ﴾</span>: أقَلَّ مِن ثُلُثِي الليلِ حِينًا.</p><p><span class="qpc-hafs">﴿وَنِصۡفَهُۥ﴾</span>: وتَقُومُ نِصْفَ الليلِ حِينًا.</p><p><span class="qpc-hafs">﴿وَثُلُثَهُۥ﴾</span>: وتَقُومُ ثُلُثَ الليلِ حِينًا آخرَ.</p><p><span class="qpc-hafs">﴿وَطَآئِفَةࣱ مِّنَ ٱلَّذِينَ مَعَكَ﴾</span>: ويَقُومُ مَعَكَ طائِفَةٌ مِن أصْحابِكَ.</p><p><span class="qpc-hafs">﴿وَٱللَّهُ يُقَدِّرُ ٱلَّيۡلَ وَٱلنَّهَارَ﴾</span>: يَعْلَمُ مَقادِيرَهُما.</p><p><span class="qpc-hafs">﴿تُحۡصُوهُ﴾</span>: تُطيقُوا قيامَه كُلَّه.</p><p><span class="qpc-hafs">﴿فَتَابَ عَلَيۡكُمۡ﴾</span>: فَخَفَّفَ عَلَيكُم.</p><p><span class="qpc-hafs">﴿فَٱقۡرَءُواْ مَا تَيَسَّرَ مِنَ ٱلۡقُرۡءَانِ﴾</span>: في الصَّلاةِ بالليلِ.</p><p><span class="qpc-hafs">﴿وَءَاخَرُونَ يَضۡرِبُونَ فِي ٱلۡأَرۡضِ﴾</span>: يَتَنَقَّلُونَ في الأرضِ للتِّجارَةِ والعَمَلِ.</p><p><span class="qpc-hafs">﴿يَبۡتَغُونَ مِن فَضۡلِ ٱللَّهِ﴾</span>: يَطْلُبُونَ مِن رِّزْقِ اللهِ الحلالِ.</p><p><span class="qpc-hafs">﴿وَأَقۡرِضُواْ ٱللَّهَ قَرۡضًا حَسَنࣰا﴾</span>: وتَصَدَّقُوا في وُجُوهِ البِرِّ والإحْسانِ مِن أمْوالِكُم.</p><p><span class="qpc-hafs">﴿وَمَا تُقَدِّمُواْ لِأَنفُسِكُم مِّنۡ خَيۡرࣲ﴾</span>: وما تَفْعَلُوا مِن وُجُوهِ البِرِّ.</p><p><span class="qpc-hafs">﴿وَأَعۡظَمَ أَجۡرࣰا﴾</span>: وأَعْظَمَ مِنهُ ثَوابًا.</p></div>"
