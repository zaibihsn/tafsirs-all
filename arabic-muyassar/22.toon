quran[78]{c,v,t}:
  22,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ زَلۡزَلَةَ ٱلسَّاعَةِ﴾</span>: هي حَرَكَةُ الأرضِ مِن أسْفَلِها، واضْطِرابُها الذي يَحدُثُ عِنْدَ قِيامِ السّاعةِ.</p></div>"
  22,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَذۡهَلُ﴾</span>: تَغْفُلُ وتَنْسى.</p><p><span class="qpc-hafs">﴿تَضَعُ﴾</span>: تُسْقِطُ، وتُلْقِي جَنِينَها.</p><p><span class="qpc-hafs">﴿سُكَـٰرَىٰ﴾</span>: أي: كالسُّكارى؛ مِن شِدَّةِ الخوفِ.</p></div>"
  22,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُجَـٰدِلُ﴾</span>: يُخاصِمُ.</p><p><span class="qpc-hafs">﴿مَّرِيدࣲ﴾</span>: مُتَمَرِّدٍ على اللهِ.</p></div>"
  22,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُتِبَ عَلَيۡهِ﴾</span>: قُدِّرَ على الشَّيطانِ.</p><p><span class="qpc-hafs">﴿مَن تَوَلَّاهُ﴾</span>: مَنِ اتَّخَذَه ولِيًّا وتَبِعَه.</p><p><span class="qpc-hafs">﴿وَيَهۡدِيهِ﴾</span>: ويُوصِلُه ويَسُوقُه.</p><p><span class="qpc-hafs">﴿عَذَابِ ٱلسَّعِيرِ﴾</span>: عذابِ جَهَنَّمَ الُموْقَدَةِ.</p></div>"
  22,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَيۡبࣲ﴾</span>: شَكٍّ.</p><p><span class="qpc-hafs">﴿مِن نُّطۡفَةࣲ﴾</span>: هي مَنِيُّ الرَّجُلِ يَقْذِفُه في رَحِم امْرَأتِه.</p><p><span class="qpc-hafs">﴿عَلَقَةࣲ﴾</span>: الدَّم الأحْمَرِ الغَلِيظِ.</p><p><span class="qpc-hafs">﴿مُّضۡغَةࣲ﴾</span>: قِطْعَةِ لَحْمٍ صَغِيرةٍ قَدْرَ ما يُمْضَغُ.</p><p><span class="qpc-hafs">﴿مُّخَلَّقَةࣲ﴾</span>: ما وُلِد تامَّ الخَلْقِ.</p><p><span class="qpc-hafs">﴿غَيۡرِ مُخَلَّقَةࣲ﴾</span>: ما تُسْقِطُه الرَّحِمُ قَبْلَ أن يَتِمَّ خَلْقُه.</p><p><span class="qpc-hafs">﴿وَنُقِرُّ﴾</span>: نُثَبِّتُ ونُبْقِي.</p><p><span class="qpc-hafs">﴿إِلَىٰٓ أَرۡذَلِ ٱلۡعُمُرِ﴾</span>: أخَسِّه، وهو الهَرمُ والخَرَفُ؛ حتى لا يَعْقِلَ.</p><p><span class="qpc-hafs">﴿هَامِدَةࣰ﴾</span>: يابِسةً لا نَباتَ فيها.</p><p><span class="qpc-hafs">﴿ٱهۡتَزَّتۡ﴾</span>: تَحرَّكَتْ بالنَّباتِ تَتَفَتَّحُ عَنْه.</p><p><span class="qpc-hafs">﴿وَرَبَتۡ﴾</span>: زادَتْ وضاعفَتْ النَّباتَ بِنُزُولِ المطرِ.</p><p><span class="qpc-hafs">﴿مِن كُلِّ زَوۡجِۭ بَهِيجࣲ﴾</span>: مِن كُلِّ صِنْفٍ حَسَنٍ ولونٍ مُسْتَحْسَنٍ.</p></div>"
  22,6,""
  22,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡعَثُ مَن فِي ٱلۡقُبُورِ﴾</span>: أي: يَبْعَثُهم أحْياءً.</p></div>"
  22,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُجَـٰدِلُ﴾</span>: يُخاصِمُ.</p></div>"
  22,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَانِيَ عِطۡفِهِۦ﴾</span>: لاويًا عُنُقَه في استكبارٍ عَنِ الحَقِّ.</p><p><span class="qpc-hafs">﴿خِزۡيࣱ﴾</span>: ذُلٌّ وهَوانٌ.</p></div>"
  22,10,""
  22,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ حَرۡفࣲ﴾</span>: على ضَعْفٍ وشَكٍّ.</p><p><span class="qpc-hafs">﴿فِتۡنَةٌ﴾</span>: ابْتِلاءٌ وشِدَّةٌ.</p><p><span class="qpc-hafs">﴿ٱنقَلَبَ عَلَىٰ وَجۡهِهِۦ﴾</span>: رَجَعَ عمّا كان عليه مِنَ الاسْتِقامَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡخُسۡرَانُ ٱلۡمُبِينُ﴾</span>: الخَسارةُ العَظِيمَةُ والصَّفْقَةُ الخاسِرةُ.</p></div>"
  22,12,""
  22,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَوۡلَىٰ﴾</span>: النَّصِيرُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَشِيرُ﴾</span>: الصّاحِبُ المُعاشِرُ.</p></div>"
  22,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: أي: مِن تَحْتِ قُصُورِها.</p></div>"
  22,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَمۡدُدۡ﴾</span>: فليَشْدُدْ.</p><p><span class="qpc-hafs">﴿بِسَبَبٍ﴾</span>: بحَبْلٍ.</p><p><span class="qpc-hafs">﴿إِلَى ٱلسَّمَآءِ﴾</span>: أي: سَماءِ بيتِه، وهو سَقْفُه.</p><p><span class="qpc-hafs">﴿ثُمَّ لۡيَقۡطَعۡ﴾</span>: أي: ذلك الحبلَ، لِيَخْنُقَ بِه نَفْسَه.</p><p><span class="qpc-hafs">﴿كَيۡدُهُۥ﴾</span>: مَكْرُه وحِيلَتُه.</p><p><span class="qpc-hafs">﴿مَا يَغِيظُ﴾</span>: ما يَجِدُ في نَفْسِه مِنَ الغَيظِ والغَضَبِ.</p></div>"
  22,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَـٰتࣲ﴾</span>: واضحاتٍ.</p></div>"
  22,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ هَادُواْ﴾</span>: اليهُودَ.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰبِـِٔينَ﴾</span>: هم قَومٌ باقُونَ على فِطْرَتِهم، ولا دِينَ مقرَّرَ لهم يَتَّبِعونه.</p><p><span class="qpc-hafs">﴿وَٱلۡمَجُوسَ﴾</span>: هم عَبَدَةُ النّارِ.</p><p><span class="qpc-hafs">﴿يَفۡصِلُ بَيۡنَهُمۡ﴾</span>: يَقْضِي بَيْنَهم.</p><p><span class="qpc-hafs">﴿شَهِيدٌ﴾</span>: رَقِيبٌ يُحصِي أعمالَ خَلْقِه كلَّها.</p></div>"
  22,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ تَرَ﴾</span>: ألم تَعلَمْ.</p><p><span class="qpc-hafs">﴿يَسۡجُدُ لَهُۥ﴾</span>: يَنْقادُ له ويَخْضَعُ.</p><p><span class="qpc-hafs">﴿حَقَّ عَلَيۡهِ﴾</span>: وجَبَ عليه.</p></div>"
  22,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَصۡمَانِ﴾</span>: فريقانِ: وهم المؤمِنُونَ والكُفّارُ.</p><p><span class="qpc-hafs">﴿ٱخۡتَصَمُواْ﴾</span>: اخْتَلَفُوا.</p><p><span class="qpc-hafs">﴿فِي رَبِّهِمۡ﴾</span>: في دِينِ ربِّهم.</p><p><span class="qpc-hafs">﴿قُطِّعَتۡ لَهُمۡ﴾</span>: جُعِلَتْ لَهم.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيمُ﴾</span>: الماءُ البالغُ نِهايةَ الحرارةِ.</p></div>"
  22,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُصۡهَرُ بِهِۦ﴾</span>: يُذابُ به.</p></div>"
  22,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّقَـٰمِعُ﴾</span>: مَطارِقُ.</p></div>"
  22,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ غَمٍّ﴾</span>: مِنَ أجْلِ ما نالَهُم مِنَ الغَمِّ والكَرْبِ.</p></div>"
  22,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَلَّوۡنَ فِيهَا﴾</span>: يُلْبَسُونَ في الجنَّةِ الحُليَّ.</p><p><span class="qpc-hafs">﴿أَسَاوِرَ﴾</span>: مفردُه سِوارٌ: وهو ما يُلبَسُ في اليد للتزيُّنِ، ويُحِيطُ بالمِعْصَمِ.</p></div>"
  22,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُدُوٓاْ﴾</span>: هَداهُمُ اللهُ ووَفَّقَهم.</p><p><span class="qpc-hafs">﴿إِلَى ٱلطَّيِّبِ مِنَ ٱلۡقَوۡلِ﴾</span>: إلى كَلِمةِ التَّوحِيدِ أنْ لا إلَهَ إلا اللهُ.</p><p><span class="qpc-hafs">﴿إِلَىٰ صِرَ ٰ⁠طِ ٱلۡحَمِيدِ﴾</span>: الصِّراطِ المحمُودِ وهو الإسْلام.</p></div>"
  22,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَآءً﴾</span>: مُسْتَوِيًا.</p><p><span class="qpc-hafs">﴿ٱلۡعَـٰكِفُ فِيهِ﴾</span>: المقيمُ فيه المُلازمُ له.</p><p><span class="qpc-hafs">﴿وَٱلۡبَادِ﴾</span>: القادمُ إليه مِن غَيْرِ أهْلِه.</p><p><span class="qpc-hafs">﴿بِإِلۡحَادِۭ﴾</span>: بِعُدُولٍ عَنِ القَصْدِ.</p></div>"
  22,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِيمَ﴾</span>: أي: بَيَّنّا له.</p><p><span class="qpc-hafs">﴿وَطَهِّرۡ بَيۡتِيَ﴾</span>: أي: مِنَ الشِّركِ والكُفْرِ وسائِرِ النَّجاساتِ.</p></div>"
  22,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَذِّن فِي ٱلنَّاسِ﴾</span>: أي: أعْلِمْهم بإعْلانٍ.</p><p><span class="qpc-hafs">﴿رِجَالࣰا﴾</span>: جَمْعُ راجِلٍ، وهو مَن جاء يَمْشِي على رِجْلَيه.</p><p><span class="qpc-hafs">﴿وَعَلَىٰ كُلِّ ضَامِرࣲ﴾</span>: أي: ورُكبانًا على كلِّ بعيرٍ مَهزولٍ أتْعَبَه طولُ السَّفَرِ.</p><p><span class="qpc-hafs">﴿فَجٍّ عَمِيقࣲ﴾</span>: طَرِيقٍ بَعِيدٍ.</p></div>"
  22,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّامࣲ مَّعۡلُومَـٰتٍ﴾</span>: أيّامٍ مُعَيَّنةٍ هي: عاشرُ ذِي الحِجَّةِ وثلاثةُ أيّامٍ بَعْدَه.</p><p><span class="qpc-hafs">﴿عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِيمَةِ ٱلۡأَنۡعَـٰمِ﴾</span>: أي: على ذَبْحِ ما رَزَقَهُم مِن بهِيَمَةِ الأنعامِ، وهي: الإبِلُ والَبَقرُ والغَنَمُ.</p><p><span class="qpc-hafs">﴿ٱلۡبَآئِسَ ٱلۡفَقِيرَ﴾</span>: هو الفقيرُ الذي اشْتَدَّ فَقْرُه.</p></div>"
  22,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ لۡيَقۡضُواْ تَفَثَهُمۡ﴾</span>: ثم لِيُزِيلُوا وسَخَهم بعد خُرُوجِهِم مِن إحْرامِهِم.</p><p><span class="qpc-hafs">﴿وَلۡيُوفُواْ نُذُورَهُمۡ﴾</span>: ولْيُوَفُّوا بما أوجَبُوه على أنْفُسِهم مِن أعْمالِ البِرِّ في الحجِّ وغيرِه.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيۡتِ ٱلۡعَتِيقِ﴾</span>: وهو الكَعْبةُ، وقد أعْتَقَها اللهُ مِن تَسَلُّطِ الجبّارينَ عَلَيها.</p></div>"
  22,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُرُمَـٰتِ ٱللَّهِ﴾</span>: جَمْعُ حُرْمَةٍ، وهي ما وجَبَ القيامُ به، وحَرُمَ التَّفْرِيطُ فيه.</p><p><span class="qpc-hafs">﴿ٱلرِّجۡسَ مِنَ ٱلۡأَوۡثَـٰنِ﴾</span>: أي: مِن عِبادَةِ الأوثانِ، فإنها رِجْسٌ.</p><p><span class="qpc-hafs">﴿ٱلزُّورِ﴾</span>: الكذِبِ والافْتِراءِ على اللهِ.</p></div>"
  22,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُنَفَآءَ لِلَّهِ﴾</span>: مُسْتَقِيمِينَ على الحقِّ.</p><p><span class="qpc-hafs">﴿خَرَّ﴾</span>: سَقَطَ.</p><p><span class="qpc-hafs">﴿فَتَخۡطَفُهُ﴾</span>: فَتَسْلُبُه وتَذْهبُ بِه.</p><p><span class="qpc-hafs">﴿تَهۡوِي بِهِ﴾</span>: تَقْذِفُه وتَرْمِي بِه.</p><p><span class="qpc-hafs">﴿سَحِيقࣲ﴾</span>: بَعِيدٍ.</p></div>"
  22,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَعَـٰٓئِرَ ٱللَّهِ﴾</span>: هي معالمُ دِينِه، ومِنها شَعِيرةُ الحَجِّ.</p></div>"
  22,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَىٰٓ أَجَلࣲ مُّسَمࣰّى﴾</span>: وهو وقتُ ذَبْحِها.</p><p><span class="qpc-hafs">﴿ثُمَّ مَحِلُّهَآ﴾</span>: أي: حيثُ يَحِلُّ ذَبْحُها.</p></div>"
  22,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنسَكࣰا﴾</span>: ذَبْحًا يَذْبَحُونَه أو عِيدًا أو حَجًّا يَحُجُّونَه.</p><p><span class="qpc-hafs">﴿عَلَىٰ مَا رَزَقَهُم﴾</span>: على ذَبْحِ ما رَزَقَهُم.</p><p><span class="qpc-hafs">﴿ٱلۡمُخۡبِتِينَ﴾</span>: الخاشِعِينَ المخْلصِيِنَ.</p></div>"
  22,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجِلَتۡ﴾</span>: خافتْ.</p></div>"
  22,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡبُدۡنَ﴾</span>: وهي الإبِلُ والبَقَرُ مما يُجْزِئُ ذَبْحُه عَنْ سَبْعةٍ.</p><p><span class="qpc-hafs">﴿صَوَآفَّ﴾</span>: أي: قائِماتٍ، بأن تُقامَ على قَوائِمِها الأرْبَعِ، ثم تُعْقَلَ إحْدى يَدَيها.</p><p><span class="qpc-hafs">﴿وَجَبَتۡ جُنُوبُهَا﴾</span>: سقَطَتْ جُنوبُها على الأرضِ.</p><p><span class="qpc-hafs">﴿ٱلۡقَانِعَ﴾</span>: الفقيرَ المُتَعَفِّفَ عَنِ السُّؤالِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمُعۡتَرَّ﴾</span>: الُمحتاجَ الَّذي يَسْأَلُ.</p></div>"
  22,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلتَّقۡوَىٰ مِنكُمۡ﴾</span>: إخْلاصُكم لله وخَشْيَتُكُم مِنه.</p></div>"
  22,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُدَ ٰ⁠فِعُ﴾</span>: يَدْفْعُ ويَرُدُّ.</p><p><span class="qpc-hafs">﴿خَوَّانࣲ﴾</span>: كثيرِ الخِيانَةِ.</p><p><span class="qpc-hafs">﴿كَفُورٍ﴾</span>: جَحُودٍ لِنِعَمِ اللهِ.</p></div>"
  22,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُذِنَ لِلَّذِينَ﴾</span>: أي: شُرِعَ لهم القِتالُ.</p></div>"
  22,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَوَ ٰ⁠مِعُ﴾</span>: مَعابدُ رُهْبانِ النَّصارى.</p><p><span class="qpc-hafs">﴿بِيَعࣱ﴾</span>: كَنائِسُ النَّصارى.</p><p><span class="qpc-hafs">﴿صَلَوَ ٰ⁠تࣱ﴾</span>: كنائِسُ اليهُودِ.</p></div>"
  22,41,""
  22,42,""
  22,43,""
  22,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ مَدۡيَنَ﴾</span>: قومُ شُعَيبٍ عليه الصَّلاة والسَّلامُ.</p><p><span class="qpc-hafs">﴿فَأَمۡلَيۡتُ﴾</span>: فأَمهَلْتُ.</p><p><span class="qpc-hafs">﴿ثُمَّ أَخَذۡتُهُمۡ﴾</span>: أي: بالعقاب فَأَهْلَكْتُهم.</p><p><span class="qpc-hafs">﴿نَكِيرِ﴾</span>: أي: إنْكارِي عَلَيهم.</p></div>"
  22,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَأَيِّن﴾</span>: فَكَثِيرًا.</p><p><span class="qpc-hafs">﴿ظَالِمَةࣱ﴾</span>: أي: أهلُها بالكُفْرِ والشِّركِ.</p><p><span class="qpc-hafs">﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾</span>: ساقِطةٌ على سُقُوفِها.</p><p><span class="qpc-hafs">﴿وَبِئۡرࣲ مُّعَطَّلَةࣲ﴾</span>: وبِئْرٍ مَهْجُورَةٍ بِمَوْتِ أهْلِها.</p><p><span class="qpc-hafs">﴿وَقَصۡرࣲ مَّشِيدٍ﴾</span>: وقَصْرٍ مُجَصَّصٍ مَرْفُوعِ البُنْيانِ، خَرِبَ بِمَوتِ أهْلِه.</p></div>"
  22,46,""
  22,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّمَّا تَعُدُّونَ﴾</span>: أي: مما تَحْسُبُونَ من سِنِي الدُّنيا.</p></div>"
  22,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡلَيۡتُ لَهَا﴾</span>: أمْهَلْتُها.</p><p><span class="qpc-hafs">﴿ظَالِمَةࣱ﴾</span>: أي: أهلُها بالكفرِ والشِّركِ.</p><p><span class="qpc-hafs">﴿ثُمَّ أَخَذۡتُهَا﴾</span>: أي: أهْلَكْتُها.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المرْجِعُ.</p></div>"
  22,49,""
  22,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرِزۡقࣱ كَرِيمࣱ﴾</span>: ورِزْقٌ حَسَنٌ لا يَنْقَطِعُ، وهو الجنَّةُ.</p></div>"
  22,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلَّذِينَ سَعَوۡاْ فِيٓ ءَايَـٰتِنَا﴾</span>: والذين اجْتَهَدُوا في مُحارَبةِ القرآنِ وإبْطالِ آياتِه وحُجَجِه.</p><p><span class="qpc-hafs">﴿مُعَـٰجِزِينَ﴾</span>: ظانِّينَ أنّهم يُعْجِزُونَنا ويَغْلِبُوننا.</p><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡجَحِيمِ﴾</span>: أهلُ النارِ الموقَدَةِ.</p></div>"
  22,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمَنَّىٰٓ﴾</span>: قَرَأَ ما نَزَلَ عَلَيهِ.</p><p><span class="qpc-hafs">﴿أَلۡقَى ٱلشَّيۡطَـٰنُ فِيٓ أُمۡنِيَّتِهِۦ﴾</span>: أي: ألْقى في قِراءتِه الوَساوِسَ والشُّبُهاتِ.</p><p><span class="qpc-hafs">﴿فَيَنسَخُ ٱللَّهُ﴾</span>: أي: فَيُزِيلُه.</p><p><span class="qpc-hafs">﴿مَا يُلۡقِي ٱلشَّيۡطَـٰنُ﴾</span>: أي: ما يُلْقِيهِ مِن وساوِسَ وشُبُهاتٍ.</p><p><span class="qpc-hafs">﴿ثُمَّ يُحۡكِمُ ٱللَّهُ ءَايَـٰتِهِۦ﴾</span>: ثُمَّ يُثَبِّتُ اللهُ آياتِه كما نَزَلَتْ ويَحفْظُها مِنَ التَّبْدِيل.</p></div>"
  22,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: ابْتلِاءً واخْتِبارًا.</p><p><span class="qpc-hafs">﴿مَّرَضࣱ﴾</span>: شكٌّ ونِفاقٌ.</p><p><span class="qpc-hafs">﴿وَٱلۡقَاسِيَةِ قُلُوبُهُمۡ﴾</span>: أي: غَلُظَتْ قُلُوبُهم عَن قَبُولِ الحَقِّ.</p><p><span class="qpc-hafs">﴿شِقَاقِۭ بَعِيدࣲ﴾</span>: خِلافٍ بَعِيدٍ عَنِ الصَّوابِ.</p></div>"
  22,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنَّهُ ٱلۡحَقُّ مِن رَّبِّكَ﴾</span>: أنّ القرآنَ هو الحقُّ النازِلُ مِن عِنْدِ اللهِ عَلَيكَ.</p><p><span class="qpc-hafs">﴿فَتُخۡبِتَ لَهُۥ﴾</span>: فَتَخْشَعَ لَهُ وتَخْضَعَ.</p></div>"
  22,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي مِرۡيَةࣲ مِّنۡهُ﴾</span>: في شَكٍّ مِن هَذا القُرآنِ.</p><p><span class="qpc-hafs">﴿بَغۡتَةً﴾</span>: فَجْأةً.</p><p><span class="qpc-hafs">﴿يَوۡمٍ عَقِيمٍ﴾</span>: هو يومُ القيامةِ الَّذي لا خيرَ فيه للكفارِ، ولا يومَ بَعْدَه.</p></div>"
  22,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُلۡكُ﴾</span>: السُّلْطانُ القاهِرُ.</p><p><span class="qpc-hafs">﴿يَوۡمَئِذࣲ﴾</span>: أي: يومَ القيامةِ.</p></div>"
  22,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّهِينࣱ﴾</span>: مُخْزٍ ومُذِلٌّ.</p></div>"
  22,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِزۡقًا حَسَنࣰا﴾</span>: وهو الجنَّةُ.</p></div>"
  22,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّدۡخَلࣰا﴾</span>: مكانَ دخولٍ، وهو الجنَّةُ.</p></div>"
  22,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ بُغِيَ عَلَيۡهِ﴾</span>: ثُمَّ اعْتُدِيَ عليه بالظُّلْمِ.</p></div>"
  22,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُولِجُ﴾</span>: يُدخِلُ.</p></div>"
  22,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يَدۡعُونَ مِن دُونِهِۦ﴾</span>: ما يَعْبُدُه الُمشْرِكُون مِن دُونِ اللهِ مِنَ الأصْنامِ وغَيرِها.</p><p><span class="qpc-hafs">﴿ٱلۡعَلِيُّ﴾</span>: أي: على خَلْقِه ذاتًا وقدْرًا وقَهْرًا.</p></div>"
  22,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَآءࣰ﴾</span>: مَطَرًا.</p></div>"
  22,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَمِيدُ﴾</span>: المحمودُ المُسْتَحِقُّ لِلْحمْدِ في كُلِّ حالٍ.</p></div>"
  22,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَخَّرَ﴾</span>: ذَلَّلَ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p><p><span class="qpc-hafs">﴿يُمۡسِكُ ٱلسَّمَآءَ﴾</span>: يَحْفظُ السَّماءَ.</p></div>"
  22,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكَفُورࣱ﴾</span>: لَجَحُودٌ.</p></div>"
  22,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنسَكًا﴾</span>: شَرِيعةً خاصَّةً.</p><p><span class="qpc-hafs">﴿هُمۡ نَاسِكُوهُ﴾</span>: هم عامِلُونَ به.</p><p><span class="qpc-hafs">﴿فَلَا يُنَـٰزِعُنَّكَ فِي ٱلۡأَمۡرِ﴾</span>: فلا يَحِقُّ لَهُم أنْ يخاصِمُوكَ في شَرِيعَتِكَ.</p><p><span class="qpc-hafs">﴿هُدࣰى مُّسۡتَقِيمࣲ﴾</span>: دِينٍ قَوِيمٍ لا اعْوِجاجَ فِيه.</p></div>"
  22,68,""
  22,69,""
  22,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي كِتَـٰبٍ﴾</span>: أي: في اللَّوحِ المحْفُوظِ.</p></div>"
  22,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً وبُرْهانًا.</p><p><span class="qpc-hafs">﴿لِلظَّـٰلِمِينَ﴾</span>: للمُشْرِكِينَ.</p></div>"
  22,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُنكَرَ﴾</span>: الأمرَ الذي يُنْكَرُ مِنَ العُبُوسِ والغَضَبِ والكَراهَةِ.</p><p><span class="qpc-hafs">﴿يَسۡطُونَ﴾</span>: يَبْطِشُونَ.</p><p><span class="qpc-hafs">﴿بِشَرࣲّ مِّن ذَ ٰ⁠لِكُمُ﴾</span>: بِشَرٍّ مِن غَيظِكُم على مَن يَتْلُو عليكُم آياتِ اللهِ.</p><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: ساءَ وقَبُحَ المكانُ الذي يَرجِعُونَ إليه.</p></div>"
  22,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسۡتَمِعُواْ لَهُۥٓ﴾</span>: أي: سَماعَ تَدَبُّرٍ.</p><p><span class="qpc-hafs">﴿تَدۡعُونَ﴾</span>: تَعْبُدُونَ.</p><p><span class="qpc-hafs">﴿ذُبَابࣰا﴾</span>: ذُبابةً واحِدةً مَعَ صِغَرِها.</p><p><span class="qpc-hafs">﴿وَإِن يَسۡلُبۡهُمُ﴾</span>: أي: وإن يَأْخُذِ الذُّبابُ شيئًا مِن هَذهِ المعْبُوداتِ.</p><p><span class="qpc-hafs">﴿لَّا يَسۡتَنقِذُوهُ مِنۡهُ﴾</span>: أي: لا يَقْدِرُوا -لِعَجْزِهِم- على اسْتِرْدادِ ما أُخِذَ مِنهم.</p><p><span class="qpc-hafs">﴿ٱلطَّالِبُ﴾</span>: هو المَعبُودُ مِن دُونِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَطۡلُوبُ﴾</span>: هو الذُّبابُ.</p></div>"
  22,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا قَدَرُواْ ٱللَّهَ حَقَّ قَدۡرِهِۦٓ﴾</span>: ما عَظَّمَ المشْرِكُونَ اللهَ تَعالى حقَّ تَعْظِيمِهِ.</p></div>"
  22,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡطَفِي﴾</span>: يَخْتارُ.</p></div>"
  22,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا بَيۡنَ أَيۡدِيهِمۡ﴾</span>: أي: أعْمالَهم التي عَمِلُوها.</p><p><span class="qpc-hafs">﴿مَا خَلۡفَهُمۡ﴾</span>: أي: أعْمالَهم التي سَيَعْمَلُونَها.</p></div>"
  22,77,""
  22,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَـٰهِدُواْ فِي ٱللَّهِ﴾</span>: أي: في سَبِيِلهِ لإعْلاءِ كَلِمَتِهِ.</p><p><span class="qpc-hafs">﴿هُوَ ٱجۡتَبَىٰكُمۡ﴾</span>: اصْطَفاكُم اللهُ لِحَمْلِ دِينِه.</p><p><span class="qpc-hafs">﴿مِنۡ حَرَجࣲ﴾</span>: مِن ضِيقٍ ومَشَقَّةٍ بتكْلِيفٍ يَشُقُّ عَلَيكُم.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: أي: في الكُتُبِ المُنَزَّلةِ السّابِقَةِ.</p><p><span class="qpc-hafs">﴿فِي هَـٰذَا﴾</span>: أي: في هَذا القرآنِ.</p><p><span class="qpc-hafs">﴿شُهَدَآءَ عَلَى ٱلنَّاسِ﴾</span>: أي: على الأممِ السّابَقَةِ أنّ رُسُلَهم قد بَلَّغَتْهم رِسالاتِ ربِّهم.</p><p><span class="qpc-hafs">﴿وَٱعۡتَصِمُواْ بِٱللَّهِ﴾</span>: أي: اجْعَلُوه عِصْمةً لكم مما تَحْذَرُونَ، والتَجِئُوا إليه في جميعِ أُمُورِكُم.</p><p><span class="qpc-hafs">﴿هُوَ مَوۡلَىٰكُمۡ﴾</span>: هو ناصِرُكُم، ومُتَوَلِّي أمورِكُم.</p></div>"
