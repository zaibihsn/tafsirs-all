quran[200]{c,v,t}:
  3,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الٓمٓ﴾</span>: سَبَقَ شَرْحُها في الآية</p></div>"
  3,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَيُّومُ﴾</span>: القائمُ بنفسِه، والمُقيمُ لأحوالِ خَلْقِه.</p></div>"
  3,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القرآنَ.</p><p><span class="qpc-hafs">﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾</span>: يَشْهَدُ على صِدْقِ ما قبلَه من كُتُبٍ.</p></div>"
  3,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُرۡقَانَ﴾</span>: ما يُفَرِّقُ بينَ الحقِّ والباطلِ، وهو القرآنُ.</p></div>"
  3,5,""
  3,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡفَ يَشَآءُ﴾</span>: مِن ذَكَرٍ وأنثى، وشَقِيٍّ وسعيدٍ، وغيرِ ذلك.</p></div>"
  3,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّحۡكَمَـٰتٌ﴾</span>: واضحاتُ المعنى، ظاهراتُ الدَّلالةِ.</p><p><span class="qpc-hafs">﴿أُمُّ ٱلۡكِتَـٰبِ﴾</span>: أصلُه الذي يُرْجَعُ إليه عندَ الاشتِباهِ.</p><p><span class="qpc-hafs">﴿مُتَشَـٰبِهَـٰتࣱ﴾</span>: لا يتعَيَّنُ معناها، ولا تَظْهَرُ دَلالتُها.</p><p><span class="qpc-hafs">﴿زَيۡغࣱ﴾</span>: مَيْلٌ.</p><p><span class="qpc-hafs">﴿فَيَتَّبِعُونَ مَا تَشَـٰبَهَ مِنۡهُ﴾</span>: يَتَّبعون الآياتِ المتشابهاتِ، فيُشَكِّكُون بها على المؤمنين.</p><p><span class="qpc-hafs">﴿ٱبۡتِغَآءَ ٱلۡفِتۡنَةِ﴾</span>: طَلَبًا منهم للتَّلبيسِ عليهم في دينِهم.</p><p><span class="qpc-hafs">﴿وَٱبۡتِغَآءَ تَأۡوِيلِهِۦ﴾</span>: ولتأويلِهم لها على الوجه الذي يوافِقُ مذهبَهم.</p><p><span class="qpc-hafs">﴿وَٱلرَّ ٰ⁠سِخُونَ﴾</span>: والمتمَكِّنُونَ.</p><p><span class="qpc-hafs">﴿كُلࣱّ﴾</span>: كلُّ القرآنِ.</p><p><span class="qpc-hafs">﴿وَمَا يَذَّكَّرُ﴾</span>: وما يتدبَّرُ المعانيَ على وجْهِها الصحيحِ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾</span>: أصحابُ العقولِ السليمةِ.</p></div>"
  3,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُزِغۡ قُلُوبَنَا﴾</span>: لاتَصْرِفْ قلوبَنا عن الإيمانِ بك.</p></div>"
  3,9,""
  3,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن تُغۡنِيَ عَنۡهُمۡ﴾</span>: لن تنفعَهم، ولن تُنْجِيَهم.</p><p><span class="qpc-hafs">﴿مِّنَ ٱللَّهِ﴾</span>: من عقوبتهِ، إن أحَلَّها بهم عاجلًا في الدنيا.</p><p><span class="qpc-hafs">﴿وَقُودُ ٱلنَّارِ﴾</span>: حَطَبُ النارِ.</p></div>"
  3,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَدَأۡبِ ءَالِ فِرۡعَوۡنَ﴾</span>: شَأْنُ الكافرين في تكذيبهِم ومايَنْزِلُ بهم من العقوبةِ مِثْلُ شأنِ آلِ فرعونَ.</p><p><span class="qpc-hafs">﴿فَأَخَذَهُمُ ٱللَّهُ﴾</span>: فعاجَلَهم بالعُقوبةِ.</p></div>"
  3,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّلَّذِينَ كَفَرُواْ﴾</span>: لليهودِ.</p><p><span class="qpc-hafs">﴿وَتُحۡشَرُونَ﴾</span>: وتُجْمَعون، وتُساقُون.</p><p><span class="qpc-hafs">﴿ٱلۡمِهَادُ﴾</span>: الفِراشُ.</p></div>"
  3,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: دَلالَةٌ عظيمةٌ.</p><p><span class="qpc-hafs">﴿ٱلۡتَقَتَا﴾</span>: أي: في معركةِ بدرٍ.</p><p><span class="qpc-hafs">﴿يَرَوۡنَهُم مِّثۡلَيۡهِمۡ﴾</span>: يرى المشركون المسلمين في العددِ مثلَيْهم.</p><p><span class="qpc-hafs">﴿لَعِبۡرَةࣰ﴾</span>: لعِظَةً.</p><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلۡأَبۡصَـٰرِ﴾</span>: لأصحابِ البصائرِ.</p></div>"
  3,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُيِّنَ﴾</span>: حُسِّنَ.</p><p><span class="qpc-hafs">﴿وَٱلۡقَنَـٰطِيرِ ٱلۡمُقَنطَرَةِ﴾</span>: والأموالِ الكثيرةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُسَوَّمَةِ﴾</span>: المُعَلَّمَةِ الحِسانِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَنۡعَـٰمِ﴾</span>: من الإبِلِ والبقرِوالغَنَمِ.</p><p><span class="qpc-hafs">﴿وَٱلۡحَرۡثِ﴾</span>: الأرضِ المتخَذَةِ للزِّراعةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَـَٔابِ﴾</span>: المَرْجِعِ.</p></div>"
  3,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن ذَ ٰ⁠لِكُمۡ﴾</span>: ممّا حُسِّنَ للناسِ في الحياةِ الدُّنيا.</p><p><span class="qpc-hafs">﴿مُّطَهَّرَةࣱ﴾</span>: من الحَيْضِ والنِّفاسِ، وسوءِ الخُلُقِ.</p><p><span class="qpc-hafs">﴿وَرِضۡوَ ٰ⁠نࣱ﴾</span>: ورِضا.</p></div>"
  3,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِنَا﴾</span>: ونَجِّنا.</p></div>"
  3,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلصَّـٰدِقِينَ﴾</span>: الذين صَدَقُوا اللهَ، فعَمِلُوا بماجاء به.</p><p><span class="qpc-hafs">﴿وَٱلۡقَـٰنِتِينَ﴾</span>: والمطيعين له.</p><p><span class="qpc-hafs">﴿بِٱلۡأَسۡحَارِ﴾</span>: بآخِرِ الليلِ.</p></div>"
  3,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمَلَـٰٓئِكَةُ﴾</span>: أي: يَشْهَدُون كذلك.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p></div>"
  3,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ مَا جَآءَهُمُ ٱلۡعِلۡمُ﴾</span>: أي: المقتضي لعَدَمِ الاختلافِ، بما تَضَمَّنَتْه كُتُبُهم المنزَّلةُ.</p><p><span class="qpc-hafs">﴿بَغۡيَۢا بَيۡنَهُمۡ﴾</span>: حَسَدًا وطَلَبًا للدُّنيا، فصَدَّهم عن اتِّباعِ الَحقِّ.</p><p><span class="qpc-hafs">﴿سَرِيعُ ٱلۡحِسَابِ﴾</span>: يحفَظُ ذلك عليهم بغيرِ كُلْفَةٍ.</p></div>"
  3,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَآجُّوكَ﴾</span>: جادَلُوك أيُّها الرسولُ.</p><p><span class="qpc-hafs">﴿أَسۡلَمۡتُ﴾</span>: أخلَصْتُ.</p><p><span class="qpc-hafs">﴿وَمَنِ ٱتَّبَعَنِ﴾</span>: وكذلك أسْلَمَ وجهَه مَنِ اتَّبعَني.</p><p><span class="qpc-hafs">﴿وَٱلۡأُمِّيِّـۧنَ﴾</span>: مُشْركي العربِ الذين لايكتبُون.</p><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا.</p></div>"
  3,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p></div>"
  3,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَبِطَتۡ﴾</span>: بَطَلَتْ.</p></div>"
  3,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَى ٱلَّذِينَ﴾</span>: إلى اليهودِ الذين كانوا في زمن النبيِّ ﷺ مِمَّن أُوتي عِلْمًا.</p><p><span class="qpc-hafs">﴿نَصِيبࣰا مِّنَ ٱلۡكِتَـٰبِ﴾</span>: حَظًّا من التوراةِ.</p><p><span class="qpc-hafs">﴿كِتَـٰبِ ٱللَّهِ﴾</span>: التوراةِ.</p><p><span class="qpc-hafs">﴿يَتَوَلَّىٰ﴾</span>: يأبى.</p></div>"
  3,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: الانصرافُ عن الحقِّ.</p><p><span class="qpc-hafs">﴿وَغَرَّهُمۡ﴾</span>: وخَدَعَهم.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يختلِقُون من الأكاذيبِ في ادِّعائِهم أنهم أبناءُ اللهِ وأحِبّاؤُه.</p></div>"
  3,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَيۡفَ﴾</span>: أي: فكيف يكونُ حالهُم؟</p><p><span class="qpc-hafs">﴿وَوُفِّيَتۡ﴾</span>: وجُوزِيَتْ.</p><p><span class="qpc-hafs">﴿مَّا كَسَبَتۡ﴾</span>: ما عَمِلَتْ من خيرٍ أو شَرٍّ.</p></div>"
  3,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنزِعُ﴾</span>: تَسْلُبُ.</p></div>"
  3,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُولِجُ﴾</span>: تُدْخِلُ.</p><p><span class="qpc-hafs">﴿وَتُخۡرِجُ ٱلۡحَيَّ مِنَ ٱلۡمَيِّتِ﴾</span>: تُخْرِجُ الإنسانَ الحَيَّ من النُّطْفةِ الميتةِ.</p><p><span class="qpc-hafs">﴿وَتُخۡرِجُ ٱلۡمَيِّتَ مِنَ ٱلۡحَيِّ﴾</span>: تُخْرِجُ النُّطْفَةَ الميتة من الإنسانِ الحيِّ.</p><p><span class="qpc-hafs">﴿بِغَيۡرِ حِسَابࣲ﴾</span>: بغير مُحاسَبةٍ.</p></div>"
  3,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَتَّخِذِ ٱلۡمُؤۡمِنُونَ ٱلۡكَـٰفِرِينَ أَوۡلِيَآءَ﴾</span>: لا تَتَّخِذُوا أيها المؤمنون الكافرين أنصارًا.</p><p><span class="qpc-hafs">﴿إِلَّآ أَن تَتَّقُواْ مِنۡهُمۡ تُقَىٰةࣰ﴾</span>: إلاأن تكونوا ضِعافًا، فرَخَّص لكم في مُهادنتِهم اتقاءً لشَرِّهم.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: رجوعُ الخلائقِ للحِسابِ.</p></div>"
  3,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُبۡدُوهُ﴾</span>: تُظْهِرُوه.</p></div>"
  3,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّحۡضَرࣰا﴾</span>: مُوَفَّرًا.</p><p><span class="qpc-hafs">﴿أَمَدَۢا﴾</span>: زَمَنًا وأجَلًا.</p></div>"
  3,31,""
  3,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا.</p></div>"
  3,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡطَفَىٰٓ﴾</span>: اختار.</p><p><span class="qpc-hafs">﴿عَلَى ٱلۡعَـٰلَمِينَ﴾</span>: جَعَلَهم أفضلَ أهلِ زمانِهم.</p></div>"
  3,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُرِّيَّةَۢ بَعۡضُهَا مِنۢ بَعۡضࣲ﴾</span>: تَسَلْسَلَ الفَضْلُ في ذَراريهم.</p></div>"
  3,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱمۡرَأَتُ عِمۡرَ ٰ⁠نَ﴾</span>: أمُّ مريمَ.</p><p><span class="qpc-hafs">﴿نَذَرۡتُ﴾</span>: جَعَلْتُه لخِدْمَةِ بيتِ المقدسِ.</p><p><span class="qpc-hafs">﴿مُحَرَّرࣰا﴾</span>: خالصًا لعبادتِك.</p></div>"
  3,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَعۡتُهَآ أُنثَىٰ﴾</span>: أي: لاتَصْلُحُ للخِدْمةِ.</p><p><span class="qpc-hafs">﴿وَلَيۡسَ ٱلذَّكَرُ كَٱلۡأُنثَىٰ﴾</span>: ليس الذَّكَرُ الذي أرَدْتُ للخدمةِ كالأنثى التي لا تَصْلُحُ لذلك.</p><p><span class="qpc-hafs">﴿أُعِيذُهَا﴾</span>: أُحَصِّنُها.</p><p><span class="qpc-hafs">﴿ٱلرَّجِيمِ﴾</span>: المَطْرودِ من رحمتك.</p></div>"
  3,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنۢبَتَهَا نَبَاتًا حَسَنࣰا﴾</span>: تَوَلّى ابْنَتَها، فكَمُلَتْ بذلك أحوالُها.</p><p><span class="qpc-hafs">﴿ٱلۡمِحۡرَابَ﴾</span>: مَحَلَّ عبادتهِ.</p></div>"
  3,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُنَالِكَ﴾</span>: عند رؤيةِ زكريّا ما عندَ مريمَ من رزقِ اللهِ، وفَضْلهِ.</p><p><span class="qpc-hafs">﴿ذُرِّيَّةࣰ طَيِّبَةً﴾</span>: ولَدًا مباركًا. وتُطْلَقُ الذُّرِّيَّةُ على الجمعِ والواحدِ.</p></div>"
  3,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمِحۡرَابِ﴾</span>: مُقَدَّم المسجدِ، وهو مكانُ عبادتِه.</p><p><span class="qpc-hafs">﴿مُصَدِّقَۢا بِكَلِمَةࣲ مِّنَ ٱللَّهِ﴾</span>: يُصَدِّقُ بعيسى عليه السلامُ.</p><p><span class="qpc-hafs">﴿وَسَيِّدࣰا﴾</span>: شريفًا في العِلْمِ والعبادةِ.</p><p><span class="qpc-hafs">﴿وَحَصُورࣰا﴾</span>: يَكُفُّ عن النساءِ، فيمتنعُ عنهنَّ مع القُدرةِ.</p></div>"
  3,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: من أيِّ وجهٍ؟</p><p><span class="qpc-hafs">﴿ٱلۡكِبَرُ﴾</span>: الشيخوخةُ.</p><p><span class="qpc-hafs">﴿عَاقِرࣱ﴾</span>: عَقيمٌ.</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ ٱللَّهُ﴾</span>: هَيِّنٌ عليه أن يخلقَ ولدًا من الكبيرِ والعقيمِ.</p></div>"
  3,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: علامةً أسْتَدِلُّ بها على وجودِ الوَلَدِ.</p><p><span class="qpc-hafs">﴿رَمۡزࣰا﴾</span>: إشارةً وإيماءً.</p><p><span class="qpc-hafs">﴿بِٱلۡعَشِيِّ﴾</span>: مِن زوالِ الشمسِ إلى أن تَغِيبَ.</p><p><span class="qpc-hafs">﴿وَٱلۡإِبۡكَـٰرِ﴾</span>: من مَطْلَعِ الفجرِ إلى وقتِ الضُّحى.</p></div>"
  3,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡطَفَىٰكِ﴾</span>: اختارَكِ لطاعتِه.</p><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: عالَمِي زمانِك.</p></div>"
  3,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱقۡنُتِي﴾</span>: أخْلِصي الطاعةَ لربِّك.</p></div>"
  3,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا كُنتَ لَدَيۡهِمۡ﴾</span>: أي: نحن نُعْلِمُك أخبارَهم.</p><p><span class="qpc-hafs">﴿يُلۡقُونَ أَقۡلَـٰمَهُمۡ﴾</span>: يُجْرُون القُرْعَةَ، بإلقاءِ سِهامِهم على كَفالةِ مريمَ، فأصابَتْ زكريا.</p></div>"
  3,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِكَلِمَةࣲ مِّنۡهُ﴾</span>: يكونُ وجودُه بكلمةٍ من اللهِ، وهي قولُه: «كن»، فيكونُ.</p><p><span class="qpc-hafs">﴿وَجِيهࣰا﴾</span>: له الجاهُ العظيمُ عندَ اللهِ.</p></div>"
  3,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡمَهۡدِ﴾</span>: في مَضْجَعِ الصبيِّ في رَضاعِه.</p><p><span class="qpc-hafs">﴿وَكَهۡلࣰا﴾</span>: مَن كان بينَ سِنِّ الشَّبابِ والشيخوخةِ.</p></div>"
  3,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: من أيِّ وجه؟</p></div>"
  3,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: الكتابةَ.</p></div>"
  3,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةࣲ﴾</span>: بعلامةٍ دالَّةٍ على أني مُرْسَلٌ من اللهِ.</p><p><span class="qpc-hafs">﴿فِيهِ﴾</span>: في ذلك الخَلْقِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَكۡمَهَ﴾</span>: مَن وُلِدَ أعمى.</p><p><span class="qpc-hafs">﴿وَٱلۡأَبۡرَصَ﴾</span>: مَن يَظْهَرُ في جِلْده بياضٌ.</p><p><span class="qpc-hafs">﴿تَدَّخِرُونَ﴾</span>: تُخَبِّئون لوقتِ الحاجةِ.</p></div>"
  3,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمُصَدِّقࣰا﴾</span>: وجِئتُكم مُصَدِّقًا.</p><p><span class="qpc-hafs">﴿بَعۡضَ ٱلَّذِي حُرِّمَ عَلَيۡكُمۡ﴾</span>: مثلَ لحومِ الإبلِ، والشُّحومِ، وغيرِها.</p></div>"
  3,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣱ﴾</span>: طريقٌ.</p></div>"
  3,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَى ٱللَّهِ﴾</span>: مُتَوَجِّهًا إلى اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَوَارِيُّونَ﴾</span>: هم أصْفِياءُ عيسى عليه السلامُ.</p></div>"
  3,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّـٰهِدِينَ﴾</span>: الذين شَهِدُوا بالحقِّ، وأقَرُّوا بالتوحيدِ.</p></div>"
  3,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَكَرُواْ﴾</span>: أرادوا قَتْلَ عيسى عليه السلام.</p><p><span class="qpc-hafs">﴿وَمَكَرَ ٱللَّهُ﴾</span>: بحَقٍّ على ما يَلِيقُ به، وذلك من إلقائِه شَبَهَ عيسى على بعض أتباعِه حتى قَتَلُوه، ورَفْعِ عيسى إليه.</p></div>"
  3,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَوَفِّيكَ﴾</span>: قابضُك من الأرضِ.</p><p><span class="qpc-hafs">﴿وَمُطَهِّرُكَ﴾</span>: ومُخَلِّصُك.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱتَّبَعُوكَ﴾</span>: هم خُلَّصُ أصحابِك الذين لم يَغْلُوا فيك.</p><p><span class="qpc-hafs">﴿فَوۡقَ ٱلَّذِينَ كَفَرُوٓاْ﴾</span>: ظاهرين على الذين جَحَدُوا نبوَّتَك.</p></div>"
  3,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلدُّنۡيَا﴾</span>: بالقَتْلِ والصَّغارِ.</p></div>"
  3,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَيُوَفِّيهِمۡ أُجُورَهُمۡ﴾</span>: فيُعْطِيهم ثوابَ أعمالِهم كاملًا.</p></div>"
  3,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡـَٔايَـٰتِ﴾</span>: من الدَّلائلِ الواضحةِ على صحةِ رسالتِك.</p><p><span class="qpc-hafs">﴿وَٱلذِّكۡرِ ٱلۡحَكِيمِ﴾</span>: القُرآنِ الذي يَفْصِلُ بينَ الحَقِّ والباطلِ</p></div>"
  3,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَثَلِ ءَادَمَ﴾</span>: مَثَلُه كمَثَلِ خَلْقِ آدمَ من غير أبٍ، ولا أمٍّ.</p></div>"
  3,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُمۡتَرِينَ﴾</span>: الشاكِّين.</p></div>"
  3,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَآجَّكَ فِيهِ﴾</span>: جادَلَك في عيسى.</p><p><span class="qpc-hafs">﴿نَبۡتَهِلۡ﴾</span>: نَتَوَجَّهْ إلى اللهِ بالدُّعاء.</p></div>"
  3,62,""
  3,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا عن تصديِقك.</p></div>"
  3,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَآءِۭ﴾</span>: عَدْلٍ وحَقّ، نلتزمُ بها.</p><p><span class="qpc-hafs">﴿وَلَا يَتَّخِذَ بَعۡضُنَا بَعۡضًا أَرۡبَابࣰا﴾</span>: ماكان بطاعةِ الأتباعِ للرؤساءِ فيما أمروهُم به من المعاصِي.</p><p><span class="qpc-hafs">﴿مُسۡلِمُونَ﴾</span>: خاضِعُون لرَبِّنا.</p></div>"
  3,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُحَآجُّونَ فِيٓ إِبۡرَ ٰ⁠هِيمَ﴾</span>: تُجادِلُون في أنّ إبراهيمَ على مِلَّتِكم.</p></div>"
  3,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَـٰجَجۡتُمۡ﴾</span>: جادَلْتُم.</p><p><span class="qpc-hafs">﴿فِيمَا لَكُم بِهِۦ عِلۡمࣱ﴾</span>: في أمْرِ دينِكم مِمّا تعتقدون صِحَّتَه.</p></div>"
  3,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مُتَّبِعًا أمْرَ الله.</p><p><span class="qpc-hafs">﴿مُّسۡلِمࣰا﴾</span>: خاشِعًا لربِّه، مُلْتَزِمًا بأحكامِه.</p></div>"
  3,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلَى﴾</span>: أحَقُّ.</p><p><span class="qpc-hafs">﴿وَهَـٰذَا ٱلنَّبِيُّ﴾</span>: محمدٌ ﷺ.</p></div>"
  3,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡ يُضِلُّونَكُمۡ﴾</span>: عن الإسلامِ.</p></div>"
  3,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَ تَكۡفُرُونَ بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: لِمَ تَجْحَدُون بآياتِ اللهِ التي أنزلها على رُسُلهِ في كُتُبِكم؟</p><p><span class="qpc-hafs">﴿وَأَنتُمۡ تَشۡهَدُونَ﴾</span>: أنه الحقُّ، فتَجِدُونه مكتوبًا عندَكم ثم تُنْكِرونه.</p></div>"
  3,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلۡبِسُونَ﴾</span>: تَخْلِطُون.</p><p><span class="qpc-hafs">﴿ٱلۡحَقَّ﴾</span>: الذي في كُتُبِكم.</p><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: بما حَرَّفْتُموه بأيدِيكم.</p><p><span class="qpc-hafs">﴿وَتَكۡتُمُونَ ٱلۡحَقَّ﴾</span>: وتُخْفُون ما في كُتبِكم من مَبْعَثِ محمدٍ ﷺ.</p></div>"
  3,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَامِنُواْ﴾</span>: صَدِّقوا.</p><p><span class="qpc-hafs">﴿وَجۡهَ ٱلنَّهَارِ﴾</span>: أوَّلَه.</p><p><span class="qpc-hafs">﴿لَعَلَّهُمۡ يَرۡجِعُونَ﴾</span>: لعلَّهم يَتَشَكَّكُون في دينِهم، ويَرْجِعُون عنه.</p></div>"
  3,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُؤۡمِنُوٓاْ﴾</span>: ولاتُصَدِّقوا.</p><p><span class="qpc-hafs">﴿أَن يُؤۡتَىٰٓ أَحَدࣱ مِّثۡلَ مَآ أُوتِيتُمۡ﴾</span>: لا تُصَدِّقُوهم لئلا يَعْلَمُوا مثلَ ما عَلِمْتُم.</p><p><span class="qpc-hafs">﴿يُحَآجُّوكُمۡ﴾</span>: يَتَّخِذُوه حُجَّةً.</p></div>"
  3,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُو ٱلۡفَضۡلِ﴾</span>: ذو العَطاءِ</p></div>"
  3,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِقِنطَارࣲ﴾</span>: على كثيرٍ من المالِ.</p><p><span class="qpc-hafs">﴿قَآئِمࣰا﴾</span>: أي: بالمطالبةِ.</p><p><span class="qpc-hafs">﴿ٱلۡأُمِّيِّـۧنَ﴾</span>: العربِ.</p><p><span class="qpc-hafs">﴿سَبِيلࣱ﴾</span>: حَرَجٌ في أموالهِم؛ لأنّ اللهَ أحَلَّها لنا.</p></div>"
  3,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنۡ أَوۡفَىٰ بِعَهۡدِهِۦ﴾</span>: مَن أدّى أمانتَه.</p></div>"
  3,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَشۡتَرُونَ بِعَهۡدِ ٱللَّهِ﴾</span>: يَسْتبدلون بوصيةِ اللهِ باتِّباعِ محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿وَأَيۡمَـٰنِهِمۡ﴾</span>: الكاذبةِ.</p><p><span class="qpc-hafs">﴿لَا خَلَـٰقَ﴾</span>: لا نصِيبَ.</p><p><span class="qpc-hafs">﴿وَلَا يُزَكِّيهِمۡ﴾</span>: ولا يُطَهِّرُهم مِن دَنَسِ ذُنوبِهم.</p></div>"
  3,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلۡوُۥنَ أَلۡسِنَتَهُم بِٱلۡكِتَـٰبِ﴾</span>: يُحَرِّفُون الكلامَ، ويُبَدِّلون آياتِ اللهِ.</p></div>"
  3,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَبَّـٰنِيِّـۧنَ﴾</span>: جَمْعُ رَبّانِيّ، وهو الذي يُصْلِحُ أمورَ الناسِ، ويقومُ بها.</p></div>"
  3,80,""
  3,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَ ٱلنَّبِيِّـۧنَ﴾</span>: العهدَ المؤكَّدَ على الأنبياءِ في تصديقِ بعضِهم بعضًا.</p><p><span class="qpc-hafs">﴿لَمَآ﴾</span>: لَئِنْ.</p><p><span class="qpc-hafs">﴿إِصۡرِي﴾</span>: عَهْدِي الُموَثَّقَ.</p></div>"
  3,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span>: أعْرَضَ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارجون عن طاعةِ اللهِ.</p></div>"
  3,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡغُونَ﴾</span>: يريدون.</p><p><span class="qpc-hafs">﴿أَسۡلَمَ﴾</span>: استسلمَ، وخَضَعَ.</p><p><span class="qpc-hafs">﴿طَوۡعࣰا﴾</span>: طَواعيةً، كالملائكةِ والأنبياءِ.</p><p><span class="qpc-hafs">﴿وَكَرۡهࣰا﴾</span>: رَغْمًا عنه، كمَن أسلمَ مخافةَ القتلِ.</p></div>"
  3,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَسۡبَاطِ﴾</span>: الأنبياءِ الذين كانُوا في قبائلِ بني إسرائيل مِن ولَدِ يعقوبَ.</p><p><span class="qpc-hafs">﴿مُسۡلِمُونَ﴾</span>: مُنقادُون بالطاعةِ.</p></div>"
  3,85,""
  3,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِي﴾</span>: يُوَفِّقُ للإيمانِ، ويُرْشِدُ للصَّوابِ.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتُ﴾</span>: الدَّلائلُ الواضحاتُ.</p></div>"
  3,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعۡنَةَ ٱللَّهِ﴾</span>: الطَّرْدَ من رحمةِ اللهِ.</p></div>"
  3,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا هُمۡ يُنظَرُونَ﴾</span>: ولا يُؤَخَّرُ عنهم لمعذِرَةٍ يَعْتَذِرُون بها.</p></div>"
  3,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡلَحُواْ﴾</span>: ما أفسَدُوه.</p></div>"
  3,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّن تُقۡبَلَ تَوۡبَتُهُمۡ﴾</span>: عند حُضورِ الموتِ.</p></div>"
  3,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوِ ٱفۡتَدَىٰ بِهِۦٓ﴾</span>: ولو دَفَعَ هذا المالَ ليَفْتَدِيَ نفسَه من العذابِ.</p></div>"
  3,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبِرَّ﴾</span>: الجنةَ.</p></div>"
  3,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا مَا حَرَّمَ﴾</span>: هو يعقوبُ، إذ حَرَّمَ على نفسِه -دونَ أتباعِه- لمرضٍ ألَمَّ به، ولمّا نَزَلَتِ التوراةُ حَرَّمَ اللهُ على بني إسرائيلَ بعضَ الأطعمةِ لظُلْمِهم.</p><p><span class="qpc-hafs">﴿إِن كُنتُمۡ صَـٰدِقِينَ﴾</span>: في دَعْواكم أنّ اللهَ أنزلَ في التوراةِ تحريمَ ماحَرَّمه يعقوبُ على نفسِه.</p></div>"
  3,94,""
  3,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَدَقَ ٱللَّهُ﴾</span>: فيما أخبرَ به.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مستقيمًا لا عِوَجَ فيه.</p></div>"
  3,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِبَكَّةَ﴾</span>: بمكةَ.</p><p><span class="qpc-hafs">﴿مُبَارَكࣰا﴾</span>: تُضاعَفُ فيه الحَسَناتُ.</p></div>"
  3,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتُۢ﴾</span>: علاماتٌ.</p><p><span class="qpc-hafs">﴿مَّقَامُ إِبۡرَ ٰ⁠هِيمَ﴾</span>: وهو الحَجَرُ الذي كان يَقِفُ عليه حين كان يرفعُ القَواعدَ من البيت.</p><p><span class="qpc-hafs">﴿سَبِيلࣰا﴾</span>: سَعَةً.</p><p><span class="qpc-hafs">﴿وَمَن كَفَرَ﴾</span>: ومَن جَحَدَ وُجوبَه.</p></div>"
  3,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَ تَكۡفُرُونَ بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: لِمَ تُنْكِرُون ما في كتبِكم من دلائلَ على أن الدينَ هو الإسلامُ؟</p></div>"
  3,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَصُدُّونَ﴾</span>: تمنعون.</p><p><span class="qpc-hafs">﴿عِوَجࣰا﴾</span>: مَيْلًا عن القصدِ، والاستقامةِ.</p><p><span class="qpc-hafs">﴿شُهَدَآءُ﴾</span>: عالِمُون أنّ ما جِئْتُ به هو الحقُّ.</p></div>"
  3,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرُدُّوكُم بَعۡدَ إِيمَـٰنِكُمۡ كَـٰفِرِينَ﴾</span>: يُلْقُوا إليكم الشُّبَهَ، فتَرْجِعُوا جاحِدِين للحقِّ.</p></div>"
  3,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتُ ٱللَّهِ﴾</span>: القرآنُ الكريمُ.</p><p><span class="qpc-hafs">﴿وَفِيكُمۡ رَسُولُهُۥ﴾</span>: يُبَلِّغُها لكم، وهو حُجَّةٌ أخرى للهِ عليكم.</p><p><span class="qpc-hafs">﴿يَعۡتَصِم بِٱللَّهِ﴾</span>: يتمسَّكْ بدِينِه، وطاعتِه.</p><p><span class="qpc-hafs">﴿هُدِيَ﴾</span>: وُفِّقَ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ﴾</span>: طريقٍ.</p></div>"
  3,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّسۡلِمُونَ﴾</span>: مُذْعِنُون له بالطاعةِ.</p></div>"
  3,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱعۡتَصِمُواْ بِحَبۡلِ ٱللَّهِ﴾</span>: وتمسَّكُوا بدينِ اللهِ.</p><p><span class="qpc-hafs">﴿فَأَلَّفَ﴾</span>: فجَمَعَ.</p><p><span class="qpc-hafs">﴿إِخۡوَ ٰ⁠نࣰا﴾</span>: مُتَحابِّين.</p><p><span class="qpc-hafs">﴿شَفَا﴾</span>: حافَةٍ وطَرفٍ.</p></div>"
  3,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣱ﴾</span>: جماعةٌ.</p></div>"
  3,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلَّذِينَ تَفَرَّقُواْ﴾</span>: من أهلِ الكتابِ.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتُ﴾</span>: الحُجَجُ الواضحاتُ.</p></div>"
  3,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبۡيَضُّ وُجُوهࣱ﴾</span>: هم أهلُ السَّعادَةِ.</p><p><span class="qpc-hafs">﴿وَتَسۡوَدُّ وُجُوهࣱ﴾</span>: هم أهلُ الشَّقاءِ.</p><p><span class="qpc-hafs">﴿أَكَفَرۡتُم﴾</span>: فُيقال لهم توبيخًا</p></div>"
  3,107,""
  3,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالصِّدْقِ واليقينِ.</p></div>"
  3,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُرۡجَعُ ٱلۡأُمُورُ﴾</span>: مَصِيرُ أمْرِ جميعِ الخَلْقِ، فيُجازي كُلًّا بما يستحِقُّ.</p></div>"
  3,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُنتُمۡ﴾</span>: أنتم يا أمةَ محمدٍ ﷺ، على الشَّرْطِ المذكورِ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارِجُون عن دينِ اللهِ.</p></div>"
  3,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّآ أَذࣰى﴾</span>: إلا ما يُؤْذِي أسماعَكم من الكَذِبِ على اللهِ والتحريفِ.</p><p><span class="qpc-hafs">﴿يُوَلُّوكُمُ ٱلۡأَدۡبَارَ﴾</span>: يُهْزَموا.</p></div>"
  3,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلذِّلَّةُ﴾</span>: الهَوانُ والصَّغارُ.</p><p><span class="qpc-hafs">﴿ثُقِفُوٓاْ﴾</span>: وُجِدُوا.</p><p><span class="qpc-hafs">﴿إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ﴾</span>: إلا بعَهْدٍ من الله يأمَنُون به على أنفسِهم.</p><p><span class="qpc-hafs">﴿وَحَبۡلࣲ مِّنَ ٱلنَّاسِ﴾</span>: بذِمَّةٍ من الناسِ.</p><p><span class="qpc-hafs">﴿وَبَآءُو﴾</span>: واستحَقُّوا غَضَبَ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَسۡكَنَةُ﴾</span>: ذُلُّ الفاقةِ والفقرِ.</p></div>"
  3,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣱ قَآئِمَةࣱ﴾</span>: جماعةٌ ثابتةٌ على الحقِّ.</p><p><span class="qpc-hafs">﴿ءَانَآءَ ٱلَّيۡلِ﴾</span>: جَمْعُ إنى، وهي ساعاتُه.</p></div>"
  3,114,""
  3,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَن يُكۡفَرُوهُ﴾</span>: فلن يُعْدَمُوا ثوابَه.</p></div>"
  3,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن تُغۡنِيَ﴾</span>: لن تَدْفَعَ عنهم.</p><p><span class="qpc-hafs">﴿مِّنَ ٱللَّهِ﴾</span>: من عذابِ اللهِ.</p></div>"
  3,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يُنفِقُونَ﴾</span>: في وجوهِ الخيرِ.</p><p><span class="qpc-hafs">﴿صِرٌّ﴾</span>: بَرْدٌ شديدٌ.</p><p><span class="qpc-hafs">﴿أَصَابَتۡ حَرۡثَ قَوۡمࣲ﴾</span>: هَبَّتْ علىَ زَرْعِ قومٍ كانوا يَرْجُون خيرَه. وكذلك إنفاقُ الكافرِ لا ينفَعُه.</p></div>"
  3,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِطَانَةࣰ مِّن دُونِكُمۡ﴾</span>: أصفياءَ مِن دونِ المؤمنين، تُطْلِعُونَهم على أسرارِكم.</p><p><span class="qpc-hafs">﴿لَا يَأۡلُونَكُمۡ خَبَالࣰا﴾</span>: لا يُقَصِّرُون في إفسادِ حالِكم.</p><p><span class="qpc-hafs">﴿مَا عَنِتُّمۡ﴾</span>: مَشَقَّتَكم.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>:: الحُجَجَ.</p></div>"
  3,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتُؤۡمِنُونَ بِٱلۡكِتَـٰبِ كُلِّهِۦ﴾</span>: وتؤمنون بالكُتُبِ المنَّزلَةِ كلها، وهم لا يُؤمنون بكتابِكم.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡغَيۡظِ﴾</span>: من شِدَّةِ الغَضَبِ.</p></div>"
  3,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدُهُمۡ﴾</span>: أذى مَكْرِهم.</p></div>"
  3,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَدَوۡتَ مِنۡ أَهۡلِكَ﴾</span>: خَرَجْتَ من بيتِك يومَ أُحُدٍ.</p><p><span class="qpc-hafs">﴿تُبَوِّئُ ٱلۡمُؤۡمِنِينَ﴾</span>: تَتَّخِذُ لهم.</p></div>"
  3,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَّآئِفَتَانِ﴾</span>: هما بنو سَلِمَةَ وبنو حارثةَ، حَدَّثَتْهم أنفسُهم يومَ أُحُدٍ بالرُّجوعِ عن لقاءِ العدوِّ، ولكنَّ اللهَ عَصَمَهم.</p><p><span class="qpc-hafs">﴿تَفۡشَلَا﴾</span>: تَجْبُنا.</p><p><span class="qpc-hafs">﴿وَلِيُّهُمَا﴾</span>: الدافعُ عنهما الضَّعْفَ.</p></div>"
  3,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَذِلَّةࣱ﴾</span>: قليلو العَدَدِ والعُدَّةِ.</p></div>"
  3,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنزَلِينَ﴾</span>: من السماءِ يُقاتِلون معكم.</p></div>"
  3,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَأۡتُوكُم﴾</span>: ويأتي كفارُ مكةَ لقتالِكم.</p><p><span class="qpc-hafs">﴿مِّن فَوۡرِهِمۡ هَـٰذَا﴾</span>: مِن ساعَتِهم هذه.</p><p><span class="qpc-hafs">﴿مُسَوِّمِينَ﴾</span>: مُعْلِمِين أنفسَهم بعلاماتٍ واضِحاتٍ.</p></div>"
  3,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا جَعَلَهُ﴾</span>: وما جَعَلَ هذا الإمدادَ بالملائكةِ.</p></div>"
  3,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَقۡطَعَ طَرَفࣰا﴾</span>: ليُهلِكَ فريقًامن الكفّارِ بالقَتْلِ.</p><p><span class="qpc-hafs">﴿أَوۡ يَكۡبِتَهُمۡ﴾</span>: أو يُغِيظَهم، ويُحْزِنَهم.</p><p><span class="qpc-hafs">﴿فَيَنقَلِبُواْ خَآئِبِينَ﴾</span>: فيعودُوا غيرَ ظافِرين بمَطْلَبِهم.</p></div>"
  3,128,""
  3,129,""
  3,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَضۡعَـٰفࣰا مُّضَـٰعَفَةࣰ﴾</span>: كانوا في الجاهليةِ إذا حانَ موعِدُ السَّدادِ يقولُ المقترضُ: أخِّرْ عني، وأَزِيدُك.</p></div>"
  3,131,""
  3,132,""
  3,133,""
  3,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّرَّآءِ﴾</span>: في اليُسْرِ وسَعَةِ العيشِ.</p><p><span class="qpc-hafs">﴿وَٱلضَّرَّآءِ﴾</span>: الضِّيقِ والشدةِ.</p><p><span class="qpc-hafs">﴿وَٱلۡكَـٰظِمِينَ﴾</span>: الذين يُمْسِكون مافي أنفسِهم من الغيظِ بالصبر.</p><p><span class="qpc-hafs">﴿وَٱلۡعَافِينَ﴾</span>: والذين يَصْفَحُون عمَّن ظَلَمَهم.</p></div>"
  3,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰحِشَةً﴾</span>: هي الفعْلَةُ القبيحةُ الخارجةُ عَمّا أذِنَ اللهُ.</p><p><span class="qpc-hafs">﴿ظَلَمُوٓاْ أَنفُسَهُمۡ﴾</span>: بارتكابِ مادونَ الفاحشةِ.</p><p><span class="qpc-hafs">﴿ذَكَرُواْ ٱللَّهَ﴾</span>: ذكَروا وعيدَه على المعصية.</p><p><span class="qpc-hafs">﴿وَلَمۡ يُصِرُّواْ﴾</span>: ولم يَثْبُتوا على ما أتَوا من الذُّنوبِ.</p><p><span class="qpc-hafs">﴿وَهُمۡ يَعۡلَمُونَ﴾</span>: قُبْحَه.</p></div>"
  3,136,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجۡرُ ٱلۡعَـٰمِلِينَ﴾</span>: ثوابُ المطيعين.</p></div>"
  3,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مضَتْ.</p><p><span class="qpc-hafs">﴿سُنَنࣱ﴾</span>: ماسَنَّه اللهُ في الأممِ المكذِّبة والسُّنَّةُ: المثالُ المُتَّبَعُ.</p><p><span class="qpc-hafs">﴿عَـٰقِبَةُ ٱلۡمُكَذِّبِينَ﴾</span>: قد أُمْهِلُ المكذِّبين وأسْتَدْرِجُهم إلى أجَلٍ، ثم أُحِلُّ بهم عُقوبتي، وهذا ماحدَث مع المشركين يومَ أُحُدٍ.</p></div>"
  3,138,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: الذي أوضَحْتُه لكم بما تَقَدَّم أو القرآنُ.</p></div>"
  3,139,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَهِنُواْ﴾</span>: ولا تضْعُفُوا بالذي نالَكم يومَ أُحُدٍ.</p><p><span class="qpc-hafs">﴿ٱلۡأَعۡلَوۡنَ﴾</span>: الغالِبُون على عَدُوِّكم بالنصرِ.</p></div>"
  3,140,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرۡحࣱ﴾</span>: جِراْحٌ وقَتْلٌ يومَ أُحُد.</p><p><span class="qpc-hafs">﴿مِّثۡلُهُۥ﴾</span>: يومَ بدرٍ.</p><p><span class="qpc-hafs">﴿نُدَاوِلُهَا﴾</span>: يُصَرِّفُها اللهُ، فيظفَرُ المؤمنُ بالكافر، والكافرُ بالمؤمن.</p><p><span class="qpc-hafs">﴿وَيَتَّخِذَ مِنكُمۡ شُهَدَآءَ﴾</span>: ويُكَرِّمَ أقوامًا بالشهادةِ.</p></div>"
  3,141,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيُمَحِّصَ﴾</span>: ولِيَخْتبرَ.</p><p><span class="qpc-hafs">﴿وَيَمۡحَقَ﴾</span>: ويُهْلِكَهم.</p></div>"
  3,142,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمَّا يَعۡلَمِ﴾</span>: أي: عِلْمًا ظاهرًا للخَلْقِ.</p></div>"
  3,143,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَوۡتَ﴾</span>: أسبابَه. وكان قومٌ من الصَّحابة مِمَّنْ لم يَشْهدوا بدرًا تمنَّوا أن يجاهِدُوا.</p><p><span class="qpc-hafs">﴿فَقَدۡ رَأَيۡتُمُوهُ﴾</span>: حَصَلَ ذلك يومَ أُحُدٍ، ولكن فَرَّ بعضُهم، وصَبَر بعضُهم.</p></div>"
  3,144,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ، فسوف يَقْبِضُه اللهُ إليه عند انقضاءِ أجَلِه.</p><p><span class="qpc-hafs">﴿ٱنقَلَبۡتُمۡ عَلَىٰٓ أَعۡقَـٰبِكُمۡ﴾</span>: ارتَددْتُم عن دينِكم.</p><p><span class="qpc-hafs">﴿فَلَن يَضُرَّ ٱللَّهَ﴾</span>: فلن يُوهِنَ ذلك عزةَ اللهِ ولا سُلطانَه، وإنما يَضُرُّ نفسَه.</p><p><span class="qpc-hafs">﴿ٱلشَّـٰكِرِينَ﴾</span>: على نِعْمَةِ الإسلامِ، الثابتين على دينِهم.</p></div>"
  3,145,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِإِذۡنِ ٱللَّهِ﴾</span>: بقَدَرِه حتى يَسْتوفيَ مُدَّتَه.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣰا﴾</span>: كَتَبَ اللهُ ذلك كتابًا.</p><p><span class="qpc-hafs">﴿مُّؤَجَّلࣰا﴾</span>: مؤقتًا لا يتقدَّمُ على أجَلهِ ولا يتأخَّرُ.</p><p><span class="qpc-hafs">﴿نُؤۡتِهِۦ مِنۡهَا﴾</span>: أي: ما قُسِم له فيها من رزقٍ.</p></div>"
  3,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَأَيِّن﴾</span>: كثيرٌ.</p><p><span class="qpc-hafs">﴿رِبِّيُّونَ كَثِيرࣱ﴾</span>: جموعٌ كثيرةٌ من أصحابِهم، أو علماءُ.</p><p><span class="qpc-hafs">﴿وَهَنُواْ﴾</span>: ضَعُفُوا.</p><p><span class="qpc-hafs">﴿وَمَا ٱسۡتَكَانُواْ﴾</span>: ما ذَلُّوا لعَدُوِّهم.</p></div>"
  3,147,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِسۡرَافَنَا﴾</span>: من الذُّنوبِ الكَبائرِ.</p></div>"
  3,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَوَابَ ٱلدُّنۡيَا﴾</span>: بالنصر، والتمكينِ في الأرض.</p><p><span class="qpc-hafs">﴿وَحُسۡنَ ثَوَابِ ٱلۡـَٔاخِرَةِ﴾</span>: وخيرَ جزاءِ الآخرةِ.</p><p><span class="qpc-hafs">﴿وَٱللَّهُ يُحِبُّ ٱلۡمُحۡسِنِينَ﴾</span>: مَن أحسنَ عبادتَه لربِّه.</p></div>"
  3,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرُدُّوكُمۡ عَلَىٰٓ أَعۡقَـٰبِكُمۡ﴾</span>: يُضِلُّوكم عن طريقِ الحقِّ.</p></div>"
  3,150,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَوۡلَىٰكُمۡ﴾</span>: ناصِرُكم.</p></div>"
  3,151,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنُلۡقِي فِي قُلُوبِ ٱلَّذِينَ كَفَرُواْ ٱلرُّعۡبَ﴾</span>: لأنّ المشركين عَزَمُوا على استئصالِ المسلمين بعد أُحُدٍ، ولكنَّ اللهَ قَذَفَ فيهم الرُّعْبَ، فرجَعوا عَمّا هَمُّوا به.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: دليلًا على استحقاقِها العبادةَ.</p><p><span class="qpc-hafs">﴿مَثۡوَى﴾</span>: مكانُ الإقامةِ.</p></div>"
  3,152,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَدَقَكُمُ ٱللَّهُ وَعۡدَهُۥٓ﴾</span>: حَقَّقَ ما وعَدَكم مِن نَصْرٍ في أُحُدٍ قبلَ تَرْكِ الرُّماةِ مقاعِدَهم.</p><p><span class="qpc-hafs">﴿تَحُسُّونَهُم﴾</span>: تستأصِلُونهم بالقَتْلِ.</p><p><span class="qpc-hafs">﴿فَشِلۡتُمۡ﴾</span>: جَبُنتم. وجواب «إذا» مقدرٌ: امتُحِنْتُم.</p><p><span class="qpc-hafs">﴿وَتَنَـٰزَعۡتُمۡ﴾</span>: اختلَفْتم: هل تَبْقَون في مَواقِعِكم، أو تتركونها للغَنائم؟</p><p><span class="qpc-hafs">﴿صَرَفَكُمۡ﴾</span>: رَدَّكم عنهم بالهزيمةِ.</p><p><span class="qpc-hafs">﴿لِيَبۡتَلِيَكُمۡ﴾</span>: ليَخْتَبِرَكم.</p></div>"
  3,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُصۡعِدُونَ﴾</span>: تَسِيرون في مستوى الأرضِ وبُطونِ الأوديةِ هاربين.</p><p><span class="qpc-hafs">﴿وَلَا تَلۡوُۥنَ﴾</span>: لاتَلْتَفِتُون إلى أحَدٍ.</p><p><span class="qpc-hafs">﴿فِيٓ أُخۡرَىٰكُمۡ﴾</span>: في الطائفةِ المتأخرةِ.</p><p><span class="qpc-hafs">﴿فَأَثَـٰبَكُمۡ﴾</span>: فجازاكم.</p><p><span class="qpc-hafs">﴿غَمَّۢا بِغَمࣲّ﴾</span>: الغَمُّ الأولُ ما أُشيعَ من قَتْل الرسولِ ﷺ، والثاني: ما نالهم من القَتْلِ والجِراحِ.</p><p><span class="qpc-hafs">﴿عَلَىٰ مَا فَاتَكُمۡ﴾</span>: من نَصْرٍ وغنيمةٍ. وفَعَلَ بكم ذلك تدريبًا لاحتمالِ الشدائدِ.</p></div>"
  3,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَنَةࣰ﴾</span>: أمانًا.</p><p><span class="qpc-hafs">﴿طَآئِفَةࣰ مِّنكُمۡ﴾</span>: هم أهلُ الإخلاصِ.</p><p><span class="qpc-hafs">﴿أَهَمَّتۡهُمۡ أَنفُسُهُمۡ﴾</span>: خَلاصُ أنفسِهم من القَتْلِ، وهم المنافقون.</p><p><span class="qpc-hafs">﴿ظَنَّ ٱلۡجَـٰهِلِيَّةِ﴾</span>: بأنّ الإسلامَ لن تقومَ له قائمةٌ.</p><p><span class="qpc-hafs">﴿هَل لَّنَا مِنَ ٱلۡأَمۡرِ مِن شَيۡءࣲ﴾</span>: هل كان لنا من اختيارٍ في الخروجِ للقتالِ؟</p><p><span class="qpc-hafs">﴿يُخۡفُونَ﴾</span>: من الحَسْرةِ على خروجِهم للقتالِ.</p><p><span class="qpc-hafs">﴿إِلَىٰ مَضَاجِعِهِمۡ﴾</span>: إلى المواضع التي كُتِبَ عليهم أنْ يُقْتَلَوا فيها.</p><p><span class="qpc-hafs">﴿مَا فِي صُدُورِكُمۡ﴾</span>: من الشَّكِّ، والنفاق.</p><p><span class="qpc-hafs">﴿وَلِيُمَحِّصَ﴾</span>: ليمِيزَ الخبيثَ من الطَّيِّبِ.</p></div>"
  3,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: فَرُّوا.</p><p><span class="qpc-hafs">﴿ٱلۡتَقَى ٱلۡجَمۡعَانِ﴾</span>: أي: يومَ أُحُدٍ، والجَمْعان: المؤمنون، والمشركون.</p><p><span class="qpc-hafs">﴿ٱسۡتَزَلَّهُمُ﴾</span>: أوْقَعَهم.</p><p><span class="qpc-hafs">﴿مَا كَسَبُواْ﴾</span>: من الذُّنوبِ.</p></div>"
  3,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلَّذِينَ كَفَرُواْ﴾</span>: من المنافقين.</p><p><span class="qpc-hafs">﴿ضَرَبُواْ فِي ٱلۡأَرۡضِ﴾</span>: سَفَرًا للبحث عن معاشِهم فماتوا.</p><p><span class="qpc-hafs">﴿غُزࣰّى﴾</span>: غازين.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: هذا القولُ.</p></div>"
  3,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّمَّا يَجۡمَعُونَ﴾</span>: ممّا يجْمَعُه أهلُ الدنيا.</p></div>"
  3,158,""
  3,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِمَا رَحۡمَةࣲ﴾</span>: فبرحمةٍ.</p><p><span class="qpc-hafs">﴿فَظًّا﴾</span>: سَيِّئَ الخُلُقِ جافيًا.</p><p><span class="qpc-hafs">﴿لَٱنفَضُّواْ﴾</span>: لَتَفرَّقُوا عنك.</p><p><span class="qpc-hafs">﴿وَشَاوِرۡهُمۡ﴾</span>: لتقتديَ بك الأمةُ، وذلك في غير ما ورَدَ به الشَّرعُ.</p><p><span class="qpc-hafs">﴿فَإِذَا عَزَمۡتَ﴾</span>: عَقِبَ المُشاورةِ، وقَصَدْتَ إمضاءَ الأمرِ.</p></div>"
  3,160,""
  3,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَغُلَّ﴾</span>: أن يَخُونَ أصحابَه بأن يأخذَ من الغنيمةِ غيرَ ما اخْتَصَّه اللهُ.</p><p><span class="qpc-hafs">﴿بِمَا غَلَّ﴾</span>: بما أخَذَه حاملًا له ليُفضحَ به.</p></div>"
  3,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَنۢ بَآءَ بِسَخَطࣲ﴾</span>: كمَن رَجَعَ بغضبٍ شديدٍ.</p></div>"
  3,163,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُمۡ دَرَجَـٰتٌ﴾</span>: ذوو دَرَجاتٍ، فدَرجاتُ مَنِ اتَّبعَ رضوانَه ليسَتْ كدرجاتِ الآخَرين.</p></div>"
  3,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنَّ﴾</span>: أنعمَ.</p><p><span class="qpc-hafs">﴿مِّنۡ أَنفُسِهِمۡ﴾</span>: من أهلِ لسانِهم.</p><p><span class="qpc-hafs">﴿وَيُزَكِّيهِمۡ﴾</span>: ويُطَهِّرُهم.</p><p><span class="qpc-hafs">﴿وَٱلۡحِكۡمَةَ﴾</span>: والسُّنَّةَ.</p><p><span class="qpc-hafs">﴿وَإِن كَانُواْ﴾</span>: وإنّهم كانوا.</p></div>"
  3,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّصِيبَةࣱ﴾</span>: يومَ أُحدٍ.</p><p><span class="qpc-hafs">﴿أَصَبۡتُم مِّثۡلَيۡهَا﴾</span>: يومَ بدرٍ من المشركين.</p><p><span class="qpc-hafs">﴿أَنَّىٰ هَـٰذَا﴾</span>: كيف يكونُ هذا، ونحن مسلمون فينا نبيُّ اللهِ؟</p><p><span class="qpc-hafs">﴿مِنۡ عِندِ أَنفُسِكُمۡ﴾</span>: عقوبةٌ لكم بسببِ مخالفتِكم أمْرَ رسولِكم.</p></div>"
  3,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡتَقَى ٱلۡجَمۡعَانِ﴾</span>: يومَ أُحُدٍ.</p><p><span class="qpc-hafs">﴿فَبِإِذۡنِ ٱللَّهِ﴾</span>: بعِلْمِه.</p></div>"
  3,167,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱدۡفَعُواْ﴾</span>: كونوا عَوْنًا لنا بتكثيرِكم سَوادَنا.</p></div>"
  3,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡ أَطَاعُونَا﴾</span>: بتَرْكِ الخروجِ من المدينةِ.</p><p><span class="qpc-hafs">﴿فَٱدۡرَءُواْ﴾</span>: فادفَعُوا.</p></div>"
  3,169,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡيَآءٌ﴾</span>: حياةً بَرْزَخيةً.</p><p><span class="qpc-hafs">﴿عِندَ رَبِّهِمۡ﴾</span>: في الجنةِ.</p></div>"
  3,170,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسۡتَبۡشِرُونَ﴾</span>: ويَفْرحون.</p><p><span class="qpc-hafs">﴿أَلَّا خَوۡفٌ عَلَيۡهِمۡ﴾</span>: فيما يَسْتقبلون من أمورِ الآخرةِ.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على مافاتَهم في الدنيا.</p></div>"
  3,171,""
  3,172,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱسۡتَجَابُواْ﴾</span>: هم الذين خرجُوا يَتَعَقَّبون المشركين في «حمراءِ الأسَدِ»، بعد هزيمتِهم في أُحُدٍ.</p><p><span class="qpc-hafs">﴿ٱلۡقَرۡحُ﴾</span>: الجراحُ من معركةِ أُحُدٍ.</p></div>"
  3,173,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ لَهُمُ ٱلنَّاسُ﴾</span>: هم بعضُ المشركين، قالوا: إن أبا سفيان ومَن معه سيعودون إليكم.</p><p><span class="qpc-hafs">﴿حَسۡبُنَا ٱللَّهُ﴾</span>: اللهُ كافِينا.</p></div>"
  3,174,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱنقَلَبُواْ﴾</span>: فرَجَعُوا من حمراءِ الأسَدِ.</p></div>"
  3,175,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخَوِّفُ أَوۡلِيَآءَهُۥ﴾</span>: يُخَوِّفُكم بأوليائِه.</p></div>"
  3,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَظࣰّا﴾</span>: نصيبًا.</p></div>"
  3,177,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡتَرَوُاْ﴾</span>: استبدلُوا.</p></div>"
  3,178,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَحۡسَبَنَّ ٱلَّذِينَ كَفَرُوٓاْ﴾</span>: إذا أطَلْنا أعمارَهم، ومَتَّعْناهم.</p><p><span class="qpc-hafs">﴿إِنَّمَا نُمۡلِي لَهُمۡ﴾</span>: نُؤَخِّرُ أجَلَهم، وعذابَهم.</p><p><span class="qpc-hafs">﴿إِثۡمࣰا﴾</span>: ظلمًا وطُغيانًا.</p></div>"
  3,179,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَذَرَ﴾</span>: لِيَدَعَ.</p><p><span class="qpc-hafs">﴿عَلَىٰ مَآ أَنتُمۡ عَلَيۡهِ﴾</span>: من التباسِ المؤمن مِنكم بالمنافقِ.</p><p><span class="qpc-hafs">﴿عَلَى ٱلۡغَيۡبِ﴾</span>: الذي يَعْلَمُه من عبادِه، فتَعْرِفُوا المؤمنَ منهم من المنافقِ، ولكنه يَمِيزُهم بالمِحَنِ.</p><p><span class="qpc-hafs">﴿يَجۡتَبِي﴾</span>: يَصْطَفي مِن رُسُله ليُطْلِعَه على شيءٍ من غيبهِ.</p></div>"
  3,180,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيُطَوَّقُونَ﴾</span>: سيكونُ طَوْقًا من نارٍ يُوضَعُ في أعناقِهم.</p></div>"
  3,181,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ قَالُوٓاْ﴾</span>: هم اليهودُ.</p><p><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ فَقِيرࣱ﴾</span>: يَطْلبُ منا أن نُقْرِضَه مالًا، وهذا للتشكيكِ على المسلمين.</p></div>"
  3,182,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا قَدَّمَتۡ أَيۡدِيكُمۡ﴾</span>: من المعاصي.</p></div>"
  3,183,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَهِدَ إِلَيۡنَآ﴾</span>: في التوراةِ.</p><p><span class="qpc-hafs">﴿بِقُرۡبَانࣲ﴾</span>: بصَدَقَةٍ يُتَقَرَّبُ بها إلى الله، فتنزلُ نارٌ من السماءِ فتحرقُها.</p></div>"
  3,184,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالمعجزاتِ الواضحاتِ.</p><p><span class="qpc-hafs">﴿وَٱلزُّبُرِ﴾</span>: الكتبِ التي أنزلها اللهُ.</p></div>"
  3,185,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعُ ٱلۡغُرُورِ﴾</span>: مُتْعَةٌ زائلةٌ، فلا تَغْترُّوا بها.</p></div>"
  3,186,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَتُبۡلَوُنَّ﴾</span>: لَتُخْتَبَرُنَّ.</p><p><span class="qpc-hafs">﴿فِيٓ أَمۡوَ ٰ⁠لِكُمۡ﴾</span>: بإخراجِ النفقاتِ الواجبةِ والمُسْتَحَبَّةِ، وبالجوائح التي تُصيبها.</p><p><span class="qpc-hafs">﴿وَأَنفُسِكُمۡ﴾</span>: بما يجبُ عليكم من الطاعاتِ، وما يَحُلُّ بكم من الجِراح، وفَقْدِ الأحبابِ.</p><p><span class="qpc-hafs">﴿مِنۡ عَزۡمِ ٱلۡأُمُورِ﴾</span>: من الأمورِ التي يُتنافَسُ فيها.</p></div>"
  3,187,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَ﴾</span>: العهدَ المُوَثَّقَ.</p><p><span class="qpc-hafs">﴿فَنَبَذُوهُ﴾</span>: تركُوا العملَ به</p><p><span class="qpc-hafs">﴿وَٱشۡتَرَوۡاْ بِهِۦ ثَمَنࣰا قَلِيلࣰا﴾</span>: أخذُوا ثمنًا بَخْسًا مقابلَ كِتْمانِهم الحقَّ، وتحريفِهم كتبَهم.</p></div>"
  3,188,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يَفۡرَحُونَ﴾</span>: أهلَ الكتابِ ومَن كان مثلَهم من الذين أخَذَ ميثاقَهم.</p><p><span class="qpc-hafs">﴿بِمَآ أَتَواْ﴾</span>: بكِتْمانهم أنّ النبيَّ ﷺ مُرْسَلٌ بالحقِّ.</p><p><span class="qpc-hafs">﴿بِمَفَازَةࣲ﴾</span>: بمَنجاةٍ.</p></div>"
  3,189,""
  3,190,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: في تَعاقُبِهِما واختلافِهما طُولًا وقِصَرًا.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَدلائلَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَلۡبَـٰبِ﴾</span>: العقولِ السليمةِ.</p></div>"
  3,191,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَتَفَكَّرُونَ﴾</span>: ويتدبَّرون.</p><p><span class="qpc-hafs">﴿بَـٰطِلࣰا﴾</span>: عَبَثًا.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَكَ﴾</span>: نُنَزِّهُك.</p></div>"
  3,192,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخۡزَيۡتَهُۥ﴾</span>: أهَنْتَه، وهو الخالدُ فيها.</p></div>"
  3,193,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنَادِيࣰا﴾</span>: هو محمدٌ ﷺ.</p><p><span class="qpc-hafs">﴿ٱلۡأَبۡرَارِ﴾</span>: الصالحين.</p></div>"
  3,194,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُخۡزِنَا﴾</span>: ولاتَفْضَحْنا بذنوبِنا.</p></div>"
  3,195,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡضُكُم مِّنۢ بَعۡضࣲ﴾</span>: هم سَواءُ في الجزاءِ على العملِ.</p></div>"
  3,196,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَغُرَّنَّكَ تَقَلُّبُ ٱلَّذِينَ كَفَرُواْ﴾</span>: لا تَغْتَرَّ بما عليه أهلُ الكفرِ من تَصَرُّفِهم في الأرضِ وضَرْبِهم فيها.</p></div>"
  3,197,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَأۡوَىٰهُمۡ﴾</span>: مصيرُهم.</p><p><span class="qpc-hafs">﴿ٱلۡمِهَادُ﴾</span>: الفِراشُ والمَضْجَعُ.</p></div>"
  3,198,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُزُلࣰا﴾</span>: هوما يُهَيَّأ للنَّزيلِ ضِيافةً.</p></div>"
  3,199,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَمَنࣰا قَلِيلًا﴾</span>: من حُطامِ الدُّنيا، فلايكتُمون ما أنزلَ اللهُ ولايُحَرِّفُونه.</p></div>"
  3,200,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَابِرُواْ﴾</span>: أي غالِبُوا أعداءَكم في الصَّبْرِ.</p><p><span class="qpc-hafs">﴿وَرَابِطُواْ﴾</span>: وأقِيمُوا على جهادِ العَدُوِّ.</p></div>"
