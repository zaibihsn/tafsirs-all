quran[118]{c,v,t}:
  23,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡلَحَ﴾</span>: فازَ بِالنَّجاةِ مِنَ النّارِ.</p></div>"
  23,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعُونَ﴾</span>: خاضِعُونَ بِقُلوبِهِم وجَوارِحِهِم.</p></div>"
  23,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنِ ٱللَّغۡوِ مُعۡرِضُونَ﴾</span>: أي: تارِكُونَ لِكُلِّ ما لا خَيرَ فِيه مِنَ العَبَثِ.</p></div>"
  23,4,""
  23,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَـٰفِظُونَ﴾</span>: أي: ممّا حَرَّم الله مِنَ الزِّنى وسائرِ الفواحِشِ.</p></div>"
  23,6,""
  23,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتَغَىٰ وَرَآءَ ذَ ٰ⁠لِكَ﴾</span>: طَلَبَ التَّمَتُّعَ بِغَيرِ ما أحَلَّه اللهُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَادُونَ﴾</span>: المُجاوِزُونَ حُدَودَ اللهِ.</p></div>"
  23,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَ ٰ⁠عُونَ﴾</span>: حافِظُونَ.</p></div>"
  23,9,""
  23,10,""
  23,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفِرۡدَوۡسَ﴾</span>: أعْلى مَنازِلِ الجنَّةِ وأَوسَطَها، وهو أفْضَلُها.</p></div>"
  23,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡإِنسَـٰنَ﴾</span>: آدَمَ.</p><p><span class="qpc-hafs">﴿مِن سُلَـٰلَةࣲ مِّن طِينࣲ﴾</span>: أي: مِن طِينٍ مأخُوذٍ مِن جَمِيعِ الأرضِ.</p></div>"
  23,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُطۡفَةࣰ﴾</span>: هي مَنِيُّ الرَّجُلِ يَقْذِفُه في رَحِمِ امْرَأَتِه.</p><p><span class="qpc-hafs">﴿قَرَارࣲ مَّكِينࣲ﴾</span>: مُسْتَقِرٍّ مُتمَكِّنٍ، وهو رَحِمُ المرْأَةِ.</p></div>"
  23,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَقَةࣰ﴾</span>: دَمًا أحْمرَ غَلِيظًا.</p><p><span class="qpc-hafs">﴿مُضۡغَةࣰ﴾</span>: قِطْعَةَ لَحْمِ قَدْرَ ما يُمَضَغُ.</p><p><span class="qpc-hafs">﴿فَكَسَوۡنَا ٱلۡعِظَـٰمَ لَحۡمࣰا﴾</span>: أي: أنْبَتْنا على كُلِّ عَظْمٍ لَحْمًا مُناسِبًا.</p><p><span class="qpc-hafs">﴿خَلۡقًا ءَاخَرَ﴾</span>: مُباينًا لِلْأَوَّلِ، وذلِكَ بِنَفْخِ الرُّوحِ فيه بَعْدَ أنْ كانَ جمادًا.</p></div>"
  23,15,""
  23,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُبۡعَثُونَ﴾</span>: تُحْيَوْن مِن قُبُورِكُم؛ لَلْحِسابِ.</p></div>"
  23,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبۡعَ طَرَآئِقَ﴾</span>: سَبْعَ سَمَواتٍ جُعِلَ بعضُها فَوْقَ بَعْضٍ.</p></div>"
  23,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِقَدَرࣲ﴾</span>: أي: بِمِقْدارِ الحاجَةِ.</p><p><span class="qpc-hafs">﴿فَأَسۡكَنَّـٰهُ فِي ٱلۡأَرۡضِ﴾</span>: أي: جَعَلْناه مُسْتَقِرًّا فِيها.</p><p><span class="qpc-hafs">﴿عَلَىٰ ذَهَابِۭ بِهِۦ﴾</span>: أي: على إذْهابِ هذا الماءِ.</p></div>"
  23,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتࣲ﴾</span>: بساتِينَ.</p></div>"
  23,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَجَرَةࣰ﴾</span>: هي شَجَرَةُ الزَّيتُونِ.</p><p><span class="qpc-hafs">﴿طُورِ﴾</span>: هو جَبَلٌ ب «سَيْناءَ».</p><p><span class="qpc-hafs">﴿بِٱلدُّهۡنِ﴾</span>: أي: مُلْتَبِسًا ثَمَرُها بالزَّيتِ.</p><p><span class="qpc-hafs">﴿وَصِبۡغࣲ﴾</span>: إدامٍ يُغْمَسُ فيه الخُبْزُ.</p></div>"
  23,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعِبۡرَةࣰ﴾</span>: لَعِظَةً وآيةً على القُدْرَةِ والرَّحْمَةِ.</p></div>"
  23,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَلَيۡهَا﴾</span>: أي: وعلى الإبِلِ من الأنعامِ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السُّفُنِ.</p></div>"
  23,23,""
  23,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَؤُاْ﴾</span>: أشرافُ القومِ وسادَتُهم.</p><p><span class="qpc-hafs">﴿أَن يَتَفَضَّلَ﴾</span>: أن يتَرَأَّسَ ويَشْرُفَ عليكم.</p></div>"
  23,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جِنَّةࣱ﴾</span>: أي: جُنُونٌ أو مَسٌّ من الجِنِّ.</p><p><span class="qpc-hafs">﴿فَتَرَبَّصُواْ﴾</span>: فانْتَظِرُوا.</p><p><span class="qpc-hafs">﴿حِينࣲ﴾</span>: أي: وقتٍ مّا.</p></div>"
  23,26,""
  23,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَعۡيُنِنَا﴾</span>: بِمَرْأىً مِنّا.</p><p><span class="qpc-hafs">﴿أَمۡرُنَا﴾</span>: أي: بِعَذابِهم بالطُّوفانِ.</p><p><span class="qpc-hafs">﴿وَفَارَ﴾</span>: نَبَعَ الماءُ وخَرَجَ بِقُوَّةٍ.</p><p><span class="qpc-hafs">﴿ٱلتَّنُّورُ﴾</span>: هو المكانُ الذي يُخْبزُ فِيه.</p><p><span class="qpc-hafs">﴿فَٱسۡلُكۡ﴾</span>: أدْخِلْ.</p><p><span class="qpc-hafs">﴿مِن كُلࣲّ﴾</span>: أي: من كُلِّ الأَحْياءِ.</p><p><span class="qpc-hafs">﴿زَوۡجَيۡنِ﴾</span>: ذَكَرًا وأنْثى.</p><p><span class="qpc-hafs">﴿سَبَقَ عَلَيۡهِ ٱلۡقَوۡلُ﴾</span>: أي: سَبَق القضاءُ بِهلاكِه؛ لِكُفْرِه كزَوْجَتِكَ وابْنِكَ.</p></div>"
  23,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَيۡتَ﴾</span>: اعْتَدَلَتْ، أي: بَعْدَ رُكُوبِكَ في السَّفِينةِ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السَّفِينةِ.</p></div>"
  23,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنزَلࣰا﴾</span>: إنْزِالًا أومَكانَ إنْزالٍ.</p></div>"
  23,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: عِبَرًا وحُجَجًا يُسْتَدَلُّ بها على سُنَنِ اللهِ في أمْثالِ هؤلاءِ مِنَ الكَفَرةِ والمُشْرِكِينَ.</p><p><span class="qpc-hafs">﴿وَإِن كُنَّا﴾</span>: وإننا كُنّا.</p><p><span class="qpc-hafs">﴿لَمُبۡتَلِينَ﴾</span>: لمُخْتَبِريِنَ الناسَ بهذه الآياتِ.</p></div>"
  23,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ أَنشَأۡنَا﴾</span>: أحْدَثْنا وخَلَقْنا.</p><p><span class="qpc-hafs">﴿قَرۡنًا ءَاخَرِينَ﴾</span>: جِيلًا آخَرَ: هم قَومُ عادٍ أو قومُ ثمُودَ.</p></div>"
  23,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَسُولࣰا مِّنۡهُمۡ﴾</span>: هو هودٌ أو صالحٌ عليهما الصَّلاةُ والسَّلامُ.</p></div>"
  23,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: الأشْرافُ.</p><p><span class="qpc-hafs">﴿بِلِقَآءِ ٱلۡـَٔاخِرَةِ﴾</span>: أي: بِلقاءِ اللهِ يومَ القِيامةِ.</p><p><span class="qpc-hafs">﴿وَأَتۡرَفۡنَـٰهُمۡ﴾</span>: جَعَلْناهُم في تَرَفٍ وسَعَةٍ حتّى بَطِرُوا.</p></div>"
  23,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّخَـٰسِرُونَ﴾</span>: أي: بِتَرْكِكُم آلِهَتَكم واتِّباعِكُم الرسولَ عليه السلام.</p></div>"
  23,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّخۡرَجُونَ﴾</span>: أي: من قُبُورِكُم أحياءً.</p></div>"
  23,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَيۡهَاتَ﴾</span>: بَعُدَ، أي: ما تُوعدُونَ به أيُّها القومُ.</p><p><span class="qpc-hafs">﴿لِمَا تُوعَدُونَ﴾</span>: هو البعثُ بَعْدَ الموتِ.</p></div>"
  23,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا نَحۡنُ بِمَبۡعُوثِينَ﴾</span>: أي: بَعْدَ المماتِ.</p></div>"
  23,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا رَجُلٌ﴾</span>: هو هُودٌ أو صالحٌ عليهما الصَّلاةُ والسَّلامُ.</p><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اختَلَقَ.</p><p><span class="qpc-hafs">﴿بِمُؤۡمِنِينَ﴾</span>: بِمُصَدِّقِينَ.</p></div>"
  23,39,""
  23,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَمَّا قَلِيلࣲ﴾</span>: أي: بَعْدَ زَمَنٍ قَريبٍ.</p></div>"
  23,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّيۡحَةُ﴾</span>: صَوْتٌ شَدِيدٌ مُهْلِكٌ.</p><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: أي: يَسْتَحِقُّونَ ذَلك العذابَ؛ لِكُفْرِهم وطُغْيانِهم.</p><p><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهُمۡ غُثَآءࣰ﴾</span>: أي: أمْواتًا كَغُثاءِ السَّيلِ الذي يَطْفُو على الماءِ.</p><p><span class="qpc-hafs">﴿فَبُعۡدࣰا﴾</span>: أي: عَن رَّحْمَةِ اللهِ.</p></div>"
  23,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنشَأۡنَا﴾</span>: خلَقْنا وأوْجَدْنا.</p><p><span class="qpc-hafs">﴿قُرُونًا ءَاخَرِينَ﴾</span>: أقْوامًا آخَرِينَ مِثْلَ قَوْمِ لُوطٍ وشُعَيبٍ وأيُّوبَ ويونسَ عليهمُ الصَّلاةُ والسَّلامُ.</p></div>"
  23,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تَسۡبِقُ﴾</span>: ما تَتَقَدَّمُ.</p><p><span class="qpc-hafs">﴿أَجَلَهَا﴾</span>: الوَقْتَ المَحْدُودَ لهلاكِها.</p><p><span class="qpc-hafs">﴿وَمَا يَسۡتَـٔۡخِرُونَ﴾</span>: ولا يتأخَّرُونَ.</p></div>"
  23,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتۡرَا﴾</span>: يَتْبَعُ بعضُهم بَعْضًا.</p><p><span class="qpc-hafs">﴿أَحَادِيثَ﴾</span>: أخْبارًا يَتَحَدَّثُ الناسُ بها للعِبْرَةِ وغيرِها.</p><p><span class="qpc-hafs">﴿فَبُعۡدࣰا﴾</span>: أي: بُعْدًا عَن رَّحْمَةِ اللهِ.</p></div>"
  23,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: أي: بالمُعْجِزاتِ التِّسْعِ، وهي: العَصا واليدُ البيضاءُ والسِّنونَ المُجْدِبةُ ونَقْصُ الثَّمَراتِ، والطُّوفانُ والجَرادُ والقُمَّلُ والضَّفادِعُ والدَّمُ</p><p><span class="qpc-hafs">﴿وَسُلۡطَـٰنࣲ مُّبِينٍ﴾</span>: بُرْهانٍ مُظْهِرٍ لِلْحَقِّ.</p></div>"
  23,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَلَإِيْهِۦ﴾</span>: وأشْرافِ قَومِه.</p><p><span class="qpc-hafs">﴿عَالِينَ﴾</span>: مُسْتَعْلِينَ على النّاسِ بالبَغْيِ والظُّلْمِ.</p></div>"
  23,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَا عَـٰبِدُونَ﴾</span>: أي: مُنْقادُون اْنِقيادَ العَبِيدِ.</p></div>"
  23,48,""
  23,49,""
  23,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: علامةً على عَظِيمِ قُدْرَتِنا.</p><p><span class="qpc-hafs">﴿وَءَاوَيۡنَـٰهُمَآ﴾</span>: وجَعَلْنا لَهُما مأْوىً ومْنزِلًا.</p><p><span class="qpc-hafs">﴿رَبۡوَةࣲ﴾</span>: بُقْعَةٍ مُرْتَفِعَةٍ.</p><p><span class="qpc-hafs">﴿ذَاتِ قَرَارࣲ﴾</span>: أي: فيها أسْبابُ الاسْتِقْرارِ من الزَّرِعِ والثِّمارِ.</p><p><span class="qpc-hafs">﴿وَمَعِينࣲ﴾</span>: وماءٍ جارٍ تَسْتَمْتِعُ بِرُؤيَتِه العُيونُ.</p></div>"
  23,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلطَّيِّبَـٰتِ﴾</span>: مايُسْتَطابُ مِنَ الحَلالِ.</p></div>"
  23,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّتُكُمۡ أُمَّةࣰ﴾</span>: دِينُكُم دِينٌ واحِدٌ وهو دَعْوةُ جَمِيعِ الأنْبِياءِ إلى عِبادَةِ اللهِ وحْدَه لا شَرِيكَ لَه.</p></div>"
  23,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَقَطَّعُوٓاْ أَمۡرَهُم بَيۡنَهُمۡ﴾</span>: تَفرَّقَ الأتْباعُ في أمْرِ دِينِهِم.</p><p><span class="qpc-hafs">﴿زُبُرࣰا﴾</span>: قِطَعًا وفِرَقًا.</p><p><span class="qpc-hafs">﴿فَرِحُونَ﴾</span>: مَسْرُورُونَ.</p></div>"
  23,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَرۡهُمۡ﴾</span>: فاتْرُكْهُم.</p><p><span class="qpc-hafs">﴿فِي غَمۡرَتِهِمۡ﴾</span>: في غَفْلَتِهِم التي غَمَرَتْهُم وغَطَّتْهم مِن كُلِّ الجِهاتِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ حِينٍ﴾</span>: إلى وقْتِ نُزُولِ العَذاب بِهِم.</p></div>"
  23,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحۡسَبُونَ﴾</span>: أيظُنُّونَ.</p><p><span class="qpc-hafs">﴿نُمِدُّهُم﴾</span>: نُعْطِيهِم اسْتِدْراجًا</p></div>"
  23,56,""
  23,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّشۡفِقُونَ﴾</span>: وجِلُونَ وحَذِرُونَ.</p></div>"
  23,58,""
  23,59,""
  23,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡتُونَ مَآ ءَاتَواْ﴾</span>: يُعْطُونَ ما أعْطَوا مِنَ الصَّدقاتِ.</p><p><span class="qpc-hafs">﴿وَجِلَةٌ﴾</span>: خائِفَةٌ.</p></div>"
  23,61,""
  23,62,""
  23,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي غَمۡرَةࣲ﴾</span>: في غَفْلَةٍ.</p><p><span class="qpc-hafs">﴿مِّن دُونِ ذَ ٰ⁠لِكَ﴾</span>: مِن دُونِ الشِّركِ.</p></div>"
  23,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتۡرَفِيهِم﴾</span>: مُنَعَّمِيهِم الذين أبْطَرَتْهُم النِّعَمُ.</p><p><span class="qpc-hafs">﴿يَجۡـَٔرُونَ﴾</span>: يَصْرُخُونَ مُسْتَغِيثِينَ.</p></div>"
  23,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَجۡـَٔرُواْ﴾</span>: لا تَصْرُخُوا.</p></div>"
  23,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنكِصُونَ﴾</span>: تَرْجِعُونَ وراءَكُم مُعْرِضِينَ عَنْ سَماعِ الآياتِ.</p></div>"
  23,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِهِۦ سَـٰمِرࣰا﴾</span>: أي: مُتَسامِرِينَ باللَّيلِ حَولَ الكَعْبَةِ.</p><p><span class="qpc-hafs">﴿تَهۡجُرُونَ﴾</span>: تَتَكَلَّمُونَ بِساقِطِ القولِ.</p></div>"
  23,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَلَمۡ يَدَّبَّرُواْ ٱلۡقَوۡلَ﴾</span>: أفلم يَتَفَكَّرُوا في القرآنِ.</p></div>"
  23,69,""
  23,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جِنَّةُۢ﴾</span>: جُنُونٌ.</p></div>"
  23,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِذِكۡرِهِمۡ﴾</span>: بالقرآنِ الذي فِيهِ عِزُّهُم وشَرفُهُم.</p></div>"
  23,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَرۡجࣰا﴾</span>: أجْرًا مِنَ المالِ.</p><p><span class="qpc-hafs">﴿فَخَرَاجُ رَبِّكَ﴾</span>: ثوابُ اللهِ وعَطاؤُه.</p></div>"
  23,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: دِينٍ قَوِيمٍ وهو الإسْلامُ.</p></div>"
  23,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَـٰكِبُونَ﴾</span>: لمائِلُونَ ومُنْحَرِفُونَ عَنْه.</p></div>"
  23,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن ضُرࣲّ﴾</span>: مِن جَدْبٍ وجُوعٍ.</p><p><span class="qpc-hafs">﴿لَّلَجُّواْ﴾</span>: لَتَمادَوا واسْتَمَرُّوا.</p><p><span class="qpc-hafs">﴿فِي طُغۡيَـٰنِهِمۡ﴾</span>: في كُفْرِهِم وعِنادِهِم.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يَتَرَدَّدُونَ.</p></div>"
  23,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا ٱسۡتَكَانُواْ﴾</span>: فما خَضَعُوا وما أظْهَرُوا المَسْكَنَةَ.</p><p><span class="qpc-hafs">﴿وَمَا يَتَضَرَّعُونَ﴾</span>: وما يَتَذَلَّلُونَ للهِ تعالى بالدُّعاءِ.</p></div>"
  23,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُبۡلِسُونَ﴾</span>: آيِسُونَ مِن كُلِّ خَيرٍ، مُتَحَيِّرُونَ.</p></div>"
  23,78,""
  23,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرَأَكُمۡ﴾</span>: خَلَقَكُم وبَثَّكُم.</p></div>"
  23,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡتِلَـٰفُ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: تَعاقُبُهُما وتَفاوُتُهُما.</p></div>"
  23,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَوَّلُونَ﴾</span>: آباؤهُم وأَسْلافُهُم المُتَقَدِّمون.</p></div>"
  23,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَبۡعُوثُونَ﴾</span>: أي: من قُبُورِنا أحْياءً.</p></div>"
  23,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: الأكاذِيبُ الَّتي كَتَبَها المُتَقَدِّمُونَ.</p></div>"
  23,84,""
  23,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَلَا تَذَكَّرُونَ﴾</span>: أنَّ اللهَ قادِرٌ على البَعْثِ والنُّشُورِ.</p></div>"
  23,86,""
  23,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَلَا تَتَّقُونَ﴾</span>: أفلا تَخافُونَ عِقابَ اللهِ على كُفْرِكُم وشِرْكِكُم؟</p></div>"
  23,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلَكُوتُ كُلِّ شَيۡءࣲ﴾</span>: مالِكُ كُلِّ شَيءٍ والمُتَصَرِّفُ فِيه.</p><p><span class="qpc-hafs">﴿يُجِيرُ﴾</span>: يُغِيثُ ويَحْمِي غيرَه.</p><p><span class="qpc-hafs">﴿وَلَا يُجَارُ عَلَيۡهِ﴾</span>: ولا يُغِيثُ ولا يَحْمِي أحَدٌ منه أحَدًا.</p></div>"
  23,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُسۡحَرُونَ﴾</span>: فَكَيفَ تُصْرَفَونَ عَنِ الحقِّ؟</p></div>"
  23,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكَـٰذِبُونَ﴾</span>: أي: في شِرْكِهِم وإنْكارِهِم البَعْثَ.</p></div>"
  23,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّذَهَبَ كُلُّ إِلَـٰهِۭ بِمَا خَلَقَ﴾</span>: أي: لانْفَردَ كُلُّ مَعْبُودٍ بِمَخْلُوقاتِه.</p><p><span class="qpc-hafs">﴿وَلَعَلَا﴾</span>: ولَغَلَبَ.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَ ٱللَّهِ﴾</span>: تَنَزَّه وتَقَدَّسَ.</p><p><span class="qpc-hafs">﴿عَمَّا يَصِفُونَ﴾</span>: أي: من كَذِبِهِم وبُهْتانِهِم بِأَنَّ له شَرِيكًا أوْ ولَدًَا.</p></div>"
  23,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلشَّهَـٰدَةِ﴾</span>: وما يُشاهَدُ.</p></div>"
  23,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يُوعَدُونَ﴾</span>: أي: مِنَ العَذابِ.</p></div>"
  23,94,""
  23,95,""
  23,96,""
  23,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَمَزَ ٰ⁠تِ﴾</span>: نَزَغاتٍ ووَساوِسَ.</p></div>"
  23,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَحۡضُرُونِ﴾</span>: أي: مِن حُضُورِ الشَّياطِينِ في أُمُورِي.</p></div>"
  23,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱرۡجِعُونِ﴾</span>: رُدُّوني إلى الدُّنيا.</p></div>"
  23,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ قَآئِلُهَا﴾</span>: يَقُولُها باللِّسانِ ولا يَعْمَلُ بِمُقْتَضاها.</p><p><span class="qpc-hafs">﴿بَرۡزَخٌ﴾</span>: هو الحاجِزُ الَّذي بين الموتِ والبَعْثِ.</p></div>"
  23,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الذي يُنفَخُ فيه للَبعْثِ.</p><p><span class="qpc-hafs">﴿فَلَآ أَنسَابَ بَيۡنَهُمۡ﴾</span>: أي: فلا تَنْفَعُهم أنْسابُهم، ولا يَتَفاخَرُونَ بها مِن هَوْلِ الموْقِفِ.</p><p><span class="qpc-hafs">﴿وَلَا يَتَسَآءَلُونَ﴾</span>: أي: لا يَسْأَلُ أحَدٌ أحَدًا.</p></div>"
  23,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: أي: بِكَثْرةِ حسناتِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ بالجنَّةِ والنَّجاةِ مِنَ النّارِ.</p></div>"
  23,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَفَّتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: أي: قَلَّتْ أعْمالُه الصّالِحَةُ.</p><p><span class="qpc-hafs">﴿خَسِرُوٓاْ أَنفُسَهُمۡ﴾</span>: أي: ضَيَّعُوها.</p></div>"
  23,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلۡفَحُ﴾</span>: تَحْرِقُ.</p><p><span class="qpc-hafs">﴿كَـٰلِحُونَ﴾</span>: عابِسُونَ تَقَلَّصَتْ شِفاهُهُم عن أسْنانِهِم؛ مِن إحْراقِ النّارِ وُجُوهَهُم.</p></div>"
  23,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِي﴾</span>: أي: آياتُ القُرآن.</p></div>"
  23,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِقۡوَتُنَا﴾</span>: هي المَلَذّاتُ والشَّهَواتُ التي كُتِبَتْ عَلَينا في سابِقِ عِلْمِكَ وساقَتْنا إلى الشِّقاءِ.</p></div>"
  23,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنۡ عُدۡنَا﴾</span>: فَإن رَّجَعْنا إلى الضَّلالِ.</p></div>"
  23,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡسَـُٔواْ فِيهَا﴾</span>: امْكُثُوا في النّارِ أذِلّاءَ صاغِرِينَ.</p></div>"
  23,109,""
  23,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِخۡرِيًّا﴾</span>: مَهْزُوءًا بهم.</p></div>"
  23,111,""
  23,112,""
  23,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَآدِّينَ﴾</span>: أي: المُتَمَكِّنِينَ مِن مَّعْرِفَةِ العَدَدِ مِنَ الملائِكَةِ أو مِنَ النّاسِ.</p></div>"
  23,114,""
  23,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبَثࣰا﴾</span>: لَعِبًا مِن غَيرِ فائِدةٍ ولاحِكْمَةٍ.</p></div>"
  23,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلِكُ﴾</span>: الَّذي يَحِقُّ لَهُ المُلْكُ على الإطْلاقِ</p><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: الثّابِتُ الَّذي لا يَزُولُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هو سَرِيرُ المُلْكِ الَّذي اسْتَوى عليه الرَّحمنُ، وتَحْمِلُه الملائِكةُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p></div>"
  23,117,""
  23,118,""
