quran[78]{c,v,t}:
  55,1,""
  55,2,""
  55,3,""
  55,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَيَانَ﴾</span>: النُّطْقَ والتَّعْبِيرَ عَمّا في الضَّمائِرِ.</p></div>"
  55,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِحُسۡبَانࣲ﴾</span>: يَجْرِيانِ بِحِسابٍ مُتْقَنٍ.</p></div>"
  55,6,""
  55,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمِيزَانَ﴾</span>: العَدْلَ الَّذِي شَرَعَهُ لِعِبادِهِ.</p></div>"
  55,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَّا تَطۡغَوۡاْ﴾</span>: لِئَلّا تَعْتَدُوا.</p></div>"
  55,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p><p><span class="qpc-hafs">﴿وَلَا تُخۡسِرُواْ﴾</span>: ولا تُنْقِصُوا.</p></div>"
  55,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَعَهَا﴾</span>: مَهَّدَها.</p><p><span class="qpc-hafs">﴿لِلۡأَنَامِ﴾</span>: لِلْخَلْقِ.</p></div>"
  55,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَكۡمَامِ﴾</span>: جَمْعُ كِمٍّ وهو وِعاءُ الثَّمرَةِ.</p></div>"
  55,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُو ٱلۡعَصۡفِ﴾</span>: ذُو القِشْرِ.</p><p><span class="qpc-hafs">﴿وَٱلرَّيۡحَانُ﴾</span>: كُلُّ نَبْتٍ طَيِّبِ الرّائِحةِ.</p></div>"
  55,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَالَآءِ﴾</span>: نِعَمِ.</p></div>"
  55,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡإِنسَـٰنَ﴾</span>: أي أباه، وهو آدَمُ.</p><p><span class="qpc-hafs">﴿مِن صَلۡصَـٰلࣲ﴾</span>: مِن طِينٍ يابِسٍ.</p><p><span class="qpc-hafs">﴿كَٱلۡفَخَّارِ﴾</span>: الطينِ الَّذِي طُبِخَ بالنّارِ.</p></div>"
  55,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَآنَّ﴾</span>: إبْلِيسَ.</p><p><span class="qpc-hafs">﴿مَّارِجࣲ﴾</span>: لَهَبِ الَّنارِ المُخْتَلِطِ بَعْضُهُ بِبَعْضٍ.</p></div>"
  55,16,""
  55,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَشۡرِقَيۡنِ﴾</span>: مَشْرِقَي الشَّمْسِ في الشِّتاءِ والصَّيفِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَغۡرِبَيۡنِ﴾</span>: مَغْرِبَيِ الشَّمسِ في الشِّتاءِ والصَّيفِ.</p></div>"
  55,18,""
  55,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرَجَ﴾</span>: خَلَطَ.</p><p><span class="qpc-hafs">﴿ٱلۡبَحۡرَيۡنِ﴾</span>: الماءَ العَذْبَ والمِلْحَ.</p><p><span class="qpc-hafs">﴿يَلۡتَقِيَانِ﴾</span>: في مَرْأى العَينِ.</p></div>"
  55,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَرۡزَخࣱ﴾</span>: حاجِزٌ.</p><p><span class="qpc-hafs">﴿لَّا يَبۡغِيَانِ﴾</span>: لا يطْغى أحَدُهُما عَلى الآخَرِ.</p></div>"
  55,21,""
  55,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللُّؤۡلُؤُ﴾</span>: الدُّرُّ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَرۡجَانُ﴾</span>: صِغارُ اللُّؤلُؤ.</p></div>"
  55,23,""
  55,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَوَارِ﴾</span>: السُّفُنُ الضَّخْمَةُ الَّتِي تَجْرِي في البَحْرِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنشَـَٔاتُ﴾</span>: المَرْفُوعاتُ الشِّراعِ.</p><p><span class="qpc-hafs">﴿كَٱلۡأَعۡلَـٰمِ﴾</span>: كالجِبالِ.</p></div>"
  55,25,""
  55,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَيۡهَا﴾</span>: عَلى وجْهِ الأرْضِ.</p><p><span class="qpc-hafs">﴿فَانࣲ﴾</span>: هالِكٌ.</p></div>"
  55,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَلَـٰلِ﴾</span>: ذُو العَظَمَةِ والكِبْرِياءِ.</p><p><span class="qpc-hafs">﴿وَٱلۡإِكۡرَامِ﴾</span>: والفَضْلِ والجُودِ.</p></div>"
  55,28,""
  55,29,""
  55,30,""
  55,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنَفۡرُغُ﴾</span>: سنفرغ لحسابكم ومجازاتكم بأعْمالِكُم.</p><p><span class="qpc-hafs">﴿أَيُّهَ ٱلثَّقَلَانِ﴾</span>: أيُّها الإنْسُ والجِنُّ.</p></div>"
  55,32,""
  55,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنفُذُواْ﴾</span>: تَخْرُجُوا.</p><p><span class="qpc-hafs">﴿أَقۡطَارِ﴾</span>: أطْرافِ.</p><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنࣲ﴾</span>: بِقُوَّةٍ وحُجَّةٍ.</p></div>"
  55,34,""
  55,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُوَاظࣱ﴾</span>: لَهَبٌ.</p><p><span class="qpc-hafs">﴿وَنُحَاسࣱ﴾</span>: مُذابٌ يُصَبُّ على رُؤُوسِكُم.</p><p><span class="qpc-hafs">﴿فَلَا تَنتَصِرَانِ﴾</span>: فَلا يَنْصُرُ بَعْضُكُم بَعْضًا.</p></div>"
  55,36,""
  55,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنشَقَّتِ﴾</span>: تَفَطَّرَتْ يَوْمَ القِيامَةِ.</p><p><span class="qpc-hafs">﴿وَرۡدَةࣰ﴾</span>: حَمْراءَ كَلَونِ الوَرْدِ.</p><p><span class="qpc-hafs">﴿كَٱلدِّهَانِ﴾</span>: كالزَّيتِ الَمغْلِيِّ والرَّصاصِ المُذابِ.</p></div>"
  55,38,""
  55,39,""
  55,40,""
  55,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسِيمَـٰهُمۡ﴾</span>: بعَلاماتِهِم.</p><p><span class="qpc-hafs">﴿بِٱلنَّوَ ٰ⁠صِي﴾</span>: بمُقَدِّمَةِ رُؤُوسِهِم.</p></div>"
  55,42,""
  55,43,""
  55,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمِيمٍ﴾</span>: الماءِ الشَّدِيدِ الحَرارَةِ.</p><p><span class="qpc-hafs">﴿ءَانࣲ﴾</span>: بالغٍ مُنْتَهاهُ في الحرارةِ.</p></div>"
  55,45,""
  55,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقَامَ رَبِّهِۦ﴾</span>: وقْتَ قِيامِهِ بين يَدَي رَبِّهِ.</p></div>"
  55,47,""
  55,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡنَانࣲ﴾</span>: أغْصانٍ نَضِرَةٍ مِنَ الفَواكِهِ والثِّمارِ.</p></div>"
  55,49,""
  55,50,""
  55,51,""
  55,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَوۡجَانِ﴾</span>: صِنْفانِ.</p></div>"
  55,53,""
  55,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَطَآئِنُهَا﴾</span>: جَمْعُ بِطانَةٍ وهي: ما يَلِي الأرْضَ مِنَ الفِراشِ.</p><p><span class="qpc-hafs">﴿إِسۡتَبۡرَقࣲ﴾</span>: غَلِيظِ الحرِيرِ الخالِصِ.</p><p><span class="qpc-hafs">﴿وَجَنَى﴾</span>: وثَمَرُ.</p><p><span class="qpc-hafs">﴿دَانࣲ﴾</span>: قَرِيبٌ إليهِم.</p></div>"
  55,55,""
  55,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِنَّ﴾</span>: في هَذِه الفُرُشِ.</p><p><span class="qpc-hafs">﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span>: لا يَصْرِفْنَ أبْصارَهُنَّ إلى غَيرِ أزْواجِهِنَّ.</p><p><span class="qpc-hafs">﴿لَمۡ يَطۡمِثۡهُنَّ﴾</span>: لم يَطَأْهُنَّ.</p></div>"
  55,57,""
  55,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡيَاقُوتُ﴾</span>: حَجَرٌ مِنَ الأحْجارِ الكَرِيمَةِ، ذُو ألْوانٍ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَرۡجَانُ﴾</span>: صِغارُ اللُّؤلُؤِ.</p></div>"
  55,59,""
  55,60,""
  55,61,""
  55,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِن دُونِهِمَا﴾</span>: ومِن دُونِ الجنَّتَينِ السّابِقَتَينِ في الدَّرَجِ.</p></div>"
  55,63,""
  55,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُدۡهَآمَّتَانِ﴾</span>: خَضْراوانِ، وقَدِ اشْتَدَّتْ خُضْرَتُهُما حَتّى مالَتْ إلى السَّوادِ.</p></div>"
  55,65,""
  55,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَضَّاخَتَانِ﴾</span>: فَوّارتانِ بالماءِ لا تَنْقَطِعانِ.</p></div>"
  55,67,""
  55,68,""
  55,69,""
  55,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِنَّ﴾</span>: في هَذِه الجنّاتِ الأرْبَعِ.</p><p><span class="qpc-hafs">﴿خَيۡرَ ٰ⁠تٌ﴾</span>: زَوْجاتٌ طيِّباتُ الأخْلاقِ.</p><p><span class="qpc-hafs">﴿حِسَانࣱ﴾</span>: حِسانُ الوُجُوهِ.</p></div>"
  55,71,""
  55,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُورࣱ﴾</span>: نِساءٌ ذَواتُ حَوَرٍ، وهو شِدَّةُ بَياضِ العَينِ وشِدَّةُ سَوادِها.</p><p><span class="qpc-hafs">﴿مَّقۡصُورَ ٰ⁠تࣱ﴾</span>: مَسْتُوراتٌ مَصُوناتٌ.</p><p><span class="qpc-hafs">﴿ٱلۡخِيَامِ﴾</span>: البُيوتِ.</p></div>"
  55,73,""
  55,74,""
  55,75,""
  55,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَفۡرَفٍ﴾</span>: وسائِدَ ذَواتِ أغْطِيَةٍ.</p><p><span class="qpc-hafs">﴿وَعَبۡقَرِيٍّ﴾</span>: وفُرُشٍ بَدِيعَةٍ.</p></div>"
  55,77,""
  55,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَـٰرَكَ﴾</span>: كَثُرَ خَيرُهُ.</p><p><span class="qpc-hafs">﴿ٱلۡجَلَـٰلِ﴾</span>: العَظَمَةِ والمَجْدِ.</p><p><span class="qpc-hafs">﴿وَٱلۡإِكۡرَامِ﴾</span>: لِأَوْلِيائِهِ.</p></div>"
