quran[54]{c,v,t}:
  34,1,""
  34,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلِجُ﴾</span>: يَدْخُلُ.</p><p><span class="qpc-hafs">﴿يَخۡرُجُ مِنۡهَا﴾</span>: أي: مِنَ النَّباتِ والمعادِن والِمياهِ.</p><p><span class="qpc-hafs">﴿وَمَا يَنزِلُ مِنَ ٱلسَّمَآءِ﴾</span>: مِنَ الأمْطارِ والملائِكةِ والكُتُبِ.</p><p><span class="qpc-hafs">﴿وَمَا يَعۡرُجُ فِيهَا﴾</span>: وما صَعَدُ إلَيها مِنَ الملائِكَةِ وأعْمالِ الخلْقِ.</p></div>"
  34,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّاعَةُ﴾</span>: القِيامةُ.</p><p><span class="qpc-hafs">﴿لَا يَعۡزُبُ عَنۡهُ﴾</span>: لا يَغِيبُ عَنْهُ ولا يَخْفى عَلَيهِ.</p><p><span class="qpc-hafs">﴿مِثۡقَالُ ذَرَّةࣲ﴾</span>: مِقْدارُ أصْغرِ نَمْلَةٍ.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣲ مُّبِينࣲ﴾</span>: كِتابٍ واضِحٍ، وهو اللَّوحُ المَحْفُوظُ.</p></div>"
  34,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرِزۡقࣱ كَرِيمࣱ﴾</span>: وهو الجنَّةُ.</p></div>"
  34,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعَـٰجِزِينَ﴾</span>: ظانِّينَ أنّهم يُعْجِزُونَنا ويَغْلِبُونَنا.</p><p><span class="qpc-hafs">﴿مِّن رِّجۡزٍ﴾</span>: أسْوَأِ العَذابِ وأشَدِّهِ.</p></div>"
  34,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَرَى﴾</span>: يَعْلمُ.</p><p><span class="qpc-hafs">﴿وَيَهۡدِيٓ﴾</span>: يُرْشِدُ.</p></div>"
  34,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنَبِّئُكُمۡ﴾</span>: يُخْبِرُكُم بِنَبَأٍ غَرِيبٍ.</p><p><span class="qpc-hafs">﴿مُزِّقۡتُمۡ﴾</span>: قُطِّعْتُم، وتَفَرَّقَتْ أجْسادُكُم إلى أجْزاءٍ.</p></div>"
  34,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡتَرَىٰ﴾</span>: هَلِ اخْتَلَقَ؟</p><p><span class="qpc-hafs">﴿جِنَّةُۢ﴾</span>: جُنُونٌ.</p></div>"
  34,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا بَيۡنَ أَيۡدِيهِمۡ وَمَا خَلۡفَهُم مِّنَ ٱلسَّمَآءِ وَٱلۡأَرۡضِ﴾</span>: أي: كُلٌّ مِنَ السَّماءِ والأرضِ يُحِيطُ بِهِم مِن أمامِهِم وخَلْفِهِم.</p><p><span class="qpc-hafs">﴿نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ﴾</span>: نَجْعَلِ الأرْضَ تَبْتَلِعُهُم وهُمْ أحْياءٌ.</p><p><span class="qpc-hafs">﴿كِسَفࣰا مِّنَ ٱلسَّمَآءِ﴾</span>: قِطَعًا مِنها.</p><p><span class="qpc-hafs">﴿مُّنِيبࣲ﴾</span>: راجِعٍ إلى رَبِّهِ بالتَّوبَةِ والطّاعَةِ.</p></div>"
  34,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوِّبِي﴾</span>: سَبِّحِي.</p><p><span class="qpc-hafs">﴿وَأَلَنَّا لَهُ ٱلۡحَدِيدَ﴾</span>: جَعَلْنا الحديدَ في يدِهِ لَيِّنًا، يَصْنَعُ بِهِ ما يَشاءُ.</p></div>"
  34,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَـٰبِغَـٰتࣲ﴾</span>: أي: دُرُوعًا واسِعاتٍ تُغَطِّي الِجسْمَ كلَّه.</p><p><span class="qpc-hafs">﴿قَدِّرۡ فِي ٱلسَّرۡدِ﴾</span>: أي: قَدِّرْ في نَسْجِ الدُّرُوعِ وإحْكامِها تَقْدِيرًا مُناسِبًا يَجْمَعُ ما بَينَ الخِفَّةِ والحَصانَةِ.</p></div>"
  34,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غُدُوُّهَا شَهۡرࣱ﴾</span>: أي: تَجْرِي الرِّيحُ مِن أوَّلِ النَّهارِ إلى انْتِصافِه مَسِيرَةَ شَهْرٍ بالسَّيرِ المُعْتادِ.</p><p><span class="qpc-hafs">﴿وَرَوَاحُهَا شَهۡرࣱ﴾</span>: أي: تَجْرِي الرِّيحُ مِن مُّنْتَصَفِ النَّهارِ إلى اللَّيلِ مَسِيرَةَ شَهْرٍ.</p><p><span class="qpc-hafs">﴿وَأَسَلۡنَا لَهُۥ عَيۡنَ ٱلۡقِطۡرِ﴾</span>: وأَسَلْنا لَهُ عَينَ النُّحاسِ كما يَسِيلُ الماءُ.</p><p><span class="qpc-hafs">﴿مَن يَزِغۡ﴾</span>: مَن يَمِلْ ويَعدِلْ.</p><p><span class="qpc-hafs">﴿ٱلسَّعِيرِ﴾</span>: النّارِ المسْتَعِرةِ.</p></div>"
  34,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّحَـٰرِيبَ﴾</span>: قُصُورٍ أو مساجِدَ.</p><p><span class="qpc-hafs">﴿وَتَمَـٰثِيلَ﴾</span>: صُوَرٍ مُجَسَّمَةٍ من نُّحاسٍ وزُجاجٍ وغيرِهِما (وحُرِّمَ ذلك في الإسْلامِ).</p><p><span class="qpc-hafs">﴿وَجِفَانࣲ﴾</span>: جَمْعُ «جَفْنَةٍ»، وهي القَصْعةُ الكَبِيرةُ.</p><p><span class="qpc-hafs">﴿كَٱلۡجَوَابِ﴾</span>: جَمْعِ «جابِيَةٍ»، وهي الحوضُ الكبيرُ الذي يُجْمعُ فيه الماءُ.</p><p><span class="qpc-hafs">﴿رَّاسِيَـٰتٍ﴾</span>: ثابتاتٍ على المواقِد، لا تَتَحَرَّكُ لِعِظَمِها.</p></div>"
  34,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَضَيۡنَا﴾</span>: حَكَمْنا.</p><p><span class="qpc-hafs">﴿دَآبَّةُ ٱلۡأَرۡضِ﴾</span>: الأَرَضَةُ الَّتي تَأْكُلُ الخَشَبَ.</p><p><span class="qpc-hafs">﴿مِنسَأَتَهُۥ﴾</span>: عَصاهُ.</p><p><span class="qpc-hafs">﴿خَرَّ﴾</span>: سَقَطَ ووَقَعَ.</p><p><span class="qpc-hafs">﴿تَبَيَّنَتِ﴾</span>: عَلِمَتْ.</p><p><span class="qpc-hafs">﴿مَا لَبِثُواْ﴾</span>: ما أقامُوا.</p><p><span class="qpc-hafs">﴿ٱلۡمُهِينِ﴾</span>: المُذِلِّ.</p></div>"
  34,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِسَبَإࣲ﴾</span>: «سبأ» بَلَدٌ باليمنِ سُمِّيَ باسم «سبأ بن يَشْجُب»، ويقعُ شرقَ صنعاء، ويُسَمّى الآنَ «مأرِبًا».</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: دَلالةٌ على قُدْرَتِنا.</p><p><span class="qpc-hafs">﴿جَنَّتَانِ عَن يَمِينࣲ وَشِمَالࣲ﴾</span>: مَجْمُوعَتانِ كَبِيرَتانِ مِنَ البساتِينِ الكثيرةِ عَن يَمِينِ الوادِي وشِمالِه.</p><p><span class="qpc-hafs">﴿طَيِّبَةࣱ﴾</span>: كريمةُ التُّربةِ حَسَنةُ الهواءِ.</p></div>"
  34,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيۡلَ ٱلۡعَرِمِ﴾</span>: السَّيلَ الجارِفَ الشَّدِيدَ.</p><p><span class="qpc-hafs">﴿خَمۡطࣲ﴾</span>: هو الثَّمرُ المُرُّ الكريهُ الطَّعْمِ والرائِحَةِ.</p><p><span class="qpc-hafs">﴿أَثۡلࣲ﴾</span>: هو شَجَرٌ شَبِيهٌ بالطَّرْفاءِ لا ثَمَرَ لَهُ.</p><p><span class="qpc-hafs">﴿سِدۡرࣲ﴾</span>: هو شجرُ النَّبْقِ كثِيرُ الشَّوكِ.</p></div>"
  34,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُجَـٰزِيٓ﴾</span>: نُعاقِبُ.</p><p><span class="qpc-hafs">﴿ٱلۡكَفُورَ﴾</span>: الجَحودَ المبالِغَ في الكُفْرِ بِنِعَمِ اللهِ ورُسُلِه.</p></div>"
  34,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيۡنَهُمۡ﴾</span>: أي: بينَ أهلِ «سبأٍ» الَّذينَ كانُوا باليمنِ.</p><p><span class="qpc-hafs">﴿ٱلۡقُرَى ٱلَّتِي بَـٰرَكۡنَا فِيهَا﴾</span>: هي بلادُ «الشّامِ».</p><p><span class="qpc-hafs">﴿قُرࣰى ظَـٰهِرَةࣰ﴾</span>: قُرىً مُتَواصِلةً مُتَقارِبة يُرى بَعْضُها مِن بَعْضٍ (على امْتِداد الطَّرِيقِ مِنَ اليمنِ إلى الشّامِ).</p><p><span class="qpc-hafs">﴿قَدَّرۡنَا فِيهَا ٱلسَّيۡرَ﴾</span>: أي: جَعَلْنا مَسافَةَ السَّيرِ بَيْنَ القُرى مَسافَةً متقارِبةً نَحْوًا مِن نِّصفِ يومٍ ليكونَ المَقِيلُ في قَرْيَةٍ والمبيتُ في أُخْرى.</p><p><span class="qpc-hafs">﴿ءَامِنِينَ﴾</span>: لا تخافُونَ عَدُوًّا ولا جُوعًا ولا عَطَشًا.</p></div>"
  34,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَـٰعِدۡ بَيۡنَ أَسۡفَارِنَا﴾</span>: أي: اجْعَلْ هذه القُرى المُتَقارِبةَ مُتَباعِدةً لِيَبْعُدَ سَفَرُنا بَينَها.</p><p><span class="qpc-hafs">﴿أَحَادِيثَ﴾</span>: أي: ذوي أخبارٍ يتحدّثُ الناسُ بها في مجالِسِهِم للتَّعَجُّبِ والاعْتِبارِ.</p><p><span class="qpc-hafs">﴿وَمَزَّقۡنَـٰهُمۡ﴾</span>: فَرَّقْناهُم في البلادِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَعِبرًا وعِظاتٍ.</p></div>"
  34,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَدَّقَ عَلَيۡهِمۡ﴾</span>: حقَّقَ عَلَيهِم.</p><p><span class="qpc-hafs">﴿ظَنَّهُۥ﴾</span>: بأنّهم يَتَّبِعُونَه.</p></div>"
  34,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: تَسَلُّطٍ واسْتِيلاءٍ بالوسْوَسَةِ والإغْواءِ.</p></div>"
  34,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَعَمۡتُم مِّن دُونِ ٱللَّهِ﴾</span>: أي: زَعَمْتُمُوهُم شركاءَ للهِ.</p><p><span class="qpc-hafs">﴿مِثۡقَالَ ذَرَّةࣲ﴾</span>: مِقْدارَ أصْغَرِ نَمْلَةٍ.</p><p><span class="qpc-hafs">﴿شِرۡكࣲ﴾</span>: مُشارَكَةٍ.</p><p><span class="qpc-hafs">﴿ظَهِيرࣲ﴾</span>: مُعِينٍ على الخَلْقِ والتَّدبيرِ.</p></div>"
  34,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُزِّعَ عَن قُلُوبِهِمۡ﴾</span>: أُزيِلَ الفَزَعُ والخوفُ عَن قُلُوبِهِم.</p></div>"
  34,24,""
  34,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجۡرَمۡنَا﴾</span>: اكْتَسَبْنا مِنَ الذُّنُوبِ.</p></div>"
  34,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡتَحُ بَيۡنَنَا﴾</span>: يَقْضِي ويَحْكُمُ بَيْنَنا.</p><p><span class="qpc-hafs">﴿ٱلۡفَتَّاحُ﴾</span>: الحاكِمُ بَينَ خَلْقِهِ.</p></div>"
  34,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرُونِيَ﴾</span>: أي: بالحُجَّةِ والدَّليلِ.</p></div>"
  34,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَآفَّةࣰ لِّلنَّاسِ﴾</span>: للنّاسِ أجْمَعِينَ.</p></div>"
  34,29,""
  34,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّيعَادُ يَوۡمࣲ﴾</span>: هو يومُ القيامةِ.</p><p><span class="qpc-hafs">﴿لَّا تَسۡتَـٔۡخِرُونَ عَنۡهُ﴾</span>: لا تتأخَّرُونَ عَنْهُ.</p><p><span class="qpc-hafs">﴿لَا تَسۡتَقۡدِمُونَ﴾</span>: لا تَتَقَدَّمُونَ عَلَيه.</p></div>"
  34,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا بِٱلَّذِي بَيۡنَ يَدَيۡهِ﴾</span>: ولا بالَّذي تَقَدَّمَهُ مِنَ الكُتُبِ السَّماوِيَّةِ كالتَّوراةِ والإنْجِيلِ والزَّبُورِ.</p><p><span class="qpc-hafs">﴿مَوۡقُوفُونَ﴾</span>: محبوسُونَ في مَوْقِفِ الحِسابِ.</p><p><span class="qpc-hafs">﴿يَرۡجِعُ بَعۡضُهُمۡ إِلَىٰ بَعۡضٍ ٱلۡقَوۡلَ﴾</span>: يتراجعُون الكلام باللَّومِ والعِتابِ فيما بَينَهُم.</p></div>"
  34,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱسۡتَكۡبَرُواْ﴾</span>: هم القادَةُ والرُّؤساءُ الضّالُّون المُضِلُّونَ.</p><p><span class="qpc-hafs">﴿صَدَدۡنَـٰكُمۡ﴾</span>: مَنَعْناكُم.</p><p><span class="qpc-hafs">﴿بَلۡ كُنتُم مُّجۡرِمِينَ﴾</span>: بَلْ كُنْتُم اخْتَرْتُم سَبِيلَ الإجْرامِ لِمَحْضِ إرادَتِكُم.</p></div>"
  34,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلۡ مَكۡرُ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: بَلْ صَدَّنا مَكْرُكُم بِنا وتَدْبِيرُكُم الشَّرَّ لَنا في اللَّيلِ والنَّهارِ.</p><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: أمْثالًا وشُرَكاءَ مِن مَّخْلُوقاتِه.</p><p><span class="qpc-hafs">﴿أَسَرُّواْ ٱلنَّدَامَةَ﴾</span>: أي: أضْمَرَ وأَخْفى الفَرِيقانِ الحسْرةَ والنَّدامةَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَغۡلَـٰلَ﴾</span>: الأطْواقَ.</p><p><span class="qpc-hafs">﴿يُجۡزَوۡنَ﴾</span>: يُعاقَبونَ.</p></div>"
  34,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن نَّذِيرٍ﴾</span>: مِن رَّسولٍ.</p><p><span class="qpc-hafs">﴿مُتۡرَفُوهَآ﴾</span>: مُتَنَعِّمُوها.</p><p><span class="qpc-hafs">﴿كَـٰفِرُونَ﴾</span>: جاحِدُون، مُنْكِرُونَ.</p></div>"
  34,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُعَذَّبِينَ﴾</span>: أي: في الدُّنيا ولا في الآخرةِ.</p></div>"
  34,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡسُطُ﴾</span>: يُوَسِّعُ.</p><p><span class="qpc-hafs">﴿يَقۡدِرُ﴾</span>: يُضَيِّقُ.</p></div>"
  34,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُلۡفَىٰٓ﴾</span>: قُرْبى.</p><p><span class="qpc-hafs">﴿لَهُمۡ جَزَآءُ ٱلضِّعۡفِ﴾</span>: لهم الثَّوابُ المُضاعَفُ.</p><p><span class="qpc-hafs">﴿ٱلۡغُرُفَـٰتِ﴾</span>: المنازلِ العالِيةِ في الجنّةِ.</p><p><span class="qpc-hafs">﴿ءَامِنُونَ﴾</span>: أي: مِن جَمِيعِ ما يكْرَهُونَ كالعذابِ والموتِ والأحْزانِ.</p></div>"
  34,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعَـٰجِزِينَ﴾</span>: ظانّينَ أنّهُم يُعْجِزُونَنا ويَغلِبُونَنا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡعَذَابِ مُحۡضَرُونَ﴾</span>: مُقيمُونَ فيه تُحضِرُهم الزَّبانيةُ، فَلا يَسْتَطِيعُونَ الخُرُوجَ منه.</p></div>"
  34,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡسُطُ﴾</span>: يُوَسِّعُ.</p><p><span class="qpc-hafs">﴿يَقۡدِرُ﴾</span>: يُضَيِّقُ.</p><p><span class="qpc-hafs">﴿يُخۡلِفُهُۥ﴾</span>: يُعَوِّضُه لكم في الدُّنيا وفي الآخِرةِ.</p></div>"
  34,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَحۡشُرُهُمۡ﴾</span>: يَجْمَعُهُم.</p></div>"
  34,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَكَ﴾</span>: نُنَزِّهُكَ يا اللهُ.</p><p><span class="qpc-hafs">﴿أَنتَ وَلِيُّنَا﴾</span>: أنتَ الَّذي نُوالِيهِ ونَعْبُدُهُ.</p><p><span class="qpc-hafs">﴿ٱلۡجِنَّ﴾</span>: أي: الشَّياطِينَ.</p></div>"
  34,42,""
  34,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَصُدَّكُمۡ﴾</span>: أن يَمْنَعَكُم.</p><p><span class="qpc-hafs">﴿إِفۡكࣱ مُّفۡتَرࣰى﴾</span>: كَذِبٌ مُخْتَلَقٌ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: واضِحٌ.</p></div>"
  34,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَدۡرُسُونَهَا﴾</span>: يَقْرَؤُونَها ويَفْهَمُونَها.</p><p><span class="qpc-hafs">﴿مِن نَّذِيرࣲ﴾</span>: مِن رَّسولٍ.</p></div>"
  34,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَّبَ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾</span>: أي: مِنَ الأُمَمِ الماضيةِ كَعادٍ وثمُودَ.</p><p><span class="qpc-hafs">﴿وَمَا بَلَغُواْ﴾</span>: وما بلَغَ أهلُ مَكَّةَ.</p><p><span class="qpc-hafs">﴿مِعۡشَارَ مَآ ءَاتَيۡنَـٰهُمۡ﴾</span>: عُشْرَ ما أعْطَيناهُم مِنَ النِّعَمِ.</p><p><span class="qpc-hafs">﴿نَكِيرِ﴾</span>: إنْكارِي عليهم بالعِقابِ والعَذابِ.</p></div>"
  34,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعِظُكُم بِوَ ٰ⁠حِدَةٍ﴾</span>: أنْصَحُكُم وأُوصِيكُم بِخَصْلَةٍ واحِدَةٍ.</p><p><span class="qpc-hafs">﴿أَن تَقُومُواْ لِلَّهِ﴾</span>: أن تَجْتَهِدُوا بالقِيامِ لهذا الأَمْرِ، مُخْلِصِينَ للهِ مِن غَيرِ هَوىً ولا عَصَبِيَّةٍ.</p><p><span class="qpc-hafs">﴿مِّن جِنَّةٍ﴾</span>: مِن جُنُونٍ.</p></div>"
  34,47,""
  34,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقۡذِفُ بِٱلۡحَقِّ﴾</span>: يَرْمِي الباطِلَ بالحقِّ فيَدْمَغُه.</p></div>"
  34,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: القرآنُ.</p><p><span class="qpc-hafs">﴿وَمَا يُبۡدِئُ ٱلۡبَـٰطِلُ وَمَا يُعِيدُ﴾</span>: أي: ذَهَبَ واضْمَحَلَّ، ولم يَبْقَ مِنهُ إقْبالٌ ولا إدْبارٌ.</p></div>"
  34,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَلۡتُ﴾</span>: أي: عَنِ الصِّراطِ المُسْتَقِيمِ.</p></div>"
  34,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذۡ فَزِعُواْ﴾</span>: خافُوا عِنْدَ مُعايَنَتِهِم العَذابَ.</p><p><span class="qpc-hafs">﴿فَلَا فَوۡتَ﴾</span>: أي: لا يفُوتُنِي أحَدٌ مِنهُم فَيَهْرُبَ.</p><p><span class="qpc-hafs">﴿مَّكَانࣲ قَرِيبࣲ﴾</span>: مَوْضِعٍ قَرِيبٍ، فهُم لا يَبْعُدُونَ عَنِ اللهِ حيثُ كانُوا.</p></div>"
  34,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّىٰ لَهُمُ ٱلتَّنَاوُشُ مِن مَّكَانِۭ بَعِيدࣲ﴾</span>: وكَيْفَ لَهُمْ أن يَتَناوَلُوا الإيمانَ في الآخِرةِ وقَدْ تَرَكُوه في الدُّنيا؟</p></div>"
  34,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَقۡذِفُونَ بِٱلۡغَيۡبِ مِن مَّكَانِۭ بَعِيدࣲ﴾</span>: يَرْمُونَ مِن مَّكانٍ بَعِيدٍ وهُمْ لا يَرَوْنَ.</p></div>"
  34,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحِيلَ﴾</span>: وحُجِزَ ومُنِعَ.</p><p><span class="qpc-hafs">﴿مَا يَشۡتَهُونَ﴾</span>: أي: مِنَ التَّوبَةِ والعوْدَةِ إلى الدُّنيا.</p><p><span class="qpc-hafs">﴿بِأَشۡيَاعِهِم﴾</span>: بأمثالِهِم مِنَ الكُفّارِ.</p><p><span class="qpc-hafs">﴿مُّرِيبِۭ﴾</span>: مُوقِعٍ في الرِّيبةِ.</p></div>"
