quran[52]{c,v,t}:
  14,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِإِذۡنِ رَبِّهِمۡ﴾</span>: بأَمْرِه وتيسيرِه وتوفيقِه.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طِ﴾</span>: طريقِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزِ﴾</span>: الغالبِ الذي لا يَقْدِرُ عليه أحدٌ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيدِ﴾</span>: المَحْمودِ في كلِّ حالٍ، المُثْنى عليه من نفسِه ومن عبادِه.</p></div>"
  14,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوَيۡلࣱ﴾</span>: هَلاكٌ ووَعيدٌ.</p></div>"
  14,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَحِبُّونَ﴾</span>: يختارون.</p><p><span class="qpc-hafs">﴿وَيَبۡغُونَهَا عِوَجًا﴾</span>: ويُريدُون أن تكونَ سبيلُ اللهِ مائلةً وفْقَ أهوائِهم.</p></div>"
  14,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَهۡدِي﴾</span>: يُوَفِّقُ مَن يشاءُ إلى الهدى.</p></div>"
  14,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بالمعجِزاتِ الدالَّةِ على صِدْقِه.</p><p><span class="qpc-hafs">﴿بِأَيَّىٰمِ ٱللَّهِ﴾</span>: بنِعَمِه وبَلاياه التي وقعَتْ على الأممِ السابقةِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: دلالاتٍ وعِبَرًا.</p><p><span class="qpc-hafs">﴿صَبَّارࣲ﴾</span>: كثيرِ الصبرِ على الطاعاتِ والبلاءِ.</p><p><span class="qpc-hafs">﴿شَكُورࣲ﴾</span>: كثيرِ الشُّكرِ على نِعَمِ اللهِ، قائمٍ بحقوقِه.</p></div>"
  14,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسُومُونَكُمۡ﴾</span>: يُذِيقُونكم.</p><p><span class="qpc-hafs">﴿وَيَسۡتَحۡيُونَ نِسَآءَكُمۡ﴾</span>: يَسْتَبْقُونَهنَّ أحياءً؛ للخِدْمةِ والامتِهان.</p><p><span class="qpc-hafs">﴿بَلَآءࣱ﴾</span>: اختبارٌ لكم بالنِّعَمِ والفِتَن.</p></div>"
  14,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَأَذَّنَ رَبُّكُمۡ﴾</span>: أعْلَمَ إعلامًا مُؤَكَّدًا.</p></div>"
  14,8,""
  14,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالبراهينِ الواضحاتِ على صِدْقِهم.</p><p><span class="qpc-hafs">﴿فَرَدُّوٓاْ أَيۡدِيَهُمۡ فِيٓ أَفۡوَ ٰ⁠هِهِمۡ﴾</span>: عَضَّتِ الأممُ على أيديها؛ غيظًا واستكبارًا عن الإيمانِ.</p><p><span class="qpc-hafs">﴿مُرِيبࣲ﴾</span>: مُوقعٍ في القَلَقِ وعَدَمِ الاطمئنانِ.</p></div>"
  14,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاطِرِ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: خالِقِهما ومُبْدِعِهما.</p><p><span class="qpc-hafs">﴿إِلَىٰٓ أَجَلࣲ مُّسَمࣰّى﴾</span>: مُدَّةِ بقائِكم في الدنيا، فلا يُعَذِّبكُم فيها.</p><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنࣲ مُّبِينࣲ﴾</span>: حُجَّةٍ ظاهرةٍ تَشْهَدُ على صِدْقِكم.</p></div>"
  14,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَمُنُّ عَلَىٰ مَن يَشَآءُ﴾</span>: يَتَفَضَّلُ عليه فيَصْطَفِيه للرِّسالةِ.</p><p><span class="qpc-hafs">﴿بِإِذۡنِ ٱللَّهِ﴾</span>: بأمْرِه ومشيئتِه.</p><p><span class="qpc-hafs">﴿وَعَلَى ٱللَّهِ فَلۡيَتَوَكَّلِ﴾</span>: فلْيَعْتَمِدْ عليه، ولْيُفَوِّضْ أمرَه إليه.</p></div>"
  14,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَدَىٰنَا سُبُلَنَا﴾</span>: أرْشَدَنا إلى طريقِ النَّجاة، ووَفَّقنا إلى اتِّباعِ شَرْعِه.</p></div>"
  14,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِلَّتِنَا﴾</span>: دينِنا.</p></div>"
  14,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضَ مِنۢ بَعۡدِهِمۡ﴾</span>: أي: أرضَ الكافرين وديارَهم مِن بَعْدِ إهلاكِهم.</p><p><span class="qpc-hafs">﴿مَقَامِي﴾</span>: مَوْقِفَه بين يَدَي اللهِ للحسابِ، أو: قيامي عليه ومراقبتي له.</p></div>"
  14,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱسۡتَفۡتَحُواْ﴾</span>: سألَ الرُّسلُ ربَّهم النصرَ على أعدائِهم، أو طَلَبُوا منه الحُكْمَ بينهَم.</p><p><span class="qpc-hafs">﴿وَخَابَ﴾</span>: خَسِرَ وهَلَكَ.</p><p><span class="qpc-hafs">﴿جَبَّارٍ﴾</span>: مُتَعاظِمٍ في نفسِه، مُتَكَبِّرٍ على غيرِه وعن الحقِّ.</p><p><span class="qpc-hafs">﴿عَنِيدࣲ﴾</span>: معاندٍ للحقِّ، مائلٍ عنه لا يَقْبَلُه.</p></div>"
  14,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن وَرَآئِهِۦ جَهَنَّمُ﴾</span>: أمامَ هذا الكافرِ ما أعَدَّ اللهُ من العذابِ في النار.</p><p><span class="qpc-hafs">﴿صَدِيدࣲ﴾</span>: ما يَسِيلُ من أجسادِ أهلِ النّارِ.</p></div>"
  14,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَجَرَّعُهُۥ﴾</span>: يَتَكلَّفُ ابتلاعَه مرَّة بعدَ مرَّةٍ؛ لحرارتهِ مع غَلَبَةِ العَطَشِ عليه.</p><p><span class="qpc-hafs">﴿وَلَا يَكَادُ يُسِيغُهُۥ﴾</span>: لا يَسْتطيعُ ابتلاعَه بسهولةٍ، بل يَشْرَبُه بعد عَناءٍ، فيُقَطِّعُ أمعاءَه.</p><p><span class="qpc-hafs">﴿وَمِن وَرَآئِهِۦ﴾</span>: وله بعدَ هذا العذابِ.</p><p><span class="qpc-hafs">﴿غَلِيظࣱ﴾</span>: شديدٌ مؤلمٌ.</p></div>"
  14,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّثَلُ ٱلَّذِينَ كَفَرُواْ﴾</span>: صفةُ أعمالِ الكفارِ في الدنيا وبُطْلانِها عندَ اللهِ بسببِ كُفْرِهم.</p><p><span class="qpc-hafs">﴿عَاصِفࣲ﴾</span>: شديدِ الريحِ.</p><p><span class="qpc-hafs">﴿لَّا يَقۡدِرُونَ مِمَّا كَسَبُواْ عَلَىٰ شَيۡءࣲ﴾</span>: لا يَجِدُون من أعمال البِرِّ ما يَنْفعُهم في الآخرةِ.</p></div>"
  14,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: على الوجهِ الصحيحِ الدّالِّ على حكمتِه، وكمالِ قدرتِه.</p></div>"
  14,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِعَزِيزࣲ﴾</span>: بممتنعٍ أو متعسِّرٍ.</p></div>"
  14,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَرَزُواْ﴾</span>: خَرَجَ الخلائقُ من قبورِهم؛ للحسابِ.</p><p><span class="qpc-hafs">﴿ٱلضُّعَفَـٰٓؤُاْ﴾</span>: ضعفاءُ الرأيِ، وهم الأتباعُ.</p><p><span class="qpc-hafs">﴿لِلَّذِينَ ٱسۡتَكۡبَرُوٓاْ﴾</span>: وهم القادةُ والرؤساءُ.</p><p><span class="qpc-hafs">﴿تَبَعࣰا﴾</span>: أتباعًا.</p><p><span class="qpc-hafs">﴿لَوۡ هَدَىٰنَا ٱللَّهُ﴾</span>: لو وفَّقَنا إلى الإيمانِ.</p><p><span class="qpc-hafs">﴿لَهَدَيۡنَـٰكُمۡ﴾</span>: لَأَرشَدْناكم إليه.</p><p><span class="qpc-hafs">﴿سَوَآءٌ عَلَيۡنَآ أَجَزِعۡنَآ﴾</span>: يَسْتَوي ضَعْفُنا عن تَحمُّلِ ما نَزَلَ بنا جميعًا من العذابِ.</p><p><span class="qpc-hafs">﴿مَّحِيصࣲ﴾</span>: مَهْرَبٍ ومَنجى.</p></div>"
  14,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُضِيَ﴾</span>: أُحكِمَ، وفُرِغَ منه، وهو الحِسابُ، ودخولُ السُّعداءِ الجنةَ، والأشقياءِ النارَ.</p><p><span class="qpc-hafs">﴿وَعۡدَ ٱلۡحَقِّ﴾</span>: بالبعثِ والجزاءِ.</p><p><span class="qpc-hafs">﴿وَوَعَدتُّكُمۡ﴾</span>: وعْدًا باطلًا بعَدَمَ البعثِ والجَزاءِ.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: تَسَلُّطٍ وإجبارٍ، أو حُجَّةٍ.</p><p><span class="qpc-hafs">﴿بِمُصۡرِخِكُمۡ﴾</span>: بمُغِيثِكم مما أنتم فيه من العذابِ.</p><p><span class="qpc-hafs">﴿بِمُصۡرِخِيَّ﴾</span>: بمُغِيثِيَّ مما أنا فيه منه.</p><p><span class="qpc-hafs">﴿بِمَآ أَشۡرَكۡتُمُونِ﴾</span>: بإشراكِكم إياي مع الله في العبادةِ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: في الدنيا.</p></div>"
  14,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: من تحتِ أشجارِ الجِنانِ وقُصورِها.</p><p><span class="qpc-hafs">﴿بِإِذۡنِ رَبِّهِمۡ﴾</span>: بأمرِه وتوفيقِه وفَضْلِه.</p><p><span class="qpc-hafs">﴿تَحِيَّتُهُمۡ فِيهَا﴾</span>: من اللهِ والملائكةِ، ويُحيِّي بعضُهم بعضًا.</p></div>"
  14,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلِمَةࣰ طَيِّبَةࣰ﴾</span>: كلمةَ التوحيدِ: لا إلهَ إلا اللهُ.</p><p><span class="qpc-hafs">﴿كَشَجَرَةࣲ طَيِّبَةٍ﴾</span>: كشَجَرَةٍ طيبةِ المنظرِ والثَّمَرِ، وهي النَّخْلَةُ.</p><p><span class="qpc-hafs">﴿ثَابِتࣱ﴾</span>: متمكِّنٌ بعروقِه في الأرضِ.</p><p><span class="qpc-hafs">﴿وَفَرۡعُهَا فِي ٱلسَّمَآءِ﴾</span>: وأعلاها مرتفِعٌ جهةَ العلوِّ.</p></div>"
  14,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُؤۡتِيٓ أُكُلَهَا﴾</span>: تُعطي ثمارَها.</p><p><span class="qpc-hafs">﴿كُلَّ حِينِۭ بِإِذۡنِ رَبِّهَا﴾</span>: كلَّ وقتٍ وقَّته اللهُ لإثْمارِها.</p></div>"
  14,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلِمَةٍ خَبِيثَةࣲ﴾</span>: هي كلمةُ الكفرِ.</p><p><span class="qpc-hafs">﴿كَشَجَرَةٍ خَبِيثَةٍ﴾</span>: كشجرةٍ رديئةٍ فاسدةٍ في الرائحةِ والطَّعْمِ والمأكلِ، وهي شجرةُ الحَنْظَلِ.</p><p><span class="qpc-hafs">﴿ٱجۡتُثَّتۡ﴾</span>: اقتُلِعَتْ من أصلِها.</p><p><span class="qpc-hafs">﴿قَرَارࣲ﴾</span>: استقرارٍ وثباتٍ.</p></div>"
  14,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلثَّابِتِ﴾</span>: الراسخِ الواضحِ، وهو كلمةُ الشهادتين.</p><p><span class="qpc-hafs">﴿وَفِي ٱلۡـَٔاخِرَةِ﴾</span>: في القبرِ عندَ سؤالِ المَلَكَين.</p></div>"
  14,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدَّلُواْ نِعۡمَتَ ٱللَّهِ كُفۡرࣰا﴾</span>: اختارُوا الكفرَ بدلًا عن شُكْرِ نعمتِه.</p><p><span class="qpc-hafs">﴿وَأَحَلُّواْ﴾</span>: أنْزَلُوا.</p><p><span class="qpc-hafs">﴿دَارَ ٱلۡبَوَارِ﴾</span>: دارَ الهَلاك، وهي جهنمُ.</p></div>"
  14,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡلَوۡنَهَا﴾</span>: يَدْخُلُونها ويُقاسُون حَرَّها.</p><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡقَرَارُ﴾</span>: ساء المستقَرُّ مُسْتَقَرُّهم.</p></div>"
  14,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: شركاءَ ونُظَراءَ مع اللهِ في عبادتِه.</p><p><span class="qpc-hafs">﴿تَمَتَّعُواْ﴾</span>: استمتِعُوا بالعيشِ في الحياةِ الدنيا.</p></div>"
  14,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا بَيۡعࣱ فِيهِ﴾</span>: لا فِداءٌ فيه، بأن يبيعَ المرءُ ما يَفْدِي به نفسَه.</p><p><span class="qpc-hafs">﴿وَلَا خِلَـٰلٌ﴾</span>: ولا صَداقَةٌ ولا مُوادَّةٌ تنفَعُ.</p></div>"
  14,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسَخَّرَ لَكُمُ﴾</span>: ذَلَّلَ لمنافِعِكم.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p></div>"
  14,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَآئِبَيۡنِ﴾</span>: دائمَيْن في حركتِهما، ومنافِعِهما لكم.</p></div>"
  14,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعۡمَتَ ٱللَّهِ﴾</span>: نِعَمَه عليكم.</p><p><span class="qpc-hafs">﴿لَا تُحۡصُوهَآ﴾</span>: لا تُطِيقوا حَصْرَها ولا القيامَ بشُكْرها؛ لكثرتِها وتنوُّعِها.</p><p><span class="qpc-hafs">﴿كَفَّارࣱ﴾</span>: كثيرُ الجُحودِ لنِعَمِ رَبِّه.</p></div>"
  14,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا ٱلۡبَلَدَ﴾</span>: أي: مكةَ.</p><p><span class="qpc-hafs">﴿وَٱجۡنُبۡنِي﴾</span>: أبْعِدْني.</p></div>"
  14,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَن تَبِعَنِي﴾</span>: اقتدى بي في التوحيدِ.</p><p><span class="qpc-hafs">﴿فَإِنَّهُۥ مِنِّي﴾</span>: فهو على ديني وسُنَّتي.</p></div>"
  14,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُحَرَّمِ﴾</span>: الذي يَحْرُمُ عندَه ما لا يَحْرُمُ في غيرِه.</p><p><span class="qpc-hafs">﴿تَهۡوِيٓ إِلَيۡهِمۡ﴾</span>: تَحِنُّ وتُسْرِعُ إليهم شوقًا وحُبًّا.</p></div>"
  14,38,""
  14,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَبَ لِي﴾</span>: أعطاني ورزقني.</p></div>"
  14,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُقِيمَ ٱلصَّلَوٰةِ﴾</span>: مُحافِظًا عليها، مُداومًا على أدائِها على أتمِّ أحوالِها.</p><p><span class="qpc-hafs">﴿وَتَقَبَّلۡ دُعَآءِ﴾</span>: تقبَّلْ عبادتي، واستجِبْ دعائي.</p></div>"
  14,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِوَ ٰ⁠لِدَيَّ﴾</span>: دعا لوالدِه بالمغفرةِ قبلَ أنْ يَتبيَّنَ له عداوتُه للهِ.</p></div>"
  14,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَشۡخَصُ فِيهِ ٱلۡأَبۡصَـٰرُ﴾</span>: تَرْتَفِعُ فيه عيونُ أهلِ الموقفِ، فتبقى مفتوحةً لا تتحَّركُ؛ مِن هَوْلِ ما يَرَوْنه.</p></div>"
  14,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُهۡطِعِينَ﴾</span>: مُسْرِعين إلى إجابةِ الداعي للحسابِ.</p><p><span class="qpc-hafs">﴿مُقۡنِعِي رُءُوسِهِمۡ﴾</span>: رافِعيها من شدَّةِ الخوفِ.</p><p><span class="qpc-hafs">﴿لَا يَرۡتَدُّ إِلَيۡهِمۡ طَرۡفُهُمۡ﴾</span>: لا تَرْجِعُ إليهم أجْفانُهم، بل تبقى عيونُهم مفتوحةً على حالِها.</p><p><span class="qpc-hafs">﴿وَأَفۡـِٔدَتُهُمۡ هَوَآءࣱ﴾</span>: وقلوبُهم خاليةٌ لا تَعي شيئًا؛ من هَوْلِ ما تَرى، وشدَّةِ الدَّهْشةِ.</p></div>"
  14,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنذِرِ﴾</span>: خَوِّف أيُّها الرسولُ.</p><p><span class="qpc-hafs">﴿يَأۡتِيهِمُ ٱلۡعَذَابُ﴾</span>: أي: عذابُ اللهِ يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿أَجَلࣲ قَرِيبࣲ﴾</span>: وقتٍ غيرِ بعيدٍ.</p><p><span class="qpc-hafs">﴿مَا لَكُم مِّن زَوَالࣲ﴾</span>: لا زوالَ لكم عن الحياةِ الدُّنيا إلى الآخرةِ.</p></div>"
  14,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَبَيَّنَ لَكُمۡ كَيۡفَ فَعَلۡنَا بِهِمۡ﴾</span>: وعَلِمْتُم بما تشاهدُونه في منازلِهم، وبما أُخْبِرْتُم، ما أنزَلْناه بهم من أنواعِ العقوباتِ.</p></div>"
  14,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعِندَ ٱللَّهِ مَكۡرُهُمۡ﴾</span>: عِلْمُه وجَزاؤُه.</p><p><span class="qpc-hafs">﴿وَإِن كَانَ مَكۡرُهُمۡ لِتَزُولَ مِنۡهُ ٱلۡجِبَالُ﴾</span>: وما كان تدبيرُهم -وإن عَظُمَ- مُعَدًّا لإزالةِ الجبالِ؛ لضَعْفِه.</p></div>"
  14,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعۡدِهِۦ رُسُلَهُۥٓ﴾</span>: ما وعَدَهم به من النصرِ والتمكينِ، وإهلاكِ أعدائِهم.</p><p><span class="qpc-hafs">﴿عَزِيزࣱ﴾</span>: غالِبٌ لا يمتنعُ عليه شيءٌ.</p></div>"
  14,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَرَزُواْ﴾</span>: خَرَجَ الخَلْقُ من قُبورِهم؛ للحسابِ.</p></div>"
  14,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّقَرَّنِينَ﴾</span>: مُقَيَّدين، أو مَقْرونًا بعضُهم مع بعضٍ.</p><p><span class="qpc-hafs">﴿ٱلۡأَصۡفَادِ﴾</span>: جَمْعُ صَفَدٍ، وهو ما يُوثَقُ به من القُيودِ.</p></div>"
  14,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَرَابِيلُهُم﴾</span>: ثيابُهم، أو قُمْصانُهم.</p><p><span class="qpc-hafs">﴿قَطِرَانࣲ﴾</span>: دُهْنٍ من عُصارةِ بعضِ الأشجارِ، أسودَ كالزِّفْتِ، وهو نَتِنٌ، حارٌّ، شديدُ الاشتعالِ.</p><p><span class="qpc-hafs">﴿وَتَغۡشَىٰ﴾</span>: تَعْلُو وتُحيطُ.</p></div>"
  14,51,""
  14,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: أي: القرآنُ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾</span>: أصحابُ العقولِ السليمةِ.</p></div>"
