quran[8]{c,v,t}:
  102,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلۡهَىٰكُمُ﴾</span>: شَغَلَكُم عَن طاعَةِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلتَّكَاثُرُ﴾</span>: التَّفاخُرُ بِكَثْرةِ الأَمْوالِ والأولادِ.</p></div>"
  102,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَتَّىٰ زُرۡتُمُ ٱلۡمَقَابِرَ﴾</span>: وانْشَغَلتُم بِذَلِكَ إلى أن دُفِنتم في المقابِر.</p></div>"
  102,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ما هَكَذا ينبغي أن يُلْهيَكُم التكاثُرُ بالأَمْوالِ.</p><p><span class="qpc-hafs">﴿سَوۡفَ تَعۡلَمُونَ﴾</span>: أنَّ الدّارَ الآخِرةَ خَيرٌ لَكُم.</p></div>"
  102,4,""
  102,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡيَقِينِ﴾</span>: لو تَعْلَمُونَ حَقَّ العِلْمِ لانْزَجَرْتُم، ولَبادَرْتُم إلى إنقاذِ أنفُسِكُم مِنَ الهَلاكِ.</p></div>"
  102,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَتَرَوُنَّ ٱلۡجَحِيمَ﴾</span>: لَتُبصِرُنَّ الجحِيمَ.</p></div>"
  102,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ لَتَرَوُنَّهَا عَيۡنَ ٱلۡيَقِينِ﴾</span>: ثُمَّ لَتُبْصِرُنَّها دُونَ رَيبٍ.</p></div>"
  102,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَئِذٍ﴾</span>: يومَ القِيامةِ.</p><p><span class="qpc-hafs">﴿عَنِ ٱلنَّعِيمِ﴾</span>: عَن كُلِّ أنَواعِ النَّعِيمِ.</p></div>"
