quran[34]{c,v,t}:
  31,1,""
  31,2,""
  31,3,""
  31,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡتُونَ﴾</span>: يُعْطُونَ.</p><p><span class="qpc-hafs">﴿يُوقِنُونَ﴾</span>: يُؤْمِنُونَ.</p></div>"
  31,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ.</p></div>"
  31,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهۡوَ ٱلۡحَدِيثِ﴾</span>: هُوَ كلُّ ما يُلْهِي عَن طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿بِغَيۡرِ عِلۡمࣲ﴾</span>: جَهْلًا بِعاقِبَةِ ذَلِكَ.</p><p><span class="qpc-hafs">﴿وَيَتَّخِذَهَا﴾</span>: ويَتَّخِذَ سَبيلَ اللهِ وآياتِ كِتابِه.</p><p><span class="qpc-hafs">﴿هُزُوًا﴾</span>: مُسْتهْزَأً بهِا.</p></div>"
  31,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَّىٰ﴾</span>: أعْرَضَ وأَدْبَرَ.</p><p><span class="qpc-hafs">﴿مُسۡتَكۡبِرࣰا﴾</span>: مُتَكبِّرًا.</p><p><span class="qpc-hafs">﴿وَقۡرࣰا﴾</span>: ثِقَلًا أو صَمَمًا فلا يَنْتَفِعُ بِما يَسْمَعُ.</p></div>"
  31,8,""
  31,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقࣰّا﴾</span>: أي: وعْدًا حَقًّا ثابِتًا.</p></div>"
  31,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَمَدࣲ﴾</span>: دَعائِمَ، مُفْرَدُه عِمادٌ.</p><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: أي: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿أَن تَمِيدَ بِكُمۡ﴾</span>: أي: لِئلا تَتَحَرَّكَ الأرْضُ وتَضْطَرِبَ بِكم.</p><p><span class="qpc-hafs">﴿بَثَّ﴾</span>: نَشَر وفَرَّقَ.</p><p><span class="qpc-hafs">﴿زَوۡجࣲ كَرِيمٍ﴾</span>: صِنْفٍ حَسَنٍ كَثِيرِ المَنفَعَةِ.</p></div>"
  31,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينࣲ﴾</span>: عُدُولٍ واضِحٍ عَنِ الطَّرِيقِ المُسْتَقِيمِ.</p></div>"
  31,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لُقۡمَـٰنَ﴾</span>: هو رَجُلٌ صالِحٌ كانَ مِن حُكَماءِ بني إسرْائِيلَ.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: العقلَ والفهمَ وإصابةَ القولِ.</p><p><span class="qpc-hafs">﴿كَفَرَ﴾</span>: أي: جَحَدَ نِعَمَ اللهِ بِعَدَمِ شُكْرِها.</p></div>"
  31,13,""
  31,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَّيۡنَا﴾</span>: أمَرْنا.</p><p><span class="qpc-hafs">﴿وَهۡنًا﴾</span>: ضَعْفًا.</p><p><span class="qpc-hafs">﴿وَفِصَـٰلُهُۥ﴾</span>: فِطامُه عَنِ الرَّضاعَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ.</p></div>"
  31,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَـٰهَدَاكَ﴾</span>: بَذَلا الجُهْدَ وحاوَلا أن يُجْبِراكَ.</p><p><span class="qpc-hafs">﴿وَصَاحِبۡهُمَا﴾</span>: عاشِرْهُما.</p><p><span class="qpc-hafs">﴿أَنَابَ إِلَيَّ﴾</span>: رَجَع إليّ بالإخْلاصِ والتَّوبة.</p><p><span class="qpc-hafs">﴿مَرۡجِعُكُمۡ﴾</span>: مَصِيرُكُم.</p><p><span class="qpc-hafs">﴿فَأُنَبِّئُكُم﴾</span>: فَأُخْبِرُكُم.</p></div>"
  31,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهَآ﴾</span>: أي: السَّيِّئةَ أو الحَسَنَةَ.</p><p><span class="qpc-hafs">﴿مِثۡقَالَ حَبَّةࣲ﴾</span>: وزْنَ حَبَّةٍ.</p><p><span class="qpc-hafs">﴿خَرۡدَلࣲ﴾</span>: وهْوَ أصْغَرُ الحُبُوبِ، والمرادُ أصغرُ شيءٍ.</p><p><span class="qpc-hafs">﴿فِي صَخۡرَةٍ﴾</span>: في باطِنِ جَبَلٍ.</p></div>"
  31,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡمَعۡرُوفِ﴾</span>: المعْرُوفُ كُلُّ فِعْلٍ يُعْرَفُ حُسْنُه بالشَّرْعِ أو العَقْلِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنكَرِ﴾</span>: وهْوَ كُلُّ فِعْلٍ يُنكِرُه الشَّرعُ أوِ العَقْلُ.</p><p><span class="qpc-hafs">﴿مِنۡ عَزۡمِ ٱلۡأُمُورِ﴾</span>: أي: مِنَ الأمُورِ الَّتي يَنْبَغِي العَزْمُ والحِرْصُ عليها.</p></div>"
  31,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُصَعِّرۡ خَدَّكَ﴾</span>: أي: لا تُمِلْه عُجْبًا واسْتِكْبارًا.</p><p><span class="qpc-hafs">﴿مَرَحًا﴾</span>: فَرَحًا وبَطَرًا.</p><p><span class="qpc-hafs">﴿مُخۡتَالࣲ﴾</span>: مُتَكَبِّرٍ.</p><p><span class="qpc-hafs">﴿فَخُورࣲ﴾</span>: مُتَباهٍ بنفسه.</p></div>"
  31,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱقۡصِدۡ فِي مَشۡيِكَ﴾</span>: أي: تَوَسَّطْ فِيه مَعَ تَواضُعٍ وسَكِينَةٍ.</p><p><span class="qpc-hafs">﴿وَٱغۡضُضۡ﴾</span>: واخْفِضْ.</p><p><span class="qpc-hafs">﴿أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ﴾</span>: أي: أقبَحَها.</p></div>"
  31,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَخَّرَ لَكُم﴾</span>: ذَلَّلَ لَكُم.</p><p><span class="qpc-hafs">﴿وَأَسۡبَغَ﴾</span>: عَمَّ وأَتَمَّ.</p><p><span class="qpc-hafs">﴿يُجَـٰدِلُ﴾</span>: يُخاصِمُ.</p><p><span class="qpc-hafs">﴿فِي ٱللَّهِ﴾</span>: أي: في تَوحِيدِه وإخْلاصِ العِبادَةِ لَهُ.</p></div>"
  31,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَذَابِ ٱلسَّعِيرِ﴾</span>: عَذابِ جَهَنَّمَ المُسْتَعِرَةِ.</p></div>"
  31,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُسۡلِمۡ وَجۡهَهُۥٓ إِلَى ٱللَّهِ﴾</span>: يُفوِّضْ إلِيهِ أمْرَهُ ويُخلِصْ لَهُ عِبادَتَه.</p><p><span class="qpc-hafs">﴿مُحۡسِنࣱ﴾</span>: مُطِيعٌ للهِ في أمْرِهِ ونَهْيِهِ.</p><p><span class="qpc-hafs">﴿ٱسۡتَمۡسَكَ﴾</span>: تمسَّكَ واعْتَصَمَ.</p><p><span class="qpc-hafs">﴿بِٱلۡعُرۡوَةِ ٱلۡوُثۡقَىٰ﴾</span>: العَهْدِ الأوْثَقِ والسَّبَبِ الأقْوى.</p><p><span class="qpc-hafs">﴿عَـٰقِبَةُ ٱلۡأُمُورِ﴾</span>: مَرْجِعُها.</p></div>"
  31,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنُنَبِّئُهُم﴾</span>: فَنُخْبِرُهُم.</p></div>"
  31,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَضۡطَرُّهُمۡ﴾</span>: نُلْجِئُهُم ونَسُوقُهُم.</p><p><span class="qpc-hafs">﴿عَذَابٍ غَلِيظࣲ﴾</span>: أي: فَظِيعٍ وثَقِيلٍ، وهُوَ عَذابُ جَهَنَّمَ.</p></div>"
  31,25,""
  31,26,""
  31,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَمُدُّهُۥ﴾</span>: أي: يَزِيدُه، فَيَصِيرُ ما في البِحارِ كلِّها مِدادًا.</p><p><span class="qpc-hafs">﴿مَّا نَفِدَتۡ﴾</span>: ما فَنِيَتْ.</p></div>"
  31,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَنَفۡسࣲ وَ ٰ⁠حِدَةٍ﴾</span>: أي: كَخَلْقِ نَفْسٍ واحِدَةٍ وبَعْثِها.</p></div>"
  31,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُولِجُ﴾</span>: يُدخِلُ.</p><p><span class="qpc-hafs">﴿سَخَّرَ﴾</span>: ذلَّلَ.</p><p><span class="qpc-hafs">﴿مُّسَمࣰّى﴾</span>: مَعْلُومٍ مُحدَّدٍ.</p></div>"
  31,30,""
  31,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p><p><span class="qpc-hafs">﴿لِيُرِيَكُم﴾</span>: ليُظْهِرَ لَكُم.</p><p><span class="qpc-hafs">﴿مِّنۡ ءَايَـٰتِهِۦٓ﴾</span>: أي: مِن آياتِه الدّالَّةِ عَلى قُدْرَتِه.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لدَلالاتٍ.</p><p><span class="qpc-hafs">﴿صَبَّارࣲ شَكُورࣲ﴾</span>: أي: صَبّارٍ عَلى الضَّرّاءِ، وشَكُورٍ عَلى السَّرّاءِ.</p></div>"
  31,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَشِيَهُم﴾</span>: عَلاهُم وغَطّاهُم.</p><p><span class="qpc-hafs">﴿كَٱلظُّلَلِ﴾</span>: أي: كَشَيءٍ يكُونُ ظِلًّا مِثْلِ الِجبالِ والسَّحابِ.</p><p><span class="qpc-hafs">﴿مُّقۡتَصِدࣱ﴾</span>: مُتَوَسِّطٌ في عَمَلِهِ وعِبادَتِه.</p><p><span class="qpc-hafs">﴿يَجۡحَدُ﴾</span>: يُنكِرُ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بحُجَجِنا.</p><p><span class="qpc-hafs">﴿خَتَّارࣲ﴾</span>: غَدّارٍ ناقِضٍ لِلْعهَدِ.</p><p><span class="qpc-hafs">﴿كَفُورࣲ﴾</span>: جَحُودٍ للنِّعَمِ لا يَشْكُرُها.</p></div>"
  31,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱخۡشَوۡاْ يَوۡمࣰا﴾</span>: أي: خافُوه واسْتَعِدُّوا لَهُ.</p><p><span class="qpc-hafs">﴿لَّا يَجۡزِي﴾</span>: لا يُغْنِي.</p><p><span class="qpc-hafs">﴿فَلَا تَغُرَّنَّكُمُ﴾</span>: فلا تَخْدَعَنَّكُم.</p><p><span class="qpc-hafs">﴿ٱلۡغَرُورُ﴾</span>: ما يَغُرُّ ويَخْدَعُ مِن شَيطانٍ وغَيرِهِ.</p></div>"
  31,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَيۡثَ﴾</span>: المَطَرَ.</p><p><span class="qpc-hafs">﴿تَدۡرِي﴾</span>: تَعْلَمُ.</p></div>"
