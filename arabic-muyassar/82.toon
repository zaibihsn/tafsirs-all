quran[19]{c,v,t}:
  82,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنفَطَرَتۡ﴾</span>: انْشَقَّتْ، واخْتَلَّ نِظامُها.</p></div>"
  82,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنتَثَرَتۡ﴾</span>: تَساقَطَتْ.</p></div>"
  82,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُجِّرَتۡ﴾</span>: فَجَّرَ اللهُ بَعْضَها في بَعْضٍ، فَمَلأَ جَمِيعَها.</p></div>"
  82,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُعۡثِرَتۡ﴾</span>: قُلِبتْ بِبَعْثِ مَن كانَ فِيها.</p></div>"
  82,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَفۡسࣱ﴾</span>: كلُّ نَفْسٍ.</p><p><span class="qpc-hafs">﴿مَّا قَدَّمَتۡ وَأَخَّرَتۡ﴾</span>: ما تَقَدَّمَ مِن أعْمالِها وما تَأَخَّرَ.</p></div>"
  82,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡإِنسَـٰنُ﴾</span>: المنْكِرُ لِلْبَعْثِ.</p><p><span class="qpc-hafs">﴿مَا غَرَّكَ بِرَبِّكَ﴾</span>: ما الَّذِي خَدَعَكَ حتّى كَفَرْتَ بِرَبِّكَ؟.</p><p><span class="qpc-hafs">﴿ٱلۡكَرِيمِ﴾</span>: الجَوادِ الكَثِيرِ الخيرِ.</p></div>"
  82,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَوَّىٰكَ﴾</span>: فَجَعَلَكَ قَوِيمًا سَلِيمًا.</p><p><span class="qpc-hafs">﴿فَعَدَلَكَ﴾</span>: فَجَعَلَكَ مُسْتَقِيمَ القامَةِ مُتَناسِبَ الأجْزاءِ.</p></div>"
  82,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا شَآءَ رَكَّبَكَ﴾</span>: رَكَّبكَ التَّرْكِيبَ الَّذِي شاءَهُ.</p></div>"
  82,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: لَيسَ الأمرُ كَما تَقُولُونَ.</p><p><span class="qpc-hafs">﴿بِٱلدِّينِ﴾</span>: بِيومِ الِحسابِ.</p></div>"
  82,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَحَـٰفِظِينَ﴾</span>: لمَلائِكَةً رُقَباءَ.</p></div>"
  82,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِرَامࣰا﴾</span>: على اللهِ.</p><p><span class="qpc-hafs">﴿كَـٰتِبِينَ﴾</span>: لِما وُكِّلُوا بإحْصائِهِ.</p></div>"
  82,12,""
  82,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَبۡرَارَ﴾</span>: القائِمينَ بِحُقُوقِ اللهِ وحُقُوقِ عِبادِهِ.</p><p><span class="qpc-hafs">﴿نَعِيمࣲ﴾</span>: التَّنَعُّمِ الدّائِم في الجنَّةِ.</p></div>"
  82,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُجَّارَ﴾</span>: الَّذِينَ قَصَّرُوا في حُقُوقِ اللهِ وحُقُوقِ عِبادِهِ.</p></div>"
  82,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡلَوۡنَهَا﴾</span>: يُصِيبُهُم لَهَبُها.</p><p><span class="qpc-hafs">﴿يَوۡمَ ٱلدِّينِ﴾</span>: يوم الجزاءِ.</p></div>"
  82,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنۡهَا﴾</span>: عذابِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿بِغَآئِبِينَ﴾</span>: لا بِخُرُوج ولا بِمَوتٍ.</p></div>"
  82,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وما أعْلَمَكَ؟</p><p><span class="qpc-hafs">﴿مَا يَوۡمُ ٱلدِّينِ﴾</span>: ما عَظَمَةُ يَومِ الحِسابِ.</p></div>"
  82,18,""
  82,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَمۡلِكُ نَفۡسࣱ لِّنَفۡسࣲ شَيۡـࣰٔا﴾</span>: لا يَقْدِرُ أحدٌ على نَفْعِ أحَدٍ.</p></div>"
