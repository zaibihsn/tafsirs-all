quran[88]{c,v,t}:
  38,1,""
  38,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِزَّةࣲ﴾</span>: تكبُّرٍ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿وَشِقَاقࣲ﴾</span>: مُشاقَّةٍ ومُخالَفةٍ للهِ ولِرَسُولِهِ.</p></div>"
  38,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمۡ أَهۡلَكۡنَا﴾</span>: كَثِيرًا أهْلَكْنا.</p><p><span class="qpc-hafs">﴿مِّن قَرۡنࣲ﴾</span>: مِن أُمَّةٍ.</p><p><span class="qpc-hafs">﴿فَنَادَواْ﴾</span>: فاسْتَغاثُوا حِينَ عايَنُوا العَذابَ.</p><p><span class="qpc-hafs">﴿وَّلَاتَ﴾</span>: ولَيسَ.</p><p><span class="qpc-hafs">﴿حِينَ مَنَاصࣲ﴾</span>: وقتَ فِرارٍ.</p></div>"
  38,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّنذِرࣱ مِّنۡهُمۡ﴾</span>: رَسُولٌ مِنهُم.</p></div>"
  38,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُجَابࣱ﴾</span>: عَجِيبٌ.</p></div>"
  38,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: أشْرافُ القوم ورُؤساؤُهُم.</p><p><span class="qpc-hafs">﴿أَنِ ٱمۡشُواْ﴾</span>: أنِ امْضُوا على ما كُنتُم عَلَيهِ ولا تَدْخُلُوا في دِينِه.</p><p><span class="qpc-hafs">﴿وَٱصۡبِرُواْ عَلَىٰٓ ءَالِهَتِكُمۡ﴾</span>: أي: اثبُتُوا على عِبادَتِها.</p><p><span class="qpc-hafs">﴿لَشَيۡءࣱ يُرَادُ﴾</span>: أي: شَيءٌ مُدَبَّرٌ يُريدُهُ محمدٌ بِنا وبآلَهتِنا؛ لِيَتَحَكَّمَ فِينا بِما يُرِيدُ.</p></div>"
  38,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمِلَّةِ ٱلۡـَٔاخِرَةِ﴾</span>: هي النَّصْرانِيَّةُ، أو دِينُ قُرَيشٍ.</p><p><span class="qpc-hafs">﴿إِلَّا ٱخۡتِلَـٰقٌ﴾</span>: إلا كَذِبٌ اختَلَقَهُ محمدٌ وافْتَراهُ.</p></div>"
  38,8,""
  38,9,""
  38,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَرۡتَقُواْ﴾</span>: فَلْيَصْعَدُوا.</p><p><span class="qpc-hafs">﴿ٱلۡأَسۡبَـٰبِ﴾</span>: المعارِجِ إلى السَّماءِ.</p></div>"
  38,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُندࣱ مَّا هُنَالِكَ﴾</span>: أي: هَؤُلاءِ الجُنْدُ المكذِّبُونَ الَّذينَ هُم في عِزَّةٍ وشِقاقٍ.</p><p><span class="qpc-hafs">﴿مَهۡزُومࣱ مِّنَ ٱلۡأَحۡزَابِ﴾</span>: سَيُهْزَمُ هَذا الجُنْدُ ويُغلَبُ، كما هُزِمَ الَّذينَ مِن قَبْلِهِم مِنَ الأحْزابِ المكَذِّبِينَ.</p></div>"
  38,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَوۡتَادِ﴾</span>: صاحِبُ القُوَّةِ العظِيمةِ مِنَ الجُنُودِ والمبانِي الشّاهِقَةِ.</p></div>"
  38,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ لۡـَٔيۡكَةِ﴾</span>: أصْحابُ الأشْجارِ والبَساتِينِ.</p></div>"
  38,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَقَّ عِقَابِ﴾</span>: فحَلَّ بهم عِقابِي وعَذابي.</p></div>"
  38,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُ﴾</span>: يَنْتَظِرُ.</p><p><span class="qpc-hafs">﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: نَفْخَةً واحِدةً في الصُّورِ.</p><p><span class="qpc-hafs">﴿مَّا لَهَا مِن فَوَاقࣲ﴾</span>: مالها مِن تَوقُّفٍ مِقْدارَ فَواقِ ناقَةٍ: وهو مابيَن حَلْبَتَيها مِنَ المدَّةِ القلِيلَةِ.</p></div>"
  38,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِطَّنَا﴾</span>: نصيبَنا مِنَ العذابِ.</p></div>"
  38,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَا ٱلۡأَيۡدِ﴾</span>: صاحِبَ القُوَّةِ.</p><p><span class="qpc-hafs">﴿أَوَّابٌ﴾</span>: كَثِيرُ الرُّجُوعِ إلى اللهِ وطاعَتِهِ عَن كُلِّ ما يَكْرَهُهُ.</p></div>"
  38,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡعَشِيِّ﴾</span>: بآخِرِ النَّهارِ.</p><p><span class="qpc-hafs">﴿وَٱلۡإِشۡرَاقِ﴾</span>: أوَّلِ النَّهارِ.</p></div>"
  38,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلطَّيۡرَ مَحۡشُورَةࣰ﴾</span>: أي: سَخَّرْنا الطَّيرَ مَجْمُوعَةً إليهِ تُسَبِّحُ اللهَ مَعَهُ.</p></div>"
  38,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَدَدۡنَا مُلۡكَهُۥ﴾</span>: أي: قَوَّيْناهُ بأسْبابِ القُوَّةِ كُلِّها.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: النُّبوَّةَ.</p><p><span class="qpc-hafs">﴿وَفَصۡلَ ٱلۡخِطَابِ﴾</span>: أي: الفَصْلَ في الكَلامِ والخُصُوماتِ.</p></div>"
  38,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبَؤُاْ ٱلۡخَصۡمِ﴾</span>: خبرُ المتخاصِمَينِ.</p><p><span class="qpc-hafs">﴿تَسَوَّرُواْ ٱلۡمِحۡرَابَ﴾</span>: تَسَلَّقُوا مَكانَ عِبادَتِهِ وأتَوهُ مِن أعلى سُورِهِ.</p></div>"
  38,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَفَزِعَ﴾</span>: فَخافَ.</p><p><span class="qpc-hafs">﴿بَغَىٰ﴾</span>: ظَلَمَ وتَعدّى.</p><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالعَدْلِ.</p><p><span class="qpc-hafs">﴿وَلَا تُشۡطِطۡ﴾</span>: لا تَجُرْ في حُكْمِكَ.</p><p><span class="qpc-hafs">﴿وَٱهۡدِنَآ﴾</span>: أرْشِدْنا.</p><p><span class="qpc-hafs">﴿سَوَآءِ ٱلصِّرَ ٰ⁠طِ﴾</span>: وسَطِ الطَّرِيقِ وهو الطَّرِيقُ الحقُّ.</p></div>"
  38,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكۡفِلۡنِيهَا﴾</span>: أعْطِنيها حتّى أكْفَلَها.</p><p><span class="qpc-hafs">﴿وَعَزَّنِي﴾</span>: غَلَبَني.</p><p><span class="qpc-hafs">﴿فِي ٱلۡخِطَابِ﴾</span>: في المُحاجَّةِ الكَلامِيَّةِ.</p></div>"
  38,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخُلَطَآءِ﴾</span>: الشُّركاءِ.</p><p><span class="qpc-hafs">﴿لَيَبۡغِي﴾</span>: لَيَظْلِمُ ويَتَعَدّى.</p><p><span class="qpc-hafs">﴿وَظَنَّ﴾</span>: أيْقَنَ.</p><p><span class="qpc-hafs">﴿فَتَنَّـٰهُ﴾</span>: ابْتَلَيناهُ وامْتَحَنّاه.</p><p><span class="qpc-hafs">﴿وَخَرَّ رَاكِعࣰا﴾</span>: سَقَطَ ساجِدًا للهِ.</p><p><span class="qpc-hafs">﴿وَأَنَابَ﴾</span>: رَجَعَ إلى اللهِ بالتَّوبَةِ.</p></div>"
  38,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَزُلۡفَىٰ﴾</span>: لقُرْبةً ومَكانَةً.</p><p><span class="qpc-hafs">﴿وَحُسۡنَ مَـَٔابࣲ﴾</span>: حُسْنَ مَرْجِعٍ في الآخِرَةِ، وهو الجنَّةُ.</p></div>"
  38,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالعَدْلِ والإنْصافِ.</p><p><span class="qpc-hafs">﴿ٱلۡهَوَىٰ﴾</span>: أي: هَوى النَّفْسِ المُخالِفَ لِلْحَقِّ.</p><p><span class="qpc-hafs">﴿بِمَا نَسُواْ يَوۡمَ ٱلۡحِسَابِ﴾</span>: أي: بِسَبَبِ تَرْكِهِم العَمَلَ لِيومِ الحِسابِ.</p></div>"
  38,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَـٰطِلࣰا﴾</span>: لَعِبًا وعَبَثًا.</p><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: فَهَلاكٌ.</p></div>"
  38,28,""
  38,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّيَدَّبَّرُوٓاْ﴾</span>: لِيَتَفكَّرُوا.</p><p><span class="qpc-hafs">﴿وَلِيَتَذَكَّرَ﴾</span>: ليتَّعِظَ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾</span>: أصْحابُ العُقُولِ السَّلِيمَةِ.</p></div>"
  38,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّابٌ﴾</span>: توّابٌ كثيرُ الرُّجُوعِ إلى اللهِ.</p></div>"
  38,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡعَشِيِّ﴾</span>: بآخِرِ النَّهارِ (مِن بَعْدِ الزَّوالِ إلى الغُرُوبِ).</p><p><span class="qpc-hafs">﴿ٱلصَّـٰفِنَـٰتُ﴾</span>: الخُيُولُ الأصِيلةُ الواقِفَةُ على ثَلاثِ قَوائِمَ وطرفِ حافِرِ الرّابِعَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡجِيَادُ﴾</span>: السَّريعَةُ في الجَرْي.</p></div>"
  38,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡبَبۡتُ حُبَّ ٱلۡخَيۡرِ﴾</span>: آثَرْتُ حُبَّ الخيلِ.</p><p><span class="qpc-hafs">﴿تَوَارَتۡ بِٱلۡحِجَابِ﴾</span>: غَرَبَتِ الشَّمسُ.</p></div>"
  38,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَفِقَ مَسۡحَۢا بِٱلسُّوقِ وَٱلۡأَعۡنَاقِ﴾</span>: فَشَرَعَ يَقْطَعُ سُوقَها وأعْناقَها بالسَّيفِ.</p></div>"
  38,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنَّا﴾</span>: ابتَلَينا.</p><p><span class="qpc-hafs">﴿جَسَدࣰا﴾</span>: شِقَّ ولَدٍ وُلِد لَهُ.</p><p><span class="qpc-hafs">﴿أَنَابَ﴾</span>: رَجَعَ إلى اللهِ بالتَّوبَةِ.</p></div>"
  38,35,""
  38,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَخَّرۡنَا لَهُ﴾</span>: فَذَلَّلْنا لَه.</p><p><span class="qpc-hafs">﴿رُخَآءً﴾</span>: لَيِّنةً طَيِّعةً.</p><p><span class="qpc-hafs">﴿حَيۡثُ أَصَابَ﴾</span>: حيثُ أرادَ.</p></div>"
  38,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَنَّآءࣲ﴾</span>: يَبْنِي لَهُ ما يشاءُ.</p><p><span class="qpc-hafs">﴿وَغَوَّاصࣲ﴾</span>: يَغُوصُ في البحْرِ لاسْتِخْراجِ نَفائِسِه.</p></div>"
  38,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُقَرَّنِينَ فِي ٱلۡأَصۡفَادِ﴾</span>: مُقَيَّدين في الأغْلالِ والسَّلاسِلِ.</p></div>"
  38,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱمۡنُنۡ أَوۡ أَمۡسِكۡ﴾</span>: فأعْطِ مَن شِئْتَ، وامنَعْ مَن شِئْتَ.</p></div>"
  38,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَزُلۡفَىٰ﴾</span>: لَقُرْبةً وكَرامةً.</p><p><span class="qpc-hafs">﴿وَحُسۡنَ مَـَٔابࣲ﴾</span>: حُسْنَ مَرْجِعٍ في الآخِرَةِ، وهو الجَنّةُ.</p></div>"
  38,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِنُصۡبࣲ﴾</span>: بِتَعَبٍ ومَشَقَّةٍ.</p><p><span class="qpc-hafs">﴿وَعَذَابٍ﴾</span>: ألَمٍ وضُرٍّ.</p></div>"
  38,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱرۡكُضۡ بِرِجۡلِكَ﴾</span>: اضْرِبْ بِها الأرْضَ.</p></div>"
  38,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلَهُۥ﴾</span>: زَوْجَهُ ووَلَدَهُ.</p><p><span class="qpc-hafs">﴿وَمِثۡلَهُم مَّعَهُمۡ﴾</span>: وزِدْناهُ مِثْلَهُم بَنِينَ وحَفَدَةً.</p><p><span class="qpc-hafs">﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: لأصْحابِ العُقُولِ السَّلِيمَةِ.</p></div>"
  38,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِغۡثࣰا﴾</span>: حُزْمَةً مِنَ الحَشِيشِ ونَحْوِهِ.</p><p><span class="qpc-hafs">﴿وَلَا تَحۡنَثۡ﴾</span>: لا تَتْرُكِ الوفاءَ بِيَمِينِكَ.</p><p><span class="qpc-hafs">﴿أَوَّابࣱ﴾</span>: رَجّاعٌ إلى طاعَةِ اللهِ.</p></div>"
  38,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلِي ٱلۡأَيۡدِي﴾</span>: أصْحابَ القُوى في طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَبۡصَـٰرِ﴾</span>: البصائرِ في الدِّينِ.</p></div>"
  38,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ﴾</span>: خَصَصْناهُم واصْطَفَيناهُم بِخاصَّةٍ عَظِيمَةٍ.</p><p><span class="qpc-hafs">﴿ذِكۡرَى ٱلدَّارِ﴾</span>: ذِكْرِ الدّارِ الآخرةِ في قُلُوبِهِم.</p></div>"
  38,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُصۡطَفَيۡنَ﴾</span>: الَّذينَ اخْتَرْناهُم لِرِسالَتِنا وطاعَتِنا.</p><p><span class="qpc-hafs">﴿ٱلۡأَخۡيَارِ﴾</span>: الُمخْتارِينَ الفضلاءِ المُخْتَصِّينَ بالخيرِ.</p></div>"
  38,48,""
  38,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرࣱ﴾</span>: عِظَةٌ وشَرَفٌ لك أيُّها الرسولُ ولِقَومِكَ.</p><p><span class="qpc-hafs">﴿مَـَٔابࣲ﴾</span>: مَصِيرٍ.</p></div>"
  38,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتِ عَدۡنࣲ﴾</span>: جَنّاتِ إقامَةٍ.</p></div>"
  38,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَّكِـِٔينَ﴾</span>: جالِسِينَ مُتَمَكِّنِينَ على السُّرُرِ.</p><p><span class="qpc-hafs">﴿يَدۡعُونَ﴾</span>: يَطْلُبُونَ.</p></div>"
  38,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span>: لا يَمْدُدْنَ أبْصارَهُنَّ إلى غَيْرِ أزْواجِهِنَّ.</p><p><span class="qpc-hafs">﴿أَتۡرَابٌ﴾</span>: مُتَساوِياتٌ في السِّنِّ.</p></div>"
  38,53,""
  38,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّفَادٍ﴾</span>: فَناءٍ وانْقِطاعِ.</p></div>"
  38,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلطَّـٰغِينَ﴾</span>: الُمتَجاوِزِينَ الحَدَّ في الكُفْرِ والمعاصِي.</p><p><span class="qpc-hafs">﴿مَـَٔابࣲ﴾</span>: مَرْجِعٍ ومَصِيرٍ.</p></div>"
  38,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡلَوۡنَهَا﴾</span>: يُعذَّبُونَ فِيها، تَغْمُرُهُم مِن جَمِيعِ جَوانِبِهِم.</p><p><span class="qpc-hafs">﴿ٱلۡمِهَادُ﴾</span>: الفِراشُ.</p></div>"
  38,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمِيمࣱ﴾</span>: ماءٌ شَدِيدُ الحَرارَةِ.</p><p><span class="qpc-hafs">﴿وَغَسَّاقࣱ﴾</span>: صَدِيدٌ سائِلٌ مِن أجْسادِ أهْلِ النّارِ.</p></div>"
  38,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاخَرُ﴾</span>: عَذابٌ آخَرُ.</p><p><span class="qpc-hafs">﴿شَكۡلِهِۦٓ﴾</span>: مِثْلِه.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جٌ﴾</span>: أصْنافٌ وألْوانٌ.</p></div>"
  38,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوۡجࣱ﴾</span>: جَماعَةٌ عَظِيمةٌ.</p><p><span class="qpc-hafs">﴿مُّقۡتَحِمࣱ﴾</span>: داخِلٌ.</p><p><span class="qpc-hafs">﴿صَالُواْ ٱلنَّارِ﴾</span>: مُقاسُونَ حَرَّها.</p></div>"
  38,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّمۡتُمُوهُ لَنَا﴾</span>: بَدَأْتُم بالكُفْرِ قَبْلنا وسَنَنْتُمُوهُ لَنا.</p><p><span class="qpc-hafs">﴿ٱلۡقَرَارُ﴾</span>: دارُ الاسْتِقْرارِ، وهي جَهَنَّمُ.</p></div>"
  38,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِعۡفࣰا﴾</span>: مُضاعَفًا.</p></div>"
  38,62,""
  38,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَّخَذۡنَـٰهُمۡ سِخۡرِيًّا﴾</span>: هَلْ أخْطأنا في تَحْقِيرِنا لَهُم، واسْتِهْزائِنا بِهِم؟</p><p><span class="qpc-hafs">﴿زَاغَتۡ﴾</span>: لم تَقَعْ عَلَيهِم.</p></div>"
  38,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: جِدالَ أهْلِ النّارِ وخِصامَهُم.</p></div>"
  38,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَهَّارُ﴾</span>: الَّذي قَهَرَ كُلَّ شَيءٍ وغَلَبَهُ.</p></div>"
  38,66,""
  38,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبَؤٌاْ عَظِيمٌ﴾</span>: خَبَرٌ عظِيمُ النَّفْعِ.</p></div>"
  38,68,""
  38,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡمَلَإِ ٱلۡأَعۡلَىٰٓ﴾</span>: مَلائِكَةِ السَّماءِ.</p></div>"
  38,70,""
  38,71,""
  38,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُّوحِي﴾</span>: رُوحِ الحَياةِ الَّتي يَخْلُقُها اللهُ.</p><p><span class="qpc-hafs">﴿فَقَعُواْ لَهُۥ سَـٰجِدِينَ﴾</span>: فاسْجُدُوا لَهُ سُجُودَ تَحِيَّةٍ وإكْرامٍ، لا سُجُودَ عِبادَةٍ وتَعْظِيمٍ.</p></div>"
  38,73,""
  38,74,""
  38,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡتَكۡبَرۡتَ﴾</span>: أتَعَظَّمْتَ وتَكَبَّرْتَ الآنَ عَنِ السُّجُودِ لآدَمَ؟</p><p><span class="qpc-hafs">﴿أَمۡ كُنتَ مِنَ ٱلۡعَالِينَ﴾</span>: أم كُنْتَ مِنَ الُمتَكَبِّرِينَ عَلى رَبِكَ مِن قَبْلُ.</p></div>"
  38,76,""
  38,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَجِيمࣱ﴾</span>: مَطْرُودٌ.</p></div>"
  38,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعۡنَتِيٓ﴾</span>: طَرْدِي وإبْعادِي.</p><p><span class="qpc-hafs">﴿ٱلدِّينِ﴾</span>: الجَزاءِ.</p></div>"
  38,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنظِرۡنِيٓ﴾</span>: فأخِّرْ أجَلِي، ولا تُهْلِكْنِي.</p></div>"
  38,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُنظَرِينَ﴾</span>: المُؤَخَّرِينَ.</p></div>"
  38,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَىٰ يَوۡمِ ٱلۡوَقۡتِ ٱلۡمَعۡلُومِ﴾</span>: إلى يومِ النَّفْخَةِ الأُولى الَّتي يَمُوتُ مِنها مَن بَقِيَ مِنَ الخلائِقِ.</p></div>"
  38,82,""
  38,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُخۡلَصِينَ﴾</span>: الَّذينَ أخْلَصْتَهُم لِعِبادَتِكَ وعَصَمْتَهم من إضْلالِ الشَّيطانِ.</p></div>"
  38,84,""
  38,85,""
  38,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُتَكَلِّفِينَ﴾</span>: الُمتَقَوِّلينَ للقُرآنِ مِن تِلْقاءِ نَفْسِي.</p></div>"
  38,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرࣱ﴾</span>: تَذْكِيرٌ.</p></div>"
  38,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبَأَهُۥ﴾</span>: خَبَرَ صِدْقِ القُرآنِ.</p><p><span class="qpc-hafs">﴿بَعۡدَ حِينِۭ﴾</span>: حِينَ يَغْلِبُ الإسْلامُ، وحيِنَ يَقَعُ عَلَيكُم العَذابُ.</p></div>"
