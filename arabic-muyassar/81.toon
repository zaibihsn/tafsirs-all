quran[29]{c,v,t}:
  81,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُوِّرَتۡ﴾</span>: لُفَّتْ، وذَهَبَ ضَوْءُها.</p></div>"
  81,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنكَدَرَتۡ﴾</span>: تَناثَرَتْ، فَذَهَبَ نُورُها.</p></div>"
  81,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُيِّرَتۡ﴾</span>: سُيِّرَتْ عن وجْهِ الأرْضِ فَصارَتْ هَباءً.</p></div>"
  81,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعِشَارُ﴾</span>: النُوقُ الحوامِلُ.</p><p><span class="qpc-hafs">﴿عُطِّلَتۡ﴾</span>: تُرِكَتْ وأُهْمِلَتْ.</p></div>"
  81,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوُحُوشُ﴾</span>: الحيواناتُ الوَحْشِيِّةُ.</p><p><span class="qpc-hafs">﴿حُشِرَتۡ﴾</span>: جُمِعَتْ واخْتَلَطَتْ، لِيَقْتَصَّ اللهُ مِن بَعْضِها لِبَعْضٍ.</p></div>"
  81,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُجِّرَتۡ﴾</span>: أُوقِدَتْ.</p></div>"
  81,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُوِّجَتۡ﴾</span>: قُرِنَتْ بأَمثالِها.</p></div>"
  81,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَوۡءُۥدَةُ﴾</span>: الطِّفْلةُ المدفُونةُ حَيَةً.</p><p><span class="qpc-hafs">﴿سُئِلَتۡ﴾</span>: سُؤالَ تَطْيِيبٍ لها ولَومٍ لِوائِدِها.</p></div>"
  81,9,""
  81,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّحُفُ﴾</span>: صُحُفُ الأَعْمالِ.</p><p><span class="qpc-hafs">﴿نُشِرَتۡ﴾</span>: عُرِضَتْ.</p></div>"
  81,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُشِطَتۡ﴾</span>: أُزِيلَتْ مِن مَّكانِها.</p></div>"
  81,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُعِّرَتۡ﴾</span>: أُوقِدَتْ.</p></div>"
  81,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُزۡلِفَتۡ﴾</span>: قُرِّبَتْ مِن أهْلِها.</p></div>"
  81,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡضَرَتۡ﴾</span>: قَدَّمَتْ من خَيرٍ أو شَرٍّ.</p></div>"
  81,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡخُنَّسِ﴾</span>: بِالنُّجُومِ المُخْتَفِيَةِ أنْوارُها نهارًا.</p></div>"
  81,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَوَارِ﴾</span>: الجارِيةِ.</p><p><span class="qpc-hafs">﴿ٱلۡكُنَّسِ﴾</span>: المسْتَتِرَةِ في أبْراجِها.</p></div>"
  81,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَسۡعَسَ﴾</span>: أقْبَلَ بِظَلامِهِ.</p></div>"
  81,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنَفَّسَ﴾</span>: ظَهَرَ ضِياؤُه.</p></div>"
  81,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهُۥ﴾</span>: إنَّ القُرآنَ.</p><p><span class="qpc-hafs">﴿رَسُولࣲ كَرِيمࣲ﴾</span>: هو جِبْرِيلُ -عَلَيه السَّلامُ-.</p></div>"
  81,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِي ٱلۡعَرۡشِ﴾</span>: اللهِ.</p><p><span class="qpc-hafs">﴿مَكِينࣲ﴾</span>: صاحبِ مَكانَةٍ رَفِيعَةٍ.</p></div>"
  81,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَمَّ﴾</span>: هُناكَ.</p><p><span class="qpc-hafs">﴿أَمِينࣲ﴾</span>: مُؤْتَمَنٍ على الوَحْيِ الَّذِي يَنْزِلُ بِه.</p></div>"
  81,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَاحِبُكُم﴾</span>: مُحَمَّدٌ ﷺ الَّذِي تَعْرِفُونَهُ.</p></div>"
  81,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدۡ رَءَاهُ﴾</span>: ولَقَدْ رَأى مُحَمَّدٌ جِبْرِيلَ.</p><p><span class="qpc-hafs">﴿بِٱلۡأُفُقِ ٱلۡمُبِينِ﴾</span>: بالأُفُقِ العَظِيمِ.</p></div>"
  81,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَى ٱلۡغَيۡبِ﴾</span>: بِتَبْلِيغ الوَحْيِ.</p><p><span class="qpc-hafs">﴿بِضَنِينࣲ﴾</span>: ببَخِيلٍ.</p></div>"
  81,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَّجِيمࣲ﴾</span>: مَطْرُودٍ منِ رَّحْمَةِ اللهِ.</p></div>"
  81,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَيۡنَ تَذۡهَبُونَ﴾</span>: فَأَينَ تَذْهَبُ بِكُم عُقُولُكُم فَي التَّكْذِيبِ بالقُرآنِ بَعْدَ هذِه الحُجَجِ القاطِعَةِ؟</p></div>"
  81,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرࣱ﴾</span>: مَوعِظَةٌ.</p></div>"
  81,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَقِيمَ﴾</span>: على الحقِّ والإيمانِ.</p></div>"
  81,29,""
