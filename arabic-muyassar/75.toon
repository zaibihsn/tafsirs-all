quran[40]{c,v,t}:
  75,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَآ أُقۡسِمُ﴾</span>: أحْلِفُ.</p></div>"
  75,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أُقۡسِمُ﴾</span>: وأحْلِفُ.</p><p><span class="qpc-hafs">﴿بِٱلنَّفۡسِ ٱللَّوَّامَةِ﴾</span>: بالأنْفُسِ الَّتِي تَلُومُ صاحِبَها على تَرْكِ الطّاعاتِ وفِعْلِ السَّيئاتِ.</p></div>"
  75,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحۡسَبُ﴾</span>: أيَظُنُّ.</p><p><span class="qpc-hafs">﴿أَلَّن نَّجۡمَعَ عِظَامَهُۥ﴾</span>: أن لَن نَّقَدِرَ على جَمْعِ عِظامِهِ بَعْدَ تَفَرُّقِها.</p></div>"
  75,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلَىٰ﴾</span>: بَلْ سَنَجْمَعُها.</p><p><span class="qpc-hafs">﴿أَن نُّسَوِّيَ بَنَانَهُۥ﴾</span>: نُعيدَ خَلْقَ أصابِعِه أو أنامِلِه مُقَوَّمةً مُتْقَنةً.</p></div>"
  75,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَفۡجُرَ﴾</span>: لِيَبْقى على فجُورِهِ.</p><p><span class="qpc-hafs">﴿أَمَامَهُۥ﴾</span>: فِيما يَسْتَقْبِلُ مِن أيامِ عُمُرِهِ.</p></div>"
  75,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّانَ﴾</span>: مَتى.</p></div>"
  75,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَرِقَ ٱلۡبَصَرُ﴾</span>: تَحَيَّر البَصَرُ ودُهِشَ فَزِعًا مما رَأى مِن أهْوالِ يَومِ القِيامَةِ.</p></div>"
  75,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَخَسَفَ ٱلۡقَمَرُ﴾</span>: وذَهبَ نُورُ القَمَرِ.</p></div>"
  75,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ﴾</span>: في ذَهابِ ضَوْئِهِما.</p></div>"
  75,10,""
  75,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمرُ كَما تَتَمَنّاهُ.</p><p><span class="qpc-hafs">﴿لَا وَزَرَ﴾</span>: لا مَلْجأَ لَكَ ولا مَنجى.</p></div>"
  75,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُسۡتَقَرُّ﴾</span>: مَصِيرُ الخلائِقِ يومَ القِيامةِ.</p></div>"
  75,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا قَدَّمَ وَأَخَّرَ﴾</span>: بِجَمِيعِ أعْمالِهِ: مِن خَيرٍ وشَرٍّ، ما قدَّمَهُ مِنها في حياتِهِ وما أخَّرَهُ.</p></div>"
  75,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ نَفۡسِهِۦ بَصِيرَةࣱ﴾</span>: بَصِيرٌ بِنَفْسِهِ، يعلَمُ اسْتِحْقاقَهُ لِلْعِقابِ.</p></div>"
  75,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ﴾</span>: حتّى في حِينِ إخْبارِه باعْتِذاراتِهِ الكاذِبةِ.</p></div>"
  75,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦٓ﴾</span>: لا تُحَرِّكْ –أيُّها النَّبِيُّ- بالقُرآنِ لِسانَكَ حتّى نُزُولِ الوحْيِ؛ لِأَجْلِ أن تَتَعَجَّلَ بِحِفْظِهِ، مخافَةَ أن يَتَفَلَّتَ مِنكَ.</p></div>"
  75,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمۡعَهُۥ﴾</span>: في صَدرِكَ.</p><p><span class="qpc-hafs">﴿وَقُرۡءَانَهُۥ﴾</span>: أن تَقْرَأَهُ بِلِسانِكَ مَتى شِئْتَ.</p></div>"
  75,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِذَا قَرَأۡنَـٰهُ﴾</span>: فَإذا قَرَأَهُ عَلَيكَ رَسُولُنا جِبْرِيلُ.</p><p><span class="qpc-hafs">﴿فَٱتَّبِعۡ قُرۡءَانَهُۥ﴾</span>: فاسْتمِعْ لِقِراءتِه وأَنْصِتْ لَهُ، ثُمُّ اقْرَأْهُ كَما أقْرَأَكَ إيّاهُ.</p></div>"
  75,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيَانَهُۥ﴾</span>: تَوْضِيحَ ما أشْكَلَ عَلَيكَ فَهْمُهُ مِن مَّعانِيهِ وأَحْكامِهِ.</p></div>"
  75,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمرُ كَما زَعَمْتُم أن لّا بَعْثَ ولا جَزاءَ.</p><p><span class="qpc-hafs">﴿ٱلۡعَاجِلَةَ﴾</span>: الدُّنيا وزِينَتَها.</p></div>"
  75,21,""
  75,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوهࣱ﴾</span>: وُجُوهُ أهْلِ السَّعادةِ.</p><p><span class="qpc-hafs">﴿يَوۡمَئِذࣲ﴾</span>: يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿نَّاضِرَةٌ﴾</span>: مُشْرِقَةٌ مُتَأَلِّقَةٌ.</p></div>"
  75,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَىٰ رَبِّهَا نَاظِرَةࣱ﴾</span>: تَنْظُرُ إلى خالِقِها فَتَتَمَتَّعُ بِذَلِكَ.</p></div>"
  75,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوُجُوهࣱ﴾</span>: ووُجُوهُ الأشْقِياءِ.</p><p><span class="qpc-hafs">﴿يَوۡمَئِذِۭ﴾</span>: يَومَ القِيامَةِ.</p><p><span class="qpc-hafs">﴿بَاسِرَةࣱ﴾</span>: عابِسَةٌ كالِحَةٌ.</p></div>"
  75,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَظُنُّ﴾</span>: تَتَوقَّعُ.</p><p><span class="qpc-hafs">﴿فَاقِرَةࣱ﴾</span>: مُصِيَبةٌ عَظِيمَةٌ.</p></div>"
  75,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: حَقًّا.</p><p><span class="qpc-hafs">﴿بَلَغَتِ ٱلتَّرَاقِيَ﴾</span>: وصَلَتْ الرُّوحُ إلى الحُلْقُومِ.</p></div>"
  75,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِيلَ﴾</span>: وقالَ بَعْضُ الحاضِرِينَ لِبَعْضٍ.</p><p><span class="qpc-hafs">﴿مَنۡۜ رَاقࣲ﴾</span>: هَل مِن راقٍ يَرْقِيهِ ويَشْفيهِ؟</p></div>"
  75,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَظَنَّ﴾</span>: وأَيقَنَ المُحْتَضِرُ.</p><p><span class="qpc-hafs">﴿أَنَّهُ﴾</span>: الأمرَ الَّذِي نَزَلَ بِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡفِرَاقُ﴾</span>: فراقُ الدُّنيا؛ لِمُعايَنَتِهِ مَلائِكَةَ الموْتِ.</p></div>"
  75,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ﴾</span>: واتَّصَلَتْ شِدَّةُ آخِر الدُّنيا بِشِدَّةِ أوّلِ الآخِرَةِ.</p></div>"
  75,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَسَاقُ﴾</span>: المرْجِعُ.</p></div>"
  75,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا صَدَّقَ﴾</span>: فلا آمنَ الكافِرُ بالرَّسُولِ ﷺ والقرآنِ.</p></div>"
  75,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَّبَ﴾</span>: بالقرآنِ.</p><p><span class="qpc-hafs">﴿وَتَوَلَّىٰ﴾</span>: وأَعْرَضَ عَنِ الإيمانِ.</p></div>"
  75,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَمَطَّىٰٓ﴾</span>: يَتَبَخْتَرُ مُخْتالًا في مِشْيتِهِ.</p></div>"
  75,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلَىٰ لَكَ﴾</span>: هَلاكٌ لَكَ.</p><p><span class="qpc-hafs">﴿فَأَوۡلَىٰ﴾</span>: فَهَلاكٌ.</p></div>"
  75,35,""
  75,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡإِنسَـٰنُ﴾</span>: هو المُنْكِرُ لِلْبَعثِ.</p><p><span class="qpc-hafs">﴿سُدًى﴾</span>: هَمَلًا لا يُحاسَبُ؟</p></div>"
  75,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُطۡفَةࣰ﴾</span>: ماءً قَلِيلًا.</p><p><span class="qpc-hafs">﴿مَّنِيࣲّ﴾</span>: ماءِ الرَّجُلِ.</p><p><span class="qpc-hafs">﴿يُمۡنَىٰ﴾</span>: يُراقُ ويُصَبُّ في الأرحامِ.</p></div>"
  75,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَقَةࣰ﴾</span>: قِطْعَةً مِن دمٍ جامِدٍ.</p><p><span class="qpc-hafs">﴿فَسَوَّىٰ﴾</span>: فعَدَّلَ صُورَتَهُ وقَوَّمَها في أحْسَنِ تَقْوِيمٍ.</p></div>"
  75,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلزَّوۡجَيۡنِ﴾</span>: الصِّنْفَينِ.</p></div>"
  75,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحۡـِۧيَ ٱلۡمَوۡتَىٰ﴾</span>: يُعيدُ الخلْقَ بَعْدَ فَنائِهِم.</p></div>"
