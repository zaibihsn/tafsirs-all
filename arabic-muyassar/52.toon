quran[49]{c,v,t}:
  52,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلطُّورِ﴾</span>: هُوَ الجَبَلُ الَّذِي كَلَّمَ اللهُ عَلَيهِ مُوسى عَلَيهِ السَّلامُ.</p></div>"
  52,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّسۡطُورࣲ﴾</span>: مَكْتُوبٍ، وهُو القُرآنُ.</p></div>"
  52,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي رَقࣲّ مَّنشُورࣲ﴾</span>: مَكْتُوبٍ في صَحِيفةٍ مَبْسُوطَةٍ.</p></div>"
  52,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡبَيۡتِ ٱلۡمَعۡمُورِ﴾</span>: هو فَوْقَ السَّماءِ السّابِعةِ تَطُوفُ بِه الملائِكةُ دائِمًا.</p></div>"
  52,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ﴾</span>: هو السَّماءُ الدُّنيا، جَعَلَها اللهُ سَقْفًا للأرْضِ.</p></div>"
  52,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَسۡجُورِ﴾</span>: الممْلُوءِ بالمياهِ.</p></div>"
  52,7,""
  52,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَافِعࣲ﴾</span>: مانِعٍ يَمْنَعُه حِينَ وقُوعِهِ.</p></div>"
  52,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمُورُ﴾</span>: تَتَحرَّكُ وتَضْطَرِبُ.</p></div>"
  52,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَسِيرُ﴾</span>: تَزُولُ عَنْ أماكِنِها وتَسيرُ كَسَيرِ السَّحابِ.</p></div>"
  52,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: فَهَلاكٌ.</p></div>"
  52,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي خَوۡضࣲ﴾</span>: في انْدِفاعٍ في الكَلامِ الباطِلِ.</p><p><span class="qpc-hafs">﴿يَلۡعَبُونَ﴾</span>: يَسْتَهْزِئُونَ.</p></div>"
  52,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُدَعُّونَ﴾</span>: يُدْفَعُونَ.</p><p><span class="qpc-hafs">﴿دَعًّا﴾</span>: دَفْعًا بِعُنْفٍ ومهانَةٍ.</p></div>"
  52,14,""
  52,15,""
  52,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡلَوۡهَا﴾</span>: ادْخُلُوها واحْتَرِقُوا بِنارِها.</p></div>"
  52,17,""
  52,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰكِهِينَ﴾</span>: طَيِّبَةً أنْفُسُكُم مُتَمَتِّعِينَ عَلى وجْهِ السُّرِورِ.</p></div>"
  52,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَنِيٓـَٔۢا﴾</span>: أكْلًا وشُرْبًا هَنِيئًا أي سائِغًا.</p></div>"
  52,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَّكِـِٔينَ﴾</span>: جالِسِين عَلى وجْهِ التَّمَكُّن والرّاحةِ.</p><p><span class="qpc-hafs">﴿سُرُرࣲ﴾</span>: جَمْعُ سَرِيرٍ وهو ما يُضْطَجَعُ عَلَيهِ، وهو مَجْلِسُ المنَعَّمِينَ.</p><p><span class="qpc-hafs">﴿مَّصۡفُوفَةࣲ﴾</span>: مُتَقابِلَةٍ.</p><p><span class="qpc-hafs">﴿وَزَوَّجۡنَـٰهُم﴾</span>: قَرَنّاهُم.</p><p><span class="qpc-hafs">﴿بِحُورٍ﴾</span>: بِنِساءٍ شَدِيداتِ بَياضِ العَينِ وسَوادها.</p><p><span class="qpc-hafs">﴿عِينࣲ﴾</span>: واسِعاتِ العُيونِ حِسانِهِنَّ.</p></div>"
  52,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَلَتۡنَـٰهُم﴾</span>: وما نَقَصْناهُم.</p><p><span class="qpc-hafs">﴿رَهِينࣱ﴾</span>: مَحْبُوسٌ مقْرُونٌ.</p></div>"
  52,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَمۡدَدۡنَـٰهُم﴾</span>: وزِدْناهُم.</p></div>"
  52,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَنَـٰزَعُونَ﴾</span>: يَتَعاطَونَ، ويُناوِلُ بعضُهم بَعْضًا.</p><p><span class="qpc-hafs">﴿كَأۡسࣰا﴾</span>: إناءً مَمْلُوءًا مِنَ الخَمْرِ.</p><p><span class="qpc-hafs">﴿لَغۡوࣱ﴾</span>: كَلامٌ لا فائِدةَ فِيهِ.</p><p><span class="qpc-hafs">﴿تَأۡثِيمࣱ﴾</span>: إثْمٌ ومَعْصِيَةٌ.</p></div>"
  52,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّكۡنُونࣱ﴾</span>: مَصُونٌ في أصْدافِهِ.</p></div>"
  52,25,""
  52,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُشۡفِقِينَ﴾</span>: خائِفِينَ مِن عَذابِ رَبِنا.</p></div>"
  52,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّمُومِ﴾</span>: نارِ جَهَنَّمَ وحَرارَتِها.</p></div>"
  52,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَرُّ﴾</span>: المُحْسِنُ.</p></div>"
  52,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِنِعۡمَتِ رَبِّكَ﴾</span>: بمَنِّهِ ولُطْفِهِ.</p><p><span class="qpc-hafs">﴿بِكَاهِنࣲ﴾</span>: يُخْبِرُ بالغَيبِ دُونَ عِلْمٍ.</p></div>"
  52,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّتَرَبَّصُ﴾</span>: نَنْتَظِرُ.</p><p><span class="qpc-hafs">﴿رَيۡبَ ٱلۡمَنُونِ﴾</span>: حوادِثَ الدَّهرِ فَيَمُوتُ.</p></div>"
  52,31,""
  52,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡلَـٰمُهُم﴾</span>: عُقُولُهم.</p><p><span class="qpc-hafs">﴿طَاغُونَ﴾</span>: مُتَجاوِزُونَ الحدَّ.</p></div>"
  52,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَقَوَّلَهُۥ﴾</span>: اخْتَلَقَهُ.</p></div>"
  52,34,""
  52,35,""
  52,36,""
  52,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُصَۜيۡطِرُونَ﴾</span>: المُتَسَلِّطُونَ.</p></div>"
  52,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلَّمࣱ﴾</span>: دَرَجٌ ومَصْعَدٌ إلى السَّماءِ.</p><p><span class="qpc-hafs">﴿يَسۡتَمِعُونَ﴾</span>: الكَلامَ الَّذِي يَجْرِي في السَّماءِ ويَسْتَرِقُونَهُ.</p><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنࣲ﴾</span>: بِحُجَّةٍ.</p></div>"
  52,39,""
  52,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّغۡرَمࣲ﴾</span>: غَرامةٍ مَطْلُوبَةٍ مِنهُم.</p></div>"
  52,41,""
  52,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدࣰا﴾</span>: مَكْرًا.</p><p><span class="qpc-hafs">﴿ٱلۡمَكِيدُونَ﴾</span>: يَعُودُ ضَرَرُ مَكْرِهِم عَلَيهِم.</p></div>"
  52,43,""
  52,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِسۡفࣰا﴾</span>: قِطَعًا كِبارًا مِنَ العَذابِ.</p><p><span class="qpc-hafs">﴿مَّرۡكُومࣱ﴾</span>: مُتَراكِمٌ بَعْضُهُ فَوْقَ بَعْضٍ.</p></div>"
  52,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَرۡهُمۡ﴾</span>: فَدَعْهُم.</p><p><span class="qpc-hafs">﴿يُصۡعَقُونَ﴾</span>: يُهلَكُونَ، وهو يومُ القِيامَةِ.</p></div>"
  52,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُغۡنِي﴾</span>: لا يَدْفَعُ.</p></div>"
  52,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَذَابࣰا دُونَ ذَ ٰ⁠لِكَ﴾</span>: مِنَ القَتْلِ والسَّبْيِ وعَذابِ القَبْرِ.</p></div>"
  52,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَعۡيُنِنَا﴾</span>: بِمَرْأىً مِنّا وحِفْظٍ واعْتِناءٍ.</p><p><span class="qpc-hafs">﴿حِينَ تَقُومُ﴾</span>: إلى الصَّلاةِ، وحِينَ تَقُومُ مِنَ النَّومِ.</p></div>"
  52,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِدۡبَـٰرَ ٱلنُّجُومِ﴾</span>: عِنْدَ صَلاةِ الصُّبْحِ حِينَ يُغَطِّي ضَوءُ الصُّبْحِ النُّجُومَ.</p></div>"
