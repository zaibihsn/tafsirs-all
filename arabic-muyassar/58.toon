quran[22]{c,v,t}:
  58,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُجَـٰدِلُكَ﴾</span>: تُراجِعُكَ الكَلامَ في زَوْجِها وهي خَوْلَةُ بِنْتُ ثَعْلَبةَ وزَوْجُها أوسُ بنُ الصّامتِ.</p><p><span class="qpc-hafs">﴿تَحَاوُرَكُمَآ﴾</span>: تَخاطُبَكُما ومُراجَعَتَكُما الكَلامَ.</p></div>"
  58,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُظَـٰهِرُونَ﴾</span>: يَقُولُ الرَّجُلُ مِنهُم لِزوجَتِهِ: «أنْتِ عَليَّ كَظَهْرِ أُمِّي» أي في حُرْمَةِ النِّكاحِ.</p></div>"
  58,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ۡ ثُمَّ يَعُودُونَ لِمَا قَالُواْ﴾</span>: ثُمَّ يَرْجِعُونَ عَن قَوْلِهِم ويَعْزِمُونَ على وطْءِ نِسائِهِم.</p><p><span class="qpc-hafs">﴿يَتَمَآسَّا﴾</span>: يَمَسَّ أحَدُهُما الآخَرَ، وهي كِنايةٌ عَنِ الِجماعِ.</p></div>"
  58,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِسۡكِينࣰا﴾</span>: هو الَّذِي لا يَمْلِكُ ما يَكْفِيهِ ويَسُدُّ حاجَتَهُ.</p></div>"
  58,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَآدُّونَ﴾</span>: يُشاقُّونَ ويُخالِفُونَ.</p><p><span class="qpc-hafs">﴿كُبِتُواْ﴾</span>: خُذِلُوا وأُهِينُوا.</p><p><span class="qpc-hafs">﴿مُّهِينࣱ﴾</span>: مُذِلٌّ.</p></div>"
  58,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡصَىٰهُ ٱللَّهُ﴾</span>: كَتَبهُ في اللَّوح المحْفُوظِ، وحَفِظَهُ عَلَيهم في صحائفِ أعْمالِهِم.</p><p><span class="qpc-hafs">﴿شَهِيدٌ﴾</span>: شاهِدٌ يَعْلَمُهُ ويُحِيطُ بِهِ، فلا يعْزُبُ عنه شَيءٌ مِنهُ.</p></div>"
  58,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّجۡوَىٰ﴾</span>: مُناجاةٍ ومُسارَّةٍ وما يَكْتُمُهُ النّاسُ مِن أحادِيثِهِم.</p><p><span class="qpc-hafs">﴿هُوَ رَابِعُهُمۡ﴾</span>: مُشاهِدُهُم بِعِلْمِهِ، وهو عَلى عَرْشِهِ.</p><p><span class="qpc-hafs">﴿وَلَآ أَدۡنَىٰ مِن ذَ ٰ⁠لِكَ﴾</span>: ولا أقَلَّ مِن ذَلِكَ.</p><p><span class="qpc-hafs">﴿هُوَ مَعَهُمۡ﴾</span>: بِعِلْمِه وهُوَ فَوْقَ العَرْشِ.</p></div>"
  58,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّجۡوَىٰ﴾</span>: حَدِيثِ السِّرِّ الَّذِي يُثيرُ الشَّكَ في نُفُوسِ المؤمِنينَ.</p><p><span class="qpc-hafs">﴿وَيَتَنَـٰجَوۡنَ﴾</span>: يَتَحَدَّثُونَ سِرًّا.</p><p><span class="qpc-hafs">﴿حَيَّوۡكَ﴾</span>: سَلَّمُوا عَلَيكَ.</p><p><span class="qpc-hafs">﴿حَسۡبُهُمۡ﴾</span>: كافِيهِم مِنَ العَذابِ.</p><p><span class="qpc-hafs">﴿يَصۡلَوۡنَهَا﴾</span>: يَدْخُلُونَها ويُقاسُونَ حَرَّها.</p><p><span class="qpc-hafs">﴿فَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: فَساءَ المنْقَلَبُ والمرْجِعُ.</p></div>"
  58,9,""
  58,10,""
  58,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَفَسَّحُواْ﴾</span>: لِيُوسِّعْ بَعْضُكُم لِبَعْضٍ المَجالِسَ.</p><p><span class="qpc-hafs">﴿يَفۡسَحِ ٱللَّهُ لَكُمۡ﴾</span>: يُوَسِّعِ اللهُ عَلَيكُم في الدُّنيا والآخِرةِ.</p><p><span class="qpc-hafs">﴿ٱنشُزُواْ﴾</span>: قُومُوا من مجالِسِكُم.</p><p><span class="qpc-hafs">﴿يَرۡفَعِ﴾</span>: يَرْفَعْ مَكانَةً.</p><p><span class="qpc-hafs">﴿دَرَجَـٰتࣲ﴾</span>: مَراتِبَ رَفِيَعةً في دِينِهِم.</p></div>"
  58,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَـٰجَيۡتُمُ ٱلرَّسُولَ﴾</span>: أرَدْتُم أن تُكَلِّمُوا رَسُولَ اللهِ ﷺ سرًّا.</p><p><span class="qpc-hafs">﴿وَأَطۡهَرُ﴾</span>: وأَزْكى لِقُلُوبِكُم مِنَ المأثَمِ.</p></div>"
  58,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَأَشۡفَقۡتُمۡ﴾</span>: أخَشِيتُم الفَقْرَ عَقِبَ تَقْدِيمِ الصَّدَقةِ؟</p></div>"
  58,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ قَوۡمًا﴾</span>: اتخذوهم أصدقاءَ يُحِبُّونهم وينصرونهم.</p></div>"
  58,15,""
  58,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُنَّةࣰ﴾</span>: وِقايِةً وسِتْرَةً.</p><p><span class="qpc-hafs">﴿مُّهِينࣱ﴾</span>: مُذِلٌّ في النّارِ.</p></div>"
  58,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّن تُغۡنِيَ﴾</span>: لَن تَدْفَعَ.</p></div>"
  58,18,""
  58,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَحۡوَذَ﴾</span>: غَلَبَ واسْتَولى.</p><p><span class="qpc-hafs">﴿فَأَنسَىٰهُمۡ﴾</span>: جَعَلَهُم يَتْرُكُونَ.</p><p><span class="qpc-hafs">﴿ذِكۡرَ ٱللَّهِ﴾</span>: تَوْحِيدَ اللهِ، والعَمَلَ بِطاعَتِهِ.</p></div>"
  58,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَآدُّونَ﴾</span>: يُخالِفُونَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَذَلِّينَ﴾</span>: مِن جُمْلةِ الأذِلّاءِ المغلوبِينَ المهانِينَ.</p></div>"
  58,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَتَبَ﴾</span>: قَضى وكَتَبَ في اللَّوحِ المحْفُوظِ.</p><p><span class="qpc-hafs">﴿لَأَغۡلِبَنَّ﴾</span>: لَتَكونَنَّ الغَلَبةُ بِالقُوَّةِ للهِ ولِرُسُلِهِ.</p><p><span class="qpc-hafs">﴿عَزِيزࣱ﴾</span>: مانِعٌ حِزْبَهُ مِن أن يُذَلَّ.</p></div>"
  58,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُوَآدُّونَ﴾</span>: يُحِبُّونَ ويُوالُونَ.</p><p><span class="qpc-hafs">﴿حَآدَّ﴾</span>: عادى.</p><p><span class="qpc-hafs">﴿عَشِيرَتَهُمۡ﴾</span>: أقْرِباءَهُم.</p><p><span class="qpc-hafs">﴿كَتَبَ﴾</span>: ثَبَّتَ.</p><p><span class="qpc-hafs">﴿وَأَيَّدَهُم﴾</span>: قَوّاهُم.</p><p><span class="qpc-hafs">﴿بِرُوحࣲ﴾</span>: بِنَصْرٍ وتأْيِيدٍ.</p><p><span class="qpc-hafs">﴿حِزۡبَ ٱللَّهِ﴾</span>: أولياؤُهُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ بِسَعادةِ الدُّنيا والآخِرَةِ.</p></div>"
