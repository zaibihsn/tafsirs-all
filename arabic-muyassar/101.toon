quran[11]{c,v,t}:
  101,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَارِعَةُ﴾</span>: السّاعةُ الَّتِي تَقْرَعُ قُلُوبَ النّاسِ بِأَهْوالِها.</p></div>"
  101,2,""
  101,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعَلَمَكَ بِها؟</p></div>"
  101,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡفَرَاشِ ٱلۡمَبۡثُوثِ﴾</span>: كالفَراشِ المُنْتَشِرِ.</p></div>"
  101,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡعِهۡنِ ٱلۡمَنفُوشِ﴾</span>: كالصُّوفِ المُتَعَدِّدِ الألوانِ الَّذِي يُنْفَشُ باليدِ، فَيَصِيرُ هَباءً ويَزُولُ.</p></div>"
  101,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: مَن رَجَحَتْ مَوازِينُ حَسَناتِهِ.</p></div>"
  101,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِيشَةࣲ رَّاضِيَةࣲ﴾</span>: حياةٍ مُرْضِيَةٍ في الجنَّةِ.</p></div>"
  101,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنۡ خَفَّتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: مَن خَفَّتْ مَوازِينُ حسناتِهِ ورَجَحَتْ مَوازينُ سَيِّئاتِهِ.</p></div>"
  101,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأُمُّهُۥ هَاوِيَةࣱ﴾</span>: فَمَأواهُ جَهَنَّمُ؛ لِأنّهُ يَهْوِي فِيها عَلى أُمِّ رَأْسِهِ.</p></div>"
  101,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعْلَمكَ؟</p><p><span class="qpc-hafs">﴿مَا هِيَهۡ﴾</span>: ما هذهِ الهاوِيةُ؟.</p></div>"
  101,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَامِيَةُۢ﴾</span>: قَدْ حَمِيَتْ مِنَ الوَقُودِ عَلَيها.</p></div>"
