quran[111]{c,v,t}:
  12,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُبِينِ﴾</span>: الواضِحِ في معانيه وأحكامِه.</p></div>"
  12,2,""
  12,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَـٰفِلِينَ﴾</span>: السّاهِين، أي: لم يَكُنْ لك عِلْمٌ بهذا الإخبارِ.</p></div>"
  12,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَـٰجِدِينَ﴾</span>: أي: سجودَ تَكريمٍ واحترامٍ.</p></div>"
  12,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَيَكِيدُواْ لَكَ﴾</span>: يَحْتالُوا من أجلِ إهلاكِك حَسَدًا.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: ظاهرُ العداوةِ.</p></div>"
  12,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَجۡتَبِيكَ﴾</span>: يختارُك لأمورٍ عظيمة.</p><p><span class="qpc-hafs">﴿تَأۡوِيلِ ٱلۡأَحَادِيثِ﴾</span>: تفسيرِ الرُّؤى المناميةِ.</p><p><span class="qpc-hafs">﴿وَيُتِمُّ نِعۡمَتَهُۥ عَلَيۡكَ﴾</span>: أي: بالنبوَّةِ والرسالةِ.</p></div>"
  12,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتࣱ﴾</span>: عِبَرٌ، وعلاماتٌ دالَّةٌ على قدرةِ اللهِ.</p></div>"
  12,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُصۡبَةٌ﴾</span>: جماعةٌ من الرجالِ متناصِرُون.</p><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينٍ﴾</span>: خطأٍ بيِّنٍ في تفضيلِهما علينا.</p></div>"
  12,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱطۡرَحُوهُ أَرۡضࣰا﴾</span>: ألْقُوه في أرضٍ بعيدةٍ.</p><p><span class="qpc-hafs">﴿يَخۡلُ لَكُمۡ وَجۡهُ أَبِيكُمۡ﴾</span>: يَخْلُصْ لكم حُبُّ أبيكم وإقبالُه عليكم.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِهِۦ﴾</span>: من بعدِ قَتْلِ يوسفَ أو إبعادِه.</p><p><span class="qpc-hafs">﴿صَـٰلِحِينَ﴾</span>: تائبين إلى اللهِ مِن فَعْلَتِكم.</p></div>"
  12,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيَـٰبَتِ ٱلۡجُبِّ﴾</span>: جوفِ البئرِ وأسفلِه حيثُ يَغيبُ خبرُه.</p><p><span class="qpc-hafs">﴿ٱلسَّيَّارَةِ﴾</span>: المسافرين المارِّينَ بالبئرِ.</p></div>"
  12,11,""
  12,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡتَعۡ﴾</span>: يَتَنعَّمْ في أكْلِ ما لَذَّ له وطابَ.</p><p><span class="qpc-hafs">﴿وَيَلۡعَبۡ﴾</span>: يتسابَقْ ويرمِ بالسِّهام معنا.</p></div>"
  12,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَحۡزُنُنِيٓ﴾</span>: لَيُؤْلمُ نفسي فِراقُ يوسفَ.</p><p><span class="qpc-hafs">﴿غَـٰفِلُونَ﴾</span>: ساهُون.</p></div>"
  12,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّخَـٰسِرُونَ﴾</span>: عاجِزُون لا خيرَ فينا.</p></div>"
  12,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَجۡمَعُوٓاْ﴾</span>: عَزَمُوا.</p><p><span class="qpc-hafs">﴿وَأَوۡحَيۡنَآ إِلَيۡهِ﴾</span>: أعلمَ اللهُ يوسُفَ؛ تَطْمينًا لقَلْبِه.</p><p><span class="qpc-hafs">﴿لَتُنَبِّئَنَّهُم﴾</span>: لتُخْبِرَنَّ إخوتَك.</p></div>"
  12,16,""
  12,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَسۡتَبِقُ﴾</span>: نتسابَقُ في الجَرْيِ والرَّمْيِ بالسِّهامِ.</p><p><span class="qpc-hafs">﴿مَتَـٰعِنَا﴾</span>: ما ننتفِعُ به من الطَّعامِ والثيابِ ونحوِهما.</p><p><span class="qpc-hafs">﴿بِمُؤۡمِنࣲ لَّنَا﴾</span>: بمُصَدِّقٍ لنا.</p></div>"
  12,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَّلَتۡ﴾</span>: زَيَّنَتْ.</p><p><span class="qpc-hafs">﴿فَصَبۡرࣱ جَمِيلࣱ﴾</span>: وهو ما لا جَزَعَ فيه، ولا شَكْوى معه لأحدٍ من الخَلْقِ.</p></div>"
  12,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيَّارَةࣱ﴾</span>: جماعةٌ من المسافرين.</p><p><span class="qpc-hafs">﴿وَارِدَهُمۡ﴾</span>: مَن يتقدَّمُهم ليطلُبَ لهم الماءَ.</p><p><span class="qpc-hafs">﴿فَأَدۡلَىٰ دَلۡوَهُۥ﴾</span>: فأَنْزَلَها الواردُ في البئرِ.</p><p><span class="qpc-hafs">﴿وَأَسَرُّوهُ﴾</span>: وأخفى الوارِدُ وأصحابُه يوسفَ عن بقيةِ المسافرين.</p><p><span class="qpc-hafs">﴿بِضَـٰعَةࣰ﴾</span>: متاعًا للتجارة.</p></div>"
  12,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَرَوۡهُ﴾</span>: باعه إخوتُه.</p><p><span class="qpc-hafs">﴿بَخۡسࣲ﴾</span>: قليلٍ ناقصٍ عن مِثْلِه.</p><p><span class="qpc-hafs">﴿ٱلزَّ ٰ⁠هِدِينَ﴾</span>: المُعْرِضين عنه، غيرِ المبالِين به.</p></div>"
  12,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكۡرِمِي مَثۡوَىٰهُ﴾</span>: اجعلي مَقامَه عندنا كريمًا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡأَرۡضِ﴾</span>: أرضِ مصرَ.</p><p><span class="qpc-hafs">﴿وَٱللَّهُ غَالِبٌ عَلَىٰٓ أَمۡرِهِۦ﴾</span>: لا يُعْجِزُه شيءٌ، ولا ينازعُه في حُكْمِه أحدٌ.</p></div>"
  12,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَشُدَّهُۥٓ﴾</span>: منتهى قوتِه الجسميةِ، وتكامُلَ عَقْلِه.</p><p><span class="qpc-hafs">﴿حُكۡمࣰا﴾</span>: حِكْمةً وفَهْمًا سديدًا، أو النبوَّةَ.</p></div>"
  12,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَ ٰ⁠وَدَتۡهُ﴾</span>: ودَعَتْ امرأةُ العزيزِ يوسُفَ إلى نفسِها بلِينٍ ومُخادَعَةٍ.</p><p><span class="qpc-hafs">﴿هَيۡتَ لَكَ﴾</span>: هلمَّ إليَّ وأقْبِلْ.</p><p><span class="qpc-hafs">﴿مَعَاذَ ٱللَّهِ﴾</span>: أستجيرُ بالله وأعتصِمُ به ممّا تُريدين مني.</p><p><span class="qpc-hafs">﴿إِنَّهُۥ رَبِّيٓ﴾</span>: إن زوجَكِ سيِّدي.</p><p><span class="qpc-hafs">﴿مَثۡوَايَ﴾</span>: مَقامي عنده.</p></div>"
  12,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَمَّتۡ بِهِۦ﴾</span>: مالَتْ إليه وعَزَمَتْ على فِعْلِ الفاحشةِ به.</p><p><span class="qpc-hafs">﴿وَهَمَّ بِهَا﴾</span>: ما خَطَرَ بنفسِه من الميلِ بمقتضى الطبيعةِ البشريَّة.</p><p><span class="qpc-hafs">﴿بُرۡهَـٰنَ رَبِّهِۦ﴾</span>: حُجَّةَ رَبِّه الواضحةَ التي مَنَعَتْه عن المَيْلِ لخَطَراتِ نفسِه.</p><p><span class="qpc-hafs">﴿ٱلسُّوٓءَ﴾</span>: كلَّ ما يَسُوءُه، ومنه خيانةُ سَيِّدِه.</p><p><span class="qpc-hafs">﴿وَٱلۡفَحۡشَآءَ﴾</span>: ما يَشْتَدُّ قُبْحُه من المعاصي، ومنه الزِّنى.</p><p><span class="qpc-hafs">﴿ٱلۡمُخۡلَصِينَ﴾</span>: المختارِين لطاعةِ اللهِ ورسالتِه.</p></div>"
  12,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱسۡتَبَقَا ٱلۡبَابَ﴾</span>: تسابَقا إليه، هو يريدُ الخروجَ وهي تمنعُه.</p><p><span class="qpc-hafs">﴿وَقَدَّتۡ قَمِيصَهُۥ مِن دُبُرࣲ﴾</span>: شَقَّتْه طُولًا مِن خَلْفٍ.</p><p><span class="qpc-hafs">﴿وَأَلۡفَيَا سَيِّدَهَا﴾</span>: وجدا زوجَها.</p></div>"
  12,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَهِدَ شَاهِدࣱ﴾</span>: صَبِيٌّ في المهد أنطقَه اللهُ ببراءته.</p></div>"
  12,27,""
  12,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدِكُنَّ﴾</span>: احتيالِكنَّ ومَكْرِكنَّ.</p></div>"
  12,29,""
  12,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَغَفَهَا حُبًّا﴾</span>: دَخَلَ حُبُّه إلى غِلاف قلبِها، حتى تَمَكَّنَ.</p></div>"
  12,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَكۡرِهِنَّ﴾</span>: باغتيابِهنَّ لها واحتيالِهنَّ في ذَمِّها.</p><p><span class="qpc-hafs">﴿أَعۡتَدَتۡ﴾</span>: هَيَّأت.</p><p><span class="qpc-hafs">﴿مُتَّكَـࣰٔا﴾</span>: ما يَتَّكِئْنَ عليه من الوَسائدِ ونحوِها.</p><p><span class="qpc-hafs">﴿أَكۡبَرۡنَهُۥ﴾</span>: أعْظَمْنَه، ودَهِشْنَ من جَمالِه الرائعِ.</p><p><span class="qpc-hafs">﴿وَقَطَّعۡنَ أَيۡدِيَهُنَّ﴾</span>: جَرَحْنَها بالسَّكاكين؛ لانشغالِهنَّ بحُسْنِه.</p><p><span class="qpc-hafs">﴿حَـٰشَ لِلَّهِ﴾</span>: معاذَ اللهِ وتنزيهًا له.</p></div>"
  12,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسۡتَعۡصَمَ﴾</span>: امتنَع وأبى.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰغِرِينَ﴾</span>: الأذِلّاءِ المُهانِين.</p></div>"
  12,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡبُ إِلَيۡهِنَّ﴾</span>: أمِلْ إلى إجابتِهنَّ.</p><p><span class="qpc-hafs">﴿ٱلۡجَـٰهِلِينَ﴾</span>: الذين يرتكِبُون الإثمَ؛ لجَهْلِهم بعواقِبه.</p></div>"
  12,34,""
  12,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدَا﴾</span>: ظَهَر.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الأدلَّةَ على براءةِ يوسفَ وعِفَّتِه.</p><p><span class="qpc-hafs">﴿حَتَّىٰ حِينࣲ﴾</span>: إلى زمنٍ غيرِ محدَّدٍ.</p></div>"
  12,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَمۡرࣰا﴾</span>: عِنَبًا يصير خَمْرًا.</p><p><span class="qpc-hafs">﴿بِتَأۡوِيلِهِۦٓ﴾</span>: بتفسيرِ ما رَأَيْنا.</p></div>"
  12,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُمَا﴾</span>: التعبيرُ للرؤيا، أو العِلْمُ بالغَيبِ.</p></div>"
  12,38,""
  12,39,""
  12,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَمَّيۡتُمُوهَآ﴾</span>: جَعَلْتُموها آلهةً، تَوَهُّمًا منكم وضلالًا.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: حُجَّةٍ تَدُلُّ على صحَّتِها.</p><p><span class="qpc-hafs">﴿ٱلۡقَيِّمُ﴾</span>: المستقيمُ، والثابتُ الذي لا شَكَّ فيه.</p></div>"
  12,41,""
  12,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَنَّ﴾</span>: عَلِمَ.</p><p><span class="qpc-hafs">﴿رَبِّكَ﴾</span>: سيِّدِكَ الملِكِ.</p><p><span class="qpc-hafs">﴿فَأَنسَىٰهُ ٱلشَّيۡطَـٰنُ﴾</span>: فأنسى الشيطانُ ساقِيَ المَلِكِ.</p><p><span class="qpc-hafs">﴿ذِكۡرَ رَبِّهِۦ﴾</span>: ذِكْرَ يوسُفَ عند سيِّده الملِكِ.</p><p><span class="qpc-hafs">﴿بِضۡعَ﴾</span>: من ثلاثٍ إلى تسعٍ.</p></div>"
  12,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِجَافࣱ﴾</span>: جَمْعُ عَجْفاءَ، وهي التي بلغَتْ غايةَ الهُزال.</p><p><span class="qpc-hafs">﴿تَعۡبُرُونَ﴾</span>: تُفَسِّرُون.</p></div>"
  12,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَضۡغَـٰثُ أَحۡلَـٰمࣲ﴾</span>: تَخاليطُ مَناماتٍ كاذبةٍ.</p><p><span class="qpc-hafs">﴿بِتَأۡوِيلِ ٱلۡأَحۡلَـٰمِ﴾</span>: بتفسيرِ ما يراه النائمون ممّا لا حقيقةَ له.</p></div>"
  12,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱدَّكَرَ﴾</span>: تَذَكَّرَ أمْرَ يوسُفَ.</p><p><span class="qpc-hafs">﴿أُمَّةٍ﴾</span>: مُدَّةٍ.</p></div>"
  12,46,""
  12,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَأَبࣰا﴾</span>: جادِّين على عادتِكم.</p><p><span class="qpc-hafs">﴿فَمَا حَصَدتُّمۡ﴾</span>: ما قَطَعْتُموه حالَ نُضْجِه.</p><p><span class="qpc-hafs">﴿فَذَرُوهُ﴾</span>: اترُكُوه وادَّخِرُوه.</p></div>"
  12,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِدَادࣱ﴾</span>: شديدةُ الجَدْبِ.</p><p><span class="qpc-hafs">﴿يَأۡكُلۡنَ مَا قَدَّمۡتُمۡ لَهُنَّ﴾</span>: يأكلُ الناسُ كلَّ ما ادَّخَرْتُم لأجْلِهنَّ.</p><p><span class="qpc-hafs">﴿تُحۡصِنُونَ﴾</span>: تُخَبِّئونه من البَذْرِ للزِّراعةِ.</p></div>"
  12,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغَاثُ ٱلنَّاسُ﴾</span>: يأتيهم المطرُ.</p><p><span class="qpc-hafs">﴿يَعۡصِرُونَ﴾</span>: ما يُعْصَرُ من الثِّمارِ؛ لكثرةِ الخيرِ.</p></div>"
  12,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَبِّكَ﴾</span>: سيِّدِكَ الملِكِ.</p><p><span class="qpc-hafs">﴿مَا بَالُ ٱلنِّسۡوَةِ﴾</span>: ما شأنُهنَّ وحقيقةُ أمْرِهنَّ معي؟</p><p><span class="qpc-hafs">﴿قَطَّعۡنَ أَيۡدِيَهُنَّ﴾</span>: جَرَحْنَها بالسَّكاكين.</p><p><span class="qpc-hafs">﴿بِكَيۡدِهِنَّ﴾</span>: باحتيالهنَّ ومَكْرِهنَّ.</p></div>"
  12,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا خَطۡبُكُنَّ﴾</span>: ما شأنكُنَّ؟</p><p><span class="qpc-hafs">﴿حَـٰشَ لِلَّهِ﴾</span>: معاذَ اللهِ وتنزيهًا له.</p><p><span class="qpc-hafs">﴿حَصۡحَصَٱلۡحَقُّ﴾</span>: ظَهَرَ بَعْدَ خَفائِه.</p></div>"
  12,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: أي: ما قُلْتُه في تنزيهِ يوسفَ، واعترافي بإغرائه.</p><p><span class="qpc-hafs">﴿لِيَعۡلَمَ﴾</span>: أي: زوجي.</p><p><span class="qpc-hafs">﴿لَمۡ أَخُنۡهُ بِٱلۡغَيۡبِ﴾</span>: لم تَقَعْ مني الفاحشةُ والأبوابُ مُغَلَّقَةٌ.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوَفِّقُ.</p></div>"
  12,53,""
  12,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡتَخۡلِصۡهُ لِنَفۡسِي﴾</span>: أجْعَلْ يوسفَ مِن خاصَّتي وأهلِ مَشُورتي.</p><p><span class="qpc-hafs">﴿مَكِينٌ﴾</span>: ذو مَكانةٍ رفيعةٍ وقولٍ نافذٍ.</p></div>"
  12,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرضِ مصرَ.</p></div>"
  12,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ﴾</span>: وكما أنْعَمْنا على يوسفَ بالخَلاصِ من السِّجْنِ.</p><p><span class="qpc-hafs">﴿يَتَبَوَّأُ مِنۡهَا﴾</span>: يَنْزِلُ من بلاد مِصرَ.</p></div>"
  12,57,""
  12,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنكِرُونَ﴾</span>: لم يَعْرِفُوا يوسفَ لطولِ المدةِ، وتَغَيُّرِهيئتِه.</p></div>"
  12,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهَّزَهُم بِجَهَازِهِمۡ﴾</span>: هيَّأ لهم ما هم في حاجةٍ إليه من طعامٍ ومَتاعٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنزِلِينَ﴾</span>: المُضِيفِين.</p></div>"
  12,60,""
  12,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنُرَ ٰ⁠وِدُ عَنۡهُ أَبَاهُ﴾</span>: سنجتهدُ في استمالةِ أبيه برِفْقٍ؛ ليُرْسِلَه معنا.</p></div>"
  12,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِفِتۡيَـٰنِهِ﴾</span>: غِلْمانِ يوسفَ.</p><p><span class="qpc-hafs">﴿بِضَـٰعَتَهُمۡ فِي رِحَالِهِمۡ﴾</span>: ثمنَ ما اشترَوْه في أمتعتِهم.</p><p><span class="qpc-hafs">﴿ٱنقَلَبُوٓاْ﴾</span>: رَجَعُوا.</p></div>"
  12,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنِعَ مِنَّا ٱلۡكَيۡلُ﴾</span>: حُكِمَ بمَنعِه عنّا بعدَ هذه المرَّةِ.</p><p><span class="qpc-hafs">﴿نَكۡتَلۡ﴾</span>: نَحصُلْ على ما نَحْتاج إليه مُقَدَّرًا بالكَيْلِ.</p></div>"
  12,64,""
  12,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعَهُمۡ﴾</span>: أوْعِيتَهم، أو أمتعتَهم.</p><p><span class="qpc-hafs">﴿مَا نَبۡغِي﴾</span>: ماذا نَطْلُبُ أكثرَ من هذا الإكرامِ؟</p><p><span class="qpc-hafs">﴿وَنَمِيرُ أَهۡلَنَا﴾</span>: نَجْلُبُ لهم الطعامَ.</p></div>"
  12,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَوۡثِقࣰا مِّنَ ٱللَّهِ﴾</span>: عَهْدًا، وتُؤَكِّدُوه بالحَلِفِ باللهِ.</p><p><span class="qpc-hafs">﴿يُحَاطَ بِكُمۡ﴾</span>: تُغْلَبُوا، فلا تَسْتطيعوا الإتيانَ به، أو تَهْلِكُوا جميعًا.</p><p><span class="qpc-hafs">﴿وَكِيلࣱ﴾</span>: رقيبٌ مُطَّلعٌ.</p></div>"
  12,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أُغۡنِي عَنكُم﴾</span>: لا أدْفَعُ عنكم.</p><p><span class="qpc-hafs">﴿عَلَيۡهِ تَوَكَّلۡتُ﴾</span>: اعتمَدْتُ على ربي وفَوَّضْتُ أمري إليه.</p></div>"
  12,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاجَةࣰ فِي نَفۡسِ يَعۡقُوبَ﴾</span>: وهي شَفَقَتُه على أولادِه أن تصيبَهم العَيْنُ.</p><p><span class="qpc-hafs">﴿قَضَىٰهَا﴾</span>: أدْرَكَها، ووَصّى أولادَه باتِّقائِها.</p></div>"
  12,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاوَىٰٓ إِلَيۡهِ أَخَاهُ﴾</span>: ضَمَّ إليه شقيقَه بِنْيامينَ.</p><p><span class="qpc-hafs">﴿فَلَا تَبۡتَئِسۡ﴾</span>: فلا تَحْزَنْ.</p></div>"
  12,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسِّقَايَةَ﴾</span>: إناءٌ للشُّرْبِ، وهو هنا المِكيالُ الذي يُكالُ به الطَّعامُ.</p><p><span class="qpc-hafs">﴿أَذَّنَ مُؤَذِّنٌ﴾</span>: نادى مُنادٍ.</p><p><span class="qpc-hafs">﴿ٱلۡعِيرُ﴾</span>: القافلةُ المحمَّلةُ بالطَّعام.</p></div>"
  12,71,""
  12,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُوَاعَ ٱلۡمَلِكِ﴾</span>: المكيالَ الذي يَكيلُ به.</p><p><span class="qpc-hafs">﴿زَعِيمࣱ﴾</span>: ضامِنٌ وكفيلٌ.</p></div>"
  12,73,""
  12,74,""
  12,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَزَ ٰ⁠ٓؤُهُۥ مَن وُجِدَ فِي رَحۡلِهِۦ﴾</span>: عقوبةُ سَرِقَتِه استرقاقُ مَن وُجِدَ المِكْيالُ في مَتاعِه.</p></div>"
  12,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ كِدۡنَا لِيُوسُفَ﴾</span>: يَسَّرْنا له هذا التدبيرَ الخَفِيَّ للتوصُّلِ إلى غَرَضِه.</p><p><span class="qpc-hafs">﴿دِينِ ٱلۡمَلِكِ﴾</span>: شريعةِ مَلِكِ مصرَ.</p></div>"
  12,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَرَّهَا﴾</span>: فأخفى يوسفُ مقالَتَهم التي سَمِعَها مِن نِسْبَتِهم إياه إلى السَّرِقَةِ.</p><p><span class="qpc-hafs">﴿مَّكَانࣰا﴾</span>: مَنزِلَةً.</p></div>"
  12,78,""
  12,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَعَاذَ ٱللَّهِ﴾</span>: نَسْتجيرُ باللّٰهِ ونعتصِمُ به.</p><p><span class="qpc-hafs">﴿مَتَـٰعَنَا﴾</span>: مِكْيالَنا الَّذي نَكِيلُ به الطَّعامَ.</p></div>"
  12,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَيۡـَٔسُواْ مِنۡهُ﴾</span>: يَئِسُوا من إجابةِ يوسفَ لمَطْلبِهم.</p><p><span class="qpc-hafs">﴿خَلَصُواْ﴾</span>: انفردُوا عن الناسِ.</p><p><span class="qpc-hafs">﴿نَجِيࣰّا﴾</span>: مُتَسارِّين يتشاوَرُون بينهم.</p><p><span class="qpc-hafs">﴿مَّوۡثِقࣰا مِّنَ ٱللَّهِ﴾</span>: عَهْدًا وأكّدْتُموه بالحَلِفِ باللهِ.</p><p><span class="qpc-hafs">﴿مَا فَرَّطتُمۡ﴾</span>: قَصَّرْتُم.</p><p><span class="qpc-hafs">﴿فَلَنۡ أَبۡرَحَ ٱلۡأَرۡضَ﴾</span>: لن أُفارِقَ أرضَ مصرَ.</p></div>"
  12,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا كُنَّا لِلۡغَيۡبِ حَـٰفِظِينَ﴾</span>: ولم نَدْرِ حين عاهَدْناك على رَدِّه أنه سيَسْرِقُ.</p></div>"
  12,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡعِيرَ﴾</span>: القافلةَ.</p><p><span class="qpc-hafs">﴿أَقۡبَلۡنَا فِيهَا﴾</span>: عُدْنا فيها.</p></div>"
  12,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَّلَتۡ﴾</span>: زَيَّنَتْ.</p><p><span class="qpc-hafs">﴿فَصَبۡرࣱ جَمِيلٌ﴾</span>: وهو ما لا جَزَعَ فيه، ولا شَكْوى معه لأحدٍ من الخَلْقِ.</p></div>"
  12,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَوَلَّىٰ عَنۡهُمۡ﴾</span>: أعرضَ يعقوبُ عن خِطابِهم.</p><p><span class="qpc-hafs">﴿يَـٰٓأَسَفَىٰ﴾</span>: يا حُزني الشديدَ.</p><p><span class="qpc-hafs">﴿وَٱبۡيَضَّتۡ عَيۡنَاهُ﴾</span>: بذَهابِ سوادِهما، مما أدّى إلى ضَعْف بَصَرِه أو ذَهابِه.</p><p><span class="qpc-hafs">﴿كَظِيمࣱ﴾</span>: ممتلئُ القلب حُزْنًا، يَكْتُمُه ولا يُبْدِيه.</p></div>"
  12,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَفۡتَؤُاْ﴾</span>: لا تَزالُ.</p><p><span class="qpc-hafs">﴿حَرَضًا﴾</span>: مُشرِفًا على الهَلاكِ.</p></div>"
  12,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَثِّي﴾</span>: هَمِّي الشديدَ.</p></div>"
  12,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَحَسَّسُواْ مِن يُوسُفَ﴾</span>: تَعَرَّفُوا وتَطَلَّبُوا خبرَه.</p><p><span class="qpc-hafs">﴿رَّوۡحِ ٱللَّهِ﴾</span>: رحمتِه وفَرَجِه.</p></div>"
  12,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلضُّرُّ﴾</span>: الشِّدَّةُ والجوعُ من الجَدْبِ.</p><p><span class="qpc-hafs">﴿مُّزۡجَىٰةࣲ﴾</span>: رديئةٍ قليلةٍ.</p></div>"
  12,89,""
  12,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنَّ ٱللَّهُ عَلَيۡنَآ﴾</span>: تَفضَّلَ علينا بالسَّلامةِ والاجتماعِ.</p></div>"
  12,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاثَرَكَ ٱللَّهُ عَلَيۡنَا﴾</span>: اختارك وفَضَّلَكَ علينا بما خَصَّكَ به من صفاتِ الكمالِ.</p></div>"
  12,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَثۡرِيبَ﴾</span>: لا تأنيبَ ولا لَوْمَ.</p></div>"
  12,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَأۡتِ بَصِيرࣰا﴾</span>: يَرْجِعُ إليه بَصَرُهُ.</p></div>"
  12,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَصَلَتِ ٱلۡعِيرُ﴾</span>: خرجَتِ القافلةُ من مصرَ قاصدةً الشّامَ.</p><p><span class="qpc-hafs">﴿لَأَجِدُ رِيحَ يُوسُفَ﴾</span>: لَأَشُمُّ رائحتَه.</p><p><span class="qpc-hafs">﴿تُفَنِّدُونِ﴾</span>: تَسْخَرُوا مني وتنسِبُوني إلى العَجْزِ، وضَعْفِ الرأيِ، أو تُكَذِّبوني.</p></div>"
  12,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلِكَ﴾</span>: خَطَئِك وبُعْدِك عن الصوابِ في حُبِّ يوسفَ.</p></div>"
  12,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَشِيرُ﴾</span>: الذي بَشَّرَ يعقوبَ بأنّ يوسفَ حيٌّ.</p></div>"
  12,97,""
  12,98,""
  12,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاوَىٰٓ إِلَيۡهِ أَبَوَيۡهِ﴾</span>: ضَمَّهما وأنزلَهما عنده.</p></div>"
  12,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَفَعَ أَبَوَيۡهِ عَلَى ٱلۡعَرۡشِ﴾</span>: أجْلَسَهما بجانبِه على سريرِ مُلْكِه؛ إكرامًا لهما.</p><p><span class="qpc-hafs">﴿وَخَرُّواْ﴾</span>: هَوى أبوه وإخوتُه إلى الأرضِ.</p><p><span class="qpc-hafs">﴿لَهُۥ سُجَّدࣰا﴾</span>: ساجدين تكريمًا ليوسفَ، على عادتِهم في تحيةِ الملُوك وأشباهِهم.</p><p><span class="qpc-hafs">﴿هَـٰذَا تَأۡوِيلُ رُءۡيَـٰيَ مِن قَبۡلُ﴾</span>: أي: هذا السجودُ تفسيرٌ وتصديقٌ للرؤيا التي رأيتُها في صِغَري.</p><p><span class="qpc-hafs">﴿حَقࣰّا﴾</span>: صِدْقًا، وليسَتْ من أكاذيبِ الأحلامِ.</p><p><span class="qpc-hafs">﴿أَحۡسَنَ بِيٓ﴾</span>: أفاض اللهُ عليَّ من نِعَمِه.</p><p><span class="qpc-hafs">﴿ٱلۡبَدۡوِ﴾</span>: باديةِ الشّامِ.</p><p><span class="qpc-hafs">﴿نَّزَغَ ٱلشَّيۡطَـٰنُ﴾</span>: أفسَدَ وأغوى؛ لأنه هو سببُ الإفسادِ.</p><p><span class="qpc-hafs">﴿لَطِيفࣱ﴾</span>: عليمٌ بخَفايا الأمورِ، مُدَبِّرٌ لها،ومُسَهِّلٌ لصعابِها.</p></div>"
  12,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُلۡكِ﴾</span>: مُلْكِ مِصْرَ.</p><p><span class="qpc-hafs">﴿تَأۡوِيلِ ٱلۡأَحَادِيثِ﴾</span>: تفسير الرُّؤى، وغيرِها من العِلْمِ.</p><p><span class="qpc-hafs">﴿فَاطِرَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: يا خالقَهما ومُبْدِعَهما.</p><p><span class="qpc-hafs">﴿وَلِيِّۦ﴾</span>: مُتَوَلِّي حِفْظي وجميعِ شأني.</p></div>"
  12,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: ما ذُكِرَ من قصةِ يوسفَ وإخوانِه.</p><p><span class="qpc-hafs">﴿وَمَا كُنتَ لَدَيۡهِمۡ﴾</span>: وما كنتَ حاضرًا مع إخوةِ يوسفَ.</p><p><span class="qpc-hafs">﴿أَجۡمَعُوٓاْ أَمۡرَهُمۡ﴾</span>: حينَ دبَّرُوا إلقاءَه في جوفِ البئرِ وظُلْمَتِه.</p><p><span class="qpc-hafs">﴿وَهُمۡ يَمۡكُرُونَ﴾</span>: يَحْتالُون في خُفْيَةٍ؛ لإيقاعِ الأذى والشَّرِّ به.</p></div>"
  12,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّاسِ﴾</span>: مُشْركِي قومِك.</p></div>"
  12,104,""
  12,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَأَيِّن﴾</span>: وكثيرٌ.</p><p><span class="qpc-hafs">﴿مِّنۡ ءَايَةࣲ﴾</span>: من الدلائلِ الدالَّةِ على وحْدانيةِ اللهِ وقدرتِه.</p><p><span class="qpc-hafs">﴿يَمُرُّونَ عَلَيۡهَا﴾</span>: يشاهِدُونها.</p></div>"
  12,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُم مُّشۡرِكُونَ﴾</span>: فهم يَخْلِطُون مع إيمانِهم باللهِ ربًّا الإشراكَ في ألوهيَّتِه وعبادتِه.</p></div>"
  12,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَـٰشِيَةࣱ﴾</span>: عقوبةٌ في الدنيا تَعُمُّهم.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأةً.</p></div>"
  12,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَصِيرَةٍ﴾</span>: يقينٍ وحُجَّةٍ واضحةٍ.</p></div>"
  12,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلِ ٱلۡقُرَىٰٓ﴾</span>: المدنِ والحاضرةِ.</p></div>"
  12,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَيۡـَٔسَ ٱلرُّسُلُ﴾</span>: يَئِسوا من إيمانِ قومِهم.</p><p><span class="qpc-hafs">﴿وَظَنُّوٓاْ أَنَّهُمۡ قَدۡ كُذِبُواْ﴾</span>: وظَنَّ المُرْسَلُ إليهم أن الرُّسَلَ قد كَذَبُوهم فيما أخبرُوهم عن اللهِ.</p><p><span class="qpc-hafs">﴿جَآءَهُمۡ نَصۡرُنَا﴾</span>: جاء نَصْرُنا لرُسِلِنا عند شِدَّةِ الكَرْبِ.</p><p><span class="qpc-hafs">﴿بَأۡسُنَا﴾</span>: عذابُنا.</p></div>"
  12,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِبۡرَةࣱ﴾</span>: عِظَةٌ.</p><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: أصحابِ العقولِ السليمةِ.</p><p><span class="qpc-hafs">﴿مَا كَانَ﴾</span>: أي: هذا القرآنُ.</p><p><span class="qpc-hafs">﴿يُفۡتَرَىٰ﴾</span>: يُخْتَلَقُ.</p><p><span class="qpc-hafs">﴿تَصۡدِيقَ ٱلَّذِي بَيۡنَ يَدَيۡهِ﴾</span>: أي: القرآنُ يَشْهَدُ على صِدْقِ ما تقدَّمه من الكتبِ المنزَّلةِ، وأنها من عندِ اللهِ.</p><p><span class="qpc-hafs">﴿وَتَفۡصِيلَ كُلِّ شَيۡءࣲ﴾</span>: تبيينَ ما يَحْتاجُ إليه العبادُ من أمورِ الدينِ.</p></div>"
