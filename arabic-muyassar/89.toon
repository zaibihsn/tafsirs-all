quran[30]{c,v,t}:
  89,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡفَجۡرِ﴾</span>: أقْسَم اللهُ بِوَقْتِ الفجْرِ.</p></div>"
  89,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَيَالٍ عَشۡرࣲ﴾</span>: هي الليالي العَشْرُ الأُوَلُ مِن ذِي الحِجَّةِ.</p></div>"
  89,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلشَّفۡعِ﴾</span>: كُلُّ شَيءٍ خَلَقَه اللهُ زَوْجًا فهو شَفْعٌ.</p><p><span class="qpc-hafs">﴿وَٱلۡوَتۡرِ﴾</span>: الفَرْدِ.</p></div>"
  89,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡرِ﴾</span>: يَسْرِي بِظَلامِهِ.</p></div>"
  89,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَسَمࣱ﴾</span>: مَقْنَعٌ ومُكْتَفىً في القَسَمِ.</p><p><span class="qpc-hafs">﴿لِّذِي حِجۡرٍ﴾</span>: لِصاحِبِ عَقْلٍ.</p></div>"
  89,6,""
  89,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِرَمَ﴾</span>: قَبِيلةِ إرَمَ.</p><p><span class="qpc-hafs">﴿ذَاتِ ٱلۡعِمَادِ﴾</span>: صاحبةِ القُوُّةِ والأبْنِيَةِ المَرْفُوعَةِ على الأعْمِدَةِ.</p></div>"
  89,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِثۡلُهَا﴾</span>: مِثْلُ تِلْكَ القَبِيلةِ في الطُّولِ والقُوَّةِ.</p></div>"
  89,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَابُواْ﴾</span>: قَطَعُوا.</p><p><span class="qpc-hafs">﴿ٱلصَّخۡرَ﴾</span>: الحَجَرَ العَظِيمَ الصُّلْبَ الَّذِي عَمِلُوا مِنهُ البُيوتَ.</p><p><span class="qpc-hafs">﴿بِٱلۡوَادِ﴾</span>: بِوادِي القُرى.</p></div>"
  89,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِي ٱلۡأَوۡتَادِ﴾</span>: صاحِبِ الجُنُودِ الَّذِين ثَبَّتُوا مُلكَهُ، وقَوَّوا لَهُ أمْرَهُ.</p></div>"
  89,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَوۡاْ﴾</span>: تَجاوَزُوا الحدَّ في الظُّلْمِ.</p></div>"
  89,12,""
  89,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَصَبَّ عَلَيۡهِمۡ﴾</span>: فَغَشّاهُم.</p><p><span class="qpc-hafs">﴿سَوۡطَ عَذَابٍ﴾</span>: عَذابًا شَدِيدا.</p></div>"
  89,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَبِٱلۡمِرۡصَادِ﴾</span>: لا يفُوتُه شَيءٌ مِن أعْمالِ العِبادِ.</p></div>"
  89,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتَلَىٰهُ﴾</span>: اخْتَبَرَهُ.</p><p><span class="qpc-hafs">﴿فَأَكۡرَمَهُۥ﴾</span>: بَسَطَ لَهُ في رِزقِهِ.</p><p><span class="qpc-hafs">﴿وَنَعَّمَهُۥ﴾</span>: جَعَلَه في أطْيَبِ عَيْشٍ.</p></div>"
  89,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتَلَىٰهُ﴾</span>: اخْتَبَرَهُ.</p><p><span class="qpc-hafs">﴿فَقَدَرَ﴾</span>: فَضَيَّقَ.</p><p><span class="qpc-hafs">﴿أَهَـٰنَنِ﴾</span>: أذَلَّنِي بالفَقْرِ.</p></div>"
  89,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمرُ كَما يَظُنُّ هَذا الإنْسانُ.</p><p><span class="qpc-hafs">﴿لَّا تُكۡرِمُونَ﴾</span>: لا تُحْسنُونَ مُعامَلةَ.</p><p><span class="qpc-hafs">﴿ٱلۡيَتِيمَ﴾</span>: الطِّفْلَ الَّذِي ماتَ أبُوهُ وهو صَغِيرٌ.</p></div>"
  89,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَحَـٰٓضُّونَ﴾</span>: ولا يَحثُّ بعضُكُم بعْضًا.</p><p><span class="qpc-hafs">﴿ٱلۡمِسۡكِينِ﴾</span>: المُحْتاجِ الَّذِي لا يَمْلِكُ ما يَكْفِيهِ.</p></div>"
  89,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلتُّرَاثَ﴾</span>: حُقُوقَ الآخرِينَ في الِميراثِ.</p><p><span class="qpc-hafs">﴿لَّمࣰّا﴾</span>: شَدِيدًا، وهو أن يأكُلَ نَصِيبَهُ ونَصِيبَ غَيرِه.</p></div>"
  89,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمࣰّا﴾</span>: كَثِيرًا مُفْرِطًا.</p></div>"
  89,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: لا ينبغِي أن يكُونَ حالُكُم كَما ذُكِر.</p><p><span class="qpc-hafs">﴿دُكَّتِ ٱلۡأَرۡضُ﴾</span>: زُلْزِلَتِ الأرْضُ وكَسَّرَ بَعْضُها بَعْضًا.</p><p><span class="qpc-hafs">﴿دَكࣰّا دَكࣰّا﴾</span>: مَرَّةً بعدَ مَرَّةٍ.</p></div>"
  89,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمَلَكُ﴾</span>: والملائِكةُ.</p><p><span class="qpc-hafs">﴿صَفࣰّا صَفࣰّا﴾</span>: صُفُوفًا صفُوفًا.</p></div>"
  89,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَذَكَّرُ ٱلۡإِنسَـٰنُ﴾</span>: يتَّعِظُ الكافِرُ ويتُوبُ.</p><p><span class="qpc-hafs">﴿وَأَنَّىٰ لَهُ ٱلذِّكۡرَىٰ﴾</span>: ومِن أينَ لَهُ التَّوبةُ؟.</p></div>"
  89,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّمۡتُ﴾</span>: العملَ الصّالحَ.</p><p><span class="qpc-hafs">﴿لِحَيَاتِي﴾</span>: في الآخِرةِ.</p></div>"
  89,25,""
  89,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُوثِقُ﴾</span>: ولا يَشُدُّ ويَربِطُ للعذابِ.</p><p><span class="qpc-hafs">﴿وَثَاقَهُۥٓ﴾</span>: رَبْطَهُ بالسَّلاسِلِ ونَحْوِها للعذابِ.</p></div>"
  89,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُطۡمَئِنَّةُ﴾</span>: الموقِنَةُ بِأنّ اللهَ ربُّها، المطيعةُ لَهُ.</p></div>"
  89,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَاضِيَةࣰ﴾</span>: بالثَّوابِ.</p><p><span class="qpc-hafs">﴿مَّرۡضِيَّةࣰ﴾</span>: مَرْضِيًّا عَنكِ.</p></div>"
  89,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي عِبَـٰدِي﴾</span>: مَعَ عِبادِي، وقيل: في جُمْلةِ عِبادِي الصّالحِينَ المُطِيعِينَ.</p></div>"
  89,30,""
