quran[56]{c,v,t}:
  74,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُدَّثِّرُ﴾</span>: المتَغَطِّي بِثِيابِهِ.</p></div>"
  74,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُمۡ﴾</span>: أي مِن مَّضْجَعِكَ.</p><p><span class="qpc-hafs">﴿فَأَنذِرۡ﴾</span>: فَحَذِّر النّاس مِن عَذابِ اللهِ.</p></div>"
  74,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَبَّكَ فَكَبِّرۡ﴾</span>: وخُصَّ رَبَّكَ وحْدَهُ بالتَّعْظِيمِ والعِبادَةِ.</p></div>"
  74,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَثِيَابَكَ فَطَهِّرۡ﴾</span>: أي مِنَ النَّجاساتِ.</p></div>"
  74,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ﴾</span>: ودُمْ على هَجْر أعْمالِ الشِّرْكِ كُلِّها.</p></div>"
  74,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ﴾</span>: ولا تُعْطِ العَطِيَّةَ؛ كَي تَلْتَمِسَ أكْثَرَ مِنها.</p></div>"
  74,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِرَبِّكَ فَٱصۡبِرۡ﴾</span>: ولِمَرْضاةِ رَبِّكَ فاصْبِرْ عَلى الأَوامِرِ والنَّواهِي.</p></div>"
  74,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُقِرَ﴾</span>: نُفِخَ نَفْخَةَ البعثِ والنُّشُورِ.</p><p><span class="qpc-hafs">﴿ٱلنَّاقُورِ﴾</span>: القَرْنِ الَّذِي يُنْفَخُ فِيهِ.</p></div>"
  74,9,""
  74,10,""
  74,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرۡنِي وَمَنۡ خَلَقۡتُ وَحِيدࣰا﴾</span>: دَعْنِي -أيُّها الرَّسُولُ- أنا والَّذِي خَلَقْتُه في بَطْنِ أُمِّهِ وحِيدًا لا مالَ لَهُ ولا ولدَ.</p></div>"
  74,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّمۡدُودࣰا﴾</span>: مبسُوطًا واسِعًا.</p></div>"
  74,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُهُودࣰا﴾</span>: حاضِرِينَ مَعَهُ في «مكَّةَ» لا يغِيبُونَ عَنْهُ.</p></div>"
  74,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَهَّدتُّ لَهُۥ﴾</span>: ويَسَّرتُ لَهُ سُبُلَ العيشِ.</p></div>"
  74,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡ أَزِيدَ﴾</span>: أي في مالِهِ ووَلَدِهِ.</p></div>"
  74,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: ليس الأمرُ كما يَزْعُمُ.</p><p><span class="qpc-hafs">﴿لِـَٔايَـٰتِنَا﴾</span>: للقرآنِ.</p><p><span class="qpc-hafs">﴿عَنِيدࣰا﴾</span>: معانِدًا مُكَذِّبًا.</p></div>"
  74,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَأُرۡهِقُهُۥ﴾</span>: سَأُكَلِّفُه.</p><p><span class="qpc-hafs">﴿صَعُودًا﴾</span>: مَشَقَّةً مِنَ العذابِ.</p></div>"
  74,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَّرَ﴾</span>: في نَفْسِهِ.</p><p><span class="qpc-hafs">﴿وَقَدَّرَ﴾</span>: وهَيَّأ ما يقُولُه مِنَ الطَّعنِ في مُحَمَّدٍ ﷺ والقرآنِ.</p></div>"
  74,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقُتِلَ﴾</span>: فَلُعِنَ، واسْتَحَقَّ بِذَلِكَ الهَلاكَ.</p><p><span class="qpc-hafs">﴿كَيۡفَ قَدَّرَ﴾</span>: كَيفَ أعَدَّ في نفسهِ هَذا الطَّعْنَ.</p></div>"
  74,20,""
  74,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَظَرَ﴾</span>: تَأَمَّلَ فيما قَدَّرَ وهَيَّأَ مِنَ الطَّعْنِ في القرآنِ.</p></div>"
  74,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبَسَ﴾</span>: قَطَّبَ وجْهَهُ.</p><p><span class="qpc-hafs">﴿وَبَسَرَ﴾</span>: واشْتَدَّ في العُبُوسِ.</p></div>"
  74,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَدۡبَرَ﴾</span>: رَجَعَ مُعْرِضًا عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿وَٱسۡتَكۡبَرَ﴾</span>: وتَعاظَمَ أن يَعْتَرِفَ بِهِ.</p></div>"
  74,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنۡ هَـٰذَآ﴾</span>: ما الَّذِي يَقُولُه مُحَمَّدٌ.</p><p><span class="qpc-hafs">﴿يُؤۡثَرُ﴾</span>: يُنْقلُ عَنِ الأوّلِينَ.</p></div>"
  74,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوۡلُ ٱلۡبَشَرِ﴾</span>: كلامُ المخلُوقيِنَ، تَعَلَّمَهُ مُحَمَّدٌ مِنهُم، ثُمَّ ادَّعى أنَّهُ مِن عندِ اللهِ.</p></div>"
  74,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَأُصۡلِيهِ﴾</span>: سَأُدْخِلُهُ.</p><p><span class="qpc-hafs">﴿سَقَرَ﴾</span>: جَهَنَّمَ.</p></div>"
  74,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وما أعلَمَكَ.</p><p><span class="qpc-hafs">﴿مَا سَقَرُ﴾</span>: أيُّ شَيءٍ جَهَنَّمُ؟</p></div>"
  74,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُبۡقِي﴾</span>: لا تَتْرُكُ مِن أجْزاءِ المُعَذَّبِينَ شَيئًا.</p><p><span class="qpc-hafs">﴿وَلَا تَذَرُ﴾</span>: ولا تَتْرُكُ مَن فيها مَيِّتًا، ولَكِنَّها تُحْرِقُهُم كُلَّما جُدِّدَ خَلْقُهُم.</p></div>"
  74,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوَّاحَةࣱ﴾</span>: حَرّاقَةٌ، مُغيِّرةٌ، مُسَوِّدةٌ.</p><p><span class="qpc-hafs">﴿لِّلۡبَشَرِ﴾</span>: للجُلودِ، مُفْردُها: بَشَرةٌ.</p></div>"
  74,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَيۡهَا﴾</span>: يَلِي أمَر جَهَنَّمَ ويَتَسَلَّطُ على أهْلِها بالعَذابِ.</p><p><span class="qpc-hafs">﴿تِسۡعَةَ عَشَرَ﴾</span>: مَلَكًا مِنَ الزَّبانِيَةِ الأَشِداءِ.</p></div>"
  74,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبَ ٱلنَّارِ﴾</span>: خَزَنَةَ النّارِ.</p><p><span class="qpc-hafs">﴿عِدَّتَهُمۡ﴾</span>: ذِكْرَ عَدَدِهِم.</p><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: اخْتِبارًا.</p><p><span class="qpc-hafs">﴿لِيَسۡتَيۡقِنَ﴾</span>: وليَحْصُلَ اليقِينُ.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ أُوتُواْ ٱلۡكِتَـٰبَ﴾</span>: اليهُودُ والنَّصارى.</p><p><span class="qpc-hafs">﴿وَلَا يَرۡتَابَ﴾</span>: ولا يَشُكَّ.</p><p><span class="qpc-hafs">﴿مَّرَضࣱ﴾</span>: نِفاقٌ.</p><p><span class="qpc-hafs">﴿مَاذَآ أَرَادَ ٱللَّهُ بِهَـٰذَا مَثَلࣰا﴾</span>: ما الَّذِي أرادَهُ اللهُ بِهذا العَدَدِ؟</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: بِمِثْلِ ذَلِكَ الَّذِي ذُكِرَ.</p><p><span class="qpc-hafs">﴿جُنُودَ رَبِّكَ﴾</span>: عَدَدَهُم.</p><p><span class="qpc-hafs">﴿هِيَ﴾</span>: النّارُ.</p><p><span class="qpc-hafs">﴿ذِكۡرَىٰ﴾</span>: تَذْكِرَةٌ ومَوْعِظَةٌ.</p></div>"
  74,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمرُ كَما ذَكَرُوا.</p></div>"
  74,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذۡ أَدۡبَرَ﴾</span>: حِينَ ولّى وذَهَبَ.</p></div>"
  74,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡفَرَ﴾</span>: أضاءَ.</p></div>"
  74,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهَا﴾</span>: إنَّ النّارَ.</p><p><span class="qpc-hafs">﴿ٱلۡكُبَرِ﴾</span>: العَظائِمِ.</p></div>"
  74,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَذِيرࣰا﴾</span>: إنْذارًا وتَخْوِيفًا.</p></div>"
  74,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَقَدَّمَ﴾</span>: يَتَقَرَّبَ إلى رَبِّهِ بِفِعْلِ الطّاعاتِ.</p><p><span class="qpc-hafs">﴿أَوۡ يَتَأَخَّرَ﴾</span>: بِفِعْلِ المعاصِي.</p></div>"
  74,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا كَسَبَتۡ﴾</span>: مِن أعْمالِ الخيرِ والشَّرِ.</p><p><span class="qpc-hafs">﴿رَهِينَةٌ﴾</span>: مَحْبُوسَةٌ مَرْهُوَنةٌ بِكَسْبِها.</p></div>"
  74,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّآ أَصۡحَـٰبَ ٱلۡيَمِينِ﴾</span>: وهم المسْلِمُونَ المخلِصُونَ.</p></div>"
  74,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَسَآءَلُونَ﴾</span>: يَسْأَلُ بَعْضُهُم بَعْضًا.</p></div>"
  74,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنِ ٱلۡمُجۡرِمِينَ﴾</span>: عَنِ الكافِرِينَ الَّذينَ أجْرمُوا في حَقِّ أنْفُسِهِم.</p></div>"
  74,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا سَلَكَكُمۡ﴾</span>: ما الَّذِي أدْخَلَكُم.</p><p><span class="qpc-hafs">﴿سَقَرَ﴾</span>: جَهَنَّمَ.</p></div>"
  74,43,""
  74,44,""
  74,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَخُوضُ﴾</span>: نَتَحَدَّثُ بالباطِلِ.</p><p><span class="qpc-hafs">﴿مَعَ ٱلۡخَآئِضِينَ﴾</span>: مَعَ أهْلِ الضَّلالةِ.</p></div>"
  74,46,""
  74,47,""
  74,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَفَـٰعَةُ﴾</span>: طَلَبُ قَضاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المَشْفُوعِ عنْدَهُ.</p><p><span class="qpc-hafs">﴿ٱلشَّـٰفِعِينَ﴾</span>: الملائِكَةِ والنَّبِيِّينَ وغَيرِهِم.</p></div>"
  74,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا لَهُمۡ﴾</span>: فما لِهؤُلاءِ المشْرِكِينَ.</p><p><span class="qpc-hafs">﴿عَنِ ٱلتَّذۡكِرَةِ﴾</span>: عَنِ القُرآنِ وما فِيهِ مِنَ المواعِظِ.</p><p><span class="qpc-hafs">﴿مُعۡرِضِينَ﴾</span>: مُنْصَرِفِينَ.</p></div>"
  74,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُمُرࣱ﴾</span>: حُمُرٌ وحْشِيِّةٌ.</p><p><span class="qpc-hafs">﴿مُّسۡتَنفِرَةࣱ﴾</span>: شَدِيَدُة النِّفارِ.</p></div>"
  74,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَسۡوَرَةِۭ﴾</span>: أسَدٍ كاسِرٍ.</p></div>"
  74,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُحُفࣰا﴾</span>: كُتُبًا.</p><p><span class="qpc-hafs">﴿مُّنَشَّرَةࣰ﴾</span>: مَفْتُوحَةً مَقْرُوءَةً.</p></div>"
  74,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمرُ كَما زَعَمُوا.</p><p><span class="qpc-hafs">﴿لَّا يَخَافُونَ ٱلۡـَٔاخِرَةَ﴾</span>: لا يُصَدِّقُونَ بالبَعْثِ والجزاءِ.</p></div>"
  74,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: حَقًّا.</p><p><span class="qpc-hafs">﴿إِنَّهُۥ﴾</span>: إنَّ القُرآنَ.</p><p><span class="qpc-hafs">﴿تَذۡكِرَةࣱ﴾</span>: مَوْعِظَةٌ بَلِيغَةٌ كافِيَةٌ لاتِّعاظِهِم.</p></div>"
  74,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَكَرَهُۥ﴾</span>: اتَّعظَ بِما فِيهِ وانْتَفَعَ بِهُداهُ.</p></div>"
  74,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يَذۡكُرُونَ﴾</span>: وما يَتَّعِظُونَ بِه.</p><p><span class="qpc-hafs">﴿أَهۡلُ ٱلتَّقۡوَىٰ﴾</span>: المسْتَحِقُّ لِأَن يُتَّقى ويُطاعَ.</p><p><span class="qpc-hafs">﴿وَأَهۡلُ ٱلۡمَغۡفِرَةِ﴾</span>: والجديرُ بأن يَغْفِرَ لِمَن آمنَ بِهِ وأطاعَهُ.</p></div>"
