quran[20]{c,v,t}:
  90,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَآ أُقۡسِمُ بِهَـٰذَا ٱلۡبَلَدِ﴾</span>: أقْسَمَ اللهُ بِهذا البَلَدِ الحَرامِ، وهو «مَكَّةُ».</p></div>"
  90,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِلُّۢ بِهَـٰذَا ٱلۡبَلَدِ﴾</span>: مُقِيمٌ في هذا البلدِ الحرامِ. أو حَلالٌ يَحِلُّ لَكَ القِتالُ فِيه ساعَةً من نَّهارِ يَومِ فتحِ مَكَّةَ.</p></div>"
  90,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوَالِدࣲ﴾</span>: آدمَ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿وَمَا وَلَدَ﴾</span>: وما تَناسَلَ مِنهُ مِن ولَدٍ.</p></div>"
  90,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي كَبَدٍ﴾</span>: في شِدَّةٍ وعَناءٍ مِن مُّكابَدَةِ الدُّنيا.</p></div>"
  90,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحۡسَبُ﴾</span>: أيَظُنُّ بِما جَمَعَهُ مِن مالٍ.</p></div>"
  90,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلَكۡتُ﴾</span>: أنفَقْتُ.</p><p><span class="qpc-hafs">﴿لُّبَدًا﴾</span>: كَثِيرًا.</p></div>"
  90,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحۡسَبُ﴾</span>: أيَظُنُّ في فِعْلِهِ هَذا.</p><p><span class="qpc-hafs">﴿أَن لَّمۡ يَرَهُۥٓ أَحَدٌ﴾</span>: أنَّ اللهَ عَزَّ وجَلَّ لا يراهُ، ولا يحاسِبُهُ على الصَّغِيرِ والكَبِيرِ.</p></div>"
  90,8,""
  90,9,""
  90,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَدَيۡنَـٰهُ ٱلنَّجۡدَيۡنِ﴾</span>: وبيَّنّا لَهُ سَبيلَي الخيرِ والشَّرِّ؟</p></div>"
  90,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا ٱقۡتَحَمَ ٱلۡعَقَبَةَ﴾</span>: فَهَلّا تَجاوَزَ مَشَقَّةَ الآخِرةِ بإنفاقِ مالِه، فَيأمَنَ.</p></div>"
  90,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعْلَمَكَ؟.</p><p><span class="qpc-hafs">﴿مَا ٱلۡعَقَبَةُ﴾</span>: ما مَشَقَّةُ الآخِرَةِ، وما يُعِينُ عَلى تَجاوُزِها؟</p></div>"
  90,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكُّ رَقَبَةٍ﴾</span>: عِتْقُ رَقَبَةٍ مُؤْمِنَةٍ مِن أسْرِ الرِّقِ.</p></div>"
  90,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِي مَسۡغَبَةࣲ﴾</span>: صاحِبِ مجاعَةٍ شَدِيدَةٍ.</p></div>"
  90,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَا مَقۡرَبَةٍ﴾</span>: مِن ذَويِ القرابةِ.</p></div>"
  90,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ مِسۡكِينࣰا ذَا مَتۡرَبَةࣲ﴾</span>: أو فَقِيرًا مُعْدَمًا لا شَيءَ عِنْدَهُ.</p></div>"
  90,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَوَاصَوۡاْ﴾</span>: وأَوْصى بعضُهُم بَعْضًا.</p><p><span class="qpc-hafs">﴿بِٱلۡمَرۡحَمَةِ﴾</span>: بالرَّحْمَةِ بالخلقِ.</p></div>"
  90,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡمَيۡمَنَةِ﴾</span>: هُمْ أصْحابُ اليمِينِ، الَّذِينَ يُؤخذُ بِهم يومَ القيامةِ ذاتَ اليمِينِ إلى الجنَّةِ.</p></div>"
  90,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بالقُرْآنِ</p><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ﴾</span>: الَّذِينَ يُؤخَذُ بِهم يومَ القيامِة ذاتَ الشِّمالِ إلى النّار.</p></div>"
  90,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّؤۡصَدَةُۢ﴾</span>: مُطْبَقةٌ مُغْلَقَةٌ عَلَيهِم.</p></div>"
