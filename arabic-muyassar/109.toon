quran[6]{c,v,t}:
  109,1,""
  109,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَآ أَعۡبُدُ مَا تَعۡبُدُونَ﴾</span>: لا تَحصُلُ منِّي عِبادَةُ ما تَعْبُدُونَ مِنَ الأصْنامِ والآلِهَةَ الزّائِفَةِ.</p></div>"
  109,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَنتُمۡ عَـٰبِدُونَ مَآ أَعۡبُدُ﴾</span>: وما أنتُم عابِدُونَ في المسْتَقْبَلِ ما أعْبُدُ مِن إلهٍ واحدٍ، هُوَ اللهُ رَبُّ العالمَينَ المُسْتَحِقُّ وحْدَهُ لِلعِبادةِ.</p></div>"
  109,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَنَا۠ عَابِدࣱ مَّا عَبَدتُّمۡ﴾</span>: ولا أنا عابِدٌ ما عبدتُم مِنَ الأصْنامِ والآلِهَةِ الباطِلةِ فيما مَضى مِنَ الأزْمانِ.</p></div>"
  109,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَنتُمۡ عَـٰبِدُونَ مَآ أَعۡبُدُ﴾</span>: ولا أنتُم عابِدُونَ مُسْتَقْبلًا ما أعْبُدُ.</p></div>"
  109,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكُمۡ دِينُكُمۡ﴾</span>: الَّذِي أصْرَرْتُم على اتِّباعِهِ، يختصُّ بِكُم وأنا بَرِيءٌ مِنهُ.</p><p><span class="qpc-hafs">﴿وَلِيَ دِينِ﴾</span>: الَّذِي أنا مُخْتَصٌّ بِهِ لا تَشْرَكُونِي فِيه، ولَيسَ في الآيةِ إقْرارٌ لِدِينِهِم.</p></div>"
