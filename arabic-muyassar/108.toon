quran[3]{c,v,t}:
  108,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكَوۡثَرَ﴾</span>: الخيرَ الكَثِيرَ في الدُّنيا والآخِرَةِ، ومِن ذَلِكَ نَهرُ الكَوْثَرِ في الجنَّةِ.</p></div>"
  108,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱنۡحَرۡ﴾</span>: واذْبَحْ ذَبيحَتكَ للهِ.</p></div>"
  108,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَانِئَكَ﴾</span>: مُبْغِضَكَ.</p><p><span class="qpc-hafs">﴿هُوَ ٱلۡأَبۡتَرُ﴾</span>: هُوَ المُنْقَطِعُ أثَرُهُ، المقطُوعُ مِن كُلِّ خَيرٍ.</p></div>"
