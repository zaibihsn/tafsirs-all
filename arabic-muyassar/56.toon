quran[96]{c,v,t}:
  56,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَاقِعَةُ﴾</span>: القِيامَةُ.</p></div>"
  56,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَاذِبَةٌ﴾</span>: لا يَكُونُ عِنْدَ وُقُوعِها تَكْذِيبٌ.</p></div>"
  56,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَافِضَةࣱ رَّافِعَةٌ﴾</span>: هي خافِضَةٌ يَحْصُلُ عِنْدَها خَفْضُ أقْوامٍ كانُوا مُرْتَفِعِينَ ورَفْعُ أقْوامٍ كانُوا مُنْخَفِضِينَ، وخافِضَةُ جِهاتٍ كانَتْ مُرْتَفِعَةً كالجِبالِ والصَّوامِعِ، رافِعَةٌ ما كانَ مُنْخَفِضًا بِسَبَبِ ما يَحْدُثُ في الكَونِ.</p></div>"
  56,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُجَّتِ﴾</span>: اضْطَرَبَتْ، بِسَبَبِ الزَّلازِلِ والخَسْفِ ونَحْوِ ذَلِكَ.</p></div>"
  56,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبُسَّتِ﴾</span>: فُتِّتَتِ الجبالُ ونُسِفَتْ.</p></div>"
  56,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَبَآءࣰ﴾</span>: ما يَلُوحُ في خُيُوطِ شُعاعِ الشَّمسِ مِن دَقِيقِ الغُبارِ.</p><p><span class="qpc-hafs">﴿مُّنۢبَثࣰّا﴾</span>: مُتَفَرِّقًا.</p></div>"
  56,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا﴾</span>: أصْنافًا.</p></div>"
  56,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡمَيۡمَنَةِ﴾</span>: هُمُ الَّذِينَ يُجْعَلُونَ في الجِهَةِ اليُمْنى فِي الجَنَّةِ أوْ فِي الَمحْشَرِ.</p></div>"
  56,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ﴾</span>: أصْحابُ الشَّقاوَةِ الَّذِينَ يُؤْخَذُ بِهِم ذاتَ الشِّمال إلى النّارِ.</p></div>"
  56,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلسَّـٰبِقُونَ﴾</span>: إلى الخَيْراتِ.</p><p><span class="qpc-hafs">﴿ٱلسَّـٰبِقُونَ﴾</span>: إلى مُنْتَهى الفَضْلِ والرِّفْعَةِ.</p></div>"
  56,11,""
  56,12,""
  56,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُلَّةࣱ﴾</span>: جَماعةٌ.</p></div>"
  56,14,""
  56,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُرُرࣲ﴾</span>: جَمْعُ سَرِيرٍ، وهو مَجِلِسُ العُظَماءِ والمُلُوكِ أيْضًا.</p><p><span class="qpc-hafs">﴿مَّوۡضُونَةࣲ﴾</span>: مَسْبُوكٍ بَعْضُها بِبَعْضٍ.</p></div>"
  56,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَقَـٰبِلِينَ﴾</span>: يَجْلِسُ بَعْضُهُم مُقابِلَ بَعْضٍ، وذَلِكَ مِن تَمامِ النَّعِيمِ لمِا فِيهِ مِنَ الأُنْسِ بِمُشاهَدَةِ الأَصْحابِ والحَدِيثِ مَعَهُم.</p></div>"
  56,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَطُوفُ﴾</span>: يَدُورُ عَلى نَحْوٍ دائِمٍ.</p><p><span class="qpc-hafs">﴿مُّخَلَّدُونَ﴾</span>: أي دائِمُونَ عَلى الطَّوافِ عَلَيهِم ومُناوَلَتِهِم.</p></div>"
  56,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَكۡوَابࣲ﴾</span>: جَمْعُ كُوبٍ، وهو إناءُ الخمْرِ.</p><p><span class="qpc-hafs">﴿وَأَبَارِيقَ﴾</span>: جَمْعِ إبْريقٍ، وهو إناءٌ تُحْمَلُ فِيهِ الخمْرُ فتُصَبُّ في الأكْوابِ.</p><p><span class="qpc-hafs">﴿وَكَأۡسࣲ﴾</span>: هو إناءٌ للخَمْرِ كاْلكُوبِ.</p><p><span class="qpc-hafs">﴿مَّعِينࣲ﴾</span>: هو الجارِي، والمُرادُ بِهِ الخَمْرُ الَّتِي لِكَثْرَتِها تَجْرِي ولَيسَتْ عَزِيَزةً كَما هِي في الدُّنيا.</p></div>"
  56,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يُصَدَّعُونَ﴾</span>: لا يُصِيبُهُم صُداعُ الرَّأْسِ.</p><p><span class="qpc-hafs">﴿وَلَا يُنزِفُونَ﴾</span>: أي لا يَعْتَرِيهِم اخْتِلاطُ العَقْلِ.</p></div>"
  56,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَخَيَّرُونَ﴾</span>: يَخْتارُونَهُ ويَشْتَهُونَهُ.</p></div>"
  56,21,""
  56,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحُورٌ﴾</span>: نِساءٌ ذَواتُ حَوَرٍ أي: نِساءٌ شَدِيداتُ بياضِ العَينِ وسَوادِها.</p><p><span class="qpc-hafs">﴿عِينࣱ﴾</span>: واسِعاتُ العُيُونِ.</p></div>"
  56,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَمۡثَـٰلِ﴾</span>: كأشْباهِ.</p><p><span class="qpc-hafs">﴿ٱللُّؤۡلُوِٕ﴾</span>: الدُّرِّ.</p><p><span class="qpc-hafs">﴿ٱلۡمَكۡنُونِ﴾</span>: المَخْزُونِ المُخَبَّأِ لِنَفاسَتِهِ.</p></div>"
  56,24,""
  56,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَغۡوࣰا﴾</span>: هُوَ الكَلامُ الَّذِي لا يُعْتَدُّ بِهِ.</p><p><span class="qpc-hafs">﴿تَأۡثِيمًا﴾</span>: هُوَ اللَّومُ والإنْكارُ.</p></div>"
  56,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَـٰمࣰا سَلَـٰمࣰا﴾</span>: سَلَّمْنا سَلامًا إثْرَ سَلامٍ.</p></div>"
  56,27,""
  56,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِدۡرࣲ﴾</span>: شَجَرٍ مِن شَجَرِ العِضاه، ذِي ورَقٍ عَرِيضٍ مُدَوَّرٍ.</p><p><span class="qpc-hafs">﴿مَّخۡضُودࣲ﴾</span>: أُزِيلَ شَوْكُهُ.</p></div>"
  56,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَطَلۡحࣲ﴾</span>: شَجَرٍ مِن شَجَرِ العِضاه، واحدُه طَلْحةٌ، كَثِيرَةُ الظِّلِّ مِن التِفافِ أغْصانِها.</p><p><span class="qpc-hafs">﴿مَّنضُودࣲ﴾</span>: مُتَراصٍّ مُتَراكِبٍ بالأغْصانِ.</p></div>"
  56,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَظِلࣲّ مَّمۡدُودࣲ﴾</span>: لا يَتَقَلَّصُ كَظِلِّ الدُّنيا.</p></div>"
  56,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآءࣲ مَّسۡكُوبࣲ﴾</span>: مَصبُوبٍ.</p></div>"
  56,32,""
  56,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا مَقۡطُوعَةࣲ وَلَا مَمۡنُوعَةࣲ﴾</span>: دائِمَةٍ مَبْذُولَةٍ لَهُم.</p></div>"
  56,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفُرُشࣲ﴾</span>: جَمْعُ فِراشٍ، وهو ما يُفْرَشُ.</p><p><span class="qpc-hafs">﴿مَّرۡفُوعَةٍ﴾</span>: عَلى الأَسِرَّةِ.</p></div>"
  56,35,""
  56,36,""
  56,37,""
  56,38,""
  56,39,""
  56,40,""
  56,41,""
  56,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَمُومࣲ﴾</span>: هي الرِّيحُ الشَّدِيدَةُ الحَرارةِ.</p><p><span class="qpc-hafs">﴿وَحَمِيمࣲ﴾</span>: هو الماءُ الشَّديدُ الحَرارةِ.</p></div>"
  56,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَحۡمُومࣲ﴾</span>: الدُّخانِ الأَسْوَدِ.</p></div>"
  56,44,""
  56,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتۡرَفِينَ﴾</span>: ذوي نِعْمَةٍ واسِعةٍ.</p></div>"
  56,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُصِرُّونَ﴾</span>: يَثْبُتُونَ عَلَيهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحِنثِ﴾</span>: الذَّنبِ والمَعْصِيَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَظِيمِ﴾</span>: القَوِيِّ في نَوْعِهِ، وهو الشِّركُ.</p></div>"
  56,47,""
  56,48,""
  56,49,""
  56,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَجۡمُوعُونَ﴾</span>: يُبْعَثُونَ ويُحْشَرُونَ جَمِيعًا.</p></div>"
  56,51,""
  56,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرࣲ مِّن زَقُّومࣲ﴾</span>: شَجَرَةٍ كَرِيهَةِ الرّائِحَةِ يُنبتُها اللهُ في جَهَنَّمَ.</p></div>"
  56,53,""
  56,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَمِيمِ﴾</span>: هُوَ الماءُ الشَّدِيدُ الغَلَيانِ.</p></div>"
  56,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡهِيمِ﴾</span>: جَمْعُ أهْيَمَ، وهُوَ البَعِيرُ الَّذِي أصابَهُ الهُيامُ، وهو داءُ يُصُيِبُ الإبِلَ فلا تَزالُ تَشْرَبُ ولا تَرْوى.</p></div>"
  56,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُزُلُهُمۡ﴾</span>: النُّزُلُ هو ما يُقَدَّمُ للضَّيفِ مِن طَعامٍ.</p></div>"
  56,57,""
  56,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُمۡنُونَ﴾</span>: ما يَكُونُ مِنكُم مِن الَمنِيِّ.</p></div>"
  56,59,""
  56,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ﴾</span>: قَضَيْنا عَلَيكُم بِالمَوْتِ أوْ سَوَّينا بَينَكُم في الموتِ.</p><p><span class="qpc-hafs">﴿بِمَسۡبُوقِينَ﴾</span>: بِمَغْلُوبِينَ.</p></div>"
  56,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّبَدِّلَ أَمۡثَـٰلَكُمۡ﴾</span>: نُغَيِّرَ خَلْقَكُم.</p><p><span class="qpc-hafs">﴿فِي مَا لَا تَعۡلَمُونَ﴾</span>: مِنَ الصِّفاتِ والأحْوال.</p></div>"
  56,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّشۡأَةَ ٱلۡأُولَىٰ﴾</span>: خَلْقَ اللهِ إياكُم ولَمْ تكُونُوا شَيئًا مَذْكُورًا.</p></div>"
  56,63,""
  56,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَزۡرَعُونَهُۥٓ﴾</span>: تُنْبِتُونَهُ.</p></div>"
  56,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُطَـٰمࣰا﴾</span>: يابِسًا هَشِيمًا لا يُنْتَفعُ بِهِ.</p><p><span class="qpc-hafs">﴿فَظَلۡتُمۡ﴾</span>: فصِرْتُمْ.</p><p><span class="qpc-hafs">﴿تَفَكَّهُونَ﴾</span>: تَعْجَبُونَ مِن يُبْسِهِ بَعْدَ خُضْرَتِهِ.</p></div>"
  56,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا لَمُغۡرَمُونَ﴾</span>: لَمُلْزَمُونَ غَرامَةَ ما أنْفَقْنا.</p></div>"
  56,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَحۡرُومُونَ﴾</span>: من الرِّزقِ.</p></div>"
  56,68,""
  56,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُزۡنِ﴾</span>: السَّحابِ.</p></div>"
  56,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُجَاجࣰا﴾</span>: شَدِيدَ المُلُوحَةِ.</p></div>"
  56,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُورُونَ﴾</span>: تُوقِدُونَ.</p></div>"
  56,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرَتَهَآ﴾</span>: الَّتِي تُقْدَحُ مِنها النّارُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنشِـُٔونَ﴾</span>: الخالِقُونَ.</p></div>"
  56,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَذۡكِرَةࣰ﴾</span>: تَذْكِيرًا لَكُم بِنارِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿وَمَتَـٰعࣰا﴾</span>: ومَنفَعَةً.</p><p><span class="qpc-hafs">﴿لِّلۡمُقۡوِينَ﴾</span>: لِلْمُسافِريِنَ.</p></div>"
  56,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَبِّحۡ﴾</span>: فنَزِّهْ.</p></div>"
  56,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ﴾</span>: بِمَساقِطِ النُّجُومِ في مَغارِبِها في السَّماءِ.</p></div>"
  56,76,""
  56,77,""
  56,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّكۡنُونࣲ﴾</span>: مَصُونٍ مَسْتُورٍ، وهو الكِتابُ الَّذِي بأيدِي الملائِكةِ.</p></div>"
  56,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُطَهَّرُونَ﴾</span>: هُمُ المَلائِكةُ الَّذِينَ طَهَّرَهُم اللهُ مِنَ الآفاتِ والذُّنُوبِ.</p></div>"
  56,80,""
  56,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَدِيثِ﴾</span>: القرآنِ.</p><p><span class="qpc-hafs">﴿مُّدۡهِنُونَ﴾</span>: مُكَذِّبُونَ.</p></div>"
  56,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِزۡقَكُمۡ﴾</span>: شُكْرَكُم لِنِعَمِ اللهِ عَلَيكُم.</p></div>"
  56,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَآ﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿بَلَغَتِ﴾</span>: أي النَّفْسُ.</p><p><span class="qpc-hafs">﴿ٱلۡحُلۡقُومَ﴾</span>: الحَلْقَ.</p></div>"
  56,84,""
  56,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَحۡنُ أَقۡرَبُ إِلَيۡهِ مِنكُمۡ﴾</span>: بِمَلائِكَتِنا ولَكِنَّكُم لا تَرَونَهُم.</p></div>"
  56,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَآ﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿غَيۡرَ مَدِينِينَ﴾</span>: غَيرَ مُحاسَبِينَ ولا مَجْزِيِّينَ بِأَعْمالِكُم.</p></div>"
  56,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡجِعُونَهَآ﴾</span>: تَرُدُّونَ النَّفْسَ.</p></div>"
  56,88,""
  56,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَوۡحࣱ﴾</span>: فَلَهُ رَحْمَةٌ وفَرَحٌ عِنْدَ مَوتِهِ.</p><p><span class="qpc-hafs">﴿وَرَيۡحَانࣱ﴾</span>: مُسْتَراحٌ.</p></div>"
  56,90,""
  56,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَلَـٰمࣱ لَّكَ﴾</span>: فسَلامةٌ لَكَ وأَمْنٌ.</p></div>"
  56,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنُزُلࣱ﴾</span>: فَضِيافَةٌ.</p><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: شَرابِ جَهَنَّمَ المَغْلِيِّ.</p></div>"
  56,93,""
  56,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَصۡلِيَةُ﴾</span>: وإدْخالٌ لِيُقاسِيَ الحرَّ.</p></div>"
  56,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقُّ ٱلۡيَقِينِ﴾</span>: اليَقِينُ حقًا.</p></div>"
  56,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَبِّحۡ﴾</span>: فَنَزِّهْ.</p></div>"
