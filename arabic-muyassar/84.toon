quran[25]{c,v,t}:
  84,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنشَقَّتۡ﴾</span>: تَصَدَّعتْ يومَ القِيامَةِ.</p></div>"
  84,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَذِنَتۡ لِرَبِّهَا﴾</span>: وأَطاعَتْ أمْرَ رَبِّها.</p><p><span class="qpc-hafs">﴿وَحُقَّتۡ﴾</span>: وحُقَّ لَها أن تَنقادَ لِأَمْرِهِ.</p></div>"
  84,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُدَّتۡ﴾</span>: بُسِطَتْ ووُسِّعَتْ.</p></div>"
  84,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَلۡقَتۡ مَا فِيهَا﴾</span>: وقَذَفَتْ ما في بَطْنِها مِنَ الأمْواتِ.</p><p><span class="qpc-hafs">﴿وَتَخَلَّتۡ﴾</span>: لم يَبْقَ شَيءٌ مِمّا في بَطْنِها.</p></div>"
  84,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَذِنَتۡ لِرَبِّهَا﴾</span>: وانْقادَتْ لِرَبِها فِيما أمَرها بِهِ.</p></div>"
  84,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَادِحٌ﴾</span>: ساعٍ إلى اللهِ.</p><p><span class="qpc-hafs">﴿فَمُلَـٰقِيهِ﴾</span>: تُلاقِي الله يَومَ القِيامَةِ.</p></div>"
  84,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوتِيَ كِتَـٰبَهُۥ﴾</span>: أُعطِيَ صَحِيفةَ أعمالِهِ.</p></div>"
  84,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسِيرࣰا﴾</span>: سَهْلا.</p></div>"
  84,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَنقَلِبُ﴾</span>: ويَرْجِعُ.</p></div>"
  84,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِتَـٰبَهُۥ﴾</span>: صَحِيفةَ أعْمالِهِ.</p></div>"
  84,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُبُورࣰا﴾</span>: بِالهَلاكِ.</p></div>"
  84,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَصۡلَىٰ سَعِيرًا﴾</span>: ويَدْخُلُ النّارَ مُقاسِيًا حَرَّها.</p></div>"
  84,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَسۡرُورًا﴾</span>: مَغْرُورًا لا يُفَكِّرُ في العواقِبِ.</p></div>"
  84,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَحُورَ﴾</span>: يَرْجِعَ إلى خالِقِه لِلْحِسابِ.</p></div>"
  84,15,""
  84,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلشَّفَقِ﴾</span>: باحْمِرارِ الأُفُقِ عِنْدَ الغُرُوب.</p></div>"
  84,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا وَسَقَ﴾</span>: وما جَمَعَ من الدَّوابِّ والحَشراتِ والهَوامِّ وغَيرِ ذَلِكَ.</p></div>"
  84,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱتَّسَقَ﴾</span>: تَكامَلَ نُورُهُ.</p></div>"
  84,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَبَقًا عَن طَبَقࣲ﴾</span>: أطوارًا مُتَعَدِّدَةً وأَحْوالًا مُتَبايِنَةً: مِنَ النُّطْفَةِ إلى العَلَقَةِ إلى المُضْغةِ إلى نَفْخِ الرُّوحِ، إلى الموتِ، إلى البعْثِ والنُّشُورِ.</p></div>"
  84,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا لَهُمۡ لَا يُؤۡمِنُونَ﴾</span>: فأيُّ شَيءٍ يَمْنَعُهُم مِنَ الإيمانِ بَعْدَ ما وُضِّحَتْ لَهُمُ الآياتُ؟</p></div>"
  84,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسۡجُدُونَ﴾</span>: لا يَخْضَعُونَ للهِ، ولا يُسَلِّمُونَ بِما جاءَ في القُرآنِ.</p></div>"
  84,22,""
  84,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا يُوعُونَ﴾</span>: بِما يَكْتُمُونَ مِن العِنادِ مَعَ عِلْمِهِم بأنّ ما جاءَ بهِ القرآنُ حَقٌّ.</p></div>"
  84,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَشِّرۡهُم﴾</span>: أي هَؤُلاءِ المكذِّبِينَ.</p></div>"
  84,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡرُ مَمۡنُونِۭ﴾</span>: غَيرُ مَقْطُوعٍ ولا مَنقُوصٍ.</p></div>"
