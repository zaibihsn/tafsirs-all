quran[60]{c,v,t}:
  30,1,""
  30,2,""
  30,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَدۡنَى ٱلۡأَرۡضِ﴾</span>: أقْرَبِ أرْضِ الشّامِ إلى فارِس.</p><p><span class="qpc-hafs">﴿غَلَبِهِمۡ﴾</span>: أي: كَوْنِهِم مَغْلُوبِينَ.</p></div>"
  30,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِضۡعِ سِنِينَ﴾</span>: أي: ما بينَ الثَّلاثَةِ إلى العَشْرَةِ</p></div>"
  30,5,""
  30,6,""
  30,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَـٰهِرࣰا مِّنَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: فَيَنْظُرُونَ إلى الأسْبابِ الظّاهِرَةِ ولا يَنْظُرُونَ إلى مُسَبِّبِها المتَصَرِّفِ فِيها الَّذي هُوَ اللهُ تَعالى.</p></div>"
  30,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَتَفَكَّرُواْ﴾</span>: أوَلَمْ يَتَأَمَّلُوا ويَتَدَبَّرُوا.</p><p><span class="qpc-hafs">﴿أَجَلࣲ مُّسَمࣰّى﴾</span>: وقْتٍ مُقَدَّرٍ هُوَ يومُ القِيامَةِ.</p><p><span class="qpc-hafs">﴿بِلِقَآيِٕ رَبِّهِمۡ﴾</span>: المُرادُ به البَعْثُ بَعْدَ الموتِ.</p></div>"
  30,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰقِبَةُ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾</span>: أي: مَصِيرُهُم الَّذي انْتهَوا إليهِ.</p><p><span class="qpc-hafs">﴿وَأَثَارُواْ ٱلۡأَرۡضَ﴾</span>: حَرَثُوها للزِّراعَةِ.</p><p><span class="qpc-hafs">﴿وَعَمَرُوهَآ﴾</span>: أي: بالبُنْيانِ والزِّراعَةِ.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالبَراهِينِ الواضِحةِ، ومنها المُعْجِزاتُ الحِسِّيةُ.</p></div>"
  30,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسُّوٓأَىٰٓ﴾</span>: تَأْنِيثُ «الأسْوأ»، ومعناها: العُقُوبَةُ المتناهِيةُ في السُّوءِ، وهي نارُ جَهَنَّم.</p></div>"
  30,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡدَؤُاْ﴾</span>: يُنْشِئُ ابتِداءً.</p><p><span class="qpc-hafs">﴿يُعِيدُهُۥ﴾</span>: يُعِيدُ الخَلْقَ مِن بَعْدِ فَنائِهِ.</p></div>"
  30,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبۡلِسُ ٱلۡمُجۡرِمُونَ﴾</span>: يَيْئَسُونَ بانْقِطاعِ حُجَّتِهِم.</p></div>"
  30,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن شُرَكَآئِهِمۡ﴾</span>: أي: مِن آلهَتِهِم الَّتي كانُوا يَعْبُدُونَها مِن دُونِ اللهِ.</p></div>"
  30,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَفَرَّقُونَ﴾</span>: أي: فَرِيقٌ في الجنَّة، وفَرِيقٌ في السَّعِيرِ.</p></div>"
  30,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَوۡضَةࣲ﴾</span>: المرادُ بِها هُنا «الجنَّةُ».</p><p><span class="qpc-hafs">﴿يُحۡبَرُونَ﴾</span>: يُكَرَّمُونَ ويُنَعَّمُونَ.</p></div>"
  30,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِقَآيِٕ ٱلۡـَٔاخِرَةِ﴾</span>: أي: البَعْثِ بَعْدَ الموتِ.</p><p><span class="qpc-hafs">﴿فِي ٱلۡعَذَابِ مُحۡضَرُونَ﴾</span>: مُقيمُونَ فِيهِ.</p></div>"
  30,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ﴾</span>: أي: فنزِّهُوهُ عمّا لا يَلِيقُ بِه.</p><p><span class="qpc-hafs">﴿حِينَ تُمۡسُونَ﴾</span>: أي: وقْتَ دُخُولِكُم في المساءِ.</p><p><span class="qpc-hafs">﴿وَحِينَ تُصۡبِحُونَ﴾</span>: أي: وقْتَ دُخُولِكَمُ في الصَّباحِ.</p></div>"
  30,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعَشِيࣰّا﴾</span>: وقْتَ العَشِيِّ، أي: بَعْدَ زَوالِ الشَّمسِ.</p><p><span class="qpc-hafs">﴿وَحِينَ تُظۡهِرُونَ﴾</span>: أي: وقْتَ الظَّهِيَرةِ.</p></div>"
  30,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَا﴾</span>: أي: قَحْطِها وجَفافِها.</p><p><span class="qpc-hafs">﴿تُخۡرَجُونَ﴾</span>: أي: تُبعثُونَ مِن قُبُورِكُم.</p></div>"
  30,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنتَشِرُونَ﴾</span>: تَتَفَرَّقُونَ.</p></div>"
  30,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ أَنفُسِكُمۡ﴾</span>: مِن جِنْسِكُم.</p><p><span class="qpc-hafs">﴿لِّتَسۡكُنُوٓاْ إِلَيۡهَا﴾</span>: لِتألَفُوها وتَطْمئنُّوا إلَيها.</p><p><span class="qpc-hafs">﴿مَّوَدَّةࣰ وَرَحۡمَةً﴾</span>: مَحَبَّةً وشَفَقَةً.</p><p><span class="qpc-hafs">﴿يَتَفَكَّرُونَ﴾</span>: يَتَدَبَّرُونَ.</p></div>"
  30,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلۡسِنَتِكُمۡ﴾</span>: لُغاتِكُم.</p></div>"
  30,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتِغَآؤُكُم﴾</span>: طَلَبُكُم والتِماسُكُم.</p><p><span class="qpc-hafs">﴿مِّن فَضۡلِهِۦٓ﴾</span>: مِن رِزْقِه.</p></div>"
  30,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَوۡفࣰا وَطَمَعࣰا﴾</span>: أي: خَوْفًا مِنَ الصَّواعِقِ وطَمعًا في الغَيثِ.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَآ﴾</span>: بَعْدَ قَحْطِها وجَفافِها.</p></div>"
  30,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَمۡرِهِۦ﴾</span>: بِإرادَتِه وقُدْرَتِهِ.</p><p><span class="qpc-hafs">﴿تَخۡرُجُونَ﴾</span>: أي: مِن قُبُورِكُم أحْياءً.</p></div>"
  30,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهُۥ قَـٰنِتُونَ﴾</span>: مُنْقادُونَ لإرادَتِه.</p></div>"
  30,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡدَؤُاْ﴾</span>: يُنْشِئُ.</p><p><span class="qpc-hafs">﴿أَهۡوَنُ﴾</span>: هيِّنٌ ويَسِيرُ.</p><p><span class="qpc-hafs">﴿ٱلۡمَثَلُ ٱلۡأَعۡلَىٰ﴾</span>: الوصْفُ الأَعْلى.</p></div>"
  30,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلَكَتۡ أَيۡمَـٰنُكُم﴾</span>: أي: العبِيدُ والإماءُ.</p><p><span class="qpc-hafs">﴿كَخِيفَتِكُمۡ أَنفُسَكُمۡ﴾</span>: أي: كَما تَخافُونَ الأحْرارَ المُشابِهِينَ لَكُم في الحرِّيَّةِ وتَمَلُّكِ الأمْوالِ.</p></div>"
  30,29,""
  30,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَقِمۡ وَجۡهَكَ لِلدِّينِ﴾</span>: أي: اسْتَقِمْ واسْتَمِر عَلى دِينِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائِلًا إليه مُسْتَقِيمًا عَلِيهِ، غَيْرَ مُلْتَفِتٍ إلى غَيْرِه مِنَ الأدْيانِ الباطِلَةِ.</p><p><span class="qpc-hafs">﴿فِطۡرَتَ ٱللَّهِ﴾</span>: أي: الزَمُوا فِطْرَةَ اللهِ، وهِيَ الإسْلامُ.</p><p><span class="qpc-hafs">﴿فَطَرَ ٱلنَّاسَ عَلَيۡهَا﴾</span>: أي: خَلَقَهُم عَلَيها.</p></div>"
  30,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنِيبِينَ إِلَيۡهِ﴾</span>: راجِعِينَ إليهِ بالتَّوبَةِ والإخْلاصِ.</p></div>"
  30,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَّقُواْ دِينَهُمۡ﴾</span>: أي: آمَنُوا بِبَعْضٍ وكَفَرُوا بِبَعْضٍ.</p><p><span class="qpc-hafs">﴿شِيَعࣰا﴾</span>: فِرَقًا وأحْزابًا مُخْتلِفَةً.</p><p><span class="qpc-hafs">﴿كُلُّ حِزۡبِۭ﴾</span>: كلُّ فَرِيقٍ.</p><p><span class="qpc-hafs">﴿فَرِحُونَ﴾</span>: مَسْرُورُونَ.</p></div>"
  30,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضُرࣱّ﴾</span>: قَحْطٌ وشِدَّةٌ.</p><p><span class="qpc-hafs">﴿مُّنِيبِينَ إِلَيۡهِ﴾</span>: مُلْتَجِئِينَ إليهِ بالتَّوبَةِ والإخْلاصِ.</p><p><span class="qpc-hafs">﴿أَذَاقَهُم مِّنۡهُ رَحۡمَةً﴾</span>: أي: كَشَفَ عَنْهُم ضُرَّهُم.</p></div>"
  30,34,""
  30,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: بُرْهانًا أو كِتابًا.</p></div>"
  30,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرِحُواْ بِهَا﴾</span>: فرِحُوا بِها فَرَحَ بَطَرٍ لا فَرَحَ شُكْرٍ.</p><p><span class="qpc-hafs">﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾</span>: أي: بِسَبَبِ أعْمالِهِم السَّيِّئةِ.</p><p><span class="qpc-hafs">﴿يَقۡنَطُونَ﴾</span>: يَيْئَسُونَ.</p></div>"
  30,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَرَوۡاْ﴾</span>: أي: أوَلَمْ يَعْلَمُوا.</p><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: يُضَيِّقُ.</p></div>"
  30,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـَٔاتِ﴾</span>: فأعْطِ.</p><p><span class="qpc-hafs">﴿ٱلۡمِسۡكِينَ﴾</span>: الفَقِيرَ الَّذِي لا يَمْلِكُ ما يَكْفِيهِ ويَسُدُّ حاجَتَه.</p><p><span class="qpc-hafs">﴿ٱبۡنَ ٱلسَّبِيلِ﴾</span>: المُسافِرَ المُحْتاجَ.</p></div>"
  30,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ ءَاتَيۡتُم﴾</span>: وما أعطَيتُم.</p><p><span class="qpc-hafs">﴿رِّبࣰا﴾</span>: قَرْضًا أو هَدِيَّةً بِقَصْدِ الرِّبا والزِّيادَةِ.</p><p><span class="qpc-hafs">﴿لِّيَرۡبُوَاْ﴾</span>: لِيَزِيِدَ ويَنْمُوَ.</p><p><span class="qpc-hafs">﴿فَلَا يَرۡبُواْ﴾</span>: فَلا يَزِيدُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُضۡعِفُونَ﴾</span>: أي: هُمْ أصْحابُ الأجْرِ المُضاعَفِ.</p></div>"
  30,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن شُرَكَآئِكُم﴾</span>: مِنَ آلَهتِكُم الَّتي تَعْبُدُونَها مِن دُونِ اللهِ.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ﴾</span>: تَنَزَّهَ اللهُ وتَقَدَّسَ.</p></div>"
  30,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا كَسَبَتۡ أَيۡدِي ٱلنَّاسِ﴾</span>: أي: بِسَبَبِ أعْمالِهِم السَّيِّئةِ.</p><p><span class="qpc-hafs">﴿بَعۡضَ ٱلَّذِي﴾</span>: أي: عُقُوبَةَ بَعْضِ الَّذي.</p><p><span class="qpc-hafs">﴿يَرۡجِعُونَ﴾</span>: أي: يَتُوبُونَ إلى اللهِ.</p></div>"
  30,42,""
  30,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلدِّينِ ٱلۡقَيِّمِ﴾</span>: أي: نَحْوَ الدِّينِ المسْتَقِيم، وهو الإسْلامُ.</p><p><span class="qpc-hafs">﴿لَّا مَرَدَّ لَهُۥ﴾</span>: أي: لا يقْدِرُ أحدٌ على ردِّهِ.</p><p><span class="qpc-hafs">﴿يَصَّدَّعُونَ﴾</span>: يَتَفَرَّقُونَ، فَرِيقٌ في الجنَّةِ وفَرِيقٌ في السَّعيرِ.</p></div>"
  30,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَمۡهَدُونَ﴾</span>: يُوَطِّئُونَ ويُهَيِّئُونَ الطَّريقَ إلى مَنازِلَ في الجنَّةِ.</p></div>"
  30,45,""
  30,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُبَشِّرَ ٰ⁠تࣲ﴾</span>: أي: بِنُزُولِ المَطَرِ.</p><p><span class="qpc-hafs">﴿مِّن رَّحۡمَتِهِۦ﴾</span>: والمرادُ بها هُنا: المَطرُ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكُ﴾</span>: السُّفُنُ.</p><p><span class="qpc-hafs">﴿لِتَبۡتَغُواْ﴾</span>: لِتَطْلُبُوا.</p></div>"
  30,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالمُعْجِزاتِ والبراهِينِ الواضِحةِ.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ أَجۡرَمُواْ﴾</span>: الَّذينَ فَعَلُوا الإجْرامَ واكْتَسَبُوا السَّيِّئاتِ.</p></div>"
  30,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتُثِيرُ﴾</span>: فتُحَرِّكُ وتَنْشُرُ.</p><p><span class="qpc-hafs">﴿فَيَبۡسُطُهُۥ﴾</span>: فَيَنْشُرُه.</p><p><span class="qpc-hafs">﴿كِسَفࣰا﴾</span>: قِطَعًا متفرِّقةً.</p><p><span class="qpc-hafs">﴿ٱلۡوَدۡقَ﴾</span>: المطَرَ.</p><p><span class="qpc-hafs">﴿مِنۡ خِلَـٰلِهِۦ﴾</span>: مِن فُرَجِ السَّحابِ ووَسَطِه.</p><p><span class="qpc-hafs">﴿يَسۡتَبۡشِرُونَ﴾</span>: يَفْرَحُونَ.</p></div>"
  30,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمُبۡلِسِينَ﴾</span>: لَآيسِينَ مِن نُّزُولِ المطَرِ.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَآ﴾</span>: بَعْدَ جَدْبِها وجَفافِها.</p></div>"
  30,50,""
  30,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِيحࣰا﴾</span>: أي: رِيحًا مُفْسِدَةً لِنَباتِهم.</p><p><span class="qpc-hafs">﴿فَرَأَوۡهُ مُصۡفَرࣰّا﴾</span>: فَرَأَوُا النَّباتَ مُصْفَرًّا بَعْدَ الخُضْرَةِ.</p><p><span class="qpc-hafs">﴿لَّظَلُّواْ﴾</span>: لَصارُوا.</p><p><span class="qpc-hafs">﴿يَكۡفُرُونَ﴾</span>: يَجْحَدُونَ باللهِ وبنِعَمِه.</p></div>"
  30,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَّوۡاْ﴾</span>: انصَرَفُوا.</p></div>"
  30,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِهَـٰدِ ٱلۡعُمۡيِ﴾</span>: بمُرْشِدِ مَن أعْماهُ اللهُ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿مُّسۡلِمُونَ﴾</span>: خاضِعُونَ مُنْقادُونَ.</p></div>"
  30,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن ضَعۡفࣲ﴾</span>: أي: مِن نُّطْفَةٍ ضَعِيفَةٍ.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ ضَعۡفࣲ﴾</span>: أي: مِن بَعْدِ ضَعْفِ الطُّفولَةِ والصِّغَرِ.</p><p><span class="qpc-hafs">﴿قُوَّةࣲ﴾</span>: أي: قُوَّةِ الشَّبابِ.</p><p><span class="qpc-hafs">﴿ضَعۡفࣰا﴾</span>: أي: ضَعْفَ الكِبَرِ والهرَمِ.</p><p><span class="qpc-hafs">﴿وَشَيۡبَةࣰ﴾</span>: أي: بياضًا في الشَّعْرِ وضَعْفًا في قُوى الجسِمِ.</p></div>"
  30,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَيۡرَ سَاعَةࣲ﴾</span>: غيرَ فَتْرَةِ قَصِيرةٍ مِنَ الزَّمَنِ.</p><p><span class="qpc-hafs">﴿يُؤۡفَكُونَ﴾</span>: يُصْرَفُونَ عَنِ الحقِّ والصِّدقِ.</p></div>"
  30,56,""
  30,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَعۡذِرَتُهُمۡ﴾</span>: اعْتِذارُهُم.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يُسۡتَعۡتَبُونَ﴾</span>: لا يُطْلَبُ مِنهُم إرْضاءُ اللهِ تَعالى بالتَّوبَةِ والطّاعَةِ.</p></div>"
  30,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةࣲ﴾</span>: أي: بِأيِّ حُجَّةٍ.</p><p><span class="qpc-hafs">﴿مُبۡطِلُونَ﴾</span>: أي: أصْحابُ أباطِيلَ.</p></div>"
  30,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَطۡبَعُ﴾</span>: يَخْتِمُ، فلا تَعِي شيئًا مِنَ الحَقِّ.</p></div>"
  30,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَسۡتَخِفَّنَّكَ﴾</span>: لا يَحْمِلَنَّكَ على الخِفَّةِ وتَرْكِ الصَّبْرِ.</p></div>"
