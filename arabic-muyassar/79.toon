quran[46]{c,v,t}:
  79,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلنَّـٰزِعَـٰتِ﴾</span>: أُقْسِمُ بالملائِكةِ الَّتِي تَنْزِعُ أرْواحَ الكُفّارِ.</p><p><span class="qpc-hafs">﴿غَرۡقࣰا﴾</span>: نَزْعًا غَرْقًا، أي مُغْرِقًا، أي تَنْزِعُ الأرْواحَ من أقاصِي الأَجْسادِ.</p></div>"
  79,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلنَّـٰشِطَـٰتِ﴾</span>: والملائِكَةِ الَّتِي تَقْبِضُ أرْواحَ المؤمِنِينَ.</p><p><span class="qpc-hafs">﴿نَشۡطࣰا﴾</span>: بِنَشاطٍ ورِفقٍ.</p></div>"
  79,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلسَّـٰبِحَـٰتِ﴾</span>: والملائِكَةِ الَّتِي تَسْبَحُ في نُزُولِها مِنَ السَّماءِ وصُعُودِها إليها.</p></div>"
  79,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلسَّـٰبِقَـٰتِ﴾</span>: فالملائِكَةِ الَّتِي تُسارِعُ إلى تَنِفيذِ أمْرِ اللهِ.</p></div>"
  79,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡمُدَبِّرَ ٰ⁠تِ أَمۡرࣰا﴾</span>: فالملائِكةِ المُنَفِّذاتِ أمْرَ رَبِّها.</p></div>"
  79,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ﴾</span>: يومَ تَضْطَرِبُ الأرضُ بالنَّفْخَةِ الأُولى نَفْخَةِ الإماتَةِ.</p></div>"
  79,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتۡبَعُهَا ٱلرَّادِفَةُ﴾</span>: تَتْبَعُها نَفْخَةٌ أُخْرى لِبَعْثِ الخَلْقِ.</p></div>"
  79,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلُوبࣱ﴾</span>: قُلُوبُ الكُفّارِ.</p><p><span class="qpc-hafs">﴿وَاجِفَةٌ﴾</span>: مُضْطَرِبَةٌ مِن شِدَّةِ الخوفِ.</p></div>"
  79,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعَةࣱ﴾</span>: ذَلِيلَةٌ مِن هَوْلِ ما تَرى.</p></div>"
  79,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَءِنَّا لَمَرۡدُودُونَ﴾</span>: أنُرَدُّ بَعْدَ مَوتِنا؟.</p><p><span class="qpc-hafs">﴿ٱلۡحَافِرَةِ﴾</span>: إلى أوَّلِ حالِنا، فَنَصِيرُ أحياءً بَعْدَ مَوْتِنا.</p></div>"
  79,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَءِذَا كُنَّا عِظَـٰمࣰا نَّخِرَةࣰ﴾</span>: أنُرَدُّ وقَدْ صِرْنا عِظامًا بالِيةً.</p></div>"
  79,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّةٌ خَاسِرَةࣱ﴾</span>: رَجْعَةٌ خائِبةٌ كاذِبةٌ.</p></div>"
  79,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ﴾</span>: نَفْخَةٌ واحِدَةٌ.</p></div>"
  79,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلسَّاهِرَةِ﴾</span>: على وجْهِ الأَرْضِ.</p></div>"
  79,15,""
  79,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُقَدَّسِ﴾</span>: الُمطَهَّرِ المبارَكِ.</p><p><span class="qpc-hafs">﴿طُوًى﴾</span>: وادٍ في جانِبِ جَبَلِ الطُّورِ.</p></div>"
  79,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: أفْرَطَ في العِصْيانِ.</p></div>"
  79,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَل لَّكَ﴾</span>: أتَوَدُّ.</p><p><span class="qpc-hafs">﴿تَزَكَّىٰ﴾</span>: تُطَهِّرَ نَفْسَكَ.</p></div>"
  79,19,""
  79,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَرَىٰهُ﴾</span>: فَأَرى مُوسى فِرْعَونَ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَةَ ٱلۡكُبۡرَىٰ﴾</span>: العلامةَ العُظْمى: العَصا واليدَ.</p></div>"
  79,21,""
  79,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَدۡبَرَ﴾</span>: ولّى مُعْرِضًا عَنِ الإيمانِ.</p><p><span class="qpc-hafs">﴿يَسۡعَىٰ﴾</span>: في مُعارَضَةِ مُوسى.</p></div>"
  79,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَشَرَ﴾</span>: فَجَمَعَ النّاسَ.</p></div>"
  79,24,""
  79,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَخَذَهُ ٱللَّهُ﴾</span>: فَعاقَبَهُ.</p><p><span class="qpc-hafs">﴿نَكَالَ ٱلۡـَٔاخِرَةِ﴾</span>: عَذابَ الآخِرَةِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأُولَىٰٓ﴾</span>: وعَذابَ الدُّنيا.</p></div>"
  79,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعِبۡرَةࣰ﴾</span>: لَمَوْعِظَةً.</p></div>"
  79,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَأَنتُمۡ أَشَدُّ خَلۡقًا أَمِ ٱلسَّمَآءُ﴾</span>: أبَعْثُكُم-أيُّها الناسُ- بَعْدَ الموتِ أشَدُّ في تَقْدِيرِكُم أم خَلْقُ السَّماءِ؟</p><p><span class="qpc-hafs">﴿بَنَىٰهَا﴾</span>: خَلَقَها.</p></div>"
  79,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَفَعَ سَمۡكَهَا﴾</span>: رَفَعَها فَوقَكُم كالبِناءِ فَأَعلى سَقْفَها في الهواءِ.</p><p><span class="qpc-hafs">﴿فَسَوَّىٰهَا﴾</span>: فعَدَّلَ أجْزاءَها بإتْقان.</p></div>"
  79,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَغۡطَشَ لَيۡلَهَا﴾</span>: وأَظْلَمَ لَيلَها.</p><p><span class="qpc-hafs">﴿وَأَخۡرَجَ ضُحَىٰهَا﴾</span>: وأَبْرَزَ نَهارَها.</p></div>"
  79,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡدَ ذَ ٰ⁠لِكَ﴾</span>: بَعْدَ خَلْقِ السَّماءِ.</p><p><span class="qpc-hafs">﴿دَحَىٰهَآ﴾</span>: بَسَطَها وأَوْدَعَ فِيها منافِعَها.</p></div>"
  79,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَرۡعَىٰهَا﴾</span>: وأَنبَتَ فِيها ما يُرعى مِنَ النباتاتِ.</p></div>"
  79,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡسَىٰهَا﴾</span>: أثْبتَها في الأرضِ.</p></div>"
  79,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعࣰا لَّكُمۡ﴾</span>: مَنفَعَةً لَكُم.</p></div>"
  79,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّآمَّةُ ٱلۡكُبۡرَىٰ﴾</span>: القِيامَةُ الكُبْرى والشِدَّةُ العُظْمى وهي النَّفْخَةُ الثّانِيةُ.</p></div>"
  79,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَذَكَّرُ ٱلۡإِنسَـٰنُ مَا سَعَىٰ﴾</span>: يُعْرَضُ عَلى الإنسانِ عَمَلُهُ، فَيَتَذَكَّرُهُ ويَعْتَرِفُ بِهِ.</p></div>"
  79,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبُرِّزَتِ﴾</span>: وأُظهِرَتْ.</p></div>"
  79,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: أفْرَطَ في العِصيانِ.</p></div>"
  79,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاثَرَ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا﴾</span>: وفَضَّل الحياةَ الدُّنيا على الآخِرَةِ.</p></div>"
  79,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَأۡوَىٰ﴾</span>: المصِيرُ والمآلُ.</p></div>"
  79,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقَامَ رَبِّهِۦ﴾</span>: القِيامَ بينَ يَدَيِ اللهِ لِلحِسابِ.</p><p><span class="qpc-hafs">﴿ٱلۡهَوَىٰ﴾</span>: الأَهْواءِ الفاسِدةِ.</p></div>"
  79,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَأۡوَىٰ﴾</span>: مَسْكَنُهُ.</p></div>"
  79,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّانَ مُرۡسَىٰهَا﴾</span>: مَتى وقْتُ السّاعةِ؟</p></div>"
  79,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيمَ أَنتَ مِن ذِكۡرَىٰهَآ﴾</span>: لَسْتَ في شَيءٍ مِن عِلْمِها.</p></div>"
  79,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ﴾</span>: مَرَدُّ ذَلِكَ إلى اللهِ عَزَّ وجَلَّ.</p></div>"
  79,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنذِرُ﴾</span>: مُحذِّرٌ مِنها.</p></div>"
  79,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَشِيَّةً﴾</span>: ما بَينَ الظُّهْرِ إلى غُرُوبِ الشَّمسِ.</p><p><span class="qpc-hafs">﴿ضُحَىٰهَا﴾</span>: ما بَينَ طُلُوعِ الشَّمسِ إلى نِصْفِ النَّهارِ.</p></div>"
