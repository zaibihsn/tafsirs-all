quran[176]{c,v,t}:
  4,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾</span>: هي آدَمُ.</p><p><span class="qpc-hafs">﴿زَوۡجَهَا﴾</span>: هي حَوّاءُ، خُلِقَتْ من ضِلْعٍ من أضلاعِ آدمَ.</p><p><span class="qpc-hafs">﴿وَبَثَّ مِنۡهُمَا﴾</span>: نَشَر من آدمَ وحَواءَ.</p><p><span class="qpc-hafs">﴿تَسَآءَلُونَ بِهِۦ﴾</span>: يَسْألُ به بعضُكم بعضًا، فيقولُ السائلُ: أسألُك باللهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَرۡحَامَ﴾</span>: واتقوا الأرحامَ أن تقطعُوها.</p></div>"
  4,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاتُواْ﴾</span>: وأَعطُوا يا أوصياءَ اليتامى.</p><p><span class="qpc-hafs">﴿ٱلۡيَتَـٰمَىٰٓ﴾</span>: هم مَن ماتَ آباؤهم وهم دونَ البلوغ. وإعطاؤُهم المالَ إذا وصَلُوا سِنَّ البُلوغِ، وأصبح لديهم قُدْرَةٌ على حِفْظِ المالِ.</p><p><span class="qpc-hafs">﴿وَلَا تَتَبَدَّلُواْ ٱلۡخَبِيثَ بِٱلطَّيِّبِ﴾</span>: ولا تأخُذوا الجيِّدَ من أموالهِم، وتجعلُوا مكانَه الرديءَ من أموالِكم.</p><p><span class="qpc-hafs">﴿وَلَا تَأۡكُلُوٓاْ أَمۡوَ ٰ⁠لَهُمۡ إِلَىٰٓ أَمۡوَ ٰ⁠لِكُمۡ﴾</span>: ولا تَخْلِطُوا أموالَهم بأموالِكم، فتأكلُوها مع أموالِكم.</p><p><span class="qpc-hafs">﴿حُوبࣰا﴾</span>: إثْمًا وظُلمًا.</p></div>"
  4,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُقۡسِطُواْ﴾</span>: تَعْدِلُوا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡيَتَـٰمَىٰ﴾</span>: في يَتامى النساءِ اللاتي تحتَ أيديكم بألّا تُعْطُوهنَّ مهورَهنَّ كغيرِهنَّ، فلا تَنْكِحُوهن، وانكِحُوا غيرَهن.</p><p><span class="qpc-hafs">﴿طَابَ﴾</span>: حَلَّ.</p><p><span class="qpc-hafs">﴿أَدۡنَىٰٓ أَلَّا تَعُولُواْ﴾</span>: أقربُ إلى ألّا تَجُوروا، ولا تَميلوا.</p></div>"
  4,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَدُقَـٰتِهِنَّ﴾</span>: مُهورِهنَّ.</p><p><span class="qpc-hafs">﴿نِحۡلَةࣰ﴾</span>: عَطِيةً واجبةً.</p><p><span class="qpc-hafs">﴿شَيۡءࣲ مِّنۡهُ﴾</span>: شيءٍ من المَهْرِ، فوَهَبْنَه لكم.</p></div>"
  4,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسُّفَهَآءَ﴾</span>: المضَيِّعين لما لِهم بسوءِ تَدْبيرِهم.</p><p><span class="qpc-hafs">﴿قِيَـٰمࣰا﴾</span>: قِوامَكم في مَعايِشكم.</p></div>"
  4,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱبۡتَلُواْ﴾</span>: واختبِرُوهم لمعرفةِ قُدُراتِهم.</p><p><span class="qpc-hafs">﴿بَلَغُواْ ٱلنِّكَاحَ﴾</span>: وصَلُوا إلى سِنِّ البلوغِ.</p><p><span class="qpc-hafs">﴿ءَانَسۡتُم مِّنۡهُمۡ رُشۡدࣰا﴾</span>: عَلِمْتُمْ منهم صَلاحًا في العقلِ والدِّين.</p><p><span class="qpc-hafs">﴿إِسۡرَافࣰا﴾</span>: بغيرِ ما أباحَه اللهُ لكم.</p><p><span class="qpc-hafs">﴿وَبِدَارًا﴾</span>: ومُبادرةً لأَكْلِها.</p><p><span class="qpc-hafs">﴿أَن يَكۡبَرُواْ﴾</span>: قبل أن يكبَرُوا فيأ خُذُوها منكم.</p><p><span class="qpc-hafs">﴿بِٱلۡمَعۡرُوفِ﴾</span>: بقَدْرِ حاجتِه عند الضرورةِ على وجْه القَرْضِ.</p><p><span class="qpc-hafs">﴿فَأَشۡهِدُواْ﴾</span>: بأَنْ يَشْهَدَ شهودٌ معكم.</p><p><span class="qpc-hafs">﴿حَسِيبࣰا﴾</span>: محاسِبًا.</p></div>"
  4,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّلرِّجَالِ﴾</span>: للذُّكورِ من أولادِ الميتِ صغارًا وكبارًا.</p></div>"
  4,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡقُرۡبَىٰ﴾</span>: ممَّن لا حَقَّ لهم في التَّرِكَةِ.</p><p><span class="qpc-hafs">﴿فَٱرۡزُقُوهُم مِّنۡهُ﴾</span>: على وجهِ الاستحبابِ.</p></div>"
  4,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَتَّقُواْ ٱللَّهَ﴾</span>: في ذلك النهيُ عن الإجحافِ بالورثةِ الضعفاءِ، فلايزيدُ في وصيَّتِه لغيرِهمِ على الثلث، وكذلك إنْ تَرَكهم أغنياءَ حَسُنَ أن يُوصيَ لغيرِهم.</p></div>"
  4,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَعِيرࣰا﴾</span>: نارًا مُوقدةً.</p></div>"
  4,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلذَّكَرِ مِثۡلُ حَظِّ ٱلۡأُنثَيَيۡنِ﴾</span>: إذا لم يكن هناك وارثٌ غيرُ أولادِه.</p><p><span class="qpc-hafs">﴿فَلِأُمِّهِ ٱلثُّلُثُ﴾</span>: ولأبيه الباقي.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ وَصِيَّةࣲ﴾</span>: هذه القِسْمَةُ للتَّرِكَةِ بعد إخراجِ وصيةِ الميتِ بما لايتجاوزُ الثلثَ.</p></div>"
  4,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهُنَّ وَلَدࣱ﴾</span>: ذكرًا أو أنثى.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ وَصِيَّةࣲ﴾</span>: من بعدِ إنفاذِ وصِيَّتِهنّ الجائزةِ.</p><p><span class="qpc-hafs">﴿لَّكُمۡ وَلَدࣱ﴾</span>: ذَكَرًا أو أنثى، منهن، أو من غيرِهنّ.</p><p><span class="qpc-hafs">﴿كَلَـٰلَةً﴾</span>: هو الميتُ الذي لا ولَدَ له ولا والدَ</p><p><span class="qpc-hafs">﴿أَخٌ أَوۡ أُخۡتࣱ﴾</span>: من أُمّ.</p><p><span class="qpc-hafs">﴿غَيۡرَ مُضَآرࣲّ﴾</span>: لا ضَرَرَ فيه على الوَرَثَةِ، فإنْ قَصَدَ صاحبُها الضَّرَرَ لوَرَثَتِه فهو باطلٌ لا يَنْفُذُ.</p></div>"
  4,13,""
  4,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّهِينࣱ﴾</span>: مُخْزٍ.</p></div>"
  4,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَـٰحِشَةَ﴾</span>: الزِّنى.</p><p><span class="qpc-hafs">﴿فَأَمۡسِكُوهُنَّ﴾</span>: فاحبِسُوهُنَّ، وكان هذا قبل نَسْخِها.</p><p><span class="qpc-hafs">﴿سَبِيلࣰا﴾</span>: مَخْرَجًا، والسبيلُ هو: الحُكْمُ بالرَّجْمِ للمُحْصَنِ والمحصَنةِ، والجلْدِ مئةَ جَلْدَةٍ، وتَغْريبِ عامٍ لغيرهما.</p></div>"
  4,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَأۡتِيَـٰنِهَا﴾</span>: أي: فاحشةَ الزِّنى.</p><p><span class="qpc-hafs">﴿فَـَٔاذُوهُمَا﴾</span>: بالضَّرْبِ، والهَجْرِ والتوبيخِ، ثم نُسِخَ بالجلْدِ والرَّجْمِ.</p></div>"
  4,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَى ٱللَّهِ﴾</span>: فهو الذي يقبَلُها.</p><p><span class="qpc-hafs">﴿بِجَهَـٰلَةࣲ﴾</span>: بجَهْلٍ منهم لعاقِبَتِها، وإيجابِها لسَخَطِ اللهِ.</p></div>"
  4,18,""
  4,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرۡهࣰا﴾</span>: هُنَّ كارهاتٌ لذلك، وكانوا في الجاهليَّةِ يجعلون نِساءَ الآباءِ والأقاربِ من التَّرِكَةِ، فيتزوَّجُون بهنَّ.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡضُلُوهُنَّ﴾</span>: لا يَحِلُّ لكم أن تَحْبِسُوا زوجاتِكم عندَكم مع عَدَمِ رغبتِكم فيهن، وذلك لقَصْدِ أن يفتَدِينَ ببعضِ المهْرِ من الحبْسِ.</p><p><span class="qpc-hafs">﴿بِفَـٰحِشَةࣲ مُّبَيِّنَةࣲ﴾</span>: بالزِّنى البيِّنِ، أو بذاءةِ اللسانِ، أو النُّشوزِ.</p></div>"
  4,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِحۡدَىٰهُنَّ﴾</span>: هي مَن تُريدون طَلاقَها.</p><p><span class="qpc-hafs">﴿قِنطَارࣰا﴾</span>: مالًا كثيرًا مَهْرًا لها.</p><p><span class="qpc-hafs">﴿بُهۡتَـٰنࣰا﴾</span>: ظُلمًا بغيرِ حَقّ.</p></div>"
  4,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡضَىٰ﴾</span>: بالجِماعِ.</p><p><span class="qpc-hafs">﴿مِّيثَـٰقًا غَلِيظࣰا﴾</span>: إمساكَهُنَّ بمعروفٍ، أو تَسْرِيحَهُنَّ بإحسانٍ.</p></div>"
  4,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَفَ﴾</span>: مضى في الجاهلية، فلا مُؤاخَذَةَ فيه.</p><p><span class="qpc-hafs">﴿وَمَقۡتࣰا﴾</span>: وبُغْضًا، أي: يُبْغِضُ اللهُ فاعلَه.</p></div>"
  4,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّهَـٰتُكُمۡ﴾</span>: ويَدْخُلُ فيه الجَدّاتُ.</p><p><span class="qpc-hafs">﴿وَبَنَاتُكُمۡ﴾</span>: ويشْمَلُ بناتِ الأولادِ.</p><p><span class="qpc-hafs">﴿وَأَخَوَ ٰ⁠تُكُمۡ﴾</span>: الشقيقاتُ، أو لأبٍ، أو لأمّ.</p><p><span class="qpc-hafs">﴿وَأُمَّهَـٰتُ نِسَآئِكُمۡ﴾</span>: سواءٌ أدخَلْتُمْ بنسائكم أم لا.</p><p><span class="qpc-hafs">﴿وَرَبَـٰٓئِبُكُمُ﴾</span>: وبناتُ نسائِكم من غيرِكم، اللاتي يتربَّينَ في بيوتِكم، فإن لم يكونوا كذلك، ولم تَدْخُلوا بأمَّهاتِهن وطَلَّقْتموهن، أو مِتْنَ قبلَ الدُّخولِ، فلا جُناحَ عليكم أن تنكِحُوهنّ.</p><p><span class="qpc-hafs">﴿وَحَلَـٰٓئِلُ أَبۡنَآئِكُمُ﴾</span>: زوجاتُ أبنائِكم ممَّن دَخَلَ الابنُ بها، أو لَم يدْخُلْ.</p></div>"
  4,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمُحۡصَنَـٰتُ﴾</span>: يَحْرُمُ نِكاحُ ذَواتِ الأزواج غيرِ المَسْبِيّات.</p><p><span class="qpc-hafs">﴿مَا مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾</span>: مَن سَبَيْتم في الجهادِ، فيَحِلُّ النكاحُ بعد الاستِبْراءِ بحَيْضَةٍ، من غير طلاقِ زوجِها الحربيِّ لها.</p><p><span class="qpc-hafs">﴿مَّا وَرَآءَ ذَ ٰ⁠لِكُمۡ﴾</span>: مِن سِواهنّ.</p><p><span class="qpc-hafs">﴿مُّحۡصِنِينَ﴾</span>: أعِفّاءَ.</p><p><span class="qpc-hafs">﴿غَيۡرَ مُسَـٰفِحِينَ﴾</span>: غيرَ زانِين.</p><p><span class="qpc-hafs">﴿أُجُورَهُنَّ﴾</span>: مُهورَهُنَّ وهذا في النِّكاحِ الشَّرْعيِّ.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ ٱلۡفَرِيضَةِ﴾</span>: من زيادةٍ أو نقصانٍ في المهْرِ، فذلك سائغٌ عند التَّراضي.</p></div>"
  4,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَوۡلًا﴾</span>: قُدرةً وسَعَةً، وهو المَهْرُ لنِكاحِ الحَرائرِ.</p><p><span class="qpc-hafs">﴿بَعۡضُكُم مِّنۢ بَعۡضࣲ﴾</span>: في النسَبِ والدِّينِ.</p><p><span class="qpc-hafs">﴿بِإِذۡنِ أَهۡلِهِنَّ﴾</span>: بموافقةِ سَيّدِهن؛ لأنّ منافعَهنّ له.</p><p><span class="qpc-hafs">﴿أَخۡدَانࣲ﴾</span>: ولا مُسِرّاتٍ بالزِّنى باتخاذِ أصدقاءَ.</p><p><span class="qpc-hafs">﴿فَعَلَيۡهِنَّ﴾</span>: فعلى الإماءِ خمسون جَلْدَةً، ونَفْيُ ستةِ أشهرٍ، وليس على الإماءِ رَجْمٌ لأنه لايَتَنَصَّفُ.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: أي: ما أُبيحَ لكم من نِكاحِ الإماءِ.</p><p><span class="qpc-hafs">﴿خَشِيَ ٱلۡعَنَتَ﴾</span>: خوفَ الوقوعِ في الزِّنى والمشقَّةِ.</p><p><span class="qpc-hafs">﴿وَأَن تَصۡبِرُواْ﴾</span>: عن نكاحِ الإماء مع العفَّةِ.</p></div>"
  4,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُنَنَ﴾</span>: طُرُقَ الأنبياءِ وأتباعِهم لتَقْتَدُوا بها.</p></div>"
  4,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَّبِعُونَ ٱلشَّهَوَ ٰ⁠تِ﴾</span>: يَنْقادُون لشهَواتِ أنفسِهم من أهلِ الباطلِ.</p><p><span class="qpc-hafs">﴿تَمِيلُواْ﴾</span>: تَنْحَرفُوا عن الدِّينِ بإتيانِكم ما حَرَّمَ عليكم.</p></div>"
  4,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يُخَفِّفَ﴾</span>: أن يُيَسِّرَ عليكم.</p></div>"
  4,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: كالرِّبا والقِمار.</p><p><span class="qpc-hafs">﴿تِجَـٰرَةً﴾</span>: موافِقَةً للشَّرعِ.</p><p><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوٓاْ أَنفُسَكُمۡ﴾</span>: بألّا تُهْلِكُوها بارتكابِ المعاصي، وألّا يقتلَ بعضُكم بعضًا، وألّا يقتلَ نفسَه حقيقةً.</p></div>"
  4,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: ما نهى اللهُ عنه مما تقدَّم.</p><p><span class="qpc-hafs">﴿عُدۡوَ ٰ⁠نࣰا﴾</span>: متجاوِزًا حَدَّ الشَّرْعِ.</p></div>"
  4,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَبَآئِرَ مَا تُنۡهَوۡنَ عَنۡهُ﴾</span>: هي كلُّ ذَنْبٍ رَتَّبَ اللهُ عليه الحَدَّ، أو صَرَّح بالوعيدِ فيه.</p><p><span class="qpc-hafs">﴿سَيِّـَٔاتِكُمۡ﴾</span>: الصَّغائرَ.</p><p><span class="qpc-hafs">﴿مُّدۡخَلࣰا كَرِيمࣰا﴾</span>: الجنةَ.</p></div>"
  4,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا فَضَّلَ ٱللَّهُ بِهِۦ بَعۡضَكُمۡ عَلَىٰ بَعۡضࣲ﴾</span>: ما فَضَّل اللهُ به غيرَكم عليكم في المواهِبِ والأرزاقِ.</p><p><span class="qpc-hafs">﴿نَصِيبࣱ﴾</span>: مقدارٌ من الجزاءِ بحسَبِ العملِ.</p><p><span class="qpc-hafs">﴿مِن فَضۡلِهِۦٓ﴾</span>: من عَوْنِه، وتوفيقِه.</p></div>"
  4,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِكُلࣲّ﴾</span>: ولكلِّ واحدٍ.</p><p><span class="qpc-hafs">﴿مَوَ ٰ⁠لِيَ﴾</span>: ورَثَةٌ يرثُون.</p><p><span class="qpc-hafs">﴿عَقَدَتۡ أَيۡمَـٰنُكُمۡ﴾</span>: تحالَفْتُم معهم بالأيمانِ على النُّصرةِ، وإعطائِهم قَدْرًا من الميراثِ، وهذا منسوخٌ.</p></div>"
  4,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوَّ ٰ⁠مُونَ﴾</span>: أهلُ قيامٍ بمصالحهنَّ.</p><p><span class="qpc-hafs">﴿بِمَا فَضَّلَ ٱللَّهُ﴾</span>: بما خَصَّهم من القِوامةِ والتفضيلِ، كالإنفاقِ وكفايةِ المؤونةِ.</p><p><span class="qpc-hafs">﴿قَـٰنِتَـٰتٌ﴾</span>: مطيعاتٌ لله، قائماتٌ بحقوقِ الزوج.</p><p><span class="qpc-hafs">﴿حَـٰفِظَـٰتࣱ لِّلۡغَيۡبِ﴾</span>: حافظاتٌ لمايَجبُ حِفْظُه عند غَيبةِ أزواجِهنَّ عنهن.</p><p><span class="qpc-hafs">﴿بِمَا حَفِظَ ٱللَّهُ﴾</span>: بحِفْظِ اللهِ، وتوفيقِه لهن.</p><p><span class="qpc-hafs">﴿نُشُوزَهُنَّ﴾</span>: استعلاءَهن على أزواجِهنَّ.</p><p><span class="qpc-hafs">﴿فَعِظُوهُنَّ﴾</span>: بالكلمةِ الطيبةِ، إن نفعَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡمَضَاجِعِ﴾</span>: جَمْعُ مَضْجَع، وهو الفِراشُ، فلا تَقْرَبُوهنَّ، إنْ نَفَعَ ذلك.</p><p><span class="qpc-hafs">﴿وَٱضۡرِبُوهُنَّ﴾</span>: ضَرْبًا غيرَ مُبَرِّحٍ أومؤثِّرٍ.</p><p><span class="qpc-hafs">﴿فَلَا تَبۡغُواْ عَلَيۡهِنَّ سَبِيلًا﴾</span>: فاحذَرُوا ظُلْمَهنَّ.</p></div>"
  4,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱبۡعَثُواْ﴾</span>: أي: إلى الزوجَيْن.</p><p><span class="qpc-hafs">﴿حَكَمࣰا﴾</span>: عَدْلًا ممَّنْ يَصْلُحُ لذلك.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمَآ﴾</span>: بينَ الزوجَين، أو الحكَمَين.</p></div>"
  4,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡيَتَـٰمَىٰ﴾</span>: الأولادِ الذين ماتَ أباؤُهم وهم دونَ البُلوغ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: الذين لا يملِكُون ما يَكْفيهم.</p><p><span class="qpc-hafs">﴿ٱلۡجُنُبِ﴾</span>: البعيدِ.</p><p><span class="qpc-hafs">﴿وَٱلصَّاحِبِ بِٱلۡجَنۢبِ﴾</span>: الرفيقِ في السَّفَر والحَضَرِ.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: المسافرِ المحتاجِ.</p><p><span class="qpc-hafs">﴿وَمَا مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾</span>: الرقيقِ ذكورًا وإناثًا.</p></div>"
  4,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعۡتَدۡنَا﴾</span>: وأَعْدَدْنا.</p><p><span class="qpc-hafs">﴿مُّهِينࣰا﴾</span>: مُخْزِيًا.</p></div>"
  4,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِئَآءَ ٱلنَّاسِ﴾</span>: من أجلِ الرِّياءِ والسُّمعةِ.</p><p><span class="qpc-hafs">﴿قَرِينࣰا﴾</span>: مُلازِمًا له، ويعملُ بطاعتِه.</p></div>"
  4,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَاذَا عَلَيۡهِمۡ﴾</span>: وأيُّ ضررٍ يَلْحقهم؟</p></div>"
  4,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَظۡلِمُ مِثۡقَالَ ذَرَّةࣲ﴾</span>: لا يُنْقِصُ أحدًا من جزاءِ عَمَلِه مقدارَ ذَرّة.</p></div>"
  4,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَيۡفَ﴾</span>: فكيف يكون حالُ الناسِ يومَ القيامةِ؟</p><p><span class="qpc-hafs">﴿بِكَ﴾</span>: أيها الرسولُ.</p><p><span class="qpc-hafs">﴿عَلَىٰ هَـٰٓؤُلَآءِ﴾</span>: على أمَّتِك.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: شاهدًا على الأمَّةِ بما عَمِلت.</p></div>"
  4,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُسَوَّىٰ بِهِمُ ٱلۡأَرۡضُ﴾</span>: يجعلهم الله والأرضَ سواءً، فيصيرون ترابًا.</p><p><span class="qpc-hafs">﴿وَلَا يَكۡتُمُونَ﴾</span>: ولا يُخْفُون عن اللهِ شيئًا، وسوف تَشْهَدُ على عَمَلِهم جَوارحُهم.</p></div>"
  4,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنتُمۡ سُكَـٰرَىٰ﴾</span>: نَزَلَ هذا الحكمُ قبلَ تحريمِ الخمرِ.</p><p><span class="qpc-hafs">﴿عَابِرِي سَبِيلٍ﴾</span>: مَن كان مُجتازًا من باب المسجد، أوهو المسافر.</p><p><span class="qpc-hafs">﴿لَـٰمَسۡتُمُ﴾</span>: جامَعْتُمْ.</p><p><span class="qpc-hafs">﴿فَتَيَمَّمُواْ صَعِيدࣰا طَيِّبࣰا﴾</span>: فاقصِدوا ترابًا طاهرًا.</p></div>"
  4,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصِيبࣰا مِّنَ ٱلۡكِتَـٰبِ﴾</span>: حَظًّا من العِلْم بالتوراةِ.</p><p><span class="qpc-hafs">﴿ٱلسَّبِيلَ﴾</span>: الطريقَ المستقيمَ.</p></div>"
  4,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيࣰّا﴾</span>: يَتَوَلّاكم.</p></div>"
  4,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَادُواْ﴾</span>: هم اليهودُ.</p><p><span class="qpc-hafs">﴿يُحَرِّفُونَ ٱلۡكَلِمَ﴾</span>: بتغييرِ اللفظِ أو المعنى أو هما جميعًا.</p><p><span class="qpc-hafs">﴿غَيۡرَ مُسۡمَعࣲ﴾</span>: لا سَمِعْتَ، وهذا من قَبيلِ الاستهزاءِ.</p><p><span class="qpc-hafs">﴿وَرَ ٰ⁠عِنَا﴾</span>: افهَمْ عنا، وأفْهِمْنا.</p><p><span class="qpc-hafs">﴿لَيَّۢا بِأَلۡسِنَتِهِمۡ﴾</span>: يَلْوُون ألسنتَهم عن الحق.</p><p><span class="qpc-hafs">﴿وَٱسۡمَعۡ﴾</span>: دونَ «غيرَ مُسْمَعٍ».</p><p><span class="qpc-hafs">﴿وَٱنظُرۡنَا﴾</span>: انتظِرْنا نَفْهَمْ عنك، بَدَلَ «راعِنا».</p><p><span class="qpc-hafs">﴿وَأَقۡوَمَ﴾</span>: وأصوبَ قولًا.</p><p><span class="qpc-hafs">﴿لَّعَنَهُمُ﴾</span>: طَرَدَهم من رحمتِه.</p></div>"
  4,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّمَا مَعَكُم﴾</span>: من الكُتُبِ.</p><p><span class="qpc-hafs">﴿أَن نَّطۡمِسَ وُجُوهࣰا فَنَرُدَّهَا عَلَىٰٓ أَدۡبَارِهَآ﴾</span>: نَمْحُوَ الوجوهَ، ونجعلَ أبصارَها في أدبارِ الوجوهِ.</p><p><span class="qpc-hafs">﴿أَصۡحَـٰبَ ٱلسَّبۡتِ﴾</span>: هم اليهودُ الذين نُهُوا عن الصَّيدِ في يومِ السبت، فلم يَنْتَهُوا.</p><p><span class="qpc-hafs">﴿مَفۡعُولًا﴾</span>: كائنًا لا محالةَ.</p></div>"
  4,48,""
  4,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُزَكُّونَ﴾</span>: يُثْنُون، وهم اليهودُ.</p></div>"
  4,50,""
  4,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصِيبࣰا﴾</span>: حَظًّا.</p><p><span class="qpc-hafs">﴿بِٱلۡجِبۡتِ وَٱلطَّـٰغُوتِ﴾</span>: هما كلُّ معبودٍ من دونِ اللهِ، أو مُطاعٍ في معصيته.</p></div>"
  4,52,""
  4,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصِيبࣱ﴾</span>: حَظٌّ.</p><p><span class="qpc-hafs">﴿فَإِذࣰا لَّا يُؤۡتُونَ﴾</span>: إن جُعِلَ لهم ذلك فإذن لايُعْطُون، لشِدَّةِ بُخْلِهم.</p><p><span class="qpc-hafs">﴿نَقِيرًا﴾</span>: النُّقطةَ في ظَهْر النَّواةِ، أو وسَطِها.</p></div>"
  4,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّاسَ﴾</span>: محمدًا وأصحابَه.</p><p><span class="qpc-hafs">﴿فَضۡلِهِۦ﴾</span>: النبوَّةِ، والنصْرِ.</p><p><span class="qpc-hafs">﴿فَقَدۡ ءَاتَيۡنَآ ءَالَ إِبۡرَ ٰ⁠هِيمَ﴾</span>: فكيف لا يَحْسُدون آلَ إبراهيمَ، واليهودُ يعترفون به؟ فما آتينا محمدًا ليس ببِدْعٍ حتى يُحْسَدَ عليه.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: ما أُوحِي إليهم من غيرِ الكتابِ.</p><p><span class="qpc-hafs">﴿مُّلۡكًا عَظِيمࣰا﴾</span>: مُلْكَ سليمانَ.</p></div>"
  4,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَعِيرًا﴾</span>: نارًا تُوقَدُ عليهم.</p></div>"
  4,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَضِجَتۡ﴾</span>: احترقَتْ.</p></div>"
  4,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّطَهَّرَةࣱ﴾</span>: من كلِّ دَنَسٍ يكونُ في نساءِ أهلِ الدُّنيا.</p><p><span class="qpc-hafs">﴿ظَلِيلًا﴾</span>: كثيفًا ممتدًّا.</p></div>"
  4,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعِمَّا﴾</span>: نِعْمَ الشيءُ.</p></div>"
  4,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُوْلِي ٱلۡأَمۡرِ﴾</span>: الأئمةَ، ومَن ولّاه المسلمون، مالم يَكُنْ في طاعتِهم معصيةٌ.</p><p><span class="qpc-hafs">﴿فَرُدُّوهُ﴾</span>: أرْجِعُوا الحُكْمَ فيه.</p><p><span class="qpc-hafs">﴿تَأۡوِيلًا﴾</span>: عاقبةً ومَرْجِعًا.</p></div>"
  4,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُنزِلَ إِلَيۡكَ﴾</span>: هوالقرآنُ.</p><p><span class="qpc-hafs">﴿ٱلطَّـٰغُوتِ﴾</span>: غيرِ ما شَرَع الله.</p></div>"
  4,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصُدُّونَ﴾</span>: يُعْرِضُون.</p></div>"
  4,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَيۡفَ﴾</span>: فكيف يكون حالُهم؟</p><p><span class="qpc-hafs">﴿وَتَوۡفِيقًا﴾</span>: بين الخُصومِ.</p></div>"
  4,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعِظۡهُمۡ﴾</span>: خَوِّفْهم من النِّفاقِ.</p><p><span class="qpc-hafs">﴿بَلِيغࣰا﴾</span>: مُؤَثِّرًا، زاجرًا لهم.</p></div>"
  4,64,""
  4,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرَ بَيۡنَهُمۡ﴾</span>: وقَعَ بينَهم من نِزاعٍ.</p><p><span class="qpc-hafs">﴿حَرَجࣰا﴾</span>: ضِيقًا.</p><p><span class="qpc-hafs">﴿وَيُسَلِّمُواْ﴾</span>: ويَنْقادوا.</p></div>"
  4,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَتَبۡنَا﴾</span>: فَرَضْنا.</p><p><span class="qpc-hafs">﴿ٱقۡتُلُوٓاْ أَنفُسَكُمۡ﴾</span>: أن يقتُلَ بعضُكم بعضًا.</p><p><span class="qpc-hafs">﴿مَا يُوعَظُونَ بِهِۦ﴾</span>: مايُنْصَحُون به.</p><p><span class="qpc-hafs">﴿تَثۡبِيتࣰا﴾</span>: تَصْديقًا.</p></div>"
  4,67,""
  4,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣰا﴾</span>: طريقًا.</p></div>"
  4,69,""
  4,70,""
  4,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُذُواْ حِذۡرَكُمۡ﴾</span>: بالاستعدادِ لعدوِّكم.</p><p><span class="qpc-hafs">﴿ثُبَاتٍ﴾</span>: جَمْعُ ثُبَة، وهي الجماعةُ بعدَ جماعةٍ.</p></div>"
  4,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: حاضِرًا، فيُصِبْني شيءٌ.</p></div>"
  4,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَن لَّمۡ تَكُنۢ بَيۡنَكُمۡ وَبَيۡنَهُۥ مَوَدَّةࣱ﴾</span>: كأنه ليس منكم، ولا بينَكم وبينَه مودةُ الإيمانِ؛ حَسَدًا منه.</p></div>"
  4,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَشۡرُونَ﴾</span>: يَبِيعون.</p></div>"
  4,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَرۡيَةِ﴾</span>: مكَّةَ.</p></div>"
  4,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّـٰغُوتِ﴾</span>: البَغْيِ والفسادِ في الأرضِ.</p><p><span class="qpc-hafs">﴿كَيۡدَ ٱلشَّيۡطَـٰنِ﴾</span>: تدبيرَه.</p></div>"
  4,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُفُّوٓاْ أَيۡدِيَكُمۡ﴾</span>: لا تُقاتِلوا، وذلك قبلَ الإذنِ بالجِهادِ.</p><p><span class="qpc-hafs">﴿أَجَلࣲ﴾</span>: وقتٍ.</p><p><span class="qpc-hafs">﴿فَتِيلًا﴾</span>: مقدارَ الخيطِ في شِقِّ نَواةِ التمرةِ.</p></div>"
  4,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُرُوجࣲ مُّشَيَّدَةࣲ﴾</span>: حُصونٍ مَنيعةٍ.</p><p><span class="qpc-hafs">﴿مِنۡ عِندِكَ﴾</span>: أيُّها الرسولُ، وهذا من جَهْلِهم.</p></div>"
  4,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمِن نَّفۡسِكَ﴾</span>: بذَنْبٍ اكْتَسَبْتَه.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: على صِدْقِ رسالتِك.</p></div>"
  4,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span>: أعْرَضَ عن طاعةِ الله ورسولِه.</p><p><span class="qpc-hafs">﴿حَفِيظࣰا﴾</span>: حافظًا لما يعملون، مُحاسِبًا.</p></div>"
  4,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَاعَةࣱ﴾</span>: أمْرُنا طاعةٌ.</p><p><span class="qpc-hafs">﴿بَرَزُواْ﴾</span>: خَرَجُوا.</p><p><span class="qpc-hafs">﴿بَيَّتَ﴾</span>: دَبَّر بلَيْلٍ.</p><p><span class="qpc-hafs">﴿غَيۡرَ ٱلَّذِي تَقُولُ﴾</span>: غيرَ ما أعْلَنُوه من الطاعةِ.</p><p><span class="qpc-hafs">﴿وَكِيلًا﴾</span>: ناصرًا.</p></div>"
  4,82,""
  4,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَهُمۡ﴾</span>: جاء هذه الطائفةَ المُبَيِّتَةَ.</p><p><span class="qpc-hafs">﴿أَذَاعُواْ بِهِۦ﴾</span>: أفشَوْه، وأعْلَنُوه.</p><p><span class="qpc-hafs">﴿لَعَلِمَهُ ٱلَّذِينَ يَسۡتَنۢبِطُونَهُۥ﴾</span>: لَعَلِمَ حقيقةَ معناه أهلُ الفقهِ والاستنباطِ منهم، فهم يعلمون ما ينبغي أن يُفْشى، أو يُكْتَمَ.</p></div>"
  4,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُكَلَّفُ إِلَّا نَفۡسَكَ﴾</span>: لا تُلْزَمُ فِعْلَ غيرِك، ولا تُؤاخَذُ به.</p><p><span class="qpc-hafs">﴿وَحَرِّضِ ٱلۡمُؤۡمِنِينَ﴾</span>: وحُضَّهم على الجهادِ.</p><p><span class="qpc-hafs">﴿يَكُفَّ﴾</span>: يَمْنَعَ.</p><p><span class="qpc-hafs">﴿بَأۡسَ﴾</span>: شدَّةَ.</p><p><span class="qpc-hafs">﴿تَنكِيلࣰا﴾</span>: عقوبةً.</p></div>"
  4,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَفَـٰعَةً حَسَنَةࣰ﴾</span>: هي السَّعْيُ لحصولِ الآخَرينَ على الخيرِ.</p><p><span class="qpc-hafs">﴿مِّنۡهَا﴾</span>: نصيبٌ مِن ثوابِها.</p><p><span class="qpc-hafs">﴿كِفۡلࣱ﴾</span>: نَصِيبٌ من إثمِها.</p><p><span class="qpc-hafs">﴿مُّقِيتࣰا﴾</span>: قديرًا، أو حفيظًا شاهدًا.</p></div>"
  4,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسِيبًا﴾</span>: مُجازِيًا.</p></div>"
  4,87,""
  4,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِئَتَيۡنِ﴾</span>: فِرْقَتَين.</p><p><span class="qpc-hafs">﴿أَرۡكَسَهُم﴾</span>: رَدَّهم إلى الكفرِ، وأوقعَهم فيه.</p><p><span class="qpc-hafs">﴿سَبِيلࣰا﴾</span>: طَريقًا.</p></div>"
  4,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَآءࣰ﴾</span>: كُفّارًا مِثْلَهم.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أصفياءَ.</p><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعرضُوا.</p></div>"
  4,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصِلُونَ إِلَىٰ قَوۡمِۭ﴾</span>: يَتَّصِلُون بقومٍ.</p><p><span class="qpc-hafs">﴿مِّيثَـٰقٌ﴾</span>: عَهْدٌ.</p><p><span class="qpc-hafs">﴿حَصِرَتۡ﴾</span>: ضاقَتْ.</p><p><span class="qpc-hafs">﴿ٱلسَّلَمَ﴾</span>: الاستسلامَ.</p></div>"
  4,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاخَرِينَ﴾</span>: من المنافقين.</p><p><span class="qpc-hafs">﴿ٱلۡفِتۡنَةِ﴾</span>: الشِّركِ.</p><p><span class="qpc-hafs">﴿أُرۡكِسُواْ﴾</span>: ارتَدُّوا، ووَقَعُوا.</p><p><span class="qpc-hafs">﴿يَعۡتَزِلُوكُمۡ﴾</span>: يَنْصَرِفُوا عنكم.</p><p><span class="qpc-hafs">﴿ٱلسَّلَمَ﴾</span>: الاستسلامَ.</p><p><span class="qpc-hafs">﴿ثَقِفۡتُمُوهُمۡ﴾</span>: وجَدْتُموهم.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً بَيِّنَةً على قَتْلِهِم، أو أسْرِهم.</p></div>"
  4,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَطَـࣰٔا﴾</span>: مِن غيرِ عَمْدٍ.</p><p><span class="qpc-hafs">﴿إِلَّآ أَن يَصَّدَّقُواْ﴾</span>: إلا أن يَتَصدَّقُوا بها عليه، ويَعْفُوا.</p><p><span class="qpc-hafs">﴿مِّيثَـٰقࣱ﴾</span>: عهدٌ.</p></div>"
  4,93,""
  4,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَبَيَّنُواْ﴾</span>: كُونُوا على بَيِّنَةٍ فيمَن تقتُلونه.</p><p><span class="qpc-hafs">﴿ٱلسَّلَـٰمَ﴾</span>: بدا منه شيءٌ من علاماتِ الإسلام، لأنه قد يكونُ مؤمنًا يُخفي إيمانَه.</p><p><span class="qpc-hafs">﴿كُنتُم مِّن قَبۡلُ﴾</span>: تُخْفُون إيمانَكم عن قومِكم المشركين.</p><p><span class="qpc-hafs">﴿فَمَنَّ ٱللَّهُ عَلَيۡكُمۡ﴾</span>: فأعَزَّكم بالإيمانِ، والقوةِ.</p></div>"
  4,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَـٰعِدُونَ﴾</span>: المتخلِّفون عن الجهادِ.</p><p><span class="qpc-hafs">﴿أُوْلِي ٱلضَّرَرِ﴾</span>: أصحابِ الأعذارِ.</p><p><span class="qpc-hafs">﴿وَكُلࣰّا﴾</span>: وكلَّ أحدٍ من المجاهدين والقاعدين، من أهلِ الأعذارِ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الجنةَ.</p></div>"
  4,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَرَجَـٰتࣲ﴾</span>: منازلَ.</p></div>"
  4,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَالِمِيٓ أَنفُسِهِمۡ﴾</span>: بقُعودِهم في دارِ الكفرِ، وتَرْكِ الهجرةِ.</p></div>"
  4,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسۡتَطِيعُونَ حِيلَةࣰ﴾</span>: لايَقْدِرُون على دَفْعِ الظُّلمِ عنهم.</p></div>"
  4,99,""
  4,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُرَ ٰ⁠غَمࣰا﴾</span>: مُتَحَوَّلًا.</p><p><span class="qpc-hafs">﴿سَعَةࣰ﴾</span>: في الرِّزقِ.</p></div>"
  4,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَبۡتُمۡ﴾</span>: سافَرْتُم.</p><p><span class="qpc-hafs">﴿يَفۡتِنَكُمُ﴾</span>: يَعْتدِيَ عليكم.</p></div>"
  4,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُنتَ﴾</span>: أي: في ساحةِ القتالِ، وأُقيمَت الصلاةُ.</p><p><span class="qpc-hafs">﴿وَلۡيَأۡخُذُوٓاْ أَسۡلِحَتَهُمۡ﴾</span>: هم الطائفةُ التي تُصَلِّي معه، تحملُ سلاحَها، وتُصَلي مع الإمامِ رَكعةً واحدةً، ثم يأخُذون مكانَ الطائفةِ التي لم تُصَلِّ.</p><p><span class="qpc-hafs">﴿فَلۡيَكُونُواْ﴾</span>: هم الطائفةُ القائمةُ بإزاءِ العدوِّ.</p><p><span class="qpc-hafs">﴿مِن وَرَآئِكُمۡ﴾</span>: من وراءِ المُصَلِّين.</p><p><span class="qpc-hafs">﴿فَلۡيُصَلُّواْ مَعَكَ﴾</span>: وهم الذين لم يُصَلُّوا، فيُصَلُّون مع الإمامِ رَكْعَةً.</p><p><span class="qpc-hafs">﴿فَيَمِيلُونَ عَلَيۡكُم مَّيۡلَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: فَيقْضُون عليكم.</p><p><span class="qpc-hafs">﴿وَلَا جُنَاحَ﴾</span>: ولا إثمَ.</p></div>"
  4,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَقِيمُواْ ٱلصَّلَوٰةَ﴾</span>: كاملةً برُكوعِها وسجودِها.</p><p><span class="qpc-hafs">﴿مَّوۡقُوتࣰا﴾</span>: في أوقاتٍ معلومةٍ.</p></div>"
  4,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَهِنُواْ﴾</span>: ولا تَضْعُفوا.</p><p><span class="qpc-hafs">﴿فِي ٱبۡتِغَآءِ ٱلۡقَوۡمِ﴾</span>: في طَلَبِ عَدوِّكم.</p><p><span class="qpc-hafs">﴿تَأۡلَمُونَ﴾</span>: من القتالِ.</p><p><span class="qpc-hafs">﴿وَتَرۡجُونَ﴾</span>: من الثوابِ والنَّصْرِ.</p></div>"
  4,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَآ أَرَىٰكَ ٱللَّهُ﴾</span>: بما أوْحى إليك، وبَصَّرَكَ به.</p><p><span class="qpc-hafs">﴿خَصِيمࣰا﴾</span>: مُدافِعًا عنهم.</p></div>"
  4,106,""
  4,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُجَـٰدِلۡ﴾</span>: ولا تُدافِعْ، وتخاصِمْ.</p><p><span class="qpc-hafs">﴿يَخۡتَانُونَ﴾</span>: يَخُونون بمعصيةِ اللهِ.</p><p><span class="qpc-hafs">﴿خَوَّانًا﴾</span>: كثيرَ الخيانةِ.</p><p><span class="qpc-hafs">﴿أَثِيمࣰا﴾</span>: كثيرَ الذَّنْبِ.</p></div>"
  4,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَخۡفُونَ﴾</span>: يَسْتَتِرُون.</p><p><span class="qpc-hafs">﴿وَهُوَ مَعَهُمۡ﴾</span>: بعِلْمِه.</p><p><span class="qpc-hafs">﴿يُبَيِّتُونَ﴾</span>: يُدَبِّرُون ليلًا.</p></div>"
  4,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلࣰا﴾</span>: مُجادِلًا يقومُ بأمرِهم.</p></div>"
  4,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظۡلِمۡ نَفۡسَهُۥ﴾</span>: بارتكابِ معصيةٍ.</p></div>"
  4,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكۡسِبُهُۥ عَلَىٰ نَفۡسِهِۦ﴾</span>: يَضُرُّها.</p></div>"
  4,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِثۡمࣰا﴾</span>: ذَنبًا عن عَمْدٍ.</p><p><span class="qpc-hafs">﴿ٱحۡتَمَلَ بُهۡتَـٰنࣰا﴾</span>: تَحَمَّلَ كَذِبًا.</p><p><span class="qpc-hafs">﴿مُّبِينࣰا﴾</span>: بَيِّنًا.</p></div>"
  4,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضۡلُ ٱللَّهِ﴾</span>: بالنبوَّةِ، فعَصَمَك بتوفيقِه.</p><p><span class="qpc-hafs">﴿يُضِلُّوكَ﴾</span>: يُزِلُّوك عن الحقِّ.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: السُّنَّةَ.</p></div>"
  4,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّجۡوَىٰهُمۡ﴾</span>: كلامِهم سِرًّا.</p><p><span class="qpc-hafs">﴿مَعۡرُوفٍ﴾</span>: أعمالِ البِرِّ، والخيرِ.</p></div>"
  4,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُشَاقِقِ﴾</span>: يُخالِفْ، ويُعادِ.</p><p><span class="qpc-hafs">﴿تَبَيَّنَ﴾</span>: ظَهَرَ.</p><p><span class="qpc-hafs">﴿نُوَلِّهِۦ مَا تَوَلَّىٰ﴾</span>: نَتْرُكْه وما تَوَجَّه إليه.</p></div>"
  4,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا دُونَ ذَ ٰ⁠لِكَ﴾</span>: ما دونَ الشِّرك.</p></div>"
  4,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَـٰثࣰا﴾</span>: أوثانًا لها أسماءٌ مؤنثةٌ.</p><p><span class="qpc-hafs">﴿مَّرِيدࣰا﴾</span>: متمرِّدًا على اللهِ، وهو إبليسُ.</p></div>"
  4,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّعَنَهُ ٱللَّهُ﴾</span>: طَرَدَه من رَحْمَتِه.</p><p><span class="qpc-hafs">﴿نَصِيبࣰا مَّفۡرُوضࣰا﴾</span>: جُزْءًا منهم معلومًا، وبَيَّن ذلك بما بعدَه.</p></div>"
  4,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَأُضِلَّنَّهُمۡ﴾</span>: ولَأَصْرِفَنَّهم عن طريقِ الهدايةِ.</p><p><span class="qpc-hafs">﴿وَلَأُمَنِّيَنَّهُمۡ﴾</span>: لَأَعِدَنَّهم بالأماني الكاذبةِ.</p><p><span class="qpc-hafs">﴿فَلَيُبَتِّكُنَّ﴾</span>: لَأَدْعُوَنَّهم إلى تَقْطِيعِ.</p><p><span class="qpc-hafs">﴿خَلۡقَ ٱللَّهِ﴾</span>: في الفِطْرَةِ والهيئةِ.</p></div>"
  4,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعِدُهُمۡ﴾</span>: بالوعودِ الكاذبةِ.</p><p><span class="qpc-hafs">﴿وَيُمَنِّيهِمۡ﴾</span>: بالأماني الباطلةِ.</p><p><span class="qpc-hafs">﴿غُرُورًا﴾</span>: خديعةً.</p></div>"
  4,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَحِيصࣰا﴾</span>: مَلْجَأً.</p></div>"
  4,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِيلࣰا﴾</span>: قولًا.</p></div>"
  4,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّيۡسَ بِأَمَانِيِّكُمۡ﴾</span>: لا يُنالُ هذا الفضلُ بالأماني.</p></div>"
  4,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَقِيرࣰا﴾</span>: النُّقطةَ في ظَهْرِ النَّواةِ.</p></div>"
  4,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُوَ مُحۡسِنࣱ﴾</span>: عاملٌ للحَسَناتِ.</p><p><span class="qpc-hafs">﴿مِلَّةَ﴾</span>: دينَ.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن العقائدِ الفاسدةِ.</p><p><span class="qpc-hafs">﴿خَلِيلࣰا﴾</span>: صَفِيًّا.</p></div>"
  4,126,""
  4,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُتۡلَىٰ عَلَيۡكُمۡ﴾</span>: أي: والقرآنُ الذي يُتْلى عليكم يُفْتِيكم فيهنَّ.</p><p><span class="qpc-hafs">﴿وَٱلۡمُسۡتَضۡعَفِينَ﴾</span>: أي: ما يُتْلى عليكم في اليتامى، والمستضعفين.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p></div>"
  4,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡلِهَا﴾</span>: زَوْجِها.</p><p><span class="qpc-hafs">﴿نُشُوزًا﴾</span>: استعلاءً بنفسِه عنها.</p><p><span class="qpc-hafs">﴿فَلَا جُنَاحَ﴾</span>: فلا حَرَجَ.</p><p><span class="qpc-hafs">﴿وَأُحۡضِرَتِ ٱلۡأَنفُسُ ٱلشُّحَّ﴾</span>: وجُبِلَتِ الأنفسُ على شُحِّ كلٍّ من الزوجَيْن بنصيبِه.</p></div>"
  4,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن تَعۡدِلُواْ﴾</span>: العَدْلَ التامَّ في مَيْلِ القلبِ.</p><p><span class="qpc-hafs">﴿فَلَا تَمِيلُواْ﴾</span>: فلا تُعْرِضُوا عن المرغوبِ عنها.</p><p><span class="qpc-hafs">﴿فَتَذَرُوهَا﴾</span>: فَتتْرُكوها.</p><p><span class="qpc-hafs">﴿كَٱلۡمُعَلَّقَةِ﴾</span>: لا هيَ مُطَلَّقةٌ، ولا هي ذاتُ زوجٍ.</p></div>"
  4,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغۡنِ ٱللَّهُ كُلࣰّا﴾</span>: يَجْعَلْه مُسْتغنيًا عن الآخَر.</p></div>"
  4,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِيَّاكُمۡ﴾</span>: وصَّينا أُمَّةَ محمدٍ ﷺ.</p></div>"
  4,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلًا﴾</span>: قائمًا بشؤونِ خَلْقِه.</p></div>"
  4,133,""
  4,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَوَابَ ٱلدُّنۡيَا﴾</span>: عَرَضَ الدنيا.</p><p><span class="qpc-hafs">﴿فَعِندَ ٱللَّهِ ثَوَابُ ٱلدُّنۡيَا وَٱلۡـَٔاخِرَةِ﴾</span>: هَلّا طَلَب بعَمَلِه ما عندَ اللهِ من ثوابِ الدنيا والآخرةِ.</p></div>"
  4,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوَّ ٰ⁠مِينَ﴾</span>: ليتكرَّرْ منكم القيامُ.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ، والإقرارِ بما عليكم من الحقوقِ.</p><p><span class="qpc-hafs">﴿شُهَدَآءَ لِلَّهِ﴾</span>: مُؤَدِّين للشَّهادةِ، لمرضاةِ اللهِ.</p><p><span class="qpc-hafs">﴿إِن يَكُنۡ﴾</span>: المشهودُ عليه.</p><p><span class="qpc-hafs">﴿أَوۡلَىٰ بِهِمَا﴾</span>: أحقُّ منكم بكلِّ واحدٍ منهما.</p><p><span class="qpc-hafs">﴿أَن تَعۡدِلُواْ﴾</span>: مخافةَ أن تَعْدِلُوا عن الحقِّ، فتَجُوروا.</p><p><span class="qpc-hafs">﴿تَلۡوُۥٓاْ﴾</span>: تُحَرِّفُوا الشهادةَ.</p><p><span class="qpc-hafs">﴿أَوۡ تُعۡرِضُواْ﴾</span>: بتَرْكِ أدائِها، أو كِتمانِها.</p></div>"
  4,136,""
  4,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبِيلَۢا﴾</span>: طريقًا.</p></div>"
  4,138,""
  4,139,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: أنصارًا.</p><p><span class="qpc-hafs">﴿أَيَبۡتَغُونَ﴾</span>: أيَطْلُبون؟</p><p><span class="qpc-hafs">﴿ٱلۡعِزَّةَ﴾</span>: النُّصْرَةَ، والمنَعَةَ.</p></div>"
  4,140,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّثۡلُهُمۡ﴾</span>: في الكفرِ، لأنكم رَضِيتم بالكفرِ والاستهزاءِ.</p></div>"
  4,141,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يَتَرَبَّصُونَ بِكُمۡ﴾</span>: المنافقون ينتظرون ما يَحُلُّ بكم.</p><p><span class="qpc-hafs">﴿فَتۡحࣱ﴾</span>: نَصْرٌ، وغنيمةٌ.</p><p><span class="qpc-hafs">﴿نَسۡتَحۡوِذۡ﴾</span>: نساعِدْكم، ونَغْلِبْ عليكم.</p><p><span class="qpc-hafs">﴿وَنَمۡنَعۡكُم﴾</span>: بتَخْذِيلهم، وتَثْبيطِهم عنكم.</p><p><span class="qpc-hafs">﴿سَبِيلًا﴾</span>: تَسَلُّطًا، وطريقًا ما داموا عاملين بالحقِّ.</p></div>"
  4,142,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخَـٰدِعُونَ ٱللَّهَ﴾</span>: بما يُظْهِرُونه من الإيمان، ويُبْطِنون الكفرَ، ظنًّا منهم أنه يَخْفى عليه.</p><p><span class="qpc-hafs">﴿وَهُوَ خَـٰدِعُهُمۡ﴾</span>: يُوصِلُ إليهم العقوبةَ بطريقٍ خَفِيّ.</p><p><span class="qpc-hafs">﴿يُرَآءُونَ﴾</span>: يَقْصِدُون بصَلاتِهم الرياءَ والسُّمْعةَ.</p></div>"
  4,143,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّذَبۡذَبِينَ﴾</span>: لايَسْتقِرُّون على حالٍ، بل هم مُتَحَيِّرون.</p><p><span class="qpc-hafs">﴿سَبِيلࣰا﴾</span>: طريقًا إلى الحقِّ.</p></div>"
  4,144,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا مُّبِينًا﴾</span>: حُجَّةً ظاهرةً على كَذِبِكم في إيمانِكم.</p></div>"
  4,145,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدَّرۡكِ﴾</span>: الطَّبَقَةِ.</p></div>"
  4,146,""
  4,147,""
  4,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن ظُلِمَ﴾</span>: فلا حَرَجَ أن يُخْبِرَ بما أُسِيءَ إليه.</p></div>"
  4,149,""
  4,150,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيۡنَ ذَ ٰ⁠لِكَ﴾</span>: بين الإيمانِ والكُفرِ، دِينًا متوسِّطًا بينهما.</p></div>"
  4,151,""
  4,152,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُجُورَهُمۡ﴾</span>: ثوابَهم.</p></div>"
  4,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡرَةࣰ﴾</span>: عِيانًا نَنْظُرُ إليه.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰعِقَةُ﴾</span>: النارُ نَزَلَتْ عليهم، فأهلَكَتْهُم.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً تُؤَيِّدُ صِدْقَ نبوَّتهِ.</p></div>"
  4,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطُّورَ﴾</span>: جَبَلَ الطُّورِ.</p><p><span class="qpc-hafs">﴿بِمِيثَـٰقِهِمۡ﴾</span>: امتَنَعُوا عن الالتزامِ بالعَهْدِ المؤكَّدِ للعملِ بالتَوْراة، فَرفَعَ اللهُ عليهم جَبَلَ الطُّور، فقَبِلُوها.</p><p><span class="qpc-hafs">﴿ٱلۡبَابَ﴾</span>: بابَ بيتِ المَقْدِسِ.</p><p><span class="qpc-hafs">﴿سُجَّدࣰا﴾</span>: خاضِعين لله، لكنهم دَخَلُوا يزحَفُون على أستاهِهم.</p><p><span class="qpc-hafs">﴿لَا تَعۡدُواْ فِي ٱلسَّبۡتِ﴾</span>: لا تَعْتَدُوا بالصَّيدِ يومَ السَّبْتِ، ولكنهم خالَفُوا.</p><p><span class="qpc-hafs">﴿مِّيثَـٰقًا غَلِيظࣰا﴾</span>: عهدًا مؤكَّدًا، فنقضُوه.</p></div>"
  4,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِمَا نَقۡضِهِم مِّيثَـٰقَهُمۡ﴾</span>: لَعَنّاهم بسببِ نَقْضِهم العهودَ المؤكَّدةَ.</p><p><span class="qpc-hafs">﴿غُلۡفُۢ﴾</span>: عليها أغطِيَةٌ، لاتفقَهُ ما تقولُ.</p><p><span class="qpc-hafs">﴿طَبَعَ﴾</span>: خَتَمَ.</p><p><span class="qpc-hafs">﴿إِلَّا قَلِيلࣰا﴾</span>: إلا إيمانًا قليلًا كإيمانِهم بموسى عليه السلامُ والتوراةِ.</p></div>"
  4,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُهۡتَـٰنًا﴾</span>: افتراءً برَمْيِها بالزِّنى.</p></div>"
  4,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُبِّهَ لَهُمۡ﴾</span>: قَتَلُوا رجلًا يُشْبِهُه.</p><p><span class="qpc-hafs">﴿يَقِينَۢا﴾</span>: مُتَيَقِّنِين بأنه عيسى، بل كانوا شاكِّين مُتَوَهِّمين فيه.</p></div>"
  4,158,""
  4,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيُؤۡمِنَنَّ بِهِۦ﴾</span>: أي: بعدَ نُزولِه آخرَ الزَّمانِ.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: شاهدًا عليهم بتكذيبِ مَن كذَّبه، وغالى فيه.</p></div>"
  4,160,""
  4,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعۡتَدۡنَا﴾</span>: وأَعْدَدْنا.</p></div>"
  4,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّ ٰ⁠سِخُونَ﴾</span>: المُتَمَكِّنون.</p><p><span class="qpc-hafs">﴿وَٱلۡمُقِيمِينَ ٱلصَّلَوٰةَ﴾</span>: أي: وأمدَحُ هؤلاء.</p></div>"
  4,163,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَسۡبَاطِ﴾</span>: الأنبياءِ الذين كانوا في قبائِلِ بني إسرائيلَ الاثنتي عشرةَ مِن ولدِ يعقوبَ.</p><p><span class="qpc-hafs">﴿زَبُورࣰا﴾</span>: اسمُ الكتابِ الذي أُنْزلَ على داودَ، وهو صُحُفٌ مكتوبةٌ.</p></div>"
  4,164,""
  4,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبَشِّرِينَ﴾</span>: أي: بثوابي.</p><p><span class="qpc-hafs">﴿وَمُنذِرِينَ﴾</span>: بعقابي.</p><p><span class="qpc-hafs">﴿بَعۡدَ ٱلرُّسُلِ﴾</span>: بعد إرسالِ الرُّسُلِ.</p></div>"
  4,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَفَىٰ بِٱللَّهِ شَهِيدًا﴾</span>: حَسْبُك اللهُ شاهدًا على صِدْقِك.</p></div>"
  4,167,""
  4,168,""
  4,169,""
  4,170,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّ لِلَّهِ مَا فِي ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: أي: فإنه غَنِيٌّ عنكم، وعن إيمانِكم لأنه مالكُ ما في السمواتِ والأرضِ.</p></div>"
  4,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَغۡلُواْ﴾</span>: لا تُجاوِزُوا الحقَّ، فتُفْرِطُوا.</p><p><span class="qpc-hafs">﴿وَكَلِمَتُهُۥٓ﴾</span>: وخَلَقَه بالكلمةِ التي أرسلَ جبريلَ بها إلى مريمَ، وهي قولُه: «كن» فكان.</p><p><span class="qpc-hafs">﴿وَرُوحࣱ مِّنۡهُ﴾</span>: كان إنسانًا بإحياءِ اللهِ له بقولِه: «كن».</p><p><span class="qpc-hafs">﴿وَلَا تَقُولُواْ ثَلَـٰثَةٌ﴾</span>: ولا تجعلُوا عيسى وأمَّه مع اللهِ شريكَيْن.</p><p><span class="qpc-hafs">﴿وَكِيلࣰا﴾</span>: مُدَبِّرًا، وكَلَ الخَلْقُ أمورَهم إليه.</p></div>"
  4,172,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّن يَسۡتَنكِفَ﴾</span>: لن يأْنَفَ، ويَسْتَكْبِرَ.</p></div>"
  4,173,""
  4,174,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُرۡهَـٰنࣱ﴾</span>: محمدٌ ﷺ.</p><p><span class="qpc-hafs">﴿نُورࣰا﴾</span>: قرآنًا.</p></div>"
  4,175,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱعۡتَصَمُواْ بِهِۦ﴾</span>: تَمَسَّكُوا به.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣰا مُّسۡتَقِيمࣰا﴾</span>: طريقًا لاعِوَجَ فيه.</p></div>"
  4,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَفۡتُونَكَ﴾</span>: يَطْلُبون حُكْمَك.</p><p><span class="qpc-hafs">﴿فِي ٱلۡكَلَـٰلَةِ﴾</span>: في ميراثِ مَن مات، وليس له ولدٌ، ولا والد.</p><p><span class="qpc-hafs">﴿فَإِن كَانَتَا ٱثۡنَتَيۡنِ﴾</span>: مَن مات كَلالةً وله أختان.</p><p><span class="qpc-hafs">﴿حَظِّ﴾</span>: نصيبِ.</p><p><span class="qpc-hafs">﴿أَن تَضِلُّواْ﴾</span>: لئلّا تَضِلُّوا عن الحقِّ.</p></div>"
