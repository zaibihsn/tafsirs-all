quran[42]{c,v,t}:
  80,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبَسَ﴾</span>: ظَهَرَ التغَيُّر والعُبُوسُ في وجْهِ الرَّسُولِ ﷺ.</p><p><span class="qpc-hafs">﴿وَتَوَلَّىٰٓ﴾</span>: وأَعْرَضَ.</p></div>"
  80,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَهُ ٱلۡأَعۡمَىٰ﴾</span>: لِأَجْلِ أن جاءَهُ.</p></div>"
  80,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُدۡرِيكَ﴾</span>: وأيُّ شَيءٍ يَجْعَلُكَ عالمًِا بِحَقِيقَةِ أمْرِهِ؟.</p><p><span class="qpc-hafs">﴿يَزَّكَّىٰٓ﴾</span>: تَزْكُو نَفسُهُ وتَطْهُرُ.</p></div>"
  80,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ يَذَّكَّرُ﴾</span>: أو يتَّعِظُ.</p></div>"
  80,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَغۡنَىٰ﴾</span>: عَنْ هَدْيِكَ.</p></div>"
  80,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَصَدَّىٰ﴾</span>: تَتَعَرَّضُ لَهُ وتُصْغِي لِكَلامِهِ.</p></div>"
  80,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا عَلَيۡكَ أَلَّا يَزَّكَّىٰ﴾</span>: وأيُّ شَيءٍ عَلَيكَ ألّا يَتَطَهَّرَ مِن كُفْرِهِ؟</p></div>"
  80,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن جَآءَكَ يَسۡعَىٰ﴾</span>: مَن كانَ حَرِيصًا عَلى لِقائِكَ.</p></div>"
  80,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡشَىٰ﴾</span>: يَخْشى اللهِ.</p></div>"
  80,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلَهَّىٰ﴾</span>: تَتَشاغَلُ.</p></div>"
  80,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: ليسَ الأمرُ كما فَعَلْتَ أيهُّا الرَّسُولُ.</p><p><span class="qpc-hafs">﴿إِنَّهَا تَذۡكِرَةࣱ﴾</span>: إنّ هَذهِ السُّورَةَ مَوعِظَةٌ لَكَ ولِكُلِّ مَن شاءَ الاتِّعاظَ.</p></div>"
  80,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَن شَآءَ ذَكَرَهُۥ﴾</span>: فَمَن شاءَ ذَكَرَ الله وعَمِلَ بِهَدْيِهِ.</p></div>"
  80,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي صُحُفࣲ مُّكَرَّمَةࣲ﴾</span>: هَذا القرآنَ في صُحُفٍ مُعَظَّمَةٍ.</p></div>"
  80,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرۡفُوعَةࣲ﴾</span>: عالية القَدْرِ.</p><p><span class="qpc-hafs">﴿مُّطَهَّرَةِۭ﴾</span>: مُطَهَّرةٍ منَ الدنَسِ والزِّيادةِ والنَّقْصِ.</p></div>"
  80,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَيۡدِي سَفَرَةࣲ﴾</span>: بِأيدِي مَلائِكَةٍ يُسْفِرُونَ بالوَحْيِ، أي: يَسْعونَ بِهِ بَينَ اللهِ ورُسُلِهِ.</p></div>"
  80,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِرَامِۭ﴾</span>: أي عَلى رَبِّهِم.</p><p><span class="qpc-hafs">﴿بَرَرَةࣲ﴾</span>: أخلاقُهُم وأَفعالُهم بارَّةٌ طاهِرَةٌ.</p></div>"
  80,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُتِلَ ٱلۡإِنسَـٰنُ﴾</span>: لُعِنَ الإنسانُ الكافرُ وعُذِّبَ.</p><p><span class="qpc-hafs">﴿مَآ أَكۡفَرَهُۥ﴾</span>: ما أشَدَّ كُفْرَهُ بِرَبِّهِ!!</p></div>"
  80,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ أَيِّ شَيۡءٍ خَلَقَهُۥ﴾</span>: أي أوَّلَ مَرَّةٍ؟.</p></div>"
  80,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن نُّطۡفَةٍ خَلَقَهُۥ﴾</span>: خَلَقَه اللهُ مِن مّاءِ قَلِيلٍ -وهو المَنِيُّ-.</p><p><span class="qpc-hafs">﴿فَقَدَّرَهُۥ﴾</span>: فَقَدَّرهُ أطْوارا.</p></div>"
  80,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ﴾</span>: ثم بَيَّنَ لَهُ طَرِيقَ الخيرِ والشَّرِّ.</p></div>"
  80,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَقۡبَرَهُۥ﴾</span>: فَجَعَلَ لَهُ مَكانًا يُقْبَرُ فِيهِ.</p></div>"
  80,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنشَرَهُۥ﴾</span>: أحْياهُ، وبَعَثَهُ بَعْدَ مَوتِهِ للْحِسابِ والجَزاءِ.</p></div>"
  80,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ليسَ الأمرُ كما يقُولُ الكافِرُ ويَفَعْلُ</p><p><span class="qpc-hafs">﴿لَمَّا يَقۡضِ مَآ أَمَرَهُۥ﴾</span>: لم يُؤَدِّ ما أمَرهُ اللهُ بِهِ.</p></div>"
  80,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَنظُرِ ٱلۡإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ﴾</span>: فَلْيَتَدَبَّرِ الإنْسانُ: كَيفَ خَلَقَ اللهُ طَعامَه الَّذِي هُوَ قِوامُ حياتِهِ؟.</p></div>"
  80,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَبَبۡنَا﴾</span>: أنْزَلَناهُ.</p></div>"
  80,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ شَقَقۡنَا ٱلۡأَرۡضَ﴾</span>: أي بِما أخْرَجْنا مِنها مِن نَّباتٍ شَتّى.</p></div>"
  80,27,""
  80,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَضۡبࣰا﴾</span>: وعَلَفًا للدَّوابِّ.</p></div>"
  80,29,""
  80,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غُلۡبࣰا﴾</span>: عَظِيمةَ الأشْجارِ.</p></div>"
  80,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَبࣰّا﴾</span>: كَلَأً.</p></div>"
  80,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّتَـٰعࣰا﴾</span>: تَنْعَمُونَ بِها وتَنْتَفِعُونَ.</p></div>"
  80,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصَّآخَّةُ﴾</span>: صَيحَةُ يَوْم القِيامَةِ الَّتِي تُصَمُّ مِن هَوْلِها الأَسْماعُ.</p></div>"
  80,34,""
  80,35,""
  80,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَـٰحِبَتِهِۦ﴾</span>: وزَوْجِه.</p></div>"
  80,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَأۡنࣱ يُغۡنِيهِ﴾</span>: أمْرٌ يَشْغَلُهُ.</p></div>"
  80,38,""
  80,39,""
  80,40,""
  80,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡهَقُهَا﴾</span>: تَغْشاها.</p><p><span class="qpc-hafs">﴿قَتَرَةٌ﴾</span>: شِبْهُ دُخانٍ يَغْشى الوجْهَ مِن كَرْبٍ شَدِيدٍ.</p></div>"
  80,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَجَرَةُ﴾</span>: الَّذِين تَجَرَّؤُوا عَلى مَحارِمِ اللهِ بالفُجُورِ والطُّغيانِ.</p></div>"
