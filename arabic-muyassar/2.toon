quran[286]{c,v,t}:
  2,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الٓمٓ﴾</span>: هذه الحروفُ المقطَّعَةُ تُشيرُ إلى أنّ القرآنَ مركَّبٌ من هذه الحروفِ التي تألَّفَتْ منها لغةُ العربِ، وقد عَجَزَ العربُ وغيرُهم عَنِ الإتيانِ بمثلِ القرآنِ، فدلَّ هذا على أن القرآنَ وحْيٌ من اللهِ.</p></div>"
  2,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبُ﴾</span>: القرآنُ.</p><p><span class="qpc-hafs">﴿لَا رَيۡبَۛ فِيهِ﴾</span>: لا شكَّ أنّه مِن عندِ اللهِ.</p><p><span class="qpc-hafs">﴿لِّلۡمُتَّقِينَ﴾</span>: الذين يَخافون اللهَ، ويتَّبعون أحكامَه.</p></div>"
  2,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡمِنُونَ﴾</span>: يُصَدِّقُون.</p><p><span class="qpc-hafs">﴿بِٱلۡغَيۡبِ﴾</span>: بما لا يُدْرَكُ بالحواسِّ والعُقولِ، فلا يُعْرَفُ إلا بالوَحْيِ، كالإيمانِ بالملائكةِ.</p><p><span class="qpc-hafs">﴿وَيُقِيمُونَ﴾</span>: يحافظون على أدائِها في مواقيتِها وفْقَ ما شَرَعَ اللهُ.</p></div>"
  2,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَآ أُنزِلَ إِلَيۡكَ﴾</span>: إلى محمدٍ ﷺ، مِنَ القرآنِ والسُّنةِ.</p><p><span class="qpc-hafs">﴿وَمَآ أُنزِلَ مِن قَبۡلِكَ﴾</span>: مِن كُتُبٍ كالتَّوراةِ والإنجيلِ</p><p><span class="qpc-hafs">﴿وَبِٱلۡـَٔاخِرَةِ هُمۡ يُوقِنُونَ﴾</span>: يُصَدِّقُون بدارِ الحياةِ بعد الموتِ، وما فيها مِنَ الحِسابِ.</p></div>"
  2,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزون.</p></div>"
  2,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَفَرُواْ﴾</span>: جَحَدُوا ما أُنْزِلَ إليك من ربِّك.</p><p><span class="qpc-hafs">﴿سَوَآءٌ﴾</span>: مُتَساوٍ.</p><p><span class="qpc-hafs">﴿ءَأَنذَرۡتَهُمۡ﴾</span>: أخَوَّفْتَهم، وحَذَّرْتَهم.</p></div>"
  2,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَتَمَ﴾</span>: طَبَعَ عليها، فلا تَعِي خيرًا.</p><p><span class="qpc-hafs">﴿غِشَـٰوَةࣱ﴾</span>: غطاءٌ، فلم يُوَفِّقْهم للهُدى.</p><p><span class="qpc-hafs">﴿عَذَابٌ﴾</span>: نارُ جَهنَّمَ في الآخِرَةِ.</p></div>"
  2,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنَ ٱلنَّاسِ﴾</span>: فريقُ المُنافقين الذين يَقُولون بألسِنَتِهم: صَدَّقْنا، وهم في باطنِهم كاذِبُون.</p></div>"
  2,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخَـٰدِعُونَ﴾</span>: يُظْهِرُون خِلافَ ما يُضْمِرُون.</p><p><span class="qpc-hafs">﴿وَمَا يَشۡعُرُونَ﴾</span>: وما يُحِسُّون بذلك؛ لفسادِ قُلوبهِم.</p></div>"
  2,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرَضࣱ﴾</span>: شكٌّ وفسادٌ.</p></div>"
  2,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُفۡسِدُواْ﴾</span>: بالمعاصِي، وإفشاءِ أسرارِ المؤمنين ومُوالاةِ الكافرين.</p></div>"
  2,12,""
  2,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَامِنُواْ﴾</span>: صَدِّقُوا بقُلوبِكم، وألسنتِكم، وجَوارِحِكم.</p><p><span class="qpc-hafs">﴿ٱلسُّفَهَآءُ﴾</span>: ضعافُ العقولِ والرأيِ، يَعْنُون بهم الصَّحابةَ.</p><p><span class="qpc-hafs">﴿لَّا يَعۡلَمُونَ﴾</span>: ما هم فيه مِنَ الخُسرانِ.</p></div>"
  2,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَيَـٰطِينِهِمۡ﴾</span>: زُعَمائِهم.</p><p><span class="qpc-hafs">﴿مُسۡتَهۡزِءُونَ﴾</span>: مُسْتَخِفُّون بالمؤمنين، ساخرُون منهم.</p></div>"
  2,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَمُدُّهُمۡ﴾</span>: يُمْهِلُهم.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنِهِمۡ﴾</span>: ضَلالَتِهم.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يَتَردَّدُون.</p></div>"
  2,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡتَرَوُاْ ٱلضَّلَـٰلَةَ بِٱلۡهُدَىٰ﴾</span>: استبدَلُوا الكفرَ بالإيمانِ.</p></div>"
  2,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثَلُهُمۡ﴾</span>: شَبَهُ المنافقين.</p><p><span class="qpc-hafs">﴿ٱسۡتَوۡقَدَ﴾</span>: أوقَدَ.</p><p><span class="qpc-hafs">﴿أَضَآءَتۡ﴾</span>: سَطَعَتْ وأنارَتْ.</p></div>"
  2,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُمُّۢ﴾</span>: عَنْ سَماعِ الحقِّ سماعَ تَدَبُّر، والصَّمَمُ: الانسدادُ.</p><p><span class="qpc-hafs">﴿بُكۡمٌ﴾</span>: عن النُّطقِ بالحق، والبُكْمُ: الخُرْسُ.</p><p><span class="qpc-hafs">﴿عُمۡيࣱ﴾</span>: عَنْ إبصارِ نورِ الهدايةِ.</p><p><span class="qpc-hafs">﴿لَا يَرۡجِعُونَ﴾</span>: لا يعُودون إلى الإيمانِ.</p></div>"
  2,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ﴾</span>: هذا شَبَهُ فريقٍ آخرَ من المنافقين الذين يَظْهَرُ لهم الحقُّ تارةً، ويَشُكُّون فيه تارة.</p><p><span class="qpc-hafs">﴿كَصَيِّبࣲ﴾</span>: الصَّيِّب: المَطَرُ الشَّديدُ، والمعنى: كأصحابِ صَيِّبٍ.</p><p><span class="qpc-hafs">﴿ٱلصَّوَ ٰ⁠عِقِ﴾</span>: جَمْعُ صاعِقَةٍ، وهي العذابُ المُهْلِكُ المُحْرِقُ.</p><p><span class="qpc-hafs">﴿مُحِيطُۢ بِٱلۡكَـٰفِرِينَ﴾</span>: لا يَفُوتونه، ولا يُعْجِزُونه.</p></div>"
  2,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكَادُ﴾</span>: يُقارِبُ.</p><p><span class="qpc-hafs">﴿يَخۡطَفُ﴾</span>: يَسْلُبُ من شِدَّةِ لَمَعانِه.</p><p><span class="qpc-hafs">﴿قَامُواْ﴾</span>: وقَفُوا في أماكنِهم مُتَحَيِّرين.</p></div>"
  2,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعَلَّكُمۡ تَتَّقُونَ﴾</span>: لتَتَّقُوه بطاعَتِه.</p></div>"
  2,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَعَلَ﴾</span>: صَيَّر.</p><p><span class="qpc-hafs">﴿فِرَ ٰ⁠شࣰا﴾</span>: بسِاطًا تَسْهُلُ حياتُكم عليه.</p><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: نُظَراءَ في العبادةِ.</p><p><span class="qpc-hafs">﴿تَعۡلَمُونَ﴾</span>: تَعْلَمُون تَفَرُّدَه بالخَلْقِ والرِّزقِ، واستحقاقَه العبوديةَ.</p></div>"
  2,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَيۡبࣲ﴾</span>: شكٍ.</p><p><span class="qpc-hafs">﴿مِّن مِّثۡلِهِۦ﴾</span>: تُماثِلُ سورةً منه.</p><p><span class="qpc-hafs">﴿شُهَدَآءَكُم﴾</span>: أعوانَكم الذين يَشْهدون لكم.</p></div>"
  2,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن تَفۡعَلُواْ﴾</span>: مستقبلًا.</p><p><span class="qpc-hafs">﴿وَقُودُهَا﴾</span>: حَطَبُها.</p><p><span class="qpc-hafs">﴿أُعِدَّتۡ﴾</span>: هُيِّئَتْ.</p></div>"
  2,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبَشِّرِ﴾</span>: أخبِرْهم بما يَسُرُّهم.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: من تحتِ قُصُورِ الجنّاتِ العاليةِ وأشجارِها الظَّليلةِ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: في الدُّنيا.</p><p><span class="qpc-hafs">﴿مُتَشَـٰبِهࣰا﴾</span>: وجَدُوا طَعمًا جديدًا، وإنْ تَشابَه مع سابقِه.</p><p><span class="qpc-hafs">﴿مُّطَهَّرَةࣱ﴾</span>: من الدَّنَسِ الحِسِّي كالَحيْضِ، والمعنويِّ كالكَذِبِ.</p></div>"
  2,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسۡتَحۡيِۦٓ﴾</span>: من الحقِّ أنَ يذْكُرَ شيئًا مّا، صغيرًا أو كبيرًا.</p><p><span class="qpc-hafs">﴿فَمَا فَوۡقَهَا﴾</span>: فما هو أكبرُ منها.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقِينَ﴾</span>: الخارجين عن طاعةِ الله.</p></div>"
  2,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنقُضُونَ﴾</span>: يَنْكُثون.</p><p><span class="qpc-hafs">﴿عَهۡدَ ٱللَّهِ﴾</span>: العهدَ الذي أخذه عليهم بالتوحيدِ والطّاعةِ.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ مِيثَـٰقِهِۦ﴾</span>: مِن بعدِ تأكيدِه باليمينِ.</p></div>"
  2,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡوَ ٰ⁠تࣰا﴾</span>: عَدَمًا غيرَ مخلوقِين.</p><p><span class="qpc-hafs">﴿فَأَحۡيَـٰكُمۡ﴾</span>: فأنشأكم بَشَرًا سويًّا.</p><p><span class="qpc-hafs">﴿يُحۡيِيكُمۡ﴾</span>: يوَم الَبْعثِ.</p></div>"
  2,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰٓ إِلَى ٱلسَّمَآءِ﴾</span>: ارتفعَ وقَصَدَ إلى خَلْق السمواتِ، وتقديرِ ما في كلِّ واحدةٍ.</p><p><span class="qpc-hafs">﴿فَسَوَّىٰهُنَّ﴾</span>: خَلَقَهُنَّ مُسْتَوِياتٍ، ودبَّرَهُنَّ.</p></div>"
  2,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلِيفَةࣰ﴾</span>: قومًا يَخْلُف بعضُهم بعضًا لعِمارةِ الأرضِ.</p><p><span class="qpc-hafs">﴿يَسۡفِكُ ٱلدِّمَآءَ﴾</span>: يُريقُها بغيرِ حَقٍّ.</p><p><span class="qpc-hafs">﴿نُسَبِّحُ بِحَمۡدِكَ﴾</span>: نُنَزِّهُك التنزيهَ اللائقَ.</p><p><span class="qpc-hafs">﴿وَنُقَدِّسُ لَكَ﴾</span>: نُمَجِّدُك، ونُطَهِّرُ ذِكْرَك عَمّا لا يَليقُ بك.</p></div>"
  2,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَسۡمَآءَ﴾</span>: أسماءَ الأشياءِ التي يَتَعارَفُ بها الناسُ.</p><p><span class="qpc-hafs">﴿هَـٰٓؤُلَآءِ﴾</span>: الموجوداتِ التي عَلَّمَها آدمَ.</p></div>"
  2,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَكَ﴾</span>: تَنْزيهًا للهِ.</p></div>"
  2,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَسۡمَآئِهِمۡ﴾</span>: بأسماءِ الأشياءِ التي عَجَزُوا عن معرفتِها.</p><p><span class="qpc-hafs">﴿تُبۡدُونَ﴾</span>: تُظْهِرُون.</p><p><span class="qpc-hafs">﴿تَكۡتُمُونَ﴾</span>: تُخْفُون.</p></div>"
  2,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡجُدُواْ لِـَٔادَمَ﴾</span>: إكرامًا له، وإظهارًا لفَضْلهِ.</p><p><span class="qpc-hafs">﴿أَبَىٰ﴾</span>: تَكَبُّرًا وحَسَدًا.</p><p><span class="qpc-hafs">﴿وَٱسۡتَكۡبَرَ﴾</span>: استعظمَ نفسَه.</p></div>"
  2,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَغَدًا﴾</span>: هنيئًا واسعًا.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: المتجاوِزين أمرَ اللِه.</p></div>"
  2,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَزَلَّهُمَا ٱلشَّيۡطَـٰنُ عَنۡهَا﴾</span>: فأوْقَعَهما الشيطانُ في الخطيئةِ ليُبْعِدَهما عَنِ الجنةِ.</p><p><span class="qpc-hafs">﴿بَعۡضُكُمۡ لِبَعۡضٍ﴾</span>: آدمُ، وحواءُ، والشيطانُ.</p><p><span class="qpc-hafs">﴿مَتَـٰعٌ﴾</span>: انتفاعٌ، واستمتاعٌ.</p><p><span class="qpc-hafs">﴿إِلَىٰ حِينࣲ﴾</span>: إلى وقتِ انتهاءِ آجالِكم.</p></div>"
  2,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلِمَـٰتࣲ﴾</span>: ما ألْهمه اللهُ مِن كلماتٍ للتَّوبةِ.</p></div>"
  2,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا خَوۡفٌ﴾</span>: آمِنُون من أهوالِ القيامةِ.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على ما فاتَهم من الدُّنيا.</p></div>"
  2,39,""
  2,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱذۡكُرُواْ نِعۡمَتِيَ﴾</span>: اصطفائي للرُّسُلِ منكم، وإنزالَ الكتبِ عليكم، ونجاتكم من فرعونَ.</p><p><span class="qpc-hafs">﴿وَأَوۡفُواْ بِعَهۡدِيٓ﴾</span>: أتِمُّوا وصِيَّتي لكم بالإيمان بكتبي وبرُسُلي جميعًا.</p><p><span class="qpc-hafs">﴿أُوفِ بِعَهۡدِكُمۡ﴾</span>: ما وعَدْتُكم به من الرحمةِ في الدنيا والآخرةِ.</p></div>"
  2,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلَ كَافِرِۭ بِهِۦ﴾</span>: بالقرآنِ.</p><p><span class="qpc-hafs">﴿وَلَا تَشۡتَرُواْ بِـَٔايَـٰتِي ثَمَنࣰا قَلِيلࣰا﴾</span>: ولا تَبيعُوا ما آتيكم به من العِلْم بما في كتابِكم من أمرِ محمدٍ ﷺ، بثمَنٍ بَخْس.</p></div>"
  2,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَلۡبِسُواْ﴾</span>: ولا تَخْلِطُوا.</p><p><span class="qpc-hafs">﴿وَتَكۡتُمُواْ ٱلۡحَقَّ﴾</span>: وتُخْفُوا صفةَ محمدٍ ﷺ في التوراةِ.</p></div>"
  2,43,""
  2,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبِرِّ﴾</span>: بالطاعةِ، والعملِ الصالحِ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التوراةَ.</p></div>"
  2,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكَبِيرَةٌ﴾</span>: شاقةٌ ثقيلةٌ.</p><p><span class="qpc-hafs">﴿ٱلۡخَـٰشِعِينَ﴾</span>: الخاضِعين لطاعَتهِ.</p></div>"
  2,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظُنُّونَ﴾</span>: يُوقِنون.</p></div>"
  2,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: عالَمِي زمانِكم؛ بكثرةِ الأنبياءِ، وإنزالِ الكتبِ.</p></div>"
  2,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمࣰا﴾</span>: يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿لَّا تَجۡزِي نَفۡسٌ﴾</span>: لا يُغني أحدٌ عن أحدٍ شيئًا.</p><p><span class="qpc-hafs">﴿عَدۡلࣱ﴾</span>: فِدْيةٌ.</p></div>"
  2,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَجَّيۡنَـٰكُم﴾</span>: نَجَّينا آباءَكم.</p><p><span class="qpc-hafs">﴿يَسۡتَحۡيُونَ نِسَآءَكُمۡ﴾</span>: يَسْتَبْقُونَهُن للخِدْمةِ والامتهانِ.</p><p><span class="qpc-hafs">﴿بَلَآءࣱ﴾</span>: اختبارٌ.</p></div>"
  2,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَقۡنَا بِكُمُ ٱلۡبَحۡرَ﴾</span>: فَصَلْنا لكم البحرَ، وجَعَلْنا فيه طُرُقًا يابسةً لعُبورِكم.</p></div>"
  2,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱتَّخَذۡتُمُ ٱلۡعِجۡلَ﴾</span>: أي مَعبْودًا لكم من دونِ اللهِ.</p></div>"
  2,52,""
  2,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التوراةَ.</p><p><span class="qpc-hafs">﴿ٱلۡفُرۡقَانَ﴾</span>: الفارقَ بينَ الحقِّ والباطلِ.</p></div>"
  2,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱقۡتُلُوٓاْ أَنفُسَكُمۡ﴾</span>: بأَنْ يَقْتُلَ بعضُكم بعضًا.</p></div>"
  2,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡرَةࣰ﴾</span>: عِيانًا.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰعِقَةُ﴾</span>: نارٌ مِنَ السماءِ.</p></div>"
  2,56,""
  2,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَمَامَ﴾</span>: السَّحابَ.</p><p><span class="qpc-hafs">﴿ٱلۡمَنَّ﴾</span>: شيءٌ يُشْبه الصَّمْغَ، طَعْمُه كالعَسَلِ.</p><p><span class="qpc-hafs">﴿ٱلسَّلۡوَىٰ﴾</span>: طيرٌ يُشْبِهُ السُّمانى.</p></div>"
  2,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَرۡيَةَ﴾</span>: بيتَ المَقْدِسِ.</p><p><span class="qpc-hafs">﴿رَغَدࣰا﴾</span>: هنيئًا.</p><p><span class="qpc-hafs">﴿حِطَّةࣱ﴾</span>: ربَّنا ضَعْ عنا ذُنوبَنا.</p></div>"
  2,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِجۡزࣰا﴾</span>: عذابًا.</p><p><span class="qpc-hafs">﴿يَفۡسُقُونَ﴾</span>: يَخْرُجون عن طاعةِ اللهِ.</p></div>"
  2,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَسۡقَىٰ﴾</span>: سألَ اللهَ أنَ يَسْقِيَ قومَه.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡاْ﴾</span>: ولا تُفْرِطُوا في الفسادِ.</p></div>"
  2,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِثَّآئِهَا﴾</span>: جَمْعُ قِثّاءَةٍ، وهو نَبْتٌ ثِمارُه تُشْبِهُ الخِيارَ، ولكنه أطولُ منه.</p><p><span class="qpc-hafs">﴿وَفُومِهَا﴾</span>: الحِنْطَةِ.</p><p><span class="qpc-hafs">﴿ٱلَّذِي هُوَ أَدۡنَىٰ﴾</span>: الطعامَ الذي هو أقلُّ قَدْرًا وقيمةً.</p><p><span class="qpc-hafs">﴿مِصۡرࣰا﴾</span>: أيَّ مدينةٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمَسۡكَنَةُ﴾</span>: الفاقَةُ، والحاجَةُ.</p><p><span class="qpc-hafs">﴿وَبَآءُو﴾</span>: رَجَعُوا.</p></div>"
  2,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلَّذِينَ هَادُواْ﴾</span>: اليهودَ.</p><p><span class="qpc-hafs">﴿ٱلصَّـٰبِـِٔينَ﴾</span>: قومٌ بَقُوا على فِطْرتهم، ولا دينَ مقرَّرٌ لهم.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على ما فاتَهُمْ من أمورِ الدُّنيا.</p></div>"
  2,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَكُمۡ﴾</span>: العهدَ المؤكَّدَ منكم بالإيمان.</p><p><span class="qpc-hafs">﴿ٱلطُّورَ﴾</span>: جبلَ سيناءَ.</p><p><span class="qpc-hafs">﴿مَآ ءَاتَيۡنَـٰكُم﴾</span>: الكتابَ الذي أعطيناكم وهو التَّوراةُ.</p><p><span class="qpc-hafs">﴿بِقُوَّةࣲ﴾</span>: بجِدٍّ.</p></div>"
  2,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّيۡتُم﴾</span>: عَصَيْتُم.</p></div>"
  2,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلسَّبۡتِ﴾</span>: في هذا اليومِ الذي أُمِرُوا بتعظيمِه.</p><p><span class="qpc-hafs">﴿خَـٰسِـِٔينَ﴾</span>: أذِلَّةً صاغِرين.</p></div>"
  2,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَكَـٰلࣰا﴾</span>: عقوبةً.</p><p><span class="qpc-hafs">﴿لِّمَا بَيۡنَ يَدَيۡهَا﴾</span>: من الذنوبِ.</p></div>"
  2,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُزُوࣰا﴾</span>: مَوْضِعَ سُخْرِيَةٍ واستِخْفافٍ.</p></div>"
  2,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَارِضࣱ﴾</span>: المُسِنَّةُ الهَرِمَةُ.</p><p><span class="qpc-hafs">﴿بِكۡرٌ﴾</span>: الصغيرةُ الفتيةُ.</p><p><span class="qpc-hafs">﴿عَوَانُۢ﴾</span>: متوسطةٌ بين البِكْرِ والهَرِمَةِ.</p></div>"
  2,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاقِعࣱ لَّوۡنُهَا﴾</span>: شديدةُ الصُّفْرَةِ.</p></div>"
  2,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَشَـٰبَهَ﴾</span>: التبسَ.</p></div>"
  2,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا ذَلُولࣱ تُثِيرُ ٱلۡأَرۡضَ﴾</span>: غيرُ مُذَلَّلَةٍ للعَمَلِ في حِراثةِ الأرضِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَرۡثَ﴾</span>: الزرعَ.</p><p><span class="qpc-hafs">﴿مُسَلَّمَةࣱ﴾</span>: خاليةٌ مِنَ العيوبِ.</p><p><span class="qpc-hafs">﴿لَّا شِيَةَ فِيهَا﴾</span>: لا لونَ فيها يخالِفُ لونَ جِلْدِها.</p></div>"
  2,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱدَّ ٰ⁠رَ ٰ⁠ـٔتُمۡ﴾</span>: فاختلفتم، كلٌّ يَدْفَعُ عن نفسِه تُهْمَةَ القتلِ.</p><p><span class="qpc-hafs">﴿مُخۡرِجࣱ﴾</span>: مُظْهِرٌ.</p></div>"
  2,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِبَعۡضِهَا﴾</span>: بجُزْءٍ مِنَ البقرةِ المذبوحةِ.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِهِۦ﴾</span>: معجزاتهِ، وحُجَجَه.</p></div>"
  2,74,""
  2,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يُؤۡمِنُواْ لَكُمۡ﴾</span>: أن يُصَدِّقَ اليهودُ بدينِكم.</p><p><span class="qpc-hafs">﴿كَلَـٰمَ ٱللَّهِ﴾</span>: التوراةَ.</p><p><span class="qpc-hafs">﴿يُحَرِّفُونَهُۥ﴾</span>: يَصْرِفُونه عن معناه.</p><p><span class="qpc-hafs">﴿عَقَلُوهُ﴾</span>: فَهِمُوه بعقولهِم على الوجهِ الصَّحيحِ.</p></div>"
  2,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا فَتَحَ﴾</span>: بما بَيَّنَ اللهُ لكم في التوراةِ من أمْرِ محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿لِيُحَآجُّوكُم﴾</span>: لتكونَ لهم الحُجَّةُ عليكم في الآخرةِ.</p></div>"
  2,77,""
  2,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنۡهُمۡ أُمِّيُّونَ﴾</span>: ومن اليهودِ طائفةٌ يَجْهَلُون القراءةَ والكتابةَ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التوراةَ وما فيها من صفاتِ محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿أَمَانِيَّ﴾</span>: أكاذيبَ.</p></div>"
  2,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: فوعيدٌ شديدٌ.</p><p><span class="qpc-hafs">﴿ثَمَنࣰا قَلِيلࣰا﴾</span>: عَرَضًا مِنَ الدنيا.</p></div>"
  2,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَهۡدࣰا﴾</span>: ميثاقًا بهذا الزعمِ.</p></div>"
  2,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيِّئَةࣰ﴾</span>: شِرْكًا.</p></div>"
  2,82,""
  2,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَ﴾</span>: العهدَ المؤكَّدَ.</p><p><span class="qpc-hafs">﴿ٱلۡيَتَـٰمَىٰ﴾</span>: الأولادِ الذين ماتَ آباؤُهم وهم دونَ البُلوغِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: الذين لا يَمْلِكُون ما يَكْفيهم.</p><p><span class="qpc-hafs">﴿حُسۡنࣰا﴾</span>: أطيبَ الكلامِ.</p><p><span class="qpc-hafs">﴿مُّعۡرِضُونَ﴾</span>: مستمرُّون في تكذيبِهم.</p></div>"
  2,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَكُمۡ﴾</span>: العهدَ المؤكَّدَ في التَّوراة.</p><p><span class="qpc-hafs">﴿أَقۡرَرۡتُمۡ﴾</span>: اعترفتُمْ.</p></div>"
  2,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰٓؤُلَآءِ﴾</span>: يا هؤلاءِ.</p><p><span class="qpc-hafs">﴿تَظَـٰهَرُونَ عَلَيۡهِم﴾</span>: يتَقَوّى كلٌّ منكم على إخوانِه بالأعداءِ.</p><p><span class="qpc-hafs">﴿تُفَـٰدُوهُمۡ﴾</span>: تُحَرِّرُوهم مِنَ الأَسْرِ بدَفْعِ الفِدْيَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبِ﴾</span>: التوراةِ.</p></div>"
  2,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡتَرَوُاْ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا﴾</span>: استحَبُّوها.</p></div>"
  2,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَفَّيۡنَا﴾</span>: أتْبَعْنا بعضَهم خَلْفَ بعضٍ.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتِ﴾</span>: المعجزاتِ الواضحاتِ.</p><p><span class="qpc-hafs">﴿بِرُوحِ ٱلۡقُدُسِ﴾</span>: جبريلَ.</p></div>"
  2,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالُواْ﴾</span>: وقال بنو إسرائيلَ.</p><p><span class="qpc-hafs">﴿غُلۡفُۢ﴾</span>: مُغَطّاةٌ لا يَنْفُذُ إليها قولُك.</p></div>"
  2,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَهُمۡ﴾</span>: جاء اليهودَ.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣱ﴾</span>: هو القرآنُ الكريمُ.</p><p><span class="qpc-hafs">﴿مُصَدِّقࣱ﴾</span>: موافِقٌ.</p><p><span class="qpc-hafs">﴿لِّمَا مَعَهُمۡ﴾</span>: من التوراة.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: مِن قَبْلِ بِعْثَةِ محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿يَسۡتَفۡتِحُونَ﴾</span>: يَسْتَنْصِرُون بالنبيِّ الذي ينتظرونه.</p></div>"
  2,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِئۡسَمَا﴾</span>: قَبُحَ.</p><p><span class="qpc-hafs">﴿ٱشۡتَرَوۡاْ﴾</span>: باعوا.</p><p><span class="qpc-hafs">﴿بَغۡيًا﴾</span>: ظُلمًا وحَسَدًا.</p><p><span class="qpc-hafs">﴿أَن يُنَزِّلَ﴾</span>: من أجْلِ أن يُنَزِّلَ.</p><p><span class="qpc-hafs">﴿مِن فَضۡلِهِۦ﴾</span>: هو تنزيلُ القرآنِ على محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿فَبَآءُو﴾</span>: فرَجَعُوا.</p><p><span class="qpc-hafs">﴿بِغَضَبٍ﴾</span>: بغَضَبِ اللهِ بسببِ تكذيبِهم للنبيَّ ﷺ.</p><p><span class="qpc-hafs">﴿عَلَىٰ غَضَبࣲ﴾</span>: بعد غضبهِ بسببِ تحريفِهم للتوراةِ.</p></div>"
  2,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَا وَرَآءَهُۥ﴾</span>: بما أنزل اللهُ بعدَ التوراةِ.</p><p><span class="qpc-hafs">﴿لِّمَا مَعَهُمۡ﴾</span>: من التَّوراةِ.</p></div>"
  2,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالمُعْجِزاتِ الواضحاتِ.</p><p><span class="qpc-hafs">﴿ٱتَّخَذۡتُمُ ٱلۡعِجۡلَ﴾</span>: أي مَعْبودًا.</p></div>"
  2,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَكُمۡ﴾</span>: العهدَ المؤكَّدَ.</p><p><span class="qpc-hafs">﴿ٱلطُّورَ﴾</span>: جبلَ الطُّورِ.</p><p><span class="qpc-hafs">﴿وَأُشۡرِبُواْ فِي قُلُوبِهِمُ ٱلۡعِجۡلَ﴾</span>: امتزجَ حُبُّ عبادَةِ العِجْلِ بقُلوبهِم.</p></div>"
  2,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَالِصَةࣰ﴾</span>: خاصةً بكم.</p><p><span class="qpc-hafs">﴿فَتَمَنَّوُاْ ٱلۡمَوۡتَ﴾</span>: ادْعُوا بالموتِ على الكاذبِ.</p></div>"
  2,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّمَتۡ﴾</span>: كَسَبَتْ.</p></div>"
  2,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُزَحۡزِحِهِۦ﴾</span>: مُبْعِدِه، ومُنْجِيه.</p><p><span class="qpc-hafs">﴿أَن يُعَمَّرَ﴾</span>: طولُ العُمْرِ.</p></div>"
  2,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن كَانَ﴾</span>: هم اليهودُ الزاعمون أنّ جبريلَ عَدُوٌّ لهم.</p><p><span class="qpc-hafs">﴿لِّمَا بَيۡنَ يَدَيۡهِ﴾</span>: لما قبلَه مِنَ الكُتُب.</p></div>"
  2,98,""
  2,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَـٰتࣲ﴾</span>: علاماتٍ دالّاتٍ على نُبُوَّتك.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارجون عن دينِ اللهِ.</p></div>"
  2,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَهۡدࣰا﴾</span>: هو الميثاقُ الذي أعطاه اليهودُ رَبَّهم.</p><p><span class="qpc-hafs">﴿نَّبَذَهُۥ﴾</span>: نَقَضَه.</p></div>"
  2,101,""
  2,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تَتۡلُواْ ٱلشَّيَـٰطِينُ﴾</span>: ما تُحَدِّثُ به الشياطينُ السَّحَرَةَ.</p><p><span class="qpc-hafs">﴿عَلَىٰ مُلۡكِ﴾</span>: على عَهْدِ.</p><p><span class="qpc-hafs">﴿وَمَآ أُنزِلَ﴾</span>: وكذلك اتَّبَعَ اليهودُ السِّحْرَ الذي أُنْزِلَ على الملَكَين. وقد عَلَّم اللهُ الملَكَين السِّحْرَ ابتلاءً منه.</p><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: ابتلاءٌ يَختبرُ اللهُ بهما عبادَه، وهو تعليمُ إنذارٍ من السِّحْرِ، لا تعليمُ دعوةٍ.</p><p><span class="qpc-hafs">﴿فَلَا تَكۡفُرۡ﴾</span>: بتعَلُّمِ السِّحْرِ، وطاعةِ الشياطين.</p><p><span class="qpc-hafs">﴿ٱشۡتَرَىٰهُ﴾</span>: اختار السِّحْرَ، واستحَبَّه.</p><p><span class="qpc-hafs">﴿خَلَـٰقࣲ﴾</span>: نصيبٍ في الخيرِ.</p></div>"
  2,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَثُوبَةࣱ﴾</span>: ثوابُ اللهِ.</p></div>"
  2,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَ ٰ⁠عِنَا﴾</span>: أي: سَمْعَك، فافهَمْ عنا، وأفْهِمْنا.</p><p><span class="qpc-hafs">﴿ٱنظُرۡنَا﴾</span>: انظُرْ إلينا وتَعَهَّدْنا.</p></div>"
  2,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡتَصُّ﴾</span>: يُؤْثِرُ.</p></div>"
  2,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا نَنسَخۡ﴾</span>: ما نُبَدِّلْ.</p><p><span class="qpc-hafs">﴿نُنسِهَا﴾</span>: نَمْحُها مِنَ القُلوبِ.</p></div>"
  2,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: قَيِّمٍ بأمرِكم.</p></div>"
  2,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَآءَ ٱلسَّبِيلِ﴾</span>: طريقَ اللهِ المستقيم.</p></div>"
  2,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرُدُّونَكُم﴾</span>: يُرْجِعُونكم.</p><p><span class="qpc-hafs">﴿بِأَمۡرِهِۦٓ﴾</span>: بحُكْمِه فيهم.</p></div>"
  2,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تُقَدِّمُواْ﴾</span>: وما تَعْمَلُوا مِن عَمَلٍ.</p></div>"
  2,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَانِيُّهُمۡ﴾</span>: أوهامُهم الفاسدةُ.</p><p><span class="qpc-hafs">﴿بُرۡهَـٰنَكُمۡ﴾</span>: حُجَّتَكم.</p></div>"
  2,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡلَمَ﴾</span>: أخلَصَ لطاعَتِه.</p><p><span class="qpc-hafs">﴿وَهُوَ مُحۡسِنࣱ﴾</span>: مُتَّبِعٌ للرسولِ ﷺ.</p></div>"
  2,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ شَيۡءࣲ﴾</span>: أي: من الدِّينِ الصَّحيحِ.</p><p><span class="qpc-hafs">﴿وَهُمۡ يَتۡلُونَ ٱلۡكِتَـٰبَ﴾</span>: يَقْرَؤون التوراةَ والإنجيلَ، وفيهما الإيمانُ بالأنبياءِ جميعًا.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ لَا يَعۡلَمُونَ﴾</span>: هم مُشْرِكو العربِ وغيرُهم.</p><p><span class="qpc-hafs">﴿يَحۡكُمُ﴾</span>: يَفْصِلُ، ويَقْضي.</p></div>"
  2,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۡ أَظۡلَمُ﴾</span>: لا أحدَ أظلمُ.</p><p><span class="qpc-hafs">﴿خِزۡيࣱ﴾</span>: ذِلَّةٌ وهَوانٌ.</p></div>"
  2,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُوَلُّواْ﴾</span>: تَتَوَجَّهُوا.</p><p><span class="qpc-hafs">﴿فَثَمَّ وَجۡهُ﴾</span>: فإنكم مُبْتَغُون وجْهَه.</p><p><span class="qpc-hafs">﴿وَ ٰ⁠سِعٌ﴾</span>: واسعُ الرحمةِ بعبادِه.</p></div>"
  2,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تَنَزَّهَ عن هذا الباطلِ.</p><p><span class="qpc-hafs">﴿قَـٰنِتُونَ﴾</span>: خاضِعُون له، مُطيعون.</p></div>"
  2,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدِيعُ﴾</span>: مُبْدِعٌ على غيرِ مثالٍ سَبَقَ.</p></div>"
  2,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: مُعْجزةٌ.</p><p><span class="qpc-hafs">﴿تَشَـٰبَهَتۡ﴾</span>: في الكُفرِ والعِنادِ.</p><p><span class="qpc-hafs">﴿يُوقِنُونَ﴾</span>: يُصَدِّقُون ويَتَّبِعُون الرسولَ ﷺ.</p></div>"
  2,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَشِيرࣰا﴾</span>: للمؤمنين بخَيْرَي الدُّنيا و الآخرةِ.</p><p><span class="qpc-hafs">﴿وَنَذِيرࣰا﴾</span>: ومُخَوِّفًا للمعانِدِين بالعذابِ.</p></div>"
  2,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِلَّتَهُمۡ﴾</span>: دينَهم.</p><p><span class="qpc-hafs">﴿هُوَ ٱلۡهُدَىٰ﴾</span>: الدِّينُ الصحيحُ.</p><p><span class="qpc-hafs">﴿وَلِيࣲّ﴾</span>: قريبٍ يمنعُك من عذابِ اللهِ.</p></div>"
  2,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ تِلَاوَتِهِۦٓ﴾</span>: يَتَّبِعُونه حَقَّ اتِّباعِه.</p></div>"
  2,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: عالَمِي زَمانِكم بكثرةِ الأنبياءِ، وإنزالِ الكُتُبِ.</p></div>"
  2,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا تَجۡزِي﴾</span>: لا تُغْني.</p><p><span class="qpc-hafs">﴿عَدۡلࣱ﴾</span>: فِدْيَةٌ تُنْجِيها من العذابِ.</p><p><span class="qpc-hafs">﴿شَفَـٰعَةࣱ﴾</span>: وساطةٌ في حُصولِ النفعِ.</p></div>"
  2,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتَلَىٰٓ﴾</span>: اختبرَ.</p><p><span class="qpc-hafs">﴿بِكَلِمَـٰتࣲ﴾</span>: بما شَرَع له من تعاليمَ.</p><p><span class="qpc-hafs">﴿فَأَتَمَّهُنَّ﴾</span>: فأدّاهن على الوجهِ الأكمَلِ.</p><p><span class="qpc-hafs">﴿إِمَامࣰا﴾</span>: قُدوةً للناس.</p><p><span class="qpc-hafs">﴿وَمِن ذُرِّيَّتِي﴾</span>: واجعَلْ بعضَ نَسْلي مَن يُقْتَدى به.</p><p><span class="qpc-hafs">﴿عَهۡدِي﴾</span>: الإمامةُ في الدِّين.</p></div>"
  2,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَيۡتَ﴾</span>: الكعبةَ.</p><p><span class="qpc-hafs">﴿مَثَابَةࣰ﴾</span>: مَرْجِعًا ومَجْمَعًا للناسِ.</p><p><span class="qpc-hafs">﴿مَّقَامِ إِبۡرَ ٰ⁠هِـۧمَ﴾</span>: الحَجَرِ الذي وقَفَ عليه.</p><p><span class="qpc-hafs">﴿وَعَهِدۡنَآ﴾</span>: وأَوْحَينا.</p><p><span class="qpc-hafs">﴿ٱلۡعَـٰكِفِينَ﴾</span>: المقيمينَ فيه للعبادةِ.</p></div>"
  2,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَتِّعُهُۥ﴾</span>: فأَرْزُقُه في حياتهِ.</p><p><span class="qpc-hafs">﴿أَضۡطَرُّهُۥٓ﴾</span>: أُلْجِئُه.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ.</p></div>"
  2,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَوَاعِدَ مِنَ ٱلۡبَيۡتِ﴾</span>: أُسُس الكعبةِ التي تنهضُ عليها.</p></div>"
  2,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسۡلِمَيۡنِ لَكَ﴾</span>: منقادَيْن لأحكامِك.</p><p><span class="qpc-hafs">﴿مُّسۡلِمَةࣰ﴾</span>: منقادةً.</p><p><span class="qpc-hafs">﴿وَأَرِنَا مَنَاسِكَنَا﴾</span>: بَصِّرْنا بمعالِم عِبادتِنا.</p></div>"
  2,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِمۡ﴾</span>: في هذه الأمةِ.</p><p><span class="qpc-hafs">﴿مِّنۡهُمۡ﴾</span>: من ذريةِ إسماعيلَ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ وَٱلۡحِكۡمَةَ﴾</span>: القرآنَ، والسُنَّةَ.</p><p><span class="qpc-hafs">﴿وَيُزَكِّيهِمۡ﴾</span>: يُطَهِّرُهم من الشِّرْكِ، وسوءِ الأخلاقِ.</p></div>"
  2,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡغَبُ عَن مِّلَّةِ إِبۡرَ ٰ⁠هِـۧمَ﴾</span>: يُعْرِضُ عن دينِه.</p><p><span class="qpc-hafs">﴿سَفِهَ نَفۡسَهُۥ﴾</span>: جَهِلَتْ نَفْسُه ما ينفعُها.</p><p><span class="qpc-hafs">﴿ٱصۡطَفَيۡنَـٰهُ﴾</span>: اختَرناه.</p></div>"
  2,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡلِمۡ﴾</span>: أخْلِصْ نفسَك لله.</p></div>"
  2,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡطَفَىٰ﴾</span>: اختارَ.</p></div>"
  2,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُنتُمۡ﴾</span>: أيُّها اليهودُ.</p><p><span class="qpc-hafs">﴿شُهَدَآءَ﴾</span>: حاضِرِين، فلا تَدَّعُوا الأباطيلَ.</p><p><span class="qpc-hafs">﴿مُسۡلِمُونَ﴾</span>: مُنْقادُون، خاضِعُون.</p></div>"
  2,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ.</p><p><span class="qpc-hafs">﴿مَا كَسَبَتۡ﴾</span>: ما عَمِلَتْ.</p></div>"
  2,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَهۡتَدُواْ﴾</span>: تُصِيبوا الحقَّ.</p><p><span class="qpc-hafs">﴿بَلۡ مِلَّةَ إِبۡرَ ٰ⁠هِـۧمَ﴾</span>: بل الهدايةُ أن نتَّبعَ دينَ إبراهيمَ.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن الباطلِ.</p></div>"
  2,136,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَسۡبَاطِ﴾</span>: هم الأنبياءُ من ولَدِ يعقوبَ في قبائلِ بني إسرائيلَ الاثنتي عَشْرَةَ.</p><p><span class="qpc-hafs">﴿مُسۡلِمُونَ﴾</span>: خاضعون.</p></div>"
  2,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا.</p><p><span class="qpc-hafs">﴿شِقَاقࣲ﴾</span>: خلافٍ شديدٍ.</p><p><span class="qpc-hafs">﴿فَسَيَكۡفِيكَهُمُ ٱللَّهُ﴾</span>: سيَكْفيك شَرَّهم.</p></div>"
  2,138,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِبۡغَةَ ٱللَّهِ﴾</span>: الزَمُوا دينَ اللهِ الإسلامَ.</p><p><span class="qpc-hafs">﴿صِبۡغَةࣰ﴾</span>: دِينًا.</p></div>"
  2,139,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتُحَآجُّونَنَا﴾</span>: أتجادِلُوننا وتخاصِمُوننا؟</p><p><span class="qpc-hafs">﴿مُخۡلِصُونَ﴾</span>: لا نعبدُ أحدًا غيره.</p></div>"
  2,140,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۡ أَظۡلَمُ﴾</span>: لا أحدَ أظلمُ.</p><p><span class="qpc-hafs">﴿كَتَمَ﴾</span>: أخْفى، وادَّعى خِلافَها.</p></div>"
  2,141,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ.</p><p><span class="qpc-hafs">﴿كَسَبَتۡ﴾</span>: عَمِلَتْ.</p></div>"
  2,142,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسُّفَهَآءُ﴾</span>: الجُهّالُ وضِعافُ العقولِ، وهم اليهودُ.</p><p><span class="qpc-hafs">﴿مَا وَلَّىٰهُمۡ﴾</span>: أيُّ شيءٍ صَرَفَ المسلمين؟</p><p><span class="qpc-hafs">﴿عَن قِبۡلَتِهِمُ﴾</span>: عن بيتِ المقْدِسِ، وهي قِبلة المسلمين أولَ الإسلامِ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ﴾</span>: طريقٍ.</p></div>"
  2,143,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسَطࣰا﴾</span>: عُدُولًا خِيارًا، لا إفراطَ عندكم، ولا تفْريطَ.</p><p><span class="qpc-hafs">﴿لِّتَكُونُواْ شُهَدَآءَ﴾</span>: لتَشْهَدُوا على الأممِ في الآخرةِ أنّ رُسُلَهم بَلَّغُوا.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: يشهدُ أنه بَلَّغَ الرسالةَ إلى أمَّتِه.</p><p><span class="qpc-hafs">﴿ٱلَّتِي كُنتَ عَلَيۡهَآ﴾</span>: التي صَرَفْناك عنها إلى الكعبةِ.</p><p><span class="qpc-hafs">﴿يَنقَلِبُ عَلَىٰ عَقِبَيۡهِ﴾</span>: يَرْتَدُّ عن دينِه.</p><p><span class="qpc-hafs">﴿وَإِن كَانَتۡ﴾</span>: وإنّ تحويلَ الِقْبلَةِ.</p><p><span class="qpc-hafs">﴿لَكَبِيرَةً﴾</span>: لَثقيلةً شاقةً.</p><p><span class="qpc-hafs">﴿لِيُضِيعَ إِيمَـٰنَكُمۡ﴾</span>: يُبْطِلَ صلاتَكم إلى القِبْلَةِ السّابقةِ.</p></div>"
  2,144,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلسَّمَآءِ﴾</span>: أي: انتظارًا للوَحْي في شأنِ القِبْلَةِ.</p><p><span class="qpc-hafs">﴿فَلَنُوَلِّيَنَّكَ﴾</span>: فَلنُوَجِّهَنّك.</p><p><span class="qpc-hafs">﴿فَوَلِّ وَجۡهَكَ﴾</span>: اصرِفْ وجْهَك.</p><p><span class="qpc-hafs">﴿شَطۡرَ﴾</span>: جِهَةَ.</p><p><span class="qpc-hafs">﴿فَوَلُّواْ﴾</span>: فَتَوجَّهُوا.</p><p><span class="qpc-hafs">﴿أَنَّهُ ٱلۡحَقُّ﴾</span>: أن تحويلَكَ إلى الكعبةِ هو الثابتُ في كُتُبهِم.</p></div>"
  2,145,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣲ﴾</span>: حُجَّةٍ.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: لأنفسِهم، المخالِفِين لأمرِ ربِّهم.</p></div>"
  2,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ ءَاتَيۡنَـٰهُمُ ٱلۡكِتَـٰبَ﴾</span>: هم أحبارُ اليهود، وعلماءُ النَّصارى.</p><p><span class="qpc-hafs">﴿يَعۡرِفُونَهُۥ﴾</span>: يَعْرِفُون محمدًا، أو يَعْرِفُون أن البيتَ الحرامَ قِبْلَتُهم، وقبلةُ الأنبياءِ السابقين.</p></div>"
  2,147,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُمۡتَرِينَ﴾</span>: الشّاكِّين.</p></div>"
  2,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِكُلࣲّ وِجۡهَةٌ﴾</span>: ولكلِّ أهلِ دينٍ قبلةٌ.</p><p><span class="qpc-hafs">﴿هُوَ مُوَلِّيهَا﴾</span>: مُتَوَجِّهٌ إليها في صلاتِه.</p><p><span class="qpc-hafs">﴿فَٱسۡتَبِقُواْ﴾</span>: فبادِرُوا، وسارِعُوا.</p><p><span class="qpc-hafs">﴿يَأۡتِ بِكُمُ﴾</span>: يومَ القيامةِ.</p></div>"
  2,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَلِّ وَجۡهَكَ﴾</span>: تَوَجَّهْ.</p><p><span class="qpc-hafs">﴿شَطۡرَ﴾</span>: نَحْوَ.</p><p><span class="qpc-hafs">﴿وَإِنَّهُۥ﴾</span>: وإنّ تَوَجُّهَك إليه.</p></div>"
  2,150,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُجَّةٌ﴾</span>: هي قولُهم حينَ تَوَجَّهَ إلى المسجدِ الحرامِ: اشتاقَ إلى دينِ قومِه.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ ظَلَمُواْ﴾</span>: هم مشركُو قريشٍ، أو المعاندون أهلُ الكتابِ، فسيَبْقَون على جِدالهم وعِنادهِم.</p><p><span class="qpc-hafs">﴿وَلِأُتِمَّ نِعۡمَتِي﴾</span>: باختيار أكملِ الشَّرائعِ لكم.</p></div>"
  2,151,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَآ أَرۡسَلۡنَا﴾</span>: كما أنَعمْنا عليكم باستقبالِ الكعبةِ أرسَلْنا.</p><p><span class="qpc-hafs">﴿يُزَكِّيكُمۡ﴾</span>: يُطَهِّرُكم من الشِّرك، وسوءِ الأخلاقِ.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: السُّنَّةَ.</p></div>"
  2,152,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱذۡكُرُونِيٓ﴾</span>: بالطاعةِ.</p><p><span class="qpc-hafs">﴿أَذۡكُرۡكُمۡ﴾</span>: بالثَّوابِ والمغفرةِ.</p></div>"
  2,153,""
  2,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡيَآءࣱ﴾</span>: حياةً خاصةً بهم في قُبورِهم.</p><p><span class="qpc-hafs">﴿لَّا تَشۡعُرُونَ﴾</span>: لا تُحِسُّون بهذه الحياةِ.</p></div>"
  2,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَنَبۡلُوَنَّكُم﴾</span>: ولَنَخْتَبِرَنَّكم.</p></div>"
  2,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا لِلَّهِ﴾</span>: إنّا عَبيدٌ له، مُدَبَّرُون بتصريفِه.</p></div>"
  2,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَلَوَ ٰ⁠تࣱ﴾</span>: مغفرةٌ، وثناءٌ حَسَنٌ.</p></div>"
  2,158,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَعَآئِرِ ٱللَّهِ﴾</span>: منْ معالمِ دينِه، وأعلامِ مَناسِكِه.</p><p><span class="qpc-hafs">﴿حَجَّ ٱلۡبَيۡتَ﴾</span>: قَصَدَه للحجِّ أو العمرةِ.</p><p><span class="qpc-hafs">﴿فَلَا جُنَاحَ﴾</span>: فلا حَرَجَ ولا إثمَ، بل يجبُ السَّعْيُ.</p><p><span class="qpc-hafs">﴿يَطَّوَّفَ بِهِمَا﴾</span>: يَسْعى بينهما.</p><p><span class="qpc-hafs">﴿تَطَوَّعَ﴾</span>: فَعَلَ الطاعةَ مِن نفسِه.</p></div>"
  2,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكۡتُمُونَ﴾</span>: يُخْفُون. وهم أحبارُ اليهودِ، وعلماءُ النصارى، وكلُّ مَن كَتَمَ الحقَّ.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتِ﴾</span>: الآياتِ الواضحاتِ الدالَّةِ على نُبُوَّةِ محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿بَيَّنَّـٰهُ﴾</span>: أظْهَرْناه في التوراةِ والإنجيلِ.</p></div>"
  2,160,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡلَحُواْ﴾</span>: ما أفْسَدُوه.</p></div>"
  2,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعۡنَةُ ٱللَّهِ﴾</span>: الطَّرْدُ مِن رحمته.</p></div>"
  2,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰلِدِينَ فِيهَا﴾</span>: دائمِين في اللَّعْنَةِ والنارِ.</p><p><span class="qpc-hafs">﴿يُنظَرُونَ﴾</span>: يُمْهَلُون لكي يَعْتَذِرُوا.</p></div>"
  2,163,""
  2,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: تعاقُبِهما.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السُّفُن.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَا﴾</span>: بعد قَحْطِها وجَفافِها.</p><p><span class="qpc-hafs">﴿بَثَّ﴾</span>: نَشَر، وفَرَّقَ.</p><p><span class="qpc-hafs">﴿دَآبَّةࣲ﴾</span>: كلِّ ما دَبَّ على وجهِ الأرضِ.</p><p><span class="qpc-hafs">﴿وَتَصۡرِيفِ ٱلرِّيَـٰحِ﴾</span>: تَوْجيهِها، وهُبوبِها، وفْقَ ما يريدُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُسَخَّرِ﴾</span>: المُسَيَّرِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَعلاماتٍ ودَلالاتٍ على قُدْرةِ اللهِ.</p></div>"
  2,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: نُظَراءَ كالأصنامِ والأولياءِ.</p><p><span class="qpc-hafs">﴿كَحُبِّ ٱللَّهِ﴾</span>: يَمْنحونهم من التعظيم ما لا يَليقُ إلا باللهِ.</p><p><span class="qpc-hafs">﴿إِذۡ يَرَوۡنَ ٱلۡعَذَابَ أَنَّ ٱلۡقُوَّةَ لِلَّهِ جَمِيعࣰا﴾</span>: أي: ليعلَمُوا حين يَرَوْنَ عذابَ جهنَّمَ أن اللهَ هو المتفرِّدُ بالقوةِ.</p></div>"
  2,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱتُّبِعُواْ﴾</span>: هم الرؤساءُ.</p><p><span class="qpc-hafs">﴿ٱلۡأَسۡبَابُ﴾</span>: الصِّلاتُ من القَرابَةِ والأَتْباعِ وغيرِ ذلك.</p></div>"
  2,167,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّةࣰ﴾</span>: عودةً إلى الدنيا.</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: أي: كما أراهم عذابه، يُريهم أعمالَهم الفاسدةَ.</p><p><span class="qpc-hafs">﴿حَسَرَ ٰ⁠تٍ﴾</span>: نَداماتٍ.</p></div>"
  2,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾</span>: طُرُقَه، وآثارَه.</p></div>"
  2,169,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡفَحۡشَآءِ﴾</span>: المعصيةِ البالغةِ القُبْحِ.</p></div>"
  2,170,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلۡفَيۡنَا﴾</span>: وجَدْنا.</p><p><span class="qpc-hafs">﴿أَوَلَوۡ كَانَ ءَابَآؤُهُمۡ لَا يَعۡقِلُونَ﴾</span>: أي: يَتَّبِعُونهم؟</p></div>"
  2,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَثَلُ ٱلَّذِينَ كَفَرُواْ﴾</span>: صِفَتُهم مع مَن يَدْعُوهم إلى الهُدى.</p><p><span class="qpc-hafs">﴿ٱلَّذِي يَنۡعِقُ﴾</span>: هو الرّاعِي الذي يَصيحُ بالبهائمِ، ويَزْجُرُها، وهي لا تَفْهَمُ معنى كلامِه، وإنما تَسْمَعُ صوته.</p><p><span class="qpc-hafs">﴿صُمُّۢ﴾</span>: سَدُّوا أسماعَهم عن الحقِّ.</p><p><span class="qpc-hafs">﴿بُكۡمٌ﴾</span>: أسْكَتُوا ألسنتَهم عن النُّطْقِ بالحقِّ.</p><p><span class="qpc-hafs">﴿عُمۡيࣱ﴾</span>: لا يَرَوْن أدلَّةَ الحقِّ.</p></div>"
  2,172,""
  2,173,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أُهِلَّ بِهِۦ لِغَيۡرِ ٱللَّهِ﴾</span>: هي الذَّبائحُ التي يُذْكَرُ عند ذَبْحِها غيرُ اللهِ.</p><p><span class="qpc-hafs">﴿غَيۡرَ بَاغࣲ﴾</span>: غيرَ طالِبٍ للمُحَرَّمِ، مع كونهِ لا يجدُ غيرَ ما ذُكِرَ، مما أحَلَّه اللهُ.</p><p><span class="qpc-hafs">﴿وَلَا عَادࣲ﴾</span>: ولا مُتَجاوزٍ حَدَّ الضَّرورةِ.</p></div>"
  2,174,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يَكۡتُمُونَ﴾</span>: هم أهلُ الكتابِ الذين يُخْفُون.</p><p><span class="qpc-hafs">﴿مَآ أَنزَلَ ٱللَّهُ مِنَ ٱلۡكِتَـٰبِ﴾</span>: من صفةِ محمدٍ ﷺ وغيرِ ذلك من الحقِّ.</p><p><span class="qpc-hafs">﴿وَيَشۡتَرُونَ بِهِۦ ثَمَنࣰا قَلِيلًا﴾</span>: يأخذون مُقابِلَ الإخفاءِ قليلًا مِن عَرَضِ الدُّنيا.</p><p><span class="qpc-hafs">﴿إِلَّا ٱلنَّارَ﴾</span>: إلا ما يُورِدُهم النارَ.</p><p><span class="qpc-hafs">﴿وَلَا يُكَلِّمُهُمُ﴾</span>: ولا يُطَهِّرُهم</p></div>"
  2,175,""
  2,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِقَاقِۭ بَعِيدࣲ﴾</span>: مُنازَعَةٍ بعيدةٍ عن الصَّوابِ.</p></div>"
  2,177,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبِرَّ﴾</span>: الخيرَ.</p><p><span class="qpc-hafs">﴿أَن تُوَلُّواْ﴾</span>: أن تَتَوَجَّهُوا في الصَّلاةِ.</p><p><span class="qpc-hafs">﴿قِبَلَ﴾</span>: جِهَةَ.</p><p><span class="qpc-hafs">﴿مَنۡ ءَامَنَ﴾</span>: بِرَّ مَن آمَنَ.</p><p><span class="qpc-hafs">﴿عَلَىٰ حُبِّهِۦ﴾</span>: وهو للمالِ مُحِبٌّ.</p><p><span class="qpc-hafs">﴿وَٱبۡنَ ٱلسَّبِيلِ﴾</span>: هو المسافِرُ المحتاجُ.</p><p><span class="qpc-hafs">﴿وَفِي ٱلرِّقَابِ﴾</span>: في تحريرِ العبيدِ، والأسرى.</p><p><span class="qpc-hafs">﴿ٱلۡبَأۡسَآءِ﴾</span>: البؤسِ والفقرِ.</p><p><span class="qpc-hafs">﴿ٱلضَّرَّآءِ﴾</span>: المرضِ.</p><p><span class="qpc-hafs">﴿ٱلۡبَأۡسِ﴾</span>: مواطِنِ القتالِ.</p></div>"
  2,178,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُتِبَ﴾</span>: فَرَضَ اللهُ.</p><p><span class="qpc-hafs">﴿ٱلۡقِصَاصُ﴾</span>: أن يُوقَعَ على الجاني مثلُ ما جَنى.</p><p><span class="qpc-hafs">﴿فَمَنۡ عُفِيَ لَهُۥ﴾</span>: مَن سامَحه وليُّ المقتولِ بالعفوِ عَنِ القِصاصِ والاكتفاءِ بالدِّيَةِ.</p><p><span class="qpc-hafs">﴿فَٱتِّبَاعُۢ﴾</span>: فاتِّباعُ ما أوجبه اللهُ نحوَ القاتِلِ من الدِّيَةِ.</p><p><span class="qpc-hafs">﴿بِٱلۡمَعۡرُوفِ﴾</span>: من غير عُنفٍ من قِبَلِ وليِّ المقتولِ.</p><p><span class="qpc-hafs">﴿وَأَدَآءٌ إِلَيۡهِ﴾</span>: أداءُ ما لَزِمَ وليَّ القاتلِ إلى أولياءِ المقتولِ.</p><p><span class="qpc-hafs">﴿بِإِحۡسَـٰنࣲ﴾</span>: من غيرِ تأخيرٍ، ولا نَقْصٍ.</p><p><span class="qpc-hafs">﴿ٱعۡتَدَىٰ﴾</span>: تجاوَزَ بعد أخْذِ الدِّيةِ.</p></div>"
  2,179,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَيَوٰةࣱ﴾</span>: أي: آمِنةٌ لكم، وفيه عقوبةٌ لأهلِ السَّفَهِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَلۡبَـٰبِ﴾</span>: العُقولِ السَّليمةِ.</p></div>"
  2,180,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُتِبَ﴾</span>: فَرَضَ اللهُ.</p><p><span class="qpc-hafs">﴿ٱلۡمَوۡتُ﴾</span>: علاماتُه ومقدِّماتُه.</p><p><span class="qpc-hafs">﴿خَيۡرًا﴾</span>: مالًا.</p><p><span class="qpc-hafs">﴿بِٱلۡمَعۡرُوفِ﴾</span>: بالعدلِ.</p></div>"
  2,181,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَدَّلَهُۥ﴾</span>: غَيَّرَ ما وصّى به الميتُ.</p><p><span class="qpc-hafs">﴿إِثۡمُهُۥ﴾</span>: إثمُ التغييرِ.</p></div>"
  2,182,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَفًا أَوۡ إِثۡمࣰا﴾</span>: مَيْلًا عَنِ الحَقِّ على سبيل الخطأ أو العَمْدِ.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمۡ﴾</span>: أطرافِ المَيتِ.</p><p><span class="qpc-hafs">﴿فَلَآ إِثۡمَ عَلَيۡهِ﴾</span>: فلا ذَنْبَ عليه بتغييرِ الوصيةِ.</p></div>"
  2,183,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ مِن قَبۡلِكُمۡ﴾</span>: هم أهلُ الكتابِ.</p></div>"
  2,184,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّامࣰا مَّعۡدُودَ ٰ⁠تࣲ﴾</span>: أيامًا مُحْصَياتٍ، وهي شهرُ رمضانَ.</p><p><span class="qpc-hafs">﴿فَعِدَّةࣱ مِّنۡ أَيَّامٍ أُخَرَ﴾</span>: فعليه صيامٌ بقَدْرِ ما أفْطَرَ، من أيامٍ أُخَرَ.</p><p><span class="qpc-hafs">﴿يُطِيقُونَهُۥ﴾</span>: يَتَكَلَّفُون صيامَه ويَشُقُّ عليهم.</p><p><span class="qpc-hafs">﴿مِسۡكِينࣲ﴾</span>: هو المحتاجُ الذي لا يَمْلِكُ ما يَكْفيه.</p><p><span class="qpc-hafs">﴿تَطَوَّعَ خَيۡرࣰا﴾</span>: زاد في قَدْرِ الفِدْيةِ تَبَرُّعًا منه.</p></div>"
  2,185,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُدࣰى﴾</span>: إرشادًا إلى سبيلِ الحقِّ.</p><p><span class="qpc-hafs">﴿وَبَيِّنَـٰتࣲ﴾</span>: دلائلَ واضحةً من البيان.</p><p><span class="qpc-hafs">﴿وَٱلۡفُرۡقَانِ﴾</span>: والفَصْل بينَ الحقِّ والباطلِ.</p><p><span class="qpc-hafs">﴿ٱلۡعِدَّةَ﴾</span>: عدةَ الصيامِ شهرًا، أو عدةَ ما أفْطَرَ فيه المريضُ والمسافرُ.</p><p><span class="qpc-hafs">﴿وَلِتُكَبِّرُواْ ٱللَّهَ﴾</span>: ولِتُعَظِّمُوه بذِكْرِه، وذلك هو التكبيرُ يومَ الفِطْرِ.</p></div>"
  2,186,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَسۡتَجِيبُواْ لِي﴾</span>: فليُطيعوني فيما أمَرْتُهُم به، ونَهَيْتُهم عنه.</p><p><span class="qpc-hafs">﴿يَرۡشُدُونَ﴾</span>: يَهْتدون.</p></div>"
  2,187,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّفَثُ﴾</span>: الجِماعُ.</p><p><span class="qpc-hafs">﴿لِبَاسࣱ﴾</span>: سِتْرٌ وسَكَنٌ.</p><p><span class="qpc-hafs">﴿تَخۡتَانُونَ﴾</span>: تَخُونون. وكانوا يُجامِعُون نساءَهم بعدالعِشاء، وكان هذا مُحَرَّمًا أولَ الإسلامِ.</p><p><span class="qpc-hafs">﴿بَـٰشِرُوهُنَّ﴾</span>: جامِعُوهنَّ.</p><p><span class="qpc-hafs">﴿ٱبۡتَغُواْ مَا كَتَبَ ٱللَّهُ لَكُمۡ﴾</span>: واطْلبُوا ما قدَّره اللهُ من الوَلَدِ.</p><p><span class="qpc-hafs">﴿ٱلۡخَيۡطُ ٱلۡأَبۡيَضُ﴾</span>: ضوءُ الصبحِ.</p><p><span class="qpc-hafs">﴿ٱلۡخَيۡطِ ٱلۡأَسۡوَدِ﴾</span>: سوادِ الليلِ.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِهِۦ﴾</span>: أحكامَه.</p></div>"
  2,188,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: بسببٍ باطلٍ كاليمينِ الكاذبةِ والرَّشوةِ.</p><p><span class="qpc-hafs">﴿وَتُدۡلُواْ بِهَآ إِلَى ٱلۡحُكَّامِ لِتَأۡكُلُواْ فَرِيقࣰا مِّنۡ أَمۡوَ ٰ⁠لِ ٱلنَّاسِ﴾</span>: لا تُلْقُوا بأموالِكم إلى الحُكّام؛ لتأكلوا أموالَ طائفةٍ من الناسِ بالحُجَجِ الباطلةِ.</p><p><span class="qpc-hafs">﴿وَأَنتُمۡ تَعۡلَمُونَ﴾</span>: تحريمَ ذلك.</p></div>"
  2,189,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَهِلَّةِ﴾</span>: جمعُ هِلالٍ، أي: عَنْ تَغَيُّر أحوالهِا بزيادةٍ أو نقصانٍ.</p><p><span class="qpc-hafs">﴿مَوَ ٰ⁠قِيتُ﴾</span>: علاماتٌ على أوقات العبادةِ والمعاملاتِ.</p><p><span class="qpc-hafs">﴿ٱلۡبِرُّ﴾</span>: الخير.</p><p><span class="qpc-hafs">﴿بِأَن تَأۡتُواْ ٱلۡبُيُوتَ مِن ظُهُورِهَا﴾</span>: كانوا أولَ الإسلام إذا أحْرَمُوا بحَجّ أو عُمْرَةٍ فَعَلُوا ذلك.</p><p><span class="qpc-hafs">﴿مَنِ ٱتَّقَىٰ﴾</span>: فِعْلُ مَن اتَّقى.</p></div>"
  2,190,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَعۡتَدُوٓاْ﴾</span>: لا تَرْتَكِبُوا المَناهيَ كقَتْلِ مَن لا يحِلُّ قَتْلُه.</p></div>"
  2,191,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثَقِفۡتُمُوهُمۡ﴾</span>: وجَدْتُموهم في أيِّ مكانٍ تَمَكَّنْتُم مِن قَتْلهِم.</p><p><span class="qpc-hafs">﴿وَٱلۡفِتۡنَةُ﴾</span>: الشِّرْك باللهِ.</p></div>"
  2,192,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنِ ٱنتَهَوۡاْ﴾</span>: تَرَكُوا ما هم فيه من الكفرِ والقِتالِ.</p></div>"
  2,193,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: شِرْكٌ بالله، أو فتنةٌ للمسلمين عن دينِهم.</p><p><span class="qpc-hafs">﴿ٱلدِّينُ لِلَّهِ﴾</span>: خالصًا لله، لا يُعْبَدُ معه غيرُه.</p></div>"
  2,194,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّهۡرُ ٱلۡحَرَامُ﴾</span>: الشهرُ الذي حَرَّمَ اللهُ القتالَ فيه.</p><p><span class="qpc-hafs">﴿بِٱلشَّهۡرِ ٱلۡحَرَامِ﴾</span>: إذا قاتَلُوكم فيه قاتَلْتُموهم فيه.</p><p><span class="qpc-hafs">﴿وَٱلۡحُرُمَـٰتُ قِصَاصࣱ﴾</span>: مَن هَتَكَ حُرْمَةً عليكم فلكم أن تَهْتِكُوا حُرْمَةً عليه، مُساواةً.</p></div>"
  2,195,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلتَّهۡلُكَةِ﴾</span>: المَهالِك، وهو كلُّ ما صَدَقَ عليه أنه تَهْلُكَةٌ في الدِّين، أو الدُّنيا.</p></div>"
  2,196,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَتِمُّواْ﴾</span>: أدُّوهما تامَّيْنِ من غيرِ مَحْظورٍ.</p><p><span class="qpc-hafs">﴿أُحۡصِرۡتُمۡ﴾</span>: حَبَسَكم حابِسٌ عن إتمامِهما بعد الإحرام بِهما.</p><p><span class="qpc-hafs">﴿فَمَا ٱسۡتَيۡسَرَ﴾</span>: فعليكم ذَبْحُ ما تَيَسَّرَ.</p><p><span class="qpc-hafs">﴿ٱلۡهَدۡيِ﴾</span>: ما يُهدى إلى البيت من الإبِلِ، أو البقر، أو الغنمِ.</p><p><span class="qpc-hafs">﴿وَلَا تَحۡلِقُواْ رُءُوسَكُمۡ﴾</span>: لا تُحِلُّوا من الإحرام بالَحلْقِ إن كنتم مُحْصَرِين.</p><p><span class="qpc-hafs">﴿مَحِلَّهُۥ﴾</span>: الموضع الذي حُصِرْتُم فيه.</p><p><span class="qpc-hafs">﴿أَوۡ نُسُكࣲ﴾</span>: أو ذبيحةٍ، وهي شاة لفقراءِ الحرمِ.</p><p><span class="qpc-hafs">﴿أَمِنتُمۡ﴾</span>: كنتم في أمْنٍ وصحةٍ.</p><p><span class="qpc-hafs">﴿تَمَتَّعَ بِٱلۡعُمۡرَةِ إِلَى ٱلۡحَجِّ﴾</span>: أحرمَ بعُمْرَةٍ، ثم أقامَ حلالًا بمكةَ إلى أن يُحْرِمَ بالحجِّ.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: أي بالهَدْيِ وما تَرَتَّبَ عليه من الصِّيامِ.</p><p><span class="qpc-hafs">﴿حَاضِرِي ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span>: ساكنِي أرضِ الحَرمِ.</p></div>"
  2,197,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَجُّ أَشۡهُرࣱ مَّعۡلُومَـٰتࣱ﴾</span>: وقتُ الحجِّ أشهرٌ معلوماتٌ، هي: شوالٌ وذو القِعْدَةِ وعَشْرُ ذي الحِجَّةِ.</p><p><span class="qpc-hafs">﴿فَرَضَ﴾</span>: أوْجَبَ الحَجَّ على نفسِه، وعَزَمَ.</p><p><span class="qpc-hafs">﴿رَفَثَ﴾</span>: الجِماعَ ومقدِّماتِه.</p><p><span class="qpc-hafs">﴿فُسُوقَ﴾</span>: الخُروجَ عن طاعةِ اللهِ بإتيانِ ما نُهِيَ عنه في حال إحرامِه لحَجِّه.</p><p><span class="qpc-hafs">﴿وَلَا جِدَالَ﴾</span>: ولا تنازُعَ، ولا مِراءَ.</p><p><span class="qpc-hafs">﴿وَتَزَوَّدُواْ﴾</span>: خُذُوا زادًا من الطَّعامِ والشَّرابِ، وزادًا من صالحِ الأعمالِ.</p><p><span class="qpc-hafs">﴿يَـٰٓأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: يا أصحاب العقولِ السليمةِ.</p></div>"
  2,198,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُنَاحٌ﴾</span>: حَرَجٌ.</p><p><span class="qpc-hafs">﴿فَضۡلࣰا﴾</span>: التماسَ الرزقِ بالتجارةِ وقْتَ الحَجِّ.</p><p><span class="qpc-hafs">﴿أَفَضۡتُم﴾</span>: دَفَعْتُم.</p><p><span class="qpc-hafs">﴿ٱلۡمَشۡعَرِ ٱلۡحَرَامِ﴾</span>: المَعْلَمِ الحَرامِ، وهو مُزْدَلِفَةُ.</p><p><span class="qpc-hafs">﴿كَمَا هَدَىٰكُمۡ﴾</span>: على الوَجْهِ الصَّحيحِ الذي هداكم إليه.</p><p><span class="qpc-hafs">﴿وَإِن كُنتُم﴾</span>: ولقد كنتم.</p></div>"
  2,199,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ حَيۡثُ أَفَاضَ ٱلنَّاسُ﴾</span>: كما عَمِلَ إبراهيمُ عليه السلامُ.</p></div>"
  2,200,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَضَيۡتُم مَّنَـٰسِكَكُمۡ﴾</span>: فَرَغْتُم مِن حَجِّكم، وذَبَحْتُم النُّسُكَ.</p><p><span class="qpc-hafs">﴿خَلَـٰقࣲ﴾</span>: نَصِيبٍ.</p></div>"
  2,201,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلدُّنۡيَا حَسَنَةࣰ﴾</span>: عافيةً ورزقًا.</p><p><span class="qpc-hafs">﴿وَفِي ٱلۡـَٔاخِرَةِ حَسَنَةࣰ﴾</span>: الَجنّةَ.</p></div>"
  2,202,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصِيبࣱ مِّمَّا كَسَبُواْ﴾</span>: حَظٌّ من أعمالهِم.</p><p><span class="qpc-hafs">﴿سَرِيعُ ٱلۡحِسَابِ﴾</span>: مُحْصٍ أعمالَ عبادِه، ومُجازِيهم بها.</p></div>"
  2,203,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أَيَّامࣲ مَّعۡدُودَ ٰ⁠تࣲ﴾</span>: هي أيامُ الحادي عشر والثاني عشرَ والثالثَ عشرَ مِن ذِي الحِجّةِ، في مِنى.</p><p><span class="qpc-hafs">﴿تَعَجَّلَ﴾</span>: نَفرَ من مِنى في اليومِ الثاني عشرَ.</p><p><span class="qpc-hafs">﴿فَلَآ إِثۡمَ﴾</span>: فلا حَرَجَ، ولا ذَنْبَ عليه في تَعَجُّله.</p><p><span class="qpc-hafs">﴿وَمَن تَأَخَّرَ﴾</span>: فنَفَرَ في اليومِ الثالثَ عَشَرَ.</p></div>"
  2,204,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنَ ٱلنَّاسِ﴾</span>: من المنافقين.</p><p><span class="qpc-hafs">﴿عَلَىٰ مَا فِي قَلۡبِهِۦ﴾</span>: من محبَّةِ الإسلامِ.</p><p><span class="qpc-hafs">﴿أَلَدُّ ٱلۡخِصَامِ﴾</span>: شديدُ العَداوةِ والمخاصَمَةِ.</p></div>"
  2,205,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span>: خَرَجَ مِن عندِك.</p><p><span class="qpc-hafs">﴿ٱلۡحَرۡثَ﴾</span>: الزَّرْعَ.</p><p><span class="qpc-hafs">﴿وَٱلنَّسۡلَ﴾</span>: نَسْلَ كلِّ دابَّةٍ.</p></div>"
  2,206,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخَذَتۡهُ ٱلۡعِزَّةُ﴾</span>: حَمَلَه الكِبْرُ وحَمِيَّةُ الجاهليةِ.</p><p><span class="qpc-hafs">﴿فَحَسۡبُهُۥ﴾</span>: فكافيتُه.</p><p><span class="qpc-hafs">﴿ٱلۡمِهَادُ﴾</span>: الفِراشُ.</p></div>"
  2,207,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَشۡرِي﴾</span>: يَبيعُ.</p></div>"
  2,208,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسِّلۡمِ﴾</span>: شرائعِ الإسلامِ.</p><p><span class="qpc-hafs">﴿كَآفَّةࣰ﴾</span>: في جميعِ أحكامِه، فلا تُضَيِّعُوا منها شيئًا.</p><p><span class="qpc-hafs">﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾</span>: طُرُقَه وآثارَه.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: ظاهرُ العَداوةِ.</p></div>"
  2,209,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَلَلۡتُم﴾</span>: أخْطَأْتُم الحقَّ.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتُ﴾</span>: الحُجَجُ الواضحَةُ.</p><p><span class="qpc-hafs">﴿عَزِيزٌ﴾</span>: في نِقْمَتِه.</p><p><span class="qpc-hafs">﴿حَكِيمٌ﴾</span>: يَضَعُ كلَّ شيءٍ في مَوْضِعِه المناسِبِ.</p></div>"
  2,210,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ يَنظُرُونَ﴾</span>: ما ينتظرُ هؤلاء الكافرونَ.</p><p><span class="qpc-hafs">﴿يَأۡتِيَهُمُ ٱللَّهُ﴾</span>: على الوجهِ الذي يَليقُ به.</p><p><span class="qpc-hafs">﴿ظُلَلࣲ﴾</span>: جمعُ ظُلَّةٍ، وهي ما يُسْتَظَلُّ به.</p><p><span class="qpc-hafs">﴿ٱلۡغَمَامِ﴾</span>: السَّحابِ.</p><p><span class="qpc-hafs">﴿وَقُضِيَ ٱلۡأَمۡرُ﴾</span>: وفُصِلَ القضاءُ بالعَدْلِ.</p></div>"
  2,211,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةِۭ بَيِّنَةࣲ﴾</span>: علامةٍ واضحةٍ، كعَصا موسى ويدِه.</p><p><span class="qpc-hafs">﴿نِعۡمَةَ ٱللَّهِ﴾</span>: الإسلامَ، وما فَرَضَ من شرائعِ دينِه.</p></div>"
  2,212,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُيِّنَ﴾</span>: حُسِّنَ.</p><p><span class="qpc-hafs">﴿وَيَسۡخَرُونَ﴾</span>: ويَسْتهزِئُون.</p><p><span class="qpc-hafs">﴿فَوۡقَهُمۡ﴾</span>: يُدْخِلُهم اللهُ أعلى درجاتِ الجنةِ.</p></div>"
  2,213,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: جماعةً واحدةً متفقين على دينٍ واحدٍ.</p><p><span class="qpc-hafs">﴿مُبَشِّرِينَ﴾</span>: مَن أطاع اللهَ بالجنةِ.</p><p><span class="qpc-hafs">﴿وَمُنذِرِينَ﴾</span>: ومُحَذِّرينَ مَن عصاه النارَ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: الكُتُبَ السماويةَ.</p><p><span class="qpc-hafs">﴿فِيهِ﴾</span>: في الكتابِ الذي أنزلَه اللهُ.</p><p><span class="qpc-hafs">﴿أُوتُوهُ﴾</span>: أُعْطُوا الكتابَ.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتُ﴾</span>: حُجَجُ اللهِ، وأدِلَّتهُ.</p><p><span class="qpc-hafs">﴿بَغۡيَۢا﴾</span>: حَسَدًا، وحِرْصًا على الدنيا.</p><p><span class="qpc-hafs">﴿فَهَدَى ٱللَّهُ﴾</span>: فوفَّقَ أمةَ محمدٍ ﷺ إلى الحَقِّ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ﴾</span>: طريقٍ.</p></div>"
  2,214,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَوۡاْ﴾</span>: مضَوا.</p><p><span class="qpc-hafs">﴿ٱلۡبَأۡسَآءُ﴾</span>: الفقرُ والشِّدَّةُ.</p><p><span class="qpc-hafs">﴿ٱلضَّرَّآءُ﴾</span>: الأمراضُ.</p><p><span class="qpc-hafs">﴿زُلۡزِلُواْ﴾</span>: أُزعِجُوا إزعاجًا شديدًا.</p></div>"
  2,215,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡيَتَـٰمَىٰ﴾</span>: والذين مات آباؤُهم وهم دونَ البُلوغِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: والمحتاجِين الذين لا يملكونَ ما يَكْفيهم.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: والمسافرِ المحتاجِ.</p></div>"
  2,216,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُتِبَ﴾</span>: فَرَضَ اللهُ.</p><p><span class="qpc-hafs">﴿وَٱللَّهُ يَعۡلَمُ﴾</span>: ما هو خيرٌ لكم.</p></div>"
  2,217,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡـَٔلُونَكَ﴾</span>: يَسْألك المُشْركون.</p><p><span class="qpc-hafs">﴿قِتَالࣲ فِيهِ﴾</span>: هل يَحِلُّ القِتالُ فيه؟</p><p><span class="qpc-hafs">﴿وَصَدٌّ﴾</span>: ومَنعٌ.</p><p><span class="qpc-hafs">﴿وَكُفۡرُۢ بِهِۦ﴾</span>: وكُفْرٌ باللهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span>: وصَدٌّ عن المسجدِ الحرامِ كذلك.</p><p><span class="qpc-hafs">﴿وَٱلۡفِتۡنَةُ﴾</span>: الشِّرْكُ.</p><p><span class="qpc-hafs">﴿أَكۡبَرُ مِنَ ٱلۡقَتۡلِ﴾</span>: أعظمُ من القَتْلِ في الشهرِ الحرامِ.</p><p><span class="qpc-hafs">﴿حَبِطَتۡ﴾</span>: بَطَلَتْ، وفَسَدَتْ.</p></div>"
  2,218,""
  2,219,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمَيۡسِرِ﴾</span>: القِمارِ.</p><p><span class="qpc-hafs">﴿إِثۡمࣱ﴾</span>: أضرارٌ، ومفاسدُ.</p><p><span class="qpc-hafs">﴿وَمَنَـٰفِعُ﴾</span>: مِن جهةِ كَسْبِ المالِ واللَّذَّةِ وغيرِهما، وهذا قبلَ التحريمِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَفۡوَ﴾</span>: الفَضْلَ الزائدَ على الحاجةِ.</p></div>"
  2,220,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِصۡلَاحࣱ لَّهُمۡ﴾</span>: مُخالَطَتُهم على وجهِ الإصلاحِ لأموالِهم.</p><p><span class="qpc-hafs">﴿لَأَعۡنَتَكُمۡ﴾</span>: لَأَوقَعكُم فيما فيه الحَرَجُ والمَشَقَّةُ بتحريمِ مخالطَتِهم.</p><p><span class="qpc-hafs">﴿حَكِيمࣱ﴾</span>: يتَصَرَّفُ في مُلْكِه بما تَقْتضيه حِكْمَتُه.</p></div>"
  2,221,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُشۡرِكَـٰتِ﴾</span>: الوثنيّاتِ.</p><p><span class="qpc-hafs">﴿وَلَأَمَةࣱ﴾</span>: المملوكةُ الرقيقةُ.</p><p><span class="qpc-hafs">﴿أُوْلَـٰٓئِكَ﴾</span>: المشركون رجالًا ونساءً.</p><p><span class="qpc-hafs">﴿إِلَى ٱلنَّارِ﴾</span>: إلى الأعمالِ المُوجبةِ للنارِ.</p><p><span class="qpc-hafs">﴿بِإِذۡنِهِۦ﴾</span>: بأمرهِ، وتوفيقِه.</p></div>"
  2,222,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱعۡتَزِلُواْ﴾</span>: اجتنِبُوا الجِماعَ، لا المجالسةَ، أو الملامسةَ.</p><p><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوهُنَّ﴾</span>: ولا تجامِعُوهُنَّ.</p><p><span class="qpc-hafs">﴿يَطۡهُرۡنَ﴾</span>: ينقطِعُ دَمُهُن.</p><p><span class="qpc-hafs">﴿تَطَهَّرۡنَ﴾</span>: اغتسَلْن.</p><p><span class="qpc-hafs">﴿فَأۡتُوهُنَّ مِنۡ حَيۡثُ أَمَرَكُمُ ٱللَّهُ﴾</span>: فجامِعُوهن في الموضعِ الذي أحلَّه اللهُ وهو القُبُلُ.</p></div>"
  2,223,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرۡثࣱ لَّكُمۡ﴾</span>: موضعُ زَرْعٍ لنُطَفِكم.</p><p><span class="qpc-hafs">﴿أَنَّىٰ شِئۡتُمۡ﴾</span>: من أيِّ جهةٍ شِئْتم، في موضع الحَرْثِ.</p><p><span class="qpc-hafs">﴿وَقَدِّمُواْ لِأَنفُسِكُمۡ﴾</span>: من التقرُّبِ إلى اللهِ بفعلِ الخيراتِ.</p></div>"
  2,224,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُرۡضَةࣰ لِّأَيۡمَـٰنِكُمۡ﴾</span>: مانعًا لكم، وحاجزًا من البِرّ، وفِعْلِ الخيرِ. فإذا دُعِيتم إلى فِعْلِه قُلْتم: إنّكم أقْسَمْتُم ألّا تفعلُوه، فالحالِفُ يُمْكِنُه أن يفعلَ البِرَّ، ثم يُكَفِّرَ.</p><p><span class="qpc-hafs">﴿أَن تَبَرُّواْ﴾</span>: مانعًا من بِرِّكم، وإصلاحِكم.</p></div>"
  2,225,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱللَّغۡوِ﴾</span>: هو اليمينُ بغير إرادةٍ لها وقَصْدٍ.</p><p><span class="qpc-hafs">﴿كَسَبَتۡ قُلُوبُكُمۡ﴾</span>: قَصَدَتْه قُلوبُكم.</p></div>"
  2,226,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡلُونَ﴾</span>: يَحْلِفُون ألّا يُجامِعُوا نساءَهم أكثرَ من أربعةِ أشهرٍ.</p><p><span class="qpc-hafs">﴿تَرَبُّصُ أَرۡبَعَةِ أَشۡهُرࣲ﴾</span>: عليهم انتظارُ أربعةِ أشهرٍ.</p><p><span class="qpc-hafs">﴿فَآءُو﴾</span>: رَجَعُوا قبلَ فواتِ الأشهرِ الأربعةِ.</p><p><span class="qpc-hafs">﴿غَفُورࣱ﴾</span>: لا يُؤاخِذُهم بتلك اليمينِ.</p></div>"
  2,227,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَزَمُواْ ٱلطَّلَـٰقَ﴾</span>: وقَعَ العَزْمُ منهم على الطَّلاقِ باستمرارِهم في اليمينِ.</p></div>"
  2,228,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَرَبَّصۡنَ﴾</span>: ينتَظِرْن دُونَ نكاحٍ بعدَ الطَّلاقِ.</p><p><span class="qpc-hafs">﴿ثَلَـٰثَةَ قُرُوٓءࣲ﴾</span>: ثلاثةَ أوقاتٍ من الطُّهر أو الحيضِ للتأكدِ من فراغِ الرَّحِم.</p><p><span class="qpc-hafs">﴿يَكۡتُمۡنَ﴾</span>: يُخْفِينَ الحَمْلَ، أو الحيضَ.</p><p><span class="qpc-hafs">﴿وَبُعُولَتُهُنَّ﴾</span>: هم أزواجُ المطلقاتِ.</p><p><span class="qpc-hafs">﴿أَحَقُّ بِرَدِّهِنَّ﴾</span>: أحقُّ بمُراجَعَتِهِنَّ في العِدَّةِ.</p><p><span class="qpc-hafs">﴿دَرَجَةࣱ﴾</span>: منزلةٌ زائدةٌ من القِوامةِ على البيتِ، والإنفاقِ، والزيادةِ في الميراث، وغيرِ ذلك.</p></div>"
  2,229,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّلَـٰقُ مَرَّتَانِ﴾</span>: أي: الذي تحصُلُ به الرَّجْعَةُ، وهو مرة بعدَ مرة.</p><p><span class="qpc-hafs">﴿بِمَعۡرُوفٍ﴾</span>: حُسْنِ العِشْرةِ بعدَ مراجَعَتِها.</p><p><span class="qpc-hafs">﴿تَسۡرِيحُۢ بِإِحۡسَـٰنࣲ﴾</span>: تَخْلِيةُ سبيلِها، مع أداءِ حُقوقِها.</p><p><span class="qpc-hafs">﴿شَيۡـًٔا﴾</span>: ممّا أعْطَيْتُموه من المَهْر ونحوِه على وجهِ المُضارَّةِ.</p><p><span class="qpc-hafs">﴿إِلَّآ أَن يَخَافَآ﴾</span>: يخافَ الزوجان ألّا يقوما بالحقوقِ الزوجيَّةِ. وهي المُخالَعَةُ بالمعروفِ.</p><p><span class="qpc-hafs">﴿فَإِنۡ خِفۡتُمۡ﴾</span>: أي: الأولياءُ، أو المتوسِّطون بين الزوجَيْن.</p><p><span class="qpc-hafs">﴿فِيمَا ٱفۡتَدَتۡ﴾</span>: فيما تدفَعُه المرأةُ للزوجِ مقابلَ الطلاقِ، وهو الخُلْعُ.</p><p><span class="qpc-hafs">﴿فَلَا تَعۡتَدُوهَا﴾</span>: فلا تَتَجاوَزُوها.</p></div>"
  2,230,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِن طَلَّقَهَا﴾</span>: أي الطَّلْقَةَ الثالثةَ.</p><p><span class="qpc-hafs">﴿نكِحَ﴾</span>: بزَواجٍ صَحيحٍ وجِماعٍ.</p><p><span class="qpc-hafs">﴿فَإِن طَلَّقَهَا﴾</span>: أي الزوجُ الثاني.</p><p><span class="qpc-hafs">﴿فَلَا جُنَاحَ عَلَيۡهِمَآ﴾</span>: أي على الزوجِ الأولِ والمرأةِ.</p><p><span class="qpc-hafs">﴿أَن يَتَرَاجَعَآ﴾</span>: أن يتزوَّجا بعَقْدٍ جديدٍ، ومَهْرٍ جديدٍ.</p></div>"
  2,231,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَلَغۡنَ أَجَلَهُنَّ﴾</span>: فقارَبْنَ انقضاءَ العِدَّةِ.</p><p><span class="qpc-hafs">﴿فَأَمۡسِكُوهُنَّ﴾</span>: فراجِعُوهُنَّ.</p><p><span class="qpc-hafs">﴿بِمَعۡرُوفٍ﴾</span>: مِن غيرِ قَصْدٍ لضِرارٍ.</p><p><span class="qpc-hafs">﴿سَرِّحُوهُنَّ﴾</span>: اترُكُوهُنَّ، حتى تنقضِيَ العِدَّةُ.</p><p><span class="qpc-hafs">﴿وَلَا تُمۡسِكُوهُنَّ ضِرَارࣰا﴾</span>: لا تَكُنْ مُراجَعَتُهن بقَصْدِ الاعتداءِ، والظلمِ لهن.</p><p><span class="qpc-hafs">﴿هُزُوࣰا﴾</span>: لَعِبًا بها بالتجرُّؤِ عليها.</p><p><span class="qpc-hafs">﴿وَٱلۡحِكۡمَةِ﴾</span>: السُّنَّةِ.</p></div>"
  2,232,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذَا طَلَّقۡتُمُ﴾</span>: خطابٌ لأولياءِ المطلقةِ دونَ الثلاثِ، إذا خَرَجَتْ من العِدَّةِ، وأرادَتْ زوجَها بنِكاحٍ جديدٍ.</p><p><span class="qpc-hafs">﴿فَبَلَغۡنَ أَجَلَهُنَّ﴾</span>: انتهَتْ عِدَّتُهن من غيرِ مراجعَةٍ لهنَّ.</p><p><span class="qpc-hafs">﴿فَلَا تَعۡضُلُوهُنَّ﴾</span>: فلا يجوزُ لوَلِيِّها أن يَمْنَعَها من التزوُّجِ بعَقْدٍ جديدٍ.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُمۡ﴾</span>: تمكينُ الأزواجِ من نكاحِ زوجاتِهِم.</p><p><span class="qpc-hafs">﴿أَزۡكَىٰ﴾</span>: أكثرُ نماءً وأنفعُ.</p></div>"
  2,233,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَوۡلَيۡنِ﴾</span>: سنتَيْنِ.</p><p><span class="qpc-hafs">﴿وَعَلَى ٱلۡمَوۡلُودِ لَهُۥ﴾</span>: هو الأبُ.</p><p><span class="qpc-hafs">﴿رِزۡقُهُنَّ﴾</span>: رِزْقُ المُرضِعاتِ المُطَلَّقاتِ.</p><p><span class="qpc-hafs">﴿وُسۡعَهَا﴾</span>: قَدْرَ طاقَتِها.</p><p><span class="qpc-hafs">﴿لَا تُضَآرَّ وَ ٰ⁠لِدَةُۢ بِوَلَدِهَا﴾</span>: لا يَحِلُّ للوالدَين أن يَجْعلوا المولودَ وسيلةً للمُضارَّةِ بينهما.</p><p><span class="qpc-hafs">﴿وَعَلَى ٱلۡوَارِثِ مِثۡلُ ذَ ٰ⁠لِكَ﴾</span>: أي: عند مَوْتِ الوالدِ وجَبَ على وارثِه مثلُ ما يجبُ على الوالدِ مِنَ النفقةِ والكِسْوةِ.</p><p><span class="qpc-hafs">﴿أَرَادَا﴾</span>: الوالدان.</p><p><span class="qpc-hafs">﴿فِصَالًا﴾</span>: فِطامَ المولودِ عن الرَّضاعةِ قبل السنتَين.</p><p><span class="qpc-hafs">﴿تَسۡتَرۡضِعُوٓاْ﴾</span>: إرضاعَ المولودِ من مُرْضِعَةٍ أخرى.</p><p><span class="qpc-hafs">﴿إِذَا سَلَّمۡتُم﴾</span>: سَلَّم الوالدُ للأمِّ حَقَّها، وسَلَّمَ للمُرْضِعَةِ أجْرَها.</p></div>"
  2,234,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَرَبَّصۡنَ﴾</span>: ينتظِرْنَ في منزلِ الزوجِ.</p><p><span class="qpc-hafs">﴿بَلَغۡنَ أَجَلَهُنَّ﴾</span>: انقضَتِ المدةُ المذكورةُ.</p><p><span class="qpc-hafs">﴿فِيمَا فَعَلۡنَ﴾</span>: مِنَ الخروجِ والتَّزيُّنِ والتعرُّضِ للخُطّابِ.</p></div>"
  2,235,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا جُنَاحَ﴾</span>: ولا إثمَ.</p><p><span class="qpc-hafs">﴿عَرَّضۡتُم بِهِۦ مِنۡ خِطۡبَةِ ٱلنِّسَآءِ﴾</span>: لَمَّحْتُم مِن طَلَبِ الزواج مِنَ المُتوفّى عنهن أزواجُهُنَّ، أو المطلقاتِ طلاقًا بائنًا، في أثناءِ العِدَّةِ.</p><p><span class="qpc-hafs">﴿أَكۡنَنتُمۡ﴾</span>: أضْمَرْتُم من نيةِ الزواجِ بهنَّ بعد انتهاءِ عِدَّتِهن.</p><p><span class="qpc-hafs">﴿لَّا تُوَاعِدُوهُنَّ سِرًّا﴾</span>: على النِّكاح.</p><p><span class="qpc-hafs">﴿قَوۡلࣰا مَّعۡرُوفࣰا﴾</span>: أي: يُفْهَمُ منه أنّ مِثْلَها يُرْغَبُ فيها.</p><p><span class="qpc-hafs">﴿حَتَّىٰ يَبۡلُغَ ٱلۡكِتَـٰبُ﴾</span>: حتى تنقضِيَ عِدَّتُها.</p></div>"
  2,236,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا جُنَاحَ﴾</span>: لا إثمَ. والمرادُ به التَّبِعَةُ من المهرِ ونحوِه.</p><p><span class="qpc-hafs">﴿إِن طَلَّقۡتُمُ﴾</span>: قبلَ المسيسِ، وفَرْضِ المَهْرِ.</p><p><span class="qpc-hafs">﴿أَوۡ تَفۡرِضُواْ لَهُنَّ﴾</span>: قبلَ أن تُحَدِّدوا مَهْرًا لهنَّ.</p><p><span class="qpc-hafs">﴿وَمَتِّعُوهُنَّ﴾</span>: أي: بشيءٍ ينتفِعْنَ به جَبْرًا لهن.</p><p><span class="qpc-hafs">﴿عَلَى ٱلۡمُوسِعِ قَدَرُهُۥ﴾</span>: على المُطَلِّق الغنيِّ قَدْرُ سَعَةِ رزقِه.</p><p><span class="qpc-hafs">﴿ٱلۡمُقۡتِرِ﴾</span>: المُطَلِّقِ الفقيرِ.</p><p><span class="qpc-hafs">﴿قَدَرُهُۥ﴾</span>: قَدَرُ ما يَمْلِكُه.</p><p><span class="qpc-hafs">﴿حَقًّا عَلَى ٱلۡمُحۡسِنِينَ﴾</span>: أي: حَقًّا ثابتًا على الذين يُحْسِنون إلى الُمطَلَّقاتِ.</p></div>"
  2,237,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن طَلَّقۡتُمُوهُنَّ﴾</span>: بعد العَقْدِ.</p><p><span class="qpc-hafs">﴿تَمَسُّوهُنَّ﴾</span>: تُجامِعُوهن.</p><p><span class="qpc-hafs">﴿فَرَضۡتُمۡ لَهُنَّ فَرِيضَةࣰ﴾</span>: التَزمْتُم لهنَّ بمَهْرٍ معينٍ.</p><p><span class="qpc-hafs">﴿إِلَّآ أَن يَعۡفُونَ﴾</span>: إلا أن يَتَسامَحَ المُطَلَّقاتُ، فيترُكْنَ نصفَ المَهْرِ المستحَقِّ لهنَّ.</p><p><span class="qpc-hafs">﴿أَوۡ يَعۡفُوَاْ ٱلَّذِي﴾</span>: أو يتسامَحَ الزوجُ، فيتركَ للمطلقةِ المهرَ كلَّه.</p><p><span class="qpc-hafs">﴿ٱلۡفَضۡلَ﴾</span>: الإحسانَ، والتسامحَ في الحقوقِ.</p></div>"
  2,238,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَـٰفِظُواْ﴾</span>: واظِبُوا.</p><p><span class="qpc-hafs">﴿وَٱلصَّلَوٰةِ ٱلۡوُسۡطَىٰ﴾</span>: هي صلاةُ العَصْرِ.</p><p><span class="qpc-hafs">﴿قَـٰنِتِينَ﴾</span>: خاشِعين ذلِيلِين.</p></div>"
  2,239,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرِجَالًا﴾</span>: ماشِين.</p><p><span class="qpc-hafs">﴿رُكۡبَانࣰا﴾</span>: راكبين.</p><p><span class="qpc-hafs">﴿فَٱذۡكُرُواْ ٱللَّهَ﴾</span>: أقيمُوا صلاتَكم كما أُمِرْتُمْ.</p></div>"
  2,240,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّتَـٰعًا﴾</span>: يُمَتَّعْنَ بالسُّكنى والنفقةِ في منزلِ الزوجِ، وذلك قبلَ النَّسْخِ.</p><p><span class="qpc-hafs">﴿إِلَى ٱلۡحَوۡلِ﴾</span>: إلى سنةٍ كاملةٍ.</p><p><span class="qpc-hafs">﴿غَيۡرَ إِخۡرَاجࣲ﴾</span>: لا يُخْرِجُهُنَّ الوَرَثَةُ.</p><p><span class="qpc-hafs">﴿فَإِنۡ خَرَجۡنَ﴾</span>: باختيارِهنَّ قبلَ الحَوْلِ.</p><p><span class="qpc-hafs">﴿فَلَا جُنَاحَ﴾</span>: فلا إثمَ.</p><p><span class="qpc-hafs">﴿مِن مَّعۡرُوفࣲ﴾</span>: من أمورٍ مُباحَةٍ.</p></div>"
  2,241,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعُۢ﴾</span>: من كِسوةٍ ونفقةٍ.</p></div>"
  2,242,""
  2,243,""
  2,244,""
  2,245,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُقۡرِضُ﴾</span>: يُنْفِقُ في سبيلِ اللهِ.</p><p><span class="qpc-hafs">﴿يَقۡبِضُ﴾</span>: يُضَيِّقُ في الرِّزقِ.</p><p><span class="qpc-hafs">﴿وَيَبۡصُۜطُ﴾</span>: ويُوَسِّعُ فيه.</p></div>"
  2,246,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَإِ﴾</span>: الأشرافِ.</p><p><span class="qpc-hafs">﴿هَلۡ عَسَيۡتُمۡ﴾</span>: هل الأمرُ كما أتَوَقَّعُه منكم، وهو الجُبْنُ عن القتالِ؟</p><p><span class="qpc-hafs">﴿كُتِبَ﴾</span>: فُرِضَ.</p><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: فَرُّوا.</p></div>"
  2,247,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنَّىٰ يَكُونُ لَهُ ٱلۡمُلۡكُ﴾</span>: كيف يكونُ له المُلْكُ، وهو لا يستحِقُّه؟</p><p><span class="qpc-hafs">﴿ٱصۡطَفَىٰهُ﴾</span>: اختارَه.</p><p><span class="qpc-hafs">﴿بَسۡطَةࣰ﴾</span>: سَعَةً وقوةً.</p><p><span class="qpc-hafs">﴿وَ ٰ⁠سِعٌ﴾</span>: واسعُ الفَضْلِ.</p></div>"
  2,248,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةَ﴾</span>: علامةَ.</p><p><span class="qpc-hafs">﴿ٱلتَّابُوتُ﴾</span>: الصندوقُ الذي فيه التوراةُ، وكان الأعداءُ قد انتزَعُوه.</p><p><span class="qpc-hafs">﴿سَكِينَةࣱ﴾</span>: طمأنينةٌ تُثَبِّتُ قلوبَ المُخْلِصين.</p><p><span class="qpc-hafs">﴿وَبَقِيَّةࣱ﴾</span>: هي الألواحُ وعَصا موسى، وغيرُ ذلك.</p></div>"
  2,249,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَصَلَ﴾</span>: خَرَجَ.</p><p><span class="qpc-hafs">﴿مُبۡتَلِيكُم﴾</span>: مُخْتَبِركُم.</p><p><span class="qpc-hafs">﴿فَلَيۡسَ مِنِّي﴾</span>: ليس من أهلِ ديني وطاعتي.</p><p><span class="qpc-hafs">﴿لَّمۡ يَطۡعَمۡهُ﴾</span>: لم يَشْرَبْه.</p><p><span class="qpc-hafs">﴿ٱغۡتَرَفَ﴾</span>: أخَذَ منه قليلًا.</p><p><span class="qpc-hafs">﴿جَاوَزَهُۥ هُوَ﴾</span>: عَبَرَ طالوتُ النهرَ مع القلَّةِ المؤمنَةِ.</p><p><span class="qpc-hafs">﴿قَالُواْ﴾</span>: قال الذين عَبَرُوا، وحَصَلَ معهم استضعافٌ لأنفسهم.</p><p><span class="qpc-hafs">﴿لَا طَاقَةَ﴾</span>: لا قُدْرَةَ.</p><p><span class="qpc-hafs">﴿يَظُنُّونَ﴾</span>: يَسْتيقِنون.</p></div>"
  2,250,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمَّا بَرَزُواْ﴾</span>: ولمّا صارُوا في مُتَّسَعٍ مِنَ الأرضِ.</p><p><span class="qpc-hafs">﴿لِجَالُوتَ﴾</span>: قائدِ الجبابرةِ.</p></div>"
  2,251,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡحِكۡمَةَ﴾</span>: النبوَّةَ.</p><p><span class="qpc-hafs">﴿وَلَوۡلَا دَفۡعُ ٱللَّهِ﴾</span>: بأن يَدْفَعَ صالحُهم المفسدين بأنْ يَصُدُّوهم عن محاولةِ الفَسادِ.</p><p><span class="qpc-hafs">﴿لَّفَسَدَتِ ٱلۡأَرۡضُ﴾</span>: لَفَسَدَ ما عليها، واختَلَّ نظامُها.</p></div>"
  2,252,""
  2,253,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّن كَلَّمَ ٱللَّهُ﴾</span>: كموسى عليه السلامُ.</p><p><span class="qpc-hafs">﴿وَرَفَعَ بَعۡضَهُمۡ دَرَجَـٰتࣲ﴾</span>: كمحمدٍ ﷺ بعمومِ رسالتِه، وخَتْمِ النبوةِ به.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتِ﴾</span>: المُعْجِزاتِ الباهراتِ كإحياء الموتى بإذنِ الله.</p><p><span class="qpc-hafs">﴿بِرُوحِ ٱلۡقُدُسِ﴾</span>: جبريلَ عليه السلامُ.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِهِم﴾</span>: من بعدِ هؤلاءِ الرُّسُل.</p></div>"
  2,254,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنفِقُواْ﴾</span>: بإخراجِ الزَّكاةِ المفروضةِ وغيرها من الصدقاتِ.</p><p><span class="qpc-hafs">﴿لَّا بَيۡعࣱ﴾</span>: فيكونَ معه رِبحٌ تَفْتَدَون به أنفسَكم.</p><p><span class="qpc-hafs">﴿وَلَا خُلَّةࣱ﴾</span>: ولا صَداقةٌ.</p><p><span class="qpc-hafs">﴿شَفَـٰعَةࣱ﴾</span>: شفاعةُ شافعٍ مُؤَثِّرةٌ.</p></div>"
  2,255,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَيُّومُ﴾</span>: القائمُ على كلِّ شيءٍ.</p><p><span class="qpc-hafs">﴿سِنَةࣱ﴾</span>: نُعاسٌ.</p><p><span class="qpc-hafs">﴿كُرۡسِيُّهُ﴾</span>: موضعُ قَدَمَي الرَّبِّ، ولا يَعْلَمُ كيفيتَه إلا اللهُ.</p><p><span class="qpc-hafs">﴿وَلَا يَـُٔودُهُۥ﴾</span>: ولا يُثْقِلُه.</p></div>"
  2,256,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَآ إِكۡرَاهَ فِي ٱلدِّينِ﴾</span>: لاتُكْرِهُوا أحدًا على الدُّخولِ في دينِ الإسلامِ.</p><p><span class="qpc-hafs">﴿ٱلرُّشۡدُ﴾</span>: الحقُّ أو الإيمانُ.</p><p><span class="qpc-hafs">﴿ٱلۡغَيِّ﴾</span>: الباطِلُ أو الكفرُ.</p><p><span class="qpc-hafs">﴿بِٱلطَّـٰغُوتِ﴾</span>: بكلِّ ما عُبِدَ من دونِ اللهِ.</p><p><span class="qpc-hafs">﴿بِٱلۡعُرۡوَةِ ٱلۡوُثۡقَىٰ﴾</span>: الطريقةِ المثلى، أو الإسلامِ.</p><p><span class="qpc-hafs">﴿لَا ٱنفِصَامَ لَهَا﴾</span>: لا انقطاعَ، ولا انكسارَ لها.</p></div>"
  2,257,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّهُ وَلِيُّ ٱلَّذِينَ ءَامَنُواْ﴾</span>: اللَّهُ يَتَوَلّاهم بتوفيقِه.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلظُّلُمَـٰتِ﴾</span>: من ظُلُماتِ الكفرِ.</p><p><span class="qpc-hafs">﴿إِلَى ٱلنُّورِ﴾</span>: إلى نورِ الإيمانِ.</p><p><span class="qpc-hafs">﴿أَوۡلِيَآؤُهُمُ ٱلطَّـٰغُوتُ﴾</span>: أنصارُهم هم الذين يَعْبُد ونَهم من دونِ اللهِ.</p></div>"
  2,258,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ تَرَ﴾</span>: ألم يَنْتهِ عِلْمُك.</p><p><span class="qpc-hafs">﴿حَآجَّ﴾</span>: جادَلَ، وهومَلِكُ بابلَ نَمْرُوذُ.</p><p><span class="qpc-hafs">﴿فِي رَبِّهِۦٓ﴾</span>: في وجودِ ربِّه.</p><p><span class="qpc-hafs">﴿أَنۡ ءَاتَىٰهُ ٱللَّهُ ٱلۡمُلۡكَ﴾</span>: لأنه أعطاه الُملْكَ فتَجَبَّر.</p><p><span class="qpc-hafs">﴿أَنَا۠ أُحۡيِۦ وَأُمِيتُ﴾</span>: أقتلُ مَن أرَدْتُ، وأعفُو عَمَّنْ أرَدْتُ قَتْلَه.</p><p><span class="qpc-hafs">﴿فَبُهِتَ﴾</span>: فَتَحَيَّر، وقامَتْ عليه الحُجَّةُ.</p></div>"
  2,259,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلَّذِي﴾</span>: عُزَيْرٌ.</p><p><span class="qpc-hafs">﴿قَرۡيَةࣲ﴾</span>: بيت المقدس.</p><p><span class="qpc-hafs">﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾</span>: تَهَدَّمَتْ دُورُها، واشتدَّ خَرابُها.</p><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: كيف؟ وهو استبعادٌ لإحيائِها.</p><p><span class="qpc-hafs">﴿لَمۡ يَتَسَنَّهۡ﴾</span>: لم يتغَيَّرْ.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: دَلالةً على قدرةِ اللهِ على البعثِ.</p><p><span class="qpc-hafs">﴿نُنشِزُهَا﴾</span>: نرفعُها، ونُرَكِّبُ بعضَها على بعضٍ.</p></div>"
  2,260,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرِنِي﴾</span>: رؤيةَ العينِ.</p><p><span class="qpc-hafs">﴿لِّيَطۡمَئِنَّ قَلۡبِي﴾</span>: ليُؤْمِنَ قلبي.</p><p><span class="qpc-hafs">﴿فَصُرۡهُنَّ إِلَيۡكَ﴾</span>: فاضْمُمْهُنَّ إليك، واجمَعْهُنَّ، ثم قَطِّعْهُنَّ.</p><p><span class="qpc-hafs">﴿سَعۡيࣰا﴾</span>: مُسْرِعَةً.</p></div>"
  2,261,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۢبَتَتۡ سَبۡعَ سَنَابِلَ﴾</span>: أخْرَجَتْ ساقًا تَشَعَّبَ منه سَبْعُ شُعَبٍ، في كل شُعبةٍ سنبلةٌ.</p><p><span class="qpc-hafs">﴿يُضَـٰعِفُ﴾</span>: الأجْرَ.</p></div>"
  2,262,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنࣰّا﴾</span>: التحَدُّثَ بما أعْطى، حتى يَبْلُغَ ذلك المُعْطى، فيؤذِيَه.</p><p><span class="qpc-hafs">﴿أَذࣰى﴾</span>: التطاولَ على المُعْطى.</p><p><span class="qpc-hafs">﴿وَلَا خَوۡفٌ عَلَيۡهِمۡ﴾</span>: فيما يَسْتقبلونه من أجْر الآخرةِ.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على شيءٍ فاتَهم في الدنيا.</p></div>"
  2,263,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوۡلࣱ مَّعۡرُوفࣱ﴾</span>: رَدٌّ جميل يُرَدُّ به السّائلُ.</p><p><span class="qpc-hafs">﴿وَمَغۡفِرَةٌ﴾</span>: وعَفْوٌ عمّا بَدَرَ من السّائلِ مِن إلحاحٍ.</p></div>"
  2,264,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلَّذِي﴾</span>: لا تُبْطِلُوها كما تَبْطُلُ صَدَقَةُ الذي.</p><p><span class="qpc-hafs">﴿رِئَآءَ ٱلنَّاسِ﴾</span>: ليراه الناسُ فَيمدَحُوه.</p><p><span class="qpc-hafs">﴿صَفۡوَانٍ﴾</span>: حجرٍ أملسَ.</p><p><span class="qpc-hafs">﴿وَابِلࣱ﴾</span>: مطرٌ غزيرٌ.</p><p><span class="qpc-hafs">﴿فَتَرَكَهُۥ صَلۡدࣰا﴾</span>: أملسَ يابِسًا لا شي ءَ عليه. وكذلك شأنُ المُرائِي لاتنفَعُه نفقتُه.</p><p><span class="qpc-hafs">﴿لَّا يَقۡدِرُونَ﴾</span>: لا ينتفعون.</p></div>"
  2,265,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَثۡبِيتࣰا﴾</span>: ويقينًا راسخًا بأنّ اللهَ سيَجْزيهم.</p><p><span class="qpc-hafs">﴿بِرَبۡوَةٍ﴾</span>: بأرضٍ عاليةٍ.</p><p><span class="qpc-hafs">﴿وَابِلࣱ﴾</span>: مطرٌ غزيرٌ.</p><p><span class="qpc-hafs">﴿أُكُلَهَا﴾</span>: ثَمَرَتَها.</p><p><span class="qpc-hafs">﴿فَطَلࣱّ﴾</span>: فالمطرُ الضعيفُ يَكْفيها.</p></div>"
  2,266,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَوَدُّ أَحَدُكُمۡ﴾</span>: نَزَلَتِ الآيةُ في رجلٍ غنيٍّ يعملُ بطاعةِ اللهِ، ثم يعملُ بالمعاصي.</p><p><span class="qpc-hafs">﴿إِعۡصَارࣱ﴾</span>: ريحٌ شديدةٌ فيها نارٌ مُحرقةٌ.</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: هكذا حالُ غيرِ المخلصينَ في نفقاتِهم.</p></div>"
  2,267,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن طَيِّبَـٰتِ مَا كَسَبۡتُمۡ﴾</span>: من جَيِّدِه، وحَلالِه.</p><p><span class="qpc-hafs">﴿وَلَا تَيَمَّمُواْ ٱلۡخَبِيثَ﴾</span>: ولا تَقْصِدُوا بالإنفاقِ الرَّديءَ من المالِ.</p><p><span class="qpc-hafs">﴿وَلَسۡتُم بِـَٔاخِذِيهِ إِلَّآ أَن تُغۡمِضُواْ فِيهِ﴾</span>: وإنْ أُعْطِيتُموه لم تأخُذُوه إلاإذا تَغاضَيْتُم عن رَداءتِه.</p></div>"
  2,268,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعِدُكُمُ ٱلۡفَقۡرَ﴾</span>: يُخَوِّفُكم، ويُغْرِيكم بالبُخْلِ.</p><p><span class="qpc-hafs">﴿بِٱلۡفَحۡشَآءِ﴾</span>: بالمعاصي.</p></div>"
  2,269,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: الإصابةَ في القولِ والفعلِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَلۡبَـٰبِ﴾</span>: العقولِ السليمةِ.</p></div>"
  2,270,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّذۡرࣲ﴾</span>: ما تُوجِبُه على نفسِك.</p><p><span class="qpc-hafs">﴿لِلظَّـٰلِمِينَ﴾</span>: المانعين لحقِّ اللهِ في المالِ.</p></div>"
  2,271,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن تُبۡدُواْ ٱلصَّدَقَـٰتِ﴾</span>: إنْ تُظْهِروها.</p><p><span class="qpc-hafs">﴿فَنِعِمَّا هِيَ﴾</span>: فنِعْمَ ما تَصَدَّقْتُم به.</p></div>"
  2,272,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلِأَنفُسِكُمۡ﴾</span>: يعودُ نَفْعُه عليكم.</p></div>"
  2,273,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُحۡصِرُواْ﴾</span>: لايَسْتطيعون السَّفرَ طَلَبًا للرِّزقِ، لانشغالهِم بالجهادِ.</p><p><span class="qpc-hafs">﴿ضَرۡبࣰا﴾</span>: سَفَرًا لطَلَبِ الرِّزْق.</p><p><span class="qpc-hafs">﴿بِسِيمَـٰهُمۡ﴾</span>: بعلاماتِهم، وآثارِ الحاجةِ فيهم.</p><p><span class="qpc-hafs">﴿إِلۡحَافࣰا﴾</span>: إلحاحًا إن اضْطُرُّوا للسؤالِ.</p></div>"
  2,274,""
  2,275,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَأۡكُلُونَ ٱلرِّبَوٰاْ﴾</span>: يتعامَلُون به. والرِّبا: ما يُؤَدِّيه المُقْتَرِضُ زيادةً على ما اقترضَ، مشروطةً في العَقْدِ.</p><p><span class="qpc-hafs">﴿لَا يَقُومُونَ﴾</span>: أي: في الآخرةِ حينَ يُبْعَثُون مِن قُبورِهم.</p><p><span class="qpc-hafs">﴿يَتَخَبَّطُهُ ٱلشَّيۡطَـٰنُ﴾</span>: يُوقِعُه في الاضطرابِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَسِّ﴾</span>: الجنونِ.</p><p><span class="qpc-hafs">﴿فَٱنتَهَىٰ﴾</span>: فارتدَعَ.</p><p><span class="qpc-hafs">﴿مَا سَلَفَ﴾</span>: ما مَضى قبلَ التحريمِ، فلا إثمَ عليه فيه.</p><p><span class="qpc-hafs">﴿وَمَنۡ عَادَ﴾</span>: أي: إلى الرِّبا.</p></div>"
  2,276,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَمۡحَقُ﴾</span>: يُذْهِبُ.</p><p><span class="qpc-hafs">﴿وَيُرۡبِي﴾</span>: يُنَمِّي، ويُضاعِفُ الأجْرَ.</p></div>"
  2,277,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا خَوۡفٌ عَلَيۡهِمۡ﴾</span>: في الآخرةِ.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على ما فاتَهم في الدُّنيا.</p></div>"
  2,278,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَذَرُواْ﴾</span>: اترُكُوا طَلبَ.</p><p><span class="qpc-hafs">﴿مَا بَقِيَ مِنَ ٱلرِّبَوٰٓاْ﴾</span>: ما بَقِيَ لكم من زيادةٍ على رؤوسِ أموالِكم.</p></div>"
  2,279,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأۡذَنُواْ﴾</span>: اعْلَمُوا ذلك، واستَيْقِنُوه.</p><p><span class="qpc-hafs">﴿لَا تَظۡلِمُونَ وَلَا تُظۡلَمُونَ﴾</span>: لا تَأْخُذُون باطلًا لا يَحِلُّ لكم، ولا تُنْقَصُون من أموالِكم.</p></div>"
  2,280,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُو عُسۡرَةࣲ﴾</span>: غيرُقادرٍ على السَّدادِ.</p><p><span class="qpc-hafs">﴿فَنَظِرَةٌ إِلَىٰ مَيۡسَرَةࣲ﴾</span>: فعليكم أن تُمْهِلُوه إلى أن يُيَسِّرَ اللهُ عليه الأداءَ.</p><p><span class="qpc-hafs">﴿وَأَن تَصَدَّقُواْ﴾</span>: أي: على المُعْسِرِ.</p></div>"
  2,281,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُوَفَّىٰ كُلُّ نَفۡسࣲ مَّا كَسَبَتۡ﴾</span>: تُجازى بما عَمِلَتْ.</p></div>"
  2,282,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَدَايَنتُم﴾</span>: تبايَعْتُمْ، وتَعاطَيْتُم بالدَّين.</p><p><span class="qpc-hafs">﴿أَجَلࣲ مُّسَمࣰّى﴾</span>: وقتٍ معلومٍ.</p><p><span class="qpc-hafs">﴿وَلۡيُمۡلِلِ ٱلَّذِي عَلَيۡهِ ٱلۡحَقُّ﴾</span>: يُمْلي المَدينُ ما عليه من الدَّين.</p><p><span class="qpc-hafs">﴿وَلَا يَبۡخَسۡ﴾</span>: ولا يُنْقِصْ.</p><p><span class="qpc-hafs">﴿سَفِيهًا﴾</span>: مُبَذِّرًا مُتلاعِبًا.</p><p><span class="qpc-hafs">﴿وَلِيُّهُۥ﴾</span>: القائمُ بأَمْرِه.</p><p><span class="qpc-hafs">﴿أَن تَضِلَّ إِحۡدَىٰهُمَا﴾</span>: مَخافةَ أنْ تَنْسى إحداهما.</p><p><span class="qpc-hafs">﴿وَلَا يَأۡبَ ٱلشُّهَدَآءُ إِذَا مَا دُعُواْ﴾</span>: لا يَمْتنعون من الإجابة إذا دُعُوا لإقامةِ الشهادةِ.</p><p><span class="qpc-hafs">﴿وَلَا تَسۡـَٔمُوٓاْ﴾</span>: ولا تَمَلُّوا من كتابةِ الدَّيْن.</p><p><span class="qpc-hafs">﴿إِلَىٰٓ أَجَلِهِۦ﴾</span>: إلى وقتِه المعلومِ.</p><p><span class="qpc-hafs">﴿أَقۡسَطُ﴾</span>: أعدَلُ.</p><p><span class="qpc-hafs">﴿وَأَقۡوَمُ﴾</span>: وأصْوَبُ.</p><p><span class="qpc-hafs">﴿وَأَدۡنَىٰٓ أَلَّا تَرۡتَابُوٓاْ﴾</span>: وأقربُ إلى نَفْيِ الشَّكِّ.</p><p><span class="qpc-hafs">﴿وَلَا يُضَآرَ﴾</span>: لا يجوزُ الإضرارُبهما.</p><p><span class="qpc-hafs">﴿فُسُوقُۢ﴾</span>: خروجٌ عن طاعةِ اللهِ.</p></div>"
  2,283,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱ﴾</span>: ادفَعُوا إلى صاحبِ الحقِّ شيئًا لضَمانِ حَقِّه.</p><p><span class="qpc-hafs">﴿فَإِنَّهُۥٓ ءَاثِمࣱ قَلۡبُهُۥ﴾</span>: فهو ذو قَلْبٍ فاجرٍ.</p></div>"
  2,284,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُبۡدُواْ﴾</span>: تُظْهِروا.</p></div>"
  2,285,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا نُفَرِّقُ﴾</span>: نُؤْمِنُ بجميعِ الرسُلِ.</p><p><span class="qpc-hafs">﴿غُفۡرَانَكَ﴾</span>: نَطْلُبُ مغفرتَك.</p></div>"
  2,286,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُسۡعَهَا﴾</span>: قَدْرَ ما تُطيقُ.</p><p><span class="qpc-hafs">﴿لَهَا مَا كَسَبَتۡ﴾</span>: أي: مَن فَعَلَ خيرًا نال أجْرَه.</p><p><span class="qpc-hafs">﴿وَعَلَيۡهَا مَا ٱكۡتَسَبَتۡ﴾</span>: أي: ومَن فَعَلَ شرًّا نال جَزاءَه.</p><p><span class="qpc-hafs">﴿إِصۡرࣰا﴾</span>: عَهْدًا لا نُطيقُ القيامَ به.</p><p><span class="qpc-hafs">﴿مَا لَا طَاقَةَ لَنَا بِهِۦ﴾</span>: ما لانَسْتطيعُه.</p><p><span class="qpc-hafs">﴿أَنتَ مَوۡلَىٰنَا﴾</span>: أنت وليُّنا، وناصِرُنا.</p></div>"
