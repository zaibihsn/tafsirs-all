quran[38]{c,v,t}:
  47,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَضَلَّ﴾</span>: أبْطلَ.</p></div>"
  47,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَفَّرَ﴾</span>: سَتَرَ.</p><p><span class="qpc-hafs">﴿بَالَهُمۡ﴾</span>: شَأْنَهُم.</p></div>"
  47,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَضۡرِبُ﴾</span>: يُبَيِّنُ.</p><p><span class="qpc-hafs">﴿أَمۡثَـٰلَهُمۡ﴾</span>: أحُوالَهُم الَّتي تُميِّزُهُم.</p></div>"
  47,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَقِيتُمُ﴾</span>: قاتَلْتُم.</p><p><span class="qpc-hafs">﴿فَضَرۡبَ ٱلرِّقَابِ﴾</span>: فاضْرِبُوا مِنهُم الأَعْناقَ.</p><p><span class="qpc-hafs">﴿أَثۡخَنتُمُوهُمۡ﴾</span>: أضْعَفْتُمُوهُم بِكَثْرةِ القَتْلِ وبالَغْتُم في قَتْلِهِم.</p><p><span class="qpc-hafs">﴿فَشُدُّواْ﴾</span>: فأحْكِمُوا.</p><p><span class="qpc-hafs">﴿ٱلۡوَثَاقَ﴾</span>: قَيْدَ الأسْرىَ.</p><p><span class="qpc-hafs">﴿مَنَّۢا﴾</span>: إطْلاقًا مِنَ الأَسْرِ.</p><p><span class="qpc-hafs">﴿فِدَآءً﴾</span>: مُبادَلةً بالمالِ أو بأسْرى مُسْلِمِينَ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ تَضَعَ ٱلۡحَرۡبُ أَوۡزَارَهَا﴾</span>: حَتّى يَنْتَهِيَ الُمحارِبُونَ عَنْ قِتالِكُم.</p></div>"
  47,5,""
  47,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَرَّفَهَا﴾</span>: بَيَّنها.</p></div>"
  47,7,""
  47,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَعۡسࣰا﴾</span>: فَخِزْيًا لَهُم وشَقاءً وبَلاءً.</p></div>"
  47,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَحۡبَطَ﴾</span>: فَأَبْطَلَ.</p></div>"
  47,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡثَـٰلُهَا﴾</span>: أمْثالُ عاقِبةِ تَكْذِيبِ الأُمَمِ السّابِقةِ مِنَ التَّدْمِيرِ والهَلاكِ.</p></div>"
  47,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَوۡلَىٰ﴾</span>: ولِيٌّ وناصِرٌ.</p></div>"
  47,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوࣰى﴾</span>: مَنزِلٌ.</p></div>"
  47,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَأَيِّن مِّن قَرۡيَةٍ﴾</span>: وكَثِيرٍ مِن أهْلِ قَرْيَةٍ.</p><p><span class="qpc-hafs">﴿مِّن قَرۡيَتِكَ﴾</span>: مِن أهْلِ قَرْيَتِكَ.</p></div>"
  47,14,""
  47,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّثَلُ﴾</span>: صِفَةُ.</p><p><span class="qpc-hafs">﴿ءَاسِنࣲ﴾</span>: مُتَغَيِّرٍ.</p><p><span class="qpc-hafs">﴿لَّذَّةࣲ﴾</span>: ذاتِ لَذّةٍ.</p><p><span class="qpc-hafs">﴿حَمِيمࣰا﴾</span>: تَناهى في شِدَّةِ حَرِّهِ.</p></div>"
  47,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَانِفًا﴾</span>: الآنَ، أي أوَّلَ وقْتٍ يَقْرُبُ مِنّا.</p><p><span class="qpc-hafs">﴿طَبَعَ﴾</span>: خَتَمَ.</p></div>"
  47,17,""
  47,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهَلۡ يَنظُرُونَ﴾</span>: فَما يَنْتَظِرُونَ.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأَةً.</p><p><span class="qpc-hafs">﴿أَشۡرَاطُهَا﴾</span>: عَلاماتُها.</p><p><span class="qpc-hafs">﴿ذِكۡرَىٰهُمۡ﴾</span>: تَذَكُّرُهُم ما ضَيَّعُوا مِن طاعَةِ اللهِ.</p></div>"
  47,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَقَلَّبَكُمۡ﴾</span>: تَصَرُّفَكُم في يَقَظَتِكُم نَهارًا.</p><p><span class="qpc-hafs">﴿وَمَثۡوَىٰكُمۡ﴾</span>: ومُسْتَقَرَّكُم في نَوْمِكُم لَيلًا.</p></div>"
  47,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿مُّحۡكَمَةࣱ﴾</span>: لا نَسْخَ فِيها.</p><p><span class="qpc-hafs">﴿مَّرَضࣱ﴾</span>: شَكٌّ في دينِ اللهِ ونِفاقٌ.</p><p><span class="qpc-hafs">﴿ٱلۡمَغۡشِيِّ عَلَيۡهِ﴾</span>: المُحْتضَرِ الذَّي في سَكْرةِ الموتِ لا يَطْرِفُ بَصَرُه.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡمَوۡتِ﴾</span>: خَوْفَ الموتِ.</p><p><span class="qpc-hafs">﴿فَأَوۡلَىٰ لَهُمۡ﴾</span>: ولِيَهُم شرٌّ فَلْيَحْذَرُوا.</p></div>"
  47,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَزَمَ ٱلۡأَمۡرُ﴾</span>: جَدَّ وعُزِمَ عَلَيهِ.</p></div>"
  47,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهَلۡ عَسَيۡتُمۡ﴾</span>: فَلَعَلَّكُم.</p><p><span class="qpc-hafs">﴿تَوَلَّيۡتُمۡ﴾</span>: أعْرَضْتُم.</p></div>"
  47,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَعَنَهُمُ﴾</span>: أبْعَدَهُم.</p></div>"
  47,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَدَبَّرُونَ﴾</span>: يتأمَّلُونَ.</p><p><span class="qpc-hafs">﴿أَمۡ﴾</span>: بَلْ.</p><p><span class="qpc-hafs">﴿عَلَىٰ قُلُوبٍ أَقۡفَالُهَآ﴾</span>: قُلُوبُهم مُقْفَلَةٌ فلا يَصِلُ إلَيها ذِكْرُ اللهِ.</p></div>"
  47,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَّلَ﴾</span>: زَيَّنَ.</p><p><span class="qpc-hafs">﴿وَأَمۡلَىٰ لَهُمۡ﴾</span>: أطالَ لَهُم أمَلَهُم.</p></div>"
  47,26,""
  47,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَيۡفَ﴾</span>: فَكَيفَ حالُهُم؟</p><p><span class="qpc-hafs">﴿تَوَفَّتۡهُمُ﴾</span>: قَبَضَتْ أرْواحَهُم.</p></div>"
  47,28,""
  47,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ حَسِبَ﴾</span>: بَلْ أظَنَّ؟</p><p><span class="qpc-hafs">﴿أَضۡغَـٰنَهُمۡ﴾</span>: أحْقادَهُم وعَداوَتَهُم.</p></div>"
  47,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسِيمَـٰهُمۡ﴾</span>: بِعَلاماتٍ ظاهِرَةٍ فِيهِم.</p><p><span class="qpc-hafs">﴿لَحۡنِ ٱلۡقَوۡلِ﴾</span>: فَحْوى الكلامِ ومَعْناهُ.</p></div>"
  47,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَنَبۡلُوَنَّكُمۡ﴾</span>: ولَنَخْتَبِرَنَّكُم.</p></div>"
  47,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَآقُّواْ﴾</span>: وخالَفُوا.</p><p><span class="qpc-hafs">﴿وَسَيُحۡبِطُ﴾</span>: وسَيُبْطِلُ.</p></div>"
  47,33,""
  47,34,""
  47,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّلۡمِ﴾</span>: الصُّلْحِ.</p><p><span class="qpc-hafs">﴿يَتِرَكُمۡ﴾</span>: يَنْقُصَكُم.</p></div>"
  47,36,""
  47,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَيُحۡفِكُمۡ﴾</span>: فيُلِحَّ عليكُم، ويُبالِغْ في طَلَبِها.</p></div>"
  47,38,""
