quran[69]{c,v,t}:
  29,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الٓمٓ﴾</span>: سَبَقَ الكَلامُ على مِثْلِه في أوَّلِ سورةِ البَقَرةِ.</p></div>"
  29,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُفۡتَنُونَ﴾</span>: لا يُبتَلَونَ.</p></div>"
  29,3,""
  29,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَسۡبِقُونَا﴾</span>: أن يُعْجِزُونا ويَفُوتُونا.</p><p><span class="qpc-hafs">﴿سَآءَ﴾</span>: بِئْسَ.</p></div>"
  29,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡجُواْ﴾</span>: يَتَوَقَّعُ ويَطْمَعُ.</p><p><span class="qpc-hafs">﴿أَجَلَ ٱللَّهِ﴾</span>: الوَقْتَ المُعَيَّنَ للبَعْثِ والجَزاءِ.</p></div>"
  29,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَـٰهَدَ﴾</span>: أي: الكُفّارَ ونَفْسَه الأَمّارةَ بالسُّوءِ.</p></div>"
  29,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنُكَفِّرَنَّ﴾</span>: لَنَمْحُوَنَّ.</p><p><span class="qpc-hafs">﴿وَلَنَجۡزِيَنَّهُمۡ﴾</span>: لَنُثِيبَنَّهم.</p></div>"
  29,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوَصَّيۡنَا﴾</span>: أي: أمَرْنا.</p><p><span class="qpc-hafs">﴿حُسۡنࣰا﴾</span>: أي: بَرًّا بِهِما وعَطْفًا عَلَيهِما.</p><p><span class="qpc-hafs">﴿جَـٰهَدَاكَ﴾</span>: ألْزَماكَ.</p></div>"
  29,9,""
  29,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةَ ٱلنَّاسِ﴾</span>: ابتلاءَهم وتَعْذِيبَهُم</p></div>"
  29,11,""
  29,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلۡنَحۡمِلۡ﴾</span>: ولْنَتَحَمَّلْ.</p></div>"
  29,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَثۡقَالَهُمۡ﴾</span>: أي: أثْقالَ ذُنُوبِهِم العَظِيمَةَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَخْتَلِقُونَ.</p></div>"
  29,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَبِثَ﴾</span>: مَكَثَ.</p><p><span class="qpc-hafs">﴿ٱلطُّوفَانُ﴾</span>: الماءُ الكَثِيرُ الذي غَمَرهُم مِن جَمِيعِ الجِهاتِ.</p></div>"
  29,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: عِبْرةً عَظِيمةً.</p></div>"
  29,16,""
  29,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡثَـٰنࣰا﴾</span>: أصْنامًا.</p><p><span class="qpc-hafs">﴿تَخۡلُقُونَ إِفۡكًا﴾</span>: تَفْتَرُونَ كَذِبًا.</p><p><span class="qpc-hafs">﴿فَٱبۡتَغُواْ﴾</span>: فالتَمِسُوا.</p></div>"
  29,18,""
  29,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَرَوۡاْ﴾</span>: أوَلم يَعْلَمُوا.</p><p><span class="qpc-hafs">﴿يُبۡدِئُ﴾</span>: يُنشِئُ ابتداءً.</p><p><span class="qpc-hafs">﴿يُعِيدُهُۥٓ﴾</span>: يُعِيدُ الخَلْقَ مِن بَعْدِ فَنائِهِ.</p></div>"
  29,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنشِئُ﴾</span>: يَخلُقُ.</p><p><span class="qpc-hafs">﴿ٱلنَّشۡأَةَ ٱلۡـَٔاخِرَةَ﴾</span>: أي: نَشْأَةً ثانيةً عِنْدَ البعْثِ.</p></div>"
  29,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُقۡلَبُونَ﴾</span>: تُرجَعُونَ.</p></div>"
  29,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُعۡجِزِينَ﴾</span>: بِسابِقِينَ اللهَ.</p></div>"
  29,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: أي: بالقرآنِ.</p><p><span class="qpc-hafs">﴿وَلِقَآئِهِۦٓ﴾</span>: أي: بالبعثِ بَعْدَ الموتِ.</p></div>"
  29,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَأَدِلَّةً واضِحَةً.</p></div>"
  29,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡثَـٰنࣰا﴾</span>: أصْنامًا، أي: اتَّخذتُموها آلِهَةً.</p><p><span class="qpc-hafs">﴿مَّوَدَّةَ بَيۡنِكُمۡ﴾</span>: أي: للتَّوادِّ والتَّواصُل بَيْنَكُم لاجْتِماعِكُم على عِبادَتِها.</p><p><span class="qpc-hafs">﴿يَكۡفُرُ بَعۡضُكُم بِبَعۡضࣲ﴾</span>: أي: يتبرَّأُ بعضُكُم مِن بَعْضٍ.</p><p><span class="qpc-hafs">﴿مَأۡوَىٰكُمُ﴾</span>: مَنزِلُكُم الذي تَأْوُونَ وتَرْجِعُونَ إليهِ.</p></div>"
  29,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـَٔامَنَ﴾</span>: أي: صَدَّقَ إبراهيمَ عَلَيهِ الصَّلاةُ والسَّلامُ.</p></div>"
  29,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡكِتَـٰبَ﴾</span>: أي: الكُتُبَ المنزَّلةَ، مِنَ التَّوراةِ والإنْجِيلِ والزَّبُورِ والقرآنِ.</p><p><span class="qpc-hafs">﴿أَجۡرَهُۥ﴾</span>: أي: ثَوابَه.</p></div>"
  29,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَـٰحِشَةَ﴾</span>: هي إتْيانُهم الرِّجالَ في أدْبارِهِم.</p></div>"
  29,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّبِيلَ﴾</span>: أي: الطَّريقَ على المارَّةِ والمسافِرِينَ، بأخْذِ أمْوالِهِم، أو قَتْلِهِم، أو إكْراهِهِم على الفاحِشَةِ.</p><p><span class="qpc-hafs">﴿فِي نَادِيكُمُ﴾</span>: في مَجْلِسِكُم.</p><p><span class="qpc-hafs">﴿ٱلۡمُنكَرَ﴾</span>: وهو كلُّ فِعْلٍ يُنكِره الشَّرْعُ أو العقْلُ كالسُّخْرِيَةِ مِنَ النّاسِ وحَذْفِ المارّةِ.</p></div>"
  29,30,""
  29,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُسُلُنَآ﴾</span>: أي: مِنَ الَملائِكَةِ.</p><p><span class="qpc-hafs">﴿هَـٰذِهِ ٱلۡقَرۡيَةِ﴾</span>: هي «سَدُومُ» قَرْيَةُ قَوْمِ لُوطٍ.</p></div>"
  29,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡغَـٰبِرِينَ﴾</span>: مِنَ الباقِينَ في العَذابِ والهَلاكِ.</p></div>"
  29,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِيٓءَ بِهِمۡ﴾</span>: اعْتَراهُ الغَمُّ بِمَجِيئِهِم خَوْفًا عَليهِم مِن قَومِهِ.</p><p><span class="qpc-hafs">﴿وَضَاقَ بِهِمۡذَرۡعࣰا﴾</span>: أي: عَجَزَ عَن تَدْبِيرِ خَلاصِهِم.</p></div>"
  29,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِجۡزࣰا﴾</span>: عَذابًا شَدِيدًا.</p></div>"
  29,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡهَآ﴾</span>: أي: مِن دِيارِ قَومِ لُوطٍ.</p><p><span class="qpc-hafs">﴿ءَايَةَۢ بَيِّنَةࣰ﴾</span>: أي: آثارًا واضِحةً.</p></div>"
  29,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱرۡجُواْ﴾</span>: تَوَقّعُوا، أوِ اخْشَوا.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡاْ﴾</span>: لا تُفْسدُوا أشدَّ الفَسادِ.</p></div>"
  29,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّجۡفَةُ﴾</span>: الزَّلْزَلةُ الشَّدِيدَةُ.</p><p><span class="qpc-hafs">﴿جَـٰثِمِينَ﴾</span>: مَيِّتِينَ بارِكِينَ على رُكَبِهِم.</p></div>"
  29,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَصَدَّهُمۡ﴾</span>: فصَرفَهُم.</p><p><span class="qpc-hafs">﴿ٱلسَّبِيلِ﴾</span>: أي: سَبِيلِ اللهِ المُسْتَقِيمِ.</p><p><span class="qpc-hafs">﴿مُسۡتَبۡصِرِينَ﴾</span>: أي: عُقَلاءَ ذَوِي بَصائِرَ مُتَمَكِّنِينَ مِن مَّعْرِفَةِ الحقِّ.</p></div>"
  29,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالأدِلَّةِ الواضِحةِ.</p><p><span class="qpc-hafs">﴿سَـٰبِقِينَ﴾</span>: فائِتِينَ مِن عَذابِ اللهِ.</p></div>"
  29,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاصِبࣰا﴾</span>: ريحًا عاصِفًا ترمِيهِم بالحَصْباءِ.</p><p><span class="qpc-hafs">﴿ٱلصَّيۡحَةُ﴾</span>: صَوْتٌ مِنَ السَّماءِ مُهلِكٌ مُرْجِفٌ.</p><p><span class="qpc-hafs">﴿خَسَفۡنَا بِهِ﴾</span>: جَعَلْنا الأرْضَ تبتَلِعُه وهو حَيٌّ.</p></div>"
  29,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡهَنَ ٱلۡبُيُوتِ﴾</span>: أضْعَفَها.</p></div>"
  29,42,""
  29,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَضۡرِبُهَا﴾</span>: أي: نُبَيِّنُها.</p><p><span class="qpc-hafs">﴿وَمَا يَعۡقِلُهَآ﴾</span>: وما يَفْهَمُها.</p></div>"
  29,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: لدَلالَةً عَظِيمةً.</p></div>"
  29,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفَحۡشَآءِ﴾</span>: أي: كُلِّ عَمَلٍ قَبِيحٍ.</p><p><span class="qpc-hafs">﴿وَٱلۡمُنكَرِ﴾</span>: وهو كلُّ فِعْلٍ يُنكِرُه الشَّرعُ أو العَقْلُ.</p></div>"
  29,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلَ ٱلۡكِتَـٰبِ﴾</span>: وهُمُ اليَهُودُ والنَّصارى.</p></div>"
  29,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يَجۡحَدُ﴾</span>: وما يُنكِرُ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: أي: بالقرآنِ وما فيه مِن دَلائِلَ وبَراهِينَ.</p><p><span class="qpc-hafs">﴿ٱلۡكَـٰفِرُونَ﴾</span>: أي: المُكابِرُونَ في كُفْرِهِم.</p></div>"
  29,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّٱرۡتَابَ﴾</span>: لَشَكَّ.</p><p><span class="qpc-hafs">﴿ٱلۡمُبۡطِلُونَ﴾</span>: هُمْ أهلُ الباطِلِ.</p></div>"
  29,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ ءَايَـٰتُۢ﴾</span>: أي: القرآنُ آياتٌ تُتْلى.</p><p><span class="qpc-hafs">﴿بَيِّنَـٰتࣱ﴾</span>: واضِحاتٌ.</p><p><span class="qpc-hafs">﴿أُوتُواْ﴾</span>: أُعْطُوا.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمُونَ﴾</span>: أي: المُعانِدُونَ الَّذينَ يَعْلَمُونَ الحقَّ ولا يَتَّبعُونَه.</p></div>"
  29,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتࣱ﴾</span>: أي: مُعْجِزاتٌ حِسِّيَّةٌ تُثْبِتُ صِدْقَهُ.</p><p><span class="qpc-hafs">﴿عِندَ ٱللَّهِ﴾</span>: أي: إنْ شاءَ أنْزَلَها، وإنْ شاءَ مَنَعَها.</p></div>"
  29,51,""
  29,52,""
  29,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجَلࣱ مُّسَمࣰّى﴾</span>: وقْتٌ مُعَيَّنٌ لا يَتَقَدَّمُ ولا يَتَأَخَّرُ.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فُجاءَةً.</p></div>"
  29,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمُحِيطَةُۢ﴾</span>: أي: سَتُحِيطُ بِهِم في الآخِرَةِ.</p></div>"
  29,55,""
  29,56,""
  29,57,""
  29,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنُبَوِّئَنَّهُم﴾</span>: لَنُنَزِّلَنَّهُم.</p><p><span class="qpc-hafs">﴿غُرَفࣰا﴾</span>: مَنازِلَ عالِيةً.</p></div>"
  29,59,""
  29,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَأَيِّن مِّن دَآبَّةࣲ﴾</span>: أي: كَثِيرٌ مِنَ الدَّوابِّ.</p><p><span class="qpc-hafs">﴿لَّا تَحۡمِلُ رِزۡقَهَا﴾</span>: أي: لا تُطِيقُ حَمْلَهُ ولا ادِّخارَهُ.</p></div>"
  29,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾</span>: فَكَيفَ يُصرَفُونَ عَن تَوحِيدِهِ؟</p></div>"
  29,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡسُطُ﴾</span>: يُوَسِّعُ.</p><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: يُضَيِّقُ.</p></div>"
  29,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ مَوۡتِهَا﴾</span>: مِن بَعْدِ قَحْطِ الأرْضِ وجَفافِها.</p></div>"
  29,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهِيَ ٱلۡحَيَوَانُ﴾</span>: لَهِيَ الحَياةُ الدّائِمَةُ الَّتي لا يُنَغِّصُها شَيءٌ.</p></div>"
  29,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡفُلۡكِ﴾</span>: في السُّفُن</p></div>"
  29,66,""
  29,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُتَخَطَّفُ ٱلنَّاسُ﴾</span>: أي: يُسْتَلَبُونَ قَتْلًا وأسْرًا.</p><p><span class="qpc-hafs">﴿أَفَبِٱلۡبَـٰطِلِ﴾</span>: أي: بالشِّركِ.</p></div>"
  29,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اخْتَلَقَ.</p><p><span class="qpc-hafs">﴿مَثۡوࣰى﴾</span>: مَسْكَنٌ.</p></div>"
  29,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَـٰهَدُواْ فِينَا﴾</span>: أي: الكُفّارَ والنَّفْسَ والشَّيطانَ.</p><p><span class="qpc-hafs">﴿لَنَهۡدِيَنَّهُمۡ سُبُلَنَا﴾</span>: لَنُرْشِدَنَّهُم طُرُقَنا.</p></div>"
