quran[50]{c,v,t}:
  77,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمُرۡسَلَـٰتِ﴾</span>: أُقسِمُ بالرِّياحِ حِينَ تَهُبُّ.</p><p><span class="qpc-hafs">﴿عُرۡفࣰا﴾</span>: مُتَتابِعةً يَتْبَعُ بَعْضُها بَعْضًا كعُرْفِ الفَرَسِ.</p></div>"
  77,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡعَـٰصِفَـٰتِ﴾</span>: وبالرِّياحِ الشَّدَيدَةِ الهُبُوبِ المُهْلِكَةِ.</p><p><span class="qpc-hafs">﴿عَصۡفࣰا﴾</span>: هُبُوبًا شَدِيدًا.</p></div>"
  77,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلنَّـٰشِرَ ٰ⁠تِ نَشۡرࣰا﴾</span>: وبالملائِكةِ المُوَكَّلِينَ بالسُّحُبِ يَسُوقُونَها حَيثُ شاء اللهُ.</p></div>"
  77,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡفَـٰرِقَـٰتِ فَرۡقࣰا﴾</span>: وبالملائِكةِ الَّتِي تَنْزِلُ مِن عِندِ اللهِ بما يَفْرُقُ بَينَ الحقِّ والباطِلِ والحَلالِ والحَرامِ.</p></div>"
  77,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡمُلۡقِيَـٰتِ ذِكۡرًا﴾</span>: وبالملائِكةِ الَّتِي تَتَلَقّى الوَحْيَ مِن عِنْدِ اللهِ وتُبَلّغُهُ رُسُلَهُ.</p></div>"
  77,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُذۡرًا أَوۡ نُذۡرًا﴾</span>: إعْذارًا وإنْذارًا مِنَ اللهِ إلى خَلْقِهِ.</p></div>"
  77,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوَ ٰ⁠قِعࣱ﴾</span>: لَنازِلٌ بِكُم لا مَحالَةَ.</p></div>"
  77,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طُمِسَتۡ﴾</span>: ذَهَبَ ضِياؤُها.</p></div>"
  77,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُرِجَتۡ﴾</span>: تَصَدَّعتْ.</p></div>"
  77,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُسِفَتۡ﴾</span>: تَطايَرَتْ وتَناثَرَتْ.</p></div>"
  77,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُقِّتَتۡ﴾</span>: عُيِّنَ لَهُم وقْتٌ لِلْفَصْلِ بَينَهُم وبَينَ الأُمَمِ.</p></div>"
  77,12,""
  77,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَوۡمِ ٱلۡفَصۡلِ﴾</span>: لِيومِ القضاءِ بين الخلائِقِ.</p></div>"
  77,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وما أعْلَمَكَ.</p></div>"
  77,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: هَلاكٌ عَظِيمٌ.</p></div>"
  77,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَوَّلِينَ﴾</span>: السابِقِينَ مِنَ الأُمَم الماضِيةِ.</p></div>"
  77,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ نُتۡبِعُهُمُ ٱلۡـَٔاخِرِينَ﴾</span>: ثم نُلحِقُ بِهِمُ المُتَأخِّرِينَ المُكَذِّبِينَ.</p></div>"
  77,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: مِثلَ ذلِك الإهْلاكِ الفَظِيعِ.</p><p><span class="qpc-hafs">﴿بِٱلۡمُجۡرِمِينَ﴾</span>: مِن كُفّارِ «مكَّةَ».</p></div>"
  77,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: هَلاكٌ وعَذابٌ شَدِيدٌ.</p></div>"
  77,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّآءࣲ مَّهِينࣲ﴾</span>: ماءٍ ضَعِيفٍ حَقِيرٍ وهو النطْفَةُ.</p></div>"
  77,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي قَرَارࣲ مَّكِينٍ﴾</span>: في مَكانٍ حَصِينٍ، وهو رَحِمُ المرأَةِ.</p></div>"
  77,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَىٰ قَدَرࣲ مَّعۡلُومࣲ﴾</span>: وقتٍ مَعْلُومٍ عِندَ اللهِ تَعالى.</p></div>"
  77,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَدَرۡنَا﴾</span>: فَقَدَرْنا على خَلْقِهِ وتَصْوِيِرهِ وإخْراجِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡقَـٰدِرُونَ﴾</span>: على الأشياءِ.</p></div>"
  77,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: هَلاكٌ وعَذابٌ شَدِيدٌ.</p></div>"
  77,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِفَاتًا﴾</span>: وِعاءً جامِعًا.</p></div>"
  77,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحۡيَآءࣰ﴾</span>: تَضُمُّ على ظَهْرِها أحياءً.</p><p><span class="qpc-hafs">﴿وَأَمۡوَ ٰ⁠تࣰا﴾</span>: و تَضُمُّ في بَطْنِها أمْواتًا.</p></div>"
  77,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿شَـٰمِخَـٰتࣲ﴾</span>: عالياتٍ.</p><p><span class="qpc-hafs">﴿فُرَاتࣰا﴾</span>: عَذْبًا سائِغًا.</p></div>"
  77,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: هلاكٌ ودمارٌ.</p></div>"
  77,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنطَلِقُوٓاْ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ﴾</span>: يُقال لِلْكافِرينَ يومَ القيامةِ: سيرُوا إلى عذابِ جَهَنَّم الَّذِي كُنْتُم بِهِ تُكَذِّبُونَ في الدُّنيا.</p></div>"
  77,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنطَلِقُوٓاْ إِلَىٰ ظِلࣲّ﴾</span>: سِيرُوا، فاسْتَظِلُّوا بِدُخانِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿شُعَبࣲ﴾</span>: قِطَعٍ.</p></div>"
  77,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا ظَلِيلࣲ﴾</span>: لا يُظِلُّ ذلك الظِّلُّ مِن حَرِّ ذَلِكَ اليومِ.</p><p><span class="qpc-hafs">﴿وَلَا يُغۡنِي مِنَ ٱللَّهَبِ﴾</span>: ولا يَدْفَعُ مِنَ حرِّ اللهبِ شيئًا.</p></div>"
  77,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهَا﴾</span>: إنّ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿بِشَرَرࣲ﴾</span>: اسْمِ جَمْعِ شَرَرَةٍ: وهي القِطعَةُ المشْتَعِلَةُ مِن دَقِيقِ الحَطَبِ يَدْفَعُها لَهَبُ النّارِ في الهواءِ.</p><p><span class="qpc-hafs">﴿كَٱلۡقَصۡرِ﴾</span>: كالبِناءِ العَظِيمِ العالِي.</p></div>"
  77,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جِمَـٰلَتࣱ﴾</span>: جمعُ جَمَلٍ، طائِفَةٌ مِنَ الإبِلِ الذُّكُورِ لا إناثَ فيها.</p><p><span class="qpc-hafs">﴿صُفۡرࣱ﴾</span>: سُودٌ يمِيلُ لونُها إلى الصُّفْرةِ.</p></div>"
  77,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: هَلاكٌ وعذابٌ شَدِيدٌ.</p></div>"
  77,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَنطِقُونَ﴾</span>: لا يَنْطِقُ فيه المُكَذِّبُونَ بِكَلامٍ يَنْفَعُهُم.</p></div>"
  77,36,""
  77,37,""
  77,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمُ ٱلۡفَصۡلِ﴾</span>: يومٌ يَفْصِلُ اللهُ فِيهِ بَينَ الخلائِقِ.</p><p><span class="qpc-hafs">﴿جَمَعۡنَـٰكُمۡ وَٱلۡأَوَّلِينَ﴾</span>: جَمَعْناكُم مَعَ الكُفّارِ مِنَ الأُمَمِ الماضِيةِ.</p></div>"
  77,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدࣱ﴾</span>: حِيلةٌ في الخلاصِ مِنَ العذابِ.</p><p><span class="qpc-hafs">﴿فَكِيدُونِ﴾</span>: فاحْتالُوا، وأنقذوا أنفُسَكُم مِن بَطْشِ اللهِ وانتِقامِهِ.</p></div>"
  77,40,""
  77,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعُيُونࣲ﴾</span>: وعُيُونِ الماءِ الجاريةِ.</p></div>"
  77,42,""
  77,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَنِيٓـَٔۢا﴾</span>: سائِغًا.</p></div>"
  77,44,""
  77,45,""
  77,46,""
  77,47,""
  77,48,""
  77,49,""
  77,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأَيِّ حَدِيثِۭ﴾</span>: فبأيِّ كِتابٍ وكَلامٍ.</p></div>"
