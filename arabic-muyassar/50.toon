quran[45]{c,v,t}:
  50,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قٓ﴾</span>: سَبَقَ الكلامُ على الحُروفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البقرةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَجِيدِ﴾</span>: ذي المجْدِ والشَّرَفِ.</p></div>"
  50,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَجِيبٌ﴾</span>: مُسْتَغْرَبٌ يُتَعَجَّبُ مِنهُ.</p></div>"
  50,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَجۡعُۢ﴾</span>: بَعْثٌ.</p></div>"
  50,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنقُصُ ٱلۡأَرۡضُ﴾</span>: تُفْنِي مِن أجْسامِهِم.</p><p><span class="qpc-hafs">﴿حَفِيظُۢ﴾</span>: مَحفُوظٌ.</p></div>"
  50,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرِيجٍ﴾</span>: مُخْتَلِطٍ مُضْطَرِبٍ.</p></div>"
  50,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُرُوجࣲ﴾</span>: شُقُوقٍ وُصُدُوعٍ.</p></div>"
  50,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَدَدۡنَـٰهَا﴾</span>: بَسَطْناها.</p><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿زَوۡجِۭ﴾</span>: نَوْعٍ وجِنْسٍ.</p><p><span class="qpc-hafs">﴿بَهِيجࣲ﴾</span>: حَسَنِ المنْظَر.</p></div>"
  50,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبۡصِرَةࣰ﴾</span>: تَجْعَلُ المرءَ مُبْصِرًا.</p><p><span class="qpc-hafs">﴿وَذِكۡرَىٰ﴾</span>: تُذَكِّرُ النّاسِي.</p><p><span class="qpc-hafs">﴿مُّنِيبࣲ﴾</span>: رَجّاعٍ إلى اللهِ.</p></div>"
  50,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبَـٰرَكࣰا﴾</span>: كَثِيرَ الخيَرِ والمنافِعِ.</p><p><span class="qpc-hafs">﴿وَحَبَّ ٱلۡحَصِيدِ﴾</span>: وحَبَّ الزَّرْعِ المحْصُودِ.</p></div>"
  50,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَاسِقَـٰتࣲ﴾</span>: مُرْتَفِعاتٍ.</p><p><span class="qpc-hafs">﴿طَلۡعࣱ﴾</span>: هُو أوَّلُ ما يَظْهَرُ مِن ثَمَرِ التَّمْرِ وهُو غِلافُ العُنْقُودِ.</p><p><span class="qpc-hafs">﴿نَّضِيدࣱ﴾</span>: مَنضُودٌ، مُصَفَّفٌ بعْضُهُ فَوْقَ بَعْضٍ.</p></div>"
  50,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّيۡتࣰا﴾</span>: أجْدَبَتْ وقَحَطَتْ.</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: كَما أحْيا اللهُ هَذِه الأَرْضَ الميتَةَ.</p><p><span class="qpc-hafs">﴿ٱلۡخُرُوجُ﴾</span>: خَرُوجُ النّاسِ يَومَ البعْثِ.</p></div>"
  50,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّسِّ﴾</span>: البِئْرِ.</p></div>"
  50,13,""
  50,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ ٱلۡأَيۡكَةِ﴾</span>: أصْحابُ الشَّجَرِ المُلْتَفِّ وهم قُوُم شُعَيبٍ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿وَقَوۡمُ تُبَّعࣲ﴾</span>: هُم سَبأٌ، وتُبَّعٌ هُوَ أحَدُ مُلُوكِ اليمَنِ.</p><p><span class="qpc-hafs">﴿فَحَقَّ﴾</span>: صَدَقَ وتَحَقَّقَ.</p><p><span class="qpc-hafs">﴿وَعِيدِ﴾</span>: إنذارِي بالعُقُوبةِ.</p></div>"
  50,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَعَيِينَا﴾</span>: أفَعَجَزْنا.</p><p><span class="qpc-hafs">﴿لَبۡسࣲ﴾</span>: اشْتِباهٍ وشَكٍّ.</p><p><span class="qpc-hafs">﴿خَلۡقࣲ جَدِيدࣲ﴾</span>: قِيامِ الخَلْقِ في البَعْثِ.</p></div>"
  50,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تُوَسۡوِسُ بِهِۦ﴾</span>: تُحَدِّث بِه.</p><p><span class="qpc-hafs">﴿حَبۡلِ ٱلۡوَرِيدِ﴾</span>: عِرْقِ العُنُقِ المُتَّصِلِ بالقلبِ.</p></div>"
  50,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَلَقَّى﴾</span>: يُسَجِّلُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُتَلَقِّيَانِ﴾</span>: المَلَكانِ المُوكَّلانِ بِكِتابَةِ أعْمالِ النّاسِ وأَقْوالِهِم.</p><p><span class="qpc-hafs">﴿عَنِ ٱلۡيَمِينِ﴾</span>: عَن يَمِينِ الإنْسانِ.</p><p><span class="qpc-hafs">﴿قَعِيدࣱ﴾</span>: مُقاعِدٌ، مِثْلُ جَلِيسٍ للمُجالِسِ.</p></div>"
  50,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَقِيبٌ﴾</span>: مَلَكٌ يَرْقُبُ قَوْلَهُ ويَكْتُبُهُ.</p><p><span class="qpc-hafs">﴿عَتِيدࣱ﴾</span>: حاضِرٌ مُعَدٌّ لِذَلِكَ.</p></div>"
  50,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَكۡرَةُ ٱلۡمَوۡتِ﴾</span>: شِدَّةُ غَمَراتِ الموتِ.</p><p><span class="qpc-hafs">﴿تَحِيدُ﴾</span>: تَفِرُّ وتَهْرُبُ.</p></div>"
  50,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الَّذِي يَنْفُخُ فِيهِ إسْرافِيلُ.</p><p><span class="qpc-hafs">﴿يَوۡمُ ٱلۡوَعِيدِ﴾</span>: أي الَّذِي تَوَعَّدَ اللهُ بِه الكُفّارَ.</p></div>"
  50,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَآئِقࣱ﴾</span>: مَلَكٌ يَسُوقُ الإنْسانَ إلى المَحْشَرِ.</p><p><span class="qpc-hafs">﴿وَشَهِيدࣱ﴾</span>: مَلَكٌ يَشْهَدُ عَلى النَّفْسِ بِما عَمِلَتْ.</p></div>"
  50,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَدِيدࣱ﴾</span>: قَوِيُّ الَّنفاذِ في المرئِي.</p></div>"
  50,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرِينُهُۥ﴾</span>: المَلَكُ الكاتِبُ الشَّهِيدُ عَلَيهِ.</p><p><span class="qpc-hafs">﴿عَتِيدٌ﴾</span>: مُهَيَّأٌ محفُوظٌ.</p></div>"
  50,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنِيدࣲ﴾</span>: مُعانِدٍ لِلْحَقِّ.</p></div>"
  50,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعۡتَدࣲ﴾</span>: ظالِمٍ مُتَجاوِزٍ لْلِحَقِّ.</p><p><span class="qpc-hafs">﴿مُّرِيبٍ﴾</span>: شاكٍّ.</p></div>"
  50,26,""
  50,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرِينُهُۥ﴾</span>: شَيْطانُه الَّذِي كانَ مُوَكَّلًا بِهِ في الدُّنيا.</p><p><span class="qpc-hafs">﴿مَآ أَطۡغَيۡتُهُۥ﴾</span>: ما أضْلَلْتُهُ.</p><p><span class="qpc-hafs">﴿ضَلَـٰلِۭ﴾</span>: طَرِيقٍ بَعِيدٍ عن سَبِيلِ الهُدى.</p></div>"
  50,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّمۡتُ إِلَيۡكُم بِٱلۡوَعِيدِ﴾</span>: أعْلَمْتُكُم ما يَنْتَظِرُ العاصِيَ مِن العُقُوبَةِ.</p></div>"
  50,29,""
  50,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّزِيدࣲ﴾</span>: زِيادةٍ في وارِدِيها.</p></div>"
  50,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُزۡلِفَتِ﴾</span>: وقُرِّبَتْ.</p><p><span class="qpc-hafs">﴿غَيۡرَ بَعِيدٍ﴾</span>: مَكانًا غَيرَ بَعِيدٍ مِنَ المُتَّقِينَ.</p></div>"
  50,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّابٍ﴾</span>: كَثِيرِ الرُّجُوعِ مِن ذُنُوبِهِ.</p><p><span class="qpc-hafs">﴿حَفِيظࣲ﴾</span>: حافظٍ لِكُلِّ عَمَلٍ صالِحٍ قَرَّبَهُ إلى ربِّهِ.</p></div>"
  50,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡغَيۡبِ﴾</span>: في حالِ غِيابهِ عَنْ أعْيُنِ النّاسِ.</p><p><span class="qpc-hafs">﴿مُّنِيبٍ﴾</span>: تائبٍ مِن ذُنُوبِهِ.</p></div>"
  50,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسَلَـٰمࣲ﴾</span>: وأَنْتُم سالِمُونَ.</p><p><span class="qpc-hafs">﴿يَوۡمُ ٱلۡخُلُودِ﴾</span>: هُوَ الَّذِي لا زَوالَ لَهُ ولا مَوْتَ.</p></div>"
  50,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَزِيدࣱ﴾</span>: النَّظَرُ إلى وجْهِ اللهِ الكريمِ.</p></div>"
  50,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قَرۡنٍ﴾</span>: مِن أُمَّةٍ.</p><p><span class="qpc-hafs">﴿بَطۡشࣰا﴾</span>: قُوَّةً وسَطْوَةً.</p><p><span class="qpc-hafs">﴿فَنَقَّبُواْ﴾</span>: فَطَوَّفُوا.</p><p><span class="qpc-hafs">﴿مَّحِيصٍ﴾</span>: مَهْرَبٍ مِن عَذابِ اللهِ.</p></div>"
  50,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَلۡبٌ﴾</span>: عَقْلٌ.</p><p><span class="qpc-hafs">﴿أَلۡقَى ٱلسَّمۡعَ﴾</span>: أصْغى السَّمْعَ، واسْتَمَعَ بِأُذُنَيْهِ.</p><p><span class="qpc-hafs">﴿شَهِيدࣱ﴾</span>: حاضِرٌ بِقَلْبِهِ.</p></div>"
  50,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا مَسَّنَا﴾</span>: وما أصابَنا.</p><p><span class="qpc-hafs">﴿لُّغُوبࣲ﴾</span>: تَعَبٍ.</p></div>"
  50,39,""
  50,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَدۡبَـٰرَ ٱلسُّجُودِ﴾</span>: عَقِبَ الصَّلَواتِ.</p></div>"
  50,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱسۡتَمِعۡ﴾</span>: أيُّها النَّبِيُّ لِما أُخْبِرُكَ بِهِ مِن أهْوالِ يَوْمِ القِيامَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنَادِ﴾</span>: هُوَ المَلَكُ المُوَكَّلُ بِنَفْخِ الصُّورِ.</p><p><span class="qpc-hafs">﴿مَّكَانࣲ قَرِيبࣲ﴾</span>: صَخْرَةِ بَيتِ المَقْدِسِ.</p></div>"
  50,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بِالصِّدْقِ.</p><p><span class="qpc-hafs">﴿يَوۡمُ ٱلۡخُرُوجِ﴾</span>: يومُ البَعْثِ مِنَ القُبُورِ.</p></div>"
  50,43,""
  50,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَشَقَّقُ﴾</span>: تَتَصَدَّعُ.</p><p><span class="qpc-hafs">﴿سِرَاعࣰا﴾</span>: مُسْرِعِينَ.</p></div>"
  50,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِجَبَّارࣲ﴾</span>: بِمُسَلَّطٍ عَلَيهِم تُجْبِرُهُم عَلى الإيمانِ.</p></div>"
