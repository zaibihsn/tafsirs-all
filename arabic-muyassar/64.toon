quran[18]{c,v,t}:
  64,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُسَبِّحُ﴾</span>: يُنَزِّهُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمۡدُ﴾</span>: الثَّناءُ الحسنُ الجميلُ.</p></div>"
  64,2,""
  64,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَوَّرَكُمۡ﴾</span>: خَلَقَكُم.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ يَومَ القِيامَةِ.</p></div>"
  64,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُسِرُّونَ﴾</span>: تُخْفُونَ.</p><p><span class="qpc-hafs">﴿تُعۡلِنُونَ﴾</span>: تُظْهِرُونَهُ.</p><p><span class="qpc-hafs">﴿بِذَاتِ ٱلصُّدُورِ﴾</span>: بما تُخْفِيهِ النَّفُوسُ.</p></div>"
  64,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَاقُواْ﴾</span>: حَلَّ بِهِم.</p><p><span class="qpc-hafs">﴿وَبَالَ﴾</span>: سُوءَ عاقِبَةِ.</p></div>"
  64,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: الآياتِ الواضِحاتِ والمُعْجِزاتِ الظّاهراتِ.</p><p><span class="qpc-hafs">﴿وَتَوَلَّواْ﴾</span>: أعْرَضُوا عَنِ الحَقِّ.</p><p><span class="qpc-hafs">﴿وَّٱسۡتَغۡنَى ٱللَّهُ﴾</span>: عَنْ عِبادَتِهِم وإيمانِهِم.</p><p><span class="qpc-hafs">﴿حَمِيدࣱ﴾</span>: مَحْمُودٌ في أقوالِهِ وأفعالِهِ وصِفاتِهِ.</p></div>"
  64,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُبۡعَثُواْ﴾</span>: يُخْرَجُوا مِن قُبُورِهِم.</p><p><span class="qpc-hafs">﴿يَسِيرࣱ﴾</span>: هِيِّنٌ.</p></div>"
  64,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلنُّورِ﴾</span>: واهْتَدُوا بالقرآنِ.</p></div>"
  64,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَوۡمِ ٱلۡجَمۡعِ﴾</span>: لِيومِ الحَشْرِ.</p><p><span class="qpc-hafs">﴿ٱلتَّغَابُنِ﴾</span>: الغَبْنُ والتَّفاوُتُ بَينَ الخَلْقِ.</p><p><span class="qpc-hafs">﴿يُكَفِّرۡ﴾</span>: يَمْحُ.</p><p><span class="qpc-hafs">﴿تَحۡتِهَا﴾</span>: تَحْتِ قُصُورِها وأَشْجارِها.</p></div>"
  64,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: وساءَ المَرْجِعُ الَّذِي صارُوا إلَيهِ، وهو جَهَنَّمُ.</p></div>"
  64,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّصِيبَةٍ﴾</span>: مَكْرُوهٍ.</p><p><span class="qpc-hafs">﴿بِإِذۡنِ ٱللَّهِ﴾</span>: بمشيئته.</p><p><span class="qpc-hafs">﴿يَهۡدِ﴾</span>: يُوَفِقْهُ اللهُ إلى مَرْضاتِهِ.</p></div>"
  64,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّيۡتُمۡ﴾</span>: أعْرَضْتُم عَن طاعَةِ اللهِ.</p></div>"
  64,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّهُ لَآ إِلَـٰهَ إِلَّا هُوَ﴾</span>: لا مَعْبُودَ بِحَقٍّ سِواهُ.</p><p><span class="qpc-hafs">﴿فَلۡيَتَوَكَّلِ﴾</span>: فَلْيَعْتَمِدوا في كُلِّ الأُمُورِ.</p></div>"
  64,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَدُوࣰّا لَّكُمۡ﴾</span>: أي: يَمْنَعُونَكُم مِنَ الإسْلامِ أو الهِجْرَةِ أو يكُونونَ سَبَبًا لِلْمَعاصِي.</p><p><span class="qpc-hafs">﴿وَإِن تَعۡفُواْ﴾</span>: تَتَجاوَزُوا عَن سَيِّئاتِهِم.</p><p><span class="qpc-hafs">﴿وَتَغۡفِرُواْ﴾</span>: وتَسْتُرُوها عَلَيهِم.</p></div>"
  64,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: اخِتبارٌ لَكُم وشُغْلٌ عَنِ الآخِرَةِ.</p><p><span class="qpc-hafs">﴿أَجۡرٌ﴾</span>: ثَوابٌ.</p></div>"
  64,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا ٱسۡتَطَعۡتُمۡ﴾</span>: أطَقْتُم.</p><p><span class="qpc-hafs">﴿خَيۡرࣰا﴾</span>: يَكُنْ خَيرًا.</p><p><span class="qpc-hafs">﴿وَمَن يُوقَ شُحَّ نَفۡسِهِۦ﴾</span>: ومَن سَلِمَ مِنَ البُخْلِ والحِرْصِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الظّافِرُونَ بِكُلِّ خَيرٍ.</p></div>"
  64,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُقۡرِضُواْ ٱللَّهَ﴾</span>: تُنْفِقُوا أمْوالَكُم في سَبِيلِ اللهِ بِإخْلاصٍ وطِيبِ نَفْسٍ.</p><p><span class="qpc-hafs">﴿شَكُورٌ﴾</span>: مُجازٍ على الطّاعةِ.</p><p><span class="qpc-hafs">﴿حَلِيمٌ﴾</span>: لا يَعْجَلُ بالعُقُوبَةِ عَلى مَن عَصاهُ.</p></div>"
  64,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَيۡبِ﴾</span>: ما غابَ.</p><p><span class="qpc-hafs">﴿ٱلشَّهَـٰدَةِ﴾</span>: ما لم يَغِبْ عَنِ الأَبْصارِ.</p></div>"
