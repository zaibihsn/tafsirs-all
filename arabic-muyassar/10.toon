quran[109]{c,v,t}:
  10,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَكِيمِ﴾</span>: المُحْكَمِ في لَفْظِه ومعناه.</p></div>"
  10,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَمَ صِدۡقٍ﴾</span>: أجرًا حسنًا؛ بما قَدَّموا من صالحِ الأعمالِ.</p></div>"
  10,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: علا وارتفعَ، استواءً يَليق بجَلالِه وعَظَمَتِه.</p><p><span class="qpc-hafs">﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾</span>: يَقْضِي أمورَ الدنيا والآخرةِ، ويُصَرِّفُها وحدَه على أكملِ الوجوهِ.</p><p><span class="qpc-hafs">﴿إِلَّا مِنۢ بَعۡدِ إِذۡنِهِۦ﴾</span>: إلا أنْ يأذنَ اللهُ له بالشفاعةِ.</p></div>"
  10,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرۡجِعُكُمۡ﴾</span>: مَعادُكم يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: ماءٍ شديدِ الحرارةِ.</p></div>"
  10,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِيَآءࣰ﴾</span>: ذاتَ ضياءٍ في النهار.</p><p><span class="qpc-hafs">﴿نُورࣰا﴾</span>: ذاتَ نورٍ في الليل.</p><p><span class="qpc-hafs">﴿وَقَدَّرَهُۥ مَنَازِلَ﴾</span>: وهَيَّأ للقَمَرِ منازلَ لا يتَعدّاها.</p><p><span class="qpc-hafs">﴿وَٱلۡحِسَابَ﴾</span>: ولتعلمُوا حسابَ الأشهرِ والأيامِ.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: أي: الَخلْقُ والتقديرُ.</p><p><span class="qpc-hafs">﴿إِلَّا بِٱلۡحَقِّ﴾</span>: إلا لحكمةٍ عظيمةٍ بالغةٍ.</p><p><span class="qpc-hafs">﴿يُفَصِّلُ﴾</span>: يُبَيِّنُ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الحُجَجَ والأدَّلةَ الدالَّةَ على عَظَمَتِه.</p></div>"
  10,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: إتيانِ أحدِهما بعد الآخَرِ.</p></div>"
  10,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ لِقَآءَنَا﴾</span>: لا يتوقَّعُون حسابَ الآخرةِ.</p><p><span class="qpc-hafs">﴿وَٱطۡمَأَنُّواْ بِهَا﴾</span>: رَكَنُوا إليها.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِنَا﴾</span>: الكونيةِ والشرعيةِ.</p><p><span class="qpc-hafs">﴿غَـٰفِلُونَ﴾</span>: ساهُون ومُعْرِضُون.</p></div>"
  10,8,""
  10,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِيهِمۡ﴾</span>: يُرْشِدُهم، ويُوَفِّقُهم إلى العملِ المُوصِلِ إلى الجنة.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهِمُ﴾</span>: مِن تحتِ غُرَفِهم ومنازلهِم.</p></div>"
  10,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَعۡوَىٰهُمۡ فِيهَا سُبۡحَـٰنَكَ ٱللَّهُمَّ﴾</span>: دعاؤُهم الذي يَدْعُون به في الجنةِ التسبيحُ والتنزيهُ لله.</p><p><span class="qpc-hafs">﴿وَتَحِيَّتُهُمۡ﴾</span>: من اللهِ وملائكتِه لهم، وتحيةُ بعضِهم بعضًا.</p><p><span class="qpc-hafs">﴿سَلَـٰمࣱ﴾</span>: دعاءٌ لهم بالسَّلامةِ من كلِّ مكروهٍ.</p></div>"
  10,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّرَّ﴾</span>: إجابةَ دعائِهم في الشرِّ.</p><p><span class="qpc-hafs">﴿ٱسۡتِعۡجَالَهُم بِٱلۡخَيۡرِ﴾</span>: تعجيلَ اللهِ لهم بالخيرِ.</p><p><span class="qpc-hafs">﴿لَقُضِيَ إِلَيۡهِمۡ أَجَلُهُمۡ﴾</span>: لأُهْلِكُوا جميعًا.</p><p><span class="qpc-hafs">﴿فَنَذَرُ﴾</span>: نَتْرُكُ.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنِهِمۡ﴾</span>: تجاوُزِهم الَحدَّ في إنكارِ البعثِ.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يتردَّدُون متحَيِّرين.</p></div>"
  10,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَسَّ﴾</span>: أصاب.</p><p><span class="qpc-hafs">﴿ٱلضُّرُّ﴾</span>: الشِّدَّةُ والمكروهُ.</p><p><span class="qpc-hafs">﴿لِجَنۢبِهِۦٓ﴾</span>: مُضْطجعًا على جَنْبِه.</p><p><span class="qpc-hafs">﴿مَرَّ كَأَن لَّمۡ يَدۡعُنَآ﴾</span>: استمرَّ على ما كان عليه قبل أن يُبْتلى.</p><p><span class="qpc-hafs">﴿لِلۡمُسۡرِفِينَ﴾</span>: المتجاوِزِين الَحدَّ في الكفرِ والمعاصي.</p></div>"
  10,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقُرُونَ﴾</span>: جَمْعُ قَرْن، وهم: القومُ المقتَرِنون في زمانٍ واحدٍ.</p><p><span class="qpc-hafs">﴿ظَلَمُواْ﴾</span>: أشرَكُوا وكَذَّبُوا.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: الدَّلالاتِ الواضحاتِ الدالَّةِ على صدقِهم.</p></div>"
  10,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَـٰٓئِفَ﴾</span>: جَمْعُ خليفة، وهو مَن يَخْلُفُ غيرَه.</p></div>"
  10,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيِّنَـٰتࣲ﴾</span>: واضحاتٍ.</p><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ لِقَآءَنَا﴾</span>: لا يتَوقَّعُون حسابَ الآخرةِ.</p><p><span class="qpc-hafs">﴿أَوۡ بَدِّلۡهُ﴾</span>: أو غَيِّرْ فيه بما ليس منه.</p></div>"
  10,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَدۡرَىٰكُم بِهِۦ﴾</span>: ولا أعْلَمَكم به على لساني.</p><p><span class="qpc-hafs">﴿عُمُرࣰا﴾</span>: زَمَنًا طويلًا، وهو أربعون سنةً.</p></div>"
  10,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اختَلَق.</p></div>"
  10,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُفَعَـٰٓؤُنَا﴾</span>: يَشْفَعُون لنا.</p><p><span class="qpc-hafs">﴿بِمَا لَا يَعۡلَمُ﴾</span>: وهو أنّ له شفيعًا عندَه بغيرِ إذنِه.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تنزيهًا له.</p></div>"
  10,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: على دينٍ واحدٍ، وهو الإسلامُ.</p><p><span class="qpc-hafs">﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾</span>: وهي تأخيرُه القضاءَ بينَهم إلى يومِ القيامةِ.</p><p><span class="qpc-hafs">﴿لَقُضِيَ بَيۡنَهُمۡ﴾</span>: عاجلًا في الدُّنيا.</p></div>"
  10,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَآ﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: علامةٌ حِسِّيةٌ مما اقترحُوه، كجَعْلِ الجبالِ ذَهَبًا.</p><p><span class="qpc-hafs">﴿إِنَّمَا ٱلۡغَيۡبُ لِلَّهِ﴾</span>: نُزولُ الآيةِ غَيْبٌ، واللهُ هو المختصُّ به.</p></div>"
  10,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّاسَ﴾</span>: المشركين.</p><p><span class="qpc-hafs">﴿رَحۡمَةࣰ﴾</span>: يُسْرًا ورَخاءً.</p><p><span class="qpc-hafs">﴿ضَرَّآءَ﴾</span>: شِدَّةً وبَلاءً.</p><p><span class="qpc-hafs">﴿مَّكۡرࣱ فِيٓ ءَايَاتِنَا﴾</span>: بالتكذيبِ والاستهزاءِ بها.</p><p><span class="qpc-hafs">﴿أَسۡرَعُ مَكۡرًا﴾</span>: أسرعُ استدراجًا وعقوبةً لكم.</p><p><span class="qpc-hafs">﴿رُسُلَنَا﴾</span>: الكَتَبةَ من الملائكةِ.</p></div>"
  10,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السُّفُنِ.</p><p><span class="qpc-hafs">﴿طَيِّبَةࣲ﴾</span>: سَهْلَةِ الهُبوبِ، موافِقَةٍ للغَرَضِ والمنفعةِ.</p><p><span class="qpc-hafs">﴿عَاصِفࣱ﴾</span>: شديدةُ الهبوبِ.</p><p><span class="qpc-hafs">﴿وَظَنُّوٓاْ﴾</span>: أيقَنُوا.</p><p><span class="qpc-hafs">﴿أُحِيطَ بِهِمۡ﴾</span>: وقَعَ عليهم الهلاكُ.</p><p><span class="qpc-hafs">﴿ٱلدِّينَ﴾</span>: الدُّعاءَ.</p></div>"
  10,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡغُونَ فِي ٱلۡأَرۡضِ﴾</span>: يُفْسِدُون فيها متجاوِزينَ الحَدَّ في المعاصي.</p><p><span class="qpc-hafs">﴿بَغۡيُكُمۡ عَلَىٰٓ أَنفُسِكُم﴾</span>: مَصِيرُ فسادِكم عائدٌ عليكم.</p><p><span class="qpc-hafs">﴿مَّتَـٰعَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: تتمتعون به مَتاعًا زائلًا.</p></div>"
  10,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثَلُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: حالُها في سُرْعَةِ انقضائِها وذَهابِ لَذّاتِها.</p><p><span class="qpc-hafs">﴿فَٱخۡتَلَطَ بِهِۦ نَبَاتُ ٱلۡأَرۡضِ﴾</span>: فَنَبتَ بماءِ المطر أنواعٌ من النباتِ، تشابَكَتْ واختلَطَ بعضُها ببعض.</p><p><span class="qpc-hafs">﴿أَخَذَتِ ٱلۡأَرۡضُ زُخۡرُفَهَا﴾</span>: ظَهَرَ حُسْنُها واستكمَلَت بهاءَها.</p><p><span class="qpc-hafs">﴿وَٱزَّيَّنَتۡ﴾</span>: وتَزَيَّنَتْ بأصنافِ النباتِ وأشكالِه وألوانِه.</p><p><span class="qpc-hafs">﴿وَظَنَّ﴾</span>: أيقنَ.</p><p><span class="qpc-hafs">﴿قَـٰدِرُونَ عَلَيۡهَآ﴾</span>: مُتَمَكِّنون مِن جَنْي ثمارِها والانتفاعِ بها.</p><p><span class="qpc-hafs">﴿أَمۡرُنَا﴾</span>: قضاؤُنا بهَلاكِ ما عليها من النباتِ والزينةِ.</p><p><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهَا حَصِيدࣰا﴾</span>: فجَعَلْنا زَرْعَها كالنَّباتِ المقطوعِ.</p><p><span class="qpc-hafs">﴿كَأَن لَّمۡ تَغۡنَ﴾</span>: كأن لم تَكُنِ الزروعُ قائمةً على ظَهْرِ الأرض.</p><p><span class="qpc-hafs">﴿بِٱلۡأَمۡسِ﴾</span>: في الماضي القريب.</p><p><span class="qpc-hafs">﴿نُفَصِّلُ﴾</span>: نُبَيِّنُ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الحُجَجَ والأدلَّةَ الواضحةَ.</p></div>"
  10,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَارِ ٱلسَّلَـٰمِ﴾</span>: الجنةِ.</p><p><span class="qpc-hafs">﴿وَيَهۡدِي﴾</span>: وُيَوفِّقُ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: الطريقِ الواضحِ، وهو دينُ الإسلامِ.</p></div>"
  10,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الجنةُ.</p><p><span class="qpc-hafs">﴿وَزِيَادَةࣱ﴾</span>: النظرُ إلى وجهِ اللهِ الكريمِ في الجنةِ.</p><p><span class="qpc-hafs">﴿وَلَا يَرۡهَقُ﴾</span>: لا يَغْشى ولا يعلوُ.</p><p><span class="qpc-hafs">﴿قَتَرࣱ﴾</span>: غبارٌ فيه سَوادٌ.</p><p><span class="qpc-hafs">﴿ذِلَّةٌ﴾</span>: هَوانٌ وكآبةٌ.</p></div>"
  10,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَسَبُواْ﴾</span>: عَمِلُوا.</p><p><span class="qpc-hafs">﴿مِّنَ ٱللَّهِ﴾</span>: من عذابِه.</p><p><span class="qpc-hafs">﴿مِنۡ عَاصِمࣲ﴾</span>: من مانعٍ.</p><p><span class="qpc-hafs">﴿قِطَعࣰا﴾</span>: أجزاءً.</p></div>"
  10,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِطَعࣰا﴾</span>: الزَمُوا مكانَكم في موقفِ الحسابِ.</p><p><span class="qpc-hafs">﴿أَنتُمۡ وَشُرَكَآؤُكُمۡ﴾</span>: أنتم وآلهتكُم، حتى تَرَوْا ما يُفْعَلُ بكم.</p><p><span class="qpc-hafs">﴿فَزَيَّلۡنَا بَيۡنَهُمۡ﴾</span>: فرَّقْنا بينَ المشركين ومَعْبُوديهم.</p></div>"
  10,29,""
  10,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبۡلُواْ﴾</span>: تَخْتَبِرُ وتَعْلَمُ.</p><p><span class="qpc-hafs">﴿مَّآ أَسۡلَفَتۡ﴾</span>: ما قَدَّمَتْ مِن عَمَلٍ.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: ذَهَبَ وبَطَلَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَعْبُدون مِن آلهةٍ مزعومةٍ.</p></div>"
  10,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾</span>: يَقْضي أمورَ الدُّنيا والآخرةِ ويُصَرِّفُها وحدَه على أكملِ الوجوهِ.</p></div>"
  10,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُصۡرَفُونَ﴾</span>: فكيف تُصْرَفون عن عبادةِ اللهِ إلى عبادةِ غيره؟</p></div>"
  10,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّتۡ﴾</span>: وجَبَتْ.</p><p><span class="qpc-hafs">﴿كَلِمَتُ رَبِّكَ﴾</span>: حُكْمُه وقضاؤُه.</p><p><span class="qpc-hafs">﴿فَسَقُوٓاْ﴾</span>: خرجُوا عن طاعةِ اللهِ وكفرُوا به.</p></div>"
  10,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾</span>: فكيف تُصْرَفون عن الحقِّ إلى الباطلِ؟</p></div>"
  10,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِيٓ إِلَى ٱلۡحَقِّ﴾</span>: يُرْشِدُ إليه.</p><p><span class="qpc-hafs">﴿يَهۡدِي لِلۡحَقِّ﴾</span>: يُرْشِدُ ويُوَفِّقُ إليه.</p><p><span class="qpc-hafs">﴿لَّا يَهِدِّيٓ﴾</span>: لا يهتدي بنفسه.</p></div>"
  10,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَنًّا﴾</span>: تَخْمينًا وتوهُّمًا.</p></div>"
  10,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَصۡدِيقَ ٱلَّذِي بَيۡنَ يَدَيۡهِ﴾</span>: مُصَدِّقًا للكتبِ التي أنزلها اللهُ على أنبيائِه.</p><p><span class="qpc-hafs">﴿وَتَفۡصِيلَ ٱلۡكِتَـٰبِ﴾</span>: ومُفَصِّلًا لما شَرَعَه اللهُ فيه من العقائِد والأحكامِ.</p></div>"
  10,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱدۡعُواْ مَنِ ٱسۡتَطَعۡتُم﴾</span>: واستَعِينُوا بمَن أمْكَنَكم الاستعانةُ به.</p></div>"
  10,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَّبُواْ﴾</span>: سارَعُوا إلى التكذيبِ.</p><p><span class="qpc-hafs">﴿بِمَا لَمۡ يُحِيطُواْ بِعِلۡمِهِۦ﴾</span>: أي: بالقرآنِ، قبل أن يُدْرِكُوا ما اشتملَ عليه.</p><p><span class="qpc-hafs">﴿وَلَمَّا يَأۡتِهِمۡ تَأۡوِيلُهُۥ﴾</span>: ولَمّا يأتِهم عاقبةُ ما تَوَعَّدَهم اللهُ به في القرآنِ.</p></div>"
  10,40,""
  10,41,""
  10,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّمَّ﴾</span>: الذين لا ينتفِعُون بسماعِ القرآنِ، ولا يَقْبَلُون ما فيه.</p></div>"
  10,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُ إِلَيۡكَ﴾</span>: يعايِنُ دلائلَ نبوَّتِك الصادقةِ، فلا ينتفعُ بها.</p></div>"
  10,44,""
  10,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّمۡ يَلۡبَثُوٓاْ﴾</span>: لم يَمْكُثوا في الدنيا.</p><p><span class="qpc-hafs">﴿يَتَعَارَفُونَ بَيۡنَهُمۡ﴾</span>: يَعْرِفُ بعضُهم بعضًا كحالِهم في الدنيا.</p></div>"
  10,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡ نَتَوَفَّيَنَّكَ﴾</span>: أي: قبلَ تعذيبِهم.</p><p><span class="qpc-hafs">﴿شَهِيدٌ عَلَىٰ مَا يَفۡعَلُونَ﴾</span>: مُطَّلِعٌ على أعمالِهم، ومُجازِيهم عليها.</p></div>"
  10,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَ رَسُولُهُمۡ﴾</span>: في الدنيا، وبَلَّغَهم فكذَّبُوه، أو في الآخرةِ للشهادةِ عليهم.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p></div>"
  10,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا ٱلۡوَعۡدُ﴾</span>: قيامُ الساعةِ والعذابُ الذي تُخَوِّفنا به.</p></div>"
  10,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجَلٌ﴾</span>: مدةٌ معلومةٌ لانقضاءِ آجالِهم.</p><p><span class="qpc-hafs">﴿فَلَا يَسۡتَـٔۡخِرُونَ﴾</span>: لا يتأخَّرُون عنه.</p><p><span class="qpc-hafs">﴿وَلَا يَسۡتَقۡدِمُونَ﴾</span>: لا يتقدَّمُون عليه.</p></div>"
  10,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُوني.</p><p><span class="qpc-hafs">﴿بَيَـٰتًا﴾</span>: ليلًا.</p><p><span class="qpc-hafs">﴿مَّاذَا يَسۡتَعۡجِلُ مِنۡهُ﴾</span>: أيُّ شيءٍ من أنواعِ العذابِ يَسْتعجلُونه؟</p></div>"
  10,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَآلۡـَٔـٰنَ﴾</span>: أتؤمنون بالعذابِ حين لا ينفعُكم الإيمانُ؟</p></div>"
  10,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَذَابَ ٱلۡخُلۡدِ﴾</span>: الدائمَ الذي لا ينقطعُ، وهوجَهَنَّمُ.</p></div>"
  10,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسۡتَنۢبِـُٔونَكَ﴾</span>: ويستخبِرُك المشركون عن العذابِ.</p><p><span class="qpc-hafs">﴿إِي وَرَبِّيٓ﴾</span>: نَعَمْ وربِّي.</p><p><span class="qpc-hafs">﴿وَمَآ أَنتُم بِمُعۡجِزِينَ﴾</span>: بفائتين من عذابِ اللهِ بالهَرَبِ.</p></div>"
  10,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَلَمَتۡ﴾</span>: أشرَكَتْ وكَفَرَتْ.</p><p><span class="qpc-hafs">﴿لَٱفۡتَدَتۡ بِهِۦ﴾</span>: لَجَعَلَتْه فِدْيَةً لها من عذابِ الآخرةِ.</p><p><span class="qpc-hafs">﴿وَأَسَرُّواْ ٱلنَّدَامَةَ﴾</span>: أخْفَوا الغَمَّ والحَسْرَةَ.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p></div>"
  10,55,""
  10,56,""
  10,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّوۡعِظَةࣱ﴾</span>: هو القرآنُ العظيمُ.</p></div>"
  10,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِفَضۡلِ ٱللَّهِ﴾</span>: الذي تَفَضَّلَ به عليكم، وهو الإسلامُ والإيمانُ.</p><p><span class="qpc-hafs">﴿وَبِرَحۡمَتِهِۦ﴾</span>: التي رَحِمَكم بها، وهي إنزالُ القرآنِ.</p></div>"
  10,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُم﴾</span>: أخْبِروني.</p><p><span class="qpc-hafs">﴿مَّآ أَنزَلَ ٱللَّهُ﴾</span>: ما خَلَقه اللهُ لأجلِ نَفْعِكم.</p><p><span class="qpc-hafs">﴿أَمۡ عَلَى ٱللَّهِ تَفۡتَرُونَ﴾</span>: تَكْذِبُون بنسبةِ التحريمِ والتحليلِ إليه.</p></div>"
  10,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا ظَنُّ ٱلَّذِينَ يَفۡتَرُونَ عَلَى ٱللَّهِ ٱلۡكَذِبَ﴾</span>: أيُّ شيءٍ ظَنُّهم، وما يُصْنَعُ بهم فيه؟</p></div>"
  10,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي شَأۡنࣲ﴾</span>: في أمْرٍمن أمورِك.</p><p><span class="qpc-hafs">﴿شُهُودًا﴾</span>: رُقَباءَ مُطَّلِعِين عليه.</p><p><span class="qpc-hafs">﴿تُفِيضُونَ فِيهِ﴾</span>: تَشْرَعُون فيه وتَعْمَلُونه.</p><p><span class="qpc-hafs">﴿وَمَا يَعۡزُبُ﴾</span>: ما يَغِيبُ ولا يَبْعُدُ.</p><p><span class="qpc-hafs">﴿مِّثۡقَالِ ذَرَّةࣲ﴾</span>: وزنِ أصغرِ نملةٍ.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣲ مُّبِينٍ﴾</span>: واضحٍ، وهو اللَّوحُ المحفوظُ.</p></div>"
  10,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على ما فاتهم من حُظوظِ الدُّنيا.</p></div>"
  10,63,""
  10,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبُشۡرَىٰ﴾</span>: البِشارةُ بما يَسُرُّهم.</p><p><span class="qpc-hafs">﴿لَا تَبۡدِيلَ لِكَلِمَـٰتِ ٱللَّهِ﴾</span>: لا إخلافَ لوَعْدِ اللهِ.</p></div>"
  10,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعِزَّةَ لِلَّهِ جَمِيعًا﴾</span>: الغَلَبَةَ، والقوةَ والقدرةَ التامةَ له تعالى.</p></div>"
  10,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّنَّ﴾</span>: الشَّكَّ.</p><p><span class="qpc-hafs">﴿يَخۡرُصُونَ﴾</span>: يَكْذِبُون فيما يَنْسُبونَه إلى اللهِ.</p></div>"
  10,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُبۡصِرًا﴾</span>: مُضِيئًا يُبْصِرُ فيه الناسُ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: دَلالاتٍ وحججًا.</p></div>"
  10,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تَنْزِيهًا له عَمّا نَسَبُوه إليه.</p><p><span class="qpc-hafs">﴿إِنۡ عِندَكُم﴾</span>: ليس لَدَيكم.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنِۭ﴾</span>: حُجَّةٍ وبُرهانٍ.</p></div>"
  10,69,""
  10,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرۡجِعُهُمۡ﴾</span>: مَصِيرُهم.</p></div>"
  10,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَبُرَ عَلَيۡكُم﴾</span>: عَظُمَ وثَقُلَ عليكم.</p><p><span class="qpc-hafs">﴿مَّقَامِي﴾</span>: إقامتي بينكم.</p><p><span class="qpc-hafs">﴿وَتَذۡكِيرِي﴾</span>: ووَعْظِي إياكم.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: بحُجَجِه وبَراهينِه.</p><p><span class="qpc-hafs">﴿فَعَلَى ٱللَّهِ تَوَكَّلۡتُ﴾</span>: اعتمَدْتُ وفوَّضْتُ أمري إليه.</p><p><span class="qpc-hafs">﴿فَأَجۡمِعُوٓاْ أَمۡرَكُمۡ﴾</span>: اكتُمُوه واعزِمُوا عليه.</p><p><span class="qpc-hafs">﴿وَشُرَكَآءَكُمۡ﴾</span>: وادْعُوا آلهتَكم؛ لنُصْرَتِكم.</p><p><span class="qpc-hafs">﴿غُمَّةࣰ﴾</span>: مُسْتَتِرًا خَفِيًّا.</p><p><span class="qpc-hafs">﴿ٱقۡضُوٓاْ إِلَيَّ﴾</span>: افعَلُوا ما تُريدون بي من العقوبةِ.</p><p><span class="qpc-hafs">﴿وَلَا تُنظِرُونِ﴾</span>: ولا تُمهِلُوني.</p></div>"
  10,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّيۡتُمۡ﴾</span>: أعْرَضْتُم عن الإيمان.</p></div>"
  10,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السَّفينةِ.</p><p><span class="qpc-hafs">﴿خَلَـٰٓئِفَ﴾</span>: أي: يَخْلُفُون الذين هَلَكُوا بالغَرَقِ.</p></div>"
  10,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالمعجزاتِ الدالَّةِ على صِدْقِهم.</p><p><span class="qpc-hafs">﴿نَطۡبَعُ﴾</span>: نَخْتِمُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُعۡتَدِينَ﴾</span>: المتجاوِزين حُدودَ اللهِ.</p></div>"
  10,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَلَإِيْهِۦ﴾</span>: أشرافِ قومِه.</p></div>"
  10,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: المعجزاتُ التي أظْهرها موسى عليه السلام.</p></div>"
  10,77,""
  10,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَلۡفِتَنَا﴾</span>: لتَصْرِفَنا.</p><p><span class="qpc-hafs">﴿ٱلۡكِبۡرِيَآءُ﴾</span>: المُلْكُ والسُّلْطانُ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرضِ مصرَ.</p></div>"
  10,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلِيمࣲ﴾</span>: مُتْقِنٍ للسِّحْرِ.</p></div>"
  10,80,""
  10,81,""
  10,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُحِقُّ ٱللَّهُ ٱلۡحَقَّ﴾</span>: يُثَبِّتُه ويُظْهِره.</p><p><span class="qpc-hafs">﴿بِكَلِمَـٰتِهِۦ﴾</span>: بقضائِه وأمْرِه.</p></div>"
  10,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡتِنَهُمۡ﴾</span>: يُعَذِّبَهم؛ ليَحْمِلَهم على الرجوعِ عن الإيمان.</p><p><span class="qpc-hafs">﴿لَعَالࣲ﴾</span>: متكبِّرٌ متطاولٌ.</p><p><span class="qpc-hafs">﴿ٱلۡمُسۡرِفِينَ﴾</span>: المتجاوِزِين الحَدَّ في الكفرِ والفسادِ.</p></div>"
  10,84,""
  10,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: موضعَ ابتلاءٍ واختبارٍ.</p></div>"
  10,86,""
  10,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَوَّءَا﴾</span>: اتَّخِذا.</p><p><span class="qpc-hafs">﴿وَٱجۡعَلُواْ بُيُوتَكُمۡ﴾</span>: أي: اجعَلُوها مساجدَ تُصَلُّون فيها عند الخوفِ.</p></div>"
  10,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱطۡمِسۡ عَلَىٰٓ أَمۡوَ ٰ⁠لِهِمۡ﴾</span>: أهْلِكْها وأتْلِفْها.</p><p><span class="qpc-hafs">﴿وَٱشۡدُدۡ عَلَىٰ قُلُوبِهِمۡ﴾</span>: اخْتِمْ عليها.</p></div>"
  10,89,""
  10,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَـٰوَزۡنَا بِبَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ ٱلۡبَحۡرَ﴾</span>: قَطَعْناه بهم حتى تَرَكُوه وراءَهم.</p><p><span class="qpc-hafs">﴿فَأَتۡبَعَهُمۡ﴾</span>: لَحِقَهم.</p><p><span class="qpc-hafs">﴿بَغۡيࣰا وَعَدۡوًا﴾</span>: ظُلْمًا واعتداءً.</p><p><span class="qpc-hafs">﴿أَدۡرَكَهُ ٱلۡغَرَقُ﴾</span>: أحاطَ به، وقَرُبَ هَلاكُه.</p></div>"
  10,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَآلۡـَٔـٰنَ﴾</span>: آلآن تُؤْمِنُ حين نَزَلَ بك الموتُ؟</p></div>"
  10,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُنَجِّيكَ﴾</span>: نَجْعَلُكَ على مُرْتفَعٍ من الأرضِ.</p><p><span class="qpc-hafs">﴿بِبَدَنِكَ﴾</span>: بجَسَدِك الذي لا رُوحَ فيه.</p><p><span class="qpc-hafs">﴿خَلۡفَكَ﴾</span>: بَعْدَك من الناسِ.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: عِبرةً يعتبرون بك.</p></div>"
  10,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَوَّأۡنَا﴾</span>: أنْزَلْنا وأسْكَنّا.</p><p><span class="qpc-hafs">﴿مُبَوَّأَ صِدۡقࣲ﴾</span>: مَنزلًا كريمًا مختارًا.</p><p><span class="qpc-hafs">﴿يَقۡضِي﴾</span>: يَحْكُمُ.</p></div>"
  10,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التوراةَ والإنجيلَ.</p><p><span class="qpc-hafs">﴿ٱلۡمُمۡتَرِينَ﴾</span>: الشاكِّين.</p></div>"
  10,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: بحُجَجِه وأدِلَّتِه.</p></div>"
  10,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّتۡ﴾</span>: وجَبَتْ.</p></div>"
  10,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةٍ﴾</span>: عِبْرةٍ وموعظةٍ.</p></div>"
  10,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَا﴾</span>: فهَلّا.</p><p><span class="qpc-hafs">﴿ٱلۡخِزۡيِ﴾</span>: الذُّلِّ والهَوانِ.</p><p><span class="qpc-hafs">﴿إِلَىٰ حِينࣲ﴾</span>: إلى وقتِ انقضاءِ آجالِهم.</p></div>"
  10,99,""
  10,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرِّجۡسَ﴾</span>: عذابَ اللهِ وغَضَبَه.</p></div>"
  10,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنظُرُواْ﴾</span>: تَفَكَّرُوا واعتَبِرُوا.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتُ﴾</span>: الدلائلُ والعِبَرُ.</p><p><span class="qpc-hafs">﴿وَٱلنُّذُرُ﴾</span>: جَمْعُ نَذِير، وهم: الرسُلُ.</p></div>"
  10,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِثۡلَ أَيَّامِ ٱلَّذِينَ خَلَوۡاْ مِن قَبۡلِهِمۡ﴾</span>: مثلَ ما حَلَّ بالأممِ السابقةِ من العذابِ.</p></div>"
  10,103,""
  10,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَفَّىٰكُمۡ﴾</span>: يُمِيتُكم.</p></div>"
  10,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَقِمۡ وَجۡهَكَ لِلدِّينِ﴾</span>: استقِمْ على دينِ الإسلامِ مُخْلِصًا لله في عبادتِك وعَمَلِك.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن الأديانِ الباطلةِ.</p></div>"
  10,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: المُشْركين.</p></div>"
  10,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِضُرࣲّ﴾</span>: بشدَّةٍ أو بلاءٍ.</p><p><span class="qpc-hafs">﴿بِخَيۡرࣲ﴾</span>: برَخاءٍ أو نِعْمةٍ.</p></div>"
  10,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: القرآنُ العظيمُ.</p><p><span class="qpc-hafs">﴿بِوَكِيلࣲ﴾</span>: بحَفيظٍ أحفَظُ أمورَكم.</p></div>"
  10,109,""
