tafsir[96]{c,v,t}:
  56,1,""
  56,2,"56:1"
  56,3,"خافضة رافعة:1- برفعهما، وهى قراءة الجمهور.وقرئا:2- بنصبهما، وهى قراءة زيد بن على، والحسن، وعيسى، وأبى حيوة، وابن أبى عبلة، وابن مقسم، والزعفراني، واليزيدي."
  56,4,""
  56,5,"56:4"
  56,6,"56:4"
  56,7,"56:4"
  56,8,"56:4"
  56,9,"56:4"
  56,10,"56:4"
  56,11,"56:4"
  56,12,"جنات:1- جمعا، وهى قراءة الجمهور.وقرئ:2- جنة، مفردا، وهى قراءة طلحة."
  56,13,""
  56,14,"56:13"
  56,15,"سرر:1- بضم الراء، وهى قراءة الجمهور.وقرئ:2- بفتحها، وهى لغة لبعض بنى تميم وكلب، وهى قراءة زيد بن على، وأبى السمال."
  56,16,""
  56,17,"56:16"
  56,18,"56:16"
  56,19,"يصدعون:1- بضم الياء وخفة الصاد، وهى قراءة الجمهور.وقرئ:2- بفتح الياء وشد الصاد، أصله: يتصدعون، وهى قراءة مجاهد.ينزفون:1- مبنيا للمفعول، وهى قراءة الجمهور.وقرئ:2- بفتح الياء وكسر الزاى، وهى قراءة ابن أبى إسحاق.3- بضم الياء وكسر الزاى، وهى قراءة ابن أبى إسحاق أيضا، وعبد الله، والسلمى، والجحدري، والأعمش، وطلحة، وعيسى."
  56,20,"وفاكهة:1- بالجر، وهى قراءة الجمهور.وقرئ:2- بالرفع، أي: ولهم فاكهة، وهى قراءة زيد بن على."
  56,21,"ولحم:1- بالجر، وهى قراءة الجمهور.وقرئ:2- بالرفع، وهى قراءة زيد بن على."
  56,22,"وحور عين:1- برفعهما، وهى قراءة الجمهور.وقرئا:2- بجرهما، وهى قراءة السلمى، والحسن، وعمرو بن عبيد، وأبى جعفر، وشيبة، والأعمش، وطلحة، والمفضل، وأبان، وعصمة، والكسائي.3- وحير، بقلب الواو ياء، وجرهما، وهى قراءة النخعي.4- وحورا عينا، بنصبهما، وهى قراءة أبى، وعبد الله.5- وحور عين، بالرفع والإضافة، وهى قراءة قتادة.6- وحور عين، بالنصب والإضافة، وهى قراءة ابن مقسم.7- وحوراء عيناء، على التوحيد، وفتح الهمزة فيهما، وهى قراءة عكرمة."
  56,23,""
  56,24,"56:23"
  56,25,"56:23"
  56,26,"56:23"
  56,27,"56:23"
  56,28,"56:23"
  56,29,"56:23"
  56,30,"56:23"
  56,31,"56:23"
  56,32,"وفاكهة كثيرة:وقرئ:برفعهما."
  56,33,""
  56,34,"وفرش:1- بضم الراء، مجرورة، وهى قراءة الجمهور.وقرئ:2- بسكونها، مرفوعة، وهى قراءة أبى حيوة."
  56,35,""
  56,36,"56:35"
  56,37,"عربا:قرئ:1- بسكون الراء، وهى لغة تميم، وهى قراءة حمزة، وكثيرين.2- بضمها، وهى قراءة باقى السبعة."
  56,38,""
  56,39,"56:38"
  56,40,"56:38"
  56,41,"56:38"
  56,42,"56:38"
  56,43,"56:38"
  56,44,"بارد ... كريم:1- بالجر، فيهما، وهى قراءة الجمهور.وقرئ:2- بالرفع، فيهما، وهى قراءة ابن أبى عبلة."
  56,45,""
  56,46,"56:45"
  56,47,"56:45"
  56,48,"56:45"
  56,49,"56:45"
  56,50,"56:45"
  56,51,"56:45"
  56,52,"شجر:1- وهى قراءة الجمهور.وقرئ:2- شجرة، وهى قراءة عبد الله."
  56,53,""
  56,54,"56:53"
  56,55,"شرب:1- بضم الشين، وهو مصدر، وهى قراءة نافع، وعاصم، وحمزة.وقرئ:2- بكسرها، اسم بمعنى «المشروب» ، وهى قراءة مجاهد، وأبى عثمان النهدي.3- بفتحها، وهو مصدر مقيس، وهى قراءة الأعرج، وابن المسيب، وشعيب بن الحبحاب، ومالك بن دينار، وابن جريج، وباقى السبعة."
  56,56,"نزلهم:1- بضم الزاى، وهى قراءة الجمهور.وقرئ:2- بسكونها، وهو أول ما يأكله الضيف، وفيه تهكم بالكفار، وهى قراءة ابن محيصن، وخارجة، عن نافع، ونعيم، ومحبوب، وأبى زيد، وهارون، وعصمة، وعياش، كلهم عن أبى عمرو."
  56,57,""
  56,58,"تمنون:1- بضم التاء، وهى قراءة الجمهور.وقرئ:2- بفتحها، وهى قراءة ابن عباس، وأبى السمال."
  56,59,""
  56,60,"قدرنا:1- بشد الدال، وهى قراءة الجمهور.وقرئ:2- بخفها، وهى قراءة ابن كثير."
  56,61,""
  56,62,"تذكرون:وقرئ:1- بشد الذال.2- بخفها، وضم الكاف، وهى قراءة طلحة."
  56,63,""
  56,64,"56:63"
  56,65,"فظلتم:1- بفتح الظاء، ولام واحدة ساكنة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى حيوة، وأبى بكر.3- فظللتم، على الأصل، بكسر اللام، وهى قراءة عبد الله، والجحدري.4- فظللتم، على الأصل، وبفتح اللام، ورويت عن الجحدري أيضا.والمشهور: ظللت، بالكسر.تفكهون:1- بالتاء، وهى قراءة الجمهور.وقرئ:2- تفكنون، أي: تندمون، وهى قراءة أبى حرام."
  56,66,"إنا:1- وهى قراءة الجمهور.وقرئ:2- أئنا، بهمزتين، وهى قراءة الأعمش، والجحدري، وأبى بكر."
  56,67,""
  56,68,"56:67"
  56,69,"56:67"
  56,70,"56:67"
  56,71,"56:67"
  56,72,"56:67"
  56,73,"56:67"
  56,74,"56:67"
  56,75,"فلا أقسم:1- على أن «لا» زائدة مؤكدة. وهى قراءة الجمهور.وقرئ:2- فلا أقسم، وهى قراءة الحسن، وعيسى.بمواقع:1- جمعا، وهى قراءة الجمهور.وقرئ:2- بموقع، مفردا، مرادا به الجمع، وهى قراءة عمرو، وعبد الله، وأهل المدينة، وحمزة، والكسائي."
  56,76,""
  56,77,"56:76"
  56,78,"56:76"
  56,79,"المطهرون:1- اسم مفعول، من «طهر» مشددا، وهى قراءة الجمهور.وقرئ:2- اسم مفعول، من «أطهر» ، وهى قراءة عيسى، ورويت عن نافع، وأبى عمرو.3- اسم فاعل «من طهر» مشددا، أي: المطهرين أنفسهم، وهى قراءة سليمان الفارسي.4- المتطهرون."
  56,80,"تنزيل:وقرئ:تنزيلا، بالنصب، أي: نزل تنزيلا."
  56,81,""
  56,82,"رزقكم:وقرئ:شكركم، وهى قراءة على، وابن عباس.قال أبو حيان: وذلك على سبيل التفسير، لمخالفة السواد.وحكى الهيثم بن عدى أن من لغة أزد شنوءة: ما رزق فلان فلانا، أي: ما شكره.تكذبون:1- من التكذيب، وهى قراءة الجمهور.وقرئ:2- تكذبون، من الكذب، وهى قراءة على، والمفضل، عن عاصم."
  56,83,""
  56,84,"حينئذ:وقرئ:بكسر النون، اتباعا لحركة الهمزة، وهى قراءة عيسى."
  56,85,""
  56,86,"56:85"
  56,87,"56:85"
  56,88,"56:85"
  56,89,"فروح:1- بفتح الراء، وهى قراءة الجمهور.وقرئ:2- بضمها، وهى قراءة عائشة، عن النبي ﷺ، وابن عباس، والحسن، وقتادة، ونوح القارئ، والضحاك، والأشهب، وشعيب بن الحبحاب، وسليمان التيمي، والربيع بن خثيم، ومحمد بن على، وأبى عمران الجونى، والكلبي، وفياض، وعبيد، وعبد الوارث، عن أبى عمرو، ويعقوب ابن سفيان، وزيد، ورويس، عنه."
  56,90,""
  56,91,"56:90"
  56,92,"56:90"
  56,93,"56:90"
  56,94,"وتصلية:1- رفعا، عطفا على «فنزل» وهى قراءة الجمهور.وقرئ:2- جرا، عطفا على «من حميم» ، وهى قراءة أحمد بن موسى، والمنقري، واللؤلئى، عن أبى عمرو."
  56,95,""
  56,96,"56:95"
