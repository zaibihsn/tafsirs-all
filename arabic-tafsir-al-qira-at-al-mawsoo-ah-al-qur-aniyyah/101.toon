tafsir[11]{c,v,t}:
  101,1,"القارعة ... ما القارعة:1- بالرفع، فيهما، وهى قراءة الجمهور.وقرئا:2- بالنصب، فيهما، على إضمار فعل، وهى قراءة عيسى."
  101,2,"101:1"
  101,3,""
  101,4,"يوم:1- بالنصب، وهى قراءة الجمهور.وقرئ:2- بالرفع، وهى قراءة زيد بن على."
  101,5,""
  101,6,"101:5"
  101,7,"101:5"
  101,8,"101:5"
  101,9,"فأمه:1- بضم الهمزة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة طلحة."
  101,10,"ماهيه:قرئ:1- بإثبات الهاء، التي هى هاء السكت، وهى قراءة الجمهور.2- بحذفها فى الوصل، وهى قراءة ابن أبى إسحاق، والأعمش، وحمزة."
  101,11,""
