  53,10,"53:1"
  53,11,"كذب:1- مخففا، وهى قراءة الجمهور.وقرئ:2- مشددا، وهى قراءة أبى رجاء، وأبى جعفر، وقتادة، والجحدري، وخالد بن إلياس، وهشام، عن ابن عامر."
  53,12,"أفتمارونه:1- أي: أفتجادلونه، وهى قراءة الجمهور.وقرئ:2- أفتمرونه، بفتح التاء وسكون الميم، مضارع «مريت» ، أي: جحدت، وهى قراءة على، وعبد الله، وابن عباس، والجحدري، ويعقوب، وابن سعدان، وحمزة، والكسائي.3- أفتمرونه، بضم التاء وسكون الميم، مضارع «أمريت» ، وهى قراءة عبد الله، فيما حكى ابن خالويه، والشعبي.قال أبو حاتم: وهو غلط."
  53,13,""
  53,14,"53:13"
  53,15,"جنة:1- وهى قراءة الجمهور.وقرئ:2- جنة، بهاء الضمير، و «جن» فعل ماض، والهاء: ضمير النبي ﷺ، وهى قراءة على، وأبى الدرداء، وأبى هريرة، وابن الزبير، وأنس، وزر، ومحمد بن كعب، وقتادة."
  53,16,""
  53,17,"53:16"
  53,18,"53:16"
  53,19,"اللات:1- خفيفة التاء، وهى قراءة الجمهور.وقرئ:2- مشددة التاء، وهى قراءة ابن عباس، ومجاهد، ومنصور بن المعتمر، وأبى صالح، وطلحة، وأبى الجوزاء، ويعقوب، وابن كثير."
  53,20,"ومناة:1- بالكسر مقصورا، وهى قراءة الجمهور.وقرئ:2- ومناءة، بالمد والهمز، وهى قراءة ابن كثير."
  53,21,""
  53,22,"ضيزى:1- من غير همز، وهى قراءة الجمهور.وقرئ:2- ضئزى، بالهمز، وهى قراءة ابن كثير.3- ضيزى: بالفتح، وهى قراءة زيد بن على."
  53,23,"يتبعون:1- بياء الغيبة، وهى قراءة الجمهور.وقرئ:2- بتاء الخطاب، وهى قراءة عبد الله، وابن عباس، وابن وثاب، وطلحة، والأعمش، وعيسى بن عمر."
  53,24,""
  53,25,"53:24"
  53,26,"شفاعتهم:1- بإفراد «الشفاعة» ، وجمع الضمير، وهى قراءة الجمهور.وقرئ:2- شفاعته، بإفراد الاثنين، وهى قراءة زيد بن على.3- شفاعاتهم، بجمعهما، وهى قراءة ابن مقسم."
  53,27,""
  53,28,"53:27"
  53,29,"53:27"
  53,30,"53:27"
  53,31,"ليجزى ... ويجزى:وقرئا:بالنون، فيهما، وهى قراءة زيد بن على."
  53,32,""
  53,33,"53:32"
  53,34,"53:32"
  53,35,"53:32"
  53,36,"53:32"
  53,37,"وفى:1- بتشديد الفاء، وهى قراءة الجمهور.وقرئ:2- بتخفيفها، وهى قراءة أبى أسامة الباهلي، وسعيد بن جبير، وأبى مالك الغفاري، وابن السميفع، وزيد بن على."
  53,38,""
  53,39,"53:38"
  53,40,"53:38"
  53,41,"53:38"
  53,42,"وأن:1- بفتح الهمزة، عطفا على ما قبلها، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى السمال."
  53,43,"وأنه:1- بفتح الهمزة، عطفا على ما قبلها، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى السمال."
  53,44,"وأنه:1- بفتح الهمزة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى السمال."
  53,45,"53:44"
  53,46,""
  53,47,"وأن:1- بفتح الهمزة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى السمال."
  53,48,"وأنه:1- بفتح الهمزة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى السمال."
  53,49,"53:48"
  53,50,"وأنه:1- بفتح الهمزة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة أبى السمال.عادا الأولى:1- عاداه بتنوينه وكسره، لالتقائه ساكنا مع سكون لام «الأولى» ، وتحقيق الهمزة بعد اللام، وهى قراءة الجمهور.وقرئ:2- على القراءة السابقة، ولكن مع نقل حركة الهمزة إلى اللام، وحذف الهمزة، هى قراءة قوم.3- بإدغام التنوين فى اللام المنقول إليها حركة الهمزة المحذوفة، وهى قراءة نافع، وأبى عمرو."
  53,51,""
  53,52,"53:51"
  53,53,"والمؤتفكة:وقرئ:والمؤتفكات، جمعا، وهى قراءة الحسن."
  53,54,""
  53,55,"تتمارى:وقرئ:بتاء واحدة مشددة، وهى قراءة يعقوب، وابن محيصن."
  53,56,""
  53,57,"53:56"
  53,58,"53:56"
  53,59,"53:56"
  53,60,"وتضحكون:وقرئ:تضحكون، بغير واو، وهى قراءة الحسن، وكذا هى فى حرف أبى، وعبد الله."
  53,61,""
  53,62,"53:61"
