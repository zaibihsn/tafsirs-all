tafsir[111]{c,v,t}:
  17,1,"لنريه:1- هذه قراءة الجمهور، وفيها التفات من ضمير الغائب إلى ضمير المتكلم.وقرئ:2- ليريه، بالياء، وهى قراءة الحسن."
  17,2,"ألا تتخذوا:قرئ:1- بالياء، على العيبة، وهى قراءة ابن عباس، ومجاهد، وقتادة، وعيسى، وأبى رجاء، وأبى عمرو.2- بالتاء، على الخطاب، وهى قراءة باقى السبعة."
  17,3,""
  17,4,"فى الكتاب:1- على الإفراد، وهى قراءة الجمهور.وقرئ:2- فى الكتب، على الجمع، وهى قراءة أبى العالية، وابن جبير.لتفسدن:وقرئ:1- بضم التاء وفتح السين، مبنيا للمفعول أي: يفسدكم غيركم، وهى قراءة ابن عباس، ونصر بن على، وجابر بن زيد.2- بفتح التاء وضم السين: أي: فسدتم، وهى قراءة عيسى.علوا:1- هذه قراءة الجمهور.وقرئ:2- عليا، بكسر اللام والياء المشددة، وهى قراءة زيد بن على."
  17,5,"عبادا:1- هذه قراءة الجمهور.وقرئ:2- عبيدا، وهى قراءة الحسن، وزيد بن على.فجاسوا:1- هذه قراءة الجمهور.وقرئ:2- فحاسوا، بالحاء المهملة، وهى قراءة أبى السمال.3- فتجوسوا، على وزن «تكسروا» ، بالجيم."
  17,6,""
  17,7,"ليسوءوا:1- هذه قراءة الجمهور، بلام «كى» ، وياء الغيبة، وضمير الجمع الغائب العائد على المبعوثين.وقرئ:2- ليسوء، بالياء وهمزة ومفتوحة على الإفراد، والفاعل المضمر عائد على الله تعالى، أو على الوعد، أو على البعث، الدال علية جملة الجزاء المحذوفة، وهى قراءة ابن عامر، وحمزة، وأبى بكر.3- لنسوء، بالنون، وهى قراءة على بن أبى طالب، وزيد بن على، والكسائي.4- لنسؤن، بلام الأمر والنون، ونون التوكيد الخفيفة آخرا، وهى قراءة أبى."
  17,8,""
  17,9,"ويبشر:1- بالتشديد، مضارع «بشر» المشدد، وهى قراءة الجمهور.وقرئ:2- يبشر، مضارع «بشر» المخفف، وهى قراءة عبد الله، وطلحة، وابن وثاب، والأخوين."
  17,10,""
  17,11,"17:10"
  17,12,"مبصره.وقرئ:مبصرة، بفتح الميم والصاد، وهو مصدر، أقيم مقام الاسم، وهى قراءة قتادة، وعلى بن الحسن."
  17,13,"طائر:وقرئ:طيره، وهى قراءة مجاهد، والحسن، وأبى رجاء.فى عنقه:وقرئ:فى عنقه، بإسكان النون.ونخرج:1- بنون، وهى قراءة الجمهور، مضارع «أخرج» ، و «كتابا» بالنصب.وقرئ:1- يخرج، بالياء، مبنيا للمفعول، و «كتابا» بالنصب أي: ويخرج الطائر كتابا، وهى قراءة أبى جعفر.2- على القراءة السابقة، و «كتاب» بالرفع، على أنه مفعول ما لم يسم فاعله، ورويت عن أبى جعفر أيضا.3- ويخرج، بفتح الياء وضم الراء، و «كتابا» بالنصب أي: طائره كتابا، وهى قراءة ابن محيصن، ومجاهد.4- على القراءة السابقة، «كتاب» بالرفع، على أنه فاعل، وهى قراءة الحسن.يلقاه:1- بفتح الياء وسكون اللام، وهى قراءة الجمهور.وقرئ:2- يلقاه، بضم الياء وفتح اللام وتشديد القاف، وهى قراءة ابن عامر، والجحدري، والحسن بخلاف عنه."
  17,14,""
  17,15,"17:14"
  17,16,"أمرنا:1- هذه قراءة الجمهور، وفيها قولان:(أ) أحدهما، من الأمر الذي هو ضد النهى.(ب) والثاني: بمعنى: كثرنا.وقرئ:2- أمرنا، بكسر الميم أي كثرنا، لغة فى المفتوح الميم، وهى قراءة الحسن، ويحيى بن يعمر، وعرمة.3- آمرنا، بالمد: كثرنا، وهى قراءة على بن أبى طالب، وابن أبى إسحاق، وأبى رجاء، وعيسى بن عمر، وسلام، وعبد الله بن أبى يزيد، والكلبي.4- أمرنا، بتشديد الميم أي: كثرنا، وهى قراءة ابن عباس، وأبى عثمان النهدي، والسدى، وزيد بن على، وأبى العالية."
  17,17,""
  17,18,"ما نشاء:1- بالنون، وهى قراءة الجمهور.وقرئ:2- ما يشاء، بالياء، وهى قراءة نافع."
  17,19,""
  17,20,"17:19"
  17,21,"أكبر:وقرئ:أكثر، بالثاء المثلثة."
  17,22,""
  17,23,"وقضى:1- فعلا ماضيا، من القضاء، وهى قراءة الجمهور.وقرئ:2- وقضاء، مصدر «قضى» ، مرفوع على الابتداء، وهى قراءة بعض ولد معاذ بن جبل.أف:قرئ:1- بالكسر والتشديد مع التنوين، وهى قراءة الحسن، والأعرج، وأبى جعفر، وشيبة، وعيسى، ونافع، وحفص.2- بالكسر والتشديد من غير تنوين، وهى قراءة أبى عمرو، وحمزة، والكسائي، وأبى بكر.3- بالفتح مشددة من غير تنوين، وهى قراءة ابن كثير، وابن عامر.4- بضم الفاء من غير تنوين، وهى قراءة أبى السمال.5- بالنصب والتشديد مع التنوين، وهى قراءة زيد بن على.6- خفيفة، وهى قراءة ابن عباس.7- بالرفع والتنوين، حكاها هارون."
  17,24,"الذل:1- بضم الذال، وهى قراءة الجمهور.وقرئ:2- الذل، بكسر الذال، وذلك على الاستعارة فى الناس لأن ذلك يستعمل فى الدواب، وهى قراءة ابن عباس، وعروة بن الزبير، والجحدري، وابن وثاب."
  17,25,""
  17,26,"17:25"
  17,27,"17:25"
  17,28,"17:25"
  17,29,"17:25"
  17,30,"17:25"
  17,31,"خشية:وقرئ:خشية، بكسر الخاء.خطئا:1- بكسر الخاء وسكون الطاء، وهى قراءة الجمهور.وقرئ:1- خطأ، بكسر الخاء وفتح الطاء والمد، على أنها مصدر خاطأ، وهى قراءة ابن كثير.2- خطأ، على وزن «نبأ» ، وهى قراءة ابن ذكوان.3- خطاء، بفتح الخاء والطاء والمد، اسم مصدر، من «أخطأ» ، كالعطاء من «أعطى» ، وهى قراءة الحسن."
  17,32,""
  17,33,"فلا يسرف:1- بياء الغيبة، وهى قراءة الجمهور.وقرئ:2- بتاء الخطاب، على خطاب «الولي» ، فالضمير له، وهى قراءة الأخوين، وزيد بن على، وحذيفة، وابن وثاب، والأعمش، ومجاهد، بخلاف.3- بضم الفاء، على الخبر، ومعناه النهى."
  17,34,""
  17,35,"17:34"
  17,36,"ولا تقف:1- بحذف الواو للجزم، مضارع «قفا» ، وهى قراءة الجمهور.وقرئ:2- ولا تقفو، بإثبات الواو، وهى قراءة زيد بن على.3- ولا تقف، مثل: ولا تقل، من: قاف يقوف، وهى قراءة معاذ القارئ.والفؤاد:وقرئ:الفواد، بفتح الفاء والواو، قلبت الهمزة واوا، بعد الضمة، ثم استصحب القلب مع الفتح، وهى لغة فى الفؤاد، وبها قرأ الجراح العقيلي."
  17,37,"مرحا:وقرئ:بكسر الراء، وهى قراءة فرقة.تخرق:وقرئ:تخرق، بضم الراء، وهى قراءة الجراح الأعرابى.وقال أبو حاتم: لا تعرف هذه اللغة."
  17,38,"سيئه:قرئ:1- سيئه، بالنصب والتأنيث، وهى قراءة الحرميين، وأبى عمرو، وأبى جعفر، والأعرج.2- سيئه، بضم الهمزة، مضافا لهاء المذكر الغائب، وهى قراءة باقى السبعة.3- سيئاته، بالجمع مضافا الهاء، وهى قراءة عبد الله.4- سيئات، بالجمع بغير هاء، وهى قراءة لعبد الله أيضا.5- خبيئه، وهى قراءة لعبد الله أيضا."
  17,39,""
  17,40,"17:39"
  17,41,"صرفنا:1- بتشديد الراء، وهى قراءة الجمهور.وقرئ:2- بتخفيف الراء، وهى قراءة الحسن.ليذكروا:1- أي ليتذكروا، من التذكير، أدغمت التاء فى الذال، وهى قراءة الجمهور.وقرئ:2- ليذكروا، بسكون الذال وضم الكاف، من «الذكر» ، وهى قراءة الأخوين، وطلحة وابن وثاب، والأعمش."
  17,42,""
  17,43,"يقولون:قرئ:1- بالتاء، وهى قراءة الأخوين.2- بالياء، وهى قراءة باقى السبعة."
  17,44,"تسبح:1- بالتاء، وهى قراءة النحويين، وحمزة، وحفص.وقرئ:2- بالياء، وهى قراءة باقى السبعة.3- سبحت، وهى قراءة عبد الله، والأعمش، وطلحة بن مصرف."
  17,45,""
  17,46,"17:45"
  17,47,"17:45"
  17,48,"17:45"
  17,49,"17:45"
  17,50,"17:45"
  17,51,"17:45"
  17,52,"17:45"
  17,53,"17:45"
  17,54,"17:45"
  17,55,"17:45"
  17,56,"17:45"
  17,57,"يدعون:1- بياء الغيبة مبنيا للفاعل، وهى قراءة الجمهور.وقرئ:2- بتاء الخطاب، وهى قراءة ابن مسعود، وقتادة.3- بياء الغيبة، مبنيا للمفعول أي: يدعونهم آلهتهم، أو يدعونهم لكشف ما حل بهم من الضر. وهى قراءة زيد بن على."
  17,58,""
  17,59,"17:58"
  17,60,"والشجرة:1- بالنصب، عطفا على «الرؤيا» ، وهى قراءة الجمهور.وقرئ:2- بالرفع، على الابتداء، والخبر محذوف، تقديره: كذلك، أي فتنة، وهى قراءة زيد بن على.ونخوفهم:1- بالنون، وهى قراءة الجمهور.وقرئ:2- ويخوفهم، بياء الغيبة، وهى قراءة الأعمش."
  17,61,""
  17,62,"17:61"
  17,63,"17:61"
  17,64,"ورجلك:1- بفتح الراء وسكون الجيم، اسم جمع، واحده: راجل، مثل ركب وراكب، وهى قراءة الجمهور.وقرئ:2- بفتح الراء وكسر الجيم، بمعنى: رجال، وقيل: صفة، أي: غير الراكب، وهى قراءة الحسن، وأبى عمرو- فى رواية- وحفص.3- ورجالك، وهى قراءة قتادة، وعكرمة."
  17,65,""
  17,66,"17:65"
  17,67,"17:65"
  17,68,"يخسف ... يرسل:قرئا:1- بالنون، وهى قراءة ابن كثير، وأبى عمرو.2- بياء الغيبة، وهى قراءة باقى القراء."
  17,69,"يعيدكم:قرئ:1- بالنون، وهى قراءة ابن كثير، وأبى عمرو.2- بياء الغيبة، وهى قراءة باقى القراء.فيرسل:قرئ:1- بالنون، وهى قراءة ابن كثير، وأبى عمرو.2- بياء الغيبة، وهى قراءة باقى القراء.فيغرقكم:قرئ:1- بالنون، وهى قراءة ابن كثير، وأبى عمرو.2- بياء الغيبة، وهى قراءة باقى القراء.3- بتاء الخطاب، مسندا إلى «الريح» ، وهى قراءة مجاهد، وأبى جعفر.4- بياء الغيبة، وفتح الغين، وشد الراء، معدى بالتضعف، وهى قراءة الحسن، وأبى رجاء.5- بتاء الخطاب وفتح الغين وشد الراء، ورويت عن أبى جعفر.6- بالنون وإسكان الغين وإدغام القاف فى الكاف، وهى قراءة حميد، ورويت عن أبى عمرو، وابن محيصن.الريح:1- بالإفراد، وهى قراءة الجمهور.وقرئ:2- الرياح، بالجمع، وهى قراءة أبى جعفر."
  17,70,""
  17,71,"ندعو:1- بالنون، وهى قراءة الجمهور.وقرئ:2- يدعو، بياء الغيبة أي: يدعو الله، وهى قراءة مجاهد.3- يدعى، مبنيا للمفعول، و «كل» مرفوع به، وهى قراءة الحسن، فيما ذكر أبو عمرو الداني."
  17,72,""
  17,73,"17:72"
  17,74,"17:72"
  17,75,"17:72"
  17,76,"وإذا لا يلبثون:وقرئ:1- وإذا لا يلبثوا، بحذف النون، أعملت «إذا» فنصب بها، وهى قراءة أبى، وكذا هى فى مصحف عبد الله.2- وإذا لا يلبثون، بضم الياء وفتح اللام والباء مشددة، وهى قراءة عطاء.3- وإذا لا يلبثون، بضم الياء وفتح اللام وكسر الباء مشددة، وهى قراءة يعقوب.خلافك:1- هذه قراءة الأخوين، وابن عامر، وحفص.وقرئ:2- خلفك، وهى قراءة باقى السبعة.3- بعدك، وهى قراءة عطاء بن أبى رباح.قال أبو حيان: والأحسن أن يجعل تفسيرا لا قراءة، لأنها تخالف سواد المصحف."
  17,77,""
  17,78,"17:77"
  17,79,"17:77"
  17,80,"17:77"
  17,81,"17:77"
  17,82,"وننزل:1- بالنون، وهى قراءة الجمهور.وقرئ:2- بالباء، خفيفة، وهى قراءة مجاهد.شفاء ورحمة:وقرئا:بالنصب على الحال، وهى قراءة زيد بن على."
  17,83,"ونأى:1- من: النأى، وهى قراءة الجمهور.وقرئ:2- وناء، وهى قراءة ابن عامر، وقيل: هو مقلوب «نأى» بمعنى: بعد وقيل: معناه: نهض بجانبه."
  17,84,""
  17,85,"17:84"
  17,86,"17:84"
  17,87,"17:84"
  17,88,"17:84"
  17,89,"صرفنا:قرئ:1- بتشديد الراء، وهى قراءة الجمهور.2- بتخفيفها، وهى قراءة الحسن."
  17,90,"تفجر:قرئ:1- تفجر، من «فجر» مخففا، وهى قراءة الكوفيين.2- تفجر، من «فجر» ، مشددا، والتضعيف للمبالغة لا للتعدية، وهى قراءة باقى السبعة.3- تفجر، من «أفجر» ، وهى قراءة الأعمش، وعبد الله بن مسلم بن يسار."
  17,91,""
  17,92,"قبيلا:وقرئ:قبلا، وهى قراءة الأعرج."
  17,93,""
  17,94,"17:93"
  17,95,"17:93"
  17,96,"17:93"
  17,97,"17:93"
  17,98,"17:93"
  17,99,"17:93"
  17,100,"17:93"
  17,101,"17:93"
  17,102,"علمت:قرئ:1- بفتح التاء، على خطاب موسى لفرعون، وهى قراءة الجمهور.2- بضم التاء، على إخبار موسى عن نفسه، وهى قراءة على بن أبى طالب، وزيد بن على، والكسائي."
  17,103,""
  17,104,"17:103"
  17,105,"17:103"
  17,106,"فرقناه:قرئ:1- بتخفيف الراء، وهى قراءة الجمهور.2- بتشديد الراء، وهى قراءة أبى عبد الله، وعلى، وابن عباس، وأبى رجاء، وقتادة، والشعبي، وحميد، وعمرو بن قائد، وزيد بن على، وعمرو بن ذر، وعكرمة، والحسن، بخلاف عنه."
  17,107,""
  17,108,"17:107"
  17,109,"17:107"
  17,110,"أياما تدعو:قرئ:أيا من تدعو، وهى قراءة طلحة بن مصرف."
  17,111,""
