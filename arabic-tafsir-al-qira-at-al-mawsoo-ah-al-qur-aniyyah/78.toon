tafsir[40]{c,v,t}:
  78,1,"يتساءلون:وقرئ:يساءلون، بغير تاء وشد السين، وهى قراءة عبد الله، وابن جبير."
  78,2,""
  78,3,"78:2"
  78,4,"سيعلمون ... سيعلمون:1- بياء الغيبة، فيهما، وهى قراءة الجمهور.وقرئ:2- الأول بالتاء، على الخطاب، والثاني بالياء، على الغيبة، ورويت عن الضحاك."
  78,5,"78:4"
  78,6,""
  78,7,"78:6"
  78,8,"78:6"
  78,9,"78:6"
  78,10,"78:6"
  78,11,"78:6"
  78,12,"78:6"
  78,13,"78:6"
  78,14,"ثجاجا:قرئ:ثجاجا، بالحاء آخرا، أي منصبا، وهى قراءة الأعرج."
  78,15,""
  78,16,"78:15"
  78,17,"78:15"
  78,18,"الصور:1- بسكون الواو، وهى قراءة الجمهور.وقرئ:2- بفتحها، وهى قراءة أبى فياض."
  78,19,""
  78,20,"78:19"
  78,21,"إن:1- بالكسر، وهى قراءة الجمهور.وقرئ:2- بفتحها، وهى قراءة أبى عمرو المنقري، وابن يعمر."
  78,22,""
  78,23,"لابثين:1- بالألف، وهى قراءة الجمهور.وقرئ:2- لبثين، بغير ألف، وهى قراءة عبد الله، وعلقمة، وزيد بن على، وابن وثاب، وعمرو بن ميمون، وعمرو بن شرحبيل، وطلحة، والأعمش، وحمزة، وقتيبة، وسورة، وروح."
  78,24,""
  78,25,"78:24"
  78,26,"وفاقا:1- بخف الفاء، وهى قراءة الجمهور.وقرئ:2- بشدها، وهى قراءة أبى بحرية، وابن أبى عبلة."
  78,27,""
  78,28,"كذابا:1- بكسر الكاف وشد الذال، وهى قراءة الجمهور.وقرئ:2- بكسر الكاف وخف الذال، وهى قراءة على، وعوف الأعرابى، وأبى رجاء، والأعمش، وعيسى.3- بضم الكاف وشد الذال، جمع «كاذب» ، وهى قراءة عمر بن عبد العزيز، والماجشون."
  78,29,"وكل شيء:1- بنصب «كل» ، وهى قراءة الجمهور.وقرئ:2- برفعها، وهى قراءة أبى السمال."
  78,30,""
  78,31,"78:30"
  78,32,"78:30"
  78,33,"78:30"
  78,34,"78:30"
  78,35,"كذابا:1- بالتشديد، وهى قراءة الجمهور.وقرئ:2- بالتخفيف، وهى قراءة الكسائي."
  78,36,"حسابا:1- بكسر الحاء وفتح السين مخففة، وهى قراءة الجمهور.وقرئ:2- بفتح الحاء وشد السين، وهى قراءة ابن قطيب.3- بكسر الحاء وشد السين، وهى قراءة شريح بن يزيد، وأبى البرهسم.4- حسنا، بالنون، وهى قراءة ابن عباس.5- حسبا، بفتح الحاء، وسكون السين والباء، حكاها العدوى، عن ابن عباس."
  78,37,"رب ... الرحمن:قرئا:1- بجرهما، وهى قراءة عبد الله، وابن أبى إسحاق، والأعمش، وابن محيصن، وابن عامر، وعاصم.2- برفعهما، وهى قراءة الأعرج، وأبى جعفر، وشيبة، وأبى عمرو، والحرميين.3- الأول بالجر، والثاني بالرفع، وهى قراءة الأخوين، والحسن، وابن وثاب، والأعمش، وابن محيصن، بخلاف عنهما."
  78,38,""
  78,39,"78:38"
  78,40,"المرء:1- بفتح الميم، وهى قراءة الجمهور.وقرئ:2- بضمها، وهى قراءة ابن أبى إسحاق."
