tafsir[21]{c,v,t}:
  92,1,""
  92,2,"تجلى:1- فعلا ماضيا، فاعله ضمير «النهار» ، وهى قراءة الجمهور.وقرئ:2- تتجلى، بتاءين، يعنى «الشمس» ، وهى قراءة عبد الله بن عبيد بن عمير."
  92,3,""
  92,4,"92:3"
  92,5,"92:3"
  92,6,"92:3"
  92,7,"92:3"
  92,8,"92:3"
  92,9,"92:3"
  92,10,"92:3"
  92,11,"92:3"
  92,12,"92:3"
  92,13,"92:3"
  92,14,"تلظى:1- بتاء واحدة، وهى قراءة الجمهور.وقرئ:2- بتاءين، وهى قراءة ابن الزبير، وزيد بن على، وطلحة، وسفيان بن عينية، وعبيد بن عمير.3- بتاء مشددة، وهى قراءة البزي."
  92,15,""
  92,16,"92:15"
  92,17,"92:15"
  92,18,"يتزكى:1- مضارع «تزكى» ، وهى قراءة الجمهور.وقرئ:2- بإدغام التاء فى الزاى، وهى قراءة الحسن بن على بن أبى طالب."
  92,19,""
  92,20,"ابتغاء:1- بالنصب، وهى قراءة الجمهور.وقرئ:2- بالرفع، وهى قراءة ابن وثاب.3- ابتغا، مقصورا، وهى قراءة ابن أبى عبلة."
  92,21,""
