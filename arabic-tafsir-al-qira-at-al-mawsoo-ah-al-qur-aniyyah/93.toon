tafsir[11]{c,v,t}:
  93,1,""
  93,2,"93:1"
  93,3,"93:1"
  93,4,"93:1"
  93,5,"93:1"
  93,6,"فآوى:1- رباعيا، وهى قراءة الجمهور.وقرئ:2- فأوى، ثلاثيا، بمعنى: رحم، وهى قراءة أبى الأشهب العقيلي."
  93,7,""
  93,8,"عائلا:1- أي فقيرا، وهى قراءة الجمهور.وقرئ:2- عيلا، كسيد، بتشديد الياء المكسورة، وهى قراءة اليماني."
  93,9,"تقهر:1- بالقاف، وهى قراءة الجمهور.وقرئ:2- بالكاف بدل القاف، وهى لغة بمعنى قراءة الجمهور، وبها قرأ ابن مسعود، وإبراهيم التيمي."
  93,10,""
  93,11,"93:10"
