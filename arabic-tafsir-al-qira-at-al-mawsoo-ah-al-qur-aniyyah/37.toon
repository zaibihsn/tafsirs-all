tafsir[182]{c,v,t}:
  37,1,""
  37,2,"37:1"
  37,3,"37:1"
  37,4,"37:1"
  37,5,"37:1"
  37,6,"بزينة الكواكب:وقرئا:1- بزينة، منونا، و «الكواكب» بالخفض، بدلا من «زينة» ، وهى قراءة ابن مسعود، ومسروق، بخلاف عنه، وأبى زرعة، وابن وثاب، وطلحة.2- بزينة، منونا، و «الكواكب» نصبا، وهى قراءة ابن وثاب، ومسروق، بخلاف عنهما، والأعمش، وطلحة، وأبى بكر.3- بتنوين «زينة» ورفع «الكواكب» ، على خبر مبتدأ، أي: هو الكواكب، أو على الفاعلية بالمصدر، وهى قراءة زيد بن على."
  37,7,""
  37,8,"لا يسمعون:1- بشد السين والميم، أي: لا يتسمعون، أدغمت التاء فى السين، وهى قراءة ابن عباس، بخلاف عنه، وابن وثاب، وعبد الله بن مسلم، وطلحة، والأعمش، وحمزة، والكسائي، وحفص.وقرئ:2- على نفي السماع، وهى قراءة الجمهور."
  37,9,""
  37,10,"خطف:1- بكسر الطاء، ثلاثيا، وهى قراءة الجمهور.وقرئ:2- بكسر الخاء والطاء مشددة، وهى قراءة الحسن، وقتادة.3- بفتح الخاء وكسر الطاء مشددة، ونسبها ابن خالويه إلى الحسن، وقتادة، وعيسى.فأتبعه:1- بالتخفيف، وهى قراءة الجمهور.وقرئ:2- بالتشديد."
  37,11,"أم من:وقرئ:1- أمن، بتخفيف الميم، دون «أم» ، على أنه استفهام ثان، وهى قراءة الأعمش."
  37,12,"عجبت:1- بتاء الخطاب، وهى قراءة الجمهور.وقرئ:2- بتاء المتكلم، وهى قراءة حمزة، والكسائي، وابن سعدان، وابن مقسم.وأنكرها بعضهم، ووجها الزمخشري، فقال: أي بلغ من عظيم آياتي وكثرة خلائقى أنى عجبت منها، فكيف بعبادي؟."
  37,13,"ذكروا:وقرئ:بتخفيف الكاف؟ وهى قراءة جناح بن حبيش."
  37,14,""
  37,15,"37:14"
  37,16,"37:14"
  37,17,"أو:1- بفتح الواو، وهى قراءة الجمهور.وقرئ:2- بإسكانها، وهى قراءة أبى جعفر، وشيبة، وابن عامر، ونافع، فى رواية قالون."
  37,18,"نعم:وقرئ:بكسر العين، وهى قراءة ابن وثاب (انظر: الأعراف، الآية: 44) ."
  37,19,""
  37,20,"37:19"
  37,21,"37:19"
  37,22,"وأزواجهم:وقرئ:بالرفع، عطفا على ضميره «ظلموا» ، وهى قراءة عيسى بن سليمان الحجازي."
  37,23,""
  37,24,"إنهم:وقرئ:أنهم، بالفتح، وهى قراءة عيسى."
  37,25,"تناصرون:1- بتاء واحدة.وقرئ:2- بتاءين.3- بإدغام إحداهما فى الأخرى."
  37,26,""
  37,27,"37:26"
  37,28,"37:26"
  37,29,"37:26"
  37,30,"37:26"
  37,31,"37:26"
  37,32,"37:26"
  37,33,"37:26"
  37,34,"37:26"
  37,35,"37:26"
  37,36,"37:26"
  37,37,"وصدق المرسلين:وقرئ:وصدق، بتخفيف الدال، و «المرسلون» بالواو، وهى قراءة عبد الله."
  37,38,"لذائقو العذاب:1- بحذف النون للإضافة، وهى قراءة الجمهور.وقرئ:2- بحذف النون، لالتقاء لام التعريف، ونصب «العذاب» ، وهى قراءة أبى السمال، وأبان، عن ثعلبة، عن عاصم.3- لذائقون العذاب، بالنون، ونصب «العذاب» ."
  37,39,""
  37,40,"37:39"
  37,41,"37:39"
  37,42,"مكرمون:وقرئ:بفتح الكاف مشدد الراء، وهى قراءة ابن مقسم."
  37,43,""
  37,44,"سرر:1- بضم الراء، وهى قراءة الجمهور.وقرئ:2- بفتحها، وهى لغة بعض تميم وكلب، وهى قراءة أبى السمال."
  37,45,""
  37,46,"37:45"
  37,47,"ينزفون:1- بضم الياء وفتح الزاى، وهى قراءة الحرميين، والعربيين.وقرئ:2- بضم الياء وكسر الزاى، وهى قراءة مجاهد، وقتادة، وحمزة، والكسائي.3- بفتح الياء وكسر الزاى، وهى قراءة ابن أبى إسحاق.4- بفتح الياء وضم الزاى، وهى قراءة طلحة."
  37,48,""
  37,49,"37:48"
  37,50,"37:48"
  37,51,"37:48"
  37,52,"المصدقين:1- بتخفيف الصاد، من «التصديق» ، وهى قراءة الجمهور.وقرئ:2- بشدها، من «التصدق» ، وهى قراءة فرقة."
  37,53,""
  37,54,"مطلعون:1- بتشديد الطاء المفتوحة، وفتح النون، وهى قراءة الجمهور.وقرئ:2- بإسكان الطاء وفتح النون، وهى قراءة أبى عمرو، فى رواية حسين الجعفي، وابن عباس، وابن محيصن، وعمار بن أبى عمار، وأبى سراج.3- بتخفيف الطاء وكسر النون، وهى قراءة أبى البرهسم، وعمار بن أبى عمار أيضا.ورد هذه القراءة أبو حاتم، لجمعها بين نون الجمع وياء المتكلم."
  37,55,""
