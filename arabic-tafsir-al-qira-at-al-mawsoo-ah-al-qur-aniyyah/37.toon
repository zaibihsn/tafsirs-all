  37,168,"37:156"
  37,169,"37:156"
  37,170,"37:156"
  37,171,"كلمتنا:1- بالإفراد، وهى قراءة الجمهور.وقرئ:2- بالجمع، وهى قراءة الضحاك."
  37,172,""
  37,173,"37:172"
  37,174,"37:172"
  37,175,"37:172"
  37,176,"37:172"
  37,177,"نزل:1- مبنيا للفاعل، وهى قراءة الجمهور.وقرئ:2- مبنيا للمفعول، وهى قراءة ابن مسعود."
