tafsir[52]{c,v,t}:
  69,1,""
  69,2,"69:1"
  69,3,"69:1"
  69,4,"69:1"
  69,5,"فأهلكوا:1- رباعيا مبنيا للمفعول، وهى قراءة الجمهور.وقرئ:2- فهلكوا، مبنيا للفاعل، وهى قراءة زيد بن على."
  69,6,""
  69,7,"حسوما:وقرئ:بالفتح، حالا من «الريح» ، وهى قراءة السدى.أعجاز:وقرئ:أعجز، على وزن «أفعل» ، كضبع وأضبع، وهى قراءة أبى نهيك."
  69,8,""
  69,9,"قبله:قرئ:1- بكسر القاف وفتح الباء، وهى قراءة أبى رجاء، وطلحة، والجحدري، والحسن، بخلاف عنه، وعاصم، فى رواية أبان، والنحويين.2- بفتح القاف وسكون الباء، ظرف زمان، وهى قراءة باقى السبعة، وأبى جعفر، وشيبة، والسلمى.والمؤتفكات:وقرئ:والمؤتفكة، على الإفراد، وهى قراءة الحسن."
  69,10,""
  69,11,"69:10"
  69,12,"69:10"
  69,13,"نفخة واحدة:1- برفعهما، وهى قراءة الجمهور.وقرئ:2- بنصبهما، على إقامة الجار والمجرور مقام الفاعل، وهى قراءة أبى السمال."
  69,14,"وحملت:1- بالتخفيف، وهى قراءة الجمهور.وقرئ:2- بالتشديد، وهى قراءة ابن أبى عبلة، وابن مقسم، والأعمش، وابن عامر، فى رواية يحيى."
  69,15,""
  69,16,"69:15"
  69,17,"69:15"
  69,18,"لا تخفى:1- بتاء التأنيث، وهى قراءة الجمهور.وقرئ:2- بالياء، وهى قراءة على، وابن وثاب، وطلحة، والأعمش، وحمزة، والكسائي، وابن مقسم، عن عاصم، وابن سعدان."
  69,19,"كتابيه:1- بإثبات هاء السكت وقفا ووصلا، مراعاة لخط المصحف، وهى قراءة الجمهور.وقرئ:2- بحذفها، وصلا ووقفا وإسكان الياء، وهى قراءة ابن محيصن."
  69,20,"حسابيه:انظر: كتابيه، الآية: 19."
  69,21,""
  69,22,"69:21"
  69,23,"69:21"
  69,24,"69:21"
  69,25,"كتابيه:انظر: الآية: 19."
  69,26,"حسابيه:انظر الآية: 19."
  69,27,""
  69,28,"ماليه:انظر الآية: 19."
  69,29,"سلطانيه:انظر الآية: 19."
  69,30,""
  69,31,"69:30"
  69,32,"69:30"
  69,33,"69:30"
  69,34,"69:30"
  69,35,"69:30"
  69,36,"69:30"
  69,37,"الخاطئون:1- بالهمز، اسم فاعل من «خطئ» ، وهى قراءة الجمهور.وقرئ:2- بياء مضمومة بدلا من الهمزة، وهى قراءة الحسن، والزهري، والعتكي، وطلحة، فى نقل.3- بضم الطاء دون همز، وهى قراءة أبى جعفر، وشيبة، وطلحة، ونافع، بخلاف عنه."
  69,38,""
  69,39,"69:38"
  69,40,"69:38"
  69,41,"تؤمنون:قرئ:1- بالياء، وهى قراءة ابن كثير، وابن عامر، وأبى عمرو بخلاف عنهما، والجحدري، والحسن.2- بتاء الخطاب، وهى قراءة باقى السبعة."
  69,42,"تذكرون:قرئ:1- بالياء، وهى قراءة ابن كثير، وابن عامر، وأبى عمرو، بخلاف عنهما، والجحدري، والحسن.2- بتاء الخطاب، وهى قراءة باقى السبعة."
  69,43,"تنزيل:1- بالرفع، وهى قراءة الجمهور.وقرئ:2- تنزيلا، بالنصب، وهى قراءة أبى السمال."
  69,44,"تقول:1- مبنيا للفاعل، وهى قراءة الجمهور.وقرئ:2- مبنيا للمفعول."
