tafsir[85]{c,v,t}:
  40,1,"حم:قرئ:1- بفتح الحاء، وهو قراءة أبى القاسم بن جبارة الهذلي، صاحب كتاب «الكامل» ، فى اختياره.2- بكسرها، على أصل التقاء الساكنين، وهى قراءة أبى السمال."
  40,2,""
  40,3,"40:2"
  40,4,"فلا يغررك:قرئ:1- بالفك، وهى لغة الحجاز، وبها قرأ الجمهور.2- بالإدغام، مفتوح الراء، وهى لغة تميم، وبها قرأ زيد بن على، وعبيد بن عمير."
  40,5,"برسولهم:1- وهى قراءة الجمهور.وقرئ:2- برسولها، يعود ضمير إلى لفظ «أمة» ، وهى قراءة عبد الله."
  40,6,"كلمة:وقرئ:1- كلمات، على الجمع، وهى قراءة ابن هرمز، وشيبة، وابن القعقاع، ونافع، وابن عامر."
  40,7,"العرش:1- بفتح العين، وهى قراءة الجمهور.وقرئ:2- بضمها، وهى قراءة ابن عباس، وفرقة."
  40,8,"جنات عدن:1- جمعا، وهى قراءة الجمهور.وقرئ:2- جنة عدن، بالإفراد، وهى قراءة زيد بن على، والأعمش، وكذا فى مصحف عبد الله.وانظر: سورة مريم، الآية: 61.صلح:وقرئ:بضم اللام، وهى قراءة ابن أبى عبلة.وذرياتهم:1- بالجمع، وهى قراءة الجمهور.وقرئ:2- بالإفراد، وهى قراءة عيسى."
  40,9,""
  40,10,"40:9"
  40,11,"40:9"
  40,12,"40:9"
  40,13,"40:9"
  40,14,"40:9"
  40,15,"رفيع:وقرئ:بالنصب، على المدح.لينذر:1- مبنيا للفاعل، و «يوم» بالنصب، مفعولا على السعة، أو ظرفا، وهى قراءة الجمهور.وقرئ:2- مبنيا للفاعل، و «يوم» بالرفع، على الفاعلية مجازا، وهى قراءة أبى، وجماعة.3- مبنيا للمفعول، وهى قراءة اليماني.4- لتنذر، بالتاء، والفاعل ضمير الروح، لأنها تؤنث.التلاق:قرئ:1- بياء، وبغير ياء."
  40,16,""
  40,17,"40:16"
  40,18,"40:16"
  40,19,"40:16"
  40,20,"يدعون:1- بياء الغيبة، وهى قراءة الجمهور.وقرئ:2- تدعون، بتاء الخطاب، وهى قراءة أبى جعفر، وشيبة، ونافع، بخلاف عنه، وهشام."
  40,21,""
  40,22,"40:21"
  40,23,"وسلطان:وقرئ:بضم اللام، وهى قراءة عيسى."
  40,24,""
  40,25,"40:24"
  40,26,"أو أن:1- وهى قراءة الكوفيين.وقرئ:2- وأن، وهى قراءة باقى السبعة.يظهر:1- مضارع «أظهر» ، مبنيا للفاعل، و «الفساد» نصبا، وهى قراءة أنس بن مالك، وابن المسيب، ومجاهد، وقتادة، وأبى رجاء، والحسن، والجحدري، ونافع، وأبى عمرو، وحفص.وقرئ:2- «ظهر» مبنيا للفاعل، و «الفساد» رفعا، وهى قراءة باقى السبعة، والأعرج، والأعمش، وابن وثاب، وعيسى.3- يشد الظاء والهاء، و «الفساد» رفعا، وهى قراءة مجاهد.4- بضم الياء وفتح الهاء، مبنيا للمفعول، و «الفساد» رفعا، وهى قراءة زيد بن على."
  40,27,"عذت:قرئ:1- بالإدغام، وهى قراءة أبى عمرو، وحمزة، والكسائي.2- بالإظهار، وهى قراءة باقى السبعة."
  40,28,"رجل:1- بضم الجيم، وهى قراءة الجمهور.وقرئ:2- بسكونها، وهى لغة تميم ونجد، وبها قرأ عيسى، وعبد الوارث، وعبيد بن عقيل، وحمزة ابن القاسم، عن أبى عمرو."
  40,29,""
  40,30,"40:29"
  40,31,"40:29"
  40,32,"التناد:وقرئ:1- بسكون الدال، فى الوصل، إجراء له مجرى الوقف، وهى قراءة فرقة.2- بتشديد الدال، من: ند البعير، إذا هرب، وهى قراءة ابن الضحاك، وأبى صالح، والكلبي، والزعفراني، وابن مقسم."
  40,33,""
  40,34,"40:33"
  40,35,"قلب:وقرئ:1- بالتنوين، وهى قراءة أبى عمرو بن ذكوان، والأعرج، بخلاف عنه.2- بالإضافة، وهى قراءة باقى السبعة."
  40,36,""
  40,37,"فأطلع:قرئ:1- برفع العين، عطفا على «أبلغ» ، وهى قراءة الجمهور.2- بنصب العين، وهى قراءة الأعرج، وأبى حيوة، وزيد بن على، والزعفراني، وابن مقسم، وحفص.زين:1- مبنيا للمفعول، وهى قراءة الجمهور.وقرئ:2- مبنيا للفاعل.صد:1- مبنيا للمفعول، وهى قراءة الجمهور.وقرئ:2- مبنيا للفاعل.3- بفتح الصاد وضم الدال، منونة، عطفا على «سوء عمله» ، وهى قراءة ابن أبى إسحاق، وعبد الرحمن ابن أبى بكرة."
  40,38,"الرشاد:وقرئ:بشد الشين، وهى قراءة معاذ بن جبل."
  40,39,""
  40,40,"يدخلون:1- مبنيا للفاعل، وهى قراءة أبى رجاء، وشيبة، والأعمش، والأخوين، والصاحبين، وحفص.وقرئ:2- مبنيا للمفعول، وهى قراءة باقى السبعة، والأعرج، والحسن، وأبى جعفر، وعيسى."
  40,41,""
  40,42,"40:41"
  40,43,"40:41"
  40,44,"40:41"
  40,45,"40:41"
  40,46,"أدخلوا:1- أمرا، من «أدخل» ، وهى قراءة الأعرج، وأبى جعفر، وشيبة، والأعمش، وابن وثاب، وطلحة، ونافع، وحمزة، والكسائي، وحفص.وقرئ:2- أمرا، من «دخل» ، وهى قراءة على، والحسن، وقتادة، وابن كثير، والعربيين."
  40,47,""
  40,48,"كل:وقرئ:كلا، بالنصب، على التوكيد لاسم «أن» ، وهى قراءة ابن السميفع، وعيسى بن عمران."
  40,49,""
  40,50,"40:49"
  40,51,"يقوم:1- بالياء، وهى قراءة الجمهور.وقرئ:2- تقوم، بتاء التأنيث، وهى قراءة ابن هرمز، وإسماعيل، والمنقري، عن أبى عمرو."
  40,52,"ينفع:قرئ:1- بالتاء، وبالياء. «انظر: سورة الروم، الآية: 57» ."
  40,53,""
  40,54,"40:53"
  40,55,"40:53"
  40,56,"40:53"
  40,57,"40:53"
  40,58,"تتذكرون:1- بتاء الخطاب، وهى قراءة قتادة، وطلحة، وأبى عبد الرحمن، وعيسى، والكوفيين.وقرئ:2- بالياء، على الغيبة، وهى قراءة الأعرج، والحسن، وأبى جعفر، وشيبة."
  40,59,""
  40,60,"سيدخلون:1- مبنيا للفاعل، وهى قراءة جمهور السبعة، والحسن، وشيبة.وقرئ:2- مبنيا للمفعول، وهى قراءة زيد بن على، وابن كثير، وأبى جعفر."
  40,61,""
  40,62,"خالق:1- بالرفع، وهى قراءة الجمهور.وقرئ:2- بالنصب، وهى قراءة زيد بن على.تؤفكون:1- بتاء الخطاب، وهى قراءة الجمهور.وقرئ:2- بياء الغيبة، وهى قراءة طلحة، فى رواية."
  40,63,""
  40,64,"صوركم:1- بضم الصاد، وهى قراءة الجمهور.وقرئ:2- بكسرها، قرارا من الضمة قبل الواو استثقالا، وهى قراءة الأعمش، وأبى زيد."
  40,65,""
  40,66,"40:65"
  40,67,"40:65"
  40,68,"40:65"
  40,69,"40:65"
  40,70,"40:65"
  40,71,"والسلاسل ... يسحبون:1- بنصب «والسلاسل» ، وبناء «يسحبون» للفاعل، وهى قراءة ابن مسعود، وابن عباس، وزيد بن على، وابن وثاب."
  40,72,""
  40,73,"40:72"
  40,74,"40:72"
  40,75,"40:72"
  40,76,"40:72"
  40,77,"يرجعون:1- بياء الغيبة، مبنيا للمفعول، وهى قراءة الجمهور.وقرئ:2- بفتح الياء، وهى قراءة أبى عبد الرحمن، ويعقوب.3- بتاء الخطاب، مفتوحة، وهى قراءة طلحة بن مصرف، ويعقوب، فى رواية الوليد بن حسان."
  40,78,""
  40,79,"40:78"
  40,80,"40:78"
