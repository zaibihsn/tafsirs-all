tafsir[59]{c,v,t}:
  44,1,""
  44,2,"44:1"
  44,3,"44:1"
  44,4,"يفرق:وقرئ:1- بفتح الياء وضم الراء، و «كل» بالنصب، أي: يفرق الله، وهى قراءة الحسن، والأعرج، والأعمش.2- نفرق، بالنون، و «كل» بالنصب. وهى قراءة زيد بن على.3- يفرق، بفتح الياء وكسر الراء. ونصب «كل» .4- يفرق، بالتشديد، مبنيا للمفعول، وهى قراءة الحسن، وزائدة، عن الأعمش."
  44,5,""
  44,6,"رحمة:وقرئ:بالرفع، أي: تلك رحمة، وهى قراءة زيد بن على، والحسن."
  44,7,"رب:1- بالخفض، بدلا من «ربك» ، وهى قراءة ابن محيصن، والأعمش، وأبى حيوة، والكوفيين.وقرئ:2- بالرفع، على القطع، وهى قراءة باقى السبعة، والأعرج، وابن أبى إسحاق، وأبى جعفر، وشيبة."
  44,8,"ربكم ورب:1- برفعهما، وهى قراءة الجمهور.وقرئ:2- بالجر، فيهما، وهى قراءة ابن أبى إسحاق، وابن محيصن، وأبى حيوة، والزعفراني، وابن مقسم، وأبى موسى عيسى بن سليمان، وصالح الناقط، كلاهما عن الكسائي.3- بالنصب، فيهما، على المدح، وهى قراءة بن جبير."
  44,9,""
  44,10,"44:9"
  44,11,"44:9"
  44,12,"44:9"
  44,13,"44:9"
  44,14,"44:9"
  44,15,"44:9"
  44,16,"نبطش:1- بفتح النون وكسر الطاء، وهى قراءة الجمهور.وقرئ:2- بفتح النون وضم الطاء، وهى قراءة الحسن، وأبى جعفر.3- بضم النون وكسر الطاء، أي: نسلط عليهم، وهى قراءة الحسن أيضا، وأبى رجاء، وطلحة."
  44,17,"فتنا:وقرئ:بتشديد التاء، للمبالغة."
  44,18,"إنى:1- بكسر الهمزة، وهى قراءة الجمهور.وقرئ:2- بفتح الهمزة."
  44,19,""
  44,20,"عذت:وقرئ:بالإدغام."
  44,21,""
  44,22,"أن هؤلاء:1- بفتح الهمزة، وهى قراءة الجمهور.وقرئ:2- بكسرها، وهى قراءة ابن أبى إسحاق، وعيسى، والحسن."
  44,23,""
  44,24,"44:23"
  44,25,"44:23"
  44,26,"ومقام:1- بفتح الميم، وهى قراءة الجمهور.وقرئ:2- بضمها، وهى قراءة ابن هرمز، وقتادة، وابن السميفع، ونافع، فى رواية خارجة."
  44,27,"ونعمة:وقرئ:بالنصب، وهى قراءة أبى رجاء.فاكهين:1- بألف، وهى قراءة الجمهور.وقرئ:2- بغير ألف، وهى قراءة أبى رجاء، والحسن."
  44,28,""
  44,29,"44:28"
  44,30,"44:28"
  44,31,"44:28"
  44,32,"44:28"
  44,33,"44:28"
  44,34,"44:28"
  44,35,"44:28"
  44,36,"44:28"
  44,37,"44:28"
  44,38,"وما بينهما:1- وهى قراءة الجمهور.وقرئ:2- وما بينهن، وهى قراءة عبيد بن عميس."
  44,39,""
  44,40,"ميقاتهم:وقرئ:بالنصب، على أنه اسم «إن» ، والخبر، «يوم الفصل»."
  44,41,""
  44,42,"44:41"
  44,43,"44:41"
  44,44,"44:41"
  44,45,"يغلى:1- بالياء، أي: الطعام، وهى قراءة مجاهد، وقتادة، والحسن، والابنين، وحفص.وقرئ:2- بالتاء، أي: الشجرة، وهى قراءة عمرو بن ميمون، وأبى رزين، والأعرج، وأبى جعفر، وشيبة، وابن محيصن، وطلحة، والحسن فى رواية، وباقى السبعة."
  44,46,""
  44,47,"فاعتلوه:1- بكسر التاء، وهى قراءة الجمهور.وقرئ:2- بضمها، وهى قراءة زيد بن على، والابنين، ونافع."
  44,48,""
  44,49,"إنك:1- بكسر الهمزة.وقرئ:2- بفتحها، وهى قراءة الحسن بن على بن أبى طالب، والكسائي."
  44,50,""
  44,51,"مقام:وقرئ:1- بضم الميم، وهى قراءة عبد الله بن عمر، وزيد بن على، وأبى جعفر، وشيبه، والأعرج، والحسن، وقتادة، ونافع، وابن عامر.2- بفتحها، وهى قراءة أبى رجاء، وعيسى، ويحيى، والأعمش، وباقى السبعة."
  44,52,""
  44,53,"44:52"
  44,54,"بحور:1- منونا، وهى قراءة الجمهور.وقرئ:2- بغير تنوين، وهى قراءة عكرمة."
  44,55,""
  44,56,"لا يذوقون:وقرئ:لا يذاقون، مبنيا للمفعول، وهى قراءة عبيد بن عمير.ووقاهم:وقرئ:مشدد القاف، وهى قراءة أبى حيوة."
  44,57,""
  44,58,"44:57"
  44,59,"44:57"
