tafsir[123]{c,v,t}:
  11,1,"فصلت:قرئ:فصلت، بفتحتين، خفيفة، على لزوم الفعل للآيات، وهى قراءة عكرمة، والضحاك، والجحدري، وزيد بن على، وابن كثير."
  11,2,""
  11,3,"يمتعكم:قرئ:يمتعكم، بالتخفيف، من «أمتع» ، وهى قراءة الحسن، وابن هرمز، وزيد بن على، وابن محيصن.تولوا:قرئ:1- بضم التاء واللام وفتح الواو، مضارع «ولى» ، وهى قراءة اليماني، وعيسى بن عمر.2- بضم التاء واللام وسكون الواو، مضارع «أولى» ، وهى قراءة الأعرج."
  11,4,""
  11,5,"يثنون:1- بفتح الياء، مضارع «ثنى» ، وهى قراءة الجمهور.وقرئ:2- بضمها، مضارع «أثنى» ، و «صدورهم» بالرفع، وهى قراءة سعيد بن جبير.3- تثنونى، مضارع «اثنونى» ، و «صدورهم» بالرفع، وهى قراءة ابن عباس، وعلى بن الحسين، وابناه: زيد ومحمد، وابنه جعفر، ومجاهد، وابن يعمر، ونصر بن عاصم، وعبد الرحمن بن أبزى، والجحدري، وابن أبى إسحاق، وأبى الأسود الدؤلي، وأبى رزين، والضحاك.4- يثنونى، بالياء، و «صدورهم» بالرفع، وهى قراءة ابن عباس أيضا، ومجاهد، وابن يعمر، وابن أبى إسحاق.ألا حين يستغشون:وقرئ:على حين يستغشون، وهى قراءة ابن عباس."
  11,6,""
  11,7,"إنكم:وقرئ:أنكم، بفتح الهمزة.سحر:وقرئ:ساحر، وهى قراءة فرقة."
  11,8,""
  11,9,"11:8"
  11,10,"لفرح:1- بكسر الراء، وهى قراءة الجمهور.وقرئ:2- بضم الراء، وهى قراءة فرقة."
  11,11,""
  11,12,"11:11"
  11,13,"11:11"
  11,14,"أنزل:وقرئ:نزل، بفتح النون والزاى وتشديدهما، وهى قراءة زيد بن على."
  11,15,"نوف:1- بالنون، وهى قراءة الجمهور.وقرئ:2- بالياء، على الغيبة، وهى قراءة طلحة بن ميمون.3- يوف، مضارع «أوفى» ، وهى قراءة زيد بن على.4- نوفى، بالتخفيف وإثبات الياء، وهى قراءة الحسن."
  11,16,"وباطل:وقرئ:1- وبطل، على أنه فعل ماض، وهى قراءة زيد بن على.2- وباطلا، بالنصب، على أنه خبر «كان» مقدم، وهى قراءة أبى، وابن مسعود."
  11,17,"كتاب موسى:وقرئ:بالنصب، وهى قراءة محمد بن السائب الكلبي."
  11,18,""
  11,19,"11:18"
  11,20,"11:18"
  11,21,"11:18"
  11,22,"11:18"
  11,23,"11:18"
  11,24,"11:18"
  11,25,"إنى:قرئ:1- بفتح الهمزة، أي: بأنى، وهى قراءة النحويين، وابن كثير.2- بكسرها، على إضمار القول، وهى قراءة ابن كثير."
  11,26,""
  11,27,"بادى الرأى:قرئ:1- بادئ الرأى، من «بدأ» أي: أول الرأى، وهى قراءة أبى عمرو، وعيسى الثقفي.2- بادى الرأى، بالياء، ومعناه: ظاهر الرأى، وهى قراءة باقى السبعة."
  11,28,"فعميت:قرئ:1- فعميت، بضم العين وتشديد الميم، مبنيا للمفعول، وهى قراءة الأخوين، وحفص.2- فعميت، بفتح العين وتخفيف الميم، مبنيا للفاعل، وهى قراءة باقى السبعة.3- فعماها، وهى قراءة أبى، وعلى، والسلمى، والحسن، والأعمش.4- وعميت، بالواو، خفيفة، وهى قراءة ابن وثاب."
  11,29,""
  11,30,"11:29"
  11,31,"11:29"
  11,32,"فأكثرت جدالنا:وقرئ:فأكثرت جدلنا، وهى قراءة ابن عباس."
  11,33,""
  11,34,"نصحى:قرئ:1- بفتح النون، مصدر، وهى قراءة عيسى بن عمر الثقفي.2- بضم النون، مصدر، أو اسم، وهى قراءة الجماعة."
  11,35,""
  11,36,"وأوحى إلى نوح أنه:قرئ:1- أوحى، مبنيا للمفعول، و «أنه» بفتح الهمزة، وهى قراءة الجمهور.2- أوحى، مبنيا للفاعل، و «إنه» بكسر الهمزة، على إضمار القول، وهى قراءة أبو البرهسم."
  11,37,""
  11,38,"11:37"
  11,39,"11:37"
  11,40,"11:37"
  11,41,"مجراها:قرئ:1- بضم الميم، وهى قراءة مجاهد، والحسن، وأبى رجاء، والأعرج، وشعبة، والجمهور من السبعة، والحرميين، والعربيين، وأبى بكر.2- بفتحها، وهى قراءة الأخوين، وحفص، وابن مسعود، وعيسى الثقفي، وزيد بن على، والأعمش.3- مجريها، اسم فاعل، من «أجرى» ، وهى قراءة الضحاك، والنخعي، وابن وثاب، وأبى رجاء، ومجاهد، وابن جندب، والكلبي، والجحدري.مرساها:قرئ:1- بفتح الميم، مع فتح ميم «مجراها» وهى قراءة ابن مسعود، وعيسى الثقفي، وزيد بن على، والأعمش.2- بضمها، اسم فاعل من «أجرى» ، وهى قراءة الضحاك، والنخعي، وابن وثاب، وأبى رجاء، ومجاهد وابن جندب، والكلبي، والجحدري."
  11,42,"نوح:وقرئ:1- بكسر التنوين، وهى قراءة الجمهور.2- بضمه، على إتباع حركته حركة الإعراب فى الحاء، وهى قراءة وكيع بن الجراح.ابنه وكان:قرئ:1- بوصل الهاء بالواو، وهى قراءة الجمهور.2- بسكون الهاء، وهى قراءة ابن عباس.3- ابناه، بألف وهاء السكت، وهى قراءة السدى.4- ابنها، بفتح الهاء وألف، أي ابن امرأته، وهى قراءة على، وعروة."
  11,43,""
  11,44,"الجودي:وقرئ:بسكون الياء، مخففة، وهى قراءة الأعمش، وابن أبى عبلة."
  11,45,""
  11,46,"عمل غير صالح:وقرئ:على أنه فعل، نصب «غير صالح» ، وهى قراءة على، وأنس، وابن عباس، وعائشة.فلا تسألن:قرئ:1- تسألن، بتشديد النون مكسورة، وهى قراءة الصاحبين.2- تسألنى، بتشديد النون مكسورة، وإثبات الياء، وهى قراءة أبى جعفر، وشيبة، وزيد بن على.3- تسألن، بتشديد النون مفتوحة، وهى قراءة ابن عباس.4- تسالنى، من غير همز، من سال يسال، وهى قراءة الحسن، وابن أبى مليكة.5- تسألن، بالهمز وإسكان اللام وكسر النون وتخفيفا، وأثبت الياء فى الوصل ورش وأبو عمرو، وحذفها الباقون، وهى قراءة باقى السبعة."
  11,47,""
  11,48,"11:47"
  11,49,"11:47"
  11,50,"غيره:وقرئ:بالخفض، وهى قراءة الكسائي.يا قوم:وقرئ:بضم الميم، وهى قراءة ابن محيصن."
  11,51,""
  11,52,"11:51"
  11,53,"11:51"
  11,54,"11:51"
  11,55,"11:51"
  11,56,"11:51"
  11,57,"فإن تولوا:1- تولوا، أي تتولوا، مضارع تولى، وهى قراءة الجمهور.وقرئ:2- تولوا، بضم التاء واللام، مضارع «ولى» ، وهى قراءة الأعرج، وعيسى الثقفي.ويستخلف:1- بضم الفاء، على معنى الخبر المستأنف، وهى قراءة الجمهور.وقرئ:2- يجزمها، عطفا على موضع الجزاء، وهى قراءة حفص.ولا تضرونه:1- بالرفع، وهى قراءة الجمهور.وقرئ:2- ولا تضروه، بالجزم، وهى قراءة عبد الله."
  11,58,""
  11,59,"11:58"
  11,60,"11:58"
  11,61,"ثمود:1- على منع الصرف، وهى قراءة الجمهور.وقرئ:2- بالصرف، على إرادة الحي، وهى قراءة ابن وثاب، والأعمش."
  11,62,""
  11,63,"11:62"
  11,64,"11:62"
  11,65,"11:62"
  11,66,"ومن خزى يومئذ:1- بالإضافة، وهى قراءة الجمهور.وقرئ:2- من خزى، بالتنوين، ونصب «يومئذ» على الظرف، معمولا ل «خزى» ، وهى قراءة طلحة، وأبان بن ثعلب.يؤمئذ:وقرئ:1- بفتح الميم، وهى فتحة بناء، لإضافته إلى «إذ» ، وهو غير متمكن، وهى قراءة نافع، والكسائي.2- بكسر الميم، وهى حركة إعراب، وهى قراءة باقى السبعة."
  11,67,""
  11,68,"11:67"
  11,69,"سلام:وقرئ:سلم، وهى قراءة الأخوين. والسلم: السلام، كحرم وحرام."
  11,70,""
  11,71,"يعقوب.قرئ:1- بالرفع، على الابتداء، وهى قراءة الحرميين، والنحويين، وأبى بكر.2- بالنصب، وهى قراءة ابن عامر، وحمزة، وحفص، وزيد بن على."
  11,72,""
  11,73,"11:72"
  11,74,"11:72"
  11,75,"11:72"
  11,76,"آتيهم:وقرئ:آتاهم، بلفظ الماضي، وهى قراءة عمرو بن هرم."
  11,77,""
  11,78,"يهرعون:1- يهرعون، مبنيا للمفعول، من «أهرع» أي: يهرعهم الطمع، وهى قراءة الجمهور.وقرئ:2- يهرعون، بفتح الياء، من «هرع» ، وهى قراءة فرقة.أطهر:1- بالرفع، وهى قراءة الجمهور.وقرئ:2- بالنصب، وهى قراءة الحسن، وزيد بن على، وعيسى بن عمر، وسعيد بن جبير، ومحمد بن مروان السعدي وقال سيبويه: هو لحن."
  11,79,""
  11,80,"أو آوى:وقرئ:بنصب الياء على إضمار «أن» بعد «أو» ، وهى قراءة شيبة، وأبى جعفر."
  11,81,"فأسر:وقرئ:1- بوصل الألف، من سرى، وهى قراءة الحرميين.2- بقطعها، وهى قراءة باقى السبعة.إلا امرأتك:قرئ:1- بالرفع، وهى قراءة ابن كثير، وأبى عمرو.2- بالنصب، وهى قراءة باقى السبعة.الصبح:وقرئ:بضم الباء، وهى لغة، وبها قرأ عيسى بن عمر."
  11,82,""
  11,83,"11:82"
  11,84,"11:82"
  11,85,"11:82"
  11,86,"بقية:وقرئ:1- بتخفيف الياء، وهى قراءة إسماعيل بن جعفر.2- تقية، بالتاء، وهى قراءة الحسن."
  11,87,"أصلواتك:وقرئ:1- على التوحيد، وهى قراءة ابن وثاب، والأخوين.وأن نفعل ... ما نشاء:1- بالنون فيهما، وهى قراءة الجمهور.وقرئا:2- بالتاء فيهما، على الخطاب، وهى قراءة الضحاك بن قيس، وابن أبى عبلة، وزيد بن على.3- بالنون فى الأول والتاء، فى الثاني، وهى قراءة أبى عبد الرحمن، وطلحة."
  11,88,""
  11,89,"لا يجرمنكم:وقرئ:بضم الياء، من «أجرم» ، وهى قراءة ابن وثاب، والأعمش.مثل:وقرئ:بفتح اللام، على أن تكون الفتحة فتحة بناء، أو تكون فتحة إعراب، أو انتصب على أنه نعت لمصدر محذوف، وهى قراءة مجاهد، والجحدري، وابن أبى إسحاق."
  11,90,""
  11,91,"11:90"
  11,92,"11:90"
  11,93,"11:90"
  11,94,"11:90"
  11,95,"بعدت:قرئ:1- بعدت، بضم العين، من «البعد» الذي هو ضد القرب، وهى قراءة السلمى، وأبى حيوة.2- بعدت، بكسرها، وهى قراءة الجمهور."
  11,96,""
  11,97,"11:96"
  11,98,"11:96"
  11,99,"11:96"
  11,100,"11:96"
  11,101,"11:96"
  11,102,"وكذلك أخذ ربكم إذا أخذ:وقرئ:إذ أخذ، وهى قراءة أبى رجاء، والجحدري.وكذلك أخذ ربك إذ أخذ، على أن «أخذ ربك» ، فعل وفاعل، و «إذ» ظرف لما مضى، وهى قراءة أبى رجاء، والجحدري."
  11,103,""
  11,104,"وما نؤخره:وقرئ:وما يؤخره، بالياء، وهى قراءة الأعمش."
  11,105,"يأت:قرئ:1- بإثبات الياء وصلا وحذفها وقفا، وهى قراءة النحويين، ونافع.2- بإثباتها وصلا ووقفا، وهى قراءة ابن كثير.3- بحذفها وصلا ووقفا، وهى قراءة باقى السبعة."
  11,106,"شقوا:وقرئ:1- بضم الشين، وهى قراءة الحسن.2- بفتح الشين، وهى قراءة الجمهور."
  11,107,""
  11,108,"سعدوا:وقرئ:1- بضم السين، وهى قراءة ابن مسعود، وطلحة بن مصرف، وابن وثاب، والأعمش، وحمزة، والكسائي، وحفص.2- بفتحها، وهى قراءة باقى السبعة."
  11,109,""
  11,110,"11:109"
  11,111,"إن:قرئ:1- بتخفيف النون ساكنة، وهى قراءة الحرميين، وأبى بكر.2- بتشديدها، وهى قراءة ابن عامر، وحمزة، وحفص.لما:قرئ:1- بتشديدها، وهى قراءة ابن عامر، وعاصم، وحمزة.2- بتخفيفها، وهى قراءة الحرميين.3- لما، بتشديد الميم وتنوينها، وهى قراءة الزهري، وسليمان بن أرقم."
  11,112,"تعملون:وقرئ:يعملون، بالياء، على الغيبة، وهى قراءة الحسن، والأعمش."
  11,113,"تركنوا:قرئ:1- بفتح الكاف، والماضي: ركن، بكسرها، وهى قراءة لجمهور.2- بضم الكاف، ماضى: ركن، بفتحها، وهى لغة قيس، وتميم، وبها قرأ قتادة، وطلحة، والأشهب.3- تركنوا، مبنيا للمفعول، من: أركنه، إذا أماله، وهى قراءة ابن أبى عبلة.4- تركنوا، بكسر التاء، على لغة تميم، وهى قراءة أبى عمرو.فتمسكم:وقرئ:بكسر التاء، على لغة تميم، وهى قراءة ابن وثاب، وعلقمة، والأعمش، وابن مصرف، وحمزة.ثم لا تنصرون:وقرئ:ثم لا تنصروا، بحذف النون، والفعل منصوب، عطفا على قوله «فتمسكم» ، وهى قراءة زيد بن على."
  11,114,"زلفا:1- بفتح اللام، وهى قراءة الجمهور.وقرئ:2- زلفى، على وزن فعلى، وهى قراءة ابن محيصن، ومجاهد.3- زلفا، بضم اللام، كأنه اسم مفرد، وهى قراءة طلحة، وعيسى، وابن أبى إسحاق، وأبى جعفر.4- زلفا، بإسكان اللام، وهى قراءة ابن محيصن، ومجاهد أيضا."
  11,115,""
  11,116,"بقية:وقرئ:1- بقية، بتخفيف الياء، اسم فاعل من «بقي» ، نحو: شجى، فهى شجية، وهى قراءة قرقة.2- بقية، بضم الياء وسكون القاف، وهى قراءة أبى جعفر، وشيبة.3- بقية، بفتح الياء، على وزن «فعلة» للمرة.إلا قليلا:وقرئ:إلا قليل، بالرفع، وهى قراءة زيد بن على."
  11,117,""
  11,118,"11:117"
  11,119,"11:117"
  11,120,"11:117"
  11,121,"11:117"
  11,122,"11:117"
  11,123,"تعملون:قرئ:1- بتاء الخطاب، وهى قراءة الصاحبين، وحفص، وقتادة، والأعرج، وشيبة، وأبى جعفر، والجحدري.2- بالياء، على الغيبة، وهى قراءة باقى السبعة."
