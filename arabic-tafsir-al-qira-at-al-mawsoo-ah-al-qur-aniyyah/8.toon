tafsir[75]{c,v,t}:
  8,1,"عن الأنفال:وقرئ:أنفال، بنقل حركة الهمزة إلى لام التعريف، وحذف الهمزة والاعتداد بالحركة والإدغام، وهى قراءة، ابن محيصن."
  8,2,"وجلت:وقرئ:بفتح الجيم، وهى لغة."
  8,3,""
  8,4,"8:3"
  8,5,"8:3"
  8,6,"ما تبين:وقرئ:ما بين، بضم الياء من غير تاء، وهى قراءة عبد الله."
  8,7,"يعدكم:وقرئ:يعدكم، بسكون الدال لتوالى الحركات، وهى قراءة مسلمة بن محارب.إحدى:وقرئ:أحد، على التذكير، إذ تأنيث «الطائفة» مجاز، وهى قراءة ابن محيصن.بكلماته:وقرئ:بكلمته، على التوحيد، وهى قراءة مسلم بن محارب."
  8,8,""
  8,9,"أنى:1- بالفتح، وهى قراءة الجمهور أي: بأنى.وقرئ:2- بالكسر، على إضمار القول، وهى قراءة عيسى بن عمر.بألف:1- على التوحيد، وهى قراءة الجمهور.وقرئ:2- بآلف، على وزن «أفلس» ، وهى قراءة الجحدري.مردفين:قرئ:1- مردفين، بفتح الدال، وهى قراءة نافع، وجماعة من أهل المدينة.2- مردفين، بكسر الدال، وهى قراءة باقى السبعة، والحسن، ومجاهد.3- مردفين، بفتح الراء وكسر الدال مشددة، وهى قراءة بعض المكيين."
  8,10,""
  8,11,"يغشيكم:قرئ:1- يغشاكم، مضارع «غشى» ، وهى قراءة مجاهد، وابن محيصن، وأبى عمرو، وابن كثير.2- يغشيكم، مضارع «أغشى» ، وهى قراءة الأعرج، وابن نصاح، وأبى حفص، ونافع.3- يغشّيكم، مضارع «غشى» ، وهى قراءة عروة بن الزبير، ومجاهد، والحسن، وعكرمة، وأبى رجاء، وابن عامر، والكوفيين.ماء:1- بالمد، وهى قراءة الجمهور.وقرئ:2- ما، بغير همز، وهى قراءة الشعبي، على أن تكون «ما» موصلة، وصلتها حرف الجر بما جره، فكأنه قال: ما للطهور، وقيل: هى ماء، وحذفت همزته.ليطهركم:وقرئ:يطهركم، بسكون الطاء، وهى قراءة ابن المسيب.ويذهب:قرئ:ويذهب: بجزم الباء، وهى قراءة عيسى بن عمر.رجز:وقرئ:1- رجز، بضم الراء، وهى قراءة ابن محيصن.2- رجس، بالسين، وهى قراءة أبى العالية."
  8,12,"أنى معكم:وقرئ:إنى معكم، بكسر الهمزة، على إضمار القول، وهى قراءة عيسى بن عمر.الرعب:وقرئ:الرعب، بضم العين، وهى قراءة ابن عامر، والكسائي، والأعرج."
  8,13,"يشاقق:الإجماع على الفك، اتباعا لخط المصحف، وهى لغة الحجاز، والإدغام لغة تميم."
  8,14,"وأن:وقرئ:وإن، بكسر الهمزة، على استئناف الإخبار، وهى قراءة الحسن، وزيد بن على، وسليمان التيمي."
  8,15,""
  8,16,"دبره:وقرئ:دبره، بسكون الباء، وهى قراءة الحسن."
  8,17,""
  8,18,"موهن:قرئ:1- موهّن، من «وهّن» بالتشديد، وهى قراءة الحرميين، وأبى عمرو.2- موهن، من «أوهن» ، وهى قراءة باقى السبعة، وأبى رجاء، والأعمش، وابن محيصن."
  8,19,"وأن الله:قرئ:1- بفتح الهمزة، وهى قراءة الصاحبين، وحفص.2- بكسر الهمزة، وهى قراءة باقى السبعة.3- والله، وهى قراءة ابن مسعود."
  8,20,""
  8,21,"8:20"
  8,22,"8:20"
  8,23,"8:20"
  8,24,"المرء:وقرئ:1- المرء، بكسر الميم، اتباعا لحركة الإعراب، وهى قراءة ابن أبى إسحاق.2- المرء، بتشديد الراء من غير همز، وهى قراءة الحسن."
  8,25,"لا تصيبن:وقرئ:لتصيبن، وهى قراءة ابن مسعود، وعلى، وزيد بن ثابت، والباقر، والربيع بن أنس، وأبى العالية."
  8,26,""
  8,27,"أماناتكم:وقرئ:أمانتكم، على التوحيد، وهى قراءة مجاهد."
  8,28,""
  8,29,"8:28"
  8,30,"8:28"
  8,31,"8:28"
  8,32,"هو الحق:قرئ:1- بالنصب، و «هو» ضمير فصل، وهى قراءة الجمهور.2- بالرفع، وهى قراءة الأعمش، وزيد بن على."
  8,33,""
  8,34,"8:33"
  8,35,"صلاتهم:وقرئ:صلاتهم، بالنصب، ورفع «مكاء» و «تصدية» ، وهى قراءة أبان بن تغلب، والأعمش، بخلاف عنهما.مكاء:وقرئ:مكا، بالقصر، منونا، وهى قراءة أبى عمرو."
  8,36,""
  8,37,"8:36"
  8,38,"إن ينتهوا نغفر لهم:وقرئا:1- إن تنتهوا نغفر لكم، وهى قراءة ابن مسعود.2- إن تنتهوا يغفر، مبنيا للفاعل، والضمير لله تعالى."
  8,39,""
  8,40,"8:39"
  8,41,"فأن لله:قرئ:فإن لله، بكسر الهمزة، وهى قراءة الجعفي، عن هارون عن أبى.خمسه:وقرئ:1- خمسه، بسكون الميم، وهى قراءة الحسن، وعبد الوارث عن أبى عمرو.2- خمسه، بكسر الخاء، على الإتباع، وهى قراءة النخعي."
  8,42,"أسفل:وقرئ:أسفل، بالرفع، وهى قراءة زيد بن على.ليهلك:وقرئ:بفتح اللام، وهى قراءة الأعمش، وعصمة.حى:قرئ:1- حيى، بالفك، وهى قراءة نافع، والبزي، وأبى بكر.2- حى، بالإدغام، وهى قراءة باقى السبعة."
  8,43,""
  8,44,"8:43"
  8,45,"8:43"
  8,46,"وتذهب:وقرئ:1- ويذهب، بالياء، وجزم الباء، وهى قراءة عيسى بن عمر.2- ويذهب، بالياء، ونصب الباء، وهى قراءة أبى حيوة، وأبان، وعصمة.فتفشلوا:وقرئ:فتفشلوا، بكسر الشين، وهى قراءة الحسن، وإبراهيم."
  8,47,""
  8,48,"8:47"
  8,49,"8:47"
  8,50,"يتوفى:وقرئ:تتوفى، بالتاء، وهى قراءة ابن عامر، والأعرج."
  8,51,""
  8,52,"8:51"
  8,53,"8:51"
  8,54,"8:51"
  8,55,"8:51"
  8,56,"8:51"
  8,57,"فشرد:وقرئ:فشرذ، بالذال، أي: ففرق، وهى قراءة الأعمش، وكذا فى مصحف عبد الله.من خلفهم:وقرئ:من خلفهم، جارا ومجرورا، ومفعول «فشرد» محذوف، أي: ناسا من خلفهم، وهى قراءة أبى حيوة، والأعمش."
  8,58,"سواء:وقرئ:سواء، بكسر السين، وهى قراءة زيد بن على."
  8,59,"ولا يحسبن:1- بالياء، وهى قراءة ابن عامر، وحمزة، وحفص.وقرئ:2- بالتاء، وهى قراءة باقى السبعة.3- ولا يحسب، بفتح السين والياء وحذف النون، وهى قراءة الأعمش.لا يعجزون:وقرئ:1- لا يعجزونى، بكسر النون وياء بعدها، وهى قراءة ابن محيصن.4- لا يعجزون، بكسر النون من غير تشديد ولا ياء، وهى قراءة طلحة."
  8,60,"رباط:وقرئ:1- ربط، بضم الراء والباء، وهى قراءة الحسن، وأبى حيوة، وعمرو بن دينار.2- ربط، بضم الراء وسكون الباء، ورويت أيضا عن الحسن، وأبى حيوة.ترهبون:وقرئ:ترهبون، مشددا، وهى قراءة الحسن، ويعقوب، وابن عقيل."
  8,61,""
  8,62,"8:61"
  8,63,"8:61"
  8,64,"8:61"
  8,65,"حرض:وقرئ:حرص، بالصاد المهملة، وهو من الحرص، وهى قراءة الأعمش.إن يكن ... وإن يكن:قرئا:1- على التذكير فيهما، وهى قراءة الكوفيين.2- على التأنيث، وهى قراءة الحرميين، وابن عامر.3- على التذكير، فى الأولى، لقوله تعالى «ويغلب» ، وعلى التأنيث فى الثانية لقوله تعالى «صابرة» ."
  8,66,"علم:وقرئ:علم، مبنيا للمفعول، وهى قراءة المفضل، عن عاصم.ضعفا:وقرئ:1- ضعفا، بالضم، وهى قراءة عيسى بن عمر.2- ضعفاء، جمع ضعيف، وهى قراءة ابن القعقاع."
  8,67,"أن يكون:1- على التذكير، على المعنى، وهى قراءة الجمهور.وقرئ:2- أن تكون، بالتاء، على تأنيث لفظ الجمع، وهى قراءة أبى عمرو.أسرى:1- أسرى، على وزن «فعلى» ، وهى قراءة الجمهور، والسبعة.وقرئ:2- أسارى، وهى قراءة يزيد بن القعقاع.يثخن:1- بالتخفيف، من «أثخن» ، وهى قراءة الجمهور.وقرئ:2- يثخن، مشددا، وهى قراءة أبى جعفر، ويحيى بن يعمر، ويحيى بن وثاب.تريدون:وقرئ:يريدون، بالياء.الآخرة:قرئت:1- بالنصب، وهى قراءة الجمهور.2- بالجر، وهى قراءة سليمان بن جماز المدني، على تقدير مضاف محذوف والتقدير: عرض الآخرة."
  8,68,""
  8,69,"8:68"
  8,70,"الأسرى:1- بالتعريف، وهى قراءة الجمهور.وقرئ:2- أسرى، بالتنكير، وهى قراءة ابن محيصن.3- الأسارى، وهى قراءة قتادة، وأبى جعفر، وابن أبى إسحاق، ونصر بن عاصم، وأبى عمرو، من السبعة.يؤتكم:وقرئ:يثبكم، من الثواب، وهى قراءة الأعمش.أخذ:وقرئ:أخذ، مبنيا للفاعل، وهى قراءة الحسن، وأبى حيوة، وشيبة، وحميد."
  8,71,""
  8,72,"ولايتهم:قرئ:1- بالكسر، وهى قراءة الأعمش، وابن وثاب، وحمزة.2- بالفتح، وهى قراءة باقى السبعة، والجمهور.تعلمون:قرئ:يعملون، بالياء، على الغيبة، وهى قراءة السلمى، والأعرج."
  8,73,"أولياء بعض:وقرئ:أولى ببعض.كبير:وقرئ:كثير، بالثاء المثلثة، وهى قراءة أبى موسى الحجازي، عن الكسائي."
  8,74,""
  8,75,"8:74"
