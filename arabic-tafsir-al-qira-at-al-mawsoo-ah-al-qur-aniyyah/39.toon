tafsir[75]{c,v,t}:
  39,1,"تنزيل:قرئ:بالنصب، وهى قراءة ابن أبى عبلة، وزيد بن على، وعيسى."
  39,2,"الدين:1- بالنصب، وهى قراءة الجمهور.وقرئ:2- بالرفع، على الفاعلية، وهى قراءة ابن أبى عبلة."
  39,3,"كاذب كفار:وقرئ:1- كذاب كفار، وهى قراءة أنس بن مالك، والجحدري، والحسن، والأعرج، وابن يعمر.2- كذوب كفور، وهى قراءة زيد بن على."
  39,4,""
  39,5,"39:4"
  39,6,"يخلقكم:وقرئ:بإدغام القاف فى الكاف، وهى قراءة عيسى، وطلحة."
  39,7,"يرضه:وقرئ:1- بوصل ضمة الهاء بواو، وهى قراءة النحويين، وابن كثير.2- بضمة، فقط، وهى قراءة ابن عامر، وحفص.3- بسكون الهاء، وهى لغة لبنى كلاب، وهى قراءة أبى بكر."
  39,8,"ليضل:1- بضم الياء، وهى قراءة الجمهور.وقرئ:2- بفتحها، وهى قراءة ابن كثير، وأبى عمرو، وعيسى."
  39,9,"أمن:وقرئ:1- بتخفيف الميم، وهى قراءة ابن كثير، ونافع، وحمزة، والأعمش، وعيسى، وشيبة، والحسن.2- بتشديد الميم، وهى «أم» أدغمت فى ميم «من» ، وهى قراءة باقى السبعة وقتادة، والأعرج، وأبى جعفر.ساجدا وقائما:1- بنصبهما على الحال، وهى قراءة الجمهور.وقرئا:2- برفعهما، إما على النعت ل «قانت» ، وإما على أنه خبر بعد خبر، والواو للجمع بين الصفتين، وهى قراءة الضحاك.يتذكر:وقرئ:يذكر، بإدغام التاء فى الذال."
  39,10,""
  39,11,"39:10"
  39,12,"39:10"
  39,13,"39:10"
  39,14,"39:10"
  39,15,"39:10"
  39,16,"39:10"
  39,17,"الطاغوت:وقرئ:الطواغيت، جمعا، وهى قراءة الحسن."
  39,18,""
  39,19,"39:18"
  39,20,"39:18"
  39,21,"يجعله:وقرئ:بالنصب، وهى قراءة أبى بشر.وقال صاحب «الكامل» : هو ضعيف."
  39,22,""
  39,23,"مثانى:1- بفتح الياء، وهى قراءة الجمهور.وقرئ:2- بسكونها، وهى قراءة هشام، وابن عامر، وأبى بشر."
  39,24,""
  39,25,"39:24"
  39,26,"39:24"
  39,27,"39:24"
  39,28,"39:24"
  39,29,"سلما:قرئ:1- سالما، اسم فاعل، أي خالصا من الشركة، وهى قراءة عبد الله، وابن عباس، وعكرمة، ومجاهد، وقتادة، والزهري، والحسن، بخلاف عنه، والجحدري، وابن كثير، وأبى عمرو.2- سلما، بفتح السين واللام، وهى قراءة الأعرج، وشيبة، وأبى رجاء، وطلحة، والحسن، بخلاف عنه، وباقى السبعة.3- سلما، بكسر السين وسكون اللام، وهى قراءة ابن جبير.4- ورجل سالم، برفعهما.مثلا:وقرئ:مثلين."
  39,30,"ميت ... ميتون:1- وهى قراءة الجمهور.وقرئ:2- مائت ... مائتون، وهى قراءة ابن الزبير، وابن أبى إسحاق، وابن محيصن، وعيسى، واليماني، وابن أبى غوث، وابن أبى عبلة."
  39,31,""
  39,32,"39:31"
  39,33,"وصدق:1- مشددا، وهى قراءة الجمهور.وقرئ:2- مخففا، وهى قراءة أبى صالح، وعكرمة بن سليمان.3- مبنيا للمفعول مشددا."
  39,34,""
  39,35,"39:34"
  39,36,"عبده:1- بالإفراد، وهو رسول الله ﷺ، وهى قراءة الجمهور.وقرئ:2- عباده، بالجمع، أي: الأنبياء والطيبين من المؤمنين، وهى قراءة أبى جعفر، ومجاهد، وابن وثاب، وطلحة، والأعمش، وحمزة، والكسائي."
  39,37,""
  39,38,"كاشفات ... ممسكات:1- على الإضافة، وهى قراءة الجمهور.وقرئا:2- بتنوينهما، ونصب ما بعدهما، وهى قراءة شيبة، والأعرج، وعمرو بن عبيد، وعيسى، بخلاف عنه، وأبى عمرو، وأبى بكر."
  39,39,""
  39,40,"39:39"
  39,41,"39:39"
  39,42,"قضى:1- مبنيا للفاعل، و «الموت» نصبا، وهى قراءة الجمهور.وقرئ:2- مبنيا للمفعول، و «الموت» رفعا، وهى قراءة ابن وثاب، والأعمش، وطلحة، وعيسى، وحمزة، والكسائي."
  39,43,""
  39,44,"39:43"
  39,45,"39:43"
  39,46,"39:43"
  39,47,"39:43"
  39,48,"39:43"
  39,49,"39:43"
  39,50,"39:43"
  39,51,"39:43"
  39,52,"39:43"
  39,53,"39:43"
  39,54,"39:43"
  39,55,"39:43"
  39,56,"يا حسرتا:1- بإبدال ياء المتكلم ألفا، وهى قراءة الجمهور.وقرئ:2- بياء الإضافة، وهى قراءة أبى جعفر.3- بالألف والياء، جمعا بين العوض والمعوض، والياء مفتوحة أو ساكنة، ورويت عن أبى جعفر أيضا.4- يا حسرتاه، بهاء السكت، فى الوقف، وهى قراءة ابن كثير."
  39,57,""
  39,58,"39:57"
  39,59,"جاءتك:1- بفتح الكاف وفتح «تاء» ما بعدها، خطابا للكافر ذى النفس، وهى قراءة الجمهور.وقرئ:2- بكسرها، وكسر «تاء» ما بعدها، والخطاب للنفس، وهى قراءة ابن يعمر، والجحدري، وأبى حيوة، والزعفراني، وابن مقسم، ومسعود بن صالح، والشافعي، عن ابن كثير، ومحمد بن عيسى، فى اختياره، ونصير، والعبسي.3- جئتك، بالهمزة من غير مد، بوزن «بعتك» وهى قراءة الحسن، والأعرج، والأعمش."
  39,60,"وجوههم:وقرئ:أجوههم، بدال الواو همزة، وهى قراءة أبى."
  39,61,"بمفازتهم:1- على الإفراد، وهى قراءة الجمهور.وقرئ:2- على الجمع، وهى قراءة السلمى، والحسن، والأعرج، والأعمش، وحمزة، والكسائي، وأبى بكر."
  39,62,""
  39,63,"39:62"
  39,64,"تأمرونى:1- بإدغام النون فى نون الوقاية وسكون الياء، وهى قراءة الجمهور.وقرئ:2- على القراءة السابقة، مع فتح الياء، وهى قراءة ابن كثير.3- بنونين على الأصل، وهى قراءة ابن عامر.4- بنون واحدة مكسورة، وفتح الياء، وهى قراءة نافع.أعبد:وقرئ:بالنصب على إضمار «أن» ."
  39,65,"ليحبطن:1- مبنيا للفاعل، و «عملك» رفع به، وهى قراءة الجمهور.وقرئ:2- بالياء من «أحبط» ، بالنصب، أي: ليحبطن الله عملك.3- بالنون، من: «أحبط» ، أي: لنحبطن عملك، بالنصب."
  39,66,""
  39,67,"قدروا:وقرئ:بتشديد الدال، وهى قراءة الحسن، وعيسى، وأبى نوفل، وأبى حيوة.قدره:وقرئ:بفتح الدال، وهى قراءة الأعمش.مطويات:وقرئ:بالنصب، على الحال، وهى قراءة عيسى، والجحدري."
  39,68,"الصور:وقرئ:بفتح الواو، جمع صورة، وهى قراءة قتادة، وزيد بن على."
  39,69,"وأشرقت:1- مبينا للفاعل، أي، أضاءت، وهى قراءة الجمهور.وقرئ:2- مبينا للمفعول، من: شرقت بالضوء، تشرق، إذا امتلأت، وهى قراءة ابن عباس، وعبيد بن عمير."
  39,70,""
  39,71,"يأتكم:1- بالياء، وهى قراءة الجمهور.وقرئ:2- تأتكم، بتاء التأنيث، وهى قراءة ابن هرمز."
  39,72,""
