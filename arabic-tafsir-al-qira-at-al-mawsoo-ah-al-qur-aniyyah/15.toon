tafsir[99]{c,v,t}:
  15,1,""
  15,2,"ربما:قرئ:1- بتخفيف الباء، وهى قراءة عاصم، ونافع.2- بتشديدها، وهى قراءة باقى السبعة.3- ربّما، بزيادة تاء، وهى قراءة طلحة بن مصرف، ويزيد بن على."
  15,3,""
  15,4,"15:3"
  15,5,"15:3"
  15,6,"نزل:وقرئ:ماضيا مخففا، مبنيا للفاعل، وهى قراءة زيد بن على."
  15,7,""
  15,8,"ما تنزل:وقرئ:1- ما تنزل، مضارع «تنزل» أي: ما تنزل، و «الملائكة» ، بالرفع، وهى قراءة الحرميين، والعربيين.2- ما تنزل، بضم التاء وفتح النون والزاى، و «الملائكة» بالرفع، وهى قراءة أبى بكر، ويحيى بن وثاب.3- ما تنزل، بضم النون الأولى وفتح الثانية وكسر الزاى، و «الملائكة» بالنصب، وهى قراءة الأخوين، وحفص، وابن مصرف.4- ما نزل، ماضيا، مخففا مبنيا للفاعل، «الملائكة» بالرفع، وهى قراءة زيد بن على."
  15,9,""
  15,10,"15:9"
  15,11,"15:9"
  15,12,"15:9"
  15,13,"15:9"
  15,14,"يعرجون:وقرئ:يعرجون، بكسر الراء، وهى لغة هذيل، وبها قرأ الأعمش، وأبى حيوة."
  15,15,"سكرت:قرئ:1- بتخفيف الكاف، مبنيا للمفعول، وهى قراءة الحسن، ومجاهد، وابن كثير.2- بتشديدها مبنيا للمفعول، وهى قراءة باقى السبعة.3- بفتح السين وكسر الكاف مخففة، مبنيا للفاعل، وهى قراءة الزهري."
  15,16,""
  15,17,"15:16"
  15,18,"15:16"
  15,19,"15:16"
  15,20,"معايش:وقرئ:معائش، بالهمز، وهى قراءة الأعرج، وخارجة عن نافع."
  15,21,""
  15,22,"15:21"
  15,23,"15:21"
  15,24,"15:21"
  15,25,"15:21"
  15,26,"15:21"
  15,27,"والجان:قرئ:والجأن، بالهمز، وهى قراءة الحسن، وعمرو بن عبيد."
  15,28,""
  15,29,"15:28"
  15,30,"15:28"
  15,31,"15:28"
  15,32,"15:28"
  15,33,"15:28"
  15,34,"15:28"
  15,35,"15:28"
  15,36,"15:28"
  15,37,"15:28"
  15,38,"15:28"
  15,39,"15:28"
  15,40,"المخلصين:قرئ:1- بفتح اللام، وهى قراءة الكوفيين، ونافع، والحسن، والأعرج أي: من أخلصته للطاعة أنت فلا يؤثر فيه تزيينى.2- بكسر اللام، وهى قراءة باقى السبعة أي: إلا من أخلص العمل لله ولم يشرك فيه غيره."
  15,41,"على:قرئ:علىّ، أي عال، وهى قراءة الضحاك، وإبراهيم، وأبى رجاء، وابن سيرين، ومجاهد، وقتادة، وقيس بن عباد، وحميد، وعمرو بن ميمون، وعمارة بن أبى حفصة، ويعقوب."
  15,42,""
  15,43,"15:42"
  15,44,"جزء:وقرئ:جزء، بتشديد الزاى من غير همز، ووجهه: أنه حذف الهمزة وألقى حركتها على الزاى ووقف بالتشديد، وهى قراءة ابن القعقاع."
  15,45,"وعيون:قرئ:1- بضم العين، وهى قراءة نافع، وأبى عمرو، وحفص، وهشام.2- بكسرها، وهى قراءة باقى السبعة."
  15,46,"ادخلوها:وقرئ:1- أدخلوها، ماضيا مبنيا للمفعول، من «الإدخال» ، وهى قراءة الحسن.2- ادخلوها، أمر من «الدخول» ، وهى قراءة الجمهور."
  15,47,""
  15,48,"15:47"
  15,49,"15:47"
  15,50,"15:47"
  15,51,"15:47"
  15,52,"15:47"
  15,53,"لا توجل:قرئ:1- مبنيا للفاعل، وهى قراءة الجمهور.2- بضم التاء مبنيا للمفعول، من «الإيجال» ، وهى قراءة الحسن.3- لا تأجل، بإبدال الواو ألفا.4- لا تواجل، من واجله."
  15,54,"أبشر تمونى:وقرئ:بشر تمونى، بغير همزة استفهام، وهى قراءة الأعرج.الكبر:وقرئ:1- بضم الكاف وسكون الباء، وهى قراءة ابن محيصن.تبشرون:وقرئ:1- تبشروني، بنون مشددة وياء المتكلم، أدغم نون الرفع فى نون الوقاية، وهى قراءة الحسن.2- تبشرون، بتشديد النون مكسورة دون ياء، وهى قراءة ابن كثير.3- تبشرون، بكسرها مخففة، وهى قراءة نافع."
  15,55,"القانطين:وقرئ:1- القنطين، من: قنط يقنط، وهى قراءة ابن وثاب، وطلحة، والأعمش."
  15,56,"يقنط:قرئ:1- بكسر النون، وهى قراءة النحويين، والأعمش.2- بفتحها، وهى قراءة باقى السبعة.3- بضمها، وهى قراءة زيد بن على، والأشهب."
  15,57,""
  15,58,"15:57"
  15,59,"لمنجوهم:قرئ:1- بالتخفيف، وهى قراءة الأخوين.2- بالتشديد، وهى قراءة باقى السبعة."
  15,60,"قدرنا:قرئ:1- بالتخفيف، وهى قراءة أبى بكر.2- بالتشديد، وهى قراءة باقى السبعة."
  15,61,""
