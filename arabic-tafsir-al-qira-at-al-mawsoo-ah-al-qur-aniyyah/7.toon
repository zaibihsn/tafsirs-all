  7,85,"7:78"
  7,86,"7:78"
  7,87,"7:78"
  7,88,"7:78"
  7,89,"7:78"
  7,90,"7:78"
  7,91,"7:78"
  7,92,"7:78"
  7,93,"آسى:وقرئ:إيسى، بكسر الهمزة، لغة، وهى قراءة ابن وثاب، وابن مصرف، والأعمش."
  7,94,""
  7,95,"7:94"
  7,96,"لفتحنا:وقرئ:لفتحنا، بتشديد التاء، وهى قراءة ابن عامر، وعيسى الثقفي، وأبى عبد الرحمن."
  7,97,""
  7,98,"أو أمن:وقرئ:أو أمن، بسكون الواو، وجعل «أو» عاطفة، وهى قراءة نافع، والابنين."
  7,99,""
  7,100,"7:99"
  7,101,"7:99"
  7,102,"7:99"
  7,103,"7:99"
  7,104,"7:99"
  7,105,"على:قرئ:1- على، بتشديد الياء، وهى قراءة نافع.2- على، بتخفيفها، وهى قراءة باقى السبعة.3- بإسقاطها، «حقيق أن لا أقول» ، وهى قراءة عبد الله، والأعمش."
  7,106,""
  7,107,"7:106"
  7,108,"7:106"
  7,109,"7:106"
  7,110,"تأمرون:قرئ:1- بفتح النون، وهى قراءة الجمهور.2- بكسرها، وهى قراءة نافع."
  7,111,"أرجه:قرئ:1- أرجئهو، بالهمز وضم الهاء ووصلها بواو، وهى قراءة ابن كثير، وهشام.2- أرجئه، بالهمز وضم الهاء، وهى قراءة أبى عمرو.3- أرجهى، بغير همز، وبكسر الهاء ووصلها بياء، وهى قراءة ورش، والكسائي.4- أرجه، بغير همز وإسكان الهاء، وهى قراءة عاصم، وحمزة.5- أرجه، بغير همز واختلاس كسرة الهاء."
  7,112,"سحار:قرئ:ساحر، وهى قراءة الأخوين."
  7,113,"إن لنا لأجرا:قرئ:1- إن، على الخبر، وهى قراءة الحرميين، وحفص.2- إن، على الاستفهام، حذفت منه الهمزة.3- أن، بإثبات همزة الاستفهام محققة أو مسهلة، وهى قراءة الأخوين، وابن عامر، وأبى بكر، وأبى عمرو."
  7,114,""
  7,115,"7:114"
  7,116,"7:114"
  7,117,"تلقف:قرئ:1- تلقف، بسكون اللام، من لقف، وهى قراءة حفص.2- تلقف، مضارع تلقف، حذفت إحدى التاءين، وهى قراءة باقى السبعة.3- بإدغام تاء المضارعة فى التاء الأصلية، وهى قراءة البزي.4- تلقم، بالميم، وهى قراءة ابن جبير."
  7,118,""
  7,119,"7:118"
  7,120,"7:118"
  7,121,"7:118"
  7,122,"7:118"
  7,123,"آمنتم:قرئ:1- آمنتم، على الخبر، وهى قراءة حفص.2- بهمزة استفهام ومدة بعدها مطولة فى تقدير ألفين، وهى قراءة العربيين، ونافع، والبزي.3- بهمزة استفهام ومدة مسهلة، وهى قراءة ورش.4- بهمزة استفهام مخففة وبعدها ألف، وهى قراءة حمزة، والكسائي.5- بإبدال همزة الاستفهام واوا، لضمة نون «فرعون» ، وهى قراءة قنبل."
  7,124,""
  7,125,"7:124"
  7,126,"تنقم:قرئ:1- بفتح القاف، مضارع «نقم» بكسرها، وهى قراءة الحسن، وأبى حيوة، وأبى اليسر هاشم، وابن أبى عبلة.2- بكسرها، وهى قراءة الجمهور، وهى الأفصح."
  7,127,"ويذرك:قرئ:1- بالياء وفتح الراء، وهى قراءة الجمهور.2- بالياء والجزم، عطفا على التوهم، وهى قراءة الأشهب العقيلي، والحسن.3- بالنون ورفع الراء، وهى قراءة أنس بن مالك.وآلهتك:1- بالجمع، وهى قراءة الجمهور.وقرئ:2- وإلهتك، على المصدرية، وهى قراءة ابن مسعود، وعلى، وابن عباس، وأنس."
  7,128,"يورثها:وقرئ:1- يورثها، بفتح الراء.2- يورثها، بتشديد الراء، وهى قراءة الحسن.العاقبة:وقرئ:بالنصب، عطفا على «إن الأرض» ، وهى قراءة ابن مسعود، وأبى."
  7,129,""
  7,130,"7:129"
  7,131,"يطيروا:وقرئ:تطيروا، بالتاء وتخفيف الطاء، فعلا ماضيا، وهى قراءة عيسى بن عمر، وطلحة بن مصرف.طائرهم:وقرئ:طيرهم، وهى قراءة الحسن."
  7,132,""
  7,133,"7:132"
  7,134,"7:132"
  7,135,"7:132"
  7,136,"7:132"
  7,137,"كلمة:وقرئ:كلمات، على الجمع، وهى قراءة الحسن.يعرشون:قرئ:1- بضم الراء، وهى قراءة ابن عامر.2- بكسر الراء، وهى لغة الحجاز، وهى قراءة باقى السبعة، والحسن ومجاهد، وأبى رجاء.3- يعرشون، بضم الياء وفتح العين وتشديد الراء، وهى قراءة ابن أبى عبلة."
  7,138,"وجاوزنا:قرئ:وجوزنا، وهو مما جاء فيه «فعل» المضعف، بمعنى «فعل» المجرد، وهى قراءة الحسن، وإبراهيم، وأبى رجاء، ويعقوب.يعكفون:قرئ:1- بكسر الكاف، وهى قراءة الأخوين، وأبى عمرو.2- بضمها، وهى قراءة باقى السبعة.وهما لغتان فصيحتان."
  7,139,""
  7,140,"7:139"
  7,141,"أنجيناكم:1- هذه قراءة الجمهور.وقرئ:2- أنجاكم، وهى قراءة ابن عامر.3- نجيناكم، مشددا.يقتلون:1- بالتشديد، من قتل، وهى قراءة الجمهور.وقرئ:2- بالتخفيف، من قتل، وهى قراءة نافع."
  7,142,""
  7,143,"دكا:وقرئ:دكاء، على وزن حمراء، وهى الناقة التي لا سنام لها، شبه الأرض بها، وهى قراءة حمزة، والكسائي."
  7,144,"برسالاتى:وقرئ:1- برسالتى، على الإفراد، وهى قراءة الحرميين.2- برسالاتى، على الجمع، وهى قراءة باقى السبعة.وبكلامي:وقرئ:1- وبكلمى، وهى قراءة أبى رجاء.2- وتكلمى، وهى قراءة الأعمش."
  7,145,"سأوريكم:1- بواو ساكنة بعد الهمزة، على ما يقتضيه رسم المصحف، وهى قراءة الحسن، وهى لغة فاشية بالحجاز.وقرئ:2- سأريكم، من رؤية العين.3- سأورثكم، وهى قراءة ابن عباس، وقسامة بن زهير."
  7,146,"الرشد:قرئ:1- الرشد، بفتحتين، وهى قراءة الأخوين.2- الرشد، بالضم، وهى قراءة باقى السبعة.3- الرشد، بضمتين، وهى قراءة ابن عامر، فى رواية.4- الرشاد، وهى قراءة أبى عبد الرحمن.لا يتخذوه:وقرئ:لا يتخذوها، على تأنيث السبيل، وهى قراءة ابن أبى عبلة."
  7,147,""
  7,148,"حليهم:وقرئ:1- بكسر الحاء، اتباعا لحركة اللام، وهى قراءة الأخوين.2- بضم الحاء، وهى قراءة باقى السبعة.3- بفتح الحاء وسكون اللام، مفرد يراد به الجنس، وهى قراءة يعقوب.خوار:وقرئ:جؤار، بالجيم والهمز، وهى قراءة على، وأبى السمال."
  7,149,"سقط:قرئ:1- سقط، مبنيا للفاعل، وهى قراءة ابن السميفع، وغيره.2- أسقط، رباعى مبنى للمفعول، وهى قراءة ابن أبى عبلة.يرحمنا:وقرئ:1- ترحمنا، بالخطاب، وهى قراءة الأخوين، والشعبي، وابن وثاب، والجحدري، وابن مصرف، والأعمش، وأيوب.2- يرحمنا، بالياء، وهى قراءة باقى السبعة، ومجاهد، والحسن، والأعرج، وأبى جعفر، وشيبة بن نصاح."
  7,150,"ابن أم:قرئ:1- بفتح الميم، وهى قراءة أبى عمرو، وحفص.2- بكسر الميم، وهى قراءة باقى السبعة.تشمت:قرئ:1- بفتح التاء وكسر الميم، ونصب «الأعداء» ، وهى قراءة ابن محيصن.2- بفتح التاء وفتح الميم، ونصب «الأعداء» ، وهى قراءة مجاهد، و «شمت» متعدية."
  7,151,""
  7,152,"7:151"
  7,153,"7:151"
  7,154,"سكت:وقرئ:أسكت، رباعيا مبنيا للمفعول، وكذا هو فى مصحف حفصة."
  7,155,""
  7,156,"هدنا:وقرئ:بكسر الهاء، من هاد يهيد، إذا حرك، وهى قراءة زيد، بن على، وأبى وجزة.أشاء:وقرئ:أساء، من الإساءة، وهى قراءة زيد بن على، والحسن، وطاووس، وعمرو بن فائد."
  7,157,"إصرهم:وقرئ:1- آصارهم، جمع إصر، وهى قراءة ابن عامر.2- أصرهم، بفتح الهمزة وبضمها.عزروه:وقرئ:1- بالتخفيف، وهى قراءة الجحدري، وقتادة وسليمان التيمي، وعيسى.2- وعززوه، بزايين، وهى قراءة جعفر بن محمد."
  7,158,""
  7,159,"7:158"
  7,160,"وقطعناهم:وقرئ:وقطعناهم، بالتخفيف، قرأ بها أبان بن تغلب، عن عاصم.عشرة:قرئت:1- عشرة، بكسر الشين، وهى قراءة ابن وثاب، والأعمش، وطلحة بن سليمان، وهى لغة تميم.2- عشرة، بإسكان الشين، وهى قراءة الجمهور، وهى لغة الحجاز."
  7,161,"نغفر لكم خطيئاتكم:قرئت:1- نغفر، بالنون، و «خطيئاتكم» جمع سلامة، وهى قراءة الكوفيين، وابن كثير، والأعمش.2- نغفر بالنون، وتخفيف همزة «خطيئاتكم» ، وإدغام الياء فى الياء، وهى قراءة الحسن.3- نغفر لكم خطاياكم، وهى قراءة أبى عمرو.4- تغفر، بالتاء مبنيا للمفعول، و «خطيئاتكم» ، جمع سلامة، وهى قراءة نافع، ومحبوب.5- تغفر، بتاء مضمومة مبنيا للمفعول، وخطيئتكم، على التوحيد وهى قراءة ابن عامر.6- تغفر، بتاء مفتوحة، على أن «الحطة» تغفر، إذ هى سبب الغفران، وهى قراءة ابن هرمز."
  7,162,""
  7,163,"يعدون:وقرئ:1- يعدون، من الأعداد، وإن كانوا يعدون آلات الصيد يوم السبت.2- يعدون، بفتح العين وتشديد الدال، وأصله: يعتدون، وهى قراءة شهر بن حوشب، وأبى نهيك.سبتهم:قرئ:يوم أسباتهم، وهى قراءة عمر بن عبد العزيز.لا يسبتون:وقرئ:1- بكسر الباء، وهى قراءة الجمهور.2- بضمها، وهى قراءة عيسى بن عمر.3- بضم ياء المضارعة على البناء للفاعل، من «أسبت» ، وهى قراءة على، وعاصم.4- بضم ياء المضارعة، على البناء للمفعول، من «أسبت» ، وهى قراءة الحسن."
  7,164,"معذرة:قرئ:1- بالرفع، وهى قراءة الجمهور.2- بالنصب، وهى قراءة زيد بن على، وعيسى بن عمر، وطلحة بن مصرف، وعاصم، فى بعض ما روى عنه."
  7,165,"بئيسى:وقرئ:1- بيس، على وزن جيد، وهى قراءة نافع، وأبى جعفر، وشيبة.2- بئس، كبئر، بالهمز، وهى قراءة ابن عامر.3- بئس، كشهد، حكاها يعقوب القارئ، وعزاها أبو الفضل الرازي إلى عيسى بن عمر، وزيد بن على.4- بأس، على وزن «ضرب» فعلا ماضيا، وهى قراءة نصر بن عاصم.5- بأس، بفتح الباء وسكون الألف.6- بيس، على وزن «كيل» ، وهى قراءة خارجة، عن نافع.7- بئس، على وزن «كبد» ، وهى قراءة أبى عبد الرحمن بن مصرف.8- بيأس، على وزن «ضيغم» ، وهى قراءة ابن عباس، وأبى بكر بن عاصم.9- بئيس، على وزن «رئيس» ، وهى قراءة باقى السبعة."
  7,166,""
  7,167,"7:166"
  7,168,"7:166"
  7,169,"ورثوا:وقرئ:بضم الواو وتشديد الراء، وهى قراءة الحسن.أن لا يقولوا:وقرئ:أن لا تقولوا، بالتاء، وهى قراءة الجحدري.ودرسوا:وقرئ:وادارسوا، وهى قراءة على، والسلمى.تعقلون:1- بالتاء على الخطاب، وهى قراءة الجمهور.وقرئ:1- بالياء، جريا على الغيبة فى الضمائر السابقة، وهى قراءة أبى عمرو، وأهل مكة."
  7,170,"يمسكون:قرئ:1- يمسكون، من أمسك، وهى قراءة عمر، وأبى العالية، وأبى بكر عن عاصم.2- يمسكون، بالتشديد، من مسك، وهى قراءة الجمهور.3- استمسكوا، وهى قراءة عبد الله، والأعمش.4- تمسكوا، فى حرف أبى."
  7,171,"واذكروا:وقرئ:1- واذكروا، بالتشديد، من الاذكار.2- تذكروا، وهى قراءة ابن مسعود."
  7,172,""
  7,173,"ذريتهم:قرئ:1- ذرياتهم، بالجمع، وهى قراءة العربيين، ونافع.2- ذريتهم، بالإفراد، وهى قراءة باقى السبعة.أن تقولوا:قرئ:1- بالياء، على الغيبة، وهى قراءة أبى عمرو.2- بالتاء، على الخطاب، وهى قراءة باقى السبعة."
  7,174,"نفصل:وقرئ:يفصل، بالياء، أي يفصل هو، أي الله تعالى."
  7,175,"فأتبعه:1- من «أتبع» ، رباعيا، وهى قراءة الجمهور.وقرئ:2- فاتبعه، مشددا، بمعنى: تبعه، وهى قراءة طلحة، والحسن."
  7,176,""
  7,177,"ساء مثلا:وقرئ:ساء مثل، بالرفع، و «القوم» بالخفض، وهى قراءة الحسن، وعيسى بن عمر، والأعمش."
  7,178,""
  7,179,"7:178"
  7,180,"يلحدون:قرئ:1- بفتح الياء والحاء، وهى قراءة ابن وثاب، والأعمش، وطلحة، وعيسى.2- بضم الياء وكسر الحاء، وهى قراءة باقى السبعة."
  7,181,""
  7,182,"سنستدرجهم:وقرئ:سيستدرجهم، بالياء، على الالتفات، أو على أن يكون الفاعل ضمير التكذيب المفهوم من «كذبوا» أي: سيستدرجهم هو، أي التكذيب، وهى قراءة النخعي، وابن وثاب."
  7,183,"إن:1- بكسر الهمزة، وهى قراءة الجمهور.وقرئ:2- أن، بفتح الهمزة، وهى قراءة عبد الحميد، عن ابن عامر."
  7,184,""
  7,185,"7:184"
  7,186,"ويذرهم:وقرئ:1- ونذرهم، بالنون، ورفع الراء، وهى قراءة الحسن، وقتادة، وأبى عبد الرحمن، وأبى جعفر، والأعرج، وشيبة، والحرميين، وابن عامر.2- بالياء ورفع الراء، وهى قراءة أبى عمرو، وعاصم.3- بالياء وجزم الراء، وهى قراءة ابن مصرف، والأعمش، والأخوين.4- بالنون والجزم، وهى رواية خارجة عن نافع."
  7,187,""
  7,188,"7:187"
  7,189,"حملا:وقرئ:حملا، بالكسر، وهى قراءة حماد بن سلمة، عن ابن كثير.فمرت:1- بتشديد الراء، وهى قراءة الجمهور أي: استمرت به.وقرئ:2- بتخفيف الراء، من المرية أي: فشكت فيما أصابها أهو حمل أو مرض، وهى قراءة ابن عباس، وأبى العالية، ويحيى بن يعمر.3- فمارت به، بألف وتخفيف الراء أي: جاءت وذهبت، وهى قراءة عبد الله بن عمرو، بن العاص، والجحدري.4- فاستمرت بحملها، وهى قراءة عبد الله.5- فاستمرت به، وشى قراءة سعيد بن أبى وقاص، والضحاك.6- فاستمارت به، وهى قراءة أبى بن كعب، والجرمي.أثقلت:وقرئ:أثقلت، على البناء للمفعول."
  7,190,"شركاء:قرئ:1- شركا، على المصدر، وهو على حذف مضاف، أي: ذا شرك، وهى قراءة ابن عباس، وأبى جعفر، وشيبة، وعكرمة، ومجاهد، وأبان بن تغلب، ونافع، وأبى بكر عن عاصم.2- شركاء، على الجمع، وهى قراءة الأخوين، وابن كثير، وأبى عمرو.يشركون:وقرئ:تشركون، بالتاء على الالتفات من الغيبة إلى الخطاب، وهى قراءة السلمى."
  7,191,"أيشركون:وقرئ:أتشركون، بالتاء، وهى قراءة السلمى."
  7,192,""
  7,193,"لا يتبعوكم:وقرئ:لا يتبعوكم، مخففا، وهى قراءة نافع."
  7,194,"أن:وقرئ:بالتخفيف، وبنصب «عبادا» و «أمثالكم» ، وتكون «إن» نافية أعملت عمل «ما» الحجازية، وهى قراءة ابن جبير."
  7,195,""
  7,196,"ولى:1- بياء مشددة وهى ياء «فعيل» ، أدغمت فى لام الكلمة، وياء المتكلم مفتوحة، وهى قراءة الجمهور.وقرئ:2- بياء واحدة مشددة مفتوحة، وهى قراءة أبى عمرو."
  7,197,""
  7,198,"7:197"
  7,199,"بالعرف:وقرئ:بضم الراء، وهى قراءة عيسى بن عمر."
  7,200,""
  7,201,"طائف:قرئ:1- طيف، وهى قراءة النحويين، وابن كثير.2- طائف، وهى قراءة باقى السبعة."
  7,202,"يمدونهم:قرئ:1- يمدونهم، من «أمد» ، وهى قراءة نافع.2- يمدونهم، من «مد» ، وهى قراءة باقى السبعة.3- يمادونهم، من «ماد» ، وهى قراءة الجحدري.لا يقصرون:قرئ:1- لا يقصرون، من «أقصر» ، وهى قراءة الجمهور.2- لا يقصرون، من «قصر» ، وهى قراءة ابن أبى عبلة، وعيسى بن عمر."
  7,203,""
  7,204,"7:203"
  7,205,"وخيفة:وقرئ:وخفية.والآصال:وقرئ والإيصال، مصدر «آصل» ، أي: دخل فى وقت الأصيل، وهى قراءة أبى مجاز لا حق بن حميد السدوسي."
  7,206,""
