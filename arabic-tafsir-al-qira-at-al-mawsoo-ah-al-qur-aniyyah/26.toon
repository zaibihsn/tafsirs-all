tafsir[227]{c,v,t}:
  26,1,"طسم:قرئ:1- بإمالة فتحة الطاء، وهى قراءة حمزة، والكسائي، وأبى بكر.2- بالفتح، وهى قراءة باقى السبعة.3- بإظهار نون «سين» ، وهى قراءة حمزة.4- بإدغامها، وهى قراءة باقى السبعة.5- بكسر الميم، وهى قراءة عيسى.6- ط س م، مقطوعا، وهى قراءة أبى جعفر، وكذا فى مصحف عبد الله."
  26,2,""
  26,3,"26:2"
  26,4,"إن نشأ ننزل:وقرئ:إن نشأ ينزل، على الغيبة، وهى قراءة أبى عمرو، فى رواية هارون.فظلت:1- ماضيا بمعنى المستقبل لأنه معطوف على «ننزل» ، وهى قراءة الجمهور.وقرئ:2- فتظل، وهى قراءة طلحة.خاضعين:وقرئ:خاضعة، وهى قراءة عيسى، وابن أبى عبلة."
  26,5,""
  26,6,"26:5"
  26,7,"26:5"
  26,8,"26:5"
  26,9,"26:5"
  26,10,"26:5"
  26,11,"يتقون:وقرئ:بكسر النون، والتقدير: أفلا يتقوننى، فحذفت نون الرفع لالتقاء الساكنين، وياء المتكلم اكتفاء بالكسرة."
  26,12,""
  26,13,"ويضيق ... ولا ينطلق:1- بالرفع فيهما، عطفا على «أخاف» ، وهى قراءة الجمهور.وقرئا:2- بالنصب، فيهما، عطفا على «يكذبون» ، وهى قراءة الأعرج، وطلحة، وعيسى، وزيد بن على، وأبى حيوة، وزائدة، عن الأعمش، ويعقوب.3- بنصب الأول ورفع الثاني، حكاها أبو عمرو الداني، عن الأعرج."
  26,14,""
  26,15,"26:14"
  26,16,"26:14"
  26,17,"26:14"
  26,18,"عمرك:وقرئ:بإسكان الميم، وهى قراءة أبى عمرو، فى رواية."
  26,19,"فعلتك:1- بفتح الفاء، على معنى الحسرة، وهى قراءة الجمهور.وقرئ:2- بكسرها، على معنى الهيئة، وهى قراءة الشعبي."
  26,20,""
  26,21,"لما:1- حرف وجوب لوجوب، أو ظرفا بمعنى: حين، وهى قراءة الجمهور.وقرئ:2- بكسر اللام وتخفيف الميم، وهى قراءة حمزة، فى رواية.حكما:1- بالإسكان، وهى قراءة الجمهور.وقرئ:2- بضم الكاف، وهى قراءة عيسى."
  26,22,"وتلك نعمة تمنها:وقرئ:وتلك نعمة مالك أن تمنها، وهى قراءة الضحاك."
  26,23,""
  26,24,"26:23"
  26,25,"26:23"
  26,26,"26:23"
  26,27,"أرسل إليكم:وقرئ:على البناء للفاعل، أي: أرسله ربه إليكم، وهى قراءة مجاهد، وحميد، والأعرج."
  26,28,"المشرق والمغرب:وقرئ:المشارق والمغارب، على الجمع، وهى قراءة عبد الله، وأصحابه، والأعمش."
  26,29,""
  26,30,"26:29"
  26,31,"26:29"
  26,32,"26:29"
  26,33,"26:29"
  26,34,"26:29"
  26,35,"26:29"
  26,36,"26:29"
  26,37,"سحار:وقرئ:ساحر، وهى قراءة الأعمش، وعاصم، فى رواية."
  26,38,""
  26,39,"26:38"
  26,40,"26:38"
  26,41,"26:38"
