  3,174,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿فَانْقَلَبُوا بِنِعْمَةٍ مِنَ اللَّهِ وَفَضْلٍ﴾</span> وذلك أنَّ رسولَ الله ﷺ، خرج في أصحابه حتى وافوْا بدرَ الصُّغْرَى، وهي ماءٌ لِبَني كِنَانَة {1}، وكانت موضع سُوقٍ لهم، يجتمعون إليها في كل عام ثمانية أيام. فلم يلْقَ رسولُ الله ﷺ، وأصحابُه، أحدًا من المشركين، ووافقوا السُّوقَ، وكانت معهم نفقاتٌ وتجارات، فباعُوا واشتَرَوْا أُدمًا {2} وزَبِيبًا، وربحوا وأصابوا للدرهم درهمَيْنِ، وانصرفوا إلى المدينة سالمين غانمين {3}؛ فذلك قوله: <span class="qpc-hafs">﴿فَانْقَلَبُوا﴾</span>، أي: وخرجوا فانقلبوا. فحذف الخروجَ؛ لأن الانقلابَ يَدُلُّ عليه؛ كقوله: <span class="qpc-hafs">﴿أَنِ اضْرِبْ بِعَصَاكَ الْبَحْرَ فَانْفَلَقَ﴾</span> [الشعراء: 63]؛ أي: فَضَرَبَه {4} فانْفَلَقَ.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿بِنِعْمَةٍ مِنَ اللَّهِ وَفَضْلٍ﴾</span> قال السُّدِّي {5}، ومجاهد: النِّعمةُ -ههنا-: العافية. والفَضْلُ: التجارة {6}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لَمْ يَمْسَسْهُمْ سُوءٌ﴾</span>. لم يُصِبْهُم قَتْلٌ وَلاَ جِراحٌ. في قول الجميع.</p><p><span class="qpc-hafs">﴿وَاَتَّبَعُواْ رِضْوَانَ اَللَّهِ﴾</span> في طاعةِ رَسُولِه.</p></div>",footnotes:1:انظر: "معجم البلدان" 1/ 357، وانظر تفسير قوله تعالى: <span class="qpc-hafs">﴿وَلَقَدْ نَصَرَكُمُ اللَّهُ بِبَدْرٍ وَأَنْتُمْ أَذِلَّةٌ﴾</span> [آية: 123].الأُدُم: جمعٌ، ومفردها: (أُدْم)، و (إدام)، وهو: ما يُستمرأ به الخبز؛ من سائل: كالخل، والزيت، واللبن، وما أشبهه؛ أو من جامد. انظر: "غريب الحديث" لأبي عبيد 1/ 286، و"المصباح المنير" 4 (أدم)، و"المعجم الوسيط" 1/ 10 (أدم).انظر: "تفسير الطبري" 4/ 182 - 183، و"تفسير النسائي" 1/ 343 - 345.في (ج): (فضرب).قوله في: "تفسير الطبري" 4/ 183، و"تفسير ابن أبي حاتم" 3/ 819، و"زاد المسير" 1/ 505 - 506.ورد قولُه في المصادر السابقة، ولكنه فسر فيها (النعمة) و (الفضل) بما أصابوا من التجارة والأجر، ولم يَرِدْ فيها أنه فسَّرَها بالعافية.
  3,175,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِنَّمَا ذَلِكُمُ الشَّيْطَانُ﴾</span> (ذلك) إشارةٌ إلى التخويف؛</p><p>أي {1}: ذلك التخويفُ الذي كان، فِعْلُ الشيطان؛ لأنه سَوَّلَهُ للمُخَوَّفِين. قاله {2} الزجاج {3}.</p><p>وعلى هذا {4}؛ الآيةُ مِنْ باب حذف المضاف، على تقدير: إنما ذلكم فِعْلُ الشيطان {5}، أو كَيْدُ الشيطان، أو تخويفُ الشيطان؛ لأنَّه سبب ذلك؛ بالدعاء {6} إليه والإغواء فيه.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يُخَوِّفُ أَوْلِيَاءَهُ﴾</span> مذهب النحويين في هذا {7}: أنَّ <span class="qpc-hafs">﴿يُخَوِّفُ﴾</span> قد حُذِف معه مفعولٌ {8} يقتضيه؛ تقديره: يخوفكم {9}، أو: يخوفُ المؤمنينَ.</p><p>وقوله تعالى <span class="qpc-hafs">﴿أَوْلِيَاءَهُ﴾</span> حُذِف منه الجارُّ، أي: بأوليائهِ، أو: مِن أوليائه، فَلَمَّا حُذِفَ الجار، وَصَلَ الفعلُ إلى المفعول الثاني فَنَصَبَهُ.</p><p>ومثله -مِن حذفِ المفعول منه-، قولُه: <span class="qpc-hafs">﴿فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِي الْيَمِّ﴾</span> [القصص: 7] المعنى: إذا خِفْتِ عليه فِرْعَونَ أو الهلاكَ.</p><p>والجارُّ المُظْهَرُ في قوله: <span class="qpc-hafs">﴿فَإِذَا خِفْتِ عَلَيْهِ﴾</span>، بمنزلة المحذوف مِن قوله: <span class="qpc-hafs">﴿أَوْلِيَاءَهُ﴾</span>.</p><p>والتقديرُ عندهم: يُخَوِّفُكم بأوليائِهِ.</p><p>قال الفَرّاءُ {10}: ومِثْلُهُ، قولُهُ: <span class="qpc-hafs">﴿لِيُنْذِرَ يَوْمَ التَّلَاقِ﴾</span> [غافر: 15]؛ معناه: لِيُنْذِرَكُمْ بِيَومِ التَّلاقِ. وقوله: <span class="qpc-hafs">﴿لِيُنْذِرَ بَأْسًا﴾</span> [الكهف: 2]؛ معناه: لِيُنْذِرَكُمْ بِبِأسٍ.</p><p>هذا الذي ذَكَرْنَا: مذهب الفرّاء، والزّجاج {11}، وأبي علي {12}.</p><p>والذي يدلّ عل هذا: قراءةُ أُبَيِّ بن كعب: (يُخوِّفُكُمْ بِأَوْلِيَائِهِ) {13}. وللمفسِّرِينَ في هذه الآية مذهبان، سِوَى ما ذكرنا:</p><p>أحدهما: أنَّ هذا، على قول القائل: (خَوَّفْتُ زَيْدًا عَمْرًا). ومعنى الآية: يُخَوِّفكم أولياءَهُ. فحذف المفعول الأول؛ كما تقول: (أعطيتُ الأموالَ)؛ أي: أعطيتُ القومَ، أو الناسَ الأموالَ.</p><p>قال ابن الأنباري {14}: وهذا أشْبَه مِن ادِّعاءِ جارٍّ {15} ما عليه دليلٌ.</p><p>قال: وقوله: <span class="qpc-hafs">﴿لِيُنْذِرَ بَأْسًا﴾</span> [الكهف 20]، معناه: لِيُنْذِرَكمْ بأسًا. وكذلك قوله: <span class="qpc-hafs">﴿لِيُنْذِرَ يَوْمَ التَّلَاقِ﴾</span> [غافر: 15] [معناه: لِيُنْذِرَكُم يومَ التَّلاقِ] {16}.</p><p>والتخويفُ يتعدَّى إلى مفعولين، من غير حرف جَرٍّ؛ تقول {17}: (خافَ زَيْدٌ القِتَالَ)، و (خَوّفْتُهُ القتالَ)؛ كما تقول: (عَرَفَ زيدٌ أخاكَ)، و (عَرَّفْتُهُ أخاكَ).</p><p>وهذا مذهب ابن عباس {18}، ومجاهد {19}، وقتادة {20}. ويَدلُّ على هذا قراءةُ ابن مسعود: (يخوِّفُكُم أولياءَهُ) {21}.</p><p>المذهب الثاني: أنَّ معنى الآية: يُخَوَفُ أولياءَهُ [المنافقين {22}؛ ليقعدوا عن قتال المشركين. كأنَّ المعنى: يُخَوِّف أولياءَه] {16} الذين يُطيعونَهُ، وُيؤْثِرُونَ أمرَهُ، وَيعْصون رَبَّهم، ويُقِيمونَ على خِلافِهِ. فأمَّا أولياءُ اللهِ، فَإنَّهُمْ لا يَخَافُونَهُ إذا خَوَّفَهم، ولا يَنْقادُون لِمُرَادهِ منهم. وهذا قولُ: الحَسَن {24}، والسدِّي {25}، وابنِ عباس في رواية عطاء {26}.</p><p>فالمذهب الأول: فيه محذوفان، والثاني: فيه محذوفٌ واحد، والثالث: لا حَذْفَ فيه.</p><p>ومعنى (الأوْلِيَاء) -في القولين الأوَّلَيْنِ-: المشركون والكفار.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَلَا تَخَافُوهُمْ﴾</span> الكناية {27} تعود إلى الأولياء في القولين الأوَّلَيْنِ. وفي الثالث: تعود إلى المشركين؛ وهم قد ذُكِروا في قوله: <span class="qpc-hafs">﴿إِنَّ النَّاسَ قَدْ جَمَعُوا لَكُمْ﴾</span> [آل عمران: 173].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَخَافُونِ إِنْ كُنْتُمْ مُؤْمِنِينَ﴾</span> أي: خافونِ {28} في تركِ أمري؛ إنْ كنتم مصدِّقِينَ بوعدي، وقد أعلمتكم أنِّي أنصركم عليهم {29}، فقد سقط عنكم {30} الخوف.</p></div>",footnotes:1:في (ج): (إلى).في (ج): (قال).في: "معاني القرآن" له 1/ 490. نقله عنه بنصه.في (ج): (هذه).في (ج): (الشيد).في (ب): (الدعاء).في (ب): (في هذه الآية).من قوله: (يقتضيه ..) إلى (.. حذف منه): ساقط من (ج).في (ب): (خوفكم).في "معاني القرآن" له 1/ 248، نقله عنه بمعناهفي "معاني القرآن" له 1/ 490.لم أقف على مصدر مذهبه.</p><p>انظر: "معاني القرآن" للأخفش 1/ 221، و"تفسير غريب القرآن" لابن قتيبة ص 108، و"تأويل المشكل" له 222، و"معاني القرآن" للنحاس 1/ 512.أخرج القراءة عنه بسنده: الثعلبيُّ في "تفسيره" 3/ 158 أ، وذكرها البغوي في "تفسيره" 2/ 139، وأبن عطية في "المحرر الوجيز" 3/ 429، وأبو حيان في "البحر" 3/ 120.لم أقف على مصدر قوله. وقد ورد -بنصه- في "زاد المسير" 1/ 507، وورد -كما هو عند المؤلف- في: "تفسير الفخر الرازي" 9/ 105.في (ج): (جاز). وفي "زاد المسير": (وهذا أشبه من ادِّعاء (باء) ما عليها دليل، ولا تدعو إليها ضرورة).ما بين المعقوفين زيادة من (ج).(تقول): ساقطة من (ب).انظر: "تفسير الطبري" 4/ 183 - 184، و"النكت والعيون" 1/ 438، وقد ورد عنه من رواية عطاء، أنه كان يقرأها: (يخوفكم أولياءه). انظر: "المصاحف" لابن أبي داود 74، و"تفسير ابن أبي حاتم" 3/ 820، و"المحتسب" 1/ 177، و"المحرر الوجيز" 3/ 328، وأوردها عنه السيوطي في "الدر المنثور" 2/ 182 وزاد نسبة إخراجها إلى الفريابي: وعبد بن حميد، وابن الأنباري في "المصاحف".</p><p>وأورد عنه ابن عطية في "المحرر" 3/ 428 أنه قرأ: (يخوفكم أولياؤُه)، أي: يخوفكم قريش ومن معهم.انظر: "تفسيره" 139، و"تفسير الطبري" 4/ 183، و"ابن أي حاتم" 3/ 820، و"النكت والعيون" 1/ 438، و"الدر المنثور" 2/ 182 وزاد نسبة إخراجه إلى عبد ابن حميد، وابن المنذر.انظر: "الطبري" 4/ 183، و"ابن ابي حاتم" 3/ 821، و"النكت والعيون" 1/ 438.ذكر الثعلبي القراءة -بسنده عن عطاء- في "تفسيره" 3/ 158 أ، وأوردها أبو حيان في "البحر" 3/ 120.أي: أولياءه من المنافقين. فالمنافقين -هنا- بدل من (أولياءه).ما بين المعقوفين زيادة من (ج).لم أقف على مصدر قوله. وقد ورد في: "النكت والعيون" 1/ 438، و"زاد المسير" 1/ 507، و"تفسير القرطبي" 4/ 282.قوله في: "تفسير الطبري" 4/ 183، و"تفسير ابن أبي حاتم" 3/ 820، و"النكت والعيون" 1/ 438، و"زاد المسير" 1/ 507، و"تفسير القرطبي" 4/ 282.لم أقف على مصدر هذه الرواية عنه.الكناية: هي الضمير.في (أ)، (ج): (خافوني)، والمثبت من (ب).في (ج): (عليكم).في (ج): (عنهم).
  3,176,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَلَا يَحْزُنْكَ الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ﴾</span>.</p><p>أكثر القُرّاءِ على <span class="qpc-hafs">﴿يَحْزُنْكَ﴾</span> -مِنَ الثلاثي-. وقرأ نافع: <span class="qpc-hafs">﴿يَحْزُنْكَ﴾</span> -بضمِّ الياء- {1}.</p><p>واختلف أهل اللغة في هذا: فقال قومٌ: (حَزَنَ، وأحْزَنَ)، بمعنى واحد {2}.</p><p>قال الزّجاج -في باب الوفاق- {3}: (حزَنَني الأمْرُ، وأَحْزَنَنِي).</p><p>و (أمرٌ حازِنٌ ومُحزِنٌ).</p><p>وقال ابن المُظَفَّر {4}: تقول {5}: (حَزَنَنِي)، و (هو يَحزُنُني حُزْنًا)، (فأَنَا مَحْزُونٌ)، و (هو حازِنٌ) {6} و (أحْزَنَنِي، فأنا مَحْزون) {7}، و (هو مُحزِنٌ).</p><p>وحكى -أيضًا- سيبويه {8} -عن بعض العرب-: أنهم يقولون: (أحْزَنْت الرجلَ): إذا جعلته حزينًا.</p><p>وحكى أبو زيد -في كتاب (خُبَأة) {9}: (أحْزَنَنِي الأمرُ إحزانًا)، و (هو يُحْزِنُنِي) بضم الياء.</p><p>وقال الخليل {10}: إذا أردت تغيير {11} (حَزِنَ)، قلت: (أحزنته). فهذا قولُ مَن سَوَّى بينهما، وجعلهما لُغَتَيْن. وهو حُجَّةٌ لِقِرَاءةِ نافع.</p><p>وروى أبو عُبَيد، عن أبي زيد، قال {12}: لا يقولون: (حَزَنه الأمرُ). ويقولون: (يَحْزُنُه). فإذا صاروا {13} على (8) الماضي، قالوا: [أحْزَنَهُ] {14}.</p><p>يستعمل الماضي مِنَ الرُّبَاعي، والمضارع مِنَ الثلاثي. وهذا شاذٌّ؛ لأنه استعمل (أحزَنَ)، وأهمل (يُحْزِن)، واستعمل (يَحْزُنُ)، وأهمل (حَزَنَ). فمن قرأ بقراءة العامَّة، فَحُجَّته: أنه أشهر اللغَتَيْنِ، وأكثرهما استعمالًا.</p><p>قال الأزهري {15}: اللغة الجَيِّدة: (حَزَنَهُ، يَحْزُنُه)، على ما قرأ به أكثر القرّاء.</p><p>وحجّة نافع: قولُ مَن زَعم أنهما لُغَتَان، وما حكاه سيبويه {16} عن الخليل، أنَّك حيث قلت: (حَزَنْتُه)، لم تُرِدْ أن تقول: [جعلتُه حزينًا، كما أنك حيث قلت: (أدْخَلته)، أردت: (جعلته داخلًا). ولكنك أردت أن تقول:] {17} جعلت فيه حُزْنًا.</p><p>كما تقول: (كحَلْتُهُ)؛ أي: جعلت فيه كُحْلًا، و (دَهَنْته)؛ جعلت {18} في دُهنًا، و (فَتَنْتُه): جعلت فيه فِتْنة. فجئت بـ (فَعَلْتُهُ) على حَدِّهِ {19}، ولم {20} تُرِد بـ (فَعَلْتُهُ) -ههنا- تغيير قوله: (حَزِنَ)، و (فَتِنَ) {21}. ولو أردت ذلك، لقلت: (أحزنته)، و (أفتنته).</p><p>وهذا الذي حكاهُ، حُجَّةُ نافع؛ لأنه أرادَ تغيير (حَزِنَ)، فنقله بالهمز.</p><p>قال الخليل {22}: ومثله: (شَتِرَ {23} الرجلُ)، و (شَتَرْتُ عَيْنَه). فإذا أردت تغيير (شَتِرَ الرجلُ)، قلت: (أشْتَرْتُ، كما تقول: (فَزعَ) {24} [و] {25} (أفزَعْتُهُ).</p><p>وأراد بـ <span class="qpc-hafs">﴿الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ﴾</span>: المنافقين، وقُرَيْظَة والنّضير -في قول ابن عباس- {26}.</p><p>ومعنى مسارعتهم في الكفر: مُظَاهَرَتُهُم {27} الكفَّارَ على محمد ﷺ. وتأويله: يُسارِعُون في نُصْرةِ الكفر. وقال الضَّحَّاكُ {28}: يعني: كفّار قريش.</p><p>فإذا قيل: معنى قوله: <span class="qpc-hafs">﴿وَلَا يَحْزُنْكَ الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ﴾</span>: لا تحزن لِكفرِهم. والحزن على كفر الكافر، ومعصيةِ العاصي، طاعةٌ، فكيف نهى عنهُ؟.</p><p>قيل: إنما نهى عنه النبيَّ ﷺ، لأنه كان يُفرطُ وُيسْرِفُ في الحُزْنِ على كُفْر قومِهِ، حتى كان يؤدّي ذلك إلى أن يَضُرّ {29} به، فنُهِي {30} [عن] {31} الإسراف فيه؛ ألا ترى إلى قوله -عز وجل-: <span class="qpc-hafs">﴿فَلَا تَذْهَبْ نَفْسُكَ عَلَيْهِمْ حَسَرَاتٍ﴾</span> [فاطر: 8].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنَّهُمْ لَنْ يَضُرُّوا اللَّهَ شَيْئًا﴾</span> يعنى: أنَّ عائِدَ الوَبَالِ في ذلك عليهم، لا على غيرهم. وقال عطاء {32}: يريد: لن يضروا أولياءَ اللهِ شيئا.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يُرِيدُ اللَّهُ أَلَّا يَجْعَلَ لَهُمْ حَظًّا فِي الْآخِرَةِ﴾</span> يعنى: نصيبًا في المجنة. وفي هذا رَدٌّ على القَدَرِيّة، وبيان أنَ الخيرَ والشرَّ بإرادة الله -جلَّ وعزَّ- {33}.</p></div>",footnotes:1:وقد قرأ نافع هذه الآية، وقرأ <span class="qpc-hafs">﴿ولِيُحْزِن﴾</span> في الآية 10 من سورة المجادلة، و <span class="qpc-hafs">﴿ليُحْزِنني﴾</span> في الآية 13 من سورة يوسف، بضم الياء وكسر الزاي في كل القرآن، إلا قوله تعالى: <span class="qpc-hafs">﴿لَا يَحْزُنُهُمُ الْفَزَعُ الْأَكْبَرُ﴾</span> [آية: 103] من سورة الأنبياء، فقد قرأها كباقي القراء الذين فتحوا الياءَ وضمُّوا الزايَ في كل القرآن.</p><p>انظر: "السبعة" 219، و"القراءات"، للأزهري 1/ 131، و"الحجة" للفارسي 3/ 99.انظر: "تهذيب اللغة" 1/ 807 (حزن)، و"المقاييس" 2/ 54 (حزن)، و"تفسير الثعلبي" 3/ 158 أ، و"ما جاء على فعلت وأفعلت" للجواليقي 34.</p><p>قال ابن دريد: (و (حَزَنني الأمر)، و (أحْزَنَنِي)، لغتان فصيحتان، أجازهما أبو زيد وغيره. وقال الأصمعي: لا أعرف إلا حزنني يحزنني، والرجل (محزون) و (حزين)، ولم يقولوا: (مُحْزَن). "الجمهرة" 1/ 529.</p><p>وفي "الصحاح" للجوهري، ينقل عن اليزيدي قوله: (حزَنه)، لغة قريش، و (أحْزَنَه) لغة تميم. 5/ 2098 (حزن)لم أقف على هذا المصدر.ورد القول التالي -مع اختلاف يسير- في: "تهذيب اللغة": 1/ 807 (حزن)، من قول أبي عمرو، برواية يونس عنه، وليس من قول الليث بن المظفر، فالمؤلف ينقل هنا عن "العين" للخليل وينسب الكلام لابن المظفر.</p><p>وانظر هذا المعنى في "العين" للخليل 3/ 160 (حزن).في (ج): (يقول).(وهو حازن): لم ترد في "تهذيب اللغة".في "التهذيب": (وأنا مُحْزَن)، وكلا الكلمتين واردتان في اللغة. انظر: "اللسان" 2/ 851 (حزن).في "الكتاب" 4/ 57.لم أقف على هذا المصدر، ولم أعثر في ترجمة أبي زيد فيما رجعت إلي من مصادر على كتابٍ له بهذا الاسم. انظر: "معجم الأدباء" 3/ 378.</p><p>والخُبَأة -في اللغة-: هي المرأة التي تلزم بيتها، وتستتر. والتي تَطَّلِع ثم تختبئ. انظر: "اللسان" 2/ 1085 (خبأ).</p><p>وكأن الكتاب في الكلمة الغريبة المهمة، وهو ما يتناسب مع المعنى اللغوي له.</p><p>وقد يكون الاسم محرفًا عن كتاب آخر له، يحتمل رسمُ اسمِهِ التحريفَ في الخط، وهو: كتاب (حِيلَة ومَحالة)؛ حيث أن رسم (حيلة) قريب من (خبأة)، فحصل فيه التحريف. والله أعلم. انظر: المصدر السابق.</p><p>ومعنى (حيلة) و (مَحالة): الحِذْق وجودة النظر، والقدرة على التصرف. انظر: "القاموس" ص 989 (حول).انظر: "كتاب سيبويه" 4/ 56.في (ب): (تعيين).قوله، في: "تهذيب اللغة" 1/ 807 (حزن). نقله عنه بتصرف.في (ب): (صيروا).ما بين المعقوفين في (أ)، (ب)، (ج): (حزنه) والمثبت هو الصواب. وقد جاء في "التهذيب": (.. ويقولون: يَحْزُنُهُ. فإذا قالوا أفْعَلَهُ الله؛ فهو بالألف). وهو يتناسب مع ذكره المؤلف بعده من استعمال الماضي من الرباعي.في "تهذيب اللغة" 1/ 807 (حزن). نقله عنه بتصرف. وانظر: قريبًا من عبارة الأزهري هذه في كتابه: "القراءات" 131.في "الكتاب" له 4/ 56. نقله عنه بتصرف واختصار يسيرين.ما بين المعقوفين زيادة من (ج). وهي في المصادر السابقة.في (ب): (أي جعلت). ولم أثبت (أي)؛ لأنها لم ترد في بقية النسخ، ولا في مصادر النص.ضبطت في "كتاب سيبويه": (حِدَةٍ). وقد ورد النص في كتاب "الحجة" للفارسي 3/ 100، وضبطت فيه كالتالي: (حَدِّه) كما هي مثبتة أعلاه.في (ج): (لم) بدون واو.هكذا ضُبِطت -هنا- بكسر التاء، وكذا عند الفارسي في "الحجة". وضَبطت في (كتاب سيبويه): (فَتَنَ) -بفتح التاء-. وأكثر مصادر اللغة التي رجعت إليها لم تشر إلى (فَتِن) بالكسر، وإنما ذَكَرَتْها بفتح التاء، إلا ما وجدته في "تهذيب اللغة" 3/ 2739 (فتن) ، حيث نقل عن أبي زيد قوله: (فَتِنَ الرجلُ، يفْتَنُ، فُتُونًا: إذا وقع في الفتنة، أو تحول من حال حسنة إلى حال سيئة).قوله في "كتاب سيبويه" 4/ 57. نقله عنه بمعناه.في (ج): (شتر) مهملة من النقط والشكل. وهذا جاءت في بعدها مهملة من النقط والشكل.</p><p>والشَّتْرُ: القطع. و (شَتَرَ ثَوْبَه): مزَّقه. و (الشَّتَرُ): الانقطاع، وانقلابٌ في جَفْنِ العين، وانشقاقُهُ، وانشقاقُ الشَّفَةِ السفلى. يقال: (شَترت عينهُ شَتَرًا)، و (شَتَرها يشْتُرُها شَتْرا)، و (أشْتَرها وشَتَّرها)، و (شَتِرَ يَشْتَر شَتَرًا).</p><p>انظر (شتر) في: "اللسان" 4/ 2193، و"القاموس" 413.في (ج): (فزع) -مهملة من النقط ولاشكل-. وكذا التي بعدها.ما بين المعقوفين زيادة من: كتاب سيبويه.لم أقف على مصدر قوله. وقد ورد هذا القول عن الكلبي. انظر: "بحر العلوم" 1/ 317.</p><p>وورد عن مجاهد، وابن إسحاق: أنهم المنافقون. انظر: "تفسير مجاهد" 1/ 139، و"تفسير الطبري" 4/ 185.المُظاهَرَةُ: المُعَاوَنَة. و (ظاهَرَ فلانٌ فلانًا): عاوَنَه. انظر: "اللسان" 5/ 2768 (ظهر).قوله في: "تفسير الثعلبي" 3/ 158 أ، و"زاد المسير" 1/ 508.في (ج): (نصر).في (ج): (نهى).ما بين المعقوفين زيادة من (ج)لم أقف على مصدر قوله. وقد ذكره ابن الجوزي في "الزاد" 1/ 508.إنَّ الله -تعالى- خالق الخير والشر، ولكنَّ الشرَّ في بعض مخلوقاته، وليس في خلق الله وفعله؛ لأن خلقَ الله وفعلَه، وقضاءَهُ وقَدَرَه، خيرٌ كلُّه؛ لأنه -تعالى- وضع الأمور في مواضعها، وذلك هو الخير والعدل، أما الشر؛ فهو: وضع الأمور في غير مواضعها، وذلك هو الظُّلْم، واللهُ مُنَزّهٌ عن الظلم. فأفعاله كلها تدور بين العدل والفضل والحكمة والمصلحة، ولا تخرج عن ذلك، فالله -تعالى- لا ينسب إليه الشرُّ، بل ينسب إليه الخير، وإنما صار الشرُّ شرًا، لانقطاع نسبته واضافته إلى الله تعالى، وفي الحديث: (.. والخير كله في يديك، والشر ليس إليك ..).</p><p>أخرجه النسائي في "السنن" 2/ 130 كتاب الصلاة. باب: الدعاء بين التكبيرة والقراءة.</p><p>فلو أضيف إليه، لم يكن شرًّا. انظر: "شفاء العليل" لابن القيم 179. وقال: (فإن قلت: لِمَ خَلَقَه وهو شر؟ قلت: خَلْقُهُ له وفِعْلُه، خيرٌ لا شرٌّ، فإن الخلق والفعل قائمٌ به -سبحانه-، والشر يستحيل قيامه به واتصافه به. وما كان في المخلوق من شر، فلعدم إضافته ونسبته إليه، والفعل والخَلْق يضاف إليه، فكان خيرًا، والذي شاءه كله خير، والذي لم يشأ وجوده بقي على العدم الأصلي، وهو الشر، فإن الشر كلَّه عَدَمٌ، وإنْ سبّبَه جهل وهو: عدم العِلْم، وظلمٌ وهو: عدم العدل. وما يترتب على ذلك من الآلام فهو من عدم استعداد المحل، وقبوله لأسباب الخيرات واللذات) 181 المصدر السابق، وانظر: "شرح العقيدة الطحاوية" (453) وما بعدها.
