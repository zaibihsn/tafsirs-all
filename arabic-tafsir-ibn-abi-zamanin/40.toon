tafsir[85]{c,v,t}:
  40,1,""
  40,2,"﴿تَنْزِيل الْكتاب﴾ الْقُرْآن ﴿من الله الْعَزِيز﴾ فِي ملكه ﴿الْعَلِيم﴾ بخلقه"
  40,3,"﴿غَافِرِ الذَّنْبِ وَقَابِلِ التَّوْبِ شَدِيدِ الْعقَاب﴾ لمن لمْ يُؤمن ﴿ذِي الطَّوْلِ﴾ الْغنى"
  40,4,"﴿مَا يُجَادِل﴾ (ل ٣٠٢) يُمَارِي ﴿فِي آيَات الله﴾ فيجحدها ﴿إِلا الَّذِينَ كَفَرُوا فَلا يغررك تقلبهم﴾ إقبالهم وإدبارهم ﴿فِي الْبِلَاد﴾ يَعْنِي: الدُّنْيَا بِغَيْر عَذَاب؛ فَإِن الله معذبهم."
  40,5,""
  40,6,"﴿وَكَذَلِكَ حَقَّتْ كَلِماَتُ رَبِّكَ﴾ أَي: سبقت."
  40,7,"﴿الَّذِينَ يَحْمِلُونَ الْعَرْشَ وَمَنْ حَوْلَهُ﴾ أَي: وَمن حول الْعَرْش ﴿وَيَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾ ﴿يَقُولُونَ﴾ (رَبَّنَا وَسِعْتَ كُلَّ شَيْءٍ} أَي: مَلَأت كل شيءٍ ﴿رَّحْمَةً وَعِلْمًا فَاغْفِرْ لِلَّذِينَ تَابُوا﴾ من الشّرك ﴿وَاتَّبَعُوا سَبِيلَكَ﴾ يَعْنِي: الْإِسْلَام."
  40,8,"﴿وَمَن صَلَحَ﴾ أَي: من آمن ﴿مِنْ آبَائِهِمْ وَأَزْوَاجِهِمْ وَذُرِّيَّاتِهِمْ﴾."
  40,9,"﴿وقهم السَّيِّئَات﴾ يَعْنِي: جَهَنَّم هِيَ جَزَاء الشّرك ﴿وَمن تق السَّيِّئَات﴾ أَي: تصرف عَنهُ"
  40,10,"﴿إِن الَّذين كفرُوا ينادون﴾ وهم فِي النَّار: ﴿لَمَقْتُ اللَّهِ أكبر من مقتكم أَنفسكُم﴾ أَي: لمقت اللَّه إيَّاهُم فِي مَعْصِيَته أكبر من مقتهم أنفسهم فِي النَّار، وَذَلِكَ أَن أحدهم يمقت نَفسه ﴿إِذْ تُدْعَوْنَ إِلَى الْإِيمَان﴾ فِي الدُّنْيَا ﴿فَتَكْفُرُونَ﴾"
  40,11,"﴿قَالُوا رَبَّنَا أَمَتَّنَا اثْنَتَيْنِ وَأَحْيَيْتَنَا اثْنَتَيْنِ﴾ وَهُوَ قَوْله فِي سُورَة الْبَقَرَة: ﴿كَيْفَ تَكْفُرُونَ بِاللَّهِ وَكُنْتُمْ أَمْوَاتًا فَأَحْيَاكُمْ ثُمَّ يُمِيتُكُمْ ثُمَّ يُحْيِيكُمْ﴾.يَقُولُ: كُنْتُم أَمْوَاتًا فِي أصلبة آبائكم نطفاً ﴿فأحياكم﴾ يَعْنِي: هَذِه الْحَيَاة الدُّنْيَا ﴿ثُمَّ يميتكم﴾ يَعْنِي: مَوْتهمْ ﴿ثمَّ يُحْيِيكُمْ﴾ يَعْنِي: الْبَعْث.﴿فَهَلْ إِلَى خُرُوجٍ من سَبِيل﴾ تَفْسِير الْحَسَن: فِيهَا إِضْمَار (قَالَ الله: لَا)"
  40,12,"ثمَّ قَالَ: ﴿ذَلِكُمْ بِأَنَّهُ إِذَا دُعِيَ اللَّهُ وَحْدَهُ كَفَرْتُمْ وَإِنْ يُشْرك بِهِ تؤمنوا﴾ تصدقوا بِعبَادة الْأَوْثَان."
  40,13,"قَوْله: ﴿هُوَ الَّذِي يُرِيكُمْ آيَاتِهِ﴾ مَا أرَاهُ العبادَ من قدرته ﴿وَيُنَزِّلُ لَكُمْ مِنَ السَّمَاءِ رِزْقًا﴾ الْمَطَر؛ يَعْنِي: فِيهِ أرزاق الْعباد ﴿وَمَا يَتَذَكَّرُ إِلا مَنْ يُنِيبُ﴾ يخلص لله"
  40,14,"<div class=ar lang=ar></div>"
  40,15,""
  40,16,""
  40,17,"﴿الْيَوْم﴾ يَعْنِي: فِي الْآخِرَة ﴿تُجْزَى كُلُّ نَفْسٍ بِمَا كَسَبَتْ لَا ظُلْمَ الْيَوْمَ إِنَّ اللَّهَ سَرِيعُ الْحِسَابِ﴾ سَمِعْتُ بَعْضَ الْكُوفِيِّينَ يَقُولُ: يَفْرَغُ من حِسَاب الْخَلَائق فِي مِقْدَار نِصْفِ يَوْمٍ مِنْ أَيَّامِ الدُّنْيَا إِذا أَخذ فِي حِسَاب الْخَلَائق وعرضهم."
  40,18,""
  40,19,"﴿يعلم خَائِنَة الْأَعْين﴾ قَالَ مُجَاهِد: يَعْنِي: نظر الْعين إِلَى مَا نهى عَنْهُ.قَالَ مُحَمَّد: الخائنة والخيانة وَاحِد."
  40,20,"﴿وَالَّذِينَ يَدْعُونَ مِن دُونِهِ﴾ يَعْنِي: أوثانهم ﴿لاَ يَقْضُونَ بِشَيْءٍ﴾."
  40,21,"﴿كَانُوا هم أَشد مِنْهُم﴾ من مُشْركي الْعَرَب ﴿قُوَّة﴾ أَي: بطشًا ﴿وَآثَارًا فِي الأَرْضِ﴾ يَعْنِي: مَا عمِلُوا من الْمَدَائِن وَغَيرهَا من آثَارهم ﴿وَمَا كَانَ لَهُمْ مِنَ اللَّهِ مِنْ وَاقٍ﴾ يقيهم من عَذَاب الله"
  40,22,"﴿إِنَّه قوي شَدِيد الْعقَاب﴾ للْمُشْرِكين."
  40,23,"﴿وَلَقَدْ أَرْسَلْنَا مُوسَى بِآيَاتِنَا وَسُلْطَانٍ مُّبِينٍ﴾ حجَّة بَيِّنَة"
  40,24,"<div class=ar lang=ar></div>"
  40,25,"﴿قَالُوا اقْتُلُوا أَبْنَاءَ الَّذِينَ آمَنُوا مَعَه﴾ أَي: صدقوه ﴿واستحيوا نِسَاءَهُمْ﴾ أَي: لَا تقتلوهن ﴿وَمَا كَيْدُ الْكَافرين إِلَّا فِي ضلال﴾ يذهب فَلَا يكون شَيْئا؛ أَي: فِي الْعَاقِبَة."
  40,26,"﴿وَقَالَ فِرْعَوْنُ ذَرُونِي أَقْتُلْ مُوسَى﴾ يَقُوله لأَصْحَابه؛ أَي: خلوا بيني وَبَينه فَأَقْتُلهُ وَلم يخف أَن يمْتَنع مِنْهُ ﴿وليدع ربه﴾ أَي: وليسْتعن ربه؛ أَي إِن ربه لَا يُغني عَنْهُ شَيْئا ﴿إِنِّي أَخَافُ أَنْ يُبَدِّلَ دِينَكُمْ﴾ قَالَ الْحَسَن: كَانُوا عَبدة أوثان ﴿وَأَن يُظْهِرَ فِي الأَرْضِ﴾ يَعْنِي: أَرض مصر ﴿الْفَسَادَ﴾.)"
  40,27,"<div class=ar lang=ar></div>"
  40,28,""
  40,29,"﴿ظَاهِرين فِي الأَرْض﴾ يَعْنِي: غَالِبين عَلَى أَرض مصر فِي الْقَهْر لَهُم ﴿فَمَنْ يَنْصُرُنَا﴾ يمنعنا ﴿من بَأْس الله﴾ عَذَابه ﴿إِن جَاءَنَا﴾ يَقُوله عَلَى الِاسْتِفْهَام - أَي: أَنَّهُ لَا يمنعنا مِنْهُ أحد.﴿قَالَ فِرْعَوْنُ مَا أُرِيكُمْ إِلا مَا أرى﴾ أَي: مَا أرى لنَفْسي ﴿وَمَا أهديكم إِلَّا سَبِيل الرشاد﴾ يَعْنِي: جحود مَا جَاءَ بِهِ مُوسَى والتمسُّك بِمَا هُمْ عَلَيْهِ."
  40,30,""
  40,31,""
  40,32,""
  40,33,""
  40,34,""
  40,35,"﴿بِغَيْر سُلْطَان أَتَاهُم﴾ بِغَيْر حجَّة أَتَتْهُم من اللَّه بِعبَادة الْأَوْثَان ﴿كَبُرَ مَقْتًا عِنْدَ الله﴾."
  40,36,"﴿ابْن لي صرحا﴾ قَالَ الكَلْبي: يَعْنِي: قصرًا ﴿لَعَلِّي أبلغ الْأَسْبَاب﴾ يَعْنِي: الْأَبْوَاب"
  40,37,"﴿فَأطلع إِلَى إِلَه مُوسَى﴾ الَّذِي يزْعم ﴿وَإِنِّي لأَظُنُّهُ كَاذِبًا﴾ مَا فِي السَّمَاء أحدٌ تعمد الْكَذِب.قَالَ اللَّه: ﴿وَكَذَلِكَ زُيِّنَ لِفِرْعَوْنَ سُوءُ عَمَلِهِ وَصُدَّ عَنِ السَّبِيل﴾ عَن طَرِيق الْهدى ﴿وَمَا كَيْدُ فِرْعَوْن إِلَّا فِي تباب﴾ خسار."
  40,38,"<div class=ar lang=ar></div>"
  40,39,""
  40,40,"﴿من عمل سَيِّئَة﴾ والسيئة هَا هُنَا: الشّرك ﴿فَلا يُجْزَى إِلا مِثْلَهَا﴾ النَّار ﴿وَمَنْ عَمِلَ صَالِحًا مِنْ ذَكَرٍ أَوْ أُنْثَى وَهُوَ مُؤْمِنٌ﴾ لَا يقبل اللَّه الْعَمَل الصَّالح إِلَّا من الْمُؤمن.﴿يُرْزَقُونَ فِيهَا بِغَيْر حِسَاب﴾ قَالَ السُّدي: يَعْنِي: بِغَيْر متابعةٍ وَلَا مَنِّ عَلَيْهِم فِيمَا يُعْطَوْن."
  40,41,"﴿مالِي أَدْعُوكُمْ إِلَى النَّجَاةِ﴾ إِلَى الْإِيمَان بِاللَّه ﴿وَتَدْعُونَنِي إِلَى النَّار﴾ إِلَى الْكفْر الَّذِي يدْخل بِهِ صَاحبه النَّار."
  40,42,""
  40,43,""
  40,44,"﴿فستذكرون مَا أَقُول لكم﴾ إِذا صرتم إِلَى النَّار ﴿وَأُفَوِّضُ أَمْرِي إِلَى الله﴾ أَي: أتوكل عَلَى اللَّه ﴿إِنَّ الله بَصِير بالعباد﴾ أَي: بأعمالهم ومصيرهم."
  40,45,""
  40,46,""
  40,47,"﴿وَإِذْ يَتَحَاجُّونَ فِي النَّارِ فَيَقُولُ الضُّعَفَاء﴾ يَعْنِي: السفلة ﴿للَّذين استكبروا﴾ يَعْنِي: الرؤساء فِي الضَّلَالَة ﴿إِنَّا كُنَّا لكم تبعا﴾ أَي: دعوتمونا إِلَى الضَّلَالَة فأطعناكم ﴿فَهَلْ أَنْتُمْ مُغْنُونَ عَنَّا نَصِيبًا﴾ أَي: جُزْءا ﴿من النَّار﴾."
  40,48,"<div class=ar lang=ar></div>"
  40,49,""
  40,50,""
  40,51,""
  40,52,"﴿يَوْم لَا ينفع الظَّالِمين﴾ الْمُشْركين ﴿معذرتهم﴾."
  40,53,"﴿وأورثنا بني إِسْرَائِيل الْكتاب﴾ بعد الْقُرُون الأولى."
  40,54,"<div class=ar lang=ar></div>"
  40,55,""
  40,56,"﴿بِغَيْر سُلْطَان أَتَاهُم﴾ بِغَيْر حجَّة أَتَتْهُم ﴿إِنْ فِي صُدُورهمْ﴾ أَي: لَيْسَ فِي صُدُورِهِمْ ﴿إِلا كِبْرٌ مَا هم ببالغيه﴾ يَعْنِي: أملَهم فِي محمدٍ وَأهل دينه أَن يهْلك ويهلكوا."
  40,57,""
  40,58,"﴿وَمَا يَسْتَوِي الْأَعْمَى﴾ الْكَافِر عمي عَن الْهدى ﴿وَالْبَصِيرُ﴾ الْمُؤمن أبْصر الْهدى ﴿وَالَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ وَلاَ الْمُسِيءُ﴾ الْمُشرك ﴿قَلِيلاً مَّا يتَذَكَّرُونَ﴾ أَي: أقلهم المتذكر؛ يَعْنِي: من يُؤمن.قَالَ محمدٌ: (وَلا الْمُسِيءُ) الْمَعْنى: والمسيء و (لَا) زَائِدَة."
  40,59,"﴿إِن السَّاعَة﴾ الْقِيَامَة ﴿لآتِيَةٌ لَا رَيْبَ فِيهَا﴾ لَا شكّ فِيهَا ﴿وَلَكِنَّ أَكْثَرَ النَّاس لَا يُؤمنُونَ﴾ بالساعة."
  40,60,""
  40,61,"﴿الَّذِي جَعَلَ لَكُمُ اللَّيْلَ لِتَسْكُنُوا فِيهِ﴾ يَعْنِي: تستقروا من النصب ﴿وَالنَّهَار مبصرا﴾ أَي: مضيئًا ﴿وَلَكِنَّ أَكْثَرَ النَّاسِ لَا يشكرون﴾ لَا يُؤمنُونَ"
  40,62,"﴿فَأنى تؤفكون﴾ فَكيف تصرفون عَن الْهدى؟!"
  40,63,"﴿كَذَلِك يؤفك﴾ يصرف ﴿الَّذِينَ كَانُوا بِآيَاتِ اللَّهِ يَجْحَدُونَ﴾."
  40,64,"﴿اللَّهُ الَّذِي خلَقَ لَكُمُ الأَرْضَ قَرَارًا﴾ مثل قَوْله: ﴿بساطا﴾ و ﴿مهادا﴾ ﴿وَالسَّمَاء بِنَاء﴾ كَقَوْلِه: ﴿وَالسَّمَاء بنيناها بأيد﴾.قَالَ مُحَمَّدٌ: كُلُّ مَا ارْتَفَعَ عَلَى الأَرْض فالعرب تسميه بِنَاء.﴿وصوركم فَأحْسن صوركُمْ﴾ أَي: جعل صوركُمْ أحسن من صور الْبَهَائِم وَالطير.﴿وَرَزَقَكُمْ مِنَ الطَّيِّبَات﴾ قَالَ السُّدي: يَقُولُ جعل رزقكم أَطْيَبَ مِنْ رِزْقِ الدَّوَابِّ وَالطَّيْرِ وَالْجِنّ ﴿فَتَبَارَكَ الله﴾ تبَارك من الْبركَة."
  40,65,"<div class=ar lang=ar></div>"
  40,66,"40:65"
  40,67,"﴿هُوَ الَّذِي خَلَقَكُمْ مِنْ تُرَابٍ﴾ يَعْنِي: خلق آدم ﴿ثُمَّ مِنْ نُطْفَة﴾ نسل آدم ﴿ثُمَّ لِتَبْلُغُوا أَشُدَّكُمْ﴾ الِاحْتِلَام ﴿ثمَّ لِتَكُونُوا شُيُوخًا﴾ يَعْنِي: من يبلغ حَتَّى يكون شَيخا ﴿وَمِنْكُمْ مَنْ يُتَوَفَّى﴾ مِنْ قَبْلُ أَن يكون شَيخا ﴿وَلِتَبْلُغُوا أَجَلا مُسَمّى﴾ الْمَوْت ﴿ولعلكم تعقلون﴾ لكَي تعقلوا."
  40,68,"<div class=ar lang=ar></div>"
  40,69,"﴿أَلَمْ تَرَ إِلَى الَّذِينَ يُجَادِلُونَ فِي آيَات الله﴾ يَعْنِي: يجحدون بآيَات اللَّه ﴿أَنَّى يصرفون﴾ كَيفَ يصرفون عَنْهَا؟! ﴿فَسَوْفَ يَعْلَمُونَ﴾"
  40,70,"<div class=ar lang=ar></div>"
  40,71,"﴿إِذِ الأَغْلالُ فِي أَعْنَاقِهِمْ وَالسَّلاسِلُ يسْحَبُونَ﴾ تسحبهم الْمَلَائِكَة؛ أَي: تجرُّهم عَلَى وُجُوههم"
  40,72,"﴿فِي الْحَمِيمِ ثُمَّ فِي النَّارِ يسجرون﴾ أَي: توقد بهم النَّار."
  40,73,"﴿أَيْنَ مَا كُنْتُمْ تُشْرِكُونَ مِنْ دُونِ اللَّهِ﴾ كَقَوْلِه: ﴿أَيْنَ مَا كُنْتُمْ تَعْبُدُونَ من دون الله﴾"
  40,74,""
  40,75,"ثمَّ رَجَعَ إِلَى قصَّتهم فَقَالَ: ﴿ذَلِكُمْ بِمَا كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ بِغَيْرِ الْحَقِّ وَبِمَا كُنْتُمْ تمرحون﴾ الْفَرح والمرح وَاحِد؛ أَي: بِمَا كُنْتُم بطرين أشرين"
  40,76,"﴿فبئس مثوى﴾ منزل ﴿المتكبرين﴾."
  40,77,"﴿فَإِمَّا نُرِيَنَّكَ بَعْضَ الَّذِي نَعِدُهُمْ﴾ من الْعَذَاب ﴿أَو نتوفينك﴾ فَيكون بعد وفاتك ﴿فَإِلَيْنَا يُرْجَعُونَ﴾ يَوْم الْقِيَامَة."
  40,78,""
  40,79,"<div class=ar lang=ar></div>"
  40,80,"﴿وَلِتَبْلُغُوا عَلَيْهَا حَاجَة فِي صدوركم﴾ يَعْنِي: الْإِبِل وَالْحَاجة: السّفر"
  40,81,""
  40,82,"<div class=ar lang=ar></div>"
  40,83,"﴿فَرِحُوا بِمَا عِنْدَهُمْ مِنَ الْعِلْمِ﴾ يَعْنِي: علمهمْ عِنْد أنفسهم هُوَ قَوْلهم لن نبعث وَلنْ نعذب ﴿وحاق بهم﴾ وَجب عَلَيْهِم ﴿مَّا كَانُوا بِهِ يَسْتَهْزِئُون﴾ أَي: عِقَاب استهزائهم."
  40,84,"﴿فَلَمَّا رَأَوْا بأسنا﴾ عذابنا فِي الدُّنْيَا ﴿قَالُوا آمَنَّا بِاللَّهِ وَحْدَهُ وَكَفَرْنَا بِمَا كُنَّا بِهِ مُشْرِكين﴾ أَي: بِمَا كُنَّا بِهِ مُصدقين من الشّرك."
  40,85,""
