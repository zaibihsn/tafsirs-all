tafsir[88]{c,v,t}:
  38,1,""
  38,2,""
  38,3,""
  38,4,""
  38,5,""
  38,6,""
  38,7,"﴿أَنِ امْشُوا وَاصْبِرُوا عَلَى آلِهَتِكُمْ إِنَّ هَذَا لَشَيْءٌ يُرَادُ مَا سَمِعْنَا بِهَذَا فِي الْمِلَّةِ الآخِرَةِ﴾ تَفْسِير الْحَسَن يَقُولُوا: مَا كَانَ عندنَا [من هَذَا من علم أَن] يخرج (ل ٢٩٢) فِي زَمَاننَا هَذَا ﴿إِنْ هَذَا إِلَّا اخْتِلَاق﴾ أَي: كذب اختلقه مُحَمَّد"
  38,8,""
  38,9,""
  38,10,"﴿أم لَهُم ملك السَّمَاوَات وَالْأَرْض وَمَا بَينهمَا﴾ عَلَى الِاسْتِفْهَام؛ أَي: لَيْسَ لَهُم من ذَلِك شَيْء ﴿فليرتقوا﴾ فليصعدوا ﴿فِي الْأَسْبَاب﴾ قَالَ السُّدي: يَعْنِي: فِي الْأَبْوَاب؛ أَبْوَاب السَّمَاوَات إِن كَانُوا يقدرُونَ عَلَى ذَلكَ؛ أَي: لَا يقدرُونَ عَلَيْهِ.قَالَ محمدٌ: الْمَعْنى إِذا ادّعوا شَيْئا من هَذِه الْأَشْيَاء الَّتِي لَا يملكهَا إِلَّا اللَّه فليصعدوا فِي الْأَسْبَاب الَّتِي توصلهم إِلَى السَّمَاء."
  38,11,""
  38,12,"﴿كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍ وَعَادٌ وَفرْعَوْن ذُو الْأَوْتَاد﴾ تَفْسِير قَتَادَة: كَانَ إِذا غضب عَلَى أحدٍ أوتد لَهُ أَرْبَعَة أوتاد على يَدَيْهِ وَرجلَيْهِ"
  38,13,""
  38,14,"﴿إِن كُلّ﴾ يَعْنِي: من أَهْلَكَ مِمَّن (مضى) من الْأُمَم السالفة.﴿إِلا كَذَّبَ الرُّسُل فَحق عِقَاب﴾ يَعْنِي: عُقُوبَته إيَّاهُم بِالْعَذَابِ"
  38,15,""
  38,16,""
  38,17,"﴿اصبر على مَا يَقُولُونَ﴾ يَأْمر نبيه بذلك ﴿وَاذْكُرْ عَبْدَنَا دَاوُد ذَا الأيد﴾ يَعْنِي: ذَا الْقُوَّة فِي أَمر اللَّه؛ فِي تَفْسِير قَتَادَة ﴿إِنَّهُ أواب﴾ أَي: رجاع منيب"
  38,18,"﴿يسبحْنَ بالْعَشي وَالْإِشْرَاق﴾ قَالَ الْحَسَنُ: كَانَ اللَّهُ قَدْ سخّر مَعَ دَاوُد جَمِيع جبال الدُّنْيَا تسبح مَعَه وَكَانَ يفقه تسبيحها"
  38,19,""
  38,20,"﴿وشددنا ملكه وَآتَيْنَاهُ الْحِكْمَة﴾ يَعْنِي النُّبُوَّة ﴿وَفصل الْخطاب﴾ قَالَ الْحَسَن: يَعْنِي: الْعدْل فِي الْقَضَاء. تَفْسِير الْآيَات من ٢٠ وَحَتَّى ٢٦ من سُورَة ص."
  38,21,""
  38,22,"<div class=ar lang=ar></div>"
  38,23,"38:22"
  38,24,""
  38,25,"قَالَ اللَّه: ﴿فَغَفَرْنَا لَهُ ذَلِكَ وَإِن﴾ ﴿لَهُ عندنَا لزلفى﴾ يَعْنِي: لقربةٌ فِي الْمنزلَة ﴿وَحُسْنَ مَآبٍ﴾ مرجع"
  38,26,"﴿يَا دَاوُدُ إِنَّا جَعَلْنَاكَ خَلِيفَةً فِي الأَرْض﴾ إِلَى قَوْله: ﴿فَيُضِلَّكَ عَنْ سَبِيلِ الله﴾ يَعْنِي: فيستزلّك الْهوى عَن طَاعَة اللَّه فِي الحكم، وَذَلِكَ من غير كُفْرٍ ﴿إِنَّ الَّذِينَ يَضِلُّونَ عَنْ سَبِيلِ اللَّهِ لَهُمْ عَذَابٌ شَدِيدٌ بِمَا نَسُوا يَوْمَ الْحِسَابِ﴾ أَي: تَرَكُوهُ وَلم يُؤمنُوا بِهِ. تَفْسِير الْآيَات من ٢٧ وَحَتَّى ٢٩ من سُورَة ص."
  38,27,""
  38,28,"﴿أم نجْعَل الْمُتَّقِينَ كالفجار﴾ كالمشركين فِي الْآخِرَة أَي: لَا نَفْعل."
  38,29,""
  38,30,"<div class=ar lang=ar></div>"
  38,31,""
  38,32,"﴿حَتَّى تَوَارَتْ﴾ غَابَتْ؛ يَعْنِي: الشَّمْس ﴿بالحجاب﴾ ففاتته صَلَاة الْعَصْر"
  38,33,""
  38,34,""
  38,35,"<div class=ar lang=ar></div>"
  38,36,""
  38,37,"﴿وَالشَّيَاطِين كل بِنَاء وغواص﴾ يغوصون فِي الْبَحْر يستخرجون لَهُ اللُّؤْلُؤ"
  38,38,""
  38,39,"﴿هَذَا عَطَاؤُنَا فَامْنُنْ أَوْ أَمْسِكْ بِغَيْر حِسَاب﴾ تَفْسِير بَعضهم: فامْنُنْ فأعط من شِئْت أَو أمسك عمَّن شِئْت بِغَيْر حِسَاب (ل ٢٩٥) أَي: فَلَا حِسَاب عَلَيْك فِي ذَلِك وَلَا حرج"
  38,40,"﴿وَإِن لَهُ عندنَا لزلفى﴾ يَعْنِي: الْقرْبَة فِي الْمنزلَة ﴿وَحُسْنَ مَآبٍ﴾ أَي: وَحسن مرجع؛ يَعْنِي الْجنَّة.تَفْسِير الْآيَات من ٤١ وَحَتَّى ٤٣ من سُورَة ص."
  38,41,""
  38,42,""
  38,43,"<div class=ar lang=ar></div>"
  38,44,""
  38,45,"﴿وَاذْكُرْ عِبَادَنَا﴾ يَقُولُهُ لِلنَّبِيِّ ﷺ ﴿أُوْلِي الأَيْدِي﴾ يَعْنِي: الْقُوَّة فِي أَمر اللَّه ﴿وَالأَبْصَارِ﴾ فِي كتاب اللَّه.قَالَ محمدٌ: (الْأَيْدِي) بِالْيَاءِ وَهُوَ الِاخْتِيَار فِي الْقِرَاءَة."
  38,46,""
  38,47,""
  38,48,""
  38,49,"(ل ٢٩٦) ﴿هَذَا ذكر﴾ يَعْنِي: الْقُرْآن ﴿وَإِنَّ لِلْمُتَّقِينَ لَحُسْنَ مآب﴾ مرجع"
  38,50,"﴿جَنَّاتِ عَدْنٍ مُفَتَّحَةً لَهُمُ الأَبْوَابُ﴾.قَالَ مُحَمَّد: (جنَّات عدن) بدل من (حسن مآب) وَمعنى (مفتحة لَهُم الْأَبْوَاب): أَي مِنْهَا."
  38,51,"﴿متكئين فِيهَا﴾ أَي: عَلَى السرر فِيهَا إِضْمَار"
  38,52,"﴿وَعِنْدهم قاصرات الطّرف﴾ يقصرن طرفَهُن عَلَى أَزوَاجهنَّ لَا ينظرن إِلَى غَيرهم ﴿أتراب﴾ عَلَى سنٍّ وَاحِدَة بَنَات ثَلَاث وَثَلَاثِينَ سنة"
  38,53,"﴿هَذَا مَا توعدون﴾ يَعْنِي: مَا وُصِفَ فِي الْجنَّة"
  38,54,"﴿مَا لَهُ من نفاد﴾ انْقِطَاع.تَفْسِير الْآيَات من ٥٥ وَحَتَّى ٦١ من سُورَة ص."
  38,55,"﴿هَذَا وَإِن للطاغين﴾ (للْمُشْرِكين) ﴿لشر مآب﴾ أَي: مرجع"
  38,56,"<div class=ar lang=ar></div>"
  38,57,""
  38,58,"﴿وَأخر﴾ يَعْنِي: الزَّمْهَرِير ﴿من شكله﴾ من نَحوه؛ أَي: من نَحْو الْحَمِيم ﴿أَزوَاج﴾ ألوان."
  38,59,"﴿هَذَا فَوْج مقتحم مَعكُمْ﴾ إِلَى قَوْله ﴿فبئس الْقَرار﴾ تَفْسِير بَعضهم يَقُولُ: جَاءَت الْمَلَائِكَة بفوج إِلَى النَّار فَقَالَت للفوج الأول الَّذين دخلُوا قبلهم: هَذَا فوجٌ مقتحم مَعكُمْ! قَالَ الفوج الأول: ﴿لَا مَرْحَبًا بِهِمْ إِنَّهُمْ صالوا النَّار﴾ قَالَ الفوج الآخر: ﴿بَلْ أَنْتُمْ لَا مَرْحَبًا بِكُمْ أَنْتُمْ قَدَّمْتُمُوهُ لنا فبئس الْقَرار﴾"
  38,60,"<div class=ar lang=ar></div>"
  38,61,"قَالَ اللَّه: ﴿قَالُوا رَبَّنَا مَنْ قَدَّمَ لَنَا هَذَا فَزِدْهُ عَذَابًا ضعفا فِي النَّار﴾.قَالَ مُحَمَّد: قَوْله: ﴿مَا قدم لنا هَذَا﴾ أَي: من سَنَّهُ وشرعه.وَقَوله: ﴿فزده عذَابا ضعفا﴾ أَي: زده عَلَى عَذَابه عذَابا آخر.تَفْسِير الْآيَات من ٦٢ وَحَتَّى ٧٠ من سُورَة ص."
  38,62,"﴿وَقَالُوا مَا لَنَا لَا نَرَى رجَالًا﴾ لما دخلُوا النَّار لمْ يَرْوهم مَعَهم فِيهَا فَقَالُوا: ﴿مَا لَنَا لَا نَرَى رِجَالا كُنَّا نَعُدُّهُمْ من الأشرار﴾ فِي الدُّنْيَا"
  38,63,""
  38,64,"قَالَ اللَّه: ﴿إِنَّ ذَلِكَ لَحَقٌّ تخاصم أهل النَّار﴾ يَعْنِي: قَول بَعضهم لبعضٍ فِي الْآيَة الأولى"
  38,65,""
  38,66,"﴿رب السَّمَاوَات وَالأَرْضِ وَمَا بَيْنَهُمَا الْعَزِيزُ الْغَفَّارُ﴾ لمن آمن."
  38,67,"﴿قل هُوَ نبأ عَظِيم﴾ يَعْنِي: الْقُرْآن"
  38,68,"﴿أَنْتُم عَنهُ معرضون﴾ يَعْنِي: الْمُشْركين"
  38,69,"﴿مَا كَانَ لِي مِنْ عِلْمٍ بالملإ الْأَعْلَى﴾ يَعْنِي: الْمَلَائِكَة ﴿إِذْ يختصمون﴾ تَفْسِير الْحَسَن: اخْتَصَمُوا فِي خلق آدم؛ قَالُوا فِيمَا بَينهم: مَا اللَّه خالقٌ خَلْقًا هُوَ أكْرم عَلَيْهِ منا."
  38,70,""
  38,71,"﴿إِذْ قَالَ رَبُّكَ لِلْمَلائِكَةِ إِنِّي خَالِقٌ بَشَرًا مِنْ طِينٍ﴾ إِلَى قَوْله: ﴿وَكَانَ من الْكَافرين﴾ قَدْ مَضَى تَفْسِيرُهُ فِي سُورَةِ الْبَقَرَة"
  38,72,"<div class=ar lang=ar></div>"
  38,73,"38:72"
  38,74,"38:72"
  38,75,""
  38,76,"<div class=ar lang=ar></div>"
  38,77,"﴿فَاخْرُجْ مِنْهَا﴾ ﴿من السَّمَاء﴾ (فَإِنَّكَ رَجِيمٌ} أَي: مَلْعُون (رجم باللعنة)"
  38,78,"﴿وَإِنَّ عَلَيْكَ لَعْنَتِي إِلَى يَوْمِ الدِّينِ﴾ وأبدا فِي مَلْعُون"
  38,79,"﴿قَالَ رَبِّ فَأَنظِرْنِي﴾ أَي: أخرْني ﴿إِلَى يَوْمِ يُبْعَثُونَ قَالَ فَإِنَّكَ مِنَ الْمُنظَرِينَ﴾."
  38,80,"<div class=ar lang=ar></div>"
  38,81,""
  38,82,"<div class=ar lang=ar></div>"
  38,83,""
  38,84,""
  38,85,"<div class=ar lang=ar></div>"
  38,86,"﴿قل مَا أَسأَلكُم عَلَيْهِ﴾ عَلَى الْقُرْآن ﴿مِنْ أَجْرٍ وَمَا أَنا من المتكلفين﴾"
  38,87,"﴿إِن هُوَ﴾ أَي: الْقُرْآن ﴿إِلَّا ذكر﴾ أَي: تفكر ﴿للْعَالمين﴾ يَعْنِي الغافلين"
  38,88,"﴿ولتعلمن نبأه بعد حِين﴾ (أَي ذَلِك يَوْم الْقِيَامَة)."
