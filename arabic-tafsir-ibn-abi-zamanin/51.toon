tafsir[60]{c,v,t}:
  51,1,"تَفْسِير سُورَة والذاريات وَهِي مَكِّيَّة كلهَابِسْمِ الله الرَّحْمَن الرَّحِيمتَفْسِير الْآيَات من ١ وَحَتَّى ١٤ من سُورَة الذاريات.قَوْله: ﴿والذاريات ذَروا﴾ وَهِي الرِّيَاح، ذروها: جريها"
  51,2,"﴿فَالْحَامِلَات وقرا﴾ السَّحَاب"
  51,3,"﴿فَالْجَارِيَات يسرا﴾ السفن تجْرِي بتيسير الله"
  51,4,"﴿فَالْمُقَسِّمَات أمرا﴾ الْمَلَائِكَة.قَالَ محمدٌ: يُقَال: ذَرَتِ الرّيح تَذْرُو ذرْوًا إِذا فَرَّقَت التُّرَاب وَغَيره فَهِيَ ذاريةٌ. وَفِيه لُغَة أُخْرَى: أَذْرَت فَهِيَ مُذْرِية ومُذْرِيات للْجَمَاعَة.وَمعنى ﴿فَالْحَامِلَات وقرا﴾: أَن السَّحَاب تحمل الوِقْر من المَاء. وَرَأَيْت فِي تَفْسِير ابْن عَبَّاس أَن معنى ﴿فَالْمُقَسِّمَاتِ أَمْرًا﴾ أَن اللَّه قسم للْمَلَائكَة الْفِعْل.قَالَ يحيى: أقسم بِهَذَا كُله"
  51,5,"﴿إِنَّ مَا تُوعَدُونَ لَصَادِقٌ﴾ لصدق، يَعْنِي: يَوْم الْبَعْث"
  51,6,"﴿وَإِنَّ الدِّينَ الْحساب (لَوَاقِعٌ﴾ لكائن."
  51,7,"﴿وَالسَّمَاء ذَات الحبك﴾ تَفْسِير ابْن عَبَّاس: يَعْنِي: استواءها. وَتَفْسِير غَيره مثل حُبُك المَاء إِذا هَاجَتْ الرّيح، وَمثل حبك الزَّرْع إِذا أَصَابَته الرّيح.قَالَ مُحَمَّد: الحبك عِنْد أهل اللُّغَة: الطرائق (الْإِنَاء الْقَائِم) إِذا ضَربته الرّيح فَصَارَت فِيهِ طرائق لَهُ حُبُك، وَكَذَلِكَ الرمل إِذا هبَّتْ عَلَيْهِ الرّيح فرأيتَ فِيهِ الطرائق فَذَلِك حُبُكه، وَاحِدهَا: حِبَاكٌ مثل مِثَال ومُثُل، وَيكون واحدُها أَيْضا: حبيكة مثل: طَريقَة وطرق."
  51,8,"﴿إِنَّكُم لفي قَول مُخْتَلف﴾ أَي: لفي اخْتِلَاف من الْبَعْث"
  51,9,"﴿يؤفك عَنهُ من أفك﴾ يُصَدُّ عَنهُ من صُدَّ عَن الْإِيمَان بِهِ"
  51,10,"﴿قتل﴾ أَي: لعن ﴿الخراصون﴾ الَّذين يكذبُون بِالْبَعْثِ وَذَلِكَ مِنْهُم تخرص"
  51,11,"﴿الَّذين هم فِي غمرة﴾ أَي: فِي غَفلَة. وَقيل: فِي حيرة ﴿ساهون﴾ أَي: لاهون لَا يُحِقُّونه.قَالَ محمدٌ: تَقول: تخرص على فلَان الْبَاطِل إِذا كذب، وَيجوز أَن يكون الخراصون الَّذين يتظنَّوْن الشَّيْء لَا يُحِقُّونه؛ فيعملون بِمَا لَا يَدْرُونَ صِحَّته."
  51,12,"﴿يسْأَلُون أَيَّانَ يَوْم الدّين﴾ أَي: مَتى يَوْم الدّين؟ وَذَلِكَ مِنْهُم استهزاء وَتَكْذيب، أَي: لَا يكون."
  51,13,"قَالَ اللَّه: ﴿يَوْمَ هُمْ عَلَى النَّار يفتنون﴾ يحرقون بهَا.قَالَ محمدٌ: (يَوْم) مَنْصُوب بِمَعْنى: يَقع الْجَزَاء ﴿يَوْمَ هُمْ عَلَى النَّارِ يُفْتَنُونَ﴾."
  51,14,"﴿ذوقوا فتنتكم﴾ حريقكم ﴿هَذَا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُون﴾ فِي الدُّنْيَا، لما كَانُوا يستعجلون بِالْعَذَابِ فِي الدُّنْيَا استهزاءً وتكذيبًا.قَالَ محمدٌ: يُقَال للحجارة السود الَّتِي يحرق بهَا قد احترقت بالنَّار الفتين."
  51,15,"﴿إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَعُيُونٍ﴾ وَهِي الْأَنْهَار"
  51,16,"﴿آخذين مَا آتَاهُم﴾ أَعْطَاهُم ﴿رَبهم﴾ فِي الْجنَّة.قَالَ محمدٌ: (آخذين) نصبٌ على الْحَال الْمَعْنى: فِي جناتٍ وعيون فِي حَال أَخذهم مَا آتَاهُم (ل ٨٣٣) رَبهم."
  51,17,"﴿كَانُوا قَلِيلا مِنَ اللَّيْلِ مَا يهجعون﴾ تَفْسِير الْحسن: يَقُول: كَانُوا لَا ينامون مِنْهُ إِلَّا قَلِيلا."
  51,18,"﴿وبالأسحار هم يَسْتَغْفِرُونَ﴾.يَحْيَى: عَنْ خَالِدٍ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: قَالَ رَسُولُ اللَّهِ: \" قَالَ الله: إِن من أَحَبَّ أَحِبَّائِي إِلَيَّ الْمَشَّائِينَ إِلَى الْمَسَاجِدِ الْمُسْتَغْفِرِينَ بِالأَسْحَارِ الْمُتَحَابِّينَ فِيَّ، أُولَئِكَ الَّذِينَ إِذَا أَرَدْتُ أَهْلَ الأَرْضِ بِسُوءٍ فَذَكَرْتُهُمْ صَرَفْتُهُ عَنْهُمْ بِهِمْ \".قَالَ محمدٌ: قَوْله: ﴿وَمَا يهجعون﴾ جَائِز أَن تكون (مَا) مُؤَكدَة صلَة، وَجَائِز أَن يكون مَا بعْدهَا مصدرا، الْمَعْنى: كَانُوا قَلِيلا من اللَّيْل هُجُوعُهم.﴿وَفِي أَمْوَالِهِمْ حق للسَّائِل والمحروم﴾ السَّائِل: الَّذِي يسْأَل، والمحروم فِي تَفْسِير الْحسن: المتعفِّف الْقَاعِد فِي بَيته الَّذِي لَا يسْأَل."
  51,19,"<div class=ar lang=ar></div>"
  51,20,"قَوْله: ﴿وَفِي الأَرْض آيَات﴾ أَي: فِيمَا خلق اللَّه فِيهَا آياتٌ ﴿لِلْمُوقِنِينَ﴾."
  51,21,"﴿وَفِي أَنفسكُم﴾ أَي: فِي بَدْء خَلْقكم من ترابٍ؛ يَعْنِي: آدم ثمَّ خلق نَسْله من نُطْفَة ﴿أَفَلا تُبْصِرُونَ﴾ يَقُوله للْمُشْرِكين"
  51,22,"﴿وَفِي السَّمَاء رزقكم﴾ الْمَطَر فِيهِ أرزاقُ الخَلْقِ ﴿وَمَا توعدون﴾ تَفْسِير بَعضهم يَعْنِي: من الْوَعْد والوعيد من السَّمَاء"
  51,23,"﴿فَوَرَبِّ السَّمَاء وَالْأَرْض إِنَّه﴾ أقسم بنفْسه إِن هَذَا الْقُرْآن ﴿لَحَقٌّ مِثْلَ مَا أَنَّكُمْ تَنْطِقُونَ﴾.قَالَ محمدٌ: من نصب (مِثْلَ) فجائزٌ أَن يكون على التوكيد بِمَعْنى: إِنَّه لحقٌ حقًّا مثل نطقكم."
  51,24,"﴿هَل أَتَاك﴾ أَي: قد أَتَاك ﴿حَدِيثُ ضَيْفِ إِبْرَاهِيم الْمُكرمين﴾ عِنْد اللَّه بالمنزلة والقربة؛ يَعْنِي: الْمَلَائِكَة الَّذين نزلُوا بِهِ فبشروه بِإسْحَاق، وَجَاءُوا بِعَذَاب قوم لوط"
  51,25,"﴿إِذْ دخلُوا عَلَيْهِ﴾ فِي صُورَة الْآدَمِيّين ﴿فَقَالُوا سَلامًا﴾ أَي: سلمُوا عَلَيْهِ ﴿قَالَ سَلامٌ﴾ رد عَلَيْهِم ﴿قوم منكرون﴾ أنكرهم حِين لمْ يَأْكُلُوا من طَعَامه.قَالَ محمدٌ: ﴿قَالُوا سَلامًا﴾ منصوبٌ [بِتَقْدِير]. سلّمنا عَلَيْك سَلاما.وَقَوله: ﴿قَالَ سَلام﴾ مَرْفُوع بِمَعْنى: قَالَ: سلامٌ عَلَيْكُم، وَيَجُوزُ أَنْ يَكُونَ عَلَى مَعْنَى: أمرنَا سَلام."
  51,26,"قَوْله: ﴿فرَاغ﴾ فَمَال ﴿إِلَى أَهْلِهِ فَجَاءَ بِعِجْلٍ سمين﴾ فَلم يَأْكُلُوا.قَالَ محمدٌ: معنى (راغ). عدل إِلَيْهِم فِي خُفْيَةٍ، قَالُوا: وَلَا يكون الرَّوَاغُ إِلَّا أَن تخفي مجيئك وذهابك.﴿قَالَ أَلا تَأْكُلُونَ﴾"
  51,27,"<div class=ar lang=ar></div>"
  51,28,"﴿فَأَوْجَسَ مِنْهُمْ خِيفَةً قَالُوا لَا تخف وبشروه بِغُلَام عليم﴾ إِسْحَاق.قَالَ مُحَمَّد: (أوجس) مَعْنَاهُ: أضمر."
  51,29,"﴿فَأَقْبَلت امْرَأَته فِي صرةٍ﴾ صَيْحَة ﴿فصكت وَجههَا﴾ جبينها ﴿وَقَالَت عَجُوز عقيم﴾ قَالَت ذَلِك تعجُّبًا؛ أَي: كَيفَ تلدُ وَهِي عجوزٌ؟!وَقَالَ محمدٌ: (عَجُوز) مَرْفُوع بِمَعْنى: أَنا عجوزٌ، وَيُقَال: عَقُمتِ المرأةُ عُقْمًا وعَقَمًا فَهِيَ بيِّنةُ العُقُومة، ورجلٌ عقيم أَيْضا."
  51,30,"﴿قَالُوا كَذَلِك قَالَ رَبك﴾ أَي: تلدي غُلَاما اسْمُه: إِسْحَاق."
  51,31,"﴿قَالَ فَمَا خطبكم﴾ فَمَا أَمركُم؟!"
  51,32,"﴿قَالُوا إِنَّا أُرْسِلْنَا إِلَى قَوْمٍ مجرمين﴾ مُشْرِكين؛ يعنون: قوم لوط"
  51,33,"﴿لِنُرْسِلَ عَلَيْهِمْ حِجَارَةً مِنْ طِينٍ﴾ قَالَ هَا هُنَا: ﴿من طين﴾ وَقَالَ فِي آيَة أُخْرَى: ﴿مِنْ سجيل﴾.قَالَ محمدٌ: تَفْسِير ابْن عَبَّاس ﴿من سجيل﴾: من آجُر}."
  51,34,"﴿مسومة﴾ أَي: مُعْلَمَة أَنَّهَا من حِجَارَة الْعَذَاب، كَانَ فِي كل حجر مِنْهَا مثل الطابع."
  51,35,"﴿فأخرجنا﴾ فأنجينا ﴿من كَانَ فِيهَا﴾ فِي قَرْيَة لوطٍ ﴿مِنَ الْمُؤْمِنِينَ﴾."
  51,36,"﴿فَمَا وَجَدْنَا فِيهَا غَيْرَ بَيْتٍ من الْمُسلمين﴾ يَعْنِي: أهل بَيت لوط فِي الْقَرَابَة، وَمن كَانَ مَعَه من الْمُؤمنِينَ."
  51,37,"قَالَ: ﴿وَتَركنَا فِيهَا﴾ أَي: فِي إهلاكنا إِيَّاهَا ﴿آيَةً للَّذين يخَافُونَ الْعَذَاب الْأَلِيم﴾ فيحذرون أَن ينزل بهم مَا نزل بهم"
  51,38,"﴿وَفِي مُوسَى﴾ أَي: وَتَركنَا فِي أمْر مُوسَى ﴿إِذْ أَرْسَلْنَاهُ إِلَى فِرْعَوْنَ بِسُلْطَانٍ مُبين﴾ بَين"
  51,39,"﴿فَتَوَلّى بركنه﴾ قَالَ الكَلْبي: يَعْنِي: بجُنُوده ﴿وَقَالَ سَاحر أَو مَجْنُون﴾ يَعْنِي: مُوسَى.قَالَ محمدٌ: الْمَعْنى: هَذَا سَاحر أَو مَجْنُون."
  51,40,"﴿فنبذناهم فِي اليم﴾ فِي الْبَحْر ﴿وَهُوَ مليم﴾ مُذْنِبٌ، وذنبه: الشّرك.قَالَ محمدٌ: يُقَال: ألامَ الرجُلُ إِذا أَتَى بذنب يلام عَلَيْهِ."
  51,41,"﴿وَفِي عَاد﴾ أَي: وَتَركنَا فِي عادٍ أَيْضا آيَة، وَهِي مثل الأولى ﴿إِذْ أرسلنَا عَلَيْهِم الرّيح الْعَقِيم﴾ الَّتِي لَا تدع سحابًا وَلَا شَجرا وَهِي الدبور"
  51,42,"﴿مَا تَذَرُ مِن شَيْءٍ أَتَتْ عَلَيْهِ﴾ ﴿ل ٢٣٩﴾ مِمَّا مرّت بِهِ، وَهُوَ الْإِنْسَان ﴿إِلَّا جعلته كالرميم﴾ كرميم الشّجر."
  51,43,"﴿وَفِي ثَمُود﴾ وَهِي مثل الأولى ﴿إِذْ قِيلَ لَهُم تمَتَّعُوا حَتَّى حِين﴾ إِلَى آجالكم بِغَيْر عَذَاب إِن آمنتم، وَإِن عصيتم عذبتم ﴿فَعَتَوْا عَن أَمر رَبهم﴾ تركُوا أمره ﴿فَأَخَذتهم الصاعقة﴾ الْعَذَاب ﴿وهم ينظرُونَ﴾ إِلَى الْعَذَاب"
  51,44,"<div class=ar lang=ar></div>"
  51,45,"﴿فَمَا اسْتَطَاعُوا من قيام﴾ تَفْسِير السُّدي: فَمَا أطاقوا أَن يقومُوا للعذاب ﴿وَمَا كَانُوا مُنْتَصِرِينَ﴾ ممتنعين."
  51,46,"﴿وَقوم نوح﴾ الْآيَة.قَالَ محمدٌ: من قَرَأَ ﴿قوم نوح﴾ بِالنّصب فعلى معنى: فأخذناه وَجُنُوده، وأخذنا قوم نوح."
  51,47,"﴿وَالسَّمَاء بنيناها بأيد﴾ بِقُوَّة.قَالَ مُحَمَّد: ﴿وَالسَّمَاء بنيناها﴾ الْمَعْنى: بنينَا السَّمَاء بنيناها.﴿وَإِنَّا لموسعون﴾ فِي الرزق"
  51,48,"﴿وَالْأَرْض فرشناها﴾ أَي: وفرشناها كَقَوْلِه: ﴿جَعَلَ لَكُمُ الأَرْض فراشا﴾ و ﴿بساطا﴾ و ﴿مهادا﴾ ﴿فَنعم الماهدون﴾.قَالَ مُحَمَّد: ﴿وَالْأَرْض فرشناها﴾ أَي: وفرشنا الأَرْض فرشناها، قَوْله: ﴿فَنعم الماهدون﴾ أَي: فَنعم الماهدون نَحن."
  51,49,"﴿وَمِن كُلِّ شَيْءٍ خَلَقْنَا زَوْجَيْنِ﴾ تَفْسِير الْكَلْبِيّ: هُوَ كَقَوْلِه ﴿وَأَنَّهُ خلق الزَّوْجَيْنِ الذّكر وَالْأُنْثَى﴾ الذّكر زوجٌ، وَالْأُنْثَى زوجٌ ﴿لَعَلَّكُمْ تذكرُونَ﴾ لكَي تذّكَّروا فتعلموا أَن الَّذِي خلق هَذِه الْأَشْيَاء واحدٌ صَمَدٌ، جعلهَا لكم آيَة فتعتبروا"
  51,50,"﴿فَفرُّوا إِلَى الله﴾ إِلَى دين اللَّه، أَمر اللَّه النَّبي ﷺ أَن يَقُوله لَهُم:﴿إِنِّي لَكُمْ مِنْهُ نَذِيرٌ مُبِينٌ﴾."
  51,51,"<div class=ar lang=ar></div>"
  51,52,"﴿كَذَلِكَ مَا أَتَى الَّذِينَ مِنْ قبلهم﴾ من قبل قَوْمك يَا مُحَمَّد، أَي: هَكَذَا مَا أَتَى الَّذين مِنْ قَبْلِهِمْ ﴿مِنْ رَسُولٍ إِلا قَالُوا سَاحر أَو مَجْنُون﴾.قَالَ محمدٌ: الْمَعْنى: إِلَّا قَالُوا: هَذَا سَاحر أَو مَجْنُون."
  51,53,"﴿أتواصوا بِهِ﴾ على الِاسْتِفْهَام، أَي: لمْ يتواصَوْا بِهِ؛ لأنّ الأمَّة الأولى لم تدْرك الْأمة الْأُخْرَى، قَالَ: ﴿بَلْ هم قوم طاغون﴾ مشركون."
  51,54,"﴿فتول عَنْهُم﴾ أَي: فَأَعْرض عَنْهُم، وَهَذَا قبل أَن يُؤمر بقتالهم ﴿فَمَا أَنْتَ بملوم﴾ فِي الحجَّةِ؛ فقد أقمتها عَلَيْهِم"
  51,55,"﴿وَذَكِّرْ فَإِنَّ الذِّكْرَى تَنْفَعُ الْمُؤْمِنِينَ﴾ إِنَّمَا يقبل التَّذْكِرَة الْمُؤْمِنُونَ"
  51,56,"﴿وَمَا خَلَقْتُ الْجِنَّ وَالإِنْسَ إِلا ليعبدون﴾ أَي: ليقروا لي بالعبودية فِي تَفْسِير ابْن عَبَّاس.قَالَ يحيى: كَقَوْلِه: ﴿وَلَئِنْ سَأَلْتَهُمْ مَنْ خَلَقَهُمْ ليَقُولن الله﴾"
  51,57,"﴿مَا أُرِيدُ مِنْهُمْ مِنْ رِزْقٍ﴾ أَي: يرزقوا أنفسهم ﴿وَمَا أُرِيدُ أَن يطْعمُون﴾ أَي: يطعموا أحدا"
  51,58,"﴿إِنَّ اللَّهَ هُوَ الرَّزَّاقُ ذُو الْقُوَّة المتين﴾ الَّذِي لَا تضعف قوته"
  51,59,"﴿فَإِن للَّذين ظلمُوا﴾ أشركوا ﴿ذَنُوبًا مِثْلَ ذَنُوبِ أَصْحَابِهِمْ﴾ يَعْنِي: من مضى قبلهم من الْمُشْركين، تَفْسِير سعيد بْن جُبَير: الذَّنُوبُ: السَّجْلُ.قَالَ يحيى: والسَّجْلُ: الدَّلْوُ.يَحْيَى: عَنْ تَمَّامِ بْنِ نَجِيحٍ، عَنِ الْحَسَنِ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: قَالَ رَسُولِ اللَّهِ ﷺ: \" لَوْ أَنَّ غَرْبًا مِنْ جَهَنَّمَ وُضِعَ بِالأَرْضِ لآذَى حَرُّهُ مَا بَيْنَ الْمَشْرِقِ وَالْمَغْرِبِ \". قَالَ تَمَّامٌ: وَالْغَرْبُ: الدَّلْوُ الْعَظِيمُ.قَالَ محمدٌ: الذَّنُوب فِي اللُّغَة: الحظُّ والنصيبُ، وَأَصله: الدَّلْوُ الْعَظِيمَة، وَكَانُوا يستقون فَيكون لكل واحدٍ ذَنُوبٌ، فَجُعِل الذَّنوب مَكَان الْحَظ والنصيب، قَالَ أَبُو ذُؤَيْبٍ:(لَعَمْرُكَ وَالمَنَايَا غَالِبَاتٌ ... لكُلِّ بَنِي أَبٍ مِنْهَا ذَنُوبُ)قَوْله: ﴿فَلا يَسْتَعْجِلُونِ﴾ أَي: فَلَا يستعجلون بِالْعَذَابِ لما كَانُوا يستعجلون بِهِ من الْعَذَاب استهزاء وتكذيباً"
  51,60,"﴿فويل للَّذين كفرُوا﴾ فِي النَّار ﴿مِنْ يَوْمِهِمُ الَّذِي يوعدون﴾ فِي الدُّنْيَا."
