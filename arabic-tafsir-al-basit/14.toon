tafsir[52]{c,v,t}:
  14,1,"﴿الر﴾ قال ابن عباس في رواية أبي صالح: أنا الله أرى {1}، وقال في رواية أبي صالح وعطاء: أنا الله الرَّحمن {2}، وعلى هذا التفسير قوله: ﴿كِتَابٌ﴾ مرفوع على خبر الابتداء، المعنى: هذا كتاب أنزلناه {3}. وقال صاحب النّظم {4}: ﴿الر﴾ اسم موضوع لجماعة الحروف المعجمة {5}، فعلى هذا ﴿كِتَابٌ﴾ موضوع في موضع رفع على {6} خبر الابتداء، كأنه قيل هذه الحروف كتاب أنزلناه، يعني أن الكتاب الذي أنزل مؤلَّف من هذه الحُروف {7}.وقوله تعالى: ﴿أَنْزَلْنَاهُ إِلَيْكَ﴾ من صفة الكتاب، ومِثلُ هذا من الكلام: زيد رجل أنفذته إليك، وقوله تعالى: ﴿لِتُخْرِجَ النَّاسَ﴾ سبب لقوله ﴿أَنْزَلْنَاهُ إِلَيْكَ﴾، فاللام في ﴿لِتُخْرِجَ﴾ معلق بالإنزال، أي: أنزلنا لهذا.وقوله تعالى: ﴿مِنَ الظُّلُمَاتِ إِلَى النُّور﴾ قال ابن عباس: يريد من الشرك إلى الإيمان {8}. قال أبو إسحاق: شبّه الكفرَ بالظلمات لأنه غير بيّن، الإيمان بيّن نيّر، فمُثّل بالنور {9}.وقوله تعالى: ﴿بِإِذْنِ رَبِّهِمْ﴾ الباء متصلة بتخرج، المعنى: لتخرج الناس بإذن ربهم، أي: بما أذِن الله لك في تعليمهم، ويجوز أن يكون ﴿بِإِذْنِ رَبِّهِمْ﴾: لا {10} يهتدي مهتد إلا بإذن الله ومشيئته {11}، هذا كله كلام أبي إسحاق {12}، والقول الثاني قول ابن عباس؛ لأنَّه قال: يُريد بقضاء ربهم {13}.وقوله تعالى: ﴿إِلَى صِرَاطِ الْعَزِيزِ الْحَمِيدِ﴾ قال ابن الأنباري: إنما لم يدخل حرف العطف في ﴿إِلَى صِرَاطِ﴾ {14} لأنه أريد بهذا الصراط: النور المذكور قبله {15}، فـ (إلى) الثانية {16}، دخلت على ما دخلت عليه الأولى {17} في المعنى، وصار كقولك: قصدت إلى زيد العاقل الفاضل، فيستغني عن حرف العطف من أجل أن المذكور بعد (إلى) الثانية ثناء على السابق ووصف له، وإنما تعاد (إلى) لمعنى {18} التفخيم والتعظيم، فالنور: هو الإسلام، وصراط العزيز الحميد: ثناء على النور، وهذا معنى قول أبي إسحاق: ثم بيّن ما النور فقال: ﴿إِلَى صِرَاطِ الْعَزِيزِ الْحَمِيدِ﴾ {19}."
  14,2,"قوله تعالى: ﴿اللَّهِ﴾ مَنْ رَفع {1} قطع مِن الأول، وجعل ﴿الَّذِي﴾ الخبر أو جعل ﴿الَّذِي﴾ صفة وأضمر خبرًا {2}، ومثله في القطع قوله: ﴿قُلْ بَلَى وَرَبِّي لَتَأْتِيَنَّكُمْ عَالِمِ الْغَيْبِ﴾ [سبأ: 3] فيمن رفع {3} ومثله: ﴿إِنَّ اللَّهَ اشْتَرَى مِنَ الْمُؤْمِنِينَ أَنْفُسَهُمْ﴾ [التوبة: 111] ثم انقطع قوله: ﴿التَّائِبُونَ﴾ [التوبة: 112] عنهم واستؤنف به. ومن خفض {4} جعله بدلاً من ﴿الْحَمِيدِ﴾ ولم يكن صفة؛ لأن اسم الله صار كالعلم {5} الذي لا يوصف به نحو: زيد وعمرو بكثرة الاستعمال {6}، وإن كان يجوز أن يوصف به من حيث المعنى؛ لأن معناه ذو العبادة {7}، كما بينا في أول الكتاب؛ على معنى أن العبادة تجب له، وقد يَغْلُب ما أصله الصفة فيصير بمنزلة العلم، كقول الشاعر {8}:ونابغةُ الجَعْدِيُّ بالرَّمْل بيتُه ... عليه صَفيحٌ من تُرَابٍ وجَنْدَلِ {9}فالأصل النابغة، ولما غلب نُزع عنه الألف واللام كما يُنزع من الأعلام، نحو: زيد وجعفر {10}."
  14,3,"قوله تعالى: ﴿الَّذِينَ يَسْتَحِبُّونَ الْحَيَاةَ الدُّنْيَا عَلَى الْآخِرَةِ﴾ إن شئتَ جعلت ﴿الَّذِينَ﴾ من صفة الكافرين في الآية المتقدمة، وإن شئت استأنفت به وجعلت الخبر قوله: ﴿أُولَئِكَ﴾ ومعنى الاستحباب: طلب محبّة الشيء بالتعرُّض إلفًا {1}، ودخلت (على) {2} في قوله: ﴿عَلَى الْآخِرَةِ﴾ لأن معنى يستحبُّون هاهنا: يؤُثرون ويختارون، فكأنَّه قيل: يُؤثرون الحياة الدنيا على الآخرة {3}، قال ابن عبّاس: يريد ما يُعجَّل لهم من {4} الدنيا وإن كان حرامًا أخذوه تهاونًا بأمر الآخرة {5}، واستبعدوها {6}، مثل قول: ﴿إِنَّ هَؤُلَاءِ يُحِبُّونَ الْعَاجِلَةَ﴾ [الإنسان: 27].﴿وَيَصُدُّونَ عَنْ سَبِيلِ اللَّهِ﴾ ويمنعون الناس عن دين الله وطاعته، ﴿وَيَبْغُونَهَا عِوَجًا﴾ ذكرنا معناه بالاستقصاء في سورة آل عمران {7}.وقوله تعالى: ﴿أُولَئِكَ فِي ضَلَالٍ بَعِيدٍ﴾ قال عطاء: يريد في خسران كبير {8}، وقال الكلبي: يعني في خطأ بعيد عن الحق {9}، ويقال: طويل."
  14,4,"قوله تعالى: ﴿وَمَا أَرْسَلْنَا مِنْ رَسُولٍ إِلَّا بِلِسَانِ قَوْمِهِ﴾ اللسان يستعمل على معان؛ أحدها: الجارحة {1}، قال الفراء: لم نسمعه من العرب إلا مُذكَّرًا {2}، وقال أبو عمرو: اللسان بعينه يذكَّر ويؤنث، فمن ذكَّره جمعه ألسنة، ومن أنَّثه جمعه ألْسُنًا {3}، واللسان يستعمل بمعنى الثناء، يقال: إن لسان الناس عليه لحسنةٌ وخيرٌ، أي: ثناؤهم {4}، ومنه قوله تعالى: ﴿وَاجْعَلْ لِي لِسَانَ صِدْقٍ﴾ [الشعراء: 84]، وقال ابن الأنباري: العرب تُوقع اللسان على الخطبة، والرسالة والكلمة والكلام، يقولون: له لسانٌ حسنةٌ، يعنون: خطبة وعبارة وكلمة، ويقولون: سبق من زيد لسانٌ عمَّه، يعنون: الكلام {5}، واللسان: اللغة أيضًا، وهو قول المفسرين {6}، وأهلِ اللغة {7} في هذه الآية، قالوا في قوله: ﴿إِلَّا بِلِسَانِ قَوْمِهِ﴾ بلغة قومه ليفهموا عنه ويعقلوا، يدل لحى هذا قوله: ﴿لِيُبَيِّنَ لَهُمْ﴾، ويقال: فلان يتكلم بلسان العرب، أي: بلغتهم {8}، قال أبو بكر: ولهذا المعنى وحد اللسان، وإن أضيف إلى القوم؛ لأنه أريد باللسان اللغة، واللغة تقع على قليل المنطق وكثيره؛ نحو: الحِنطة والذرة والقمح والعسل والشعير وما أشبهها من أسماء {9} الأجناس التي تقع على القليل والكثير بلفظ واحد {10}، قال ابن عباس في هذه الآية: يريد بلسان سعد {11} بن بكر بن هوازن؛ وهي من أفصح العرب؛ وهي لغة يفهمها جميع العرب.وقوله تعالى: ﴿فَيُضِلُّ اللَّهُ مَنْ يَشَاءُ﴾ قال ابن عباس: جعل المشيئة إليه وحده لا شريك له {12}، قال أبو بكر: رَفَعَ ﴿فَيُضِلُّ اللَّهُ مَنْ يَشَاءُ﴾ بعد التّبيين بإيثاره الباطل {13}، ﴿وَيَهْدِي مَنْ يَشَاءُ﴾: باتِّباع الحق.قال الفراء: وإذا رأيت الفعل منصوبًا وبعده فعل قد نُسِق {14} عليه فإن كان {15} يُشاكل {16} معنى الفعل الذي قبله نَسَقْته {17} عليه، وإن رأيته غير مشاكل لمعناه استأنفته فرفعته؛ نحو قوله: ﴿يُرِيدُونَ أَنْ يُطْفِئُوا نُورَ اللَّهِ بِأَفْوَاهِهِمْ وَيَأْبَى اللَّهُ﴾ [التوبة: 32] فيأبى في موضع رفع لا يجوز إلا ذلك {18}؛ لأنه لا يحسن أن تُبادل {19} بـ ﴿يُرِيدُونَ أَنْ﴾: ﴿وَيَأْبَى اللَّهُ﴾ فإذا لم يمكن وضع الثاني موضع الأول بطل العطف، ومثله قوله: ﴿لِنُبَيِّنَ لَكُمْ وَنُقِرُّ {20} فِي الْأَرْحَامِ﴾ [الحج: 5] ومن ذلك قولهم: أردت أن أزورك فيمنعُنى المطرُ، بالرفع غير منسوق على ما قبله لما ذكرنا، ومثله قول الشاعر {21}:يُريدُ أن يُعْرِبَه فيُعْجمُه {22}"
  14,5,"قوله تعالى: ﴿وَلَقَدْ أَرْسَلْنَا مُوسَى بِآيَاتِنَا﴾ أي: بالبراهين التي دلت على صحة نبوته مثل اليد والعصا وغيرهما من آيات موسى {1}.وقوله تعالى: ﴿أَنْ أَخْرِجْ قَوْمَكَ﴾ أي: بأن أخرج قومك {2}، قال أبو إسحاق: (أنْ) هاهنا يصلح أن تكون المخففة {3} التي للخبر، ويصلح أن تكون مفسِّرة {4} بمعنى: أيّ، ولكون المعنى: ﴿وَلَقَدْ أَرْسَلْنَا مُوسَى بِآيَاتِنَا﴾ أي {5}: أخرج قومك، كأن المعنى: قلنا له: أَخْرِج قومك، ومثل هذا قوله: ﴿وَانْطَلَقَ الْمَلَأُ مِنْهُمْ أَنِ امْشُوا﴾ [ص: 6]: (أي امشوا) {6} والتأويل: قالوا لهم امشوا {7}، وإن جعلتها المخففة التي هي للخبر كان المعنى: أرسلناه بأن يخرج قومه، إلا أن الجار حذف ووُصِلتْ (أن) بلفظ الأمر للمخاطب، والمعنى معنى الخبر؛ نحو قولك: كتبت أن قُمْ، وأمرته أن يقوم، إلا أنها وصلت بلفظ الأمر الذي كان للمخاطب، وحُكي القولين عن سيبويه {8}.وقوله تعالى ﴿مِنَ الظُّلُمَاتِ إِلَى النُّورِ﴾ قال ابن عباس: يريد من الشرك إلى الإيمان {9}، ﴿وَذَكِّرْهُمْ بِأَيَّامِ اللَّهِ﴾، الأيام: جمع يوم، واليوم مقداره من طلوع {10} الشمس إلى غروبها، وكانت الأيام في الأصل: أيْوام واجتمعت الياء والواو، سُبقت إحداهما بالسكون فأدغمت إحداهما في الأخرى وغُلبت الواو {11}، ويُعبَّر بالأيام عن الوقائع والنِّعم والنقم؛ لأن هذه كلها تقع فيها، ذَكره شَمر، وقال ابن السَّكِّيت: العرب تقول: الأيام في معنى الوقائع، يقال: هو عالم بأيام العرب، يريد: وقائعها {12}.قال ابن عباس في هذه الآية: يريد بنِعم الله {13}، وهو قول مجاهد {14}، وأبي بن كعب؛ رواه عن النبّي ﷺ في قوله: ﴿وَذَكِّرْهُمْ بِأَيَّامِ اللَّهِ﴾ قال: ""أيامه: نِعَمُه"" {15}.ونحو هذا قال الحسن {16}، وسعيد بن جبير {17}، وقال مقاتل بن سليمان: بوقائع الله في الأمم السالفة {18}، قال أبو إسحاق: أي ذكِّرهم بنِعم أيام الله عليهم، وبنقم أيام الله التي انتقم فيها من قوم نوح وعاد وثمود {19}، وقال الفراء: يقول: خوِّفهم بما نزل بعاد وثمود وغيرهم من العذاب، وبالعفو {20} عن آخرين، وهو في المعنى: خذهم بالشدة واللين {21}.وقال أهل المعاني: يقول: عظهم بالترغيب (والترهيب، والوعد والوعيد؛ والترغيب) {22}، والوعد: (أن يذكِّرهم) {23} بما أنعم الله عليهم، وعلى مَن قبلهم ممن آمنوا بالرسل وصدَّقوه فيما مضى من الأيام، (والترهيب والوعيد: أي ذكِّرهم بأس الله وعذابه وانتقامه ممن كذَّب الرسل فيما مضى من الأيام) {24}؛ ليرغبوا في الوعد فيصدِّقوا، ويحْذروا فيتركوا التكذيب {25}، ومن الأيام التي أريد بها الدُّول من النعيم {26} قوله تعالى: ﴿وَتِلْكَ الْأَيَّامُ نُدَاوِلُهَا بَيْنَ النَّاسِ﴾ {27} [آل عمران: 140]، والعرب تقول: من ير يومًا (يُرَ به {28}، معناه: من يرى لنفسه يوم سرور بمصرع غيره، رأى غيرُه مثلَ ذلك اليوم بمصرعه، وكل هذا) {22} يدل على أنه يُعبَّر باليوم والأيام من حادثات الخير والشر {30}.وقوله تعالى: ﴿إِنَّ فِي ذَلِكَ لَآيَاتٍ لِكُلِّ صَبَّارٍ شَكُورٍ﴾ قال ابن عباس: يريد لكل صَبَّارٍ على طاعة الله وعن معاصيه، شكور لأنعم الله {31}، وقال أهل المعاني: أراد لآياتٍ لكل مؤمن؛ لأن الصبر والشكر من أفعال المؤمنين، والحال لا يخلو من نعمة وشدة، والمؤمن شاكر في أحديهما {32} صابر في الأخرى {33}."
  14,6,"قوله تعالى: ﴿وَيُذَبِّحُونَ أَبْنَاءَكُمْ﴾ وقال في سورة البقرة [49] ﴿يُذَبِّحُونَ﴾ بغير واو؛ لأنه تفسير لقوله: ﴿سُوءَ الْعَذَابِ﴾ فذكر العذاب مجملاً ثم فسَّره بما بعده، ولا تحتاج في تفسيره إلى الواو كما تقول: أتاني القوم؛ زيدٌ وجعفرٌ وعمروٌ، لا تدخل الواو في زيد، لأنك أردت أن تُفسِّر به القوم، ومثل هذا قوله: ﴿وَمَنْ يَفْعَلْ ذَلِكَ يَلْقَ أَثَامًا (68) يُضَاعَفْ لَهُ الْعَذَابُ﴾ [الفرقان: 68 - 69]، والآثام {1} فيه نيَّة العذاب كثيره وقليله، ثم فسره بغير الواو فقال: ﴿يُضَاعَفْ﴾ وفي هذه السورة أدخل الواو لأن المعنى: أنهم يعذبونهم بغير التذبيح وبالتذبيح أيضًا، فقوله: ﴿وَيُذَبِّحُونَ﴾ جنس آخر من العذاب لا تفسير لما قبله، وما في هذه الآية مفسَّر {2} في سورة البقرة {3}، وما ذكرنا في معنى طرح الواو وإثباته كله معنى قول الفراء {4}."
  14,7,"قوله تعالى: ﴿وَإِذْ تَأَذَّنَ رَبُّكُمْ﴾ عطف على قوله: ﴿اذْكُرُوا نِعْمَةَ اللَّهِ عَلَيْكُمْ إِذْ أَنْجَاكُمْ﴾، ﴿وَإِذْ تَأَذَّنَ رَبُّكُمْ﴾ وهذا {1} إخبار عما قال موسى لقومه، ومعنى ﴿تَأَذَّنَ﴾ قال المفسرون: أعْلَم {2}، قال الفراء: تأذن وأذن بمعنى واحد {3}، وربما قالت {4}: تفعَّل وأفعل في معنى واحد، وهذا من ذلك {5} ومثله: توعَّد وأوعد، وهو كثير، وذكرنا الكلام في تأذن في سورة الأعراف {6}.وقوله تعالى: ﴿لَئِنْ شَكَرْتُمْ لَأَزِيدَنَّكُمْ﴾ قال ابن عباس: يريد لئن وحدتموني وأطعتموني لأزيدنكم نعمة {7} ومعنى شكر النعمة هو الاعتراف بحق المنعم، والاعتراف بحق الله تعالى هو التوحيد والطاعة، فلذلك فسَّره ابن عباس بهما، ومعني قوله: ﴿لَأَزِيدَنَّكُمْ﴾ أي مما يجب الشكرعليه؛ وهو النعمة.وقوله تعالى: ﴿وَلَئِنْ كَفَرْتُمْ﴾ أي جحدتم حقي وحق نعمتي، ﴿إِنَّ عَذَابِي لَشَدِيدٌ﴾ تهديد بالعذاب على كفران النعمة."
  14,8,"قوله تعالى: ﴿وَقَالَ مُوسَى إِنْ تَكْفُرُوا أَنْتُمْ وَمَنْ فِي الْأَرْضِ جَمِيعًا فَإِنَّ اللَّهَ لَغَنِيٌّ﴾: عن خلقه وعن شكر العباد، و (حَمِيدٌ): مستحق للحمد في أفعاله لأنه مُتفضِّل بفعله أو عادل فيه.قال ابن عباس: يريد لا يُنْقص كفرُكُم ملكوت الله شيئًا {1} ولا تزيد طاعتُكم لله ملْكًا {2}.وقال أهل المعاني: هذا بيان أن {3} الله تعالى يجلُّ {4} عن لَحَاق المنافع والمضار."
  14,9,"قوله تعالى: ﴿أَلَمْ يَأْتِكُمْ﴾ إلى قوله: ﴿وَالَّذِينَ مِنْ بَعْدِهِمْ﴾ يعني: من بعد هؤلاء الذين ذكرهم من أهلكهم الله بتكذيبهم رسلهم، ﴿لَا يَعْلَمُهُمْ إِلَّا اللَّهُ﴾ فيه وجهان {1} من التفسير؛ أحدهما: أن معناه والذين من بعدهم لا يحصى عددهم ولا يعرف تعيينهم وتحصيلهم إلا الله وحده، وهذا قول ابن عباس لأنه قال: ﴿لَا يَعْلَمُهُمْ إِلَّا اللَّهُ﴾: لكثرتهم {2}، فأما النسابون الذين نسبوا القبائل إلى آدم فإنهم لا يدَّعون إحصاء جيمع الأمم بعد عاد وثمود والإحاطة بمعرفة أجناسها وأنواعها لكنهم ينسبون بعضًا يعرفونه ويمسكون عن نسب بعض، وقوم من المفسرين يحملونه على أن أكثر أهل العلم يبطلون من النسب ما جاوز عدنان، ويقولون أولئك أمم لا يَعرف تعيينهم {3} غير الله -عز وجل- {4} ولهذا قال ابن مسعود في هذه الآية: كذب النسَّابون {5}، وقال عروة بن الزبير: ما وجدنا أحدًا يعرف ما وراء عدنان {6}. وروى الكلبي عن أبي صالح عن ابن عباس قال: بين عدنان وإسماعيل ثلاثون أبًا لا يُعرفون {7}.قال ابن الأنباري: فمن بني على هذه الآثار، قال مَنْ فوق عدنان منقطعة معرفتهم عن قلوب الناس، إلا من كان من الأنبياء الذين نوه الله بأسمائهم، وعلى قول هؤلاء: لا يعرف النسابون أحدًا ممن قال الله تعالى: ﴿لَا يَعْلَمُهُمْ إِلَّا اللَّهُ﴾ (لأن الله تعالى) {8} أهلك أممًا من العرب وغيرها فانقطعت أخبارهم وعفت آثارهم وبطلت أنسابهم {9}.وقوله تعالى: ﴿فَرَدُّوا أَيْدِيَهُمْ فِي أَفْوَاهِهِمْ﴾ اختلفوا في تأويل هذه؛ فقال ابن مسعود: عضُّوا عليها غيظًا {10}، والمعنى: سَبُّوا {11} الرسلَ وأبغضوهم وثقل عليهم مكانهم، وعضُّوا على أصابعهم من شدة الغيظ، وهذا معنى قول ابن عباس في رواية عطاء وابن زيد {12} واختبار ابن قتيبة {13}، واعتبروا هذا بقوله: ﴿وَإِذَا خَلَوْا عَضُّوا عَلَيْكُمُ الْأَنَامِلَ مِنَ الْغَيْظِ﴾ [آل عمران: 119] وقد مرَّ، وقال الكلبي: أي وضعوا الأيدي على الأفواه إشارة إلى الرسل أن اسكتوا {14}.ورُوي عن ابن عباس أنه قال: كان إذا جاءهم الرسول سكَّتوه وأشاروا بأيديهم إلى أفواه أنفسهم كما تُسَكِّت {15} أنت غيرَك {16}. وقال مقاتل: كانوا يأخذون أيدي الرسل فيضعونها على أفواههم ليسكتوهم ويقطعوا كلامهم {17}. وذكر الفراء والزجاج وابن الأنباري قولًا آخر وهو أن المعنى: ردوا نِعَمَ الرسل بأفواههم، فالأيدي هاهنا المراد بها النِعم.قال الفراء: أي ردوا ما لو قبلوه لكان نعمًا من الله -عز وجل- عندهم {18}.وقال الزجاج: ردوا أيدي {19} الرسل: أي نِعَم الرسل؛ لأن مجيئهم بالبينات نِعَمٌ {20}.(وقال أبو بكر: ويجوز أن يكون المعنى: ردوا نعم أنفسهم؛ لأنها نعم) {21} من الله عليها {22} رفضوها واطَّرحوها، وجاء رجل (في) على معنى الباء؛ لقيام بعض الصفات مقام بعض {23}، وتقول: طيِّئ {24}: أدخلك الله في الجنَّة، وأنشد الفراء: وأرغبُ فيها من لَقِيطٍ ورهْطِهِ ... ولكنَّني عن سِنْبِس لَسْتُ رَاغبٌ {25}أراد: أرغب بهذه المرأة عن هؤلاء.وقال أبو إسحاق: ومعنى في أفواههم: بأفواههم، أي ردوا تلك النِعَم بالنطق بالتكذيب بما جاءت به الرسل كما يقول: جلست في البيت وبالبيت {26}، وهذا معنى قول مجاهد: ردوا نعمهم بأفواههم {27}.وقال أبو عبيدة: مجاز هذا مجاز المَثَل، ومعناه: كفوا عما أمروا بقبوله من الحق ولم يؤمنوا به، قال: ويقال: ردّ يده في فمه، أي: أمسك ولم يجب {28}، ويكون المعنى على هذا: لم يجيبوا الرسل إلى ما دعوهم إليه، فعبَّر عن ترك إجابتهم بوضع اليد في الفم؛ وذلك أن الواضع يده في فمه لا يقدر على الكلام.وقوله تعالى: ﴿وَقَالُوا إِنَّا كَفَرْنَا بِمَا أُرْسِلْتُمْ بِهِ﴾ أي: على زعمكم بالإرسال؛ لأنهم لم {29} يُقرُّوا أنهم أرسلوا."
  14,10,"قوله تعالى: ﴿قَالَتْ رُسُلُهُمْ أَفِي اللَّهِ﴾ الآية. هذا استفهام معناه الإنكار أي لا شكَّ في الله، والمعنى في توحيد الله، ثم وُصف بما يدل على وحدانيته؛ وهو قوله: ﴿فَاطِرِ السَّمَاوَاتِ وَالْأَرْضِ يَدْعُوكُمْ﴾ أي: بالرسل والكتب.وقال ابن، عباس: ﴿يَدْعُوكُمْ﴾: إلى طاعته {1}.﴿لِيَغْفِرَ لَكُمْ مِنْ ذُنُوبِكُمْ﴾ قال أبو عبيدة: (من) زائدة {2}، وأنكر سيبريه زيادتها في الواجب {3}، فإن حكمنا بزيادتها {4} فهو ظاهر، وإن لم . . . . . . . . . . . . . . . . . . . . . . . .يُحكم بزيادتها فقال بعضهم هي: للتبعيض {5}، وذُكِر البعضُ هاهنا وأُريد به الجميع توسعًا {6}.وقال بعضهم: (مِنْ) هاهنا للبدل {7}، والمعنى: لتكون المغفرة بدلاً من الذنوب، فدخلت (من) لِتُضمَّن المغفرة معنى البدل من السيئة.وقوله تعالى: ﴿وَيُؤَخِّرَكُمْ إِلَى أَجَلٍ مُسَمًّى﴾ قال ابن عباس: ويمتعكم في الدنيا في النعيم والنضارة {8} إلى الموت {9}.قال المفسرون: معناه: لا يعاجلكم بالعذاب {10}.قال صاحب النظم: أي إن لم تجيبوا إلى ما يدعوكم إليه عولجتم بالعذاب عن أجل الموت المسمى لكم {11}."
  14,11,""
  14,12,"14:11"
  14,13,"وباقي الآية وما بعدها إلى قوله: ﴿لَنُخْرِجَنَّكُمْ مِنْ أَرْضِنَا أَوْ لَتَعُودُنَّ فِي مِلَّتِنَا﴾ ظاهر، ومعنى ﴿أَوْ لَتَعُودُنَّ فِي مِلَّتِنَا﴾ ذكرناه في قصة شعيب في سورة الأعراف [آية: 88]. ابن الأنباري هاهنا، أن قوله: ﴿لَتَعُودُنَّ﴾ في الظاهر عطف على جواب اليمين، ثم أجاب عن هذا وقال معنى الكلام: لنخرجنَّكم من أرضنا حتى تعودوا في ملتنا، ولكي تعودوا، وإلا تعودوا {1}، لقول امرئ القيس {2}:إنما نُحَاوِلُ مُلْكًا أو نَمُوتَ فنُعْذَرَاالمعنى: إلا أن نموت وحتى نموت، فكان يجب على هذا أن تكون (أو تعودوا) {3}، غير أنه غلب ظاهر الكلام، ونُقل ﴿لَتَعُودُنَّ﴾ عن لفظ الشرط إلى لفظ اليمين، وأُشرك بينه وبين الذي قبله في اللفظ وإن كان مخالفه في المعنى؛ كما قالوا: لو تُرك عبد الله والأسدَ لأكله، فنصبوا الأسد لأنه مخالف الأول، ورفعه بعضُهم بالنَّسق {4} للتسوية بين اللفظين والمعنيان مختلفان حين أُمن اللبس والإشكال، وقال تعالى: ﴿تُقَاتِلُونَهُمْ أَوْ يُسْلِمُونَ﴾ [الفتح: 16]، فعطف يُسْلِمون على تقاتلون تغليبًا للَّفظ {5}، والآخر على المعنى {6}، وهذا الذي ذكرنا كله كلامُ أبي بكر، وهو شرح ما ذكره الفراء في هذه الآيهَ {7}."
  14,14,"قوله تعالى: ﴿ذَلِكَ لِمَنْ خَافَ مَقَامِي﴾ قال صاحب النظم: أشار بقوله ﴿ذَلِكَ﴾ إلى قوله: ﴿وَلَنُسْكِنَنَّكُمُ الْأَرْضَ﴾ دون ما قبله لأنه قال: ﴿ذَلِكَ لِمَنْ خَافَ مَقَامِي﴾ وخَوْفُهم لا يكون سببًا لإهلاك الظالمين، وإنما يمون سببًا لإسكانهم {1} الأرض، وهذا يدل على أن (ذلك) يجوز أن يكون إشارة إلى شيء دون شيء مما تقدمه، كقوله: ﴿ذَلِكَ لِمَنْ خَشِيَ الْعَنَتَ مِنْكُمْ﴾ [النساء: 25] إشارة إلى إباحة تزويج الأمة، وقد ذكر قبله أحكامًا سوى هذا، وهو قوله: ﴿فَإِنْ أَتَيْنَ بِفَاحِشَةٍ فَعَلَيْهِنَّ نِصْفُ مَا عَلَى الْمُحْصَنَاتِ مِنَ الْعَذَابِ﴾ [النساء: 25] ثم قال: ﴿ذَلِكَ لِمَنْ خَشِيَ﴾ وهو في الظاهر كأنه متصل بهذه القصة، وهو بالمعنى متصل بالقصة التي قبل هذا، وهو قوله: ﴿وَمَنْ لَمْ يَسْتَطِعْ مِنْكُمْ طَوْلًا﴾ إلى قوله ﴿مِنْ فَتَيَاتِكُمُ الْمُؤْمِنَاتِ﴾.والمقام هاهنا مصدر كالقيام، يقال: قام قِيَامًا ومُقَامًا {2}.ومعنى: ﴿خَافَ مَقَامِي﴾ قال ابن عباس: خاف مُقامه بين يَدَيَّ {3}.وقال الكلبي: مقامه بين يَدَي رب العالمين يوم القيامة {4}، وهذا قول أكثر المفسرين {5}.وعلى هذا، هو من باب إضافة المصدر إلى المفعول {6}؛ كما تقول: ندمت على ضربك {7}، وسُرِرْتُ {8} برؤيتك {9}، ومنه: في ﴿بِسُؤَالِ نَعْجَتِكَ﴾ {10} [ص: 24]، و ﴿مِنْ دُعَاءِ الْخَيْرِ﴾ {11} [فصلت: 49].قال الفراء: وإن شئت قلت: ذلك لمن خاف مقامي عليه ومراقبتي {12}، كقوله تعالى: ﴿أَفَمَنْ هُوَ قَائِمٌ عَلَى كُلِّ نَفْسٍ بِمَا كَسَبَتْ﴾ [الرعد:33]. وعلى هذا الوجه: المصدر مضاف إلى الفاعل، وفي قوله تعالى: ﴿وَلِمَنْ خَافَ مَقَامَ رَبِّهِ﴾ [الرحمن: 46]، الوجهان {13}.وقوله تعالى: ﴿وَخَافَ وَعِيدِ﴾، الوعيد: اسم من أوعد إيعادًا {14}، أي: تهدد، معناه: الخبر عن العقاب على الإجرام، قال ابن عباس: خاف مما أوعدت من العذاب {15}."
  14,15,"قوله تعالى: ﴿وَاسْتَفْتَحُوا﴾ ذكرنا معنى الاستفتاح عند قوله: ﴿وَكَانُوا مِنْ قَبْلُ يَسْتَفْتِحُونَ﴾ [البقرة: 89]، وللاستفتاح هاهنا معنيان، أحدهما: طلب الفتح بالنصرة {1}، والثاني: طلبه بالقضاء {2}، وكلا المعنيين ذكره المفسرون.قال ابن عباس: يعني استنصروا {3}.وقال مجاهد وقتادة: يعني الرسلُ استنصروا الله، ودعوا على قومهم بالعذاب لمّا يئسوا من إيمانهم {4}، كما قال نوح: ﴿رَبِّ لَا تَذَرْ عَلَى الْأَرْضِ﴾ [نوح: 26]، وقول موسى: ﴿رَبَّنَا اطْمِسْ عَلَى أَمْوَالِهِمْ﴾ الآية. [يونس: 88]، وقال لوط: ﴿انْصُرْنِي عَلَى الْقَوْمِ الْمُفْسِدِينَ﴾ [العنكبوت: 30]، وهذا المعنى اختيار أبي إسحاق؛ قال: سألوا الله أن يفتح عليهم، أي {5} ينصرهم، وكل نصر فهو فتح {6}.وقال ابن زيد استَقْضَوا {7}، وهو قول مقاتل؛ قال: يعني الأمم؛ وذلك أنهم قالوا: اللهم إن كان هؤلاء الرسل صادقين فعذِّبنا، شكًّا منهم في صدقهم {8}، كقوله: ﴿ائْتِنَا بِعَذَابِ اللَّهِ إِنْ كُنْتَ مِنَ الصَّادِقِينَ﴾ [العنكبوت: 29].وقوله تعالى: ﴿وَخَابَ كُلُّ جَبَّارٍ﴾، وذكرنا معنى الجبار في قوله: ﴿إِنَّ فِيهَا قَوْمًا جَبَّارِينَ﴾ [المائدة: 22]، ومعنى الجبّار هاهنا: المتكبر عن طاعة الله وعبادف، ومنه قوله تعالى: ﴿وَلَمْ يَكُنْ جَبَّارًا عَصِيًّا﴾ [مريم: 14]، قال أبو عبيد عن الأحمر {9} يقال فيه: جَبَرِيَّةٌ، وجَبَرُوُّةٌ، وجَبَرُوت، وجُبُّورَةٌ {10}.وحكى الزجاج: الجَبْرِيَّة، والجِبِريَّة، بكسر الجيم والباء، والتَّجْبَارُ، والجِبْرياء، فهي تسع لغات في مصدر {11}، وفي حديث امرأة حضرت النَّبي ﷺ فأمرها بأمر فأبت {12} عليه فقال: ""دَعُوها فإنها جبَّارة"" {13} أي: مستكبرة {14}.وقال الليث {15}: قلب جبار ذو كبْر، لا يقبل موعظة {16}.وقوله تعالى: ﴿عَنِيدٍ﴾ واختلف أهل اللغة في اشتقاق العنيد؛ فقال النضر بن شُمَيْل: العُنُود: الخلاف والتباعد والتَّرك {17}، يقال: أشدّ ما عَنَدْت من قومك، أي: باعدت {18} عنهم، قال أكثر أهل اللغة: وأصله من العنْدُ {19}، وهو الناحية، يقال: فلان يمشي عَنْدًا، أي ناحية {20}، ومنه:إنِّي كَبيرٌ لا أُطِيقُ العُنَّدا {21} فمعني عَانَد وعَنَدَ: أخذ في ناحية معرضًا.قال أبو حاتم عن الأصمعي: عَنَدَ فلان عن الطريق، يَعْنِدُ عُنُودًا إذا تباعد {22}، وروى شمر عن أبي عدنان {23} عنه {24}: عَانَد فلانٌ فلانًا إذا جَانَبَه، ودمٌ عَانِد: يسيل جَانِبًا {25}، ونحو ذلك قال الكسائي فيما رَوى عنه أبو عبيد: عَنَدَت الطعنةُ، إذا سال دمُها بعيدًا من صاحبها، وهي طنعةٌ عانِدةٌ، وعَنَدَ {26} الدمُ: إذا سال في جانب {27}، والعَنُود من الإبل: التي لا يخالطها إنما هو في ناحية أبدًا {28}، وعلى هذا المعنى كلُّ كلامِ أكثرِ المفسرين في تفسير العَنيد؛ قال قتادة: العنيد: المعرض عن طاعة الله {29}، وهو قول ابن عباس ومجاهد: هو المجانب للحق {30}.وقال إبراهيم: الناكب عن الحق {31}.وقال ابن زيد: المخالف للحق {32}.وقال أبو إسحاق: الذي يعدل عن القصد {6}.وقال قوم من أهل اللغة: أصله من: عَنَدَ الحُبَارَى فرخَه، إذا عارضه بالطيران أول ما ينهض كأنه يعلمه الطيران {34}، ومنه المَثَلُ: كلُّ شيء يحب ولده حتى الحُبَارى {35}، وُيحب عَنَدَه، أي اعتراضه، فالمعاند: المعارض لك بالخلاف {36}.قال ابن الأعرابي: أَعْنَدَ الرجل، إذا عارض إنسانًا بالخلاف، وأعْنَدَ، إذا عارض بالاتفاق {37}، وعاند البعير خطامه أي: عارضه {38}، والعَنُود من الإبل، التي تُعاند الإبل فتعارضه {39}، وقال قوم من أهل اللغة: معنى عَنَدَ، إذا أبى قبولَ الشيء مع العلم به تكبرًا عنه وبغيًا وطغيانًا {40}، ومعنى ﴿وَخَابَ كُلُّ جَبَّارٍ عَنِيدٍ﴾: فاز الرسل بالنصرة، وخاب كل من كفر؛ لأنه لم يظفر بما تمنَّى."
  14,16,"قوله تعالى: ﴿مِنْ وَرَائِهِ جَهَنَّمُ﴾ [قال ابن عباس والمفسرون: يريد أمامه جهنم] {1} بين يديه {2}، ووراء يكون لخلف وقُدَّام، وإنما معناه ما توارى عنك؛ أي: ما اسْتَتَر عنك {3} فعلى هذا إنما قيل (من ورائه) لما بين يديه؛ لاستتاره عنه، فصار كما يكون خلفه لمّا كان لا يراه. وذهب قوم إلى أن الوراء من الأضداد؛ يكون الخلف والقُدَّام {4}، وهو قول أبي عبيدة {5}، وابن السِّكِّيت {6}، وأبي الهيثم {7}.قال أهل المعاني: وإنما جاز ذلك {8} لأنه ما من مكان إلا ويصح أن يكون خلفًا وقدامًا، ولمّا {9} كان ما هو خلف يجوز أن يصير قدامًا، جاز أن يقع الوراء على القُدَّام {10}، ومن هذا قوله تعالى: ﴿وَكَانَ وَرَاءَهُمْ مَلِكٌ﴾ [الكهف:79]، أي: أمامهم {11}، ويقال: الموت من {12} وراء الإنسان، أي: أمامه، وذكر ابن الأنباري وجهًا ثالثًا؛ وهو: أن وراء هاهنا بمعنى بعد {13}، والكناية فيه تعود إلى اليأس الذي دلَّ عليه قوله: ﴿وَخَابَ﴾ كأنه قال: من بعد يأسه {14} جهنم، كقول النابغة:ولَيْسَ وَرَاء اللهِ للمَرْءِ مَذْهَبُ {15}أي: وليس بعد الله مذهب.وقال مقاتل: ﴿مِنْ وَرَائِهِ جَهَنَّمُ﴾ يعني بَعْده {16}، وهذا على معنى أن جهنم تلحقه، وأن عاقبته تصير إليها؛ كما يقال: وراءك برد شديد؛ أي: أنه يأتيك ويبلغك، وأنا من وراء هذا الأمر، أي: أصل إليه طالبًا، ومنه قول لبيد:أَلَيْسَ وَرَائِي إنْ تَرَاخَتْ مَنِيَّتي ... لُزُومُ العَصَا تُحْنَى عليها الأصَابعُ {17}جعل الشيب وزمانه وراءه، على معنى أنه يأتيه {18} ويلحقه. وبقي شيء من الكلام في وراء سنذكره عند قوله: ﴿وَكَانَ وَرَاءَهُمْ مَلِكٌ﴾ [الكهف: 79]، إن شاء الله.وقوله تعالى: ﴿وَيُسْقَى مِنْ مَاءٍ صَدِيدٍ﴾ الصديد في اللغة: ماء الجرح المختلط بالدم والقيح {19}، يقال: أصَدَّ الجرح.قال ابن عباس: يريد صديد القيح والدم الذي يخرج من فروج الزُناة {20}، وهو قول القرظي {21}، والربيع {22}.وقال قتادة والكلبي: هو ما يخرج من جلد الكافر ولحمه {23}، وتلخيص قوله: ﴿مِنْ مَاءٍ صَدِيدٍ﴾: من مائع سائل هو صديد، وقال أبو علي: تقديره: من ماء ذي صديد، قال: وهذا خلاف قوله. ﴿وَسَقَاهُمْ رَبُّهُمْ شَرَابًا طَهُورًا﴾ {24} [الإنسان: 21]."
  14,17,"قوله تعالى: ﴿يَتَجَرَّعُهُ﴾ قال: جَرعَ الماء واجْترعَه جَرعًا واجْتراعًا، فإذا تابع الجَرْع مرة بعد أُخرى كالمتكاره، قيل: تَجَرَّعه {1}، فمعنى التَّجَرُّع: تناوْل المشروب جَرْعة جَرْعة على استمرار، وهو معنى قول ابن عباس: يريد بالكُرْه {2}.وقوله تعالى: ﴿وَلَا يَكَادُ يُسِيغُهُ﴾ ذكرنا معنى (كاد) عند قوله: ﴿يَكَادُ الْبَرْقُ﴾ [البقرة: 20] ويقال: ساغ الشراب في الحلق، يَسُوْغُ سَوْغًا، وأساغه الله {3}.وأنشد الفراء {4}: وساغَ ليَ الشَّرَابُ وكُنْتُ قَبْلًا ... أكادُ أغَصُّ بالماءِ الحَمِيم {5}قال المفسرون في هذه الآية: يتحسَّاه ويشربه بالجَرع لا بمرة واحدة لمرارته {6}، وقالوا (يكاد) صلة؛ المعنى: ولا يسيغه {7}، كقوله: {لَمْ يَكَدْ يَرَاهَا} [النو: 40] أي: لم يرها، قال ابن عباس: لا يُجِيْزُه {8}.وقال أهل المعاني: معنى ﴿وَلَا يَكَادُ يُسِيغُهُ﴾: بعد إبطاء؛ لأن العرب تقول: ما كدت أقوم؛ أي: قمت بعد إبطاء، قال تعالى: ﴿فَذَبَحُوهَا وَمَا كَادُوا يَفْعَلُونَ﴾ [البقرة: 71] يعني: فعلوا بعد إبطاء؛ لتعذر وجودها، فعلى هذا (كاد) ليس بصلة.وقوله: ﴿لَمْ يَكَدْ يَرَاهَا﴾ جاز أن تكون صلة؛ لأنه قد قام الدليل عند وصف تكاثف الظلمة {9} على عدم الرؤية، فوضح {10} بذلك أنّ ﴿يَكَدْ﴾ مزيد للتوكيد، والدليل على الإساغة قوله: ﴿يُصْهَرُ بِهِ مَا فِي بُطُونِهِمْ﴾ [الحج: 20] ولا يكون الضمير {11} إلا بعد الإساغة، وأيضًا فإن قوله: ﴿يَتَجَرَّعُهُ﴾ يدل على أنهم أساغوا منه {12} الشيء بعد الشيء، فكيف أن يصح أن يقال بعده: لا يُسيغه، البتة.فإن قيل: فكيف وجه ما قاله المفسرون؟قيل: يُحْمل على وجهين؛ أحدهما: ذكره ابن الأنباري وهو أن المعنى: ولا يُسيغ جمْعه؛ كأنه يَجْرع البعض، ولم يُسغ الجميع لمرارته، فوقع الجحدُ بعد إثباتِ التَّجرعِ؛ على معنى إساغة الكل.الوجه الثاني: أن معنى الإساغة في اللغة: إجراء الشراب في الحلق على تَقَبُّل النَّفْس واستطابة المشروب {13}، والكافر يتجرع ذلك الشراب علي كراهته ولا يُسيغه أي: لا يستطيعه ولا يشربه شُربًا بمرة واحدة، فعلى ما ذكرنا من الوجهين يصح أن تكون (يكاد) صلة على ما ذكره المفسرون، وقول من لم يجعل (يكاد) صلةً أمثل.وقوله تعالى: ﴿وَيَأْتِيهِ الْمَوْتُ مِنْ كُلِّ مَكَانٍ﴾ ذكر أهل المعاني في ﴿وَيَأْتِيهِ الْمَوْتُ﴾ وجهين؛ أحدهما: أن هذا من باب حذف المضاف؛ على معنى: ويأتيه هَمُّ الموت وألمُه وكربُه {14}؛ لأنه يستحيل أن يأتيه الموت؛ عين الموت ثم لا يموت، وقد قال الله: ﴿وَمَا هُوَ بِمَيِّتٍ﴾.والمعنى: أن الله تعالى حبس نفس الكافر في جسده على اجتماع آلام الموت وأفانِينِه {15} عليه ليصل إليه الألم، ومع ذلك لم يفارقه الروح فيستريح، الوجه الثاني: أنه أراد بالموت هاهنا: موت الضُّر والبلاء؛ كما يقال: فلان ميت مما لحقه، ومات فلان موتات بما أباح {16} عليه من البلية؛ يعني: إنه كالميت وإن كان فيه روح، كما ورد في الحديث: ""إن الفقر مكتوب عند الله الموت الأعظم"" {17} وقد قال الشاعر {18}:ليس مَنْ مَاتَ فاسْتَرَاحَ بمَيتٍ ... إنَّما الميتُ ميتُ الأحْيَاءِإنَّما الميتُ مَنْ يَعيشُ كَئِيبًا ... كاسِفًا بَالُهُ قَلِيلَ الرَّخَاءِ {19}فجعله ميتًا، وهذا قول أبي بكر، وهو معنى قول الأخفش؛ يعنىِ: البلايا التي تصيب الكافر في النار {20}.وقوله تعالى: ﴿مِنْ كُلِّ مَكَانٍ﴾ قال ابن عباس: يريد من كل شعرة في جسده {21}.وقال الثوري: من كل عِرْق {22}، وهذا قول أكثر المفسرين: جعلوا المكان من جسده {23}، وروى عن ابن عباس في قوله من كل مكان: أي من كل جهة؛ من عن يمينه وشماله، ومن فوقه وتحته، ومن قدامه وخلفه {24}.وقوله تعالى: ﴿وَمِنْ وَرَائِهِ عَذَابٌ غَلِيظٌ﴾ قال عطاء عن ابن عباس: يريد أمامه يوم القيامة {25}.وقال الكلبي: يقول من بعد الصديد عذاب غليظ {26}، وهذا اختيار أبي إسحاق وأبي بكر؛ قال أبو إسحاق: أي ومن بعد ذلك {27}، وقال أبو بكر: ومن بعد هذا العذاب المذكور عذاب غليظ {28}، ومعنى غِلَظِ العذاب: اتصال الآلام وكثرتها؛ كالشيء الغليظ الذي كثر أجزاؤه وتكاثف، كما قلنا في: ﴿عَذَابٌ عَظِيمٌ﴾ [البقرة: 7]"
  14,18,"قوله تعالى: ﴿مَثَلُ الَّذِينَ كَفَرُوا﴾ الآية. اختلفوا في الرفع للمثل، فقال الزجاج: هو مرفوع على معنى: وفيما يتلى عليكم {1}، وهذا مذهب سيبويه {2}. وقال الفراء: التقدير مثل أعمال الذين كفروا بربهم كرماد، فحذف المضاف اعتمادًا على ذكره بعد المضاف إليه، وذلك أن العرب تقدِّم المضاف إليه لأنه أعرف {3}، ثم يأتي بالذي يخبر به عنه معه كهذه الآية، ألا ترى أنه قدَّم (الذين) ثم ذكر بعده الأعمال مضافة إلى الكناية عن الذين؛ كقوله تعالى: ﴿الَّذِي أَحْسَنَ كُلَّ شَيْءٍ خَلَقَهُ﴾ [السجدة: 7] أي: خَلْقَ كُلِّ شيء، ومثله قوله: ﴿وَيَوْمَ الْقِيَامَةِ تَرَى الَّذِينَ كَذَبُوا عَلَى اللَّهِ وُجُوهُهُمْ مُسْوَدَّةٌ﴾ [الزمر: 60] المعنى: ترى وجوه الذين كذبوا على الله مسودَّة {4}، وفي هذا أقوال ووجوه ذكرناها مستقصاة في قوله: ﴿مَثَلُ الْجَنَّةِ الَّتِي وُعِدَ الْمُتَّقُونَ﴾ [آية: 35] في سورة الرعد.وقوله تعالى: ﴿أَعْمَالُهُمْ كَرَمَادٍ﴾ قال الليث: الرَّمادُ دُقاق الفحم من حراقةِ النار، وصار الرَّمادُ رمادًا إذا صار هباءًا أدق ما يكون {5}، ورمَّد اللحمَ، إذا ألقاه في الرماد {6}، ومنه المثل: شَوى أَخُوك حتى إذا أنْضَجَ رَمَّدَ {7}.وقوله تعالى: ﴿فِي يَوْمٍ عَاصِفٍ﴾ قال ابن السِّكِّيت: عصفت الريح وأعصفت، فهي ريح عاصف ومُعْصِفة إذا اشتدت {8}، وقال الزجاج في باب الوفاق: عَصَفَت الرِّيحُ عُصُوْفًا وأعْصَفت إعصافًا، إذا اشتد هبوبها {9}، قال الفراء: جعل العُصوْفَ تابعًا لليوم في إعرابه {10}، وإنما العُصُوف للرياح، وذلك جائز على وجهين: أحديهما {11}: أن العُصُوْفَ وإنْ للرِّيح فإن اليوم قد يُوصَفُ به؛ لأن الريح تكون فيه، فجائز أن يقول: يومٌ عاصفٌ {12}؛ كما يقال: يومٌ باردٌ، ويومٌ حارٌ، والبرد والحر فيهما {13}، وقال أبو عبيدة: العرب تفعل ذلك في الظرف، وأنشد لجرير:لَقَد لُمْتِنا يا أُمَّ غَيْلان في السُّرَى ... ونِمْتِ وما لَيْلُ الْمَطِيِّ بنائِم {14}فوصف الليل بالنوم لَمّا كان فيه، ومثله: يوم ماطر، وليلة ماطرة {15}، وقال أبو حاتم: هذا من كلام العرب، قال الله تعالى: ﴿بَلْ مَكْرُ اللَّيْلِ وَالنَّهَار﴾ [سبأ: 33] أضاف إليهما وهما لا يمكران {16}، وقال: {وَالنَّهَارِ مُبْصِرًا} {17} [يونس: 67] ومنه قول جرير:وأعْوَرَ من نَبْهان أمّا نَهارُهُ ... فأعْمَى وأمّا لَيْلُهُ فبصِيرُ {18}قال الفراء: والوجه الآخر {19} أن يريد: في يومٍ عاصفِ الريح، فَيَحذِف الريح؛ لأنها قد ذُكرت {20} في أول الكلام، كما قال {21}:إذا جاء يومٌ مُظلِمُ الشمسِ كاسفُ {22}يريد كاسف الشمس؛ فحذفه لأنه قَدَّم ذكره، ومضى مثل هذا في قوله: ﴿بِهَا جَاءَتْهَا رِيحٌ عَاصِفٌ﴾ [يونس: 22] قال الزجاج وغيره: تأويله أن كل ما تقرَّب به الذين كفروا إلى الله فمُحْبَطٌ {23}؛ غير منتفع به {24}؛ لأنهم أشركوا فيها غير الله؛ كالرماد الذي ذرَّته الريح وصار هباءً لا ينتفع به، وذلك قوله: ﴿لَا يَقْدِرُونَ مِمَّا كَسَبُوا﴾ أي: في الدنيا، ﴿عَلَى شَيْءٍ﴾: في الآخرة، قال ابن عباس: يريد لا يجدون ثواب ما عملوا {25}.وقوله تعالى: ﴿ذَلِكَ هُوَ الضَّلَالُ الْبَعِيدُ﴾ قال ابن عباس: يريد الخسران الكبير {26}، وعلى هذا يعني بالضلال: ضلالَ أعمالهم وهلاكَها وذهابها، وإذا ذهبت أعمالُهم ذهابَ الرمادِ في عُصوف الريح، فقد كَبُرَ خسرانُهم، ومعنى ﴿الْبَعِيدُ﴾ هاهنا: الذي لا يُرْجَى عَوْده، فهو بعيد من العود؛ لذهابه على الوجه الذي ذُكر، وقال الكلبي {27}: الخطاء الطويل {28}، فعلى هذا المراد بالضلال هاهنا ضلال الكفار كقوله: ﴿ضَلُّوا ضَلَالًا بَعِيدًا﴾ [النساء: 167] أي بعيد من الهدى والرجوع عنه."
  14,19,"قوله تعالى: ﴿أَلَمْ تَرَ أَنَّ اللَّهَ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ﴾ الآية. معنى: ﴿أَلَمْ تَرَ﴾ هاهنا التنبيه {1} على خَلْق السموات والأرض، وقرأ حمزة والكسائي: ﴿خَالِقَ السَّمَاوَاتِ﴾ على فاعل {2} فمن قرأ: ﴿خَلَقَ﴾ {3} أخبر بلفظ الماضي على فَعَل؛ لأن ذلك أمرٌ ماض، ومن قرأ: ﴿خَالِقُ﴾ قال هو كقوله: ﴿فَاطِرِ السَّمَاوَاتِ﴾ [فاطر: 1]، وقوله تعالى: ﴿فَالِقُ الْإِصْبَاحِ وَجَعَلَ اللَّيْلَ سَكَنًا﴾ [الأنعام: 96] وكل هذا مما قد فُصِّل ومَضى، ومعنى قوله: ﴿بِالْحَقِّ﴾ ذكرنا الكلام فيه عند قوله: ﴿مَا خَلَقَ اللَّهُ ذَلِكَ إِلَّا بِالْحَقِّ﴾ في سورة يونس [آية: 5].وقوله تعالى: ﴿إِنْ يَشَأْ يُذْهِبْكُمْ وَيَأْتِ بِخَلْقٍ جَدِيدٍ﴾ قال ابن عباس والكلبي: يريد أُمِيْتُكم يا معشر الكفار وأخلق قومًا غيركم خيرًا منكم وأطوع، وهو خطاب لأهل مكة {4}.وقال أهل المعاني: دلّ بقوله: ﴿خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ﴾ (على قدرته على الإهلاك والإذهاب؛ لأنه إذا قَدر على خلق السموات والأرض) {5} قدر على إذهابهم بالهلاك؛ لأن من قدر على الإيجاد قدر على الإفناء {6}، وأما الجديد، فمصدره الجِدَّة، ويقال: أجَدَّ ثوبًا واسْتَجدَّه، إذا اتخذه جديدًا {7} وأصله من قولهم: قُطع عنه العمل في ابتداء أمره، وقال المازني في قوله {8}: أرَسْمًا جَدِيدًا من سُعادَ تَجَنَّبُ {9}أراد بالجديد المقطوع الأثر لدروسه {10}، وفي ذكر الجديد في الآية دليل على أنه {11} ذلك الخلق الذي يأتي بهم جديدًا هم أفضل من الأول وأطوع لله، كما قال المفسرون {12}؛ لأنهم لو كانوا كالأول في العصيان لم يكن فائدة في إذهابهم والإتيان بغيرهم."
  14,20,"قوله تعالى: ﴿وَمَا ذَلِكَ عَلَى اللَّهِ بِعَزِيزٍ﴾ قال ابن عباس: يريد لا يعز عليه شيء يريده {1}.قال الكسائي: ليس يعز على الله أن يميتكم ويأتي بغيركم {2}.وقال أهل المعاني: أي: لا يمتنع على مَنْ قَدَر على خَلْق السموات والأرض أن يذهبكم ويأتي بخلق سِواكم {3}، ومضى الكلام في معنى العزيز، ومعناه هاهنا: الممتنع بقوته."
  14,21,"قوله تعالى: ﴿وَبَرَزُوا لِلَّهِ جَمِيعًا﴾ برز معناه في اللغة: ظهر بعد الخفاء، ومنه يقال للمكان الواسع البَرازُ؛ لظهوره {1}، وقيل في قوله: ﴿وَتَرَى الْأَرْضَ بَارِزَةً﴾ [الكهف: 47] أي: ظاهرة بلا جبل ولا تل يستر ما وراءه {2}، وامرأة بَرْزَةٌ، إذا كانت تظهر للناس {3}، وقد جاء برز بمعنى أبْرَزَ في قول لبيد:النّاطِقُ المَبْروزُ والمختُومُ {4} قال ابن هانىء {5}: يقال: بَرزته برزًا، بمعنى {6} أبْرزْتُه برْزًا {7}، ويقال: قد بَرَزَ فلان على أقرانه، إذا فاقهم وسبقهم، وأصله في الخيل؛ إذا سبق أحدها قيل قد بَرَّز عليها {8}، كأنه خرج من غمارها فظهر.قال ابن عباس في قوله: ﴿وَبَرَزُوا لِلَّهِ جَمِيعًا﴾ يريد: في البعث يوم القيامة {9}.قال المفسرون: خرجوا من قبورهم {10} وورد هذا بلفظ المضي وإن كان معناه الاستقبال، لتحقق كونه {11} كما ذكرنا في قوله: ﴿وَنَادَى أَصْحَابُ النَّارِ﴾ [الأعراف: 50]، ﴿وَنَادَى أَصْحَابُ الْجَنَّةِ﴾ [الأعراف: 44]؛ لأنه أصدَق وقوعَه؛ كأنه قد وقع وأتى، ومعنى ﴿اللَّهُ﴾ اللام هاهنا لام أجل، وتأويله: لأجل أمر الله إيّاهم بالبروز {12}.وقال أبو إسحاق: أي جمعهم الله في حشرهم فاجتمع التابع والمتبوع {13}، ﴿فَقَالَ الضُّعَفَاءُ﴾ وهم الأتباع، ﴿لِلَّذِينَ اسْتَكْبَرُوا﴾ قال ابن عباس: يريد الأتباع لأكابرهم الذين استكبروا عن عبادة الله {14}، ﴿إِنَّا كُنَّا لَكُمْ﴾ أي: في الدنيا ﴿لَكُمْ تَبَعًا﴾، قال الفراء وأبو عبيدة وجميع أهل العربية: التَّبَعُ جمع تابع مثل: خادم وخَدَم، وغائب وغَيَب، ونافر ونفَر، وحارس وحَرَس، وراصد ورَصَد {15}.قال الزجاج: وجائز أن يكون مَصْدرًا سُمَّي به، أي: كنا ذوي تبع {16}.﴿فَهَلْ أَنْتُمْ مُغْنُونَ عَنَّا مِنْ عَذَابِ اللَّهِ﴾ قال ابن عباس: فهل أنتم دافعون عنا من عذاب الله) {17}، ﴿قَالُوا لَوْ هَدَانَا اللَّهُ لَهَدَيْنَاكُمْ﴾ يريدون أنهم إنما دعوهم إلى الضلال؛ لأن الله تعالى أضلهم ولم يهدهم، فدعوا أتباعهم إلى ما كانوا عليه من الضلال، ولو هداهم الله لدعوهم إلى الهدى، هذا قال ابن عباس: لو أرشدنا الله لأرشدناكم {18}.وقوله تعالى: ﴿سَوَاءٌ عَلَيْنَا﴾ إلى آخره، قال الزجاج: ﴿سَوَاءٌ﴾ ابتداء، و ﴿أَجَزِعْنَا﴾ في موضع الخبر {19}، والكلام في هذا قد سبق في قولى: ﴿سَوَاءٌ عَلَيْهِمْ أَأَنْذَرْتَهُمْ﴾ [البقرة: 6]، وذكرنا معنى المحيص في قوله: ﴿وَلَا يَجِدُونَ عَنْهَا مَحِيصًا﴾ [النساء: 121]."
  14,22,"قوله تعالى: ﴿وَقَالَ الشَّيْطَانُ لَمَّا قُضِيَ الْأَمْرُ﴾ الآية. قال المفسرون: إذا استقر أهل الجنّة في الجنّة وأهل النار في النار، اجتمع أهل النار باللائمة على إبليس لعنه الله، فيقوم فيما بينهم خطيبًا ويقول ما أخبر الله تعالى بقوله: ﴿وَقَالَ الشَّيْطَانُ﴾ الآية. {1} قال أبو إسحاق: ذكر الله أمر إبليس وما يقوله في القيامة تحذيرًا من إضلاله وإغوائه {2}.وقوله تعالى: ﴿لَمَّا قُضِيَ الْأَمْر﴾ قال ابن عباس: يريد حين قضى الله بين العباد؛ فصار أهل الجنّة إلى منازلهم وكرامتهم، وأمَرَ بأهل جهنّم إلى العذاب {3}، وقال الضحاك: فُرغ من الأمر {4}، وهو معنى قول ابن عباس.وقوله تعالى: ﴿إِنَّ اللَّهَ وَعَدَكُمْ وَعْدَ الْحَقِّ﴾ قال مقاتل: يعني كون هذا اليوم فَصَدَقكم {5} وعْده، ووعدتكم أنه غير كائن فأخلفتكم {6}، وقال أبو إسحاق: أي وعد من أطاعه الجنّة ووعد من عصاه النار، ووعدتكم خلاف ذلك {2}.وقوله تعالى: ﴿وَعْدَ الْحَقِّ﴾ هو من باب إضافة الشيء إلى نَعْته كقوله: ﴿وَحَبَّ الْحَصِيدِ﴾ [ق: 9] ومسجد الجامع، على قول الكوفيين، والمعنى: وعدكم الوعدَ الحقَ {8}، وعلى مذهب البصريين يكون التقدير: وعْدَ اليومِ الحقِ، أو الأمر الحق {9}، أو يكون التقدير: وعدكم الحق ثم ذكر المصدر تأكيدًا وفيه إضمار؛ لأن تلخيصه: وعدكم وعد الحق فصدقكم، وحُذف ذلك لدلالة تلك الحالة على صدق ذلك الوعد والوفاء به، ولأنه ذكر في وعد الشيطان الإخلافُ، فدل ذلك على الصدق في وعد الله.وقوله تعالى: ﴿وَوَعَدْتُكُمْ فَأَخْلَفْتُكُمْ﴾ الوعد يقتضي مفعولًا ثانياً، وحُذف هاهنا للعلم به والتقدير: ووعدتكم أن لا جنّة ولا نار ولا حشر ولا حساب فأخلفتكم.وقوله تعالى: ﴿وَمَا كَانَ لِيَ عَلَيْكُمْ مِنْ سُلْطَانٍ﴾ قال ابن عباس: يريد من حجة أحتج بها عليكم، أي: بما أظهرت لكم حجة {10}، ﴿إِلَّا أَنْ دَعَوْتُكُمْ﴾ هذا من الاستثناء المنقطع؛ أي: لكن دعوتكم ﴿فَاسْتَجَبْتُمْ لِي﴾ {11} قال: يريد فصدقتموني وقبلتم مقالتي، وقال أبو إسحاق: أي أغويتكم وأضللتكم فاتبعتموني {2}، ﴿فَلَا تَلُومُونِي وَلُومُوا أَنْفُسَكُمْ﴾ حيث أجبتموني وطاوعتموني من غير سلطان ولا برهان، قال أهل المعاني: ولَوْم النفس يصح على الإساءة كما يصح حمدها على الإحسان {13}، كما قال {14}: صَحِبْتُك إذ عَيْنِي عليها غِشَاوةٌ ... فلما انْجَلَتْ قطَّعْتُ نَفْسِي ألُومُها {15}وقوله تعالى: ﴿مَا أَنَا بِمُصْرِخِكُمْ﴾ قال ابن عباس: يريد بمغيثكم ولا منقذكم {16} وهو قول الجميع {17}.وقال ابن الأعرابي: المصارخ {18} المُسْتَغيث، والمُصْرِخُ المُغِيثُ {19}، يقال: صرخ فلان، إذا استغثاث وقال: واغوْثاه، وأصرختُه: أغثته، وقال الفراء: أصرخْتُ الرجل، إذا أغثته إصْراخًا، وقد صَرَخَ الصَّارخ يَصْرَخُ، ويَصْرُخُ لغة قليلة، صَرْخًا وصُرَاخًا {20}.وقوله تعالى: ﴿وَمَا أَنْتُمْ بِمُصْرِخِيّ﴾ القراءة الصحيحة فتح الياء {21} وهو الأصل {22}.قال الزجاج: وذلك أن [ياء] {23} الإضافة إذا لم يكن قبلها ساكن حُرِّكتْ إلى الفتح؛ نحو غلاميَ، وذلك أن الاسم المضمر لمّا كان علي حرف واحد وقد منع الإعراب، حرِّك بأخف الحركات {24}، ويجوز إسكانها {25}، لثقل {26} الياء التي قبلها كسرة {27}، وإذا كان قبل الياء ساكن حرَّكت إلى الفتح لا غير {28}، لأن أصلها أن تحرك ولا ساكن قبلها، فإذا كان قبلها ساكن صارت حركتُها لازمةً لالتقاء الساكنين؛ نحو: ﴿هُدَايَ﴾ [طه: 123]، و ﴿وَمَحْيَاىَ﴾ [الأنعام: 162]، و ﴿عَصَايَ﴾ [طه: 18] ونحو هذا قال الفراء {29}، وقراءة حمزة ﴿بِمُصْرِخِيَّ﴾ بكسر الياء {30} وهو {31} قراءة الأعمش {32} ويحيى بن وثاب {33}.قال الفراء: ولعلها من وهْم القُرَّاء {34} فإنه قلَّ من سَلم منهم من الوهْم، ولعله ظن أن الباءَ {35} في ﴿بِمُصْرِخِيَّ﴾ خافضةٌ للحرف كله، والياء من المتكلم خارجةٌ من ذلك، ومما يرى أنهم أوهموا فيه: ﴿نُوَلِّهِ مَا تَوَلَّى وَنُصْلِهِ جَهَنَّمَ﴾ [النساء: 115] ظنُّوا والله أعلم أن الجزم في الهاء، والهاءُ في موضع نصب، وقد انجزم الفعل قبلها بسقوط الياء منه، قال: وسمعت بعض العرب {36} ينشد:قلت {37} لَهَا هَل لَكِ يَا تَا فيِّ ... قالَتْ لنا ما أنتَ بالمَرْضِيّ {38} فخفض الياء من (فيِّ) فإن يك ذلك صحيحًا، فهو مما يلتقي من الساكنين فيُخفض الآخِرُ منهما، وإن كان له أصل في الفتح، ألا ترى أنهم يقولون: لي أره منذ {39} اليوم، والرفع في الذال هي {40} الوجه {41}، والخفض جائز، فكذلك الياء من مصرخيّ خفضت ولها أصل في النصب، انتهى كلامه، {42}. وقال أبو إسحاق: هذه القراءة عند جميع النحويين ردية مرذولة لا وجه لها إلا وُجَيْه {43} ضعيف! وهو ما أجازه الفراء من الكسر على أصل التقاء الساكنين، وأنشد:قالَ لَهَا هَل لكِ يا تا فيِّ ... قالَتْ له ما أنْتَ بالمَرْضِيوهذا الشعر مما لا يُلتفت إليه، فليس يُعرف قائل هذا الشعر من العرب {44}، ولا هو مما يحتج به {45} في كتاب الله {46}.قال أبو علي: زعم قطرب أن هذا لغة في بني يربوع {47}؛ يزيدون على ياء (الإضافة ياء) {48} وأنشد:ماضٍ إذا ما هَمَّ بالمُضِىّ {49} ... قال لَهَا هل لكِ يا تا فيِّقال: ووجه ذلك من القياس أن الياء ليست تخْلُو من أن تكون في موضع نصب أو جر، فالياء في النصب والجر كالهاء فيهما، وكالكاف في: أكبر منك {50}، وهذا لك، فكما أن الهاء قد لحقتها الزيادة {51} في قولك: هذا الشيء لَهُو، وضَرَبَهُو، ولحق الكاف أيضًا الزيادة {52} في قول من قال: أعْطيْتُكاه وأعطيْتُكِيه، فيما حكاه سيبويه {53} وهما أختا الياء، وكما لحقت التاء الزيادة في نحو ما أنشد {54}:رَمَيْتِيهِ فأصمَيْتِ ... وما أخْطَاتِ الرَّمْيَه {55}كذلك ألحقوا الياء الزيادة من المدّ، فقالوا: (فِيِّي) ثم حذفت الياءُ الزائدة على الياء {56} كما حذفت من الهاء في قوله {57}:وما لَهُ من مَجْدٍ تَلِيد {58}وكما حذفت الزيادة من الكاف، في قول من قال: أَعْطيْتُكه وأَعطيتُكِه {59}، كذلك حذفت الياء اللاحقة للياء كما حذفت من أختيها {60} وأُقرَّت الكسرة التي كانت تلي الياء المحذوفة، فبقيت الياء على ما كانت عليه من الكسرة {61}، فإذا كانت هذه الكسرة في الياء على هذه {62} وإن كان غيرها أفشى منها، وعضَّده من القياس ما ذَكَرْنا، لم {63} يجز لقائل أن يقول: إن القراءة بذلك لحن؛ لاستقامة {64} ذلك في السماع والقياس {65}، وما كان كذلك لا يكون لحنًا {66}.قوله تعالى: ﴿إِنِّي كَفَرْتُ بِمَا أَشْرَكْتُمُونِ مِنْ قَبْلُ﴾ ما هاهنا بمعنى المصدر؛ أي: كفرت بإشراككم إيَّاي {67} مع الله في الطاعة {68}، قال الزجاج: إني كفرت بشرككم أيُّها التُّباع إيّاي بالله {69} وهذا معنى قول ابن عباس: يريد: إني {70} جحدت بما كنتم تطيعوني في الدينا؛ وتلخيصه: جحدت أن أكون شريكًا لله فيما أشركتموني {71}، وقال الفراء: ﴿إِنِّي كَفَرْتُ بِمَا أَشْرَكْتُمُونِ﴾ هذا من قول إبليس؛ يعني: كفرت بالله الذي أشركتموني به، أي: كفرت به من قبلكم فجعل (ما) في مذهب ما يؤدى عن الاسم {72}، وعلى هذا القول (ما) بمعنى (مَنْ) والقول هو الأول.وقوله تعالى: ﴿إِنَّ الظَّالِمِينَ﴾ قال ابن عباس: يريد المشركين {73}، قال المفسرون: هم الذين وضعوا العبادة والطاعة في غير موضعها {74}."
  14,23,"قوله تعالى: ﴿تَحِيَّتُهُمْ فِيهَا سَلَامٌ﴾ ذكرنا معنى التحية عند قوله: ﴿وَإِذَا حُيِّيتُمْ بِتَحِيَّةٍ﴾ [النساء: 86] قال ابن عباس: يريد أن الله يُحيِّهم بالسلام من عنده، وبعضهم يُحَيِّ بعضا بالسلام {1} وعلى هذا قوله: ﴿تَحِيَّتُهُمْ﴾ مصدر مضاف، فإن جعلته مضافًا إلى الفاعل فهو تحية بعضهم بعضًا، وإن جعلته مضافًا إلى المفعول فهو تحية الله إيّاهم والملائكة، وقد ذكر ابن عباس الوجهين."
  14,24,"قوله تعالى: ﴿أَلَمْ تَرَ كَيْفَ ضَرَبَ اللَّهُ مَثَلًا﴾ أي: بيّن الله شِبْهًا، ثم فسَّر ذلك المثل، فقال: ﴿كَلِمَةً طَيِّبَةً﴾ قال ابن عباس: يريد لا إله إلا الله {1}، وهو قول عامة المفسرين {2}.وقوله تعالى: ﴿كَشَجَرَةٍ طَيِّبَةٍ﴾ قال ابن عباس في رواية عطاء: يريد النخلة {3}، وهو قول أكثر أهل التأويل {4}، وأراد: كشجرة طيبة الثمرة، فاستغنى عن ذكرها بدلالة الكلام عليها، ﴿أَصْلُهَا﴾ أي: أجل هذه الشجرة الطيبة ﴿ثَابِتٌ﴾، ﴿وَفَرْعُهَا﴾: أعلاها، قال: ﴿فِي السَّمَاءِ﴾."
  14,25,"﴿تُؤْتِي﴾ أي هذه الشجرة، ﴿أُكُلَهَا﴾: ثمرها وما يؤكل منها، ﴿كُلَّ حِينٍ﴾ الحين: وقت من الزمان قلَّ أو كثُر، طال أو قَصُر {1}، واختلفوا في المراد بالحين هاهنا؛ فقال ابن عباس في رواية عطاء: يريد ستة أشهر {2}، وهو قول سعيد بن جبير وقتادة والحسن قالوا: ما بين صرامها {3} إلى حملها ستة أشهر {4}.وقال مجاهد وابن زيد: كل سنة {5}، وهو قول ابن عباس في رواية عكرمة؛ قال: هو ما (بين العام إلى العام) {6} المقبل {7}، وقال في رواية أبي ظَبيان {8}: كل حين: كل غدوة وعشية {9}، وهو قول الربيع بن أنس {10}.وقال سعيد بن المُسيَّب: كل حين يعني: شهرين؛ لأن مدة إطعام النخلة شهران {11}، قال أهل التأويل وأهل المعاني: شبَّه الله تعالى الإيمان بالنخلة لثبات الإيمان في قلب المؤمن كثبات النخلة في مَنْبِتها، وشبَّه ارتفاع (عمله إلى السماء بارتفاع) {6} فروع النخلة، وشبَّه ما يكسبه المؤمن من بركة الإيمان وثوابه في كل وقت وزمان، بما ينال من ثمرة النخلة في أوقات [السنّة] {13} كلها؛ من الرطب والتمر وما يجري مجراهما مما لا يعدم ولا ينقطع وجوده {14}.وقال الزجاج: جعل الله مَثل المؤمن في نُطْقه بتوحيده {15}، والإيمان بنبيّه واتّباع شريعته الشجرة الطيبة؛ فجعل نفع الإقامة على توحيده كنفع الشجرة التي لا ينقطع نفعُها وثمرها {16}، وقال آخرون: إنما مَثَّلَ الله سبحانه الإيمان بالشجرة؛ لأن الشجرة لا تستحق أن تسمّى شجرة إلا بثلاثة أشياء: عرق راسخ، وأصل قائم، وفرع عال، كذلك الإيمان لا يتم إلا بثلاثة أشياء: تصديق بالقلب، وقول باللسان، وعمل بالأبدان {17}.قال ابن الأنباري: وكان غير مستنكر تشبيه الكلمة بالشجرة وهي من غير جنسها، كما لا يُستَنكر تشبيه الناس بالأسد والأقمار والبحار، وجنس الإنسان يخالف هذه الأجناس، ومعروف من كلامهم: عبد الله الشمسَ طالعة، وزيدٌ القمرَ منيرًا، وعمرو الأسدَ عاديًا {18}، وبكر البحر زاخرًا {19}.وقال أبو إسحاق في قوله: ﴿تُؤْتِي أُكُلَهَا كُلَّ حِينٍ﴾: جميع من شاهدنا من أهل اللغة يذهب إلى أن الحين اسم كالوقت، يصلح لجميع الأزمان كلها، طالت أم قصُرت، والمعنى في ﴿تُؤْتِي أُكُلَهَا كُلَّ حِينٍ﴾: أنها يُنتفع بها في كل وقت، لا ينقطع نفعها البتة، قال: والدليل على أن الحين بمنزلة الوقت قول النابغة في صفة الحيَّة والملدوغ:تَنَاذَرَها {20} الرَّاقُون من سُوء سَمِّها ... تُطَلِّقُه حِينًا وحِينًا تُراجِعُ {21} قال: المعنى أن السمَّ يخفُّ ألمه وقتًا ويعود وقتًا {22}، فعلى هذا، الاختيار: أن يكون المعنى ﴿تُؤْتِي أُكُلَهَا كُلَّ حِينٍ﴾: أي: كل وقت في جميع السنة، وهو قول الضحاك، قال: كل ساعة، ليلاً ونهارًا، شتاءً وصيفًا، تُؤكل في جميع الأوقات، كذلك المؤمن لا يخلو من الخير في الأوقات كلها {23}، وقد قال ابن عباس: يريد ستة أشهر طلعٌ رَخْصٌ {24} وستة أشهر رُطبٌ رَطيبٌ {25}، فبين أن الانتفاع بالنخلة دائم في جميع السنة.وقوله تعالى: ﴿وَيَضْرِبُ اللَّهُ الْأَمْثَالَ لِلنَّاسِ﴾ قال ابن عباس: يريد أهل مكة {26}، ﴿لَعَلَّهُمْ يَتَذَكَّرُونَ﴾: لكي يتعظوا."
  14,26,"قوله تعالى: ﴿وَمَثَلُ كَلِمَةٍ خَبِيثَةٍ﴾ يعني: الشرك بالله في قول الجميع {1}، ﴿كَشَجَرَةٍ خَبِيثَةٍ﴾ قال ابن عباس في رواية عطاء: يريد الثوم {2}، وروى مقاتل عن الضحاك عنه {3} قال: هي الكُشُوث {4}، وقال أنس بن مالك: هي الحنظل {5}، فكما أنها أخبث الأشجار، فكذلك الشرك أخبث الكلمات، وكما أنه لا ينتفع بها كذلك الشرك لا ينتفع صاحبه.وقوله تعالى: ﴿اجْتُثَّتْ﴾ قال ابن عباس: اقتلعت {6}، وقال السدّىِ: انتزعت {7}، وقال الضحاك: استؤصلت {8}، وقال الزجاج: ومعني ﴿اجْتُثَّتْ﴾ في اللغة: أخذت جُثَّتُها بكمالها {9}.وهذا قول المُؤَرِّج قال: أخذت جثتها وهي نفسها {10}.وقوله تعالى: ﴿مِنْ فَوْقِ الْأَرْضِ﴾ قال ابن عباس: يريد ليس لها أصل تام، فهي فوق الأرض لم ترسخ فيها، ولم تضرب فيها بعرق، كذلك الشرك بالله ليس له حجة ولا ثبات ولا شيء {11}.وقوله تعالى: ﴿مَا لَهَا مِنْ قَرَارٍ﴾ قال المفسرون: أي من أصل في الأرض {12}، والقرار مصدر سُمّي به المُسْتَقَر، وهذه الأشجار التي ذُكرت في {13} تفسير الشجرة الخبيثة ليس لها مستقر في الأرض يبقى على الأرض فنفى أن يكون لها قرار لمّا كانت تتقلَّع بأدنى شيء، والكَشوث لا قرار له في الأرض بتّة، قال الزجاج: المعنى أن ذكر الله بالتوحيد يبقى أبدًا، ويبقى نفعُه أبدًا، وأن الكفر والضلال لا ثبوت له {14}."
  14,27,"قوله تعالى: ﴿يُثَبِّتُ اللَّهُ الَّذِينَ آمَنُوا بِالْقَوْلِ الثَّابِتِ﴾ قال ابن عباس: يريد الذين صدّقوا محمدًا ﷺ يثبتهم بالقول الثابت وهو لا إله إلا الله {1}، وهذا دليل على أنه أراد بالكلمة الطيبة كلمة الإخلاص؛ لأنه بعدما شبهها بالشجرة الطيبة التي لها أصل ثابت، سمّاها القول الثابت.وقوله تعالى: ﴿فِي الْحَيَاةِ الدُّنْيَا﴾ قال المفسرون: يثبتهم بلا إله إلا الله في الحياة الدنيا على الحق والتمسك بالعُرَى {2}، وإذا ثبتهم بها في الدنيا ثبتهم في الآخرة.ومعنى ﴿وَفِي الْآخِرَةِ﴾: قال ابن عباس: يريد في القبر {3}، وهذا قول عامة المفسرين؛ قالوا: إن هذه الآية وردت في فتنة القبر وسؤال الملكين، وتلقين الله المؤمن كلمة الحق في القبر عند السؤال، وتثبيته إياه بها على الحق {4}.وروى ذلك البراء بن عازب مرفوعًا، أن النبيّ ﷺ قال في قوله: ﴿يُثَبِّتُ اللَّهُ الَّذِينَ آمَنُوا بِالْقَوْلِ الثَّابِتِ فِي الْحَيَاةِ الدُّنْيَا وَفِي الْآخِرَةِ﴾ قال: ""حين يقال من ربك، وما دينك، ومن نبيك؟ فيقول: ربي الله، وديني الإسلام، ونبيّ محمد ﷺ"" {5}، والباء في: ﴿بِالْقَوْلِ الثَّابِتِ﴾ من صلة التثبيت، على ما بيّنا، ويجوز أن تكون من صلة آمنوا، علر، معنى: الذين آمنوا بلا إله إلا الله يثبتهم على الحق في الحياة الدنيا وفي الآخرة، قال ابن عباس: من دام على الشهادة في الدنيا يثبته الله عليها في قبره ويلقِّنه إيّاها {6}، وإنما فسّر الآخرة هاهنا بالقبر؛ لأن الميت انقطع بالموت عن أحكام الدنيا وصار {7} مجزيًا بالحسنات والسيئات فدخل في أحكام الآخرة، قاله أبو بكر بن الأنباري، وقد أشار إلى هذا المعنى أبو إسحاق؛ فقال: ﴿فِي الْآخِرَةِ﴾ لأن هذا بعد وفاته {8}؛ يريد هذا السؤال.وقوله تعالى: ﴿وَيُضِلُّ اللَّهُ الظَّالِمِينَ﴾ يعني: لا يُلقِّن {9} المشركين [و] {10} الكافرين، حتى إذا سئلوا في قبورهم قالوا: لا ندري، قال الفراء: يُضلهم عن هذه الكلمة {11}.وقوله تعالى: ﴿وَيَفْعَلُ اللَّهُ مَا يَشَاءُ﴾ أي من تثبيت المؤمن وتلقينه الصواب وإضلاله الكافر، قال الفراء: أي لا يُنْكَر له قدرة ولا يُسأل عما يفعل {12}."
  14,28,"قوله تعالى: ﴿أَلَمْ تَرَ إِلَى الَّذِينَ بَدَّلُوا نِعْمَتَ اللَّهِ كُفْرًا﴾ قال ابن عباس: يريد كفار قريش {1}، وهو قول سعيد بن جبير ومجاهد، والضحاك {2}، وقتادة قال: هم مشركو مكة، أنعم الله عليهم بالنبيّ ﷺ فكفروا به ودعوا قومهم إلى الكفر {3}، وذلك قوله: ﴿وَأَحَلُّوا قَوْمَهُمْ﴾ يعني: الذين اتبعوهم.﴿دَارَ الْبَوَارِ﴾: الهلاك، يقال رجل بائر، وقوم بُور {4}، ومنه قولهتعالي: ﴿وَكُنْتُمْ قَوْمًا بُورًا﴾ [الفتح: 12]، هذا قول جميع أهل اللغة {5}، وأراد بـ ﴿دَارَ الْبَوَارِ﴾: جهنّم، ألا ترى أنه فسّرها فقال:"
  14,29,"﴿جَهَنَّمَ يَصْلَوْنَهَا وَبِئْسَ الْقَرَارُ﴾ أي: المقر، وهو مصدرٌ سُمي به."
  14,30,"قوله تعالى: ﴿وَجَعَلُوا لِلَّهِ أَنْدَادًا﴾ قال ابن عباس: يريد من الحجارة والخشب وغير ذلك {1}، ﴿لِيُضِلُّوا﴾: الناس عن دين الله، وقرأ الكوفيون بفتح الياء {2} والمعنى: أنهم لم ينتفعوا بما اتخذوا من الأنداد، ولم يتخذوها {3} إلا ليزيغوا عن الطريق المستقيم الذي نُصبت الأدلة عليه، وهذه لام العاقبة {4}، وقد ذكرنا معناها في مواضع.ثم أوعدهم بالعذاب فقال: ﴿قُلْ تَمَتَّعُوا فَإِنَّ مَصِيرَكُمْ إِلَى النَّار﴾ قال ابن عباس في هذه الآية: لو صار الكافر مريضًا سقيمًا، لا ينام ليلاً ولا نهارًا، جائعًا لا يجد ما يأكل ويشرب، لكان هذا كله نعيمًا عندما يصير إليه من شدة العذاب، ولو كان المؤمن في الدنيا في أنعم عيشة لكان بؤسًا عندما يصير إليه من نعيم الآخرة {5}."
  14,31,"وقوله تعالى: ﴿قُلْ لِعِبَادِيَ الَّذِينَ آمَنُوا يُقِيمُوا الصَّلَاةَ﴾ قال الفراء: جُزمت ﴿يُقِيمُوا﴾ بتأويل الجزاء، ومعناه معنى أمرة كقولك: قل لعبد الله يذهب عنا، يريد: قل له: اذهب عنا، فجُزم بنية الجواب وتأويله الأمر، ومثل هذا قوله: ﴿لِلَّذِينَ آمَنُوا يَغْفِرُوا﴾ [الجاثيه:14]، ﴿وَقُلْ لِعِبَادِي يَقُولُوا الَّتِي هِيَ أَحْسَنُ﴾ [الإسراء: 53]، هذا كلامه {1} ومعنى هذا أن {2} قوله: ﴿وَيُقِيمُوا الصَّلَاةَ﴾ معناه معنى الأمر؛ أي: قل لهم يقيموا الصلاة، إلا أنه أُجري على ظاهر اللفظ كأنه جواب قوله: ﴿قُلْ﴾، وزاد ابن الأنباري لهذا بيانًا فقال: هذا على معنى: قل لعبادي الذين آمنوا أقيموا الصلاة، فصُرف عن لفظ الأمر إلى لفظ الخبر، وجُعل كالجواب للشرط المقدَّر من الأمر، وهو أمر في الحقيقة {3}.ومعنى قول أبي بكر: جُعل (كالجواب للشرط المقدّر) {4}، هو أن إلأمر معه شرط مقدّرة كقول القائل: أطع الله يدخلك الجنة، معناه: إن أطعته يدخلك الجنة، لذلك التقدير في هذه الآية: إن يقل لهم يقيموا، هذا ظاهر الكلام، وهو في المعنى أمر على ما بينّا.وقال أبو إسحاق قوله: ﴿يُقِيمُوا﴾ مجزوم بمعنى اللام؛ كأنه ليقيموا إلا أنها أسقطت؛ لأن الأمر قد دل على الغائب بقُل، يقول: قل لزيد ليضْرب عمرًا، وإن شئت قلت: قل لزيد يضرب عمرًا، ولا يجوز: يضربْ زيدٌ عمرًا، بالجزم حتى يقول: لِيضربْ؛ لأن لام الغائب ليس هاهنا منها عوض إذا حذفتها، وذكر وجهًا ثالثًا؛ وهو أن يكون المعنى: قل لعبادي الذين آمنوا [أقيموا الصلاة] {5} يقيموا الصلاة؛ لأنهم إذا آمنوا وصدّقوا فإن {6} تصديقهم بقبولهم {7} أمر الله {8}، فعلى هذا قوله ﴿يُقِيمُوا﴾ جواب أمر محذوف.وقوله تعالى: ﴿يَوْمٌ لَا بَيْعٌ فِيهِ﴾ قال أبو عبيدة: البيع هاهنا: الفداء، والخلال: المخالَّة {9}، قال مقاتل: إنما هو يوم لا بيع فيه ولا شراء، ولا مخالَّة ولا قرابة، إنما هي أعمال يثاب بها قوم ويعاقب عليها آخرون {10}، ومثل هذه الآية قوله: ﴿يَوْمٌ لَا بَيْعٌ فِيهِ وَلَا خُلَّةٌ وَلَا شَفَاعَةٌ﴾ في سورة البقرة [254]، وقد مرّ.وجميع أهل المعاني قالوا في الخلال هاهنا إنه: المُخالَّة {11}، وأنشدوا قول امرئ القيس: ولسْتُ بمَقْلِيِّ {12} الخِلالِ ولاقَالَي {13}قال أبو علي: ويجوز أن يكون جمع خُلَّة مثل: بُرْمَة وبِرام {14}، وعُلْبة وعِلاب {15}، قال ابن الأنباري: ولا تنافي بين هذه الآية وبين قوله: ﴿الْأَخِلَّاءُ يَوْمَئِذٍ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إِلَّا الْمُتَّقِينَ﴾ [الزخرف: 67] فأثبت الخُلَّة للمتقين؛ لأن لذلك اليوم أحوالًا ومواطن مختلفةً، ففي بعضها يشتغل كل خليل عن خُلَّةِ خليله {16}، يدل {17} على ذلك قوله: ﴿وَلَا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾ [المعارج: 10]، وقوله تعالى: ﴿يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ﴾ [عبس: 34]، وفي بعضها يتعاطف أولياء الله بالمُخالَّة التي كانت بينهم."
  14,32,""
  14,33,"قوله تعالى: ﴿وَسَخَّرَ لَكُمُ الشَّمْسَ وَالْقَمَرَ دَائِبَيْنِ﴾ قال ابن عباس: يريد ليُعرف النهار من الليل، والليل من النهار {1}.قال الزجاج: معناه دآئبين {2} في إصلاح ما يصلحانه من النبات وغيره لا يفْتُران {3}، ومعنى الدؤوب في اللغة: مرور الشيء في العمل على عادة جارية فيه، دأب يَدْأَبُ دأْبًا ودُؤُوبًا {4} وقد ذكرنا هذا في قوله: ﴿قَالَ تَزْرَعُونَ سَبْعَ سِنِينَ دَأَبًا﴾ [يوسف: 47]وقوله تعالى: ﴿وَسَخَّرَ لَكُمُ اللَّيْلَ وَالنَّهَارَ﴾ قال ابن عباس: يريد لتبتغوا بالنهار من فضله وتقوموا بطاعته وفرائضه، واليل لتسكنوا فيه، وجعل ذلك راحة لكم {5}."
  14,34,"قوله تعالى: ﴿وَآتَاكُمْ مِنْ كُلِّ مَا سَأَلْتُمُوهُ﴾ قال أبو علي: المفعول محذوف تقديره من كل مسؤول شيئًا أو مسؤولًا أو نحو ذلك، ومثله قوله: ﴿يُخْرِجْ لَنَا مِمَّا تُنْبِتُ الْأَرْضُ﴾ [البقرة: 61] أي: شيئًا، فحذف المفعول، وكذلك قوله: ﴿وَأُوتِينَا مِنْ كُلِّ شَيْءٍ﴾ [النمل: 16] قال: ويجوز في قياس قول أبي الحسن {1} أن يكون الجار والمجرور في موضع نصب، وتكون (من) زيادة في الإيجاب كما تكون زيادة في غير الإيجاب {2}، وقال ابن الأنباري: تقدير الآية: ﴿وَآتَاكُمْ مِنْ كُلِّ مَا سَأَلْتُمُوهُ﴾ وما لم تسألوه؛ لأنا لم نسأله شمسًا ولا قمرًا ولا كثيراً من نِعمه التي ابتدأنا بالإحسان إلينا بها، فاكتُفِي بالسؤال عن غير {3} المسؤول؛ كقوله: ﴿سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾ {4} [النحل: 81]، قال: ويجوز أن يكون المعنى: وآتاكم من كل ما تتمنُّون تشْتهون وتُؤثرون {5}، قال الكسائى: العرب تقول إذا أتيت فلانًا أعطاك سُؤلك، وصرت منه إلى ما سألت، لا يعنون السؤال بعينه، ولكنهم يريدون ما يشتهي وَيتمنّى وُيؤثر، هذا كلامه {6}، وأما مفعول الإيتاء فهو على ما ذكره أبو علي {7}.وقوله تعالى: ﴿وَإِنْ تَعُدُّوا نِعْمَتَ اللَّهِ لَا تُحْصُوهَا﴾ النعمة هاهنا اسم أقيم مقام المصدر يقال: أنعم الله عليه، يُنْعِم إنعامًا ونِعْمَةً، أقيم الاسم مُقَام الإنعام؛ كقولك: أنفقت عليه إنفاقًا ونفقةً، بمعنى واحد {8} ولذلك لم يجمع؛ لأنه في مذهب المصدر، ومعنى قوله: ﴿لَا تُحْصُوهَا﴾: لا يأتوا على جميعها بالعَدِّ لكثرتها، بيانه قوله: ﴿وَأَحْصَى كُلَّ شَيْءٍ عَدَدًا﴾ [الجن: 28] أي أحاط علمه باستيفاء عدد كل شيء.وقال الكلبي: لا تحفظوها {9}، وقال أبو العالية: لا تطيقون عدّها {10}، والقولان قد فُسّر بهما {11} قوله: ﴿عَلِمَ أَنْ لَنْ تُحْصُوهُ﴾ [المزمل: 20] قال الفراء: علم أن لن تحفظوا مواقيت الليل {12}، وقال غيره: معناه: علم أن لن تطيقوه {13}.وقوله تعالى: ﴿إِنَّ الْإِنْسَانَ لَظَلُومٌ كَفَّارٌ﴾ قال ابن عباس: يريد: أبا جهل ظلوم لنفسه كفّار بنعمة ربه {14}، وقال أبو إسحاق: هذا اسم للجنس، فقصد به الكافر خاصة؛ كما قال: {وَالْعَصْرِ (1) إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ (2) إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا} فالإنسان غير المؤمن ظلوم كَفَّار {15}، قال المفسرون: ظلوم: كافرٌ شاكرٌ غيرَ من أنعم عليه، واضعٌ الشكر غير موضعه، ﴿كَفَّارٌ﴾: جحود لنعم الله {16}."
  14,35,"قوله تعالى: ﴿وَإِذْ قَالَ إِبْرَاهِيمُ رَبِّ اجْعَلْ هَذَا الْبَلَدَ آمِنًا﴾ تفسير هذا قد سبق في سورة البقرة {1}.وقوله تعالى: ﴿وَاجْنُبْنِي وَبَنِيَّ أَنْ نَعْبُدَ الْأَصْنَامَ﴾ قال الكفراء: أهل الحجاز تقول: جَنبَنِي يَجْنُبُنِي خفيفة، وأهل نجد تقول: أجْنبَنِي شرَّه وجَنَّبَنِي شرَّه {2}، ونحو هذا قال الكسائي {3}، وقال الزجاج: أجْنَبْتُه كذا وكذا: جعلته ناحية منه وجانبًا، وكذلك جَنَّبْتُه وجَنَبْتُه {4}، وأنشد أبو عبيدة لأُميّة بن الأَسْكَر:وتَنْفُضُ مَهْدَهُ شَفَقًا عَلَيْه ... وتَجْنُبُه قلائِصنا الصِّعَابَا {5} قال أبو إسحاق: ومعنى الدعاء من إبراهيم أن يُجَنَّبَ عبادة الأصنام، وهو غير عابد لها، على معنى: ثبِّتْنِي على اجتناب عبادتها؛ كما قال: ﴿وَاجْعَلْنَا مُسْلِمَيْنِ لَكَ﴾ [البقرة: 128]، أي: ثبِّتْنا على الإسلام {6}.وقال غيره من أهل المعاني قوله: ﴿وَبَنِيَّ﴾ دعاء لمن أذن الله في أن يدعو له؛ فكأنه قال: وبنيَّ الذين أذنت لي في الدعاء لهم؛ لأن دعاء الأنبياء مستجاب، وقد كان من نسله من عبد الصنم {7}، أو خص بهذه الدعوة أبناءه من صُلْبِه {8}.والصَّنم: الصورة التي تُعْبَد، وجمعه أصنام {9}."
  14,36,"قوله تعالى: ﴿رَبِّ إِنَّهُنَّ أَضْلَلْنَ كَثِيرًا مِنَ النَّاسِ﴾ قال أبو إسحاق وغيره: أي ضَلُّوا بسببها؛ لأن الأصنام لا تعقل ولا تفعل شيئًا؛ كما يقول: قد افْتَنَتْنِي هذه الدار؛ أي: أحْبَبْتُها واسْتَحْسَنْتُها وافْتُتِنْتُ بسببها {1}، فلما ضل الناس بسببها صارت كأنها أضلتهم، فنُسِب الفعل إليها.وقوله تعالى: ﴿فَمَنْ تَبِعَنِي﴾ قال ابن عباس: يريد على ديني بالتوحيد لك والمعرفة بك {2}.وقوله تعالى: ﴿فَإِنَّهُ مِنِّي﴾ قال ابن الأنباري: يريد من المُتديِّنين بميني المتمسِّكين بحبلي؛ كما قال {3}:إذا حاوَلْتَ في أسَدٍ فُجُورًا ... فإني لَسْتُ منكَ ولَسْتَ مِنّي {4}أراد: ولستَ من المتمسِّكين بِحَبْلي {5}.وقوله تعالى: ﴿وَمَنْ عَصَانِي فَإِنَّكَ غَفُورٌ رَحِيمٌ﴾ [قال السّدي: معناه ومن عصاني ثم تاب {6}، ﴿فَإِنَّكَ غَفُورٌ رَحِيمٌ﴾] {7} له إن تاب وإن آمن، لا أنه يقول: أن من كفر فإن الله يغفر له، وقال مقاتل: ومن عصاني فيما دون الشرك فإنك غفور رحيم {8}، وشرح أبو بكر هذا فقال: معناه: فمن عصاني فخالف في بعض الشرائع، وعقْدُ التوحيد معه فإنك غفور رحيم، إن شئت تغفر له غفرت إذ كان مسلمًا {9}، وذكر وجهين آخرين، أحدهمما. أن هذا كان قبل أن يُعلِّمه الله أنه لا يغفر {10} الشرك، كما استغفر لأبويه {11}، وهو يُقَدِّر أن ذلك غيرُ محظور، فلما عرف أنهما غير مغفور لهما تبرأ منهما {12}. والآخر: ومن عصاني بإقامته على الكفر فإنك غفور رحيم، يعني: أنك قادر على أن تغفر له وترحمه؛ بأن تنقله عن الكفر إلى الإسلام وتهديه إلى الصواب {13}."
  14,37,"قوله تعالى: ﴿رَبَّنَا إِنِّي أَسْكَنْتُ مِنْ ذُرِّيَّتِي﴾ قال الفراء: ولم يأت منهم بشىء {1} يقع عليه الفعل، وهو حائز أن يقول: قد أصبنا من بنى فلان، وقتلنا من بني فلان، وإن لم يقل رجالاً؛ لأن (من) تؤدّي عن بعض القوم؛ كقولك: قد أصبنا من الطعام وشربنا من الماء، ومثله: ﴿أَنْ أَفِيضُوا عَلَيْنَا مِنَ الْمَاءِ﴾ {2} [الأعراف: 50] قال أبو بكر: ويجوز أن يقال: إن (من) دخلت لتوكيد الكلام، والتقدير: ربنا إني أسكنت ذريتي {3} كما قال ذو الرُّمّة:تَبَسَّمْن عن نَوْرِ الأقَاحيِّ في الضُّحَى ... وفَتَّرْنَ من أبْصَارِ مضْرُوجةٍ نُجْلِ {4} وعلى ما ذكر الفراء (من) دخلت للتبعيض، والتأويل: إني أسكنت بعض ذريتي، وذلك أنه أنزل إسماعيل بعض ذرية إبراهيم، يدل على هذا قول ابن عباس في هذه الآية ﴿إِنِّي أَسْكَنْتُ مِنْ ذُرِّيَّتِي﴾ يريد: إسماعيل {5}، ﴿بِوَادٍ غَيْرِ ذِي زَرْعٍ﴾ قال: يريد وادي مكة، ومكة كلها واد، والكلام في الوادي قد ذكرنا عند قوله: ﴿فَسَالَتْ أَوْدِيَةٌ﴾ [الرعد: 17] والقول الأول: اختيار أبي علي، قال: معناه إني أسكنت من ذريتي ناسًا، فحذف المفعول لدلالة الإسكان عليه {6}.وقوله تعالى: ﴿عِنْدَ بَيْتِكَ الْمُحَرَّمِ﴾ قيل معناه: عند بيتك المحرم الذي كان قبل أن ترفعه من الأرض حتى رفعته أيام الطوفان؛ لأن إسكان الخليلِ إسماعيلَ مكة كان قبل بنائهما البيت، وقيل: عند بيتك المحرم الذي قد مضى في سابق علمك أنه يحدث في هذا الوادي {7}.وقوله تعالى: ﴿رَبَّنَا لِيُقِيمُوا الصَّلَاةَ﴾ قال ابن عباس: يريد ليعبدوك {8}.﴿فَاجْعَلْ أَفْئِدَةً مِنَ النَّاسِ تَهْوِي إِلَيْهِمْ﴾، أبو عبيد عن الأصمعي قال: هَوَى يَهْوِي هُوِيًّا، إذا سقط من عُلو إلى سفْل {9}، وقال ابن الأعرابي: هَوَت العُقابُ {10} نَهْوِي هَوِيُّا بالفتح، إذا انقضّت {11} على صيد أو غيره {12}، وقال الفراء في هذه الآية: ﴿تَهْوِي إِلَيْهِم﴾ تريدهم؛ كما تقول: رأيت فلانًا يَهْوِي نحوك {2}، معناه: تنحط إليهم وتنحدر وتنزل {14}، يقال هوى الحجر من رأس الجبل يهوي، إذا انحدر وانصب {15}، هذا قول أهل اللغة في هذا الحرف.فأما قول المفسرين؛ فقال ابن عباس في رواية عطاء: يريد تحِنّ {16} إليهم زيارة بيتك {17}، وفي هذا بيان أن حنين الناس إليهم إنما هو لحج البيت لا لأعيانهم، وفي هذا دعاء للمؤمنين بأن يرزقهم حج البيت، ودعاءٌ لسكان مكة {18} من ذريته؛ لأنهم يرتفقون {19} بمن يأتي مكة لزيارة البيت {20}، وقال قتادة في قوله: ﴿تَهْوِي إِلَيْهِم﴾: تنزع إليهم {21}، وقال أبو إسحاق: أي: اجعل أفئدة جماعة من الناس تنزع إليهم {22}، وهذا معنى قول مجاهد: لو قال: أفئدة الناس؛ لازدحمت عليه فارس والروم والترك والهند {23}، وقال سعيد بن جبير: لو قال: أفئدة الناس؛ لحجت إليه اليهود والنصارى والمجوس، ولكنه قال: ﴿أَفْئِدَةً مِنَ النَّاسِ﴾ فهم المسلمون {24}، وقال ابن عباس في قوله: ﴿أَفْئِدَةً مِنَ النَّاسِ﴾: يريد من المؤمنين من ذريته ومن غير ذريته.وقوله تعالى: ﴿وَارْزُقْهُمْ مِنَ الثَّمَرَاتِ﴾ ذكرنا تفسيره في سورة البقرة عند قوله: ﴿وَارْزُقْ أَهْلَهُ مِنَ الثَّمَرَاتِ﴾ [البقرة: 126].وقوله تعالى: ﴿لَعَلَّهُمْ يَشْكُرُونَ﴾ قال: يريد كي يوحدوك ويعظموك."
  14,38,""
  14,39,"قوله تعالى: ﴿الْحَمْدُ لِلَّهِ الَّذِي وَهَبَ لِي عَلَى الْكِبَرِ إِسْمَاعِيلَ وَإِسْحَاقَ﴾ قال ابن عباس: وُلِدَ إسماعيلُ لإبراهيم وهو ابن تسع وتسعين سنة {1}، ووُلد له إسحاقُ وهو ابن مائة واثنتى {2} عشرة سنة {3}."
  14,40,"قوله تعالى: ﴿رَبِّ اجْعَلْنِي مُقِيمَ الصَّلَاةِ﴾ ذكره على النعت ولم يذكره على الفعل؛ لأن النعت ألزم وأكثر من الفعل، كأنه قال: رب اجعلني من عادتي إقامة الصلاة، ولو قال: اجعلني أقيم الصلاة، لم يكن فيه من المبالغة ما في المقيم، وذكرنا استقصاء هذا الفصل فيقوله: ﴿وَلَا تَجْعَلْ يَدَكَ مَغْلُولَةً إِلَى عُنُقِكَ﴾ الآية [الإسراء: 29].وقوله تعالى: ﴿وَمِنْ ذُرِّيَّتِي﴾ قال الزجاج: أي: واجعل من ذريتي من يقيم الصلاة {1}، وهذا كما ذكرنا في قوله: ﴿إِنِّي أَسْكَنْتُ مِنْ ذُرِّيَّتِي﴾، وقوله: ﴿وَآتَاكُمْ مِنْ كُلِّ مَا سَأَلْتُمُوهُ﴾.وقوله تعالى: ﴿رَبَّنَا وَتَقَبَّلْ دُعَاءِ﴾ قال ابن عباس: يريد عبادتي {2}، وهذا كقوله ﷺ: ""الدُّعاءُ مخُّ العبادة"" {3}."
  14,41,"قوله تعالى: ﴿رَبَّنَا اغْفِرْ لِي وَلِوَالِدَيَّ﴾ قال أبو إسحاق: كان هذا الدعاء من إبراهيم لوالديه قبل أن يتبين له أن أباه عَدُوُّ للهِ {1}، وقد ذكرنا ذلك في قوله: ﴿وَمَا كَانَ اسْتِغْفَارُ إِبْرَاهِيمَ لِأَبِيهِ إِلَّا عَنْ مَوْعِدَةٍ وَعَدَهَا إِيَّاهُ﴾ الآية. [التوبة: 114] ولعل الأمّ كانت مسلمة، يدل على ذلك أنه ذكر عذره في استغفاره لأبيه دون أُمِّه {2}، وقال ابن الأنباري: استغفر لأبويه وهما حيّان طمعًا في أن يُهْدَيا إلى الإسلام ويَسْعَدا بالدين {3}، وقال غيره: استغفر لهما بشرط الإيمان {4}، يدل عليه ما قال ابن عباس في هذه الآية: يريد: من لقيك مؤمنًا مصدقًا فتجاوز عنه {5}، وهو معنى قوله: ﴿وَلِلْمُؤْمِنِينَ﴾، وقيل: أراد بوالديه آدم وحواء {6}."
  14,42,"قوله تعالى: ﴿وَلَا تَحْسَبَنَّ اللَّهَ غَافِلًا عَمَّا يَعْمَلُ الظَّالِمُونَ﴾ قال ابن عباس: يريد المشركين أهل مكة {1}، وكان سفيان بن عيينة إذا قرأ هذه الآية قال: هذا تعزية للمظلوم، ووعيد للظالم {2}.وقوله تعالى: ﴿لِيَوْمٍ تَشْخَصُ فِيهِ الْأَبْصَارُ﴾ قال شمر: يقال: شخص الرجلُ بصرَه، [وشخص البصرُ نفسُه، إذا سما وطَمَح وشَصا {3}، كلُّ ذلك مِثْلُ الشُّخُوصِ {4}.وقال ابن السِّكِّيت: شَخَصَ بصرُهُ] {5}، إذا فتح عينيه لا يَطْرِفُ {6}.قال الفراء: أي لا يغتمض من هول ما يرى في ذلك اليوم {7}.وقال ابن عباس: يريد يوم القيامة تشخص فيه أبصار الخلائق إلى الهواء، يريد: أنهم لعجائب ما يرون، ولشدة الحَيْرةِ والدووة لا يغْتَمضون {8}."
  14,43,"قوله تعالى: ﴿مُهْطِعِينَ﴾ قال أبو إسحاق: منصوب على الحال، المعنى: إنما يؤخرهم ليوم تشخص فيه أبصارُهُم مهطعين، فعلى ما ذكره الألف واللام في: ﴿الْأَبْصَارُ﴾ يدل على الكناية؛ لأن التأويل بأبصارهم على ما ذَكر، وأما تفسير الإهطاع {1} فقال أبو عبيدة: هو الإسراع {2}، يقال: أهطع البعير في سيره واستهطع، إذا أسرع {3}، وهو اختيار الزجاج؛ قال: مهطعين: مسرعين، وأنشد {4}:بِدِجْلةَ أَهْلُهَا ولَقَد أراهُمْ {5} ... بِدِجْلةَ مُهْطِعِينَ إلى السّمَاعِ {6}قال: أي مسرعين {7}، وأنشد أبو عبيدة:بمُهْطِعٍ سُرُحٍ كأنّ زِمَامَه ... في رأسِ جِذْعٍ من أَوالَ مُشَذَّبِ {8} قال أبو عبيدة: أهطع وهطع إذا أسرع مقبلًا خائفًا، لا يكون إلا مع خوف {9}، وقال أحمد بن يحيىَّ: المُهطِعُ الذي ينظر في ذُلٍّ وخشوعٍ {10}، وقال ابن جريج: المهطع الساكت المنطلق إلى الهُتافِ إذا هتف هاتفٌ {11} وقال الليث: يقال للرجل إذا أقرَّ وذلَّ قد أهطع {12}، وأنشد:ونِمْرُ بن سَعْدٍ لي مُطيعٌ ومُهطِعُ {13}فهذه أربعة أقوال لأهل اللغة في تفسير هذا الحرف، وأما قول المفسرين: فقال سعيد بن جبير، والحسن، وقتادة: مسرعين {14}، وقال سعيد عن قتادة: منطلقين عامدين إلى الداعي {15}، وقال نافع بن الأزرق لابن عباس: أخبرني عن قولى: ﴿مُهْطِعِينَ﴾ ما الإهطاع؟ قال: النظر {16}، وفي ذلك يقول الشاعر {17}:إذا دَعَانَا فأهْطَعْنا لدَعْوته ... داعٍ سميعٌ فَلَفُّونَا وسَاقُوْنا {18}وهذا قول مجاهد والضحاك والكلبي والعوفي عن ابن عباس قالوا: ناظرين مديمي النظر من غير أن يطرفوا {19}، ونحو ذلك قال أبو الضحى؛ قال: الإهطاع من التَّحْمِيج {20} الذي زدتُم {21} النظر ولا يَطْرِف {22}.وهذه الأقوال توافق ما حكينا من أهل اللغة، والجامع لهذه الأقوال قول من قال الإهطاع: إسراعٌ مع إدامة نظر {23}.وقوله تعالى: ﴿مُقْنِعِي رُءُوسِهِمْ﴾ قال ابن السكَيت: أقنع رأسه إذا رفعه {24}، قال النضر: أقنع فلانٌ رأسه، وهو أن يرفع بصره ووجهه إلى السماء، قال: والمقنع: الرافع رأسه إلى السماء {25}، وقال أحمد بن يحييَّ: الإقناع: رفع الرأس والنظر في ذل وخشوع {26}.ومنه ما روي عن النبيّ ﷺ أنه قال: ""تُقْنِع يديك في الدعاء"". أي: ترفعهما {27}.وقال أبو إِسحاق: المقنع الرافع {28}، وأنشد للشمَّاخ:يُبَاكرْن العِضَاهَ بمُقْنَعاتٍ ... نَوَاجِذُهُنَّ كالحدأِ الوَقِيعِ {29}أراد بأفواه مرفوعات إلى العِضَاة، يصف إبلًا ترعى الشجرَ، شبَّه أنيابها بالفؤوس المحدُودة، والحِدأُ: الفؤوس بالكسر، وعند الكوفيين الحَدَأُ بالفتح جمع حَدَأة، فهما لغتان {30}، ونحو ما قال أهل اللغة قال المفسرون في الإقناع، قالوا: ﴿مُقْنِعِي رُءُوسِهِمْ﴾: رافعي رؤوسهم، وهو قول ابن عباس ومجاهد والضحاك وقتادة وابن زيد {31}، قال الحسن: وجوه الناس يوم القيامة إلى السماء لا ينظر أحد إلى أحد {32}.وقوله تعالى: ﴿لَا يَرْتَدُّ إِلَيْهِمْ طَرْفُهُمْ﴾ أي لا ترجع إليهم أبصارهم من شدة النظر؛ فهي شاخصة والطَرْفُ: تحريك الجفون في النظر، يقال: شخص بصره فما يَطْرِف {33}، والطرْفُ: اسم جامع للبصر لا يُثنَى ولا يُجمع {34}.وتأويل قوله: ﴿لَا يَرْتَدُّ إِلَيْهِمْ طَرْفُهُمْ﴾ أي: نظرهم إلى شيء واحد، فكأن ذلك الشيء الذي ينظرون إليه قد ذهب بنظرهم نحوه؛ فليسوا ينظرون إلى غيره، هذا معنى قولنا: لا يرجع إليهم نظرهم.وقوله تعالى: ﴿وَأَفْئِدَتُهُمْ هَوَاءٌ﴾ قال ابن عباس في رواية عطاء: يريد خرجت القلوب من مواضعها فصارت في الحناجر {35}، ونحو هذا قال قتادة: انتزعت حتى صارت في حناجرهم {36}، فعلى هذا، الأفئدة: أريد بها مواضع القلوب، وذهب قوم من أهل اللغة إلى الفرق بين القلب والفؤاد؛ فقال الليث: القلب مضغةٌ من الفؤاد معلَّقة بالنيَّاط {37}.وقال النبيّ ﷺ: ""أتاكم أهل اليمن هم أرقُّ قلوبًا وألينُ أفئدة"" {38}، فوصف القلوب بالرقّة والأفئدة باللين، وكأن القلب أخصُّ منا لفؤاد، ولذلك قالوا: أصبت حبة قلبه {39}، والهواء: ما بين السماء والأرض {40}، والعرب تسمّي كل خالٍ هواء {41}، يقولون: بيت هواء، إذا كان خاليًا قفْرًا لا شيء فيه، والمعنى في الآية: أن قلوبهم ارتفعت إلى حناجرهم من فزع ذلك اليوم وهوله، وبقي موضعها هواء لا شيء فيه كهواء ما بين السماء والأرض، ولهذا المعنى قالوا للجبان: مُجوَّفٌ هواء، أي أنه لا قلب له، ومنه قول حسان:فأنْتَ مُجوَّفٌ نَخِبٌ هَوَاءُ {42} وقال زهير يصف ناقة:كأنّ الرَّحْلَ منها فَوقَ صَعْلٍ ... من الظِّلْمَانِ جُؤْجُؤُهُ هَواءُ {43}أي لا قلب في صدره فهو خال، وذهب آخرون إلى أن معنى الآية: أن قلوبهم عما ذهلوا من الفزع خلت عن العقول، وهو معنى قول ابن عباس في رواية العوفي، وبه قال مجاهد، ومُرَّة، وابن زيد، واختاره الأخفش؛ فقال في قوله: ﴿وَأَفْئِدَتُهُمْ هَوَاءٌ﴾ أي جَوْفٌ لا عقول لها ولا خير فيها {44}، وعلى هذا القول، المراد بالأفئدة: القلوب، وهو الصحيح في اللغة {45}، قال الله تعالى: ﴿إِنَّ السَّمْعَ وَالْبَصَرَ وَالْفُؤَادَ كُلُّ أُولَئِكَ كَانَ عَنْهُ مَسْئُولًا﴾ [الإسراء: 36] يعني القلب، وقال امرؤ القيس:رَمَتْني بسَهْمٍ أصابَ الفُؤادَ ... غداةَ الرَّحِيل فلم أشهريعني أصاب قلبي، الأزهري: ولم أرهم يفرقون بينهما {46}، ويحتاج في هذا التفسير إلى تقدير المضاف، كأن المعنى: وأفئدتهم ذات هواء؛ أي خالية."
  14,44,"قوله تعالى: ﴿وَأَنْذِرِ النَّاسَ﴾ هذا عطف على قوله: ﴿وَلَا تَحْسَبَنَّ اللَّهَ غَافِلًا﴾ لأنه قد تمَّ وصف الكفار وحالهم عند البعث في القيامة، ثم عاد إلى خطاب النبيّ ﷺ وأمره بالإنذار فقال: ﴿وَأَنْذِرِ النَّاسَ﴾ قال ابن عباس: يعني أهل مكة {1}، قال: ولو أن أهل مكة اتبعوا النبي ﷺ ما اختلف عليه اثنان، قال: ويقال لو آمن الوليد بن المغيرة ما تخلَّف عن رسول الله ﷺ أحد.وقوله تعالى: ﴿يَوْمَ يَأْتِيهِمُ الْعَذَابُ﴾ (يوم) مفعول به، والعامل فيه أنذرهم؛ كما يقول: خوّفه العقاب وخوّفه الهلاك، ولا يكون على الظرف؛ لأنه لم يؤمر بالإنذار في ذلك اليوم {2}.وقوله تعالى: ﴿فَيَقُولُ﴾ عطف ﴿يَأْتِيهِمُ﴾؛ يعني: فيقولون في ذلك اليوم، ﴿الَّذِينَ ظَلَمُوا﴾ قال ابن عباس: يريد أشركوا {3}، ﴿رَبَّنَا أَخِّرْنَا إِلَى أَجَلٍ قَرِيبٍ﴾ استمْهَلوا مدةً يسيرة لكي يجيبوا الدعوة ويتبعوا الرسل، قال ابن عباس: يريدون الرجعة إلى الدنيا، وهذا معنى وليس بتفسير، وذلك أنهم لما استَمهَلوا للإجابة صار كأنهم قالوا: أرجعنا إلى الدنيا أيامًا؛ لأن الآخرة ليست بدار تكليف، وإنما كُلِّفوا الإجابة في دار [الدنيا فيجابون عن هذا الاستمهال، ويقال لهم: ﴿أَوَلَمْ يكُونُوا أَقْسَمْتُمْ مِنْ قبْلُ مَا لَكُمْ مِنْ] {4} زَوَالٍ﴾ قال مجاهد: أي من انتقال عن الدنيا إلى الآخرة {5}؛ أي لا تبعثون.قال ابن عباس: يريد حلفتم في الدنيا أنكم لا تبعثون {6}، وهو قوله: ﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ لَا يَبْعَثُ اللَّهُ مَنْ يَمُوتُ﴾ [النحل: 38]."
  14,45,"قوله تعالى: ﴿وَسَكَنْتُمْ فِي مَسَاكِنِ الَّذِينَ ظَلَمُوا أَنْفُسَهُمْ﴾ قال المفسرون: يعني الأممَ الكافرة قبلهم؛ قومَ نوح وعاد وثمود، ظلموا أنفسهم بالكفر والمعصية {1}، وهذا احتجاج عليهم؛ يقول: كان ينبغي أن ينزجروا ويرتدعوا اعتبارًا بمساكنهم، بعد ما تبيّن لكم كيف فعلنا بهم، ﴿وَضَرَبْنَا لَكُمُ الْأَمْثَالَ﴾ قال ابن عباس: يريد الأمثال التي في القرآن {2}."
  14,46,"قوله تعالى: ﴿وَقَدْ مَكَرُوا مَكْرَهُمْ﴾ [يعني مكرهم بالنبيّ ﷺ وما همُّوا به من قتله أو نفيه {1}. ﴿وَعِنْدَ اللَّهِ مَكْرُهُمْ﴾ {2} أي قد عرف الله مكرهم، وهو عالم به لا يخفى عليه ما فعلوا، فهو يجازيهم عيه، وقال أبو علي: وعند الله جزاءُ مكرِهم فحذف المضافَ كما حُذف من قوله: ﴿تَرَى الظَّالِمِينَ مُشْفِقِينَ مِمَّا كَسَبُوا وَهُوَ وَاقِعٌ بِهِمْ﴾ [الشورى: 22] أي: جزاؤه.وقوله تعالى: ﴿وَإِنْ كَانَ مَكْرُهُمْ لِتَزُولَ مِنْهُ الْجِبَالُ﴾ (إن) هاهنا يعني بها: ما، واللام المكسورة بعدها يعني بها الجحد، ومن سبيلها نصبُ الفعل المستقبل، والنحويون يسمونها لام الجحود {3}، ومثله قوله: ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُم﴾، و ﴿مَا كَانَ اللَّهُ لِيَذَرَ﴾ [آل عمران: 179] والجبال هاهنا مَثلٌ لأمر النبيّ ﷺ وأمرِ دين الإسلام وأعلامِه ودلالتِه، على معنى أن ثبوته كثبوت الجبال الراسية؛ لأن أدته تعالى قد وعد نبيه ﷺ إظهار دينه على كل الأديان، ويدل على صحة هذا المعنى قوله بعدُ: ﴿فَلَا تَحْسَبَنَّ اللَّهَ مُخْلِفَ وَعْدِهِ رُسُلَهُ﴾ أي {4}: فقد وعدك الظهور عليهم والغلبة لهم ومعنى الآية: وما كان مكرهم ليزول منه ما هو مثلُ الجبال في امتناعه ممن أراد إزالته {5}، هذا الذي ذكرنا معنى قول الحسن: كان مكرُهم أوهنَ وأضعفَ من أن تزول منه الجبال {6}، قال: و (إن) هاهنا بمعنى (ما) {7}؛كقوله: ﴿لَاتَّخَذْنَاهُ مِنْ لَدُنَّا إِنْ كُنَّا فَاعِلِينَ﴾ {8} [الأنبياء: 17] وقول: ﴿فِيمَا إِنْ مَكَّنَّاكُمْ فِيهِ﴾ {9} [الأحقاف: 26]، وهو كثير، وهذا القول اختيار أبي إسحاق {10} وأبي بكر وأبي علي {11}.قال أبو علي: وقد استعمل لفظ الجبال في غير هذا، في تعظيم الشيء وتفخيمه {12}، قال ابن مُقبل:إذا مِتُّ عن ذِكرِ القوافي فَلَنْ تَرَى ... لها شَاعِرًا مِثلي أطَبَّ وأَشْعَرَاوأكثرَ بَيْتًا شَاعِرًا ضُرِبَتْ به ... بُطُون جِبَالِ الشِّعْرِ حتَّى تَيَسَّرا {13} فاستعار للشعر جبالاً؛ يريد امتناعه على من أراده. هذا الذي ذكرنا معنى قراءة العامة {14}، وقرأ الكسائي: (لَتزولُ) بفتح اللام الأولى وضم الثانية {15}، وعلى هذه القراءة معنى قوله: ﴿وَقَدْ مَكَرُوا مَكْرَهُمْ﴾ يعني الأمم الكافرة من قبل؛ وهم الذين ذُكروا في قوله: ﴿الَّذِينَ ظَلَمُوا أَنْفُسَهُمْ﴾ وهو معنى قول ابن عباس: يريد ما مكر نمرود بإبراهيم، يجوز أن يعني أيضًا مكر الكفار بالنبيّ ﷺ كما ذكرنا، ﴿وَإِنْ كَانَ مَكْرُهُمْ﴾ معنى (إنْ) على هذه القراءة المخففة من الثقيلة، قاله أبو علي {16}.وقال أبو بكر: (إنْ) مع اللام يعني بها هاهنا: (قد)؛ كما يقول العربي: إنْ كان عبد الله لَيزورنا، يريد: قد كان، واللام في: ﴿لِتَزُولَ﴾ لام الجواب، والمستقبل بعدها مرفوع، والمعنى قد كانت الجبال تزول من مكرهم على تعظيم أمر مكرهم؛ كقوله: ﴿وَمَكَرُوا مَكْرًا كُبَّارًا﴾ [نوح: 22].وقال أبو إسحاق: وإن كان مكرُهم يبلغ في الكيد إلى إزالة الجبال، فإن الله ينصرُ دينه {17}، فإن قيل هذه القراءة على ما ذكرتم يُوجب أن الجبال قد زالت بمكرهم وهل كان ذلك؟والجواب عن هذا من وجهين: أحدهما لأهل المعاني، والثاني للمفسرين؛ أما أهل المعاني فإنهم قالوا: هذا مبالغة في وصف مكرهم بالعظيم، وإن لم يكن جبلٌ قط زال لمكرهم، فهذا على مذهب العرب في المبالغة؛ يقول: وإن كان مكرُهم قد بلغ من كِبَرِه وعِظَمِه أن يُزيلَ ما هو مثل الجبال في الامتناع على من {18} أراد إزالتَه ثباتُها؛ كأنه قيل: لو أزال مكرُهم الجبال لما أزال أمرَ الإسلام.يدل على صحة ما ذكرنا قراءةُ جماعة من الصحابة: (وإن كاد مَكْرُهم لَتَزولُ) بالدال {19}، أي {20}: قد قاربت الجبال أن تَزولَ، وهذا معنى قول أبي إسحاق {21} وأبي بكر {22} وأبي علي {23}؛ قال أبو علي: ومثل هذا في تعظيم الأمر قول الشاعر:ألمْ تَرَ صَدْعًا في السَّمَاءِ مُبَيِّنًا ... على ابنِ لُبَيْنى الحارثِ بن هِشَامِ {24}وهذا ليس على أنه شوهد صدع في السماء، ولكنه مبالغة على معنى أن الأمر قد قرب من ذلك، ومثله كثير في الشعر، وذكر ابن قتيبة باب ما أفرطت الشعراء في وصفه، وأنشد أبياتًا كثيرة، ثم قال: وهذا كله علي المبالغة في الوصف، وينوون في جمعه {25}: يكافى يفعل {26}، وأنشد أبو إسحاق قول الأعشى:لئن كنتَ في جُبٍّ ثَمانينَ قامةً ... ورُقِّيتَ أسبابَ السماءِ بِسُلّملَيسْتَدرِكَنَّكَ القَوْلُ حتَّى تَهِرّهُ ... وتَعْلَمَ أني عنكم غيرُ مُنَجِّمِ {27} قال: فإنما بالغ في الوصف، وهو يعلم أنه لا يُرَقَّى {28} أسبابَ السماء {29}.وقال أبو بكر في قول الأعشى: تأويله لئن كنت فيما تَقْدِر ويُقَدَّر لك في قعر الأرض أو في السماء، لَيَصلنَّ إليك مني ما كره، لذلك معنى ﴿وَإِنْ كَانَ مَكْرُهُمْ لِتَزُولَ مِنْهُ الْجِبَالُ﴾: عند أنفسهم وفيما يقدّرون، فليس ينفعهم ذلك إذا كان الله قد وعد على ألسنة رسله ظهورَ الحق على الباطل.وأما المفسرون فإنهم ذهبوا إلى قصة نمرود مع التابوت والنسور، وأن الجبال حين سمعت حفيف النسور والتابوت عند هبوطها ظنت أن ذلك أمرٌ من الله تعالى عظيم، وأن الساعة قد قامت ففزعت وزالت، وهذا يُروى عن علي -رضي الله عنه- ومجاهد وعكرمة {30}.قال مجاهد: كان ذلك بختنصر {31}."
  14,47,"قوله تعالى: ﴿فَلَا تَحْسَبَنَّ اللَّهَ مُخْلِفَ وَعْدِهِ رُسُلَهُ﴾ قال الفراء: أُضيفت ﴿مُخْلِفَ﴾ إلى الوعد ونُصبت الرسلُ على التأويل؛ لأن الإخلاف قد يقع بالوعد كما يقع بالرسل، فيقول أخلفت الوعدَ وأخلفت الرسلَ {1}، وإذا كان الفعل يقع على شيئين مختلفين مثل: كَسَوْتك الثوبَ وأدخلتك الدار، فابدأ بإضافة الفعل إلى الرجل؛ تقول: هو كاسي عبد الله ثوبًا، ومدخله الدارَ، ويجوز: هو كاسي الثوبِ عبد الله، ومدخل الدارِ زيدًا؛ لأن الفعل قد يأخذ الدار كأخذه عبد الله فيقول: أدخلت الدار، وكسوت الثوب، ومثله قول الشاعر {2}: تَرَى الثورَ فيها مُدخِلَ الظِّلِّ رَأسَهُ ... وسَائِرُهُ بَادٍ إلى الشَّمْس أجْمَعُ {3}أي مدخل رأسه الظلَّ، فقلب وأضاف مُدخلَ إلى الظلِّ [لأن الظل] {4} التبس برأسه {5}، فصار كل واحد منهما داخلًا في صاحبه {6}، قال ابن عباس: ﴿فَلَا تَحْسَبَنَّ اللَّهَ﴾: يا محمد، ﴿مُخْلِفَ وَعْدِهِ رُسُلَهُ﴾ يريد النصر والفتح وإظهار الدين {7}، ﴿إِنَّ اللَّهَ عَزِيزٌ ذُو انْتِقَامٍ﴾ قال: يريد: أن الله منيع شديد الانتقام، ومعنى الانتقام الجزاء بما كان من السيئات."
  14,48,"قوله تعالى: ﴿يَوْمَ تُبَدَّلُ الْأَرْضُ﴾ الآية. ذكر الزجاج في نصب (يوم) وجهين؛ أحدهما: أنه صفة لقوله ﴿يَوْمَ يَقُومُ الْحِسَابُ﴾ {1}، والآخر: أنه على معنى ينتقم يوم تبدل {2}، وذكرنا في قوله: {بَدَّلْنَاهُمْ جُلُودًا} [النساء: 56] أن التبديل يقع على معنيين، أحدهما: تبديل العين إلى غيره، والثاني: تبديل الصورةِ والعين قائمة، وقد ذُكر المعنيان في هذه الآية، قال ابن عباس: الأرض هي تلك الأرض، وإنما تُبدل آكامُها وجبالها وأشجارها {3}، ثم أنشد {4}:فما الناسُ بالناسِ الذين عَهِدتُهُم ... ولا الدَّارُ بالدَّارِ التي كنت أعْرِفُ {5}ونحو هذا روى أبو هريرة عن النبيّ ﷺ قال: ""يبدل الله الأرض غير الأرض فيبسطها {6} ويمدُّها مدَّ الأديم العُكاظيِّ لا ترى فيها عوجًا ولا أمتًا"" {7}.وقال الحسن: هي هذه الأرض إلا أنها تُغيَّر إلى سورة أخرى {8}.وأما تبديل السموات فقال ابن عباس في رواية أبي صالح: وتبديل المموات بأن يزاد فيها وينقص منها {9}.وقال ابن الأنباري: باختلاف هيئتها؛ كما ذكر الله تعالى أنها مرة كالمهل {10}، وتكون كالدهان {11}، وعلى هذا القول معنى التبديلِ في الآية: وتبديلُ الصورةِ باختلاف الهيئةِ، والعينُ كما هي، كما تقول: قد بدلت قميصي جُبة؛ أن تقلبَ العينَ من حال إلى حال أخرى، وهو اختيار أبي إسحاق، قال: قد يقول: بَدَّل زيدٌ، إذا تغيرت حاله، فمعنى تبديل الأرض: تسيير جبالها وتفجير بحارها، وكونها مستوية لا ترى فيها عوجًا ولا أمتًا، وتبديل السموات: انتثار كواكبها وانفطارها، وتكوير شمسها وخسوف قمرها.قال: وقوله: ﴿وَالسَّمَاوَاتُ﴾ أي وتبدل السمواتُ غيرَ السموات {12}، ومثله قال أبو علي: قال وهو كقوله -ﷺ-: لا يُقتل مؤمنٌ بكافر ولا ذو عهد في عهده"" {13} {14}.المعنى: ولا ذو عهد في عهده بكافر، كما كان التقدير في الآية؛ والسموات غير السموات، وذهب قوم إلى تبديل العين، فقال ابن مسعود: تبدل بأرض كالفضة بيضاء نقية، لم يُسفك فيها دم ولم يعمل عليها خطيئة {15}، ونحو ذلك قال ابن عباس في رواية الكلبي وعطاء {16}.يؤكد هذا ما روى سَهْل بن سَعد عن رسول الله -ﷺ- قال: ""يُحْشرُ الناسُ يوم القيامة على أرض بيضاء عَفْراءَ كَقُرْصَةِ النَّقيّ ليس فيها معلم لأحد"" {17}.وقال علي -رضي الله عنه- في هذه الآية: الأرض من فضة والسماء من ذهب {18}، ومذهب أكثر المفسرين؛ عكرمة، ومجاهد، والقرظي، وكعب: على أن هذا التبديل هو تبديل العين {19}.وسألتْ عائشةُ رسولَ الله ﷺ عن هذه الآية وقالت: أين يكون الناس يومئذ؟ قال: ""على الصراط"" {20} قوله تعالى: ﴿وَبَرَزُوا لِلَّهِ الْوَاحِدِ الْقَهَّارِ﴾ أىِ ظهروا وخرجوا من قبورهم، وهو كقوله: ﴿وَبَرَزُوا لِلَّهِ جَمِيعًا﴾ [إبراهيم: 21] وقد مرّ."
  14,49,"قوله تعالى: ﴿وَتَرَى الْمُجْرِمِينَ﴾ قال ابن عباس: يريد الذين أجرموا، زعموا أن لله شريكًا وولدًا ونظيرًا {1}، ﴿يَوْمَئِذٍ﴾ يريد يوم القيامة، ﴿مُقَرَّنِينَ﴾ يقال: قرنت الشيء بالشيء، إذا شددته به ووصلته، والقَرْنُ اسم الحبل الذي شُدَّ به شيئان {2}، وجاء هاهنا على التكثير لكثرة أولئك القوم.وقوله تعالى: ﴿فِي الْأَصْفَادِ﴾ جمع صفْد وهو القيد، يقال: صَفَدْتُ الرجلَ فهو مَصْفُود، والمصدر: الصَّفْد، والاسم: الصَّفَد، ومثله الصِّفادُ: وهو كل ما يوثق به من نِسْع أو قِدِّ {3}، ويقال أيضًا من هذا صَفَّدته بالتشديد، ومنه الحديث: ""صُفِّدت الشَّياطين"" {4}.قال أبو عبيد: شُدَّت بالأغلال، قال عمرو:وأُبْنَا بالمُلُوكِ مُصَفَّدِينا {5} قال: وأما أصْفَدْتُه بالألف، فهو أن تعطيه وتصله، والاسم منه الصَّفَد، وكذلك الوَثاق {6}.وقال الزجاج: صَفَدتُه بالحديد وأصفدته، ومثله في العطية {7}، إلا أن الاختيار في العطية أصفدته، وفي الحديد صفدته {8}.قال ابن عباس: يريد بالأصفاد: سلاسلَ الحديد والأغلال {9}.قال الكلبي: ﴿مُقَرَّنِينَ﴾ كل كافر مع شيطان في غل {10}، وقال هطاء: وهو معنى قوله: ﴿وَإِذَا النُّفُوسُ زُوِّجَتْ﴾ [التكوير: 7] أي قُرنت نفوس المؤمنين بالحور العِين، ونفوس الكافرين بالشياطين {11}، وفي هذا المعنى أيضاً قوله: ﴿احْشُرُوا الَّذِينَ ظَلَمُوا وَأَزْوَاجَهُمْ﴾ [الصافات: 22].قال ابن عباس: وقرناؤهم من الشياطين {12}، وقال قوم في معنى: ﴿مُقَرَّنِينَ﴾: قُرن بعضهم ببعض {13}.وقال ابن زيد: قُرنت أيديهم وأرجلُهم إلى رقابهم بالأغلال {14}، فهذا {15} ثلاثة أقوال في معنى: ﴿مُقَرَّنِينَ﴾."
  14,50,"قوله تعالى: ﴿سَرَابِيلُهُمْ مِنْ قَطِرَانٍ﴾ السرابيل جمع سِرْبال وهو القُمُص، والفعل منه تسربلتُ، وسربلتُ غيري {1}.قال امرئ القيس:لَعُوبٌ تُنَسِّيني إذا قُمتُ سِرْبالي {2} وقال الزجاج: هو كل ما لُبِس {3}.والقطران: هناء الإبل.قال الليث: وهو شيء يَتَحلَّب من شجر يقال له: الأَبْهُل {4}.قال الفراء: أهلَ الحجاز وبنو أسد يفتحون القاف ويكسرون الطاء، وبعض قيس {5} وتميم {6} يقولون: قِطْران بكسر القاف وتسكين الطاء {7}، وأنشد:عَلَيْهم سَرَابِيلُ الحَدِيدِ كأنَّهم ... جِمَالٌ بها القَطرانُ مَطْلِيَّةٌ بُزُل {8} وفيه لغة أخرى وهو فتح القاف وتسكين الطاء {9}، وبه قرأ عيسى بن عمر. قال أبو إسحاق: وجُعلت سرابيلهم من قطران والله أعلم؛ لأن القطران يبالغ في اشتعال النار في الجلود، ولو أراد الله المبالغة في إحراقهم بغير نار وبغير قطران لقدر على ذلك، ولكنه عذَّب بما يَعقل العبادُ العذابَ من جهته، وحذّرهم ما يعرفون حقيقته {3}.قال ابن الأنباري: والنار لا تُبطل ذلك القطران ولا يُفنيها، كما لا يُهلك أغلالَها وأنكالَها وحَيّاتِها وهوامَها وأشجارَها {11}، وللقطران أيضًا روائح خبيئة، وقال غيره: وفيه أيضًا عقاب بالتسويد لسواد دخانه {12}."
  14,51,"قوله تعالى: ﴿لِيَجْزِيَ اللَّهُ كُلَّ نَفْسٍ مَا كَسَبَتْ﴾ هذه اللام تتعلق بقوله: ﴿وَتَغْشَى﴾ أي تغشى النار وجوههم ليقع لهم الجزاء من الله بما كسبوا، فمعنى ﴿كُلَّ نَفْسٍ﴾ هاهنا من الكفار؛ لأن جزاء المؤمن لا يقع بهذا {1}.وقوله تعالى: ﴿إِنَّ اللَّهَ سَرِيعُ الْحِسَابِ﴾ ذكرنا معناه في سورة البقرة عند تمام المائتين منها."
  14,52,"قوله تعالى: ﴿هَذَا بَلَاغٌ لِلنَّاسِ﴾ قال ابن عباس: يريد ما أنزلت إليك من قصة إبراهيم ودعائه لوالده وما تبرأ منه من عبادة الأصنام وما دعا للمؤمنين، وقال غيره من أهل العلم: ﴿هَذَا﴾: القرآن {1}، ﴿بَلَاغٌ لِلنَّاسِ﴾ والبلاغ اسم يقوم مقام التبليغ، قال أبو علي الجرجاني: تأويله: فعلنا هذا؛ يعني إنزال القرآن وما فيه من المواعظ لتبلِّغ الناس، وهذا عطف على البلاغ بالفعل، وهو قوله: ﴿وَلِيُنْذَرُوا بِهِ﴾ {2}، قال ابن عباس: ولتنذر يامحمد قومك {3}، ﴿وَلِيَعْلَمُوا أَنَّمَا هُوَ إِلَهٌ وَاحِدٌ﴾ أي بما ذكر فيه من الحجج التي تدل على وحدانيته، ﴿وَلِيَذَّكَّرَ أُولُو الْأَلْبَابِ﴾ قال يريد وليتعظ أهل اللب والعقل والبصائر."
