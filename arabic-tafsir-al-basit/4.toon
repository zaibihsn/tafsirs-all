tafsir[176]{c,v,t}:
  4,1,"﴿يَا أَيُّهَا النَّاسُ اتَّقُوا رَبَّكُمُ﴾ قال ابن عباس: الخطاب لأهل مكة {1}.وقوله تعالى: ﴿الَّذِي خَلَقَكُمْ مِنْ نَفْسٍ وَاحِدَةٍ﴾ أنثها على لفظ النفس وإن عَنَى به مُذَكَّرا كما قال:أبُوكَ خَلِيفةٌ وَلَدَتْه أُخْرى ... وأَنْت خَلِيفةٌ ذاكَ الكَماَل {2}وعنى بالنفس الواحدة آدم {3}.وقوله تعالى: ﴿وَخَلَقَ مِنْهَا زَوْجَهَا﴾ حواء {4}، خلقت من (ضلع {5} من أضلاع آدم، ولذلك قال النبي ﷺ: ""إن المرأة خلقت من ضلع، فإن ذهبت تقيمها كسرتها، وإن تركتها وفيها عوج استمتعت بها"" {6}.وقوله تعالى: ﴿وَبَثَّ مِنْهُمَا﴾ يريد فرّق ونشر {7}. قال ابن المُظَفَّر {8}: البث تفريقك الأشياء، يقال بثّوا الخيلَ في الغارة، وبثّ الصياد كِلابه، وخلق الله الخلق فبثّهم في الأرض، بثث البسط إذا نشرتها {9}، قال الله تعالى: ﴿وَزَرَابِيُّ مَبْثُوثَةٌ﴾ {10} [الغاشية: 16].قال الفراء، والزجاج: وبعض العرب يقول أَبَثّ {11} الله الخلق. وبثّ الحديث إذا نشره وأفشاه، وكذلك أبثه {12}، قال ذو الرمّة: وأُسْقيِه حتَّى كَادَ مما أَبثُّه ... تُكَلِّمُني أَحْجَارُه وَملاعِبُه {13}وقوله تعالى: ﴿وَاتَّقُوا اللَّهَ الَّذِي تَسَاءَلُونَ بِهِ وَالْأَرْحَامَ﴾ قُرئ (تساءلون) بالتخفيف والتشديد {14}؛ فمن شدّد أراد: تتساءلون، فأدغَم التاء في السين لاجتماعهما في أنهما من حروف طرفِ اللسان وأصول الثنايا واجتماعِهما في الهمس.ومن خفف، حذف تاء تتفاعلون لاجتماع حروف متقاربة فأعلَّها بالحَذْف، كما أعلَّ الأول بالإدغام {15}، وإذا اجتمعت المتقاربة خففت بالحذف أو بالإدغام أو بالإبدال {16}، (فالحذف والإدغام، كالقراءتين في هذا الحرف) {17}. والإبدال كقولهم: طست (للطس) {18} أُبدِلَ من السين الثانية التاء لتقاربهما، قال العجَّاج:أَإِنْ رأيتِ (هَامَتِي) {19} كالطَّسْتِ {20}وأنشد المازني في الطسّ:لو عَرَضَت لأَيْبُلِي قَسّ ... أشعثَ في هيكلِه مُنْدَسّحَنَّ إِلَيهَا كحَنِين الطَّسّ {21}ومعنى: ﴿تَسَاءَلُونَ بِهِ وَالْأَرْحَامَ﴾ أي تتساءلون فيما بينكم حوائجكم وحقوقكم به فتقولون: أسألُك بالله والرحِم، وأنشدك اللهَ والرحم {22}.قال ابن عباس: يريدون أن أهل مكة لم يكونوا يؤمنون بالبَعْث، وكانوا يتواصلون بالأرحام، فإذا ناشد الرجلُ الرجلَ، قال: أنشدك الله والرحم، وكذلك كان يكتب المشركون إلى رسول الله ﷺ: نناشدك الله والرحم (إلَّا) {23} بعثت إلينا فلانًا وفلانًا {24}.وعلى هذا التفسير انتصب ﴿وَالْأَرْحَامَ﴾ بالعطف على موضع ﴿بِهِ﴾، كأنه قيل: وتذكرون الأرحامَ؛ لأن معنى ﴿تَسَاءَلُونَ بِهِ﴾: تذكرونه في سؤالكم ومناشدتكم، فالأرحام عطف على موضع الجار والمجرور.قال أبو علي {25} وعلي بن عيسى {26}: ويكون كقوله: فَلَسْنَا بِالجِبَالِ وَلا الحَديدَا {27}وقال أكثر المفسرين: معنى ﴿وَالْأَرْحَامَ﴾ أي: واتقوا الأرحام أن تقطعوها. قاله: قتادة {28}، ومجاهد، والسدي، والضحاك، وابن زيد {29} والربيع {30} {31}، والفراء {32}، والزجاج {33}.وعلى هذا التفسير انتصب الأرحام بالعطف على قوله أي: اتقوا اللهَ واتقوا الأرحامَ، أي: اتقوا حقَّ الأرحام فصلوها ولا تقطعوها {34}.ويجوز على هذا التفسير أنْ يكون منصوبًا بالإغراء، أي: والأرحام فاحفظوها وصلوها، كقولك: الأسدَ الأسدَ {35}وهذا التفسير يدل على تحريم قطيعة الرحم، وينبئ بوجوب صلتها. وقرأ حمزة ﴿والأرحامِ﴾ جرًا {36} بالعطف على المَكْنِيّ في ﴿بِهِ﴾ كما يقال: سألتك باللهِ والرحمِ، ونشدتك باللهِ والرحم، وإنما حَملَه على هذه القراءة ما ورد في التفسير أن المشركين كانوا يقولون: نناشدك بالله والرحم، ونسألك بالله والرحم إلّا فعلت كذا {37}.وضعف النحويون كلُّهم هذه القراءة واستقبحوها {38}، فقال أبو علي {39}: هذا ضعيف في القياس قليل في الاستعمال، وما كان كذلك فَتركُ الأخذ به أحسن {40}؛ وضعفه أنَّ المشاكلة تُراعَى في باب العطف حتى يعطف الشك على الشكلِ، والمعطوف ينبغي أنْ يكون مُشاكلًا للمعطوف عليه، والمضمرُ المجرور قد خرج عن شبه الاسم وصار بمنزلة الحرف بدلالة أنه لا ينفصل، وذلك أن الكاف والهاء في قولك: (بِهِ وبِكَ) {41} (ألا) {42} ترى واحدًا منهما منفصلًا عن الجار، فصار كالتنوين؛ فلأن المضمر المجرور أيضا قد صار عِوَضًا من التنوين إذا اتصل باسمٍ، نحو: غلامك، وغلامه، وغلامي، وأيضًا فإنه على حرف كما أن التنوين على حرف.قال {43}: ويدلك على أنه قد جرى عندهم مجرى التنوين حذفهم الياء من المُنَادَى المضاف {44} (في الاختيار) {45} كحذفهم التنوين (من المفرد) {45} وذلك قولهم: يا غلام، وهو أكثر في الاستعمال {47} من: يا غلامي، فشابه المضمرُ المجرور التنوينُ من هذه الوجوه. وإذا كان كذلك خرج عن حدّ الاسم وصار بمنزلة الحرف، فلم يعطف على المضمر المجرور لخروج المعطوف عليه عن شَبَه الاسم إلى شبَه الحرف، وقد ذكرنا شأن التشاكل، يُرَاعى في باب العطف فلا يُعطف الاسم على الحرف.وقال الزجاج {48}: إجماع النحويين أنه يقبح أن يُنْسقَ باسمٍ ظاهر على اسم مُضمَر في حال الخفض إلا بإظهار الخافض {49}، كقوله تعالى: {فَخَسَفْنَا بِهِ وَبِدَارِهِ الْأَرْضَ} [القصص: 81] {50}، ويستقبح النحويون: مررت به وزيد {51}، لأن المكني المخفوض حرف متصل غير منفصل، فكأنه كالتنوين في الاسم، فقبح أن (يعطف) {52} باسم يقوم بنفسه على اسم لا يقوم بنفسه. هذا كلامه {53}. وقد ذكر أبو علي وجه الشبه بينهما كما حكينا.وقال علي بن عيسى {54}: ومما يزيد هذا الفصل بيانًا أنهم لم يستحسنوا عطف الظاهر المرفوع على المضمر المرفوع حتى يؤكد، فينفع {55} العطف في اللفظ على المضمر المنفصل الذي يجري مَجرى الأجنبي، وذلك نحو: اذهب وزيد، وذهبت وزيد، لا يستحسنون ذلك حتى يؤكدوه، فيقولوا: اذهب أنت وزيد، وذهبت أنا وزيد {56}؛ لأنه لما اختلط الاسم بالفعل حتى صار كبعض أجزائه لوقوع إعرابه بعده في نحو: تفعلين، وتفعلان، وتفعلون، ولإسكانهم الآخر منه إذا اتصل بالضمير مع تحريكهم نحو: (عَلَيْطٍ) {57}، (لم يستجيزوا العطف عليه إلا بالتأكيد) {58} ليقع العطف عليه في اللفظ، فلا يكون كأنه عطف اسمًا على فِعل {59}، كما يصير في المجرور، كأنه عطف اسمًا على تنوين {60}. وإذا ضَعُف في المرفوع مع أن له ضميرًا منفصلًا نحو: أنت وهو، امتنع في المجرور؛ لأن المضمَر المجرور لا منفصل له، وليس بعد الضعف إلا الامتناع.فأما الضمير المنصوب نحو: ضربته، لا يستقبح العطف عليه؛ لأنه ظاهر لم يختلط بالفعل حتى صار كبعض أجزائه، كضمير المرفوع، ولا يقوم مقام التنوين في موضع ما كضمير المجرور، وذلك أن ضمير المنصوب لا يتصل إلا بالفعل نحو: منعته وقتلته، ولا ينون الفعل قط.وضمير المجرور إما أن يَتَّصل باسمٍ فيقوم فيه مقام التنوين، أو بحرفٍ نحو: به وبك، واتصالُه بالحرف كاتصالهِ بالاسم، ألا ترى أنه لا ينفصل من الاسم، ولا يفصل بينهما كما يفصل بين الجار والمجرور الظاهر في باب المضاف والمضاف إليه نحو:كأن أصواتَ -مِن إِيغالِهِنَّ بنا- ... أَوَاخِرِ المَيْس إِنْقَاض الفَراريجِ {61}وإِذا اتّصلَ بالحرف لم ينفَصِل منه ولم يُفصل أيضًا بينهما بشيء، فلا فصل إذًا بين اتصاله بالاسم وبين اتصاله بالحرف.ولأبي عثمان المازني {62} تفسير لهذا الفصل مُقنع، وهو أنه قال: الثاني في العطف شريكٌ للأول، فإنْ كان الأول يصلح أَنْ يكون شريكًا الثاني وإلا لم يصلح أَنْ يكون الثاني شريكًا له. (بيان هذا أنك لا تقول) {63}: مررت بزيدٍ وبك كذلك لا تقول: مررت بك وزيد.وقال سيبويه: لا يجوز عطف الظاهر على المكني المخفوض من غير إعادة الخافض إلا في ضرورة الشعر {64}، وأنشد:فاليَومَ قرَّبت تهجُونا وتشتُمُنا ... فاذْهَب فَمَا بِكَ والأيامِ من عَجَبِ {65}وأنشد الفراء أيضًا: نُعَلِّقُ في مثلِ السَّواري سيوفَنَا ... وما بَينَها والكَعْبِ غَوطٌ نَفَانِفُ {66}قال أبو إسحاق {67}: وقراءة حمزة مع ضَعفِها وقُبحِها في العربية خطأ في أمر الدين عظيم؛ لأن النبي ﷺ قال: ""لا تحلفوا بآبائكم {68} فكيف يكون: تتساءلون بالله (والرحم)؟ {69} {70}.يعني أن الحَلِفَ بغير الله لا يجوز، وإذا عطفت الأرحام (كالمَكْنِيّ) {71} عن اسم الله أوجب جواز الحَلِف بالأرحامِ، وذلك غير جائز.وقوله تعالى: ﴿إِنَّ اللَّهَ كَانَ عَلَيْكُمْ رَقِيبًا﴾ [النساء: 1]. الرقيب: الحافظ، يقال: رَقَبَ يرقُبُ رِقْبَةً وُرقُوبا {72}. ومعناه: أنه يرقُب عليكم أعمالكم فاتقوه فيما نهاكم."
  4,2,"قوله تعالى: ﴿وَآتُوا الْيَتَامَى أَمْوَالَهُمْ﴾. قال المفسرون: الخطاب للأوصياء وأولياء اليتامى {1}. أي أعطوهم أموالهم. وإنما يُعطى إذا بلغ، ولا يُتْمَ بعد البلوغ {2}، ولكن قد يُستَصحب الاسم وإن زال معناه، كقوله: ﴿فَأُلْقِيَ السَّحَرَةُ سَاجِدِينَ (46)﴾ [الشعراء: 46]، أي: الذين كانوا سحرة قبل السجود. وقد كان يقال للنبي ﷺ يتيمُ أبي طَالِب {3}.وقوله تعالى: ﴿وَلَا تَتَبَدَّلُوا الْخَبِيثَ بِالطَّيِّبِ﴾.يقال: تبدل الشيء بالشيء إذا أخذه مكانَه {4}، قال العجّاج:مَن إِنْ تَبَدَّلتُ بِلادِي آدُر {5}قال أكثر المفسرين: كان ولي اليتيم يأخذ الجيّد من ماله ويجعل مكانَه الرديء، بجعل الزائف بدل الجيد، والمهزول بدل السمين، فنهى الله تعالى عن ذلك {6}.قال مجاهد وبَاذَان {7}: أي: لا تجعل بدل رِزقك الحلال حرامًا تتعجّله، فتأخذه عن مال اليتيم {8}.ومعنى هذا ما قال الفراء والزجاج: يقول: لا تأكلوا أموالَ اليتامى بدل أموالكم، وأموالهُم عليكم حرام، وأموالكم حلال {9}.وقوله تعالى: ﴿وَلَا تَأْكُلُوا أَمْوَالَهُمْ إِلَى أَمْوَالِكُمْ﴾. قال أكثر المفسرين: لا (تضيفوا) {10} أموالهم في الأكل إلى أموالكم، إن احتجتم إليها فليس لكم أن تأكلوها مع أموالكم {11}.قال عطاء: يريد تَربَح على يتيمك، بأن يَهوَى دابة عندك أو ثوبًا فتبيعه منه بأكثر من ثمنه، وهو غِرّ {12} صغير السن {13}.وهذا الذي ذكره عطاء هو نوع من أكل مال اليتيِم، ولا يجوز ذلك بأي وجهٍ كان.وقوله تعالى: ﴿إِنَّهُ كَانَ حُوبًا كَبِيرًا﴾ [النساء: 2] الكناية تعود إلى الأكل، ودل (تأكلوا) على المصدر {14}. والحُوب الإثم الكبير، وكذلك الحَوب والحَاب، ثلاث لغات في الاسم والمصدر، يقال: حَاب يحُوب حُوبا، وحَوبا وحَابًا وحيابًة، إذا أَثِم {15}.قال الفراء: الحُوب لأهل الحجاز، والحَوب لتميم، ومعناهما الإثم {16}.وقال أمية بن الأسكر الليثي {17} -وكان ابنه قد هاجر بغير إذنه {18} -:وإنَّ مُهَاجِرَينِ تَكنَّفَاهُ ... غَدَاتَئِذٍ لَقَد خَطِئَا وَحَابَا {19} وحكى الفراء، عن بني أسد أنهم يقولون للقتال: حَائِب {20}. وقال النبي ﷺ: ""رب تقبل توبتي، واغسل حوبتي"" {21}، قال أبو عبيد {22}: حَوْبتي يعني: المآثم، قال: وكل مأثم حُوب وحَوب، والواحدة حَوبة، ومِن هذا قوله: ألك حوبة؟ قال: نعم {23}.وهو عندي: كل حرمة تأثم الإنسان بتركها وتضييعها من أُمّ أو أُخت أو بِنت أو غيرهن {24}.ويقال {25}: تَحوَّب فلان إذا تعبّد، كأنه يُلقي الحُوب عن نفسه بالعبادة، مثل: تأثم {26}.قال الكُميت:وصُبَّ له شَولٌ من الماء غَائرٌ {27} ... به كَفَّ عنه الحِيبَةَ المتَحَوِّبُ {28}والحِيبَة ما يُتأثم منه، يصف ذِئبًا سقاه وأطعمه {29}.قوله تعالى: ﴿وَإِنْ خِفْتُمْ أَلَّا تُقْسِطُوا فِي الْيَتَامَى فَانْكِحُوا مَا طَابَ لَكُمْ مِنَ النِّسَاءِ﴾ الآية.الإقساط: العَدل، يقال أَقسط الرجل إذا عدل {30}، قال تعالى: ﴿وَأَقْسِطُوا إِنَّ اللَّهَ يُحِبُّ الْمُقْسِطِينَ﴾ [الحجرات: 9].والقسط: العدل والنصفة {31}، قال الله تعالى: ﴿كُونُوا قَوَّامِينَ بِالْقِسْطِ﴾ [النساء: 135].قال الزجاجي: وأصل قَسَط وأَقْسَط جميعًا من القِسط، وهو النصيب، فإذا قالوا: قسط بمعنى: جار، أرادوا أنه ظلم صاحبه في قِسطه الذي يصيبه. ألا ترى أنهم قالوا: قاسطته فقسطتُه إذا غلبته على قِسطه، فبني قَسَط على بناء ظلم وجار وعسف وغلب، وإذا قالوا: أقسط، فالمراد به أنه صار ذا قسط وعدل، فبُني على بناء أنصف، إذا أتى بالنَّصف والعدل في قوله، وفعله، وقسمه {32}.واختلف أقوال أهل التأويل في هذه الآية، فرُوي عن عروة أنه قال: قلت لعائشة: قول الله تعالى: ﴿وَإِنْ خِفْتُمْ أَلَّا تُقْسِطُوا فِي الْيَتَامَى﴾؟ فقالت يا ابن أختي هي اليتيمة تكون في حَجرِ وليّها فيرغب في مالها وجمالها ويريد أن ينكحها بأدنى من صداقها، فنُهوا أن ينكحوهن إلا أن يقسطوا لهن في إكمال الصداق، وأُمِروا أن يَنكحوا ما سِواهن من النساء {33}.وعلى هذا التفسير تقدير الآية: وإن خفتم ألا تُقسطوا في نكاح اليتامى، أي: الإناث منهم، فحذف المضاف؛ لأن قوله بعد: ﴿فَانْكِحُوا﴾ يدل على النكاح {34}.وقوله تعالى: ﴿فَانْكِحُوا مَا طَابَ لَكُمْ﴾ أي: من غيرهن، وذلك أن قوله: ﴿فَانْكِحُوا مَا طَابَ لَكُمْ﴾ بعد ذكر خوف الحَرج مِن نِكاح اليتامى، يدل على أن المراد به من غيرهن {35}.هذا وجه ما رُوي عن عائشة رضي الله عنها في هذه الآية.وقال ابن عباس في رواية الوالبي {36} وعطاء، يقول: فكما خِفتم ألا تُقسطوا في اليتامى وَهمَّكم ذلك، فكذلك فخافوا في النساء ألا تعدلوا فيهن ولا تتزوجوا أكثر مما يمكنكم إمساكهن والقيام بحقهن؛ لأن النساء كاليتامى في الضعف، والعجز {37}.وهذا قول سعيد بن جبير، وقتادة، والربيع، والضحاك، والسدي {38}، واختيار الفراء {39}.وشرح ابن قتيبة هذا القول، فقال: المعنى: أن الله -جل وعز- قال لنا: فكما تخافون أن لا تعدلوا بين اليتامى إذا أكلفتموهم {40}، فخافوا أيضًا أنْ لا تعدلوا بين النساء إذا نكحتموهن، فانكحوا اثنتين، وثلاثًا، وأربعًا، ولا تتجاوزوا ذلك فتعجزوا عن العدل {41}.وقال ابن عباس: قُصِر الرجالُ على أربع، مِنْ أجل اليتامى {42}.وكان {43} العدل في اليتامى شديدًا على كافِلِهم، قصر الرجال على ما بين الواحدة إلى الأربع من النساء، ولم يُطلَق لهم ما فوق ذلك لئلا يميلوا.وقال مجاهد: معنى الآية: إن تحرجتم من ولاية اليتامى وأموالهم إيمانًا وتصديقًا فكذلك تحرجوا مِن الزنا، فانكحوا النساء الحلال نكاحًا طيبًا ثم بين لهم عددًا محصورًا، وكانوا يتزوجون ما شاءوا من غير عدد {44}، وهذا القول اختيار الزجاج {45}.وهذه أوجهٌ صحيحةٌ من التأويل لهذه الآية {46}.وقوله تعالى: ﴿مَا طَابَ﴾ ولم يقل: (من) الأصل أن (من) لما يعقل، و (ما) لما لا يعقل {47}.ولأهل العربية في هذا قولان: أحدهما: أن (ما) ههنا عبارة عن المصدر، فقال الفراء: معناه فانكحوا الطيب لكم من النساء {48}.وقال مجاهد: فانكحوا النكاح الذي طاب لكم من النساء {49}.قال الفراء: وهذا كما تقول في الكلام: خُذ من عبيدي ما شئت، أي: مشيئتك فإن قلت: مَن شئت، فمعناه: خذ الذي شئت {50}.فعلى هذا (ما طاب) بمنزلة الطيب.والقول الثاني: أن (ما) و (من) ربما يتعاقبان، قال الله تعالى: ﴿وَالسَّمَاءِ وَمَا بَنَاهَا﴾ [الشمس: 5]، وقال: ﴿فَمِنْهُمْ مَنْ يَمْشِي عَلَى بَطْنِهِ﴾ {51} [النور: 45].وحكى أبو عَمْرو بن العلاء {52}، عن العرب: سبحان ما سبح له الرعد {53}.ومعنى قوله (طاب) أي: حلّ {54}، وإنما أباح النكاح من اللاتي تحل دون المحرمات اللواتي ذُكِرن في قوله: ﴿حُرِّمَتْ عَلَيْكُمْ أُمَّهَاتُكُمْ﴾ [النساء: 23] إلى آخر الآية {55}.وقوله تعالى: ﴿مَثْنَى وَثُلَاثَ وَرُبَاعَ﴾. بدل مما طاب، ومعناه: اثنتَين، وثلاثًا (ثلاثًا {56}) وأربعًا (أربعًا) {56}.قال أبو إسحاق {58}: إلا أنه لم ينصرف لجهتين لا أعلم أحدًا من النحويين ذكرهما؛ وهي أنه اجتمع فيه علتان: أنه معدول عن اثنتين اثنتين {59} وثلاث ثلاث، وأنه عُدِل عن تأنيث.قال أصحابنا {60}: إنه اجتمع علتان: أنه عَدْل {61}، وأنه نكرة، والنكرة أصل الأشياء {62}، وهذا {63} كان ينبغي أن يخفّفه {64}؛ لأنّ النكرة تخفف ولا تعد (فرعًا {65}) هذا كلام أبي إسحاق {66}.وقد أخطا لي {67} في موضعين من هذا الفصل أصلحهما أبو علي وذكر معنى العدل فقال {68}: اعلم أنّ العدل ضرب من الاشتقاق، فكل معدول مشتق، وليس كل مشتق معدولًا، وإنما صار العدل ثقلًا.وثانيًا: لأنك تلفظ بكلمة وتريد بها كلمة على لفظ آخر، ألا ترى أنك تريد بعُمَر وزُفَر (عَامِرًا وَزافِرًا) {69}، فأنت تلفظ بكلمة وتريد أخرى، وليس كذلك سائر المشتقات، لأنك تريد بها نفس اللفظ المسموع، ولست تُحيل بها على لفظ آخر، نحو: ضارب ومضروب؛ فإنهما اشتقا من الضرب، ولا تريد بلفظ واحد منهما لفظًا غيره، كما تريد بُعمَر عامرًا، وبزُفَر زَافِرًا، وبمثنى اثنين اثنين، فصار المعدول بمخالفته سائر المشتقات ثقيِلًا؛ إذ ليس في جنس الاشتقاق شيءٌ على حِدِّهِ.وقول أبي إسحاق: إن مثنى لا ينصرف لجهتين: وهو أنه معدول عن اثنتين اثنتين، وأنه عُدِل عن تأنيث، مراده بهذا أنه لما عدل عن التأنيث كان ذلك ثقلًا آخر لما لم يكن المعدول عنه هو الأول المذكر، فزاد بذلك ثقلًا انضم إلى المعنى الأول فلم ينصرف.إلى هذا الوجه ذهب أبو إسحاق، ولو سُلِّم له أنه عُدِل عن تانيث لم يكن ثقلًا مانعًا من الصرف يدل على ذلك أن التعريف ثانٍ، كما أن التأنيث كذلك، ولم يكن العدل عن التعريف ثقلًا معتدًا في منع الصرف، ألا ترى أنه لو كان مُعتَدًا به لوجب أن لا ينصرف (عُمر) في النكرة في قول جميع الناس، دلالة على أن العدل عن التعريف غير معتد به ثقلًا، على أنا لا نسلم أنه معدول عن تأنيث.وقوله في ذلك دعوى لا دلالة عليها، ألا ترى أنه لا يجد فصلًا بينه وبين من قَلَب هذا عليه، فقال: إنه معدول عن التذكير هو أقرب إلى الصواب؛ لأن الأصل التذكير حتى يُعلم التأنيث، ولم نعلم التأنيث هنا. فإن قال: عَلِمنا التأنيث بقوله: ﴿مِنَ النِّسَاءِ مَثْنَى﴾ فجرى على النساء وهي مؤنثة، قيل: لا يدل هذا على أنّ العدل عن التأنيث، بل العدل يكون عن التذكير، وإنما جرى على النساء، من حيث كان تأنيثها تأنيث الجمع، وهذا الضرب من التأنيث ليس بحقيقي، ألا ترى أنك تقول: هي الرجال، كما تقول: هي النساء، فلما كان تأنيث النساء تأنيث الجمع جرى عليه هذه الأسماء كما جرى على غير النساء مما تأنيثه تأنيث جمع؛ لأنّ تأنيث الجمع ليس بحقيقي، إنما هي من أجل اللفظ، فهو مثل: الدار، والنار، وما أشبه ذلك.ولو جاز لقائل أن يقول: مثنى وبابُه معدول عن مؤنث لما جرى على النساء وواحدتهن مؤنثة، لجاز لآخر أن يقول: إنه مذكر؛ لأنه جرى صفة على الأجنحة في قوله: ﴿أُولِي أَجْنِحَةٍ مَثْنَى﴾ [فاطر: 1]، وواحدها مُذكّر.وهذا هو القول والوجه لما بينّا أنّ تأنيث الجمع ليس بحقيقي، على أن هذه الأسماء قد جرت المذكر الحقيقي، قال: ولقد قتلتكم {70} ثناءَ وَموحَدًا ... وتركتُ مُرَّة مثل أمسِ الدَّابِرِ {71}فأما ذكره في قول: قال: إنه اجتمع فيه علتان، أنه عَدْل وأنه نكرة، الفصل إلى آخره، فاعلم أنه غلط بين في الحكاية عنهم، وإنما يذهبون في امتناعه من الانصراف إلى أنه معدول، وأنه صفة. وهذا لفظ سيبويه، قال {72} عن الخليل في (أحاد، ومثنى): إنما كان حده واحدا واحدا، واثنين واثنين، فجاء (معدولًا {73}) عن وجهه فتُرِك صرفه. قلت: أتصرفه في النكرة؟ قال: لا، لأنه نكرة يوصف به نكرة.وحكى الخليل، عن أبي عمرو أنه قال في قوله: ﴿أُولِي أَجْنِحَةٍ مَثْنَى وَثُلَاثَ وَرُبَاعَ﴾ [فاطر: 1]: أنها صفة {74}.فقد نصوا على الصفة كما ترى، ونحو هذا قال أبو الحسن {75} وغيره من أصحابنا. انقضى كلام أبي علي {76}.ومن النحويين {77} من يذهب إلى أن العلّة المانعة للصرف في (مثنى) وبابه، أن العدل تكرر فيه؛ لأنه عُدِل لفظ (اثنين)، وعُدِل عن معناه أيضًا، وذلك لا يستعمل في موضع يستعمل {78} فيه الأعداد غير المعدولة. ألا ترى أنك تقول: جاءني اثنان وثلاثة، ولا يجوز أن تقول: جاءني مثنى وثلاث، حتى يتقدم قبله جمع؛ لأن هذا الباب جُعِل بيانًا لترتيب الفعل، فإذا قال القائل: جاءني القوم مثنى مثنى، أفاد أن ترتيب مجيئهم وقع اثنين اثنين.وأما الأعداد غير المعدولة، فإنما الغرض فيها الإخبار عن مقدار المعدود (دون {79}) غيره، فقد بان بما ذكرنا اختلافهما في المعنى، فلذلك جاز أن تقوم العلة مقام العلتين، لإيجابها حكمين مختلفين {80}.والواو في قوله: ﴿مَثْنَى وَثُلَاثَ وَرُبَاعَ﴾ دالة على تفرّق الأنواع، وتجنيس المُباح من الزوجات، فمن تزوج مثنى لم يضم إليهما ثلاثًا، وكذلك من تزوج ثلاثًا لم يضم إليهن أربعًا.قال الشاعر:ولَكِنَّمَا أَهْلِي بوادٍ أَنيسُه ... ذئابٌ تَبَغَّى الناس مثْنَى وَموْحَدا {81} فعَنى مثنى في حال، وموحد في حال أخرى، وليس (موحد) مضمومًا إلى (مثنى) في المعنى.وقال ابن الأنباري: الواو هنا معناها التفرّق، وليست واوًا جامعة، فإذا كانت بهذه الصفة قُدِّر الفعل بعدها، وكان التأويل: فانكحوا ما طاب لكم من النساء مثنى، وانكحوا ثلاثًا في غير الحال الأول، وانكحوا رباع في غير الحالين {82}.وهذا معنى قول النحويين: أن الواو ههنا للبدل {83}، كأنه قيل: وثلاث بدلا من مثنى، ورُباع بدلًا من ثلاث {84}.وقال صاحب النظم {85}: الواو في هذا الفصل بمنزلة (أو)؛ لأنه لما كانت (أو) بمنزلة واو النسق جاز أن تكون الواو بمنزلة (أو) {86}.ولا تدل هذه الآية على إباحة التسع {87}؛ لأن الله تعالى خاطب العرب بأفصح اللغات وأبلغها، وليس من شأن الخطيب البليغ أَنْ يُفرِّق العدد في مثل هذه الحال، يقول: أعط زيدًا درهمين وثلاثة وأربعة؛ لأنه يصير أعيا كلام {88}.وقوله تعالى: ﴿فَإِنْ خِفْتُمْ أَلَّا تَعْدِلُوا﴾، أي: في الأربع، بالحب والجماع {89}.﴿فَوَاحِدَةً﴾ أي: فلينكح كل واحد منكم واحدة {90}.ومن قرأ بالرفع {91} أراد: فواحدةٌ مقنَع، أو فواحدةٌ رضا {92}.وقوله تعالى: ﴿أَوْ مَا مَلَكَتْ أَيْمَانُكُمْ﴾. يريد من الجواري {93}؛ لأنه لا يلزم فيهن من الحقوق كالذي يلزم في الحرائر، ولا قسمة فيهن باليوم والليلة {94}.ومعنى الأيمان ههنا بيان، تقديره: أو ما ملكتم {95}.وقوله تعالى: ﴿ذَلِكَ أَدْنَى أَلَّا تَعُولُوا﴾ [النساء: 3] الإشارة في ﴿ذَلِك﴾ تعود إلى قوله: ﴿فَانْكِحُوا مَا طَابَ﴾ {96} أي: نكاحكم هؤلاء النسوة على قلة عددهن أقرب إلى العدل وأبعد من الظلم والجور.ومعنى ﴿تَعُولُوا﴾: تميلوا (وتجورا) {97}، عن جميع أهل التفسير واللغة {98}، وروي ذلك مرفوعًا.روت عائشة، عن النبي ﷺ في قوله: ﴿ذَلِكَ أَدْنَى أَلَّا تَعُولُوا﴾ قال: ""لا تجوروا"". ورُوي: ""أن لا تميلوا"" {99}. كلا {100} اللفظين مرويّ.قال ابن المظفر: العَول المَيل في الحكم إلى الجور {101}.وقال أبو عبيدة، عن الأصمعي: وعال الميزان إذا مال، وإنما هو مأخوذ من الجور {102}، وأنشد لأبي طالب {103}: بِميزانِ قسط لا يُعِلّ شَعيرةً ... ووزَّانُ صدقٍ وزنُه غيرُ عائلِ {104}وقال الفراء: عال الرجل يعول عَولًا وعِيالةً، إذا مال وجار {105}.وعلى هذا القول ابن عباس، والحسن، وإبراهيم، وقتادة، والربيع، والسدي، وأبو مالك {106}،وعكرمة {107}، والفراء {108}، والزجاج {109}، وابن قتيبة {110}، وابن الأنباري {111}.وأخبرني العروضي قراءةً، وسعيد بن العباس القرشي كتابةً، عن الأزهري، قال: أخبرني عبد الملك {112}، عن الربيع {113}، عن الشافعي - رضي الله عنه - {114} أنه قال: معناه ألّا يكثر عيالكم {115}.وإلى هذا القول ذهب من المفسرين عبد الرحمن بن زيد بن أسلم {116}، وليس قول من خطّأ الشافعي في هذا بشيءٍ، فقد روى لنا الفسوي أبو الحسين، عن حَمْد بن محمد الفقيه، عن أبي عمر {117} محمد بن عبد الواحد، عن أحمد بن يحيى، عن سَلَمة {118}، عن الفراء، عن الكسائي {119}، أنه قال: ومن العرب الفُصَحاء من يقول: عال يعول، إذا كثر عياله {120}.قال الكسائي: وهي لغة فصيحة سمعتُها من العرب {121}.قال الأزهري {122}: وهذا يدل على أن الشافعي لم يخطئ من جهة اللغة؛ لأن الكسائي ثقة مأمون {123}.قال {124}: والمعروف من كلام العرب: عال الرجل يعول، إذا جار ومال {125}، وأعال {126}، إذا كثر عياله {127}.وقال ابن الأنباري: وهذا القول -على قلة القائلين به- له مخرج في اللغة، وهو أن العرب تقول: قد عالت الفريضة، إذا زادت سهامها، وأعلتها أنا (إذ أردت {128}) في سهامها {129}. فكذلك قوله: ﴿أَلَّا تَعُولُوا﴾ معناه ألا يزداد عيالكم فتضيعوا الواجب والمفترض لهم {130}.وهذا القول وإن صح، فالاختيار القول الأول {131}، لقوله: ﴿أَوْ مَا مَلَكَتْ أَيْمَانُكُمْ﴾ فأطلق الآية من ملك اليمين، والأقل والأكثر منها {132}، وهن كلهن عيال تتصل بهن المؤونة، وسواء كثر العيال من الحرائر أو الإماء، فلا معنى إذًا أن يقول: ذلك أدنى أن لا يكثر عليكم {133} بعد إباحة الكثير من السراري.ودليل آخر، وهو أنه قال: ﴿فَإِنْ خِفْتُمْ أَلَّا تَعْدِلُوا﴾ ولم يقل: أن تفتقروا، فكان الجواب معطوفًا على هذا الشرط، ولا يكون جوابه إلا بضد العدل وهو الجور، لا لكثرة العيال. ذكر هذا صاحب النظم {134}.ورُوي عن مجاهد أنه قال: معنى قوله: ﴿أَلَّا تَعْدِلُوا﴾ ألا تضلوا {135}. وهذا راجع إلى الأول {136}، لأن الميل عن الحق ضلال.قوله تعالى: ﴿وَآتُوا النِّسَاءَ صَدُقَاتِهِنَّ نِحْلَةً﴾ فيه قولان:أحدهما: أن هذا خطاب لأولياء النساء، وذلك أنّ العرب كانت في الجاهلية لا تُعطي النساء من مهورها شيئًا، ولذلك كانوا يقولون لمن وُلدت له ابنة: هنيئًا لك النافجة. ومعناه أنك تأخذ مهرها إبلًا فتضمها إلى إبلك فتنفج مالك، أي تعظمه {137}.وقال ابن الأعرابي: النافجة ما يأخذه الرجل إذا زَوّج ابنته من الحُلوان فنهى الله عز وجل عن ذلك، وأمر بدفع الحق إلى أهله {138}.وهذا قول الكلبي {139}، وأبي صالح {140}، واختيار الفراء {141}، وابن قتيبة {142}.القول الثاني: أن الخطاب للأزواج، أُمِروا بإيفاء النساء مهورهن.وهذا قول إبراهيم {143}، وعلقمة، وقتادة {144}، وابن زيد {145}، واختيار الزجاج؛ قال: لأنه لا ذكر للأولياء ههنا، وما قبل هذا خطاب للناكحين وهم الأزواج {146}.والصدقات والمهور، واحدتها صَدُقَة، وفيها لغات هذه أعلاها وهي لغة أهل الحجاز {147}.وذكرنا أن موضوع (ص د ق) على هذا الترتيب، للإكمال والصحة في قوله: ﴿لَا تُبْطِلُوا صَدَقَاتِكُمْ﴾ {148} [البقرة: 264]، وعلى هذا الأصل سُمي المهر: صداقًا وصَدُقة؛ لأن عقد النكاح يتم ويكمل.وقوله تعالى: ﴿نِحْلَةً﴾. قال ابن عباس {149}، وقتادة، وابن جريج، (وأبي زيد) {150}: فريضة {151}. وإنما فسروا النحلة بالفريضة؛ لأن النحلة معناها في اللغة: الديانة والمِلّة والشِرعة والمَذهب.قال الزجاج، عن بعضهم في قوله: ﴿نِحْلَةً﴾ أي: ديانة {152}، ومثله رُوي {153} عن ابن الأعرابي: نحلة: أي: دينًا وتدينًا {154}. يقال: فلان ينتحل كذا، إذا كان يتدين به، ونِحْلَتُه كذا أي: دينه ومذهبه {155}.فقوله: ﴿وَآتُوا النِّسَاءَ صَدُقَاتِهِنَّ﴾ أي آتوهن مهورهن، فإنها نِحلة، أي دين وشريعة ومذهب في الدين، وما هو ديانة فهو فريضة.قال ابن الأنباري: يقال: فلان (مُنْتَحِلٌ {156}) كذا، إذا كان يتدين به ويجعله فَرضًا على نفسه {157}.وقال الكلبي: أي: عطية وهبة {158}، يقال نحلت فلانًا شيئًا أنحله نِحلة ونُحلاً. قال الفراء، والنحلة العطية {159}.ومعنى هذا القول: أن الله تعالى جعل الصداق نِحلةً للنساء، بأن جعل على الرجال الصداق، ولم يجعل على المرأة شيئًا من الغُرم، فتلك نحلة من الله -عز وجل- للنساء. وهذا القول اختيار الفراء {160}.وقال أبو عبيدة: معنى قوله: ﴿نِحْلَةً﴾ أي: عن طيب نفس {161}، وذلك أن النحلة في اللغة العطية من غير أخذ عوض، كما يَنحَل الرجلُ ولدَه شيئًا من ماله، وما أعطي من غير طلب عوض لا يكون إلا عن النفس، فأمر الله تعالى بإعطاء مهور النساء من غير مُطالبة منهن ولا مُخاصمة فيه؛ لأن ما يؤخذ بالمحاكمة لا يقال له نِحلة {162}.قال ابن الأنباري: وهذا القول هو المختارة لأن النَّحلة بالهبة أشهر منها بالفريضة، وحمل الشيء على الأشهر والأعرف فيه أولى {163}.وانتصابها على المصدر في قوله {164} من جعلها مصدرًا بمعنى: الهبة {165}، وفي قول الآخرين على أنه مفعول له {166}، كما تقول: افعل هذا أجرًا واحتسابًا.وقوله تعالى: ﴿فَإِنْ طِبْنَ لَكُمْ عَنْ شَيْءٍ مِنْهُ نَفْسًا﴾. قال الفراء {141} والزجاج: المعنى فإن طابت أنفُسهن لكم عن شيء من الصداق {168}، فنقل الفعل من الأنفس إليهن، فخرجت النفس مُفسّرة كما قالوا: أنت حسنٌ وجهًا، والفعل في الأصل للوجه، فلما حُوّل إلى صاحب الوجه خرج الوجه مفسّرًا لموقع الفعل. (ومثله: قررتُ به عينًا، وضقتُ به ذرعًا) {169}ووحد النفس {170}؛ (لأن المراد به بيان موقع الفعل وتفسير له، وذلك يعرف بالواحد دون الجميع. ومثله: عشرون درهما) {169}.قال الفراء: ولو جمعت كان صوابًا {172}، كقوله: ﴿بِالْأَخْسَرِينَ أَعْمَالًا﴾ [الكهف: 103]، وقوله تعالى: ﴿مِنْهُ﴾ (مِن) ليست ههنا للتبعيض، بل هي للتجنيس، والتقدير: عن شيء من هذا الجنس الذي هو مهر، كقوله: ﴿فَاجْتَنِبُوا الرِّجْسَ مِنَ الْأَوْثَانِ﴾ [الحج: 30]، وذلك أن المرأة لو طابت نفسُها عن جميع المهر حل للزوج أخذه كله.والخطاب في: ﴿لَكُمْ﴾ يجوز أن يكون للأولياء، ويجوز أن يكون للأزواج، على ما ذكرنا من القولين في قوله: ﴿وَآتُوا النِّسَاءَ صَدُقَاتِهِنَّ﴾ {173}.وقوله تعالى: ﴿فَكُلُوهُ هَنِيئًا مَرِيئًا﴾. قال الفراء {174}: يقال هَنَأني الطعام، ومَرأَني (يهيئني {175}) ويمرئني هَنأً وَمرءًا. ومنهم من يقول: هنئني ومرئني -بالكسر- وهي قليلة، يَهْنَأني وَيْمَرأني فإذا أفردوا قالوا: أمرأني هذا الطعام {176}، ولا يقولون: أهنأني. وقد مَرُؤ هذا الطعام مَرْأاة، وهنؤ هُنْأة. الليث {177}: ما كان مريئًا، ولقد مرؤ، واستمرأته، وهذا يُمرئ الطعام.وقيل: إن أصل الهنيء من الهناء وهو معالجة الجَرَب بالقَطران {178}، فالهنيء شفاء من المرض كالهناء شفاء من الجرب {179}.قال المفسرون: معنى الهنيء: الطيب المَساغ الذي لا يُنغِّصه شيء، والمريء: المحمود العاقبة التامّ الهضم الذي لا يضر ولا يُؤذي. يقول: لا تخافون في الدنيا به مطالبة، ولا في الآخرة تبعة {180}.ورُوي عن ابن عباس، عن النبي ﷺ: أنه سئل عن هذه الآية، فقال: ""إذا جادت لزوجها بالمهر طائعة، غير مُكرَهة لا يَقْضي به عليه سلطان، ولا يؤاخذه الله به في الآخرة"" {181}.قال الحضرمي {182}: إن ناسًا كانوا يتأثَّمون أَنْ يرجع أحدهم في شىِء مما ساق إلى امرأته، فقال الله تعالى: ﴿فَإِنْ طِبْنَ لَكُمْ عَنْ شَيْءٍ مِنْهُ نَفْسًا فَكُلُوهُ هَنِيئًا مَرِيئًا﴾ {183}."
  4,3,""
  4,4,"4:3"
  4,5,"قوله تعالى: ﴿وَلَا تُؤْتُوا السُّفَهَاءَ أَمْوَالَكُمُ الَّتِي جَعَلَ اللَّهُ لَكُمْ قِيَامًا﴾ الآية قال ابن عباس في هذه الآية: لا تَعمَد إلى مالك الذي خَوَّلك الله وجعله لك معيشةً؛ فتعطيه امرأتك وبنيك، فيكونوا هم الذين يقومون عليك ثم تنظر إلى ما في أيديهم، ولكن أَمْسِك مالك وأَصْلِحه وكن أنت الذي تنفق عليهم في كِسوتهم ورِزقهم ومؤنتهم {1}.والسفهاء: هم النساء والصبيان في قول ابن عباس {2}، والحسن وقتادة، وسعيد بن جبير، والسدي {3}، واختيار الفراء {4}، وابن قتيبة {5}.وقال الكلبي: إذا علم الرجل أنّ امرأته سفيهةٌ مُفْسِدةٌ، وأن ولدَه سفيهٌ مُفسِد فلا ينبغي له أن يُسلِّط واحدًا منهما على ماله فيفسد {6}.وقال مجاهد، وجويبر، عن الضحاك: أراد بالسفهاء ههنا النساء فقط {7}.وقال مجاهد: من سفهاء من كُنّ، أزواجًا أو بناتٍ أو أمهاتٍ {8}. وهذا مذهب ابن عمر {9}.ويدل على هذا ما رَوى أبو أمامة {10} أن النبي ﷺ قال: ""ألا إنّما خُلِقت النار للسفهاء، -يقولها ثلاثًا- ألا وإن السفهاء النساء إلا امرأة أطاعت قيّمها"" {11}. فإن قيل: لو كان المراد بالسفهاء النساء لقال: السفائه أو السفيهات في جميع السفيه {12}، نحو غرائب وغريبات في جمع: الغريبة. فالجواب ما قال الزجاج، وهو أن السفهاء يجوز في جمع السفيهة نحو: فقيرة وفقراء {13}.وقال الزُّهري، وأبو مالك، وابن زيد: عَنى بالسفهاء ههنا السفهاء من الأولاد، يقول: لا تُعط مالك الذي هو قيامك ولدَك السفيه فيفسده {14}وفي الآية قول رابع، وهو أن السفهاء: الأيتام وكل من يستحق صفة سفيه من محجور عليه في المال. وهو مذهب الشافعي {15}، وعكرمة {16} ، واختيار الزجاج {17}.قال عكرمة: هو مال اليتيم يكون عندك، يقول: لا تُؤتِه إيّاه وأنفِق عليه حتى يبلُغ {18}.فإن قيل على هذا القول: كيف أضاف الأموال إلى الأولياء وهي للسفهاء؟ قلنا: إنما أضاف إليهم؛ لأنها الجنس الذي جعله الله أموالًا للناس، فصار كقوله: ﴿لَقَدْ جَاءَكُمْ رَسُولٌ مِنْ أَنْفُسِكُمْ﴾ [التوبة: 128]، وقوله: ﴿فَاقْتُلُوا أَنْفُسَكُمْ﴾ [البقرة: 54]، ردها إلى الجنس {19}.قال أبو إسحاق {20}: إنما قيل أموالكم؛ لأن معناها الشيء الذي به قِوام أمركم، كما قال: ﴿ثُمَّ أَنْتُمْ هَؤُلَاءِ تَقْتُلُونَ أَنْفُسَكُمْ﴾ [البقرة: 85]، ولم يكن الرجل منهم يقتل نفسه، ولكن كان بعضهم يقتل بعضًا، أي: تقتلون الجنس الذي هو جنسكم {21}.وقال بعض النحويين: إذا اختلط المخاطب مع الغائب غُلِّب المخاطب، لذلك أضاف الأموال إليهم وهي للسفهاء، وهذا التفسير دليل على ما ذهب إليه الشافعي رحمه الله من جواز الحجر على الرجل البالغ إذا كان مُبذِّرًا مُفسدًا لماله {22}.وقوله تعالى: ﴿الَّتِي جَعَلَ اللَّهُ لَكُمْ قِيَامًا﴾. قال ابن عباس: يريد قيامًا لمعايشكم وصلاح دنياكم {23}.قال أبو عبيدة {24}: (قِيام) مصدر، ويجيء في معناه (قِوام)، وهو الذي يقيمك، وانما أذهبوا الواو لكسرة القاف كما قالوا: صِوار وصِيار {25}.وبنو ضبة {26} تقول في جمع طويل: طِيال، والعامّة على: طِوال {27}.وإنما أعل القيام؛ لأنه مصدر قد اعتل فعله، فاتّبع الفعل في الإعلال، ومثله من المصادر الصِّيام والعِياذ والحِياكة، ونحو ذلك فيما {28} قلبت الواو فيه ياء؛ لأنها مصادر جارية على الفعل في الإعلال {29}.قال أبو علي: وأما القِوام الذي حكاه أبو عبيدة فإنه ينبغي أن يكون اسمًا غير مصدر، كالقَوام فيمن فَتح، ويجوز أن يكون مصدر قَاوم، كما أن (الغِوار مصدر غاور) {30} {31}.وقرأ نافع، وابن عامر: (قِيَمًا) {32}.قال الأخفش: قِيامًا وقِوامًا وقِيمًا وقِومًا واحِد {33}.فالقِيَم عنده مصدر في معنى القِيام، وفِعَل يجيء في المصادر كالشِّبَع والرِّضَا {34}.فإن قيل {35}: كيف اعتلّ وهو على وزنٍ ينبغي أن يصح معه ولا يعتلّ، كما لم يعتلّ العِوض والحِول، ونحو ذلك؟والجواب: أن هذا الوزن لما جاء في الجمع مُتَّبعًا واحدَه في الإعلال، نحو: دِيمَةٍ ودِيَم، وحِيلَةٍ وحيَل، جاء أيضًا في المصدر متّبعًا للفعل فأعِلّ كما يعل الفعل؛ لأن (المصادر {36}) أشد اتّباعًا لأفعالها في الإعلال {37} من الجمع للواحد. ولا يلزم على هذا (الوعد) و (الوزن) وبابه، فإنه لم يعل الواو فيه كما أعل في (بعد)؛ لأنه على بناء فِعَل، ولا طريق للإعلال عليه، وليس كذلك فِعَل؛ لأن الكسرة توجب الإعلال في الواو، ولا سيما إذا انضم إليها الإعلال {37} في الفعل. ويمكن أن يحمل القِيَم على الشذوذ كما قُلبت الواو في (ثِيَرَة {39})، وكما قالوا: طويل وطيال. في لغة بني ضبة، وكما قالوا: جِياد في جمع جواد، وكان حكمه أن تصح عينُه في الجمع، فكما شذّت هذه الأشياء عما عليه الاستعمال كذلك شذ قولهم: قِيَما {40}.وقول من قال إن (القِيَم) ههنا جمع (قِيمَة) لا وجه له {41}.والدليل على أن قِيَما ههنا مصدر بمعنى القِيام وليس بجمع قوله: ﴿دِينًا قِيَمًا﴾ [الأنعام: 161]، ولا وجه لجمع القِيمة في وصف الدين به {42}، ونبين ذلك إذا انتهينا إليه إن شاء الله {43}.وذهب الكسائي إلى أن القيام ههنا اسم بمعنى القِوام، وهو ما يقوم به الشيء، وجعلهما لغتين بمعنى {44}.واختاره ابن قتيبة، وقال: يقال: هذا (قِوام {45}) أمرك وقيام أمرك: أي ما يقوم به أمرك {5}.ويقارب قول الزجاج هذا؛ فإنه قال: المعنى في هذه الآية: التي جعلها الله تقيمكم فتقومون بها قيامًا {47}.ومن قرأ (قِيَما) فهو راجع إلى هذا، والمعنى: جعلها الله قيمةً للأشياء، فيها (تقوم أموركم {48}) {49}. ولم يرتض أبو علي هذا القول في القيم كما ذكرنا.وقوله تعالى: ﴿وَارْزُقُوهُمْ فِيهَا وَاكْسُوهُمْ﴾. قال ابن عباس: يريد أنفقوا عليهم منها {50}.ومعنى الرزق من العباد هو الإجراء الموظف لوقت معلوم، يقال: رَزَق فلانٌ عيالَه كذا وكذا، أي: أجرى عليهم. وإنما قال: (فيها) ولم يقل: منها؛ لأنه أراد (جعلوا {51}) لهم فيها رزقًا، كأنه أوجب ذلك لهم {52}.وقوله تعالى: ﴿وَقُولُوا لَهُمْ قَوْلًا مَعْرُوفًا﴾ [النساء: 5]. قال ابن جريج ومجاهد: أي: عِدةً جميلةً من البر والصلة {53}.وقال ابن عباس: يِريد عدة حسنة، يقول: إذا رَبحتُ في سفري هذه فعلت {54} بك ما أنت أهله، وإن غنمتُ في غزاتي أعطيتُك {55}.قال ابن زيد: هو الدعاء. يقول: عافانا الله وإياك، بَارك الله فيك {56}.وكل ما سكنت إليه النفوس وأحبته من دول أو عمل فهو معروف، وما أنكرته وكرهته ونفرت منه فهو منكر {57}.وقال الزجاج: أي علموهم مع إطعامكم وكسوتكم إياهم أمر دينهم {58}."
  4,6,"قوله تعالى: ﴿وَابْتَلُوا الْيَتَامَى﴾ الآية. قال المفسرون: نزلت في ثابت بن رفاعة {1}، وفي عمه {2}، وذلك أن رفاعة توفي وترك ابنه ثابتًا وهو صغير، فأتى عم ثابت إلى النبي ﷺ فقال: إن ابن أخي يتيم في حجري، فما يحل لي من ماله، ومتى أدفع إليه ماله؟ فأنزل الله- عز وجل-: ﴿وَابْتَلُوا الْيَتَامَى﴾ {3}.قال الحسن، وقتادة، ومجاهد، والسدي، وابن زيد: اختبروهم في عقولهم وأديانهم {4}.ومعنى هذا الابتلاء وكيفيته -على ما ذكره الفقهاء-: أن يُردّ إليه الأمر في نفقته عند مراهقة الحلم، ويعطى شيئًا نزرًا يتصرف فيه، ليعرف كيف تدبيره وتصرفه. وإن كانت جاريةً يرد إليها ما يرد إلى النساء من أمر البيت وتدبير الغزل والقطن {5}.وقوله تعالى: ﴿حَتَّى إِذَا بَلَغُوا النِّكَاحَ﴾. قال ابن عباس ومجاهد والسدي وابن زيد: يريد الحلم {6}.وتقديره: حتى إذا بلغوا حال النكاح من الاحتلام.وقال آخرون: أي بلغوا مبلغ الرجال والنساء من القدرة على النكاح {7}. قال ابن قتيبة: أي بلغوا أن ينكحوا النساء {8}.ومعنى النكاح هو إنزال الماء، فإذا أنزل الغلام أو الجارية فقد بلغ، سواءٌ كان عن جماع أو احتلام.وقوله تعالى: ﴿فَإِنْ آنَسْتُمْ مِنْهُمْ رُشْدًا فَادْفَعُوا إِلَيْهِمْ أَمْوَالَهُمْ﴾. معنى (آنستم) قال ابن عباس: عرفتم {9}، وقال عطاء عنه: يريد رأيتم {10}.وقال الفراء: وجدتم {11}. وقال الزجاج: علمتم {12}.وأصل الإيناس في اللغة: الإبصار {13}، ومنه قوله: ﴿آنَسَ مِنْ جَانِبِ الطُّورِ نَارًا﴾ [القصص: 29]، وقال ابن حلزة {14}:آنَست نَبأَةً وأفَزَعها القَـ ... ـنَّاص عَصرًا وقد دَنا الإمساءُ {15}أي أحسَّت ووجدت.وقوله تعالى: ﴿رُشْدًا﴾ قال ابن عباس والسدي: هو الصلاح في العقل وحفظ المال {16}. وقال عطاء عنه: يريد صلاحًا ومعرفة وعقلًا {17}.وقال الزجاج. معنى الرشد: الطريقة المستقيمة التي تثقون {18} معها بأنهم يحفظون أموالهم {19}.وقال الشافعي -رضي الله عنه-: الرشد: من يكون صالحًا في دينه، مصلحًا لماله {20}. ولا يجوز دفع مال اليتيم إليه إلا بعد البلوغ وتبين العفاف وإصلاح المال منه {21}.وأبو حنيفة وأصحابه اعتبروا صلاح المال، ولم يعتبروا صلاح الدين {22}.وهذا الاختلاف يعود إلى الاختلاف في معنى الرشد، فمن جعل معنى الرشد حفظ المال وإصلاحه يزيل الحجر عن اليتيم بالبلوغ وحفظ المال، دون الصلاح في الدين، ومن جعل معنى الرشد صلاح الدين وحفظ المال اعتبرهما في زوال الحجر عن اليتيم، وهذا هو الأولى {23}؛ فإن أهل اللغة قالوا في معنى الرشد: إنه إصابة الخير {24}، والمفسد في دينه لا يكون مصيبًا للخير. وأيضًا فإن الرشد نقيض الغي، قال الله تعالى: ﴿قَدْ تَبَيَّنَ الرُّشْدُ مِنَ الْغَيِّ﴾ [البقرة: 256]، والغي: هو الجهالة والبطالة والفساد. قال طرفة:أرى قبرَ نَحَّامٍ بَخيلٍ بمالِه ... كقبر غويٍّ في البَطَالة مُفْسدِ {25}فجعل المفسد غويًا {26}، فدل هذا على أن المفسد في دينه لم يبلغ الرشد.وقوله تعالى: ﴿وَلَا تَأْكُلُوهَا إِسْرَافًا وَبِدَارًا أَنْ يَكْبَرُوا﴾.قال ابن عباس: يريد لا تبادروا في أموال اليتامى بالسرف قبل أن يبلغ الحلم والرشد {27}.وقال المفسرون: يريد {28}: لا تبادروا بأكل مالهم كبرهم ورشدهم حذرًا أن يبلغوا فيلزمكم تسليم المال إليهم {29}.و (أن) في محل النصب؛ لأنه مفعول المصدر، على تقدير: مبادرة كبرهم {30}. ثم بين ما يحل لهم فقال: ﴿وَمَنْ كَانَ غَنِيًّا فَلْيَسْتَعْفِفْ﴾. قال ابن عباس: يريد: من كان غنيًّا من الأوصياء فليستعفف عن مال اليتيم ولا يأكل منه شيئًا {31}.معنى: ﴿فَلْيَسْتَعْفِفْ﴾ أي: ليترك ذلك ولا يأكل. يقال: استعفف عن الشيء وعف إذا امتنع منه وتركه {32}.وقوله تعالى: ﴿وَمَنْ كَانَ فَقِيرًا فَلْيَأْكُلْ بِالْمَعْرُوفِ﴾. اختلفوا في الأكل بالمعروف: ما هو؟ فقال قوم: هو أن يأخذ بقدر ما يحتاج إليه من مال اليتيم قرضًا، ثم إذا أيسر قضاه، فإن مات ولم يقدر على القضاء فلا شيء عليه.وهذا قول سعيد بن جبير {33}، وعبيدة {34} {35}، ومجاهد {36}، وأبي العالية {37}، وأكثر الروايات عن ابن عباس {38}.والدليل على صحة هذا التأويل قوله تعالى: ﴿إِلَّا مَنْ أَمَرَ بِصَدَقَةٍ أَوْ مَعْرُوفٍ﴾ [النساء: 114]، قالوا: يعني القرض {39}. وما روي عن عمر -رضي الله عنه- أنه قال: (ألا) {40} إني أنزلت نفسي من مال الله عز وجل بمنزلتي من مال اليتيم، إن استغنيت استعففت، وإن افتقرت أكلت بالمعروف، فإذا أيسرتُ قضيت {41}.وقال بعضهم: معنى الأكل بالمعروف هو أن يقتصد ولا يسرف، ثم لا قضاء عليه فيما يأكل. فهذا قول عطاء {42}، وعكرمة {43}، والسدي {44}.وقال إبراهيم: هو ما سد الجوعة ووارى العورة {45}.وذهبت عائشة وجماعة من العلماء {46} إلى أن المعروف هو أن يأخذ من جميع المال إذا كان يلي ذلك بقدر قيامه وعمله وأجرته، وإن أتى على جميع المال، ولا قضاء عليه، وهذا طعمة من الله له {47}. ودليل صحة هذا ما روي عن ابن عباس، قال: جاء رجل إلى النبي ﷺ فقال: يا رسول الله إن في حجري يتيمًا أفاضربه؟ قال: ""مما كنت ضاربًا منه ولدك""، قال: يا رسول الله أفآكل من ماله؟ قال: ""غير متأثل مالًا، ولا واقٍ مالك بماله"" {48} وعلى هذا الحكم اليوم، فالقيم ممنوع من الإسراف، وإنما له أجر مثل عمله؛ لأنه أجير بالشرع. والغني يستعف كما أمره الله، وإن أخذ الأجرة حلت له في الحكم في مقابلة عمله {49}.وقوله تعالى: ﴿فَإِذَا دَفَعْتُمْ إِلَيْهِمْ أَمْوَالَهُمْ فَأَشْهِدُوا عَلَيْهِمْ﴾. هذا وصية من الله تعالى للأولياء بالإشهاد على دفع المال إذا دفعوه إلى الأيتام، لكن إن وقع اختلاف أمكن للولي أن يقيم البينة على أنه رد المال إليه {50}. وفي هذا دليل على أن القول قول اليتيم عند التنازع، وذلك أن القيّم خير {51} مؤتمن من جهة اليتيم، وإنما هو مؤتمن من جهة الشرع، ولذلك أمر بالإشهاد {52}، وليس بفريضة {53}.قوله تعالى: ﴿وَكَفَى بِاللَّهِ حَسِيبًا﴾ قال ابن الأنباري والأزهري: يكون بمعنى محاسبًا، ويكون بمعنى كافيًا {54}.فمن الأول قولهم للرجل عند التهدد: حسيبه الله. ومعناه: محاسبه الله على ما يفعل من الظلم {55}.وأنشد ابن الأنباري {56} قول قيس المجنون {57}:دعا المحرمون اللهَ يستغفرونه ... بمكةَ يومًا أن تُمَحَّا ذُنوبُهاوناديتُ يا ربّاه أولُ سؤلتي ... لنفسي لَيلَى ثم أنت حسيبُها {58}قال {59} فمعناه: ثم أنت محاسبها على ظلمها.قالوا: فالحسيب هو المحاسب بمنزلة قول العرب: الشريب. للمشارب {60}.وأنشد {61} أيضًا قول المخبل السعدي {62}:فلا تُدخِلنَّ الدهر قبرك حَوبَةً ... يقوُم بها يومًا عليك حسيبُ {63}معناه محاسبك عليه الله تعالى {64}.ومن الكفاية قولهم: حسيبك الله. ومعناه: كافي إياك الله {65}.وقد ذكرنا في اللغة في هذا {66} قوله: ﴿حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ﴾ [آل عمران: 173].وقال ابن عباس في قوله: ﴿وَكَفَى بِاللَّهِ حَسِيبًا﴾: يريد مجازيًا للحسن والمسيء {67}، وهذا يعود إلى المحاسب؛ لأن الحساب إنما هو للجزاء.والباء في قوله: ﴿وَكَفَى بِاللَّهِ﴾، ﴿وَكَفَى بِرَبِكَ﴾ [الإسراء:17 ،65] ، [الفرقان:31] في جميع القرآن {68} زائدة {69}.قال الزجاج: المعنى: كفى الله، كفى ربُك {70}. واستقصاء هذا مذكور في هذه السورة عند قوله: ﴿وَكَفَى بِاللَّهِ وَلِيًّا وَكَفَى بِاللَّهِ نَصِيرًا﴾ [النساء: 45] {71}.وحسيبًا منصوب على وجهين: أحدهما الحال. المعنى: وكفى بالله في حال الكفاية والحساب، الثاني: يكون منصوبًا على التمييز، على معنى: كفى الله من الكِفاء والمحاسبين {72}."
  4,7,"قوله تعالى: ﴿لِلرِّجَالِ نَصِيبٌ﴾ الآية. قال المفسرون: كانت العرب في الجاهلية لا تورث النساء ولا الصغار شيئًا وإن كانوا ذكورًا، وإنما كانت تورث الكبار ومن طاعن بالرماح وحاز الغنيمة، فأبطل الله عز وجل ذلك، وأعلم أن حق الميراث على ما ذُكر من القرض {1}.وقوله تعالى: ﴿نَصِيبًا مَفْرُوضًا﴾. قد ذكرنا معنى الفرض فيما تقدم {2}. واختلفوا في انتصاب قوله: ﴿نَصِيبًا﴾، فقال الفراء {3}: لأنه اسم في موضع المصدر، كقولك: قسمًا واجبًا وحقًّا لازمًا {4}.ولو كان اسمًا (ليس في معنى المصدر) {5} لم ينصب (نحو: لك عندي حق درهمًا) {6}، ومثله مما ينصب قولك: لك عندي درهمان هبة مقبوضة. فالمفروض في هذا الموضع بمنزلة قولك: فريضة وفرضاً {7}.وقال الزجاج: هذا منصوب على الحال، المعنى: لهؤلاء أنصبة على ما ذكرناها في حال الفرض {8}.وقال الأخفش: هو نصب على معنى: جعل لهم نصيبًا {9}. والآية تدل على [هذا؛ لأن قوله: ﴿لِلرِّجَالِ نَصِيبٌ﴾ ﴿وَلِلنِّسَاءِ نَصِيبٌ﴾ يدل على {10}] معنى جعل لهم نصيبًا {11}"
  4,8,"قوله تعالى: ﴿وَإِذَا حَضَرَ الْقِسْمَةَ﴾ عنى قسمة المال بين الورثة، يقال: قسمت المال قسمًا و [قسَّمته] تقسيمًا، والقسم اسم للمقسوم، والقسيم الذي يقاسمك (...) {1} المقسوم أيضًا، يقال: أخذ قسمه وقسيمه ومقسمه {2}. وهذا قد ذكره ثعلب عن ابن الأعرابي، وهو صحيح.قال الخليل: (القِسْم {3}) الحظّ والنصيب من الخير {4}، ومنه سمي الرجل: مقسما. وأنشد النضر:فما لك إلا مِقسمٌ ليس فائتًا ... به أحدٌ فاستَأْخِرَن أو تَقَدَّمَ {5}ويقال: قاسمت فلانًا المال مقاسمةً، وأقسمنا، وتقاسمنا المال فيما بيننا {6}.قال النابغة {7}:إنّا اقتَسَمْنا خُطَّتَينا بيَننا ... فحَمَلتُ بَرَّةَ واحتملتَ فَجَارِ {8}و (القسمة) {9} الاسم من الاقتسام، لا من القسم {10}، كالخبرة من الاختبار.ولا يكاد الفصحاء يقولون: قَسمت بينهم قِسمة. وقد ذكر ذلك في كتاب الليث {11}، وليس ذلك بصحيح. وقسْمَتك ما أخذته من الأقسام، والجمع قِسَم.وقوله تعالى: ﴿أُولُو الْقُرْبَى﴾ {12} يعني: الذين يحزنون ولا يرثون {13}.﴿وَالْيَتَامَى وَالْمَسَاكِينُ﴾ الآية. اختلفوا في حكمها، فقال ابن عباس في رواية عطاء وعطية {7}: هذه الآية منسوخة بآية المواريث، وإباحة الثلث للميت يجعله حيث يشاء من القرابات واليتامى والمساكين {15}.وهذا مذهب سعيد بن المسيب {7}، وأبي مالك، والضحاك {17}.وقال في رواية عكرمة ومِقْسَم {18}: الآية محكمة غير منسوخة {19}.وهذا مذهب أبي موسى، وإبراهيم، والشعبي، والزهري، ومجاهد، والحسن، وسعيد بن جبير، وعبيدة، وقتادة {20}.ثم اختلف هؤلاء، فذهب بعضهم إلى أنه يجب على الوارث أن يرضخ لمن حضر القسمة شيئًا من المال بقدر ما تطيب به نفسه.هذا إذا كان الوارث كبيرًا، فإن كان صغيرًا تولى إعطاء هؤلاء وليه {21}.قال الحسن والنخعي: أدركنا الناس وهم يقسمون على القرابات {22}، والمساكين، واليتامى من العين، فإذا قُسِم الذهب والورق وصارت القسمة إلى الأرضين والرقيق وما أشبه ذلك قالوا لهم قولًا معروفًا، كانوا يقولون: بُورك فيهم {23}.وقال ابن عباس والسدي وغيرهما: إذا حضر القسمة هؤلاء؛ فإنْ كان الميت أوصى لهم بشيء أُنفِذ، وإن لم يوص {24} وكان الورثة كِبارًا رَضَخُوا لهم، وإن كانوا صغارًا اعتذر إليهم الولي، ويقول: إني لا أملك هذا المال، وإنما هو لهؤلاء الضعفاء الذين لا يعقلون ما عليهم من الحق، وإن يكبروا فسيعرفون حقكم. فهذا هو القول المعروف {25}.وقال بعضهم: هذا على الندب والاستحباب، لا على الفرض والإيجاب؛ يستحب للوارث أن يقسم لهؤلاء شيئًا من التركة، فإن ترك ذلك لم يُحَرَّج {26}.وهذا هو الذي عليه الناس اليوم {27}.وقوله تعالى: ﴿فَارْزُقُوهُمْ مِنْهُ﴾ أي: من الميراث، رَدّ الكناية إلى معنى القسمة لا إلى اللفظ، كقوله: ﴿ثُمَّ اسْتَخْرَجَهَا مِنْ وِعَاءِ أَخِيهِ﴾ [يوسف: 76]، والصُّواع مذكر لا يُكنى عنه بالتأنيث، لكن أريد به المَشْربة والسِّقاية، فعادت الكناية إلى المعنى لا إلى اللفظ {28}.وقال أبو علي: القسمة ههنا يراد بها المقسوم؛ لأنه إنما يُرزق من التركة المقسومة {29}."
  4,9,"قوله تعالى: ﴿وَلْيَخْشَ الَّذِينَ لَوْ تَرَكُوا مِنْ خَلْفِهِمْ﴾ الآية. اختلفوا في هذه الآية على قولين:أحدهما: أن معنى الآية: وليخش من لو كان له ولد صغار خاف عليهم بعده الضيعة، أن يأمر الموصي بالإسراف فيما يعطيه اليتامى المساكين وأقاربه الذين لا يورثون، فيكون قد أمره بما لم يكن يفعله لو كان هو الميت.قال ابن عباس في رواية عطاء: كان الرجل إذا حضرته الوفاة قعد عنده أصحاب رسول الله ﷺ فقالوا: انظر لنفسك فإنّ ولدك لا يُغنون عنك من الله شيئًا، فيُقدِّم جل ماله وَيحجب ولده، وهذا قبل أن تكون الوصية في الثلث، فكره الله ذلك منهم وقال: ﴿وَلْيَخْشَ الَّذِينَ لَوْ تَرَكُوا مِنْ خَلْفِهِمْ﴾ يريد: من بعدهم. ﴿ذُرِّيَّةً ضِعَافًا﴾ يريد: صغارًا. ﴿خَافُوا عَلَيْهِمْ﴾ الفقر، ﴿فَلْيَتَّقُوا اللَّهَ﴾ يريد: فليخافوا الله إذا تَعدَّوا عند أحد من إخوانهم وهو في الموت. ﴿وَلْيَقُولُوا قَوْلًا سَدِيدًا﴾ يريد بالسديد من القول العدل، وهو أن يأمره أن يُخَلِّف ماله لولده ويتصدق ما دون الثلث {1}.وهذا قول أكثر المفسرين، سعيد بن جبير والحسن وقتادة والسدي والضحاك ومجاهد {2}.والقول الثاني: أن هذا وعظ لولاة اليتامى، وعظوا في تَوِليَتِهم أمرهم بأن يفعلوا كما يحبون أن يُفعل بأولادهم من بعدهم. يقول: وليخش من لو ترك ولدًا صغارًا خاف عليهم الضَّيعة، فليُحسن إلى من كفله من اليتامى، وليفعل بهم ما يحب أن يفعل بولده من بعده.وهذا قول تحتمله الآية، ولم أر أحدًا من المفسرين ذكره {3}، وبعض المتأخرين حكاه، وعزاه إلى الكلبي {4}. وليس هو في تفسيره المعروف بطريق يوسف بن بلال {5}.وقرأ {6} حمزة: ﴿ضِعَافًا خَافُوا﴾ بالإمالة فيهما {7}. ووجه إمالة (ضعاف) أنّ ما كان على وزن فِعال، وكان أوله حرفًا مستعليًا مكسورًا، نحو: صِفات {8}، وقِفاف {9}، وخِباث وغِلاب، يحسن فيه الإمالة، وذلك أنه تصعّد بالحرف المستعلي ثم انحدر بالكسر، فيستحب أن لا يتصعّد بالتفخيم بعد التصوّب {10} بالكسر، فيجعل الصوت {11} على طريقة واحدة فلا يتصعّد بالتفخيم بعد التصوّب بالكسرة {12} التي في خفت فينحوا نحوها بالإمالة.قال سيبويه: بلغنا عن ابن أبي إسحاق {13} أنه سمع كثير عزة يقول: صار مكان كذا {14}، بالإمالة {15}.وقوله تعالى: ﴿وَلْيَقُولُوا قَوْلًا سَدِيدًا﴾ السديد: العدل والصواب من القول {16}. قال ابن المظّفر {17}: قال قل قولا سَدَدًا وسدَادًا وسدِيدًا {18} والسدَد مقصور من السداد {19}، وأنشد {20} لكعب {21}:ماذا عليها وماذا كان ينقصها ... يوم الترّحل لو قالت لنا سدَدَا {22}قال الأزهري: وقرأت بخط شَمِر: يقال سدّ عليك الرجل يسدّ سدًّا إذا أتى السداد. وما كان هذا الشيء سديدًا. ولقد سد يسد سدادًا وسدودا. وقال أوس:فما جَبُنوا أنّا نَسُدّ عليهِمُ ... ولكِن لَقُوا نارًا تحُسُّ وتَسْفَعُ {23} يقول لم يجبنوا من الإنصاف في القتال، ولكنا جُرنا عليهم فلقونا ونحن كالنار التي لا تُبقي شيئًا {24}.ويقال: إنه لَيَسد في القول، إذا كان يأتي القول السديد، وقد أسددت ما شئت، أي: طلبت السداد، أصبته أو لم تصبه. ويقال: سدده الله، أي: وفقه للسداد {25}."
  4,10,"قوله تعالى: ﴿إِنَّ الَّذِينَ يَأْكُلُونَ أَمْوَالَ الْيَتَامَى ظُلْمًا إِنَّمَا يَأْكُلُونَ فِي بُطُونِهِمْ نَارًا﴾.سماه بما يؤول إليه في العاقبة، والعرب تُسمي الشيء باسم ما يؤول إليه عاقبته، كقوله: ﴿أَرَانِي أَعْصِرُ خَمْرًا﴾ [يوسف: 36]، يعني: العنب، فسماه خمرًا بما يؤول إليه {1}. ويقولون للأمر الشديد: هو الموت، ومنه قول ابن الدُّمَينة الخثعمي {2}:قليل قذى العينين نعلُم أنّه ... هو الموتُ إن لَم يلق عَنّا بوائقه {3} أي: السبب المؤديِ إلى الموت، وعلى هذا قوله ﷺ في الشارب من آنية الذهب والفضة: ""إنما يُجرجِر في بطنه نار جهنم"" {4}.قال السدي: يبعث آكل مال اليتيم ظُلمًا يوم القيامة ولَهَبُ النار ودُخانه يخرج من فيه وأذنيه وأنفه وعينيه، يعرفه من رآه بأكل مال اليتيم {5}.وقوله تعالى: ﴿وَسَيَصْلَوْنَ سَعِيرًا﴾ وقرئ بضم الياء {6}.قال أبو زيد: يقال: صلي الرجل النارَ يصلاها صليً وصَلاءً، وهو صالي النار من قوم صالين وصِليّ {7}. قال الله تعالى: ﴿إِلَّا مَنْ هُوَ صَالِ الْجَحِيمِ﴾ [الصافات: 163]. قال الشاعر:والله لولا النار أن يصلاها {8} وقال تعالى: ﴿جَهَنَّمَ يَصْلَوْنَهَا﴾ [إبراهيم: 29، 56]، [المجادلة: 8].قال الفراء: الصَّلاء اسم للوقود، وهو الصَّلا، إذا كسرت مددت، وإذا فتحت قصرت {9}. قال ابن حلزة:فتنورت نارها {10} من بعيدٍ ... بخَزازَى هيهات منك الصَّلاء {11}ومن ضم {12} الياء فهو من قولهم: أصلاه الله حر النار إصلاءً، قال الله تعالى: ﴿فَسَوْفَ نُصْلِيهِ نَارًا﴾ [النساء: 56]، وقال تعالى: ﴿سَأُصْلِيهِ سَقَرَ﴾ [المدثر: 26].وأما السّعير فهو النار المُستعرة. يقال (سعرت {13}) النار أسعَرُها سَعرًا، وهي مسعورة وسعيرة، فالسعير معدول عن: مسعورة كما عُدِل: كف خضيب. عن: مخضوبة، وكذلك سعرت العرب سعرًا. واستعرت النار إذا استوقدت.والسعير: النار نفسها. (وسُعار النار) {14} حرّها {15}."
  4,11,"قوله تعالى: ﴿يُوصِيكُمُ اللَّهُ فِي أَوْلَادِكُمْ﴾ الآية. فقد ذكرنا معنى الإيصاء والتوصية في اللغة. ومعنى ﴿يُوصِيكُمُ﴾ ههنا: قال الزجاج: أي: يفرض {1} عليكم؛ لأن الوصية من الله عز وجل فرض، والدليل على ذلك: ﴿وَلَا تَقْتُلُوا النَّفْسَ الَّتِي حَرَّمَ اللَّهُ إِلَّا بِالْحَقِّ ذَلِكُمْ وَصَّاكُمْ بِهِ﴾ [الأنعام: 151]، وهذا من الفرض المحكم علينا {2}.وقوله تعالى: ﴿فِي أَوْلَادِكُمْ﴾، اسم الولد يقع على ولد الصلب وعلى ولد الولد وإن سَفَل {3}، ثم ثبتت على هذا ميراث ولد الولد بهذه الآية {4}.فإن قيل: بماذا يتعلق قوله: ﴿يُوصِيكُمُ﴾، ولا يقال في الكلام: أوصيك لزيد كذا؟ والجواب ما قال الفراء، وهو أن الوصية قول، فمعنى قوله ﴿يُوصِيكُمُ اللَّهُ﴾ {5}: يقول الله لكم، وعلى هذا أيضًا: ﴿وَعَدَ اللَّهُ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ لَهُمْ مَغْفِرَةٌ﴾ [المائدة: 9]، أي: قال الله لهم مغفرة؛ لأن الوعد قول {6}.﴿لِلذَّكَرِ مِثْلُ حَظِّ الْأُنْثَيَيْنِ﴾، وقال الكسائي: قوله: ﴿لِلذَّكَرِ مِثْلُ حَظِّ الْأُنْثَيَيْنِ﴾ بيان لما أوصى به وحكاية له، لأن الذي أوصاهم به هو هذا، ومثله قوله: ﴿وَعَدَ اللَّهُ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ﴾ [المائدة: 9] ثم ذكر ما وعدهم فقال: ﴿لَهُمْ مَغْفِرَةٌ وَأَجْرٌ عَظِيمٌ﴾ ولهم مغفرة هو الذي وعدهم به، وكذلك قوله: ﴿ثُمَّ بَدَا لَهُمْ مِنْ بَعْدِ مَا رَأَوُا الْآيَاتِ لَيَسْجُنُنَّهُ﴾ [يوسف: 35].ويقول: بدا لي أن لعبد الله مالًا، فإذا (ألقيت) {7} أن قلت: بدا لي لعبد الله مالٌ {8}، وأنشد الكسائي على ذلك:إني سأُبدِي لك فيما أُبدي ... لي شجَنَانِ شَجَنٌ بِنَجْدِ {9}وقوله تعالى: ﴿فَإِنْ كُنَّ نِسَاءً﴾، يعني: فإن كن {10} المتروكات؛ وذلك أن اسم الولد يطلق على الإناث والذكور {11}، فلما فرض فريضة الذكور وأراد تبيين حال الإناث كنى عنهن بكناية جمع أسمائهن في الأولاد، وتقديره: الأولاد إن كن نساء فوت اثنتين فلهن ثلثا ما ترك {12}.واجتمعت الأمة على أن للبنتين الثلثين {13}، إلا ما روي عن ابن عباس أنه ذهب إلى ظاهر الآية، وقال: الثلثان فرض الثلاث من البنات؛ لأن الله تعالى قال: ﴿فَإِنْ كُنَّ نِسَاءً فَوْقَ اثْنَتَيْنِ﴾ {14}: فجعل الثلثين للنساء إذا زده {15} على الثلثين {16}، وعنده أن فرض البنتين النصف كفرض الواحدةوهذا غير مأخوذ به {17}.ووجه الآية أن (فوق) ههنا صلة لا معنى له، أراد: فإن كن نساء اثنتين، كقوله: ﴿فَاضْرِبُوا فَوْقَ الْأَعْنَاقِ﴾ [الأنفال: 12]، يريد: فاضربوا الأعناق {18} وسمى البنتين نساء، لأن الابنين جماعة عند العرب. ونبين ذلك في آخر الآية {19}.وقال أكثر المفسرين: إنما أعطينا البنتين الثلثين بتأويل القرآن لا بنص فرض، وذلك أن الله تعالى [جعل للبنت الواحدة النصف في قوله: ﴿وَإِنْ كَانَتْ وَاحِدَةً فَلَهَا النِّصْفُ﴾، وجعل للأخت الواحدة النصف أيضًا في قوله: ﴿إِنِ امْرُؤٌ هَلَكَ لَيْسَ لَهُ وَلَدٌ وَلَهُ أُخْتٌ فَلَهَا نِصْفُ مَا تَرَكَ﴾ [النساء: 176]، ثم جعل للأختين الثلثين، علمنا أن للبنتين] {20} الثلثين قياسًا على الأختين، كما أن للأخوات الثلثين بما نص في البنات في قوله: ﴿فَإِنْ كُنَّ نِسَاءً﴾ الآية {21}وحرر الحسن بن يحيى {22} هذا الفصل فقال: (إن الله تعالى) {23} أمسك في هذه الآية عن ذكر البنتين، وذكر الواحدة والثلاث وما فوقها، وذكر فيِ (قوله (¬3)): ﴿يَسْتَفْتُونَكَ﴾ في آخر النساء الأخت الواحدة والبنتين {24} ، وأمسك عن ذكر الثلاث وما فوقها، فتضمن كل واحدة من هاتين الآيتين ما كف عن ذكره في غيرها، ويحتمل كل واحد منهما فيما أمسك عنه فيها على ما ذكره في غيرها ليأتلف المعنى على (ما يجب {25}) إن شاء الله {26}.قال أبو إسحاق: جعل الله عز وجل كتابه يدل بعضه على بعض تفقيهًا للمسلمين وتعليمًا؛ ليعملوا فيما يحزبهم {27} في الأمور على هذه الأدلة، وقال بعضهم {28}: في الآية دليل على أن للبنتين الثلثين؛ لأنه قال: ﴿لِلذَّكَرِ مِثْلُ حَظِّ الْأُنْثَيَيْنِ﴾، وكان أول العدد ذكرًا وأنثى، فللذكر الثلثان وللأنثى الثلث. فلما دل هذا على أن للذكر الثلثين وللبنت الواحدة الثلث، عُلم أن للبنتين الثلثين من حيث علم أن للذكر الثلثين.وأما مذهب ابن عباس فهو محال في القياس، حيث يجعل البنتين كالواحدة. والبنتان كالجماعة؛ لأن منزلة الاثنين منزلة الجمع {29}، في كثير من الأحكام، فصلاة الاثنين جماعة، والأخوان كالإخوة في حجب الأم من الثلث إلى السدس، ويجيء ذلك في آخر الآية، فالجمع بالجمع أولى أن يقاس من الجمع بالواحد {30}. وأيضًا فإن الآية في قول مقاتل، والكلبي نازلة في أم كجّة {31}، وكانت لها ثلاث بنات، فنزلت في جواب ما استفتت وأجيبت في بناتها خصوصًا، وكن ثلاثًا {32}، ولذلك ما خصت الثلاث بالذكر في الآية دون الثنتين.وقوله تعالى: ﴿وَإِنْ كَانَتْ وَاحِدَةً﴾ وقرأ نافع (واحدةٌ) بالرفع {33} على معنى: إن وقعت واحدة، أي: إن حدث حكم واحدة، أو إرث واحدة؛ لأن {34} المراد حكمها والقضاء في إرثها، لا ذاتها.والاختيار قراءة العامة؛ لأن التي قبلها لها خبر منصوب، وهو قوله: ﴿فَإِنْ كُنَّ نِسَاءً﴾، وكما أن الضمير هناك: إن كن المتروكات أو الوارثات نساء، كذلك ههنا: وإن كانت المتروكة واحدة {35}.وقوله تعالى: ﴿وَلِأَبَوَيْهِ﴾ يعني: ولأبوي الميت، كناية عن غير مذكور {36}، وهما والداه. والأصل أن يقال: أبة {37}، ولكن استغنى عنها بأم، فأبوان تثنية أب وأبة، وكذلك لو ثنيت ابنًا وابنًة ولم تخف اللبس لقلت: ابنان {38}.وقوله تعالى: ﴿لِكُلِّ وَاحِدٍ مِنْهُمَا السُّدُسُ مِمَّا تَرَكَ إِنْ كَانَ لَهُ وَلَدٌ﴾. أو ولد ابن، واسم الولد يقع على ولد الابن {39}.والأب يرث من جهة التسمية السدس، ويرث بغير تسمية على جهة التعصيب.مثال ذلك: لو مات عن ابنة وأبوين، كان للابنة النصف وللأم السدس، وكذلك للأب بالتسمية لأن الله تعالى قال: ﴿لِكُلِّ وَاحِدٍ مِنْهُمَا السُّدُسُ مِمَّا تَرَكَ إِنْ كَانَ لَهُ وَلَدٌ﴾، وههنا ولد وهو البنت، والسدس الباقي للأب أيضًا بحق التعصيب {40}.وقوله تعالى: ﴿فَإِنْ لَمْ يَكُنْ لَهُ وَلَدٌ وَوَرِثَهُ أَبَوَاهُ فَلِأُمِّهِ الثُّلُثُ﴾.أكثر القراء على ضم الهمزة من (أم) في جميع المواضع. وقرأ حمزة والكسائي بكسر الألف إذا وليتها كسرة أو ياء {41}، (نحو هذا) {42} ونحو قوله: ﴿يَطُوفُونَ﴾ {43}، ﴿أَوْ بُيُوتِ أُمَّهَاتِكُمْ﴾ [النور: 61]، ﴿فِي أُمِّهَا رَسُولًا﴾ [القصص: 59].فأما إذا كان ما قبل الهمزة غير كسر فالضم لا غير، مثل ﴿وَجَعَلْنَا ابْنَ مَرْيَمَ وَأُمَّهُ﴾ [المؤمنون: 50] {44}.وإنما جاز كسر همزة (أم) لأن الهمزة حرف مستثقل، بدلالة تخفيفهم لها، فأتبعوها ما قبلها من الياء والكسرة، ليكون العمل فيها من وجه واحد {45}.قال أبو إسحاق: إنهم استثقلوا الضمة بعد الكسرة في قوله: ﴿فَلِأُمِّهِ﴾، وليس في كلام العرب مثل: فِعُل بكسر الفاء وضم العين، فلما اختلطت اللام [بالاسم] {46} شبه بالكلمة الواحدة، فأبدل من الضمة كسرة {47}.وأيضًا فإن الهمزة لما يتعاورها من القلب والتخفيف تشبه الياء والواو، فتتغير كما تتغير الياء والواو، وتقارب الهاء في المخرج، والهاء قد اتبع الكسرة في نحو: بهم، وبهي {48}. كذلك الهمزة.فإن قيل: وهلا فعلوا ذلك بغير هذا الحرف، مما فيه الهمزة، نحو: أتّ وأسّ وأدّ من أسماء الرجال؟قيل: إن هذا الحرف قد كثر في كلامهم، والتغيير إلى ما كثر أسرع، وقد يختص الشيء في الموضع بما لا يكون في أمثاله، كقولهم: أسطاع وأهراق، ولم يفعل ذلك بما أشبهه، كذلك هذا التغيير في الهمزة مع الكسرة والياء اختص به هذا الحرف، ولم يكن فيما أشبهه {49}.و (أما) {50} من ضم الهمزة فإنه أتى بها على الأصل، ألا ترى أن الهمزة في: أد وأف وبابه مضمومة على جميع أحوالها، ولا يؤدي إلى استعمال فِعُل، لأن اللام ليست من أصل الكلمة، واللام {51} من (فلأمه) قديرها تقدير الانفصال {52}.وقوله تعالى: ﴿فَإِنْ كَانَ لَهُ إِخْوَةٌ فَلِأُمِّهِ السُّدُسُ﴾. أجمعت الأمة على أن الأخوين يحجبان الأم من الثلث إلى السدس كرجل مات عن أبوين وأخوين، كان للأم السدس، والباقي للأب. فالأخوان فما فوقهما يحجبان الأم عن الثلث إلى السدس. والأخ الواحد لا يحجب.وابن عباس يخالف في هذه المسألة: فلا تحجب الأم عن الثلث إلى السدس بأقل من ثلاثة إخوة. وقال لعثمان {53} -رضي الله عنه-: بم {54} صار الأخوان يردان الأم إلى السدس، وإنما قال الله عز وجل: ﴿فَإِنْ كَانَ لَهُ إِخْوَةٌ﴾ والأخوان في لسان قومك ليسا بإخوة؟ فقال عثمان: يا بني إن قومك حجبوها بأخوين، ولا أستطيع نقض أمر قد كان قبلي {55}. مقابلة بالإجماع.قال علماء اللغة: قول ابن عباس: الأخوان في لسان قومك ليسا بإخوة غلط منه؛ لأن الأخوين جماعة كالإخوة، وذلك أنك إذا جمعت واحدًا إلى واحد فهما جماعة ويقال لهما إخوة {56}.وحكى سيبويه أن العرب تقول: قد وضعا رحالهما. يريدون: رحلي راحلتيها {57}.قال ابن الأنباري: التثنية عند العرب أول الجمع، ومشهور في كلامهم إيقاع الجمع على التثنية، من ذلك قوله تعالى: ﴿وَكُنَّا لِحُكْمِهِمْ شَاهِدِينَ﴾ [الأنبياء: 78]، وهو يريد داود وسليمان، ومنه قوله: ﴿فَقَدْ صَغَتْ قُلُوبُكُمَا﴾ [التحريم: 4] يريد قلبيكما {58}. والعرب تقول: لطمت أوجه الرجلين، وضربت أرؤسهما، وشققت بطونهما، فيجمعون في موضع التثنية {59}.قال قتادة: وإنما حجب الإخوة الأم من غير أن يرثوا مع الأب (لمعونة الأب) {60}؛ لأنه يقوم بشأنهم وينفق عليهم دون الأم {61}.وقوله تعالى: ﴿مِنْ بَعْدِ وَصِيَّةٍ يُوصِي بِهَا أَوْ دَيْنٍ﴾، أي: هذه الأنصبة إنما تقسم بعد قضاء الدين وإنفاذ وصية الميت في ثلثه، وذكر الوصية مقدمةً على الدين، وذلك تقديم في اللفظ لا في الحكم؛ لأن (أو) لا توجب ترتيبًا، وإنما هي لأحد الشيئين؛ كأنه قيل: من بعد أحد هذين {62} مفردًا أو مضمومًا إلى الآخر {63}.قوله تعالى: ﴿يُوصِي بِهَا﴾ قرئ بكسر الصاد وفتحها {64}.فمن كسر {65} فلأنه تقدم ذكر الميت المفروض فيما ترك، يبين ذلك قوله: ﴿فَإِنْ كَانَ لَهُ إِخْوَةٌ فَلِأُمِّهِ السُّدُسُ﴾ أي: لأم الميت ﴿مِنْ بَعْدِ وَصِيَّةٍ﴾ يوصيها الميت. ومن فتح الصاد فإنه يؤول في المعنى إلى يوصي، ألا ترى أن الموصي هو الميت، والذي {66} حسن فتح الصاد أنه ليس لميت {67} إنما هو شائع في الجميع، فلذلك حسن يوصى {68} {69}.وقوله تعالى: ﴿أَوْ دَيْنٍ﴾ إن قيل: ما معنى (أو) هاهنا، وهلا كان من بعد وصية يوصي بها (ودين) {70}؟. والجواب: ما قاله الزجاج، وهو أن معناه الإباحة، كما لو قال قائل: جالس الحسنَ أو الشعبي، المعنى: أن كل واحد منهما {71} أهل أن يجالس، فإن جالست الحسن فأنت مصيب، (أو الشعبي فأنت مصيب، وإن جمعتهما فأنت مصيب) {72}، ولو قال: جالس الرجلين، فجالست واحدًا منهما وتركت الآخر كنت غير متبع ما أمرت به. كذلك في الآية لو كان: ﴿مِنْ بَعْدِ وَصِيَّةٍ يُوصِي بِهَا (و) دَيْنٍ﴾ احتمل اللفظ أن يكون هذا (الحكم المذكور في الآية) (¬6) إذا اجتمعت الوصية والدين، فإذا انفرد كان حكم آخر، فإذا كانت ""أو"" دلت على أن أحدهما إن كان فالميراث بعده، وكذلك إن كانا كلاهما {73}.وقوله تعالى: ﴿آبَاؤُكُمْ وَأَبْنَاؤُكُمْ لَا تَدْرُونَ أَيُّهُمْ أَقْرَبُ لَكُمْ نَفْعًا﴾. في هذا قولان: أحدهما: أن هذا فصل معترض بين ذكر الورّاث وأنصبائهم، وبين قوله: ﴿فَرِيضَةً مِنَ اللَّهِ﴾، ولا تعلق لمعناه بمعنى الآية، ومعنى هذا الفصل في قول ابن عباس والكلبي: أن الله تعالى يُشَفِّع المؤمنين بعضهم في بعض، فأطوعكم لله عز وجل من الآباء والأبناء أرفعكم درجة {74}. فإن كان الوالد أرفع درجة في الجنة من ولده رفع الله إليه ولده بمسألته {75}، ليقرّ بذلك عينه، وإن كان الولد أرفع درجة من والديه، رفع الله إليه والديه، فقال الله عز وجل: ﴿لَا تَدْرُونَ أَيُّهُمْ أَقْرَبُ لَكُمْ نَفْعًا﴾، لأن أحدهما لا يعرف منفعة صاحبه له في الجنة، وسبقه إلى منزلة عالية تكون سببًا لرفعه إليها {76}.القول الثاني: أن هذا فصل معترض بينهما، ومعناه متعلق بمعنى الآية.يقول: لا تدرون أيهم أقرب لكم نفعًا في الدنيا فتعطونه من الميراث ما يستحق، ولكن الله تعالى قد فرض الفرائض على ما هو عنده حكمة، ولو وكل إليكم لم تعلموا أيهم أنفع لكم، فأفسدتم وضيعتم وأعطيتم من لا يستحق ومنعتم من يجب له الميراث، وهذا قول الزجاج {77}، وابن الأنباري، وجماعة من أهل المعاني {78}، وإليه أشار ابن عباس في رواية عطاء {79}.وقوله تعالى: ﴿فَرِيضَةً مِنَ اللَّهِ﴾ منصوب على التوكيد من قوله: ﴿وَلِأَبَوَيْهِ﴾، أي لهؤلاء الورثة ما ذكرنا مفروضًا، (ففريضة) {80} مؤكدة لقوله: ﴿يُوصِيكُمُ اللَّهُ﴾ {81}.وقوله تعالى: ﴿إِنَّ اللَّهَ كَانَ عَلِيمًا حَكِيمًا﴾. قال الحسن: كان عليمًا بالأشياء قبل خلقها، حكيمًا فيما يقدر {82}.وقال عطاء: كان عليمًا بخلقه قبل أن يخلقهم، حكيمًا حيث فرض للصغار مع الكبار، ولم يخصّ الكبار بالميراث كما كانت العرب تفعل {83}.وحكى الزجاج عن سيبويه، قال: كأن القوم شاهدوا علمًا وحكمة ومغفرة وتفضلًا، فقيل لهم: إن الله كان كذلك، أي: لم يزل على ما شاهدتم {84}.وقال الخليل: الخبر عن الله عز وجل بمثل هذه الأشياء، كالخبر بالاستقبال والحال؛ لأن صفات الله تعالى لا يجوز عليها الزوال والتقلب {85}.وقوله تعالى: ﴿وَإِنْ كَانَ رَجُلٌ يُورَثُ كَلَالَةً﴾. قد أكثروا في الكلالة، والذي عليه الأكثرون وهو الصواب أن الكلالة ما عدا الوالد والولد {86}.وهو قول أبي بكر، وعمر، وابن عباس، وابن زيد، وقتادة، والزهري، وابن إسحاق {87}.وأخبرني موسى بن الفضل {88}، حدثنا الأصم {89}، عن محمد بن الجهم {90}، عن الفراء، قال: الكلالة ما خلا الولد والوالد {91}.وأقرأني العروضي، عن الأزهري، قال: أخبرني المنذري {92}، عن الحسين ابن فهم {93}، عن سلمة، عن أبي عبيدة، أنه قال: الكلالة كل من لم يرثه (ولد أو أب) {94}. ونحو ذلك قال الأخفش {95}.قال المنذري: وسمعت أبا العباس {96} يقول: الكلالة من القرابة ما خلا الوالد والولد. سموا كلالة لاستدارتهم بنسب الميت من تكلله النسب أي أحاط به واشتمل عليه {97}. فهم بمنزلة العصبة، كالإخوة والأخوات والأعمام وأبنائهم.قال: وسمعته {98} مرة يقول: الكلالة من سقط عنه طرفاه، وهما أبواه (وولداه {99})، فصار كلا وكلالة، أي: عيالًا على الأصل. يقول: سقط (من {100}) الطرفين فصار عيالًا عليهم {101}. وقيل: لأن من لا يكون والدًا ولا ولدًا كلّت قرابته عن أن تكون قرابة ماسة. يقال: هو أكَلُّ من هذا، أي: أبعد نسبًا {102}.وحديث جابر يفسر الكلالة، وأنه الوارث (غير الوالد والولد)؛ لأنه يقول: مرضت مرضًا أشفيت منه على الموت، فأتيت النبي ﷺ، فقلت: إني رجل ليس يرثني إلا كلالة {103}.أراد أنه لا والد له ولا ولد، فكل من مات ولا ولد له ولا والد فهو كلالة ورثته، وكل وارث ليس بوالد للميت ولا ولد له فهو كلالة موروثه {104}.فالكلالة اسم يقع على الوارث والموروث إذا كانا بالصفة التي ذكرنا {105}.ويقال: رجل كلالة وامرأة كلالة وقوم كلالة، لا يثنى ولا يجمع؛ لأنه مصدر كالدلالة والوكالة، يقال: كل الرجل يكل كلالة، أي صار كلًّا، وهو الذي لا ولد له ولا والد. ذكره الليث {106}، وهو صحيح.والدليل على أن الوارث يُسمى كلالة حديث جابر أنه قال: ليس يرثني إلا كلالة، والدليل على أن الموروث الميت يُسمى كلالة قول الفرزدق:وَرِثتُم قَناةَ المُلك لا عن كَلالةٍ ... (عن ابنَي منافٍ: عبدِ شمسٍ وهاشم) {107} {108}وقول الشاعر:يهز سلاحًا لم يرِثه كلالةً ... يَشُكُّ بِه منهَا جلودَ المَغَابنِ {109}يصف ثورًا وقرنه وأنه ورثه من أبيه، وجعل القرن له كالرمح من الأسلحة، وأنه يشق به مغابن الكلاب. فالكلالة في هذا البيت يحتمل أنه الوارث، ويحتمل أنه الموروث.قال الأزهري: ودل قول الشاعر {110} أن الأب ليس بكلالة، وأن سائر الأولياء من العصبة بعد الولد كلالة، وهو قوله:فإنَّ أبا المرءِ أحمَى له ... وَمولى الكَلالةِ لا يَغْضَبُ {111}أراد أن أبا المرء أغضب له إذا ظُلم، وموالي الكلالة وهم الإخوة والأعمام وبنو الأعمام وسائر القرابات لا يغضبون للمرء غضب الأب {112}.وقوله تعالى: ﴿وَإِنْ كَانَ رَجُلٌ يُورَثُ كَلَالَةً﴾ الكلالة في هذه الآية الميت، وهو الموروث، والمراد به الأخ للأم إذا مات. ويورث ههنا من: وُرِثَ يُورث، لا من: أُورِثَ يُورَث {113}.وانتصب كلالة من وجهين: أحدهما: أنه خبر كان {114}.والثاني: على الحال. المعنى يورث في حالٍ مكللةٍ نسب ورثته، أي لا ولد له ولا والد. وهذا الوجه هو الاختيار، وهو قول الزجاج، والكلالة مصدر وقع موقع الحال، تقديره: يورث متكلل النسب {115}.وقوله تعالى: ﴿وَلَهُ أَخٌ أَوْ أُخْتٌ﴾ إن قيل: قد سبق ذكر الرجل والمرأة في قوله: ﴿وَإِنْ كَانَ رَجُلٌ يُورَثُ كَلَالَةً أَوِ امْرَأَةٌ﴾ ثم قال: ﴿وَلَهُ أَخٌ﴾ فأضاف إلى الرجل وكنى عنه دون المرأة؟قال الفراء: وذلك جائز، إذا جاء حرفان في معنى واحد بـ (أو) أسندت التفسير إلى أيهما شئت، وإن شئت أسندت إليهما {116}، تقول في الكلام: من كان له أخ أو أخت فليصله تذهب إلى الأخ، وفليصلها تذهب إلى الأخت، وإن قلت: فليصلهما، فذلك جائز، (وإن شئت قلت: فليصلهم) {117}، كقراءة من قرأ ﴿إن يكن غنيا أو فقيرا فالله أولى بهم﴾ [النساء: 135] {118} ذهب إلى الجميع لأنهما اثنان غير مؤقتين {119}.وأجمع المفسرون على أن المراد (بالأخ والأخت ههنا من الأم) {120} {121}، وكذلك في قراءة سعد بن أبي وقاص {122}: (وله أخ أو أخت من أم) {123}.قال ابن عباس في رواية عطاء: وله أخ أو أخت من أمه {124}.﴿فَلِكُلِّ وَاحِدٍ مِنْهُمَا السُّدُسُ﴾ (وفرض) {125} الواحد من ولد الأم السدس، فإن كانوا أكثر من واحد اشتركوا في الثلث، الذكر والأنثى فيه سواء. هذا لا خلاف فيه بين الأمة {126}.قال أبو إسحاق: وإنما استُدِل على أن المراد بالأخ والأخت ههنا أولاد الأم بأن ذكر في آخر هذه السورة في قوله: ﴿قُلِ اللَّهُ يُفْتِيكُمْ فِي الْكَلَالَةِ﴾ [النساء: 176] {127} أن للأختين الثلثين، وأن للإخوة كل المال، فعُلم ههنا لما جعل للواحد السدس وللاثنين الثلث، ولم يزادوا على الثلث شيئًا ما كانوا، أنه يعني بهم الإخوة لأم {128}.وقوله تعالى: ﴿غَيْرَ مُضَارٍّ﴾ أي: مدخل الضرر على الورثة {129}. قال المفسرون: هو أن يوصي الرجل بدين ليس عليه {130}، يريد بذلك ضرر الورثة، فمنع الله منه.وانتصب ﴿غَيْرَ مُضَارٍّ﴾ على الحال، المعنى. يُوصَى بها غير مضار {131}.وقوله تعالى: ﴿وَصِيَّةً مِنَ اللَّهِ﴾ قال ابن عباس: يريد فريضة من الله {132}. وهذا مثل ما ذكرنا في قوله: ﴿يُوصِيكُمُ اللَّهُ﴾ [النساء: 11].وانتصابه على المصدر من قوله: ﴿يُوصِيكُمُ اللَّهُ﴾ {133}.وقال الفراء: يريد: فلكل واحد منهما السدس وصية من الله، كما تقول: لك درهمان نفقة إلى أهلك {134}. وذكرنا هذا الوجه في قوله: ﴿نَصِيبًا مَفْرُوضًا﴾ [النساء: 7].وقوله تعالى: ﴿وَاللَّهُ عَلِيمٌ﴾ قال ابن عباس: بمن يجوز في وصيته {135}. وقال الزجاج: ﴿عَلِيمٌ﴾ {136} بما دبّر من هذه الفرائض، حليم عمّن عصاه بأن أخَّره وقبل توبته {137}."
  4,12,""
  4,13,"وقوله تعالى: ﴿تِلْكَ حُدُودُ اللَّهِ﴾ الآية.ذكرنا معنى الحدود فيما تقدم. قال ابن عباس: يريد ما حد الله من فرائضه {1}. وقال ابن كيسان {2}، والزجاج: أي: هذه التي تليت في أمر الفرائض وأمر اليتامى في أول السورة {3}.وقوله تعالى: ﴿وَمَنْ يُطِعِ اللَّهَ وَرَسُولَهُ يُدْخِلْهُ﴾ {4}.وقرأ نافع وابن عامر بالنون، والمعنى فيه كالمعنى في الياء، ومثله قوله: ﴿بَلِ اللَّهُ مَوْلَاكُمْ﴾ [آل عمران: 150]، ثم قال: ﴿سَنُلْقِى﴾ بالنون [آل عمران: 151] {5}.وقوله تعالى: ﴿خَالِدِينَ فِيهَا﴾ قال أبو إسحاق: أي: ندخلهم مقدرين الخلود فيها، وهذا كما تقول في الكلام: مررت برجل معه صقرٌ صائدًا به غدًا، أي: مقدرًا الصيد غدًا، لأن الحال لا يكون إلا ما أنت فيه {6}."
  4,14,"وقوله تعالى: ﴿وَمَنْ يَعْصِ اللَّهَ وَرَسُولَهُ﴾.قال الضحاك: المعصية ههنا الشرك {1}.وقال عكرمة عن ابن عباس: من لم يرض بقسم الله، ويتعدى ما قال الله يدخله نارًا {2}، وقال الكلبي: يعني: يكفر بقسمة المواريث ويتعد حدوده استحلالًا {3}.وقوله تعالى: ﴿يُدْخِلْهُ نَارًا خَالِدًا فِيهَا وَلَهُ عَذَابٌ مُهِينٌ﴾ [النساء: 14] {4}. في نصب خالد وجهان: أحدهما: أنه حال من الهاء في ﴿يُدْخِلْهُ﴾، على تقدير: يدخله خالدًا في النار، إلا أنه لما تقدم ذكر النار كنى عنها {5}.الثاني: أنه من نعت النار. في قول الزجاج {6}، وهذا كما يقول زيد: مررت بدار ساكن فيها، ومثله: ﴿مِنْ هَذِهِ الْقَرْيَةِ الظَّالِمِ أَهْلُهَا﴾ [النساء: 75]."
  4,15,"قوله تعالى: ﴿وَاللَّاتِي يَأْتِينَ الْفَاحِشَةَ﴾ الآية. اللاتي جمع التي، وللعرب في جمع التي لغات، يقال: اللاتي، واللات، واللواتي، واللوات، واللوا، واللائي، واللاء، واللآت، واللاآت {1}. قال الشاعر: من اللَّواتي والّتي واللاّتي ... زَعَمنَ أنَّي كَبِرَت لِداتي {2}فجمع بين ثلاثة أحرف للمبالغة في التوكيد، وكل واحد منها يكفي من الآخر.والعرب قد تقول في جمع النساء: التي، فتقول: ما فعل الهندات التي أمرها كذا، وقال الآخر:اللَّات كالبِيض لَّما تَعْدُ أن دَرَسَتْ ... صُفرُ الأَنَامل من قَرع القَوَاقِيزِ {3}وقال آخر:من اللاء لم يَحجُجْن {4} يَبغِين حِسبةً ... ولكنْ لِيَقْتُلن البَريء المُغَفَّلا {5}وقال آخر:أولئك أخْدانِي وأخلال شِيمَتي ... وأخدانُك اللَّاآت زُّينَّ بالكَتمِ {6} قال ابن الأنباري: العرب تقول في الجمع من غير الحيوان: التي، ومن الحيوان: اللاتي، كقوله: ﴿أَمْوَالَكُمُ الَّتِي جَعَلَ اللَّهُ لَكُمْ قِيَامًا﴾ [النساء: 5]، وقال في هذه الآية: ﴿وَاللَّاتِي﴾. والعِلّة في ذلك أن الجمع من غير الحيوان سبيله سبيل الشيء الواحد. وتأويله قوله: ﴿أَمْوَالَكُمْ﴾ التي (عدتكم {7}) التي جعل الله لكم قيامًا. وجمع الحيوان لا يُجرى مجرى الواحد، ألا ترى أنك تقول: الأموال أخذتها، والأثواب اشتريتها. وتقول في جميع الحيوان: ما فعلت الهندات اللاتي رأيتهن. فتنعتهن بالجمع {8}؛ لأن كل واحدة منهن يقع على عين معروفة، ولا يجري مجرى شيء كما يجري الجمع من الموات مجرى شيء و (عدّه) {9}. ومن العرب من يُسَوِّي بين الموات وغيره في هذا المعنى، فيقول: ما فعلت الهندات التي من أمرها كذا، وما فعلت الأثواب اللاتي من قصتهن كذا وكذا. والأول هو المختار {10}. وأنشد في جمع النساء:من اللَّواتي والّتي واللَّاتي {11}وقوله تعالى: ﴿يَأْتِينَ الْفَاحِشَةَ﴾ أي: يفعلنها، يقال: أتيت أمرًا قبيحًا، أي فعلته. قال الله تعالى: ﴿لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾ [مريم: 27]، وقال: ﴿لَقَدْ جِئْتُمْ شَيْئًا إِدًّا﴾ [مريم: 89] {12}.والفاحشة: الفِعلة القبيحة، وهي مصدر عند أهل اللغة؛ كالعافية والعاقبة، يقال: فَحَش الرجل يفحش فحشًا وفاحشةً، وأفحش إذا جاء بالقبيح من القول أو الفعل {13}. ذكره الزجاج في باب الوفاق {14}.وأجمعوا على أن الفاحشة ههنا الزنا {15}.وقوله تعالى: ﴿فَاسْتَشْهِدُوا عَلَيْهِنَّ أَرْبَعَةً مِنْكُمْ﴾. أي: من المسلمين {16} ﴿فَإِنْ شَهِدُوا﴾ بالزنا {17} ﴿فَأَمْسِكُوهُنَّ فِي الْبُيُوتِ﴾: أي: فاحبسوهن في السجون {18}.قال المفسرون: هذا أمر كانوا يستعملونه في أول الإسلام إذا كان الزانيان ثيبين حبسا ومنعا من مخالطة الناس، وإذا كانا بِكْريَن أُوذِيا بالتعنيف والتوبيخ، فيقال لهما: انتهكتما حُرماتِ الله وعصيتماه، واستهدفتما لعقابه، هذا وما أشبهه من الكلام، ثم نَسخ الله الحبس والأذى بِرَجْم الثيِّبين وجلد البِكرين {19}.أخبرنا أبو القاسم عبد الرحمن بن محمد السراج {20} رحمه الله، أخبرنا أبو الحسن محمد بن الحسن الكارزي {21}، أخبرنا علي بن عبد العزيز {22}، أخبرنا أبو عُبَيد، حدثنا حجاج بن محمد {23}، عن ابن جريج، وعثمان بن عطاء {24}، عن عطاء الخراساني {25}، عن ابن عباس في هذه الآية قال: نسخها قوله: ﴿الزَّانِيَةُ وَالزَّانِي فَاجْلِدُوا﴾ الآية [النور: 2] {26}.قال أبو عبيد: وحدثنا عبد الله بن صالح {27}، عن معاوية بن صالح {28}، عن علي بن أبي طلحة، عن ابن عباس في هذه الآية، وفي قوله: ﴿وَاللَّذَانِ يَأْتِيَانِهَا مِنْكُمْ فَآذُوهُمَا﴾ قال: كانت المرأة إذا زنت حُبست في البيت حتى تموت، وكان الرجل إذا زنا أوذي بالتعيير {29}، والضرب بالنّعال، فنزلت: ﴿الزَّانِيَةُ وَالزَّانِي فَاجْلِدُوا كُلَّ وَاحِدٍ مِنْهُمَا مِائَةَ جَلْدَةٍ﴾ [النور: 2]، قال: وإن كانا محصنين رجما بسنة رسول الله ﷺ قال: فهو سبيلهما الذي جعله الله لهما يعني: قوله: ﴿أَوْ يَجْعَلَ اللَّهُ لَهُنَّ سَبِيلًا﴾ {30}.قال أبو عبيد: حدثنا أبو النضر {31}، عن شعبة {32}، عن قتادة، عن الحسن {33}، عن حِطَّان بن عبد الله الرقاشي {34}، عن عُبادة بن الصامت {35}، قال: قال رسول الله ﷺ: ""خُذوا عني، قد جعل الله لهن سبيلًا، البِكر يُجلد ويُنفى، والثيّب يُجلد ويُرجم"" {36}.وخص النساء بالذكر في هذه الآية، والحد في الزنا على النساء والرجال واحد؛ لأن المرأة أحرص على الزنا من الرجل، فخصها بالذكر، كما قدم اسمها في آية الزنا، وهو قوله: ﴿الزَّانِيَةُ وَالزَّانِي﴾ {37} [النور: 2]. وقدم اسم الرجل في آية السرقة في قوله: ﴿وَالسَّارِقُ وَالسَّارِقَةُ﴾ [المائدة: 38] من حيث كان الرجل أحرص على السرقة من المرأة {38}.قال المفسرون: بعض الآية منسوخ، وهو الإمساك في البيوت، وبعضها ثابت، وهو استشهاد الأربعة {39}. واقترن بناسخ الوحي {40} وحيٌ غير متلوّ على لسان الرسول وهو التغريب والرجم {41}.وجلد الثيب منسوخ أيضًا، فعله رسول الله ﷺ، ثم تركه {42}."
  4,16,"قوله تعالى: ﴿وَاللَّذَانِ يَأْتِيَانِهَا مِنْكُمْ﴾. قرأ ابن كثير {1}: (اللَّذَانّ)، (هَذَانّ)، (هاتَينّ)، (فَذَانِّك) مشددة النون، ووافقه أبو عمرو في: (فَذَانِّك). وإنما شدد نون التثنية لأنه جعل التشديد عِوضًا من الحذف الذي لحق الكلمة، ألا ترى أن قولهم: إذًا قد حذف لامها، وقد حذفت الياء من: (اللَّذَانِّ) في التثنية. فإن قلت: إنّ الحذف في: (اللَّذَانّ)، إنما هو لالتقاء الساكنين، وما حذف لالتقاء الساكنين فهو في تقدير الثبات بدلالة قوله:ولا ذاكر الله إلا قليلًا {2}ألا ترى أنه نصب مع الحذف كما ينصب مع الإثبات؟ قيل: إن المحذوف {3} في (اللَّذانّ) لمّا لم يظهر في التثنية التي كان يلزم أن يثبت فيها ويتحرك، أشبه ما حُذف حذفًا، لغير التقاء الساكنين، فاقتضى العوض، وكذلك القول في: (هذان) التشديد فيه عوض من المحذوف عنه في التثنية وكان حقهما في التثنية: اللّذيان وهذيان. واتفقت هذه الأسماء من (اللذان وهذان) في هذا التعويض، كما اتفقتا في التحقير في فتح الأوائل منهما، مع ضمها في غيرهما، وفي إلحاق الألف أواخرها {4}، وذلك نحو: اللذيّا، واللتيّا، وهاتيّا، وهاذيّا {5}.فأما تخصيص أبي عمرو التعويض في المُبهمة ألزم {6}، فبحسب لزومها الحذف ألزمها العوض، ألا ترى أن اللذين {7} إذا قلت: اللذيّا، فحقّرت أظهرت اللام المحذوفة في التثنية في التحقير، وإذا حقّرت المُبهمة {8} قلت: ذيّا {9}، فالحذف قائم؛ لأنه كان ينبغي: ذَييّا {10}، الياء الأولى عين الفعل، والثانية للتحقير، والثالثة لام الفعل، فُحذفت التي هي عين الفعل، ولم يجُز أنْ تحذف التي هي لام، لأنك لو حذفتها لتحركت ياء التحقير لمجاورتها الألف، وهذه الياء لا تُحّرك أبدًا، فلما لم يُتَم المُبهم في التحقير لمجاورتها الألف، وأُتِم الموصول، خص المبهم بالعوض دون الموصول. فإن قيل: هلا وجب العوض من المنقوص في التثنية نحو: دم، ويد، وغد؟ قيل: هذا لا يلزم، ألا تري أنهم عوضوا في: أسطاع، وأهراق، ولم يعوضوا في: أجاد، وأقام، ونحو ذلك. وأيضًا فإن الحذف لَمَّا لم يلزم هذه الأساء المتمكنة كان الحذف كلا حذف، ألا ترى أنّ منه ما يتم في الواحد نحو:إن مع اليوم أخاه غدوًا {11}ومنه ما يتم في التثنية نحو: يديان بيضاوان {12}.ونحو:جرى الدميان بالخبر اليقين {13}وفي الجمع نحو: أيد، ودماء، وفي التحقير نحو: دُميّ، ويُديّة، وليست المبهمة كذلك.ويمكن أن يكون أبو عمرو قَدّر (ذَانِّك) تثنية ذلك، فعوض الحرف في التثنية من الحرف الزائد الذي كان في الإفراد، والأول أشبه {14}.وقوله تعالى: ﴿يَأْتِيَانِهَا﴾ أي الفاحشة {15}. قال المفسرون: هذا في البِكرين يزنيان {16}.وقوله تعالى: ﴿فَآذُوهُمَا﴾ قال عطاء وقتادة والسدي: يعني التَّعيير باللسان والتوبيخ، كما ذكرنا {17}.وقال ابن عباس: يؤذيان بالتعبير ويضربان بالنعال {18}.﴿فَإِنْ تَابَا﴾ من الفاحشة، ﴿وَأَصْلَحَا﴾ العمل فيما بعد، فاتركوا أذاهما {19}.وقد ذكرنا حكم هذه الآية في الآية التي قبلها.وقوله تعالى: ﴿إِنَّ اللَّهَ كَانَ تَوَّابًا رَحِيمًا﴾ [النساء: 16]. معنى التَّواب أنه يعود على عبده بفضله ومغفرته إذا تاب إليه من ذنبه {20}.وذكرنا قول سيبويه والخليل في مثل قوله: ﴿وَكَانَ اللَّهُ عَلِيمًا حَكِيمًا﴾، ﴿وَكَانَ اللَّهُ غَفُورًا رَحِيمًا﴾ وما أشبه هذا.وكان أبو عبيدة يتأول في كان معنيين: المُضِيّ والاستقبال، وينشد قول جرير:فأدركت من قَد كان قبلي ولم أَدَع ... لمَن كان بَعدي في القصائدِ مَصْنَعَا {21}وقال ابن الأنباري: معنى قوله: ﴿وَكَانَ اللَّهُ عَلِيمًا﴾ وأشباه هذا: وكان الله أبدًا ولم يزل كذلك، وصَلحَ وضعُ الماضي في موضع الدائم؛ لأن المعنى كان مفهومًا غير مُلبِس، كقوله: ﴿وَنَادَى أَصْحَابُ الْجَنَّة﴾ [الأعراف: 44]، وهو يريد: ويُنادي؛ لأن المعنى مفهوم، وإنما (عبرنا للماضي) {22}؛ لأن الذي هو في علم الله كونه لا بد من وقوعه، فكأنه قد وقع، ولا يجوز: قام عبد الله، بمعنى: يقوم لأنه يُشكل.وذهب المبرد وابن قتيبة إلى أن (كان) في مثل هذا صلة في جميع القرآن {23}، وأنشد المبرد:فكيف إذا مررتُ بدارِ قوم {24} ... وجيرانٍ لَنا كانوا كِرام {25}فألغى كان. قال ابن الأنباري: ولا وجه لهذا عندي؛ لأنه لا يُلغى {26} الكونُ وهو عامل، والكون في البيت الذي أنشده المبرد غير عامل."
  4,17,"قوله تعالى: ﴿إِنَّمَا التَّوْبَةُ عَلَى اللَّهِ﴾. قال الحسن: يعني: التوبة التي يقبلها الله {1}، فتكون (على) بمعنى عند.وقال أهل المعاني: إن الله تعالى وعَد قبول التوبة من المؤمنين في قوله: ﴿كَتَبَ رَبُّكُمْ عَلَى نَفْسِهِ الرَّحْمَةَ﴾ الآية [الأنعام: 54]، وإذا وعد الله تعالى شيئًا صدّق ميعاده ولم يجز الخلف فيه، فمعنى (على الله) أنه أوجب ذلك على نفسه بفضله {2}.وقوله تعالى: ﴿لِلَّذِينَ يَعْمَلُونَ السُّوءَ بِجَهَالَةٍ﴾. اتفقوا على أنه لم يُرِد بالجهالة ههنا أنهم يجهلون أنها ذنوب ومعاصي {3}؛ لأن من عمل ذنبًا وهو لا يعلم أنه ذنب لم يستحق عقابًا؛ لأن الخطأ مرفوع عن هذه الأمة.قال الكلبي: لم يَجهل أنه ذنب، ولكنه جهل عقوبته {4}، ومثل هذا قال الفراء {5}.وهذا لا يصح؛ لأنه يوجب أن من علم عقوبته وكان عالمًا بالتهديد فيه وكنه العقوبة لم تكن له توبة.والصحيح في هذا ما قال المفسرون أن المعاصي كلها جهالة، ومن عصى ربه فهو جاهل {6}، يدل عليه قوله عز وجل إخبارًا عن يوسف: ﴿أَصْبُ إِلَيْهِنَّ وَأَكُنْ مِنَ الْجَاهِلِينَ﴾ [يوسف: 33]، أي من العاصين {7}.قال ابن عباس في هذه الآية: يريد أن ذنب المؤمن بجهل {8} منه {9}.وقال الزجاج: معنى الجهالة ههنا، أنهم في اختيارهم اللذة الفانية على اللذة الباقية جُهّال {10}.وقوله تعالى: ﴿ثُمَّ يَتُوبُونَ مِنْ قَرِيبٍ﴾. قال ابن عباس: يريد ولو قبل موته بفواق {11}، وهو قول أبي موسى الأشعري {12} {13}.وقال عكرمة وابن زيد: ما قبل الموت فهو قريب {14}، وكذلك قال الزجاج، أي: يتوبون قبل الموت؛ لأن ما بين الإنسان والموت قريب، فالتوبة مقبولة قبل اليقين بالموت {15}.وقوله تعالى: ﴿وَكَانَ اللَّهُ عَلِيمًا حَكِيمًا﴾. قال ابن عباس: يريد علم ما في قلوب المؤمنين من التصديق واليقين فحكم لهم بالتوبة قبل الموت بقدر فَوَاق ناقة {16}."
  4,18,"قوله تعالى: ﴿وَلَيْسَتِ التَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ السَّيِّئَاتِ﴾ الآية. تعلقت الوعيدية {1} بهذه الآية، وقالت: أخبر الله تعالى أن عصاةَ أهل الصلاة إذا أهملوا أمرهم إلى انقضاء آجالهم حصلوا على عذاب الآخرة مع الكفار؛ لأنه جمعهم في قوله: ﴿أُولَئِكَ أَعْتَدْنَا لَهُمْ عَذَابًا أَلِيمًا﴾ {2}.والجواب: ليس الأمر على ما زعمتم، فقد قال ابن عباس في رواية عطاء: ﴿وَلَيْسَتِ التَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ السَّيِّئَاتِ﴾ يريد الشرك {3}.وقال عكرمة عنه في هذه الآية: هم أهل الشرك {4}.أخبرناه أبو القاسم عبد الرحمن بن محمد، أخبرنا محمد بن الحسن الكارزي، أخبرنا على بن عبد العزيز، أخبرنا أبو عبيد {5}، حدثنا مُحمد بن ربيعة {6}، عن النّضر بن عمران {7}، عن عكرمة، عن ابن عباس.وقال الربيع بن أنس: ﴿إِنِّي تُبْتُ الْآنَ﴾ هو المنافق، ألا ترى يتلوه الكافرون {8}.وقال سعيد بن جبير: نزلت الأولى في المؤمنين، يعني قوله: ﴿إِنَّمَا التَّوْبَةُ عَلَى اللَّهِ﴾ الآية، والوسطى في المنافقين، يعني قوله: ﴿وَلَيْسَتِ التَّوْبَةُ﴾، والأخرى في الكافرين، يعني قوله: ﴿وَلَا الَّذِينَ يَمُوتُونَ﴾ {9}.وإذا كانت الآية نازلة إما في الكفار أو المنافقين، على قول الصحابة والتابعين الذين شاهدوا التنزيل، وعرفوا التأويل، فلا وجه لحملها على أهل الصلاة.وبهذا الإسناد الذي ذكرنا عن أبي عبيد قال: حدثنا ابن صالح ، -يعني: عبد الله-، عن معاوية بن صالح، عن علي بن أبي طلحة، عن ابن عباس، في قوله: ﴿وَلَيْسَتِ التَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ السَّيِّئَاتِ﴾ قال: ثم أنزل الله بعد ذلك: ﴿إِنَّ اللَّهَ لَا يَغْفِرُ أَنْ يُشْرَكَ بِهِ وَيَغْفِرُ مَا دُونَ ذَلِكَ لِمَنْ يَشَاءُ﴾ [النساء: 48] فحرم الله المغفرة على من مات وهو كافر، وأرجى أهل التوحيد إلى مشيئته، ولم يُؤيسهم من المغفرة {10}.فإن قيل: هذا على ما رَوَيتم نسخٌ للأول، ونسخ الخبر لا يجوز. قلنا: لا نَدعي {11} النسخ، ولفظ النسخ لم يُنقل عن ابن عباس، ولكن الآية الأولى اقتضت العموم بظاهرها، فلما نزلت الآية الثانية علمنا أن المراد بالأولى غير أهل التوحيد، من المنافقين والكافرين {12}.وقوله تعالى: ﴿وَلَا الَّذِينَ يَمُوتُونَ وَهُمْ كُفَّارٌ﴾. الذين في موضع الخفض بالعطف على الأول {13}. ومعناه: لا توبة للكفار إذا ماتوا على كفرهم في الآخرة {14}، وإنما لم تقبل التوبة في الآخرة لرفع التكليف ومعاينة ما وعدوا في الدنيا من الثواب والعقاب، ولهذا لم تقبل توبة المُحتَضر لمعاينة أحكام الآخرة.قال الزجاج: ولأنه تاب في وقت (لا يُمكنه التصرف {15}) فيما يُحقق التوبة {16}.وقوله تعالى: ﴿أُولَئِكَ أَعْتَدْنَا﴾ أي: هيأنا وأعددنا. يقال: أعتدت الشيء فهو معتد وعتيد، وقد عتد الشيء عتادة وهو عتيد حاضر. قاله الليث، قال: ومن هنالك سميت العتيدة، التي فيها طيب الرجل وأدهانه، والعتاد ما أعده الرجل من السلاح والدواب والآلة للجهاد، ويُجمع: أعْتُدَةً، وأعتُدًا. ويقال: فرس عَتِدٌ وعَتَدٌ، وهو المُعَدّ للركوب {17}.واختلفوا في هذا الحرف، فقال قوم: عَتَد، بناء على حدة وأصل بنفسه {18} ثم تُدغم التاء في الدال فيقال: أعدّ، والعدّة إنما هي العتدة ولكن أُدغمت التاء في الدال، الذي يدل على هذا قولهم: العدان، في جمع: عتود، وأصله عتدان، فعلى هذا الأصل أعتد، وأعدّ مدغم منه.وقال آخرون بناء أَعدّ من عين ودالين؛ لأنهم يقولون: أعددنا، فيظهرون الدالين، وأنشدوا قول امرئ القيس {19}: أعددتُ للحرب صارمًا ذَكرًا ... مُجرَّب الوَقع غير ذي عَتَبِ {20}ولم يقل أَعَتدْت {21}.قال الأزهري: جائز أن يكون الأصل أعددت، ثم قلبت إحدى الدالين تاء، فعلى هذا الأصل أعدّ، وأعتد مقلوب {22} منه {23}.قال الأزهري: وجائز أن يكون عتد بناء على حدة، وأعدّ بناء مضاعفًا، وهذا هو الأصوب عندي {24}."
  4,19,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا لَا يَحِلُّ لَكُمْ أَنْ تَرِثُوا النِّسَاءَ كَرْهًا﴾ الآية.قال المفسرون: كان الرجل في الجاهلية {1} إذا مات جاء ابنه من غيرها أو قريبه من عصبته فألقى ثوبه على المرأة، فصار أحق بها من نفسها ومن غيره، فإن شاء تزوجها بغير صَداق، إلا الصَّداق الأول الذي أصدقها الميت، وإن شاء زوَّجها غيره وأخذ صَداقها، ولم يُعطِها منه شيئًا، فأنزل الله تعالى هذه الآية، وأعلم أن ذلك حرام، وأن الرجل لا يرث المرأة من الميت {2}.وقال بعضهم: الوراثة تعود إلى المال، وذلك أن وارث الميت كان له أن يمنعها من الأزواج إلى أن تموت فيرثها ما ورثت من الميت، فقال الله تعالى: لا يحل لكم أن ترثوهن أموالهن وهن كارهات {3}.وقوله تعالى: ﴿كَرْهًا﴾ قرئ بفتح الكاف وضمها {4}، وهما لغتان، كالفَقْر والفُقر، والضَّعف والضعف، والشَّهد والشُّهد {5}. قال أحمد بن يحيى {6}: ولا أعلم بين الأحرف التي ضمها (بعض القراء {7}) وفتحها بعضهم من: الكَره والكُره فرقًا في العربية، ولا في سُنَّة تُتّبع، ولا أرى الناس اتفقوا على الحرف الذي في سورة البقرة خاصة، وهو قوله: ﴿كُتِبَ عَلَيْكُمُ الْقِتَالُ وَهُوَ كُرْهٌ لَكُمْ﴾ [البقرة: 216]، إلا أنه اسم وبقية القرآن مصادر {8}.قال الأزهري: وقد أجمع كثير من أهل اللغة أن الكَره والكُره لغتان، فبأي لغة قرئ فجائز، إلا الفراء {9}.وقد ذكرنا قوله في سورة البقرة {10}.وقوله تعالى: ﴿وَلَا تَعْضُلُوهُنَّ لِتَذْهَبُوا بِبَعْضِ مَا آتَيْتُمُوهُنَّ﴾ ذكرنا معنى العضل في سورة البقرة {11}.قال ابن عباس وقتادة والسدي والضحاك: المَنهيّ عن العضل ههنا الأزواج، فهو أن يُمسكوهن إذا لم يكن لهم فيهن حاجة إضرارًا بهن حتى يَفتدين ببعض مُهورهن {12}.وهذا القول اختيار الزجاج، قال: هؤلاء المُخاطَبون غير أولئك.وكان الرجل منهم إذا تزوج امرأة ولم تكن من حاجته حبسها لتفتدي منه، فأَعلمَ الله عز وجل أنّ ذلك لا يَحلّ {13}.وقوله تعالى: ﴿تَعْضُلُوهُنَّ﴾ يَصلح أن يكون نصبًا وجزمًا {14}. أما النصب على أن المعنى: لا يحلّ لكم أن ترثوا النساء ولا أن تعضلوهن {15}، قال الفراء: وكذا هو في قراءة عبد الله {16}. وأما الجَزْم فعلى النهي {17}.قال الأزهري {18}: العَضل في هذه الآية من الزوج لامرأته، وهو أن يُضارّها ولا يُحسن معاشرتها، ليضطرها بذلك إلى الافتداء منه بمهرها الذي أمهرها، سماه الله عَضلاً؛ لأنه يمنعها حقها من النفقة وحسن العشرة، كما أن الولي إذا منع أَيِّمه {19} من التزويج فقد منعها (الحق الذي يجب لها عليه) {20} {21}.وقوله تعالى: ﴿إِلَّا أَنْ يَأْتِينَ بِفَاحِشَةٍ مُبَيِّنَةٍ﴾. قال ابن عباس في رواية عطاء، والحسن وأبو قلابة {22} والسدي: الفاحشة ههنا الزنا {23}.وهو اختيار الزجاج {24}.وقال ابن مسعود وقتادة والضحاك: هي النشوز {25}.ثم اختلفوا في حُكم الآية؛ فقال الأكثرون: إذا زنت امرأة تحتَ رجُلٍ، أو نَشزَت عليه، حلّ له أن يَسْأَلها الخُلع، وأن يُضارَّها ويُسيء معاشرتها لتفتدي منه بالمهر.قال أبو قلابة: إذا رأى الرجل من امرأته فاحشةً فلا بأس أنْ يضارّها حتى تَخَتلِع منه {26}. قال الأزهري: فجعل الله عز وجل اللواتي يأتين الفاحشة مُستَثنيات من جُملة النساء اللواتي نهى الله أزواجهن عن عضلهن ليذهبوا ببعض ما آتوهن من الصداق {18}.وذهب بعضهم إلى أن هذا كان يجوز ثم نُسخ.قال عطاء الخراساني: كان الرجل إذا أصابت امرأته فاحشةً أَخذ منها ما ساق إليها وأخرجها {28}، فنَسخ ذلك الحدود {29}.وهذا الاختلاف على قول من يجعل الفاحشة الزنا، ومن جعلها النشوز فلا نَسخ عنده، وللزوج إذا نَشزت المرأة أن يُسيء {30} عِشرتها لترغب في الفدية.واختلف {31} القراء في المبيّنة والمبيّنات، فقرئت بفتح الياء وكسرها {32}.قال سيبويه: يقال: أبان الأمر وأبنته واستبان، واستبنته، وبيّن وبيّنته {33}، وقد ذكرنا هذا فيما تقدم. فمن فتح الياء فالمعنى عنده: يُبيَّن فحشها فهي مبينة، ومن كسر فحجته ما جاء في التفسير: فاحشة ظاهرة، فظاهرة حجة لمبيِّنة {34}. ثم قال: ﴿وَعَاشِرُوهُنَّ بِالْمَعْرُوفِ﴾ قال ابن عباس: يريد احْجبها بما يَجِب لها عليك من الحق {35}. وقال الزجاج: هو النُّصفة في المبيت والنفقة، والإجمال في القول {36}. وهذا قبل أن يأتين بالفاحشة.وقوله تعالى: ﴿وَيَجْعَلَ اللَّهُ فِيهِ خَيْرًا كَثِيرًا﴾ [النساء: 19]. قال ابن عباس {37}: يريد فيما كرهتم مما هو لله رضا. ﴿خَيْرًا كَثِيرًا﴾ {38} يريد ثوابًا عظيمًا {39}.قال المفسرون: الخير الكثير في المرأة المكروهة أن يرزقه الله منها ولدًا صالحًا ويعطفه عليه {40}.وقوله تعالى: ﴿فِيهِ﴾ الكناية تعود إلى قوله: ﴿شَيْئًا﴾، ويجوز أن تعود إلى الكراههَ والكُره؛ لأن الفعل يدل على المصدر {41}."
  4,20,"قوله تعالى: ﴿وَإِنْ أَرَدْتُمُ اسْتِبْدَالَ زَوْجٍ مَكَانَ زَوْجٍ﴾ الآية. قال المفسرون: لما ذكر الله تعالى في الآية الأولى مُضارّة الزوجات إذا أتين بفاحشة، بَيّن في هذه الآية تحريم المضُارة في غير حال الفاحشة، ونهى عن بَخس {1} حقَّها من المهر إذا أراد الرجل طلاقها وأن يتزوج غيرها، فليس المهر للمرأة موقوفًا على التمسك بها، حتى إذا أراد الاستبدال جاز له أخذه، بل هو تَمليكٌ صحيح لا يجوز الرجوع فيه {2}.وقوله تعالى: ﴿وَآتَيْتُمْ إِحْدَاهُنَّ قِنْطَارًا﴾. فيه دليل على جواز المُغالاة في المهر {3}، فقد رُوي أنّ عمر - رضي الله عنه - قال على المنبر: ألا لا تُغالوا في مُهور نسائكم. فقامت امرأة وقالت: يا ابنَ الخطاب: الله يُعطينا وأنت تمنع، وتلت هذه الآية، فقال عمر: كُلّ الناس أفقه من عمر، ورجع عن كراهة المُغالاة {4}.وقوله تعالى: ﴿أَتَأْخُذُونَهُ بُهْتَانًا﴾.البهتان في اللغة الكذب الذي يواجه به صاحبه على جهة المُكابرة له، وأصله من قولهم: بُهِت الرجل، إذا تحيّر، فالبهتان كذب يُحيِّر الإنسان لعِظَمه، ثم جُعل كل باطل يتحيّر من بطلانه بهتانًا، وهو اسم من البَهت، يقال: بَهَته، أي {5}: استقبله بأمر يقذفه به وهو منه بريء {6}، ومنه الحديث: إذا واجهت أخاك بما ليس فيه فقد بهته {7}.قال الزجاج: البهتان ههنا مصدر وضع موضع الحال، المعنى: أتأخذونه مباهتين وآثمين {8}.وقال ابن عباس في هذه الآية: يريد أن أخذك إياه بعدما دخلت بها بهتان وإثم عظيم {9}. وفُسر البهتان في هذه الآية بالظلم {10}."
  4,21,"وقوله تعالى: ﴿وَكَيْفَ تَأْخُذُونَهُ﴾. استفهام معناه التوبيخ والتعظيم لأخذ المهر بغير حِلّه {1}. ومضت نظائره والكلام {2}.وقوله تعالى: ﴿وَقَدْ أَفْضَى بَعْضُكُمْ إِلَى بَعْضٍ﴾. الإفضاء في اللغة معناه الوصول، يقال: أفضى إليه، أي: وَصل إليه بالملابسة معه قال الشاعر:بِلًى {3} وَثأًى أَفضَى إلى كُل كُثْبَةٍ {4} ... بَدا سَيرُها مِن ظَاهِرٍ بعد ظَاهِرِ {5}أي: البلى والفساد وصل إلى الخرز {6}.وأصله من الفضاء، الذي هو السعة، يقال: فَضا يفضو، فُضُوّا وفَضاءً، إذا اتسع. والفاضي المكان الواسع. فالإفضاء الوصول باتساع المذهب {7}.وقال ابن المظفر: أفضى فلان إلى فلان، أي: وصل إليه. وأصله أنه صار في فُرجته وفَضائه {8}.وللمفسرين في الإفضاء في هذه الآية قولان: أحدهما: أن الإفضاء ههنا كناية عن الجماع. قال ابن عباس في رواية عطاء: ﴿وَقَدْ أَفْضَى بَعْضُكُمْ إِلَى بَعْضٍ﴾ يريد الجماع {9}. وهو قول مجاهد والسدي {10}، واختيار الزجاج {11}، وابن قتيبة {12}، ومذهب الشافعي؛ لأن عنده للزوج أن يرجع في نصف المهر إذا طلق قبل المسيس وإن خلا بها {13}.القول الثاني: أن الإفضاء أن يخلو بها وإن لم يُجامعها.وهذا القول اختيار الفراء في الإفضاء {14}، ومذهب أبي حنيفة {15}؛ لأن الخلوة عنده تمنع من الرجوع في شيء من المهر بالطلاق {16}.واللغة تحتمل المذهبين، روى ثعلب، عن ابن الأعرابي: أفضى الرجل: دخل على أهله، وأفضى: إذا جامعها {17}. قال {18}: والإفضاء في الحقيقة الانتهاء، ومنه قوله تعالى: ﴿وَكَيْفَ تَأْخُذُونَهُ وَقَدْ أَفْضَى﴾ أي: انتهى وأوى {19}.وابن عباس والأكثرون على القول الأول {20}.وقوله تعالى: ﴿وَأَخَذْنَ مِنْكُمْ مِيثَاقًا غَلِيظًا﴾ [النساء: 21]. قال الحسن وابن سيرين {21} والضحاك وقتادة والسدي وعكرمة والفراء: هو قولهم عند العقد: زَوجتُكها على ما أخذ الله للنساء على الرجال من إمساك بمعروف أو تسريح بإحسان {22}.قال الزجاج: التسريح بإحسان لا يكون بأن يأخذ مهرها، هذا تسريح بإساءة لا تسريح بإحسان {23}.وقال مجاهد وابن زيد: الميثاق الغليظ كلمة النكاح التي يُستحل بها فروج النساء {24}، وهو قول ابن عباس في رواية عطاء، قال: الميثاق الغليظ: يريد الشهادة والخُطبة التي فيها ذكر الله والصلاة على النبي ﷺ والنكاح {25}. وقد قال النبي ﷺ: ""اتقوا الله في النساء، فإنكم (أخذتموهن بأمان) {26} الله، واستحللتم فُروجهن بكلمة الله"" {27}. والصحيح أن هذه الآية غير ناسخة لجواز الخُلع {28}، وأن للزوج أن يأخذ من المُختلعة {29}؛ (لأن النشوز منها، فهو في حكم المُكره، لا المريد للاستبدال {30}.وذهب بكر بن عبد الله {31} إلى أنه ليس للزوج أن يأخذ من المُختلعة {32}) شيئًا بظاهر هذه الآية {33}."
  4,22,"وقوله تعالى: ﴿وَلَا تَنْكِحُوا مَا نَكَحَ آبَاؤُكُمْ﴾ الآية. قال ابن عباس وجميع المفسرين: كانت العرب يتزوج الرجل منهم امرأة أبيه من بعده التي ليست بأمه، وكان نكاحًا جائزًا في العرب، فنهى الله عنه وحرمه {1}.فقوله: ﴿مَا نَكَحَ﴾ يحتمل أن تكون (ما) بمعنى: مَن، فيكون المعنى: ولا تنكحوا مَن نكح. ويحتمل أن تكون (ما) بمعنى المصدر، فيكون المعنى: ولا تنكحوا نكاح آبائكم، أي: كنكاح آبائكم، يعني: أن آبائهم كانوا ينكحون أزواج آبائهم، فنهاهم الله أن يكون نكاحهم كنكاح آبائهم، فيكون في التقدير الأول النهي عن التزوج بمنكوحات الآباء، وفي التقدير الثاني النهي عن أن يكون نكاحهم كنكاح آبائهم في البطلان والفساد {2}.وقوله تعالى: ﴿مِنَ النِّسَاءِ﴾ عام في الحرائر والإماء، أما الحرة فتحرم بنفس العقد {3}، دخل بها الأب أو لم يدخل {4}؛ لإطلاق النهي عن نكاحها من غير تقييد، والأمَة يحرم نكاحها بوطء الأب {5}.وقوله تعالى: ﴿إِلَّا مَا قَدْ سَلَفَ﴾. سلف في اللغة معناه: تقدم ومضى، يقال: سَلَف يَسلُف سُلُوفا {6} فهو سَالِف. وكل مال قدمته في ثمن سلعة اشتريتها بصفة معلومة فهو سَلَفٌ وسَلَم {7}.ويقال: سَلَفَ له عمل صالح، أي: تقدم، والسلف أيضًا من تقدم من آبائك وذوي قرابتك.ومنه قول طفيل {8}:مضوا سلفًا قصدُ السَّبيلِ عليهمُ ... وصرفُ المنايا بالرجالِ تَقَلَّبُ {9}أراد أنهم تقدمونا، وقصد سبيلنا عليهم {10}.واختلفوا في هذا الاستثناء بعد إجماعهم على أن هذا ليس بمُخرِجٍ من التحريم؛ لأنه لو كان استثناءً مُخرِجًا من التحريم لوجب أن يُقرّ ما قد مضى منه في النكاح قبل نزول الآية إذ كانوا أحياء {11}، وأكثرهم على أنه استثناء منقطع؛ على معنى: لكن ما قد سلف فإن الله قد تجاوز عنه {12}.وهذا قول ابن عباس في رواية عطاء {13}، والكلبي {13}، وأبي عبيدة {15}، وقُطْرُب {16} {17}، وابن الأنباري {18}، إلا أن بعض هؤلاء قالوا: لكن ما قد سلف فدعوه واجتنبوه {19}.وقد ذكرنا معنى الاستثناء المنقطع عند قوله: ﴿إِلَّا الَّذِينَ ظَلَمُوا مِنْهُمْ﴾ [البقرة: 150].وقال المفضل: إلا ههنا بمعنى بَعْد، يعني: بعدما قد سلف فإن ذلك معفو عنه {20}. وهذا اختيار الحسن بن يحيى الجرجاني، واحتج بقول الله عز وجل: ﴿لَا يَذُوقُونَ فِيهَا الْمَوْتَ إِلَّا الْمَوْتَةَ الْأُولَى﴾ [الدخان: 56]، أي: بعد الموتة الأولى؛ لأن أحدًا لا يدخل الجنة إلا بعد أن يذوق الموت {21}.وقال الأخفش: في الآية محذوف استثني هذا عنه {22}، كأنه قيل: لا تنكحوا ما نكح آباؤكم من النساء؛ فإنكم تؤاخذون به إلا ما قد سلف، أي: فليس عليكم جناح فيما مضى قبل التحريم، وحُذفت المؤاخذة؛ لأن النهي يدل عليه {23}.وقوله تعالى: ﴿إِنَّهُ كَانَ فَاحِشَةً وَمَقْتًا﴾. الكناية تعود إلى النكاح، أي: ذلك النكاح، والفعل دلّ على المصدر {24}.والمقت أشد البُغض {25}، مَقَته يمقُته مقتًا، فهو ممقوت ومقيت {26}.وفي هذا قولان:أحدهما: أن هذا إخبار عما كان في الجاهلية، أُعلِمُوا أن هذا الذي حُرّم عليهم لم يزل مُنكرًا في قلوبهم، ممقوتًا عندهم، وكانت العرب تقول لولد الرجل من امرأة أبيه مقيت ومقتي {27}، والمقت عندهم بُغضٌ عن أمر قبيح ركبهُ صاحبه.وهذا الوجه اختيار الزجاج {28}، وابن الأنباري، قال أبو بكر: يريد أنهم لم يزالوا يستسمجونه {29}، وإن أتوه، ويسمونه المَقت؛ لبغضهم إياه فخبّر الله عز وجل بكان عما مضى من شنآنهم له قبل الإسلام الذي حَظَره.القول الثاني: أن المعنى: أنه فاحشة في الإسلام، أي: زنًا ومقت من الله لمن فعله {30}.وهو قول ابن عباس في رواية عطاء {31}، واختيار المبرد، ويذهب إلى أن (كان) زائدة، والمعنى: إنه فاحشة ومقت {32}.وأنكر ذلك عليه الزجاج وابن الأنباري {33}، وقالا: كيف تكون زائدة وهي عاملة، وقد مر هذا، وبعض النحويين {34} نصر أبا العباس {35} وقال المعنى: هو فاحشة، وأدُخلت كان لِيَدُل أنه عند الله قبل هذه الحال كذا كان.وقوله تعالى: ﴿وَسَاَءَ سَبِيلًا﴾. قال الليث: سَاء يَسُوء فعلٌ للذم ومجاوز، يقال: ساء الشيء يسوء، فهو سيء، إذا قَبُح، ويقال: سَاء ما فعل صنيعًا، أي: قبح صنيعُه صنيعًا {36}.قال ابن قتيبة: أي: قبح هذا الفعل فعلًا وطريقًا، كما تقول: ساء هذا مذهبًا، وهو منصوب على التميز {37}، كما قال: ﴿وَحَسُنَ أُولَئِكَ رَفِيقًا﴾ [النساء: 69] {38}."
  4,23,"قوله تعالى: ﴿حُرِّمَتْ عَلَيْكُمْ أُمَّهَاتُكُمْ﴾ الآية. الأُمَّهات جمع أمّ، وأم في الأصل أُمَّهَة، مثل: قُبَّرة وحُمَّرة، وأسقطت الهاء في التوحيد {1}، قال الشاعر في اللغة الأصلية:أُمَّهَتي خِنْدِفُ (وإِليَاسُ {2}) أَبِي {3}وقد يُجمع الأم: أمات {4}، بغير هاء، وأكثر ما يُستعمل في الحيوان غير الآدمي {5}، قال الراعي {6}:كانَتْ نَجَائِبَ مُنذِرٍ ومُحَرِّقٍ ... أُمَّاتُهُنّ وطَرْقُهُنّ فَحِيلا {7}وقولهم أمهات، بالجمع، الهاء فيها زيادة، ووزنها فعلهات، وقول الشاعر: أُمّهَتيِ خِندِفُ وإِليَاسُ أَبِي {8}أي: أمي، والهاء زائدة {9}.وأجاز أبو بكر أن تكون الهاء أصلية، وتكون أمَّهة وزنها فُعَّلَة، وهو في هذا القول بمنزلة: تُرهَة، وأُبَّهَة، وعُلّفة، وقُبَّرة.ويقول {10} هذا القول ما رواه صاحب العين من قولهم: تأمّهت {11} أمّا، فتأمهَت يبين أنه تفعّلت، بمنزلة: تفّوهت وتنبّهت، إلا أن قولهم في المصدر -الذي هو الأصل- أمومة يقوي زيادة الهاء؛ لأن العرب تقول: أمّ بينة الأمومة، فهذا يقوي أن وزنها فُعْلَهَة.ويزيد في قوة ذلك قول الشاعر:إذا الأُمَّهاتُ قَبَحْنَ الوُجوهَ ... فَرجْتَ الظَّلامَ {12} بِأُمَّاتِكَا {13} {14} إلا أن غالب الأمر يقال فيمن يَعقل بالهاء، وفيمن لا يعقل بغير هاء، أرادوا الفرق بينهما {15}، والقول بزيادة الهاء أولى من اعتقاد حذفها؛ لأن الهاء أحد الحروف العشرة التي تُسمى حروف الزيادة، لا حروف النقص، فلا ينبغي أن يعتقد أن الهاء هي الأصل، وأن أُمًّا محذوف من أُمَّهَة.فأما قول من قال: تأمّهت أمًّا، فيظهره مما يعارضه قولهم: أمّ بيّنة الأُمومة، بحذف الهاء، فرواية برواية، وبقي النظرة {16} الذي قدمناه وهو أن الهاء كثيرًا ما تُزاد في الكلام، وقلّ ما يوجد حذفها، على أن قولهم: تأمّهت، إنما حكاها صاحب العين، وفي ذلك الكتاب من الخَطَل والاضطراب مالا يدفعه نظَّار {17}، وذاكرت بكتاب العين يومًا شيخَنا أبا علي، فأعفى {18} عنه ولم يرضه، لما فيه من القول المرذول والتصرف الفاسد {19}.وذهب ابن الأنباري إلى أن الأصل: أُمّ، ثم يقال في النداء: يا أُمّاه، فيدخلون هاء السكت. ثم إن بعض العرب يُسقط الألف وُيَشبَّه هاء السكتة بتاء التأنيث وتقدير بالإضافة بعدها، فيقول: يا أمّت كما قالوا: يا أَبَت، ثم قد تُستعمل التاء في أمّ في غير النداء، ولم يُستعمل ذلك في الأب، وهو قوله: تَقَبّلتَها من أُمَّةٍ لك طَالَمَا ... (بت {20}) في الأسْواق عَنها خِمَارُها {21}وقالت العرب: هؤلاء أُمَّات زيد، وأُمّهات زيد، فأَجْرَوا الهاء الأصلية، وأصل زيادتها في باب النداء، وقد قال بعضهم: هذه أمّهتك، قال:أُمَّهَتِي خِنْدَفُ وإلياسُ أَبِيفزيدت ههنا دخولها للسكت، ثم شُبَّهت بالأصلية، وزيدت بعدها؛ لأنها شبهت بتاء التأنيث.وكل امرأة رجع نسبُك إليها بالولادة من جهة أبيك أو من جهة أمك بدرجة أو بدرجات، وبإناث رَجَعتَ إليها أو ذكور، فهن أمك {22}.وقوله تعالى: ﴿وَبَنَاتُكُمْ﴾. قد ذكرنا الكلام في أصل البنت والأخت عند قوله: ﴿يُذَبِّحُونَ أَبْنَاءَكُمْ﴾ [البقرة: 49] {23}. وُكلّ أنثى رجع نسبُها إليك بالولادة بدرجة أو درجات بإناث أو ذكور فهن بنتك.وتحريم هاتين مؤبد لم تَزالا، ولم تَحِلا قط لأحد.وقوله تعالى: ﴿وَأَخَوَاتُكُمْ﴾. كل أنثى وَلَدَها شخصٌ وَلَدَك في الدرجة الأولى فهي أُختُك.وقوله تعالى: ﴿وَعَمَّاتُكُمْ﴾. هي جمع العمَّة، وكل ذَكَرٍ رجع نسبُك إليه فأخته عمّتك، وقد تكون العمة من جهة الأم، وهي أخت أبي أمك.وقوله تعالى: ﴿وَبَنَاتُ الْأَخِ وَبَنَاتُ الْأُخْتِ﴾. مضى الكلام في الأخ والأخت عند قوله: ﴿.يُذَبِّحُونَ أَبْنَاءَكُمْ﴾ [البقرة: 49]. والتحديد في بنات الأخ وبنات الأخت كالتحديد في بنت الصلب، وهؤلاء محرمات بالأنساب والأرحام.قال المفسرون وأهل العلم: كل امرأة حرّم الله نِكاحها للنسب والرحم فتحريمها مُبهم، والمُبهمة لا تحلّ بوجهٍ من الوجوه. والتي كانت تحلّ ثُمّ حُرمت بسبب حَدَث، وهن اللواتي ذكرن في باقي الآية، فليست مُبهمة {24}.وقوله تعالى: ﴿وَأُمَّهَاتُكُمُ اللَّاتِي أَرْضَعْنَكُمْ﴾. هؤلاء سمين أمهات للحُرمة، كأزواج النبي ﷺ سماهن الله تعالى أمهات المؤمنين في قوله: ﴿وَأَزْوَاجُهُ أُمَّهَاتُهُمْ﴾ [الأحزاب: 6].وكل أنثى انتسبتَ باللبن إليها فهي أمك، فالتي أرضَعَتْكَ أو رجلًا {25} أُرضِعت بِلبانه من زوجته أو أمّ ولده فهي أمك، وكذلك كل امرأة ولدت امرأة أرضعتك أو رجلًا أرضعك فهي أمك.وإنما يحرم الرضاع بشرطين: أحدهما: أن يكون خمس رضعات {26}.والثاني: أن يكون في الحولين {27}، وما بعد الحولين من الرضاع لا يُحَرِّم {28}، لقوله ﷺ: ""لا رضاع بعد الحولين"" {29}.وقوله تعالى: ﴿وَأَخَوَاتُكُمْ مِنَ الرَّضَاعَةِ﴾. وأخوات الرضاعة ثلاث الأولى: أختك لأبيك وأمك وهي الصغيرة الأجنبية التي أرضعتها أمك بلِبان أبيك، سواءٌ أرضعَتها معك أو مع ولدٍ قبلك أو بعدك. والثانية: أختك لأبيك دون أمك، وهي التي أرضعَتها زوجةُ أبيك بلِبان أبيك. والثالثة: أختك لأمك دون أبيك، وهي التي أرضَعَتها أمك بلبان رجل آخر.وهاتان المرأتان -أعني: أمَّ الرضاعة وأخت الرضاعة- لولا الرضاعة لم يَحرُما، وكان الرضاع تحريمها {30} فصارتا في حكم المبهمات؛ إذ تأبّد تحريمها {30} بعد الرضع.وروت عائشة رضي الله عنها، عن النبي ﷺ قال: ""يحرمُ من الرضاعةِ ما يحرمُ من النسبِ"" {32}.فعلمنا من هذا أن السبع المحرمات بالنسب على التفصيل والبيان الذي ذكرنا محرمات باللبن، وقال أولو التحقيق من ذوي العلم: إن الحد الذي ذكره رسول الله ﷺ في حديث عائشة معلوم من الآية ومستنبط عنها؛ وذلك أن الله تعالى لما ذكر حُرمة الرَّضاع ذكر طريقة الوِلادة بذكر الأمهات، وطريقة الأخُوّة بذكر الأخوات، وكل امرأة حُرمَت بالنَسَب حُرمَت بإحدى هاتين؛ لأن الأم والبنت حرمتا بالولادة، والخمس الباقيات من المحرمات بالنسب حَرُمْنَ بطريق الأخُوّة.وقوله تعالى: ﴿وَأُمَّهَاتُ نِسَائِكُمْ﴾. حد أم امرأتك كحد أمك، سواءٌ كانت من اللبن أو من النسب، فهي حرام عليك بنفس العقد على ابنتها؛ لأن الله تعالى أطلقَ التحريم ولم يُقيِّده بالدخول. هذا إجماع الأمة اليوم {33}.وكان جماعة من الصحابة يذهبون إلى أن المرأة إنما تحرم بالدخول بالبنت، كالربيبة إنما تحرم بالدخول بأمها، وهو قول علي وزيد {34} {35} وابن عمر وابن الزُّبَير {36}، وجابر {37} -رضي الله عنه-، ورُوي ذلك عن ابن عباس {38}، وقال علي -رضي الله عنه-: الأمّ والابنة بمنزلة، إن لم يدخل بهذه تزوج هذه، وإن لم يدخل بهذه تزوج هذه {39}.وهؤلاء يجعلون قول: ﴿مِنْ نِسَائِكُمُ اللَّاتِي دَخَلْتُمْ بِهِنَّ فَإِنْ لَمْ تَكُونُوا دَخَلْتُمْ بِهِنَّ﴾ منتظمًا للربائب وأمهات النساء، ويقول: أمهات النساء اللاتي لم يُدخَل بهن غيره {40} محرمة.والصحيح ما عليه الجماعة، روى عَمرو بن شُعَيب {41}، عن أبيه، عن جده، عن النبي ﷺ، قال: ""إذا نكح الرجلُ المرأةَ فلا يَحلّ له أن يتزوج أمها، دخل بالبنت أو لم يدخل، وإذا تزوج الأم فلم يدخل بها ثم طلقها فإن شاء تزوج البنت"" {42} ففصل بين الربيبة وأم المرأة.وقال ابن جريج: قلت لعطاء: الرجل ينكح المرأة ثم {43} لا يراها ولا يجامعها حتى يطلقها، أتحل له أمها؟ قال: لا هي مُرسلة، دخل بها أو لم يدخل {44}.وكان عبد الله بن مسعود أفتى بنكاح أم المرأة إذا طلّق بنتها قبل المسيس، وهو يومئذ بالكوفة، فاتفق له دخول المدينة فصادفهم مجتمعين على خلاف فتواه، فلما رجع إلى الكوفة لم يدخُل داره حتى حضر ذلك الرجل وقرع عليه الباب، وأمره بالنزول عن تلك المرأة {45}.وقال صاحب النظم: في نظم هذه الآية دليل على أن الشرط بالدخول مختص به الربائب دون أمهات النساء؛ لأن قوله: ﴿وَأُمَّهَاتُ نِسَائِكُمْ﴾ لفظ قائم بنفسه في المعنى المعقود في ظاهره، وليس من نظم العرب في كلامها الجاري المستعمل بينهم أن يقال: أمهات نسائي من نسائي اللاتي دخلت بهن، كما لا يقال في واحدتها: أمّ امرأتي من امرأتي التي دخلت بها، وعادتهم الجارية بينهم في هذا أن يقولوا: أم امرأتي التي دخلت بها، وأمهات نسائي اللاتي دخلت بهن.فقولك في هذا: من نسائي ومن امرأتي زيادة لا حاجة بقيام المعنى إليها، فلما لم يَجُز أن يكون قوله: ﴿مِنْ نِسَائِكُمُ﴾ طِبقًا لقوله: ﴿وَأُمَّهَاتُ نِسَائِكُمْ﴾ لم يَجُز أن يكون شرطًا مُرصَدًا، ولا معطوفًا عليه، وصار هذا الشرط مخصوصًا بذكر الربائب ومقصورًا عليه، دون ذكر أمهات النساء.وقال محمد بن يزيد بن عبد الأكبر {46}: قوله: ﴿اللَّاتِي دَخَلْتُمْ بِهِنَّ﴾ نعت للنساء اللواتي من أمهات الربائب لا غير، والدليل على ذلك إجماع الناس أن الربيبة تحلّ إذا لم يدخل بأمها، فمن أجاز أن يكون قوله تعالى: ﴿مِنْ نِسَائِكُمُ اللَّاتِي دَخَلْتُمْ بِهِنَّ﴾ نعتًا لقوله: ﴿وَأُمَّهَاتُ نِسَائِكُم﴾ بقيت الربائب مطلقة، وخرج أن يكون ﴿اللَّاتِي دَخَلْتُمْ بِهِن﴾ لأمهات الربائب، وحينئذٍ لا يجوز تَزوُّج الربيبة إذا لم يدخل بأمها.قال الزجاج: والدليل على أن ما قال أبو العباس هو الصحيح أن الخبرين إذا اختلفا لم يكن نعتهما واحدًا. لا يجيز النحويون: مررت بنسائك وهربت من نساء زيد الظريفات. على أن يكون الظريفات نعتًا (للفريقين من النساء) {47}.وقوله تعالى: ﴿وَرَبَائِبُكُمُ اللَّاتِي فِي حُجُورِكُمْ﴾. الربائب جمع الربيبة، وهي بنت امرأة الرجل من غيره، ومعناها: مربوبة؛ لأن الرجل هو يربّيها. يقال: رَبَبْتُ فلانًا أربُّه، وربّبته أُرَبِّبُه، وربّيته أُربِّيه، وربته فأنا أربته. كله معنى واحد، قاله الأصمعي {48}. قال الشاعر: وذاكَ لَه إذا العنقَاءُ صارت ... مُربَّبَة وشبّ ابن الخَصِيّ {49}وقال الراجز:والقبُر صهر ضَامنٌ زِمَّيتُ ... ليس لمنَ ضُمَّنَه تَربيتُ {50}وقوله تعالى: ﴿اللَّاتِي فِي حُجُورِكُمْ﴾. قال المفسرون: يقول: اللاتي ربيتموهن في حجوركم. وهي جمع حِجر، وفيه لغتان، قال ابن السكيت: حَجْرُ الإنسان وحِجْرُه بالفتح والكسر {51}.قال أهل المعاني: المراد بقوله: ﴿فِي حُجُورِكُمْ﴾ أي في ضمانكم وتربيتكم، ويقال: فلان في حِجر فلان، إذا كان يلي تربيته {52}، وذلك أن كل من ربّى صبيًّا أجلسه في حِجره، فصار الحِجر عبارةً عن التربية، كما يقال: فلان في حضانة فلان، وأصله من الحِضن الذي هو الإبط {53}.وقال أبو عبيدة: ﴿فِي حُجُورِكُمْ﴾ أي: في بيوتكم {54}. قال الأزهري: ويقال: فلان في حجر فلان، أي: في كنفه ومنعه {51}.وحد الربيبة في رجوعها إلى زوجتك مثل حد بنتك في رجوعها إليك، وهي لا تَحرُم بمجرد العقد على الأم، وإنما تحرم بالدخول، والدخول هو الجماع ههنا بالإجماع {56}.وقوله تعالى: ﴿وَحَلَائِلُ أَبْنَائِكُمُ﴾. قال الليث: الحليل والحليلة الزوج والمرأة، سميا به {57} لأنهما يحلان في موضع واحد، والجميع {58} الحلائل {59}.وقال أبو عبيدة {60}: سميا بذلك؛ لأن كل واحد منهما يُحالّ صاحبه، قال: وكل من نَازَلك أو جاورك {61} فهو حليلك، وأنشد:ولستُ بأطلس الثوبين يُصبِي ... حليلتَه إذا هَدَأ النِّيَامُ {62}قال: لم يُرِد بالحليلة ههنا امرأته، إنما أراد جارته؛ لأنها تُحالّه في المنزل. قال: ويقال: إنما سميت الزوجة حليلة؛ لأن كل واحد منهما يحل إزار صاحبه، على معنى أنه يَحِلُّ له {63}. يقال: حلّ فهو حليل، مثل: صح فهو صحيح. وقال الزجاج: حليلة: يعني {64}: محلة، من الحلال {65}.وقيل: لأن كل واحد منهما يحل إزاره صاحبه {66}.وقوله تعالى: ﴿الَّذِينَ مِنْ أَصْلَابِكُمْ﴾. فيه احتراز عن المُتبنَّى، وكان المتَبنّى في صدر الإسلام بمنزلة الابن.قال عطاء: وليس يحرم عليك حليلة ابن ادعيته وليس هو من صُلبِك، ونكح رسول الله ﷺ امرأة زيد بن حارثة {67}، فقال في ذلك المشركون: إنه تزوج امرأة ابنه، فأنزل الله: ﴿وَمَا جَعَلَ أَدْعِيَاءَكُمْ أَبْنَاءَكُمْ﴾ [الأحزاب: 4]، وقال: ﴿لِكَيْ لَا يَكُونَ عَلَى الْمُؤْمِنِينَ حَرَجٌ فِي أَزْوَاجِ أَدْعِيَائِهِمْ﴾ [الأحزاب: 37] {68}.قال أهل العلم: وحليلة الابن من الرضاع ملحقةٌ في التحريم بحليلة ابن الصلب بالسنة {69}، وهي قول رسول الله ﷺ: ""يحرم من الرضاع ما يحرم من النسب"" {70}.وهذا التحريم يحصل بنفس العقد، كحليلة الأب لا خلاف في هذا {71}.فأما ما رُوي أن ابن عباس سئل عن قوله: ﴿وَحَلَائِلُ أَبْنَائِكُمُ الَّذِينَ مِنْ أَصْلَابِكُمْ﴾ ولم يبين أدخل بها الابن أم لا؟ فقال ابن عباس: أبهموا ما أبهم الله {72}، فإن هذا ليس من إبهام الأمر، ولكن قوله: ﴿حُرِّمَتْ عَلَيْكُمْ﴾ إلى قوله: ﴿وَبَنَاتُ الْأُخْتِ﴾ {73} هذا كله يسمى التحريم المُبْهم؛ لأنه لا يحل بوجه ولا سبب، ولما سئل ابن عباس عن قوله: ﴿وَأُمَّهَاتُ نِسَائِكُمْ﴾ وعن قوله: ﴿وَحَلَائِلُ أَبْنَائِكُمُ﴾ ولم يبين أنهن مدخول بهن أم لا، أجاب فقال: هذا من المبهم، أي: مما لا وجه فيه غير التحريم، سواء دخل بهن أو لم يدخل بهن.وقوله تعالى: ﴿وَأَنْ تَجْمَعُوا بَيْنَ الْأُخْتَيْنِ﴾. أن في محل الرفع؛ لأنه بمعنى: والجمع بين الأختين، عطف على ما قبله {74}.ويحرم على الرجل أن يجمع في النكاح أختين بالنسب أو باللبن. ويجوز الجمع بين أختين أمتين بملك اليمين، فإذا وطئ إحداهما حَرُمَت الثانية عليه، ولا يحل له ما لم يزل ملكه عن الأولى ببيع أو هبة أو عتق أو كتابة {75}.وقوله تعالى: ﴿إِلَّا مَا قَدْ سَلَفَ﴾. فيه قولان: قال عطاء: يريد إلا ما قد مضى في الأمم ﴿إِنَّ اللَّهَ كَانَ غَفُورًا﴾ لما مضى، ﴿رَحِيمًا﴾ بمن أطاعه. قال: ويذكرون أن يعقوب عليه السلام جمع بين ليا أم يهوذا {76} وراحيل أم يوسف {77}، وكان فيما مضى حلالًا لجميع الأمم فحرمه {78} الله على هذه الأمة رحمة منه عليهم لما علم من شدة غَيرةِ النَّساء، بعضهن على بعض {79}.وهذا قول السدي في رواية أسباط {80} عنه {81}.وقال الكلبي: ﴿إِلَّا مَا قَدْ سَلَف﴾ مضى منكم في الجاهلية فلا، تؤاخذون به بعد الإسلام {82}.وهو قول مقاتل {83}، واختيار أبي إسحاق {84}. قال مقاتل في قوله: ﴿إِلَّا مَا قَدْ سَلَفَ﴾ قال: لأنهم كانوا يجمعون بينهما {85}.قال ابن عباس: كان أهل الجاهلية يحرمون ما حرم الله إلا امرأة الأب والجمع بين الأختين {86}.وقال أبو إسحاق: المعنى: سِوى ما سلف فإنه مغفور لكم {65}.قال أبو بكر: وهذا من الاستثناء المنقطع ﴿إِلَّا﴾ بمعنى: لكن، كأنه قيل: لكن ما قد سلف فأنتم غير مؤاخذين به {88}. وقد ذكرنا هذا عند قوله: ﴿إِلَّا الَّذِينَ ظَلَمُوا﴾ [البقرة: 150].واعلم أن المحرمات بالنسب سبعة أصناف، ذُكِرت نسقًا في أول الآية. والمحرمات بالسبب صنفان: صنف يحرم بالرضاع، وهو الأمهات والأخوات، على ما ذكرنا من التفصيل، وصنف يحرم بسبب المصاهرة، وهو أم المرأة وحليلة الأب وحليلة الابن والربائب، على التفصيل الذي ذكرنا، وحليلة الأب لم تُذكر في هذه الآية، إنما ذكرت في قوله: ﴿وَلَا تَنْكِحُوا مَا نَكَحَ آبَاؤُكُمْ﴾ [النساء: 22].فأما الجمع بين الأختين فإنه تحريم الجمع {89}، لأنه يجوز نكاح الثانية بعد طلاق الأولى، ويُلحق بهذا الصنف عمة المرأة وخالتها، فكما لا يجوز الجمع بين المرأة وأختها لا يجوز الجمع بين المرأة على عمتها، وخالتها {90}؛ لما رُوى أن النبي ﷺ قال: ""لا تُنكح المرأة على عمتها ولا على خالتها لا {91} الصغرى على الكبرى، ولا الكبرى على الصغرى"" {92}، أراد الدرجة في النسب لا صِغَرَ السن وكِبَرَه.وقال أهل العلم في حد ما يَحْرُم الجمع بينه: كل امرأتين بينهما قرابة أو لبن لو كان ذلك بينك وبين امرأة لم يَجُز لك نكاحُها لم يجز لك الجمع بينهما. فأما ملك اليمين فكل امرأة حَرُم عليك نكاحها بنسب أو لبن أو صهر، فإذا وجد ذلك المعنى في مملوكة حَرُم عليك وطؤها بملك اليمين، وكل امرأتين حرم عليك الجمع بينهما بقرابة موجودة بينهما أو بلبن، فإذا ملكت أمَتَين وبينهما مثل ذلك المعنى حَرُم عليك وطؤهما بملك اليمين، فإذا وَطِئت إحداهما لم يكن لك وطء الثانية ما لم تُحَرِّم الأولى على نفسك بإزالة الملك عنها بِبَيع أو عِتق أو هِبَة، أو بإزالة الملك عن بعضها {93} بكتابة أو تزويج.واعلم أن التحريم الحاصل بالمُصاهرة يحصل بنكاح صحيح، فلو زنى بامرأة لم تحرم عليه أمها ولا بنتها، ولا تحرم المزنيّ بها على آباء الواطئ، ولا أبنائه، وإنما تتعلق هذه الحُرمة بنكاح صحيح، أو فاسد يجب به الصَّداق والعِدّة ويُلحق به الولد، ولا يتعلّق بالسفاح الصريح.وهذا قول عُروة، وسعيد، ومجاهد، والزهري، ومذهب مالك، والشافعي وفقهاء الحجاز {94}.وقال أهل العراق: الزنا يتعلق به تحريم المصاهرة، حتى لو زنى الأب بامرأة ابنِه انفسخ نكاحها، وكذلك نكاح الأب إن زنى الابن بامرأته. وقالوا: لو قَبّل الأب امرأة الابن ولمسها بالشهوة انفسخ نكاح الابن، ولو قبل أجنبية أو لمسها أو وطئها فيما دون الفرج حصل تحريم المصاهرة. وهذا قول الشعبي والنخعي ومذهب أبي حنيفة {95}.والآية حجة ظاهرة عليهم؛ لأن الله تعالى حرم أمهات النساء والربائب وحلائل الأبناء، وهذه الأسماء لا تثبت بوجود الزنا، فإنّ أم المزنيّ بها لا تكون أم امرأته، ولا بنتها ربيته، وإذا زنى الابن بامرأةٍ لم تَصِر حليلته حتى تحرم على الأب {96}.وقد قال ابن عباس: الحرام لا يحرم الحلال {97}."
  4,24,"وقوله تعالى: ﴿وَالْمُحْصَنَاتُ مِنَ النِّسَاءِ إِلَّا مَا مَلَكَتْ أَيْمَانُكُمْ﴾ الآية. الإحصان في اللغة أصله المَنع، وكذلك الحَصَانة، ولذلك قيل: مدينة حصينة، ودرعٌ حصينة، أي: مانعة صاحبها من الجَرح. قال الله تعالى: ﴿وَعَلَّمْنَاهُ صَنْعَةَ لَبُوسٍ لَكُمْ لِتُحْصِنَكُمْ مِنْ بَأْسِكُمْ﴾ [الأنبياء: 80] معناه: لتمنعكم وتُحرِزَكم {1}، والحصن الموضع الحَصين لمنعه من بغاه من الأعداء {2}. والحِصَان: الفرس لمنعه صاحبه من الهلاك، والحَصَان المرأة العفيفة لمنعها فرجها من الفساد، قال الله تعالى: ﴿وَمَرْيَمَ ابْنَتَ عِمْرَانَ الَّتِي أَحْصَنَتْ فَرْجَهَا﴾ [التحريم: 12]، أي: منعته من الزنا، ويقال: حَصَنَت المرأة تحصُن: إذا عفّت عن الريبة حُصنا وهي حَصان، مثل: جبنت جُبنًا وهي جبان {3}.قال سيبويه: وقالوا أيضًا: حِصنا كما قالوا: عِلما {4}.وقال أبو عبيد والزجاج والكسائي: حصانة أيضًا {5}.وقال شمر: امرأة حصان وحاصِن، وهي العفيفة، وأنشد:وحاصن من حاصِنات ملسِ ... من الأذى ومن قِراف الوَقْسِ {6} فقد حصل من هذا أنه امرأة حَاصِن وحَصَان بينة الحِصن والحَصَن والحَصانة، ثلاث مصادر.وأنشد ابن السكيت {7}:الحِصن أدنى لو تأييته ... من حثيِك التُّرب على الراكِب {8}وقال الزجاج: يقال: امرأة حصان بينّة الحصن، وفرس حصان: بيّن التحصن والتحصين، وبناء حصين: بيّن الحصانة، ولو قيل في كله: الحصانة، لجاز بإجماع {9}.وأما الإحصان فإنه يقع على معان كلها ترجع إلى معنى واحد، منها الحرية، يدل على ذلك قوله: ﴿وَالَّذِينَ يَرْمُونَ الْمُحْصَنَاتِ﴾ [النور: 4] يعني: الحرائر {10}، ألا ترى أنه إذا قذف غير حرة لم يُجلد ثمانين، وكذلك قوله: ﴿فَعَلَيْهِنَّ نِصْفُ مَا عَلَى الْمُحْصَنَاتِ﴾ [النساء: 25] يعني الحرائر، وكذلك قوله تعالى: ﴿وَمَنْ لَمْ يَسْتَطِعْ مِنْكُمْ طَوْلًا أَنْ يَنْكِحَ الْمُحْصَنَاتِ﴾ [النساء: 25]، أي: الحرائر {11}.ومنها {12} العفاف، وهو قوله: ﴿مُحْصَنَاتٍ غَيْرَ مُسَافِحَاتٍ﴾ [النساء: 25]، {13}، وقوله تعالى: ﴿مُحْصِنِينَ غَيْرَ مُسَافِحِينَ﴾ [النساء:24] [المائدة:5] وقوله: ﴿الَّتِي أَحْصَنَتْ فَرْجَهَا﴾ [التحريم: 12]، أي: أعفته.ومنها الإسلام، من ذلك قوله تعالى: ﴿فَإِذَا أُحْصِنَّ﴾ [النساء: 25] قيل في تفسيره: أسلمن {14}.ومنها كون المرأة ذات زوج، يقال: امرأة محصنة، إذا كانت ذات زوج، والمحصنات: المتزوجات، بدلالة قوله: ﴿وَالْمُحْصَنَاتُ مِنَ النِّسَاءِ إِلَّا مَا مَلَكَتْ أَيْمَانُكُمْ﴾ يعني: ذوات الأزواج {15}. ونذكر ذلك عند التفسير.وليس تبعد هذه المعاني عما عليه موضوع اللغة، فإن الإحصان هو أن يُحمى الشيء وُيمنع، والحرّة تُحَصِّن نفسها وتَحصُن هي، وليست كالأمة. والعفة أيضًا مانعة من الزنا، والعفيفة تمنع نفسها، وكذلك الإسلام مانع من الفواحش، والمحصنة ذات الزوج؛ لأن الزوج أحصنها ومنع منها.واختلف القراء في: ﴿الْمُحْصَنَاتُ﴾ فقرأوا بفتح الصاد وكسرها في جميع القرآن {16}، إلا التي في هذه الآية، فإنهم اجتمعوا على الفتح فيها {17}.فمن قرأ بالكسر جعل الفعل لهن، ومن قرأ بالفتح جعل الفعل لغيرهن {18}.قال أبو عبيد {19}: اجتمع القراء على نصب الصاد في الحرف الأول من النساء؛ لأن تأويلها ذوات الأزواج يُسبَين فيُحلهن السِباء {20} تُوطأ بملك اليمين، ويَنتقض نكاحهن.فأما ما سوى الحرف الأول فالقراء مختلفون، فمنهم من يكسر الصاد، ومنهم من يفتحها، فمن نصب، ذهب إلى ذوات الأزواج، ومن كسر ذهب إلى أنهن أسلمن فأحصنّ أنفسهن فهن محصنات {21}.وقال الليث: أُحصِنت المرأة فهي محصنة، وهي التي أحصنها زوجها، وهن المُحصنات، والمعنى أنهن أحُصِنّ بأزواجهن {22}.أخبرني العروضي، عن الأزهري، قال: أخبرني المنذري، عن ثعلب عن ابن الأعرابي، قال: كلام العرب كله على: أفْعَل فهو مُفْعِل، إلا ثلاثة أحرف: أَحصَن فهو مُحصَن، وألفَج فهو ملفَج {23}، وأَسهَب فهو مُسهَب {24}.وأما التفسير فالمحصنات في هذه الآية ذوات الأزواج {25}، وهن محرمات على كل أحد إلا على أزواجهن، لذلك عُطِفن على المحرمات في الآية التي قبلها {26}.ثم استثنى فقال: ﴿إِلَّا مَا مَلَكَتْ أَيْمَانُكُمْ﴾ يريد: إلا ما ملكتموهن بالسبي من دار الحرب، فإنها تحل لمالكها ولا عِدّة عليها، فتُستبرأ بحيضة وتوطأ.وهذا قول ابن مسعود {27}، وابن عباس، وأبي قلابة، وابن زيد، وأبيه {28}، ومكحول {29}، والزهري {30}.قال أبو سعيد الخُدري: لما كان يوم أوْطَاس أَصَبْنا نساءً لهن أزواج في المشركين، فكرههنّ رجال منا، فأنزل الله تعالى: ﴿وَالْمُحْصَنَاتُ مِنَ النِّسَاءِ إِلَّا مَا مَلَكَتْ أَيْمَانُكُمْ﴾ {31}.ولا يمكن حمل المحصنات في هذه الآية على الحرائر، ولا على المسلمات، ولا على العفائف؛ لأن التحريم مُحالٌ في هذه الأجناس، فتعين حملها على الوجه الرابع وهو المنكوحة.وإذا وقع السبا على الزوجين الحربيّين أو على أحدهما انقطع منادي رسول الله ﷺ: ""ألا لا تُوطأ حاملٌ حتى تضع، ولا حائلٌ حتى تحيض"" {32}.فأباح وطأهن بعد الاستبراء، لانفساخ نكاحهن.وذهب جماعة من الصحابة -بظاهر هذه الآية- إلى أن الأَمَة المنكوحة إذا بيعت وقع عليها الطلاق، وبانت من الزوج بالبيع.واحتجوا بقوله: ﴿إِلَّا مَا مَلَكَتْ أَيْمَانُكُمْ﴾ قالوا: فإذا ملكها البائع وجب أن يحل له وطؤها.وهذا يحكى عن ابن عباس وابن مسعود وأُبَيّ {33}، وجابر، وأنس، وسعيد بن المسيب، والحسن {34}.وليس الأمر على ما ذهبوا إليه؛ فإن هذه الآية مخصوصة بملك اليمن في الحربية إذا سبيت من دار العرب، بدليل حديث بريرة {35}، فإن عائشة اشترتها وأعتقتها، ثم خيّرها النبي ﷺ، وكانت مزوجة، فاختارت الفراق {36}، ولو وقع الطلاق بالبيع ما خيرت.وهذا الذي ذكرنا من أن البيع لا يكون طلاقًا مذهب عمر {37}، وعلي، وعبد الرحمن بن عوف {38}، وإجماع الفقهاء اليوم.وقوله تعالى: ﴿كِتَابَ اللَّهِ عَلَيْكُمْ﴾. قال ابن عباس: يريد: هذا ما حرم الله عليكم {39}. يعني: كتب تحريم ما ذكر من النساء عليكم.وانتصابه على مصدر جرى الفعل من غيره، كأنه قيل: حرمت هذه النساء كتابًا من الله عليكم، أي: كتابة {40}.ومعنى الكتابة ههنا التحريم؛ لأنه كتابة التحريم، أي: إثباته وتأكيده.ومثله: ﴿وَتَرَى الْجِبَالَ تَحْسَبُهَا جَامِدَةً وَهِيَ تَمُرُّ مَرَّ السَّحَابِ صُنْعَ اللَّهِ الَّذِي﴾ [النمل: 88]، وقد مر كثير من هذا، (وهذا) {41} معنى قول الفراء والزجاج {42}.وقد كشف أبو علي عن هذا فقال: ليس انتصابه على: عليكم كتاب الله، ولكن كتاب مصدر، دل ما تقدم على الفعل الناصب له، وذلك أن قوله: ﴿حُرِمَتْ عَلَيْكُمْ﴾ فيه دلالة على أن ذلك مكتوب عليهم فانتصب ﴿كِتَابَ اللَّهِ﴾ بهذا الفعل الذي دل عليه ما تقدمه من الكلام {43}. وعلى ذلك قول الشاعر:[ما {44}] إِنْ يمسّ الأرض إلاَ منْكِبٌ ... مِنْه وحرفُ السّاقِ طَيَّ المِحْمَلِ {45}قال الزجاج: ويجوز أن يكون منصوبًا على جهة الأمر، ويكون: ﴿عَلَيْكُمْ﴾ مُفسرًا له، فيكون المعنى: الزموا كتاب الله {46}.قال الفراء: وقد قال بعض النحويين: معناه: عليكم كتاب الله، واحتج بقول الشاعر:يا أيها المائح دلوى دونكا {47}فالدلو عِنْده في موضع نصب، كما يقال: دونك زيدًا، وهذا لا يصح عند النحويين، لأن الإغراء لا يجوز فيه تقديم المنصوب على حرف الإغراء، لا تقول العرب: زيدًا عليك، أو زيدًا دونك. إنما تقول: عليك زيدًا، ودونك زيدًا {48}.قال الزجاج {49}: لأن قولك: عليك زيدًا ليس له ناصب في اللفظ متصرف، فيجوز تقديم نصبه {50}، وقول الشاعر:.......... دلوى دونكما {51}الدلو في موضع رفع، على معنى: هذه دلوي دونك، كقولك: زيدٌ فاضربوه، وإن نصبت الدلوَ أضمرت في الكلام شيئًا، كأنك تقول: خذ دلوي، أو دونك دلوي دونك {52}. وعلى هذا يجوز أن تقول: زيدًا عليك، فيكون منصوبًا بشيء مضمر قبله.وقوله تعالى: ﴿وَأُحِلَّ لَكُمْ مَا وَرَاءَ ذَلِكُمْ﴾. وقرئ: ﴿وَأُحِلَّ﴾ بضم الألف {53}، والفتح {54} أشبه بما قبله، لأن معنى ﴿كِتَابَ اللَّهِ عَلَيْكُمْ﴾: كتب الله عليكم كتابًا وأحلّ لكم فبناء الفتح للفاعل ههنا أحسن.ومن بين {55} الفعل للمفعول به فقال: وأحل لكم، فهو في المعنى يؤول إلى الأول، وفي ذلك مراعاةُ مُشاكلةِ ما بعد بما قبل {56}، وهو قوله: ﴿حُرِّمَت﴾، فلما كان التحريم مبنيًّا للمفعول به كذلك الإحلال.وقوله تعالى: ﴿مَا وَرَاءَ ذَلِكُمْ﴾ قال الفراء وغيره: يقول ما سوى ذلك، كقوله: ﴿وَيَكْفُرُونَ بِمَا وَرَاءَهُ﴾ [البقرة: 91] يريد: سواه {57}.وقال الزجاج: ومعنى: ﴿مَا وَرَاءَ ذَلِكُمْ﴾: أي: ما بعد هذه النساء التي حُرّمت حلال {58}.وهذا الإحلال مخصوص بالسنة، وهو ما ذكرنا من تحريم تَزَوُّج المرأة على عمتها وعلى خالتها {59}.قال أبو إسحاق: لم يقل الله عز وجل: لا أحرم عليكم غير هؤلاء، وقال: ﴿وَمَا آتَاكُمُ الرَّسُولُ فَخُذُوهُ وَمَا نَهَاكُمْ عَنْهُ فَانْتَهُوا﴾ [الحشر: 7]، قال: وآتاهم أن الخالة كالوالدة، وأن العمة بمنزلة الوالد في وجوب الحق كالوالدة. {60} فإذًا العمة والخالة كالوالدة، وتَزّوج المرأة على عمتها وخالتها كتزوجها على أمها.وقوله تعالى: ﴿أَنْ تَبْتَغُوا بِأَمْوَالِكُمْ﴾. محل ﴿أَنْ﴾ رفع على البدل من (ما) في قراءة من قرأ ﴿وأُحلَّ﴾ بضم الألف، ومن قرأ بالفتح كان محل (أن) نصبًا. قالوا: ويجوز أن يكون محلّه نصبً على القراءتين بفقد الخافض، كأنه قيل: لأن تبتغوا، ثم حذف الخافض {61}.والمعنى: أحلّ لكم أن تطلبوا بأموالكم، إما بنكاح وصداق، أو بملك وثمن، وفي هذا دليل على أن الصداق لا يَتَقدّر بشيء؛ لإطلاق قوله: ﴿أَنْ تَبْتَغُوا بِأَمْوَالِكُمْ﴾، فمن ابتغى بقدر جاز أن يكون ثمنًا في بيعٍ أو أجرة في إجارة فقد استحل.وقوله تعالى: ﴿مُحْصِنِينَ﴾. أي: متعففين عن الزنا، وهو قول ابن عباس {62}.وقال مجاهد: ناكحين {63}، وهو اختيار الزجاج؛ لأنه (قال) {64}: عاقدين التزويج {65}.وقال الفراء: يقول: أن تبتغوا الحلال {57}.وقوله تعالى: ﴿غَيْرَ مُسَافِحِينَ﴾. أي: غير زانين. عن مجاهد {67}، والسدي {68}.وقال ابن عباس: السفاح الزنا {69}.قال الليث: السفاح والمسافحة: أن تقيم امرأة مع رجل على فجور من غير تزويج صحيح، والمُسافِحة: الزانية {70}. وروي أن النبي ﷺ قال: قال لي جبريل: ""ما بينك وبين آدم نكاح لا سفاح فيه"" {71}.وأصله في اللغة: من السَّفح وهو الصَّبّ، يقال: سفح الدمع مسفوحًا، وسفح الدم: صبّه، وفلان سفّاحٌ للدماء: أي: سفّاك {72}.وسمي الزنا سِفاحًا، لأنه ليس ثم حرمةُ نكاح ولا عقد تزويج {73}، وإنما يسفح كل واحد من الزانيين نطفته، أي: يصبها ويريقها، فسمي سفاحًا لهذا المعنى. كما سمي مِذًاء من المذي، وكان الرجل في الجاهلية إذا أراد أن يفجر بالمرأة يقول لها: سافحيني، أو ماذيني {74}.وقوله تعالى: ﴿فَمَا اسْتَمْتَعْتُمْ بِهِ مِنْهُنَّ﴾. قال الحسن ومجاهد وابن زيد وأكثر المفسرين: يعني: فما انتفعتم وتلذّذتم من النساء بالنكاح الصحيح {75}. قال أبو إسحاق: يريد فما استمتعتم به منهن على عقد التزويج الذي جرى ذكره {76}.﴿فَآتُوهُنَّ أُجُورَهُنَّ فَرِيضَةً﴾. أي: مهورهن، فإن استمتع بالدخول بها آتى {77} المهر تامًا، وإن استمتع بعقد النكاح آتى نصف المهر {78}.والاستمتاع في اللغة: الانتفاع، وكل ما انتفع به فهو متاع {79}. هذا التفسير هو الذي عليه إجماع الفقهاء وعلماء الأمة {80}.وسُمي المهر في هذه الآية أجرًا لأنه أجر الاستمتاع {81}.وانتصاب الفريضة ههنا على الحال، أي: مفروضة {82}.وقوله تعالى: ﴿وَلَا جُنَاحَ عَلَيْكُمْ فِيمَا تَرَاضَيْتُمْ بِهِ مِنْ بَعْدِ الْفَرِيضَةِ﴾.قال عطاء: يريد: إذا سميت المهر بعدّة من الدنانير أو الحيوان، فلا حرج بعد ذلك أن تحطّ من عدة الدنانير أو الحيوان، إذا كان ذلك برضا المرأة {83}. ففسر هذا التراضي بالحطّ من المهر والإبراء.وقال الزجاج: أي: لا إثم عليكم في أن تَهب المرأة للزوج مهرها، أو يهب الرجل للمرأة تمام المهر إذا طلقها قبل الدخول {84}.وقيل: هذا في الخُلع، يقول: لا جناح عليكم فيما تَفتدي به المرأة نفسها {85}.وذهب كثير من المفسرين إلى أن المراد بالاستمتاع في هذه الآية المُتعة {86} التي كانت مُباحةً في ابتداء الإسلام، وهو ما رُوي أن النبي ﷺ، لما قدم مكة في عمرته، تزين نساء أهل مكة، فشكا أصحاب رسول الله ﷺ إليه العُزبة {87}، فقال: ""استمتعوا من هذه النساء""، وروي أنه قال: ""تمتعوا منهن"" {88}.وكان الرجل في صدر الإسلام يعطي المرأة دينارًا أو دراهم، أو ما كان، مما يتراضيان به، على أن يستمتع بها يومًا أو أسبوعًا، على ما يتراضيان عليه من الأجل، فإذا انقضى الأجل فليس له عليها سبيل، وهي منه بريئة، وعليه أن يستبرئ رحمها فإن قال لها: زيديني في الأيام وأزيدك في الأجر كانت المرأة بالخيار، إن شاءت فَعَلت ذلك، وإن شاءت لم تفعل {89}.قالوا: وذلك قوله: ﴿وَلَا جُنَاحَ عَلَيْكُمْ فِيمَا تَرَاضَيْتُمْ بِهِ مِنْ بَعْدِ الْفَرِيضَةِ﴾ أي: من زيادة الأجل والأجر {90}. ثم أجمع أكثر هؤلاء على أن هذا الحكم منسوخ {91}، إلا ابن عباس وعمران بن حصين {92}، فإنهما كانا يريان جواز نِكاح المُتعة {93}. كان ابن عباس يُفتي بها.قال عمارة {94} مولى الشريد {95}: سألت ابن عباس عن المُتعة، أسِفاح هي أم نكاح؟ قال: لا سفاح ولا نكاح. قلت: فما هي؟ قال: هي المُتعة كما قال الله. قلت: هل لها من عدة؟ قال نعم، عدتها حيضة. قلت: هل يتوارثان؟ قال: لا {96}.وروى عبيد الله بن عبد الله بن عتبة {97}: أن ابن عباس كان يُفتي بها،ويغمصُ {98} ذلك أهلُ العراق، وأَبَى أن ينكل عن ذلك، حتى طفق بعض الشعراء يقول:أقول للركب إذْ طَالَ الثَّواءُ بنا ... يا صَاحِ هَلْ لَك في فُتيا ابن عباسِهل لك في رَخصة الأطرافِ ناعمة ... تكون مَثواك حتى رجعة الناس {99} قال: فازداد لها أهل العلم قَذرًا وبُغضًا، حين قيل فيها الأشعار {100}وقال عمران بن حُصين: نزلت آية المتعة في كتاب الله عز وجل ولم ينزل آية بعدها تنسخها، وأمرنا بها رسول الله ﷺ وتمتعنا معه، ومات ولم يَنهنا عنه. قال رجلٌ بَعْدُ برأيهِ ما شاء {101}.وجميع الصحابة على أن المتعة منسوخة حرام {102}.روى الربيع بن (سَبرة) {103} الجهني {104}، عن أبيه قال: غدوت على رسول الله ﷺ فإذا هو قائم بين الركن والمقام، مسندٌ ظهره إلى الكعبة، يقول: ""يا أيها الناس إني كنتُ أمرتُكم بالاستمتاع من هذه النساء، ألا وإن الله قد حرَّم عليكم إلى يوم القيامة، فمن كان عنده منهن شيء فليُخَلّ سبيلها، ولا تأخذوا مما آتيتموهن شيئًا"" {105}.وروى الحارث بن غُزَيّة {106} أن رسول الله ﷺ قال: ""مُتعة النساء حرام"" {107}.وقال عمر - رضي الله عنه -: لَنْ أُوتَى برجلٍ منكم نكح امرأة إلى أجل إلا رجمته بالحجارة {108}.وروي عن ابن الحَنفيّة {109}: أن عليًا - رضي الله عنه - مر بابن عباس وهو يفتي بنكاح المتعة أنه لا بأس بها، فقال: إن رسول الله ﷺ نهى عنها وعن لحوم الحُمُر الأهلية يوم خيبر {110}.قال أبو عبيد: هذا التوقيت يرجع إلى النهي عن لحوم الحُمُر؛ لأن الرخصة في المتعة كانت في عمرة النبي ﷺ، وهي بعد خيبر، والنهي عن المتعةُ مطلق غير مُؤَقت {111}.وكانت عائشة إذا ذُكِر لها المتعة قالت: والله ما نجد في كتاب الله إلا النكاح والاستِسرار، ثم تتلو هذه الآيات الثلاثة: ﴿وَالَّذِينَ هُمْ لِفُرُوجِهِمْ حَافِظُونَ﴾ [المؤمنون: 5]، إلى آخرها {112}.وقال ابن مسعود: المتعة منسوخة، نسخها الطلاق والصَّداق والعِدّة والميراث {113}.قال أبو عبيد: فالمسلمون اليوم مُجمعون على أن متعة النساء قد نُسخت بالتحريم، نسخها الكتاب والسنة {114}.هذا قول أهل العلم اليوم جميعًا من أهل العراق، وأهل الحجاز، وأهل الشام، وأصحاب الأثر، وأصحاب الرأي: أنه لا رُخصة فيها لمضطر ولا غيره.وقد رُوي عن ابن عباس شيء شبيه بالرجوع عنها، وهو ما روى عطاء الخرساني، عن ابن عباس في قوله: ﴿فَمَا اسْتَمْتَعْتُمْ بِهِ مِنْهُنَّ﴾ قال: نسختها: ﴿يَا أَيُّهَا النَّبِيُّ إِذَا طَلَّقْتُمُ النِّسَاءَ فَطَلِّقُوهُنَّ لِعِدَّتِهِنَّ﴾ [الطلاق: 1] {115}.وقوله تعالى: ﴿إِنَّ اللَّهَ كَانَ عَلِيمًا﴾ أي: بما يُصْلِح أمر العباد (حكيمً) فيما بين {116} لهم من عقد النكاح الذي به حُفظت الأموال والأنساب {117}."
  4,25,"قوله تعالى: ﴿وَمَنْ لَمْ يَسْتَطِعْ مِنْكُمْ طَوْلًا﴾ الآية. قال ابن عباس، وسعيد بن جبير، ومجاهد، وقتادة، والسدي، وابن زيد: الطَّول: الغنى والسعة {1}.وقال الفراء: الطّول: الفضل، يقال: طال عليه يطول طَولًا في الإفضال. ولفلان على فلان طَول، أي: فضل {2}.وقال ابن المظفر والزجاج: الطول: القُدرة {3}. يقال: فلان ذو طول، أي: ذو قدرة في ماله {4}، وقيل في تفسير قوله: ﴿ذِي الطَّوْلِ﴾ [غافر: 3] ذي القدرة. وهذه الأقوال كلها في المعنى واحد.وُيراد بالقدرة ههنا القدرة على المهر {5}، وأصل الطَّول من الطُّول خِلاف القِصَر {6}، وذلك أن الغني يُنال به معاني الأمور، كالطول في أنه يُنال به ما لا ينال بالقِصَر. واشتقاق الطائل من الطول، يقال للشيء إذا لم يكن ذا مَنٍّ يُرغب فيه: هذا شيء غير طائل {7}.ومنه: لقد زادني حبًّا لنفسيَ أَنَّني ... بغيضٌ إلى كُلِّ امرئ غيرِ طائلِ {8}وقوله تعالى:. ﴿أَنْ يَنْكِحَ الْمُحْصَنَاتِ الْمُؤْمِنَاتِ﴾ قال ابن عباس وغيره: يريد الحرائر {9}.فمن فتح الصاد {10} أراد أنهن أُحصِنّ لحريتهن، ولم تُبتذل كالأَمَة، فهن محصَنات، ومن كسر الصاد {11} أراد أنهن أحصن أنفسهن لحريتهن، ولم يبرُزن بروزَ الأمة، فهن مُحصِنات {12}.وتقييد المحصنات ههنا بالمؤمنات، ووصفهن بالإيمان يفيد عند من يقول بالمفهوم أن من وجد طول حرة كتابية لم يكن ممنوعًا عن نكاح الأمَة {13}، وإنما يُمنع إذا وجد طَول حرة مؤمنة كما ذكر الله تعالى. هذا مذهب أكثر أصحابنا {14}.ومنهم من يقول: إذا قدر على طَول حرّة كتابية منع من نكاح الأَمَة، كما لو قدر على طول حرة مؤمنة {15}.ويُحتمل هذا التقييد على غالب الحال؛ لأنّ الغالب من نكاح المسلمين مناكحة المسلمات، والخطاب ربما يأتي مقيدًا بغالب الحال، فلا يكون له مفهوم يُخالف المنظوم، كقوله: ﴿فَلَيْسَ عَلَيْكُمْ جُنَاحٌ أَنْ تَقْصُرُوا مِنَ الصَّلَاةِ إِنْ خِفْتُمْ﴾ [النساء: 101]، ثم لم يكن الخوف مشروطًا في جواز القصر، ولكنه نزل على الغالب، وكان الغالب من أسفارهم الخوف، ولهذا نظائر {16}.وقوله تعالى: ﴿فَمِنْ مَا مَلَكَتْ أَيْمَانُكُمْ﴾. أي: فليتزوج مما ملكت أيمانكم. قال ابن عباس: يريد جارية أخيك في الإسلام {17}.ولا يجوز للإنسان أن يتزوج جاريةَ نفسِه بالإجماع {18}، ومعنى قوله: ﴿فَمِنْ مَا مَلَكَتْ أَيْمَانُكُمْ﴾ هو أن يتزوج الرجل ما يملك غيره ممّن يكون على مثل حاله من الإسلام. فأباح أن ينكح بعضنا فتاة بعض، كما فسره ابن عباس.وقوله تعالى: ﴿مِنْ فَتَيَاتِكُمُ الْمُؤْمِنَاتِ﴾. الفتيات: المملوكات والإماء. جمع فتاة، تقول العرب للأَمَة: فتاة، وللعبد: فتى {19}.ورُوي عن النبي ﷺ أنه قال: ""لا يقولن أحُدكم: عبدي، ولكن لِيَقُل: فتاي وفتاتي"" {20}.وقال ابن السكيت: يقال: (تفتّت) {21} الجارية، إذا راهقت فخُدِرت {22} ومُنِعت من اللعب مع الصبيان. وقد فتيت تفتيةً.ويقال للجارية الحَدثة: فتاة، وللغلام: فتى {23}.أبو عبيد: الفتاء ممدود مصدر الفِتيّ في السن. وأنشد:إذا عاش الفتى مائتين عامًا ... فقد ذهب اللذاذة والفَتَاء {24}فالفتاة الشابة، والفتاة الأمَة، عجوزًا كانت أو شابة {25}؛ لأنها كالشابة في أنه لا تُوقر توقير الكبير.وقوله تعالى: ﴿الْمُؤْمِنَاتِ﴾ أفاد هذا التقييد أنه لا يجوز التزوّج بالأَمَة الكِتابية، سواءٌ كان الزوج حرًا أو عبدًا. وهذا قول مجاهد {26}، وسعيد {27}، والحسن {28}، ومذهب مالك {29}، والشافعي {30}.ومذهب أهل العراق أنه يجوز التزّوج بالأمَة الكِتابية {31}. والآية حجة عليهم {32}.وقوله تعالى: ﴿وَاللَّهُ أَعْلَمُ بِإِيمَانِكُمْ﴾. قال الزجاج: أي: اعملوا على الظاهر في الإيمان فإنكم متعبدون بما ظهر، (والله يتولى السرائر والحقائق) {33}.وقوله تعالى: ﴿بَعْضُكُمْ مِنْ بَعْضٍ﴾. ذكر أهل المعاني الزجاج وابن الأنباري وغيرهما، فيه وجهين:أحدهما: كلكم بنو آدم وولده، فلا يتداخلنكم شموخ وأنفَة من تزّوج الإماء عند الضرورة، فإنكم تتساوون في أنكم بنو آدم. فعلى هذا قوله: ﴿بَعْضُكُمْ مِنْ بَعْضٍ﴾ أي: في النسَب {34}.والثاني: أن المعنى: بعضكم يوالي بعضًا، ويُلابس بعضًا في ظاهر الحكم، من حيث شملكم الإسلام، فاجتمعتم فيه، وصرتم متكافئين متماثلين بجمع الإسلام لكم، واستوائكم في حكمه. قال الراعي:فقُلت ما أنا مِمَّن لا يواصِلُني ... ولا ثَوائِي إلا ريثَ أَحْتَمِلَ {35}أي: لا ألابس من لا يواصلني ولا أواليه. والمعنى: دينكم واحد فأنتم متساوون في هذه الجهة، فمتى وقع لأحدكم الضرورة جاز له تزّوج الأمَة {36}.قال الزجاج: ويُقَوِّي هذا الوجه أنه ذكر ههنا المؤمنات من العبيد {37}والى هذا أشار ابن عباس في تفسير هذه الآية، فقال: يريد: المؤمنون بعضهم أكفاء لبعض {27}.قالوا: وإنما قيل لهم ذلك؛ لأن العرب كانت تطعن في الأنساب، وتفتخر بالأحساب، وتُعَيِّر بالهُجنة، وتُسمي ابن الأَمَة الهَجِين، فأعلمَ الله أن أمر العبيد وغيرهم مستوي {39} في باب الإيمان.وإنما حرم التزّوج بالأمة إذا وُجد إلى الحرة سبيل لمعنيين:أحدهما: أن ولد الحُرّ من المملوك {40} مملوك لسيدها، فلا يجوز له إرقاق ولده ما دام مستغنيًا.والثاني: أنّ الأَمَة مُستَخدمةٌ في الحاجات، مُمتهنة بكثَرة عِشرة الرجال وذلك شاق على الزوج {41}.وقوله تعالى: ﴿وَآتُوهُنَّ أُجُورَهُنَّ﴾: أي: مهورهن {42}.﴿بِالْمَعْرُوفِ﴾: من غير مَطْل وضِرَار {43}. والإجماع على أن المهر إنما يدفع إلى مولاها؛ لأنه ملكه، وإنما أضيف الإيتاء إليهن؛ لأنه ثمن بُضعهن، وإذا آتى المولى فقد آتاها؛ لأنه وإن آتاها كان لمولاها انتزاعه منها.وقوله تعالى: ﴿مُحْصَنَاتٍ﴾ قال ابن عباس وغيره: يريد عفائف {44}.وهو الحال من قوله: ﴿فَانْكِحُوهُنَّ﴾ {45}. وظاهر هذا يوجب أن نكاح الزواني من الإماء حرام.واختلف الناس في نكاح الزواني من الحرائر، وسنذكر ذلك عند قوله: ﴿الزَّانِي لَا يَنْكِحُ إِلَّا زَانِيَةً﴾ [النور: 3] والأكثرون على أنه يجوز نكاح الزانية، وأن قوله: ﴿الزَّانِي لَا يَنْكِحُ إِلَّا زَانِيَةً﴾ [النور: 3]، منسوخ بقوله. ﴿وَأَنْكِحُوا الْأَيَامَى مِنْكُمْ﴾ [النور: 32] {46}. والذي في هذه الآية محمول على الندب والاستحباب.وقوله تعالى: ﴿غَيْرَ مُسَافِحَات﴾ أي: غير زواني {47}.﴿وَلَا مُتَّخِذَاتِ أَخْدَانٍ﴾ جمع خِدْن، والخِدنْ والخَدِين الذي يُخادنك يكون معك في كل أمر ظاهر وباطن، وخِدْن الجارية مُخَدَّنها {48}.قال قتادة والضحاك وأهل التفسير: المُسافِحة التي تؤاجر نفسها مُعلِنَةً بالزنا. يزنين بمن لقيهن من غير ميعاد، ويَسفحن {49} مياههن. والتي تتخذ الخِدْن هي التي تزني سرًّا {50}.وكانت العرب في الجاهلية يعيبون الزنا العلانية، ولا يكادون يعيبون اتخاذ الأخدان فجاء الله بالإسلام فهدم ذلك، وقال: ﴿قُلْ إِنَّمَا حَرَّمَ رَبِّيَ الْفَوَاحِشَ مَا ظَهَرَ مِنْهَا وَمَا بَطَنَ﴾ {51} [الأعراف: 33]، وقال: ﴿مُحْصَنَاتٍ غَيْرَ مُسَافِحَاتٍ وَلَا مُتَّخِذَاتِ أَخْدَانٍ﴾.وقال الشعبي: الزنا على نحوين خبيثين، أحدهما أخبث من الآخر، فأما الذي هو أخبثهما فالسفاح، وهو الفجور بمن أتاها، والثاني: اتخاذ الخدن، وهو الزنا في السر {52}.قال قتادة: ونهى الله عن نكاح المُسَافِحة وذات الخِدْن {53}.وقوله تعالى: ﴿فَإِذَا أُحْصِنَّ﴾. قرئ بالوجهين؛ فمن ضم الألف {54} فمعناه: أُحصنّ بالأزواج، على معنى: تَزوجْن {55}. قاله ابن عباس، وسعيد ابن جبير والحسن ومجاهد وقتادة {56}.ومن فتح الألف {57} فمعناه: أَسلَمْن {58}.كذلك قال عمر، وابن مسعود، والشعبي وإبراهيم والسدي {59}.وقوله تعالى: ﴿فَإِنْ أَتَيْنَ بِفَاحِشَةٍ﴾ يريد: زنا {60}.﴿فَعَلَيْهِنَّ نِصْفُ مَا عَلَى الْمُحْصَنَاتِ مِنَ الْعَذَابِ﴾ أي: عليهن نصف الحدّ {61}.والمحصنات ههنا الأبكار اللاتي أحصنهن العفاف {62}، وحَدُّهن مائة، ويتنصف ذلك في حق الأمَة إذا زنَت {63}. وإن حملنا المحصنات على فوات الزوج لم يَسْهُل؛ لأن حدّهن الرجم، ولا يتنصف الرجم، ولا مدخل له في هذا العبيد {64}. ويقال لم شرط الإحصان في حد الإماء، والإحصان في قوله: ﴿أُحْصِنَّ﴾، و ﴿أَحصنَّ﴾ على اختلاف القراءتين فُسر بالتزوج والإسلام وليس واحد منهما شرطًا في وجوب الحد على الأَمَة إذا زنت؛ فإن الكافرة إذا زنت كان حدها خمسين جلدة، وكذلك الخالية عن الزوج؟والجواب: أن من فسر الإحصان ههنا بالإسلام قال: إنها إذا كانت كافرة لم يكن عليها سبيل، إلا بأن ترضى بحكمنا. وإذا كانت مسلمة أقمنا عليها الحد، ففائدة ذكر الإسلام راجعة إلى أصل إقامة الحد مع بيان قَدرِه.ومن فسر الإحصان بالتزوّج قال: فائدة ذكره ههنا أن الحرة المحصنة بالزوج حدها الرجم، فقيد الله تعالى حكم الأَمَة عند ذكر الحد بالإحصان، إذ لو نص على غير حالة الإحصان بالنكاح لم يبعد أن يَتوهّم مُتوهِّم وجوب الرجم عليها إذا زنت وهي متزوجة، من حيث لم يكن للرجم نصف، كما استوت الحُرّة والأَمَة في قطع السرقة لَمّا لم يكن للقطع نصف {65}.وقوله تعالى: ﴿ذَلِكَ لِمَنْ خَشِيَ الْعَنَتَ مِنْكُمْ﴾. الإشارة تعود إلى نكاح الأمَة عند عدم الطول {66}.وذكرنا معنى العنت والإعنات في اللغة عند قوله: ﴿وَلَوْ شَاءَ اللَّهُ لَأَعْنَتَكُمْ﴾ [البقرة: 220] وقوله: ﴿وَدُّوا مَا عَنِتُّمْ﴾ [آل عمران: 118]. وفسر العنت ههنا: الزنا في قول ابن عباس وسعيد بن جبير وعطية والضحاك وابن زيد {67}. وبيان هذا ما ذكره المُبرَّد: ذلك لمن خاف أن يحمله شدة الشبَق، والغُلمة على الزنا، فيلقى العذاب العظيم في الآخرة، والحد في الدنيا {68}. وإنما سمي الزنا العَنَت من المشقة في الدنيا والآخرة.وقال عطاء: العَنَت المشقة في شدة الغُربة {69}. وهذا اختيار الزجاج، قال: العنت في اللغة المشقة الشديدة، يقال: أَكَمةٌ عنوت، إذا كانت شاقّة المَصعد {70}.قال الأزهري: وهذا الذي قاله أبو إسحاق صحيح، فإذا شقّ على الرجل الغربة {71} وغلبته الغُلمة، ولم يجد ما يتزوج به حرة، فله أن ينكح أَمَة؛ لأن غلبة الشهوة واجتماع الماء في صُلب الرجل ربما آذى {72}.وحكى أبو إسحاق، عن بعضهم: قال: معناه أن يعشق الأمَة. قال {73}: وليس في الآية ذكر العشق، ولكن ذا العشق يلقى عنتًا {74}.وقوله تعالى: ﴿وَأَنْ تَصْبِرُوا خَيْرٌ لَكُمْ﴾. أباح الله تعالى نكاح الأمَة بشرطين: أحدهما: في أول الآية، وهو عدم الطَّول.والثاني: في آخرها، وهو خوف العنت. ثم قال مع ذلك: ﴿وَأَنْ تَصْبِرُوا﴾ يريد: عن تزوج الإماء. قاله ابن عباس، وسعيد بن جبير، ومجاهد، وقتادة {75}.﴿خَيْرٌ لَكُمْ﴾ ألا يصير الولد عبدًا {76}."
  4,26,"قوله تعالى: ﴿يُرِيدُ اللَّهُ لِيُبَيِّنَ لَكُمْ﴾ الآية. اختلفت النحوية {1} في وجه اللام في قوله: ﴿لِيُبَيِّنَ لَكُمْ﴾.فقال الفراء: العرب تجعل اللام التي بمعنى (كي) في موضع (أن) في: أردت وأمرت، فتقول: أردت أن تذهب، وأردت لتذهب، وأمرتك أن تقوم، وأمرتك لتقوم. قال الله: ﴿وَأُمِرْنَا لِنُسْلِمَ لِرَبِّ الْعَالَمِينَ﴾ [الأنعام: 71]، وقال في موضع آخر: ﴿قُلْ إِنِّي أُمِرْتُ أَنْ أَكُونَ أَوَّلَ مَنْ أَسْلَمَ﴾ [الأنعام: 14]، وقال: ﴿يُرِيدُونَ لِيُطْفِئُوا﴾ [الصف: 8]، و ﴿أَنْ يُطْفِئُوا﴾ [التوبة: 32].وإنما صلحت اللام في موضع أن في: أمرت وأردت؛ لأنهما يطلبان المستقبل، ولا يصلحان مع الماضي، ألا ترى أنك تقول: أمرتك أن تقوم، ولا يصلح: أمرتك أن قمت. (وكذلك: أردت أن تقوم، ولا يصلح: أردت أن قمت) {2}. فلما رأوا (أن) في غير هذين تكون للماضي وللمستقبل استوثقوا لمعنى الاستقبال بكَي وباللام التي على {3} معنى كي، (وربما جمعوا بين اللام وكي) {4} وربما جمعوا بين ثلاثتهن، وأنشد {5}: أردت لكيما لَا ترى لي عَثرة ... ومن ذا {6} الذي يُعطى الكَمال فيكمُلُ {7}فجمع بين اللام و (بين) {8} كي.وقال الله تعالى: ﴿لِكَيْلَا تَأْسَوْا عَلَى مَا فَاتَكُمْ﴾ [الحديد: 23].وقال الآخر {9} في الجمع بينهن:أردتَ لِكَيمَا أنْ تَطِير بِقِربتي ... فتتركُها شنًّا ببَيْداءَ بَلْقَعِ {10}وإنما جمعوا بينهما {11} لاتفاقهما في المعنى، واختلاف لفظهما {12}.وأنكر الزجاج أن تقع اللام في معنى (أن)، واستشهد على ذلك بقول الشاعر: أردت لِكَيما يعلمُ الناس أنها ... سراويل سعدٍ {13} والوُفود شْهوُد {14}فلو كانت بمعنى أن لم تدخل على كي، كما لا يدخل عليها أن.(ومذهب سيبويه وأصحابه أن اللام فى خلت في هذا وأشباهه على تقدير المصدر، أي: الإرادة للبيان) {15}، كما قال: ﴿إِنْ كُنْتُمْ لِلرُّؤْيَا تَعْبُرُونَ﴾ [يوسف: 43]، أي: إن كانت عبارتكم للرؤيا، وكذلك قوله: ﴿لِلَّذِينَ هُمْ لِرَبِّهِمْ يَرْهَبُونَ﴾ [الأعراف: 154] أي: الذين هم رهبتهم لربهم {16}.وأنشدوا لكُثَيّر:أُريد لأنّسى ذِكرَها فكأنما ... تَخَيَّل لي ليلى بكل سبيلِ {17}أي: إرادتي لهذا.فأما التفسير، فقال ابن عباس: يريد الله ليبين لكم ما يبعدكم منه ويقربكم إلى طاعته {18}.وقال الكلبي: يريد الله ليبين لكم أن الصبر عن نكاح الإماء خير لكم {19}.وقال غيره: يريد الله أن يبين لكم شرائع دينكم ومصالح أمركم {20}.وقوله تعالى: ﴿وَيَهْدِيَكُمْ سُنَنَ الَّذِينَ مِنْ قَبْلِكُمْ﴾. قال ابن عباس: يريد دين إبراهيم وإسماعيل، دين الحنيفية {21}.وقال الزجاج: أي: يدلكم على طاعته، كما دل الأنبياء والذين اتبعوهم من قبلكم {22}.وقال مقاتل {23}: ويهديكم سنن الذين من قبلكم من تحريم الأمهات والبنات وكذلك كانت سنّة الذين من قبلكم {24}.وقال الكلبي: يقول: هكذا حرمت على مَن كان قبلكم من أهل التوراة، والإنجيل، و (الزبور) {25}، وسائر الكتب {26}. فالبيان على قول هذين خاص في المحرمات وإن عم اللفظ؛ لأن الشرائع مختلفة.وقوله تعالى: ﴿وَيَتُوبَ عَلَيْكُمْ﴾. قال ابن عباس: حتى لا تعرفوا غيره ولا تدعوا معه إلهًا آخر {27}.وبيان هذا المعنى ما قاله محمد بن جرير: يعني: يرجع بكم من معصيته التي كنتم عليها {28} قبل هذا إلى طاعته التي أمركم بها. وإذا فعل بهم ذلك لم يعرفوا غيره إلهًا {29}.﴿وَاللَّهُ عَلِيمٌ﴾ بما يُصلحكم في تدبيره فيكم {30}."
  4,27,"قوله تعالى: ﴿وَاللَّهُ يُرِيدُ أَنْ يَتُوبَ عَلَيْكُمْ﴾. قال ابن عباس: يريد أن يخُرجكم من كل ما يكره إلى ما يُحِب ويرضى {1}.وقال ابن كيسان: والله يأمركم بما فيه المغفرة لذنوبكم. وقال الزجاج: أي: يدلكم على ما يكون سببًا لتوبتكم التي يغفر لكم بها ما سلف من ذنوبكم {2}.وقوله تعالى: ﴿وَيُرِيدُ الَّذِينَ يَتَّبِعُونَ الشَّهَوَاتِ﴾. قال ابن عباس: يريد الزنا وما لم يحلّ لكم {3}. وكذلك قال مجاهد: هم الزناة، يريدون أن يزني أهل الإسلام، وهو قوله: ﴿أَنْ تَمِيلُوا مَيْلًا عَظِيمًا﴾ {4}.وقال السدي: هم اليهود؛ تقول: نكاح الأخت من الأب حلال {5}. وهو قول مقاتل {6}.وقال ابن زيد: هم جميع أهل الباطل في دينهم {7}. وهذا هو الأظهر من هذه الأقاويل؛ لأنه على معنى العموم الموافق لظاهر اللفظ {8}.وفي هذا دلالة على أن من اتبع شهوته فيما يحل لا يوصف باتباع الشهوة، ولا يُطلق عليه هذا الوصف؛ لأن الله تعالى أطلق على المُبطِلين ممن يتبعون شهواتهم (فيما) {9} لا يحل.والشهوات جمع شهوة، والشهوة في الأصل مصدر شهَيت الشيء أشهى شهوةً فهو شهيّ. ورجل شهوات {10}، ورجال شَهاوى {11}.وقوله تعالى: ﴿أَنْ تَمِيلُوا مَيْلًا عَظِيمًا﴾ [النساء: 27]. أي: عن الحق وقصد السبيل بالمعصية مخصوصة {12}، بشّرهم الله بأن إرادته فيهم التوبة. وليس فيها دليل على أنه لا يريد كفر الكافر {13}."
  4,28,"قوله تعالى: ﴿يُرِيدُ اللَّهُ أَنْ يُخَفِّفَ عَنْكُمْ﴾. خص بعضهم التخفيف في هذه الآية، فقال: المراد به نكاح الأمَة عند الضرورة. وهو قول مجاهد {1} ومقاتل {2}.والباقون قالوا: هذا عام في كل أحكام الشرع، وفي جميع ما يَسّره لنا وسهّله علينا إحسانًا منه إلينا، ولم يُثَقِّل التكليف علينا كما ثَقّل على بني إسرائيل بفضله ولُطفه. وعلى العموم دل كلام ابن عباس في تفسيره هذا التخفيف فقال: يريد شدة المئونة يخففها عنكم {3}.وقوله تعالى: ﴿وَخُلِقَ الْإِنْسَانُ ضَعِيفًا﴾ [النساء: 28]. قال ابن عباس. يَضعُف عن الصبر عن الجِماع {4}. وبهذا قال أكثرهم.قال الكلبي وطاوس: لا يصبر عن النساء {5}. وقال ابن كيسان والزجاج: أي: يستميله هواه وشهوته فهو ضعيف في ذلك {6}.وقال الحسن: هو أنه خلق من ماء مهين {7}."
  4,29,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا لَا تَأْكُلُوا أَمْوَالَكُمْ بَيْنَكُمْ بِالْبَاطِلِ﴾. قال أهل المعاني: خص الله تعالى الأكل بالنهي عنه تنبيهًا على غيره؛ لأنه أيضًا لا يجوز جمع المال من الباطل، ولا هِبتُه، ولا التصرف فيه. ولكن المعظم والمقصود من المال الأكل والإنفاق، فنص عليه تنبيهًا على غيره، كما قال: ﴿إِنَّ الَّذِينَ يَأْكُلُونَ أَمْوَالَ الْيَتَامَى﴾ الآية [النساء: 10]، وكما يحرم أكل مال اليتيم بالظلم يحرم إنفاقه في غير الأكل.وقوله تعالى: ﴿بِالْبَاطِلِ﴾ قال ابن عباس: يريد بما لم يحله لكم {1}.وقال الكلبي: يقول: لا تأكلوها إلا بحقها {2}.قال أصحاب المعاني: الباطل اسم جامع لكل ما لا يَحلّ في الشرع كالربا والغصب والسرقة والخيانة وكل محرم محظور.نهى بهذه الآية عن جميع المكاسب الباطلة بالشرع.قال الزجاج: حرم الله عز وجل المال، إلا أن يُؤخذ {3} على السبيل {4} الذي ذكر من الفرائض في المواريث والمهور والتسري {5} والبيع والصدقات التي ذُكرت وجوهها {6}.ثم قال: ﴿إِلَّا أَنْ تَكُونَ تِجَارَةً عَنْ تَرَاضٍ مِنْكُمْ﴾ وأجمعوا على أن هذا استثناء منقطع؛ لأن التجارة عن تراض ليست من أكل المال بالباطل {7}.واختلف القراء في التجارة فرفعها بعضهم {8}، على معنى إلا أن يقع تجارة {9}.ومن نصب {10} فعلى تقدير: إلا أن تكون التجارةُ تجارة {11}، كما قال:أعينَيّ هَلّا تبكيان عِفاقًا {12} ... إذا كان طَعنًا بينهم وعناقًا {13}أو يكون على حذف المضاف بتقدير: إلا أن تكون الأموال أموال تجارة، ثم تحذف المضاف وتُقيم المضاف إليه مقامه {14}.والاختيار الرفع لمعنيين: أحدهما: أن الرفع أدل على انقطاع الاستثناء، وأن الأول محرّم على الاطلاق، والثاني: أن من نصب أضمر التجارة، فقال: معناه: إلا أن تكون التجارة تجارة. والإضمار قبل الذكر ليس بقوي، وإن كان جائزًا {15}، ومعنى قوله: ﴿عَنْ تَرَاضٍ مِنْكُمْ﴾ هو أن يكون عليه، فذلك باطل لم يدخل فيما أباحه الله من البيع {16}.وقال عطاء في قوله: ﴿إِلَّا أَنْ تَكُونَ تِجَارَةً عَنْ تَرَاضٍ مِنْكُمْ﴾ يعني: ليس فيها شيء من الربا {2}وذلك أن البيع إذا قُصد به الربا قلّ ما يقع التراضي به، وإذا لم يوجد التراضي لم يحلّ.وذهب كثير من أهل التأويل إلى أن التراضي في التجارة أن يكون خيار المتبايعين باقيًا إلى أن يتفرقا عن المجلس {18}.وهذا قول شريح {19}وابن سيرين والشعبي {20}، ومذهب الشافعي {21}، ويدل على هذا ما روي أن النبي ﷺ قال: ""ألا لا يتفرقَنّ بيعان إلا عن رضى"" {22}.وقوله تعالى: ﴿وَلَا تَقْتُلُوا أَنْفُسَكُمْ﴾، أي: لا يقتل بعضكم بعضًا.وهذا قول عطاء {23}، والحسن {24}، والكلبي {25}، والزجاج {26}، والأكثرين {27}وإنما قال: (أنفسكم) لأنهم أهل دين واحد، فهم كالنفس الواحدة، فجرى على قول العرب: قتلنا وربّ الكعبة. إذا قتل بعضهم؛ لأن قتل بعضهم كالقتل لهم {28}.وذهب قوم إلى أن هذا نهي للإنسان عن قتل نفسه، فقال أبو عبيدة: ﴿وَلَا تَقْتُلُوا أَنْفُسَكُمْ﴾ لا تهلكوها {29}.ويؤيد هذا حديث عمرو بن العاص {30}، وهو أنه احتلم في بعض أسفاره، وخاف الهلاك على نفسه من الاغتسال، فتيمم وصلى بأصحابه، فلما رجع ذكر ذلك للنبي ﷺ فقال: أشفقت إن اغتسلت أن أهلك، وذكرت قول الله عز وجل: ﴿وَلَا تَقْتُلُوا أَنْفُسَكُمْ إِنَّ اللَّهَ كَانَ بِكُمْ رَحِيمًا﴾ فتيممت وصليت، فضحك رسول الله ﷺ، ولم يقل شيئًا {31}.والقول الأول أظهر، وهذا الثاني يدخل تحت دلالة الأول؛ لأنه إذا حرم عليه قتل غيره من أهل دينه؛ لأنه بمنزلة نفسه، فقد حرم عليه قتل نفسه."
  4,30,"وقوله تعالى: ﴿وَمَنْ يَفْعَلْ ذَلِكَ عُدْوَانًا وَظُلْمًا﴾ الآية. كان ابن عباس يقول: الإشارة تعود إلى كل ما نُهي عنه من أول سورة النساء إلى هذا الموضع {1}. فعلى هذا الوعيد راجع إلى جميع المحرمات السابقة في هذه السورة.وقال ابن جريج: قلت لعطاء: أفي كل ذلك؟ قال: لا، ولكن في قتل النفس {2}. فالوعيد على قول عطاء خاص في قتل النفس المُحرمة، ووجهه أنه يرده إلى أقرب مذكور إليه {3}.وقال قوم: الوعيد راجع إلى أكل المال بالباطل وقتل النفس المحرمة، فالوعيد بكل واحدة من الخصلتين. وهذا اختيار الزجاج، قال: وعد الله عز وجل على أكل المال ظلمًا، وعلى القتل عدوانًا النار. قال: ومعنى العدوان أن يعدوا ما أُمِر به {4}.والأظهر هذا القول؛ لاتصال الوعيد بذكر النهي عن الأمرين.وقوله تعالى: ﴿وَكَانَ ذَلِكَ عَلَى اللَّهِ يَسِيرًا﴾ يقال: يسر الشيء فهو يسير، وهو ضد عسير {5}. ومعناه أنه قادر على المتوعد لا يتهيأ له الامتناع منه ولا الهرب عنه فيتعذر الإيقاع به {6}.31 - قوله تعالى: ﴿إِنْ تَجْتَنِبُوا كَبَائِرَ مَا تُنْهَوْنَ عَنْهُ﴾ الآية. الاجتناب والتجنّب والمجانبة المُباعدة عن الشيء وتركه جانبًا {7}، قال:وقالت تَجَنَّبنا ولا تَقْرَبنَّنا ... فَكَيف وأنتم حاجَتِي أَتَجَنَّبُ {8}وسنذكر هذا ملخصًا عند قوله: ﴿وَالْجَارِ الْجُنُبِ﴾ [النساء: 36] إن شاء الله.واختلفوا في الكبائر ما هي؟ فروى عبد الله بن عمرو {9} أن رسول الله ﷺ قال: ""الكبائر: الإشراك بالله، واليمين الغموس، وعقوق الوالدين، وقتال النفس"" {10}.وروى أبو هريرة عنه ﷺ أنه قال: ""الكبائر أولهن الإشراك بالله، وقتل النفس بغير حقها، وأكل الربا، وأكل مال اليتيم بِدارًا أن يكبَروا، وفرارٌ يوم الزحف، ورمي المحصنة، والانقلاب إلى الأعراب بعد الهجرة"" {11}.وقال ابن عباس في رواية سعيد بن جبير: كل شيء عُصِي اللهُ فيه فهو كبيرة، فمن عمل منها شيئًا فليستغفر الله، فإن الله لا يُخلّد في النار من هذه الأمة إلا راجعًا عن الإسلام، أو جاحد فريضة، أو مكذبًا بقدر {12}.وقال في رواية علي بن أبي طلحة: هي كل ذنب ختمه الله عز وجل بنار، أو غصب، أو لعنة، أو عذاب {13}.وهذا قول الحسين {14} وسعيد بن جبير والضحاك. قالوا: كل مما جاء في القرآن مقرونًا بذكر الوعيد فهو كبير، نحو قتل النفس المحرمة، وقذف المحصنة، والربا، والزنا، وأكل مال اليتيم، والفرار من الزحف {15}.وروى السدي، عن أبي مالك، قال: ذكروا الكبائر عند عبد الله بن مسعود، فقال عبد الله بن مسعود: افتتحوا سورة النساء، فكل شيء نهى الله عنه حتى ثلاث وثلاثين آية {16} فهو كبيرة.ثم قال: مصداق ذلك: ﴿إِنْ تَجْتَنِبُوا كَبَائِرَ مَا تُنْهَوْنَ عَنْهُ﴾ الآية {17} وإلى هذا القول ذهب مقاتل {18}.والصحيح أنه ليس لها حدّ يعرفه العباد وتتميّز به من الصغائر تميُّزَ إشارة، ولو عُرف ذلك لكانت الصغائر مباحة، ولكن الله تعالى يعلم ذلك وأخفاه عن العباد، ليجتهد كل أحد في اجتناب ما نهى عنه رجاء أن يكون مجتنب الكبائر. ونظير هذا في الشريعة إخفاء الصلاة الوسطى في الصلوات، وليلة القدر في ليالي رمضان، وساعة الإجابة في ساعات الجمعة.يؤكد هذا ما رُوي عن ابن جبير أنه قال: سأل رجل ابن عباس عن الكبائر أسبع هي؟ قال: هي إلى السّبعمائة أقرب، إلا أنه لا كبيرة مع الاستغفار ولا صغيرة مع الإصرار {19}.وقال السدي: الكبائر ما رآه الناس بينهم فاحشة قبيحة. وذهب في هذا إلى معنى اللفظ، وذلك أن حقيقة الكبائر ما كَبُر وعظُم من الذنوب. قاله الزجاج {20}.وقوله تعالى: ﴿نُكَفِّرْ عَنْكُمْ سَيِّئَاتِكُمْ﴾. السيئات المكفّرة باجتناب الكبائر هي ما دون الكبائر، والمعاصي مما يجتمع في عمله أهل الصلاح وأهل الفسق، مثل النظرة والكذبة واللمسة والقُبلة، وأشباه ذلك. وهذه تقع مكفّرةً بالصلوات الخمس، فقد قال ﷺ: ""الخمس كفارات لما بينهن ما اجتنبت {21} الكبائر"" {22} {23}.وقوله تعالى: ﴿وَنُدْخِلْكُمْ مُدْخَلًا كَرِيمًا﴾. وقرئ (مَدخلا) {24} بفتح الميم. وهو بعد قوله: ﴿وَنُدْخِلْكُمْ﴾ محتمل أمرين: أحدهما: أن يكون مصدرًا وتضمر له فعلًا دلّ عليه الفعل المذكور، وانتصابه بذلك الفعل المضمر. والتقدير: وندخلكم فتدخلون مَدْخَلًا.والثاني: أن يكون مكانًا، كأنه قال: وندخلكم مكانًا. وهو على هذا التقدير منتصب بهذا الفعل المذكور {25}.ومن قرأ بضم الميم جاز أن يكون مكانًا، وأن يكون مصدرًا، فإن جعلته مصدرًا جاز أن تريد مفعولًا محذوفًا من الكلام، كأنه: وندخلكم الجنة مدخلًا كريمًا، أي إدخالًا كريمًا {26}.والأشبه على القراءتين أن يكون مكانًا؛ لأن المفسرين قالوا في قوله: ﴿مُدْخَلًا كَرِيمًا﴾: هو الجنة {27}، ولأنا رأينا المكان وصف بالكريم، وهو قوله: ﴿وَمَقَامٍ كَرِيمٍ﴾ [الدخان: 26]، فوصف المكان بالكريم، فكذلك يكون قوله: ﴿مُدْخَلًا﴾ يراد به المكان مثل المقام.ويجوز أن يكون المراد به الدخول أو الإدخال؛ فإن {28} كان قد وصف بالكريم، ويكون المعنى: دخولًا تكرمون فيه، خلاف من قيل فيهم: ﴿الَّذِينَ يُحْشَرُونَ عَلَى وُجُوهِهِمْ إِلَى جَهَنَّمَ﴾ [الفرقان: 34] الآية {29}.ومعنى الكريم: الشريف الفاضل، قال الله تعالى: ﴿إِنَّ أَكْرَمَكُمْ عِنْدَ اللَّهِ﴾ [الحجرات: 13] أي أفضلكم، وقال: ﴿وَلَقَدْ كَرَّمْنَا بَنِي آدَمَ﴾ [الإسراء: 70] أي شرفناهم وفضلناهم، ومنه قوله: ﴿أَرَأَيْتَكَ هَذَا الَّذِي كَرَّمْتَ عَلَيَّ﴾ [الإسراء: 62] أي فضلت. وزدنا بيانًا لمعنى الكريم في سورة الأنفال، عند قوله: ﴿وَرِزْقٌ كَرِيمٌ﴾ [الأنفال: 4]."
  4,31,""
  4,32,"قوله تعالى: ﴿وَلَا تَتَمَنَّوْا مَا فَضَّلَ اللَّهُ بِهِ بَعْضَكُمْ عَلَى بَعْضٍ﴾. التمني في اللغة: تقدير ما يحب على جهة الاستمتاع به. وقد مضى القول فيه عند قوله: ﴿إِلَّا أَمَانِيَّ﴾ [البقرة: 78].قال مجاهد: قالت أم سلمة: يا رسول الله: يغزو الرجال ولا نغزو، وإنما لنا نصف الميراث، فليتنا كنا رجالًا، فجاهدنا وغزونا، وكان لنا مثل أجر الرجال. فنزلت هذه الآية {1}.وهذا قول أكثر المفسرين. قالوا: وفي هذه الآية: أن يتمنى أحد مال غيره ومنزل غيره، فإن ذلك هو الحسد. وقد جاء: لا يتمنين أحدكم مال أخيه، ولكن ليقل: اللهم ارزقني، اللهم أعطني مثله {2}.وهذا النهي نهي تحريم عند أكثر العلماء. وليس لأحد أن يقول: ليت مال فلان لي، وانما يجوز أن يقول: ليت مثله لي {3}.وقال الفراء: هذا نهي أدب وتنزيه، دون تحريم {4}.والصحيح هو الأول؛ لأنه لا يُعدل بصيغة النهي عن معناه إلا بقرينة.وقوله تعالى: ﴿لِلرِّجَالِ نَصِيبٌ مِمَّا اكْتَسَبُوا وَلِلنِّسَاءِ نَصِيبٌ مِمَّا اكْتَسَبْنَ﴾. قال ابن عباس في رواية عطاء: ﴿مِمَّا اكْتَسَبُوا﴾ يريد الجهاد، وما لا يصلح للنساء. ﴿وَلِلنِّسَاءِ نَصِيبٌ مِمَّا اكْتَسَبْنَ﴾ يريد حفظ فروجهن، وطاعة (زوجهن) {5}، وحفظه إذا غاب، وترقع وتصنع في بيتها، نظرًا منها لزوجها مثل العجين والطبيخ وما يصلح في معايشه، ولها في ذلك ثواب عظيم {6}. فالنصيب على هذا معناه الثواب، أي لكل واحد من الفريقين حظ من الثواب.وقال قتادة ومقاتل والسدي: قالت الرجال: إنا لنرجو أن نُفَضَّل على النساء بحسناتنا في الآخرة، كما فُضِّلنا عليهن في الميراث، فيكون أجرنا على الضعف من أجر النساء. وقالت النساء: إنا لنرجو أن يكون الوزر علينا نصف ما على الرجال في الآخرة، كما لنا الميراث على النصف من نصيبهم في الدنيا.فأنزل الله عز وجل: ﴿لِلرِّجَالِ نَصِيبٌ مِمَّا اكْتَسَبُوا﴾ من الثواب والعقاب ﴿وَلِلنِّسَاءِ﴾ كذلك {7}. فسوى بين الفريقين في الثواب والعقاب، واستحقاقهم إياهما بالاكتساب.ولأصحاب المعاني في هذا وجه آخر: يقول: لكل فريق من الرجال والنساء نصيب مما اكتسب من نعيم الدنيا، فينبغي أن يقنع به رضًى بما قسم الله له، ولا يتمنى مال غيره.وقوله تعالى: ﴿وَاسْأَلُوا اللَّهَ مِنْ فَضْلِهِ﴾.أي إن احتجتم إلى ما لغيركم (وأجبكم) {8} أن يكون لكم مثل ما له فاسألوا الله أن يعطيكم مثل ذلك من فضله {9}.وقال رسول الله ﷺ: ""سلوا الله من فضله، فإنه يحب أن يُسأل"" {10}.قال أبو علي: (من) في قوله: ﴿مِنْ فَضْلِهِ﴾ في موضع المفعول الثاني في قول أبي الحسن، ويكون المفعول الثاني محذوفًا في قياس قول سيبويه، والصفة قائمة مقامه {11}؛ كأنه قيل: واسألوا الله نعمه وفضله."
  4,33,"وقوله تعالى: ﴿وَلِكُلٍّ جَعَلْنَا مَوَالِيَ مِمَّا تَرَكَ الْوَالِدَانِ وَالْأَقْرَبُونَ﴾ الآية. أراد: ولكل واحد من الرجال والنساء، جعلنا موالي.قال ابن عباس ومجاهد وقتادة وابن زيد: أي عصبة {1}.وقال السدي: أي ورثة {2}.ومضى الكلام في المولى، واشتقاقه في اللغة.وقوله تعالى: ﴿مِمَّا تَرَكَ الْوَالِدَانِ وَالْأَقْرَبُونَ﴾ فيه قولان:أحدهما: أن (من) في قوله (مما) متعلق بمحذوف، ذلك المحذوف من صفة المولى، كأنه قيل: لكل جعلنا ورثة يرثون، أو يُعطَون مما ترك والداه وأقربوه من ميراثهم له. والوالدان والأقربون على هذا هم الذين ماتوا وورثهم المعني بقوله. ﴿وَلِكُلٍّ﴾، والألف واللام في الوالدان والأقربون بدل عن الكناية، كأنه قيل: مما ترك والداه وأقربوه، كقوله: ﴿فَإِنَّ الْجَنَّةَ هِيَ الْمَأْوَى﴾ [النازعات: 41] أي مأواه.الثاني: أن قوله: ﴿مِمَّا تَرَكَ﴾ في صفة (موالي) {3}، أي: موالي ممن تركهم وخلّفهم الميت، ثم فسر الموالي فقال: ﴿الْوَالِدَانِ وَالْأَقْرَبُونَ﴾ أي هم هؤلاء. و (ما) على هذا القول بمنزلة (مَن)، والوالدان والأقربون هم الوارثون. وعلى هذا القول يحتمل أن يكون المعنى: ولكل شخص جعلنا ورثةً ممن تركهم والداه وأقربوه، أي: تشعبت العصبة والورثة عن الوالدين والأقربين {4}.والوالدان والأقربون {5} مرتفعة بالفعل الذي هو الترك.وعلى القولين اللذين ذكرنا يجوز أن يُعنى بقوله: (ولكل) المال والميراث فيكون المعنى على القول الأول: ولكل مال وميراث مما ترك الوالدان والأقربون جعلنا موالي، أي عصبة وورثة يرثونه، وعلى هذا يكون قد فصل بين الصفة والموصوف بقوله: ﴿جَعَلْنَا مَوَالِيَ﴾. وعلى القول الثاني يكون المعنى: ولكل مال مما ترك الميت جعلنا ورثة، ثم ابتدأ (فقال) {6}: ﴿الْوَالِدَانِ وَالْأَقْرَبُونَ﴾ أي هم هؤلاء، وقوله تعالى: ﴿جَعَلْنَا مَوَالِيَ﴾ فاصل أيضًا، وجملة هذا أنك إذا فسرت الكل بالشخص كان (من) في قوله (مما) متعلقًا بمحذوف، أو صفة لموالي، وإن (فسرته) بالمال كان في صفة (لكل)، مفصولًا بينه وبين الموصوف بقوله: ﴿جَعَلْنَا مَوَالِيَ﴾، فتدبّره تفهم إن شاء الله.وقوله تعالى: ﴿وَالَّذِينَ عَقَدَتْ أَيْمَانُكُمْ﴾. هم الحلفاء {7} في قول الجميع {8}. ويجوز أن يُعطف على: ﴿الْوَالِدَانِ وَالْأَقْرَبُونَ﴾ {9} فيكون حكم الحُلفاء كحكم الوالدين والأقربين، في كونهم وارثين أو موروثين، على ما بينّا.وقوله تعالى: ﴿فَآتُوهُمْ نَصِيبَهُمْ﴾. الكناية تعود إما إلى الموالي، أو إلى الوالدان والأقربون والحلفاء إذا جعلناهم وارثين، إلا أن المفسرين يحملون قوله: ﴿والذين عاقدت أيمانكم﴾ على الابتداء، ولا يعطفونه {10} على ما قبله.قالوا: وكان الرجل في الجاهلية يعاقد الرجل، ويقول له: دمي دمك، ويرثني وارثك، وثأري ثأرك، وحربي حربك، وسِلمي سِلمك فلما قام الإسلام جعل للحليف السدس {11}.واختلف القراء في قوله: ﴿عَاقَدَت﴾، فقرأ أهل الكوفة (عَقَدَتْ) {12} بالتخفيف من غير ألف.والباقون (عَاقَدَت) بالألف {13}. وهذا أشبه بهذا المعنى؛ لأن لكل نفر من المعاقدين يمينًا على المُخالفة {14}، وجعل الأيمان في اللفظ هي المعاقدة، والمعنى على الحالفين الذين هم أصحاب الأيمان، فالمعنى: والذين عاقدت حلفهم أيمانُكم. حذف الذكر للعائد {15} من الصلة إلى الموصول. وهؤلاء الذين قرأوا في المفاعلة حملوا الكلام على المعنى، حيث كان من كل واحد من الفريقين يمين.ومن قرأ (عَقَدَتْ) كان المعنى: عقدت حلفَهم أيمانكم، كالأول، إلا أنهم حملوا على لفظ الأيمان، لأن الفعل لم يُسند إلى أصحاب الأيمان في اللفظ، إنما أُسنِد إلى الأيمان {16}.والأيمان ههنا يحتمل أن يكون جمع يمين من اليد، ويحتمل أن يكون من القَسَم، وذلك أنهم كانوا يضربون صفقة البيعة بأيمانهم ويأخذ بعضهم بيد بعض على الوفاء والتمسك بالعهد، ويتحالفون عليه أيضًا {17}.وقوله تعالى: ﴿فَآتُوهُمْ نَصِيبَهُمْ﴾. أي حظهم من الميراث. عن ابن عباس وسعيد بن جبير وقتادة وعامر والضحاك {18}. ثم نسخ ذلك بقوله: ﴿وَأُولُو الْأَرْحَامِ بَعْضُهُمْ أَوْلَى بِبَعْضٍ﴾ [الأنفال: 75].أخبرنا عبد الرحمن بن محمد السراج، أخبرنا أبو الحسن الكارزي، أخبرنا علي بن عبد العزيز، عن أبي عبيد، حدثنا حجاج، عن ابن جريج، وعثمان بن عطاء، عن عطاء الخرساني، عن ابن عباس: ﴿وَالَّذِينَ عَقَدَتْ أَيْمَانُكُمْ فَآتُوهُمْ نَصِيبَهُم﴾ قال: كان الرجل قبل الإسلام يعاقد الرجل، يقول: يرثني وارثك، نسختها ﴿وَأُولُو الْأَرْحَامِ بَعْضُهُمْ أَوْلَى بِبَعْضٍ﴾ [الأنفال: 75] {19}.وقال مجاهد في هذه الآية: كان حلف في الجاهلية، فأُمِروا أن يُعطوهم نصيبهم من المشورة والنصر والرفد، ولا ميراث {20}.وعلى هذا لا يكون في الآية نَسخٌ لقوله عز وجل: ﴿أَوْفُوا بِالْعُقُودِ﴾ [المائدة: 1]، ولما رُوي أنه ﷺ قال يوم فتح مكة: ""ما كان من حِلف في الجاهلية فتمسّكوا به؛ فإنه لم يزده الإسلام إلا شِدّة. ولا تُحدثوا حلفًا في الإسلام"" {21}، وقال ﷺ: ""شهدت حلف المطيبين {22} وأنا غلام مع عمومتي، فما أحب أن لي حُمر النَّعم وأني أنكثُه"" {23}.وقال سعيد بن المسيب في هذه الآية: إنما أنزل الله ذلك في الذين كانوا يتبنّون أبناء غيرهم وُيوَرِّثونهم، فأنزل الله فيهم أن يُجعل لهم نصيب من الوصية، ورد الميراث إلى الموالي من ذوي الرحم والعصبة، وأبى الله أن يجعل للمدّعَين {24} ميراثًا ممن {25} ادعاهم، ولكن جعل لهم نصيبًا من الوصية مكان ما تعاقدوا عليه في الميراث الذي رد عليهم فيه أمرهم {26}.وبمثل هذا قال الحسن {27}، واختار {28} ابن كيسان، فقال في قوله: ﴿وَالَّذِينَ عَقَدَتْ أَيْمَانُكُمْ﴾: هم {29} الأدعياء، وكان لهم ميراث الأولاد، فلما نزلت المواريث لم يذكروا فيها، فأوصى الله بهم {30}.فقد حصل في قوله: ﴿فَآتُوهُمْ نَصِيبَهُمْ﴾ ثلاثة أقوال، الأول: من الميراث، ثم نُسخ. والثاني: من النصر، والثالث: من الوصية، ولم ينسخ على هذين.وقوله تعالى: ﴿إِنَّ اللَّهَ كَانَ عَلَى كُلِّ شَيْءٍ شَهِيدًا﴾. قال عطاء: يريد: لم يغب عنه علم ما خلق وبرأ {31}."
  4,34,"قوله تعالى: ﴿الرِّجَالُ قَوَّامُونَ عَلَى النِّسَاءِ﴾. قال المفسرون: لطم رجل امرأته فجاءت إلى النبي ﷺ تطلب القصاص فنزلت هذه الآية {1}.ومعنى ﴿قَوَّامُونَ عَلَى النِّسَاءِ﴾: متسلطون {2} على تأديبهن والأخذ فوق أيديهن {3}.قال ابن عباس: يعني أمِّروا عليهن، فعلى المرأة أن تطيع زوجها في طاعة الله {4}.والقوّام المبالغ في القيام، يقال: هذا قَيِّم المرأة وقوّامها، الذي يقوم بأمرها ويحفظها {5}. أنشد الزجاج:الله بيني وبين قيِّمها ... يفرّ مني بِهَا وأتَّبِعُ {6} قالوا: وليس بين الزوج والمرأة قصاص إلا في النفس والجرح.وقال الزهري: لا قصاص بينهما إلا في النفس، فأما في الجِراحة فالدية ولا قِصاص {7}.وكان النبي ﷺ أوجب القصاص على الزوج باللّطْم، فلما نزلت هذه قال: ""أردنا أمرًا وأراد الله أمرًا، والذي أراد الله خير"" ورفع القصاص {8}.وقوله تعالى: ﴿بِمَا فَضَّلَ اللَّهُ بَعْضَهُمْ عَلَى بَعْضٍ﴾. قال ابن عباس: يريد الله بما فضل الله الرجال على النساء {9}.قالوا: بالعقل والعلم والعزم والقوة في التصرف والجهاد والشهادة والميراث {10}.وقوله تعالى: ﴿وَبِمَا أَنْفَقُوا مِنْ أَمْوَالِهِمْ﴾. يريد المهور والإنفاق عليهن، فالرجل له الفضل على امرأته بما ساق إليها من المهر وبما أنفق عليها من ماله {11}.وقوله تعالى: ﴿فَالصَّالِحَاتُ قَانِتَاتٌ﴾. قال المفسرون: مطيعات لأزواجهن {12}. وأصل القنوت دوام الطاعة {13}.وقال الزجاج: قيمات بحقوق أزواجهن {14}.وظاهر هذا إخبار، وتأويله الأمر لها بأن تكون طائعة {15}. ولا تكون المرأة صالحة إلا إذا كانت مُطيعةً لزوجها؛ لأن الله تعالى قال: ﴿فَالصَّالِحَاتُ قَانِتَاتٌ﴾ أي: الصالحات من اللواتي يُطِعن أزواجهن.والقنوت لفظ الطاعة. وهو عام في طاعة الله، وطاعة الزوج {16}.وقوله تعالى: ﴿حَافِظَاتٌ لِلْغَيْبِ﴾.قال ابن عباس: يعني لا تدخل منزله من يكره، ولا تُوطئ فراشه أحدًا غيره، وتحفظه في نفسها وفيما يحق له بما استودعها الله {17}.وقال قتادة وعطاء وسفيان {18}: أي حافظاتٌ لما غاب عنه أزواجهن من المال، وما يجب من ضيافة {19} نفسها له {20}.وقال أبو روق {21}: يعني يحفظن فروجهن في غيبة أزواجهن {22}.والغيب ههنا مصدر بمعنى المفعول، وهو المَغِيب عنه.وقوله تعالى: ﴿بِمَا حَفِظَ اللَّهُ﴾. قال المفسرون: أي بما حفظهن الله في إيجاب المهر والنفقة لهن، وإيصاء الزوج بهن. ومعنى هذا أن الله راعاهن في حقوقهن وأوصى بهن إلى الأزواج، فعليهن في مقابله الحفظ للغيب وطاعة الله والزوج {23}.وما في قوله: ﴿بِمَا حَفِظَ اللَّهُ﴾ يحتمل أن يكون بمعنى الذي، والعائد (إليه) {24} من الصلة محذوف، على تقدير: بما حفظ الله لهن، ويكون (ما) عبارة عما راعى الله لهن من حقوقهن.ويحتمل أن يكون (ما) غير موصول، بمعنى المصدر، أي بحفظ الله {25}، وعلى هذا التقدير يحتمل معنيين آخرين: أحدهما: أنهن حافظات للغيب بحفظ الله إياهن، أي لا يتيسر لهن حفظ الغيب إلا بتوفيق الله، وأن يحفظهن الله حتى لا يضيعن، فيكون هذا من باب إضافة المصدر إلى المفعول {26}.وقوله تعالى: ﴿وَاللَّاتِي تَخَافُونَ نُشُوزَهُنَّ﴾. قال ابن عباس: يريد تعلمون نشوزهن {27}.قال الفراء: وهو كالظن؛ لأن الظانّ كالشاكّ والخائف قد يرجو، فلذلك ضارع الخوف الظن والعلم، ألا ترى أنك تقول للخبر يبلغك: أما والله لقد خِفت ذاك، وأنشد:أتاني كلامٌ عن نُصيبٍ يَقولُه ... وما خِفْت يا سلَّام أنك عائِبِي {28}كأنه قال: وما ظننت أنك عائبي {29}.ومضى الكلام في الخوف بمعنى العلم.ويحتمل أن يكون الخوف ههنا الذي هو ضد الأمن، كأنه قيل: تخافون نشوزهن لعلمكم بالأحوال المؤذية {30} به {31}.قال محمد بن كعب {32} {33}: والنشوز ههنا معصية الزوج في قول الجميع {34}.قال عطاء: هو أن لا تتعطّر له وتمنعه من نفسها، وتتغيّر عن أشياء كانت تفعلها به وعما كان يستلذ منها {35}.وأصل النشوز الترفع على الزوج بالخلاف، من قولهم: نشز الشيء، أي ارتفع، ومنه يقال للمرتفع من الأرض نشز {36}.وقوله تعالى: ﴿فَعِظُوهُنَّ﴾. قال الكلبي: فعظوهن بكتاب، وذكروهن اللهَ وما أمرهن به {37}.وقوله تعالى: ﴿وَاهْجُرُوهُنَّ فِي الْمَضَاجِعِ﴾. قال أبو زيد: هَجر الرجل هجرًا إذا تباعد ونأى {38}.وقال ابن المظفر: الهَجْر من الهجران وهو ترك ما يلزمك تعاهدُه {39}.قال ابن عباس وعكرمة والضحاك والسدي: المراد بالهجر ههنا أن يهجر كلامها، فلا يكلمها في المضجع {40}.قال ابن عباس: الهَجر أن لا يجامعها، ويوليها ظهره على الفراش، (ولا يكلمها) {41} {42}.وقال الشعبي ومجاهد وإبراهيم: المراد به هجر المضاجعة {43}، يقول: فرِّقوا بينكم وبينهن في المضاجع.وهذا اختيار أبي إسحاق؛ لأنه قال في قوله: ﴿وَاهْجُرُوهُنَّ فِي الْمَضَاجِعِ﴾: أي في النوم معهن والقرب منهن، فإنهن إن كن يحببن أزواجهن شق عليهن الهجران في المضاجع، وإن كن مبغضات وافقهن ذلك، فكان ذلك دليلًا على أن النشوز منهن {44}.وروى أبو الضحى {45} ومسروق عن ابن عباس، قال: هذا كله في المضجع، إذا هي عصت أن تضطجع معه {46}. والمعنى على هذا: واللاتي تخافون نشوزهن في المضاجع فعظوهن واهجروهن واضربوهن.والمضاجع جمع المضجَع، وهو الموضع الذي يُضطجع عليه. وذكرنا ذلك فيما تقدم.وذهب الكلبي وسعيد بن جبير إلى أنّ قوله: ﴿وَاهْجُرُوهُنَّ﴾ من الهجر الذي هو بمعنى القبيح من الكلام، يريد عنّفوهن وغلّظوا في القول لهن {47}.وقوله تعالى: ﴿وَاضْرِبُوهُنَّ﴾. يعني ضربا غير مبرح بإجماع {48}.قال ابن عباس: أدبًا بمثل اللكزة {49}.قال القُرخي، عن علي - رضي الله عنه -: يعظُها بلسانه، فإنْ انتهت فلا سبيل له عليها، وإن أَبَت هَجَر مضجعًا، فإن أَبَت ضربها، فإن أبت أن تتّعظ بالضرب بُعِثَ الحكمان {17}. فللزوج أن يتلافى نشوز امرأته بما أذِنَ الله له فيه. وكان رسول الله ﷺ قال: ""لا تضربوا إماءَ الله"" {51}.ونهى عن ضرب النساء حتى ذَئِر النساء على أزواجهن {52}، فشكوا إلى رسول الله ﷺ، ونزلت الآية في ضربهن {53}.وقوله تعالى: ﴿فَإِنْ أَطَعْنَكُمْ﴾. أي فيما يُلتَمس منهن. وقال السدي: أتينَ فُرشَكم {54}.وقوله تعالى: ﴿فَلَا تَبْغُوا عَلَيْهِنَّ سَبِيلًا﴾. قال ابن عباس: لا تتجنّوا عليهن العِلَل {55}.وقال عطاء: يريد ليس لك عليها سبيل في هجرها في المضجع، ولا في ضربها {17}.وقال الكلبي وسفيان بن عيينة: لا تُكلِّفوهن الحبّ لكم {57}.وقال الزجاج: لا يطلب عليهن طريق عنت {58}. وهذا جامع للأقوال كلها"
  4,35,"قوله تعالى: ﴿وَإِنْ خِفْتُمْ شِقَاقَ بَيْنِهِمَا﴾. قال ابن عباس: يريد علمتم {1}. وذكرنا الخوف بمعنى العلم آنفًا.قال الزجاج: (خفتم) ههنا بمعنى: (أيقنتم) خطأ {2}؛ لو علمنا الشقاق على الحقيقة لم يُحتج {3} إلى الحكمين، وإنما يُخاف الشقاق {4}.وليس الأمر على ما قال أبو إسحاق؛ فإن الخوف ههنا بمعنى العلم صحيح، وكذلك يجب أن يكون؛ لأن بعثة الحكمين إنما تكون إذا علمنا شقاقًا بينهما، ولكن لا نعلم أيهما المتعدي الظالم، فيُبعث الحكمان ليتعرفا ذلك، وقبل وقوع الشقاق ليس حاله بعثة الحكمين. فقول أبي إسحاق: (لو علمنا الشقاق على الحقيقة لم يُحتج إلى الحكمين) وهم؛ لأنا نحتاج إلى الحكمين في هذه الحالة، وحيث نعلم المُشَاقّ بين الزوجين من هو لم يُحتج إلى الحكمين.ولم يفصل الزجاج بين الحالتين، والذي في الآية إذا علمنا شقاقًا بينهما، ولم نعلم من أيهما ذلك الشقاق، وكلام ابن عباس شديد {5} والمنِكر وَاهِم.والشقاق: العداوة والخلاف، كالمشاقّة. واشتقاقه من أن المشاقين {6} كل واحد منهما في شق غير شق صاحبه {7}.والمعنى: شقاقًا بينهما، فأضيف المصدر إلى الظرف، وإضافة المصادر إلى الظروف جائزة، لحصولها فيها، كقولك: يعجبني صوم يوم عرفة، وسير الليلة المقمرة {8}.وقوله تعالى: ﴿فَابْعَثُوا حَكَمًا مِنْ أَهْلِهِ﴾. قال سعيد بن جبير والضحاك: المأمور ببعث الحكمين السلطان الذي يترافع الزوجان فيما شجر بينهما إليه {9}.والحكم بمعنى الحاكم، وهو المانع من الظلم {10}، ومنه المثل السائر: في بيته يُؤتى الحكم {11}.قال ابن عباس: يريد من أهل الفضل {12}.يعني أن الحكم يجب أن يكون فاضلًا، يعرف ما لأحد الزوجين على الآخر، ويعرف أحكام العِشرة {13}.وقوله تعالى: ﴿مِنْ أَهْلِهِ﴾، و ﴿مِنْ أَهْلِهَا﴾. أي من أقارب هذا وأقارب تلك.قال ابن عباس: فإذا التقى الحكمان قال أحدهما للآخر: ادخل على قريبتك، فقل لها تخبرك الذي نقمت على زوجها، وقل لها: ألك فيه حاجة؟، وإلا فنحن ندخل فيما بينكما حتى يفارقك، وإن كان لك به حاجة فنحن نرده إلى ما تحبين.ويقول الآخر لصاحبه: القَ قريبَك، فقل له: ألك في أهلك حاجة؟. فيخلو حَكَمُ الرجل بصاحبه، فيقول {14}: أخبرني ما في نفسكَ، أتهواها أم لا؟ فإني لا أدري ما أقول في أمركَ، حتى أستطلع رأيكَ. فإن كان الرجل كارهًا قال: لا حاجة لي فيها، خُذ لها مني ما استطعت وفرِّق بيني وبينها. فيعرف عند ذلك أن النشوز جاء من قبله. وإن قال: إني أهواها، فأرضِها من مالي بما أرادت، ولا تفرِّق بيني وبينها، علم أنه ليس بناشز.ويخلو حكم المرأة بالمرأة، فيقول: أعلميني ما في نفسك، أتهوَين زوجكِ أم لا؟ فإني لا أدري ما أقول في أمركِ حتى أستَطلع رأيكِ فيه، فإن كانت هي الناشزة، قالت: أنشدك الله أنْ تُفرِّق بيني وبينه، أعطه ما أراد من مالى، فلا حاجة لي فيه. فإذا قالت ذلك علم أنها ناشزة. وإن لم تكن ناشزة، قالت: إني أهواه، ولكني أستزيده في نفقتي، فعِظه وحُثّه عليّ بخير، فإنه إليّ مسيء.فإذا كان النشوز من قبل المرأة أقبلا عليها، فقالا لها: يا عدو الله، أنتِ العاصية الظالمة لزوجك، المسيئة لنفسكِ، فوالله لا ينفق عليكِ أبدًا ولا يجامعك، حتى ترجعي عن فعلك وتفيئي إلى الله، فلا يأتيها زوجها ولا ينفق عليها حتى ترجع إلى الحق. وإن كان النشوز من قبل الرجل أقبلا عليه، فقالا: أنت العاصي لله المبغض لامرأتك، الظالم لنفسك، نفقتها عليك أبدًا ما دامت، ولا تدخل لها بيتًا، ولا ترى لها وجهًا، حتى تفيء إلى أمر الله وترجع عما أنت عليه. ثم يأخذانه بنفقتها ما دام على حاله حتى يرجع، فإذا رجع جَمَعَا بينه وبينها {15}.وقوله تعالى: ﴿إِنْ يُرِيدَا إِصْلَاحًا يُوَفِّقِ اللَّهُ﴾ بين الزوج والمرأة.فالكناية في ﴿بَيْنِهِمَا﴾ تعود على الزوجين. وأجاز بعضهم فيما حكاه ابن حبيب {16} أن تعود الكناية على الحكمين {17}. فيكون المعنى: يوفق الله صلاحًا للزوجين بين الحكمين {18}.ومذهب عمر - رضي الله عنه - أيضًا هذا، وهو أن المعني بإرادة الإصلاح الحكمان.وقد رُوي أنه بعث حكمين بين زوجين فرجعا وأخبراه أن الزوجين لم يصطلحا، فعلاهما بالدرّة وقال: لو أردتما إصلاحًا وفق الله بينهما.فرجعا وأخلصا، فإذا الزوجان قد أغلقا الباب دونهما واصطلحها {19}وهذه القصة تُقوي عود الكناية إلى الزوجين. هذا إذا أراد الحكمان إصلاحًا ورأيا ذلك.فإن أدى اجتهادهما إلى التفريق، فقد اختلف العلماء في ذلك:فمذهب عثمان وعلي رضي الله عنهما وسعيد بن جبير والشعبي والسدي وإبراهيم وشريح: أن لهما التفريق بينهما بالطلاق إن رأياه؛ لأن التحكيم توكيل {20}.قال عبيدة السلماني: شهدت عليًا - رضي الله عنه - وجاءته امرأة وزوجها، مع كل واحد منهما فِئَامٌ من الناس، فقال: ما شأنهما؟ فأُخْبِرَ بالشقاق بينهما، فقال: ابعثوا حكمًا من أهله وحكمًا من أهلها، ثم قال للحكمين: أتدريان ما عليكما؟ إن عليكما إن رأيتما أن تفرقا فرقتما، وإن رأيتما أن تجمعا جمعتما. فقالت المرأة: رضيتُ بما في كتاب الله عليّ ولي {21}. وقال الزوج: أما الفُرقة فلا. فقال علي: كذبتَ حتى تُقِرّ بمثل الذي أقرت {22} به {23}.والظاهر من هذا الكلام أن عليًا - رضي الله عنه - رأى الفُرقة من غير رضا الزوج، ولذلك قال: كذبت، ولم يقل: فلا أبعث الحكمين حتى ترضى.وإذا تعذر تنفيذ العقد بأحكامه فالوجه رفعه، وهذا هو الظاهر الصحيح من مذهب الشافعي -رحمه الله- الذي نص عليه في كتاب الطلاق من أحكام القرآن {24}، وهو اختيار المزني {25} {26}.وقال الحسن: الحكمان يحكمان في الاجتماع ولا يحكمان في الفرقة إلا بأمرهما {27}. وهذا أحد قولي الشافعي، وقد نص عليه في ""المُختصر""، وقال: لا بد من توكيل الزوج في الطلاق؛ لأنّ الطلاق إلى الأزواج {28}.قال الزجاج: وحقيقة أمر الحكمين أنهما {29} يقصدان الإصلاح، وليس لهما طلاق، وإنما عليهما أن يُعَرِّفا الإمام حقيقة ما وقفا عليه؛ فإن رأى الإمام أن يُفرِّق فرّق، وإن رأى أنْ يجمع جمع، وإن وكّل الحكمين بتفريق أو جمع فهما بمنزلته.والذي فعله عليّ رحمه الله من قوله: وإن رأيتما أن تفرقا فرقتما، تولية منه إياهما ذلك {30}.وقوله تعالى: ﴿يُوَفِّقِ اللَّهُ بَيْنَهُمَا﴾ {31} معنى التوفيق في اللغة هو تيسير وَفق الشيء، وهو ما يوافقه، أي يساوي حَالَته، ويقال: حَلوبَة فلان وَفق عياله، أي يخرج من لبنها ما يكفي عياله، على معنى أن ذلك مساوٍ لقدر حاجته {32}.قال الراعي:أما الفقير الذي كانت حَلُوبته ... وَفقَ العِيَال فلم يُترك له سَبَدُ {33}فالموافقة المواساة {34} في أمر من الأمور. والتوفيق بين النفسين إصلاحٌ بينهما لمساواة فيه. وقوله تعالى: ﴿جَزَاءً وِفَاقًا﴾ [النبأ: 26]، أي: على وَفق أعمالهم.الليث يقول: لا يتوفق عبدٌ حتى يوفقه الله، وإن فلانًا موفّق رشيد {35}.ووَفق كل شيء ما يكون متفقًا معه، كقوله:يَهوِين شَتَّى ويقَعنَ وفْقًا {36}وقوله تعالى: ﴿إِنَّ اللَّهَ كَانَ عَلِيمًا خَبِيرًا﴾. قال ابن عباس: يريد: عليمًا بما في قلوبهم من المودة، وخبيرًا بما يكون إذا هو طلّقها من وُجْدِه عليها، أو وُجدِها عليه {37}."
  4,36,"وقوله تعالى: ﴿وَاعْبُدُوا اللَّهَ وَلَا تُشْرِكُوا بِهِ شَيْئًا وَبِالْوَالِدَيْنِ إِحْسَانًا﴾. قال الزجاج المعنى: أوصاكم الله بعبادته، وأوصاكم بالوالدين إحسانًا {1}.وقال الفراء: وأحسنوا بالوالدين إحسانًا. أمرهم بالإحسان {2}.قال ابن عباس: يريد البِرّ بهما مع اللطف ولين الجانب، ولا يُغلظ لهما الجواب، ولا يُحدّ إليهما النظر، ولا يرفع صوته عليهما، كما قال الله: ﴿وَاخْفِضْ لَهُمَا جَنَاحَ الذُّلِّ مِنَ الرَّحْمَةِ﴾ [الإسراء: 24] يكون بين أيديهما ذليلًا مثل العبد بين يدي السيد الفظّ الغليظ، تذلّلًا لهما مع المحبة {3}.﴿وَبِذِي الْقُرْبَى﴾، القربى مصدر كالقرابة {4}، ومثله البُشرى والرُّجعى.قال ابن عباس: يصله ويعطف عليه {5}. وقال الزجاج: أمر الله: عز وجل بالإحسان إلى ذوي القرابة بعد الوالدين {6}.﴿وَالْيَتَامَى﴾، قال ابن عباس: يرفق بهم ويدنيهم ويمسح رأسهم.﴿وَالْمَسَاكِينِ﴾، قال: يريد: بَذْلُ يسر، أو ردّ جميل {3}.﴿وَالْجَارِ ذِي الْقُرْبَى﴾، قال عامة المفسرين: يعني القريب في النسب، الذي يبنك وبينه قرابة، وله حقوق؛ حق القرابة وحق الجوار وحق الإسلام {8}.ودل كلام الزجاج على أنه أراد بالقُربى ههنا قرب الدار والمعرفة والاختلاط، لأنه قال: هو الذي يقاربك ويعرفك {9}. ويُقوي هذا أنه قابله بالجار الغريب في قوله: ﴿وَالْجَارِ الْجُنُبِ﴾، فكما أن الغريب لا يعرفك لبعد داره فالجار ذي القربى هو الذي يعرفك لقرب داره وأرضه من دارك وأرضك {10}.والذي عليه المفسرون هو الأول.وقوله تعالى: ﴿وَالْجَارِ الْجُنُبِ﴾.الجنب نعت على فعل، مثل: (أُحُد) في: ناقةٌ أُحُد، وبابٌ غُلُق {11}، وقارورةٌ فُتُح. وأصله من الجنابة ضدّ القرابة، وهو البُعد {12}.قال علقمة بن عبدة {13}:فَلا تَحْرمنِّى نَائِلًا عن جَنَابةٍ ... فإني امرؤٌ وَسْط القِبَاب غَريبُ {14}وقال الأعشى {15}:أتيتُ حُريثًا زائرًا عن جنابةٍ ... وكان حُرَيثٌ عن عَطَائِيَ جَامِدًا {16} وقال آخر:كِرامٌ إذا ما جئتَهم عن جنابةٍ ... أعفّاءُ عن جار الخليطِ المجاور {17}ورجل جُنُب، إذا كان غريبًا متباعدًا عن أهله. وقوم أجناب، ورجل أجنَب وأجنبي، وهو البعيد منك في القرابة {18}. وأصل الجنب التنحية والإبعاد، ومنه قوله: ﴿وَاجْنُبْنِي وَبَنِيَّ أَنْ نَعْبُدَ الْأَصْنَامَ﴾ [إبراهيم: 35]. والجانبان الناحيتان لتنحّي كل واحدة {19} عن الأخرى {20}.وروى المفضَّل عن عَاصم {21}: ﴿وَالْجَارِ الْجُنُبِ﴾ بفتح الجيم وسكون النون {22}، وهو يحتمل معنيين:أحدهما: أن يريد بالجنب الناحية، ويكون المعنى على هذا: ذي الجَنْب، فحذف المضاف؛ لأن المعنى مفهوم، ألا ترى أن الناحية لا يكون الجار إياها، والمعنى: ذي ناحية ليس هو الآن بها، أي: هو غريب {23}.والآخر: أن يكون وصفًا، مثل: ضرب وندب وفسل {24}، فهذا وصف جري على الموصوف، كما أن الجنب كذلك {25}.قال ابن عباس وعامتهم: الجار الجنب هو الذي ليس بينك وبينه قرابة {26}. وله حق الجوار، فإن كان من أهل دينك فله حق الإيمان {27}.ومعنى وصفه بالبُعد ههنا أنه ليس من قومك، ونَسبُه بعيد عنك، ألا ترى أن مجاهدًا وقتادة قالا: هو جارك من قوم آخرين {28}.ويحتمل أن يُراد بهذا البُعد بُعد الدار، وهو الغريب من بلد غير بلدك يجاورك، فهو متباعد عن أهله وبلده.وإلى هذا ذهب الزجاج، فإنه قال: هو الجار الغريب {29} المتباعد {30}.وحكى ابن جرير عن نَوفٍ البِكَالي {31} أنه ذهب إلى أن المراد بهذا البُعد بُعد الدين، فقال في الجمار الجنب: إنه الكافر {32}. وقد قال النبي ﷺ في المشرك الجار: ""له حق الجِوَار وإن كان مشركًا"" {33}.وقوله تعالى: ﴿وَالصَّاحِبِ بِالْجَنْبِ﴾. قال ابن عباس وسعيد بن جبير ومجاهد وقتادة والحسن والسدي والضحاك: هو الرفيق في السفر {34}.قال عطاء عن ابن عباس: يريد صاحبك في السفر، وهو جارك إلى جانبك، فله حق الجوار وحق الصحبة {35}.وهذا اختيار الفراء {36} والزجاج {37} وابن قتيبة {38}.وقال علي وابن مسعود وابن أبي ليلى {39} وإبراهيم: هو زوجتك تكون معك إلى جنبك {40}.وقال ابن جريج وابن زيد: هو الذي يلزمك ويصحبك رجاء خيرك ونفعك {41}.وقوله تعالى: ﴿وَابْنِ السَّبِيل﴾. هو الضيف، يجب قِراه إلى أن يبلغ حيث يريد.قال ابن عباس ومجاهد والربيع: يريد عابر السبيل، تُروِيه وتُطعِمه حتى يرحل عنك {42}.﴿وَمَا مَلَكَتْ أَيْمَانُكُمْ﴾ يعني المماليك.قال ابن عباس: يريد المملوك، تُحسن رزقَه وتحتمل مساوئه وتعفو عنه فيما يُخطئ، فإن لاءمك فاحسبه وأنت مُحسن، وإن خالفك في الملاءمة فبعه لعله يوافق غيرك وتبرأ من إثمه {3}.وروى عمر بن الخطاب أن رسول الله ﷺ قال: ""من ابتاع شيئًا من الخدم فلم يوافق شيمته شيمته فليبع ويشتر حتى يوافق شيمته شيمته، فإن الناس شِيمَ، ولا تعذبوا عباد الله"" {3}.وقوله تعالى: ﴿إِنَّ اللَّهَ لَا يُحِبُّ مَنْ كَانَ مُخْتَالًا فَخُورًا﴾ [النساء: 36] المختال: ذو الخيلاء والكبر {45}.قال ابن عباس: يريد بالمختال العظيم في نفسه، الذي لا يقوم بحقوق الله {46}.قال الزجاج: وإنما ذكر الاختيال ههنا، لأنَّ المختال يأنف من ذوي قراباته إذا كانوا فقراء، ومن جيرانه إذا كانوا كذلك، فلا يُحسن عشرتهم {47}.وذكرنا اشتقاقه في اللغة عند قوله: ﴿وَالْخَيْلِ الْمُسَوَّمَةِ﴾ [آل عمران: 14].ومعنى الفخر في اللغة هو البذخ والتطاول، والفخور الذي يعدِّد مناقبه كبرًا وتطاولًا {48}.قال ابن عباس: هو الذي يفخر على عباد الله بما خوّله الله من كرامته وما أعطاه من نعمته {49}."
  4,37,"قوله تعالى: ﴿الَّذِينَ يَبْخَلُونَ وَيَأْمُرُونَ النَّاسَ بِالْبُخْلِ﴾. جائز أن يكون موضع (الذين) نصبًا على البدل {1}. المعنى: أنَّ الله لا يحب من كان مختالًا فخورًا، ولا يحب الذين يبخلون.وجائز أن يكون رفعه على الابتداء ويكون الخبر: ﴿إِنَّ اللَّهَ لَا يَظْلِمُ مِثْقَالَ ذَرَّةٍ﴾ [النساء: 40]، أي لا يظلمهم مثقال ذرة. قاله الزجاج {2}.والأولى أن يكون مستأنفًا، لأنَّ الآية نازلة في اليهود {3}. ومعنى البُخل في كلام العرب منع الإحسان، وفي الشريعة منع الواجب {4}.وفيه أربع لغات: البَخْل مثل الفَقْر، والبَخَل مثل الكَرَم، والبُخْل مثل الفُقر، والبُخُل بضمتين. ذكره المبِّرد، وقال: ونظيره أرض جرز، وفيه اللغات الأربع {5}.وأجمعوا على أن الآية نازلة في اليهود {6}.واختلفوا في معنى هذا البخل، فذكر فيه قولان: أحدهما: أن المراد به البخل بالعلم. وهو قول سعيد بن جبير والكلبي ومقاتل.قال سعيد: هذا في العلم ليس في الدنيا منه شيء {7}.وقال الكلبي: هم اليهود، بخلوا أن يصدقوا من أتاهم صفة محمد ﷺ ونعته، وأمروا قومهم بالبخل، وهو كتمان أمره {8}.وقال مقاتل: ﴿الَّذِينَ يَبْخَلُونَ﴾ رؤوس اليهود، ﴿وَيَأْمُرُونَ النَّاسَ بِالْبُخْلِ﴾ كانوا يأمرون سفلتهم بكتمان نعت محمد ﷺ {9}.واختار الزجاج هذا القول، فقال: هم اليهود بخلوا بعلم ما كان عندهم من مبعث النبي ﷺ {10}.القول الثاني: أن هذا البخل معناه البخل بالمال. وهو قول ابن عباس وابن زيد {11}.قال ابن عباس في رواية عطاء: ثم ذكر اليهود فقال: ﴿الَّذِينَ يَبْخَلُونَ وَيَأْمُرُونَ النَّاسَ بِالْبُخْلِ﴾ يريد يبخلون بأموالهم عمن هو دونهم من المؤمنين في المال، وهو أكرم على الله منهم {12}.وقال في رواية غيره {13}: نزلت في رؤساء اليهود؛ كانوا يأتون رجالًا من الأنصار ينتصحونهم {14}، ويقولون لهم: لا تُنفقوا أموالكم فإنا نخشى عليكم الفقر، ولا تدرون ما يكون {15}.وروي مثل هذا القول عن مجاهد والسدي، قالا: هم اليهود بخلوا بما أعطوا من الرزق {16}وقوله تعالى: ﴿وَيَكْتُمُونَ مَا آتَاهُمُ اللَّهُ مِنْ فَضْلِهِ﴾ قال ابن عباس: يريد العلم بما في التوراة مما عظم الله به أمر محمد ﷺ وأمته {17}.وقال مقاتل: يعني ما في التوراة من أمر محمد ونعته {18}.وهذا قول عامة المفسرين، فالفضل ههنا هو ما أوتوا من العلم، برسالة النبي ﷺ."
  4,38,"قوله تعالى: ﴿وَالَّذِينَ يُنْفِقُونَ أَمْوَالَهُمْ رِئَاءَ النَّاسِ﴾ الآية. إن شئت عطفت الذين في هذه الآية على الذين في الآية التي قبلها، وإن شئت جعلته في موضع الخفض عطفا على قوله: ﴿لِلْكَافِرِينَ عَذَابًا مُهِينًا﴾ {1}.قال السدي: نزلت في المنافقين {2}. واختاره الزجاج {3}، وهو الوجه؛ لذكر الرياء ههنا، وهو ضرب من النفاق، وقال بعضهم: نزلت في مشركي مكة المتفقين على عداوة رسول الله ﷺ {2}.وقوله تعالى: ﴿وَمَنْ يَكُنِ الشَّيْطَانُ لَهُ قَرِينًا﴾معنى القرين في اللغة هو الذي يقارنك ويُصاحبك {5}، من قولهم: قرنت الشيء بغيره إذا شددته إليه {6}.وقيل: إنما اتصل الكلام ههنا بذكر الشيطان تقريعًا لهم على طاعة الشيطان. وعلى هذا دل كلام أبي إسحاق؛ لأنه قال: أي من يكن عمله بما يُسول له الشيطان فبئس العمل عمله {7}.وقال الكلبي: هذا في الآخرة، يجعل الله الشياطين قرنائهم في النار، يقرن مع كل كافر شيطان في سلاسل النار {8}. يقول الله: ﴿وَمَنْ يَكُنِ الشَّيْطَانُ لَهُ قَرِينًا﴾ صاحبا ﴿فَسَاءَ قَرِينًا﴾ يقول: بئس الصاحب الشيطان.وقوله تعالى: ﴿فَسَاءَ قَرِينًا﴾ قد ذكرنا معنى ساء في هذه السورة. وانتصب (قرينًا) ههنا على التمييز والتفسير {9}؛ لأن (ساء) معناه (بئس)، و (بئس) تنصب النكرة، كقولك: بئس رجلًا زيد، لأنك إذا قلت: بئس، جاز أن تذكر رجلًا أو حمارًا، فإذا ذكرت نوعًا ميزته من سائر الأنواع {10}، وفيه ضمير فاعل لأنه فعل، والفعل لا يخلو من الفاعل، فصار المميِّز {11} كالمفعول فلهذا نصب. وقد استوفينا (القول) {12} في (نعم، وبئس)."
  4,39,"قوله تعالى: ﴿وَمَاذَا عَلَيْهِمْ لَوْ آمَنُوا بِاللَّهِ﴾ الآية. هذا احتجاج على هؤلاء الذين ذكرهم الله بأنهم لا يؤمنون بالله، والمعنى أن الإنسان يُحاسب نفسه فيما عليه وله، فإذا ظهر له ما عليه في فعل شيء من استحقاق العقاب، وما له في تركه من استحقاق الثواب عمل على ذلك في تركه والانصراف عنه.ومعنى الآية كأن الله تعالى يقول: ليتفكروا ولينظروا ماذا عليهم في الإيمان لو آمنوا؟ وهو استفهام في معنى الإنكار.ويصلح أن يكون (ما) و (ذا) اسمًا واحدًا، فيكون المعنى: وأي شيء عليهم {1}، ويجوز أن يكون (ذا) في معنى الذي، وتكون (ما) وحدها اسمًا، ويكون المعنى: وما الذي عليهم لو آمنوا {2}.وقد بسطنا الكلام في تفسير (ماذا) في موضعين في سورة البقرة {3}.وقوله تعالى: ﴿لَوْ آمَنُوا بِاللَّهِ وَالْيَوْمِ الْآخِرِ﴾.قال ابن عباس: يريد بنية صادقة، يصدِّق القلبُ اللسان، ويصدق اللسانُ القلب {4}.﴿وَأَنْفَقُوا مِمَّا رَزَقَهُمُ اللَّهُ﴾ يريد: يصدقوا مما تفضل الله به عليهم {5}.وقوله تعالى: ﴿وَكَانَ اللَّهُ بِهِمْ عَلِيمًا﴾. تأويله: لا ينفعهم ما ينفقونه على جهة الرياء؛ لأن الله بهم عليم مجاز لهم بما يسرون من قليل أو كثير {6}."
  4,40,"قوله تعالى: ﴿{إِنَّ اللَّهَ لَا يَظْلِمُ مِثْقَالَ ذَرَّةٍ﴾ الآية. قد ذكرنا أن الظلم يستعمل في معان كثيرة. وهو ههنا بمعنى النقص.قال ابن عباس: يريد لا ينقص مثقال ذرة {1}.والمثقال مقدار الشيء في الثِّقل. وهو مفعال من الثقل، يقال: هذا على مثقال هذا، أي وزن هذا. ومعنى ﴿مِثْقَالَ ذَرَّةٍ﴾: أي ما يكون وزنه وزن الذرة {2}.وأما الذرة فهي النملة الحميراء الصغيرة في قول أهل اللغة {3}، وهو قول ابن عباس {4} وابن زيد {5}.وروى يزيد بن الأصم {6} عن ابن عباس في هذه الآية قال: أدخل ابن عباس يده في التراب، ثم رفعها، ثم نفخ فيه فقال: كل واحدة من هؤلاء ذرَّة {7}.والمراد من هذا: لا يظلم قليلًا ولا كثيرًا، ولكن الكلام خرج على أصغر ما يتعارفه الناس، يدل على هذا قوله: ﴿إِنَّ اللَّهَ لَا يَظْلِمُ النَّاسَ شَيْئًا﴾ [يونس: 44].قال ابن عباس: نزل قوله: ﴿إِنَّ اللَّهَ لَا يَظْلِمُ مِثْقَالَ ذَرَّةٍ﴾ في المنافقين، وقوله تعالى: ﴿وَإِنْ تَكُ حَسَنَةً﴾ في المؤمنين. يقول: لا ينقص ﴿مِثْقَالَ﴾ {8} ذرة من عمل منافق إلا جازاه بها رواه عطاء عنه {9}.وقال آخرون: هذا على العموم {10}. ثم اختلفوا؛ فذهب بعضهم في تأويله إلى ما رواه أنس أن النبي ﷺ قال: ""وإن الله لا يظلم حسنة، أما المؤمن فيثاب عليها الرزق في الدنيا، ويجزى بها في الآخرة. وأما الكافر فيُطعم بها في الدنيا، فإذا كان يوم القيامة لم تكن له حسنة"" {11}.وذهب بعضهم إلى تأويل هذه الآية: إن الله لا يظلم مثقال ذرة للخصم على الخصم، بل يأخذ له ومنه، ولا يظلم مثقال ذرة تبقى للخصم، بل يثيبه عليها ويُضعفها له. واحتجوا بما روي عن ابن مسعود أنه قال: يُؤتى بالعبد يوم القيامة وينادي منادٍ على رؤوس الأولين والآخرين: هذا فلان بن فلان، من كان له عليه حق فليأت إلى حقه. ثم يقال له: آت هؤلاء حقوقهم. فيقول: يا رب من أين وقد ذهبت الدنيا. فيقول الله لملائكته في أعماله الصالحة: فأعطوهم منها، فإن بقي مثقال ذرة من حسنة ضعّفها الله تعالى لعبده وأدخله الجنة بفضل رحمته.ومصداق ذلك في كتاب الله ﴿إِنَّ اللَّهَ لَا يَظْلِمُ مِثْقَالَ ذَرَّةٍ﴾ {12}.وقوله تعالى: ﴿وَإِنْ تَكُ حَسَنَةً﴾. الأصل: وإن تكن (بالنون) كقوله: ﴿إِنْ يَكُنْ غَنِيًّا أَوْ فَقِيرًا﴾ [النساء: 135]، وذلك أن النون إذا سكنت {13} للجزم وسقطت الواو لسكونها وسكون النون فصار (تكن)، ويجوز حذف النون من تكن؛ لأنها ساكنة وهي تشبه حروف اللين، وحروف اللين إذا وقعت طرفًا سقطت، كقولك: لم أدر، وإن تدع. كذلك حُذفت هذه النون استخفافًا لكثرة الاستعمال كما قالوا: لا أدرِ ولم أبل، والأصل: لم أبال ولا أدري.ووجه شبه النون بحروف اللين أنَّ الغنة التي في النون كاللين الذي في حروف اللين، وأيضًا فإنها تحذف لالتقاء الساكنين، كما حذفوهن كلذلك في نحو: غزا القوم، وتغطي ابنك وتصبو {14} المرأة. ألا ترى أنك لم تظهر الألف ولا الباء {15} ولا الواو في اللفظ، بل حذفتهن لاجتماع الساكنين. وكذلك يفعلون في النون فيقولون: مِلآن، أي: من الآن {16}، وأنشد سيبويه:فلست بآتيه ولا أستطيعه ... ولكِ اسقني إن كان ماؤك ذا فضل {17}وأنشد قُطرب:لم يك الحق سوى أن هاجه ... رسم دار قد تعفى بالسِّرر {18}يريد بالأول: ولكن، والثاني: لم يكن، فلم يحرِّكا وحذفا.جعلوا النون أيضًا علمًا للرفع في نحو: يقومان ويقومون وتقومين، كما جعلوا الواو والألف علمًا له، نحو: أخوك وأبوك، والزيدان، والزيدون، إلى غير ذلك مما يطول ذكره {19}.وقرئ قوله: (حسنةٌ) بالرفع والنصب {20}، فمن رفع فهي اسم كان ولا خبر لها ههنا، وهي في مذهب التمام. على معنى: وإن تحدث حسنة، أو إن تقع حسنة. ومن نصب كان المعنى: وإن لَكن فعلتُه حسنةً.والنصب حسن، لتقدم ذكر (مثقال ذرة)، فتجعل الذرة اسمًا وحسنة الخبر، على تقدير: وإن تكن الذرة حسنةً يضاعفها الله {21}.قال ابن عباس: ﴿وَإِنْ تَكُ حَسَنَةً﴾ يريد: من مؤمن ﴿يُضَاعِفْهَا﴾ يريد: عشرة أضعافها {22}.وقال السدي: هذا عند الحساب والقصاص (فمن بقي له من الحسنات شيء يضاعفه بسبع مائة، وإلى الأجر العظيم {23}.ولهذا كان يقول بعض الصالحين: فُصَلت {24} حسناتي سيئاتي بمثقال ذرة أحب إلي من الدنيا وما فيها {25}) {26}.وقوله تعالى: ﴿وَيُؤْتِ مِنْ لَدُنْهُ أَجْرًا عَظِيمًا﴾ قال عطاء: يريد من عنده أجرًا عظيمًا يتفضل عليه بأكثر من العشرة الأضعاف {27}.وقال الكلبي: الأجر العظيم الجنة {28}.وقال الحسن: هذا أحب إلى العلماء؛ أن لو قال: الحسنة بمائة ألف وهو كقوله: ﴿لَيْلَةُ الْقَدْرِ خَيْرٌ مِنْ أَلْفِ شَهْرٍ﴾ [القدر: 3]، ولم يقل مثل ألف شهر {23}.وقال أبو عثمان النهدي {30}: بلغني عن أبي هريرة {31} أنه قال: إن الله عز وجل يُعطي عبده المؤمن بالحسنة الواحدة ألف ألف حسنة. فقضي أن انطلقت حاجًا أو معتمرًا، فلقيته فقلت: بلغني عنك أنك تقول: إن الله عز وجل يُعطي عبده المؤمن بالحسنة ألف ألف حسنة. قال أبو هريرة: لم أقل ذلك، ولكني قلت: إن الحسنة تضاعف ألفي ألف {32} حسنة ثم تلا هذه الآية وقال: إذا قال الله عز جل: ﴿أَجْرًا عَظِيمًا﴾ فمن يقدر قدره {33}.وسنذكر اللغات في لدن والكلام فيه في سورة الكهف إن شاء الله."
  4,41,"قوله تعالى: ﴿فَكَيْفَ إِذَا جِئْنَا مِنْ كُلِّ أُمَّةٍ بِشَهِيدٍ﴾. قال الزجاج والأكثرون: أي فكيف تكون حال هؤلاء القوم الذين ذكرهم الله من المنافقين والمشركين يوم القيامة، وحذف (تكون) لأنَّ في الكلام دليلًا على ما حذف.وكيف (لفظها) {1} لفظ الاستفهام، ومعناها ههنا التوبيخ {2}.والاستفهام كثيرًا ما يرد بمعنى التوبيخ، وقد (ذكرنا) {3} لم أجاز أن يتضمن الاستفهام التوبيخ والإنكار في مواضع مما مضى {4}.وقال صاحب النظم: هذا فصل منسوق فيه (على ما) {5} قبل من قوله: ﴿إِنَّ اللَّهَ لَا يَظْلِمُ مِثْقَالَ ذَرَّةٍ﴾ وتوكيدٌ لما تقدم من الخبر، وتحقيق لما بعده، على تأويل: إن الله لا يظلم مثقال ذرة، فكيف يظلمه إذا كان يوم القيامة؟ ففي قوله: (فكيف) طرف من الإنكار، أي أن ذلك لا يكون في وقت من الأوقات {6}.فعلى القول الأول {7} في (كيف) توبيخ للقوم الذين مضى ذكرهم، وعلى القول الثاني {8} فيه إنكار لظلم الله أحدًا.ومعنى قوله: ﴿وَجِئْنَا بِكَ عَلَى هَؤُلَاءِ شَهِيدًا﴾ قال ابن عباس: يريد: أتيناهم {9}.قال المفسرون: يُؤتى بنبي كل أمة يشهد عليها ولها {10}.وقوله تعالى: ﴿وَجِئْنَا بِكَ عَلَى هَؤُلَاءِ شَهِيدًا﴾. أي على هؤلاء المنافقين والمشركين الذين ذكرهم يشهد عليهم بما فعلوا {11}."
  4,42,"قوله تعالى: ﴿يَوْمَئِذٍ يَوَدُّ الَّذِينَ كَفَرُوا﴾ الآية. يوم في قوله: ﴿يَوْمَئِذٍ﴾ ظرف و""يود""، وهو مضاف إلى إذ، وذلك نحو قولهم: ليلتئذ، وساعتئذ، وحينئذ. ودخل التنوين في إذ بدلًا من الإضافة، وذلك أنَّ أصل هذا أن تكون إذ مضافة إلى جملة، إما من مبتدأ وخبر، نحو: جئتك إذ زيد أمير، وقصدتك إذ الخليفة عبد الملك، قال الله تعالى: ﴿إِذِ الْأَغْلَالُ فِي أَعْنَاقِهِمْ﴾ [غافر: 71]، وقال القطامي {1}:إذا الفوارسُ من قيس بشكَّتها ... حولي شهودٌ وما قومي بشهاد {2}وإما من فعل وفاعل نحو: قمت إذ قام {3} زيد، وجلست إذ سار محمد. قال الله تعالى: ﴿وَإِذْ قَالَ رَبُّكَ لِلْمَلَائِكَةِ﴾ [البقرة: 30]، ﴿وَإِذْ قَتَلْتُمْ نَفْسًا﴾ [البقرة: 72]، ثم اقتطع المُضاف إليه إذ في مثل هذا، ومثله قوله: {مِنْ عَذَابِ يَوْمِئِذ} [المعارج:11]، و ﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾ [الروم: 43].والتقدير في هذه الآية وفي غيرها: يوم إذ ذاك كذلك، فلما حذف المضاف إليه إذ عوّض منه التنوين، فدخل وهو ساكن على الذال وهي ساكنة، فكسرت الذال لالتقاء الساكنين فقيل: يومئذ. وليست هذه الكسرة في الذال كسرة إعراب، وإن كانت إذ في موضع جر بالإضافة ما قبلها إليها، وإنما الكسرة فيها لسكونها وسكون التنوين بعدها، كما كسرت الهاء في صهٍ ومهٍ لسكونها وسكون التنوين بعدها، وإن اختلفت جهتا التنوين فيهما، فكان في إذ عوضًا من المضاف إليه، وفي صه علمًا للتنكير، ويدل على أن الكسرة في ذال (إذ) إنما هي حركة التقاء ساكنين: (هي) {4} والتنوين قول الشاعر:نهيتُك عن طلابك أمَّ عمرو ... بعاقبة وأنت إذ صحيح {5}ألا ترى أن إذ في هذا البيت ليس قبلها شيء {6}.ومضى القول في (يود) عند قوله: ﴿يَوَدُّ أَحَدُهُمْ لَوْ يُعَمَّرُ﴾ {7} [البقرة: 96] {8}.وأما النقير {9} فقال ابن السكيت: النقير النكتة في ظهر النواة {10}.وقال أبو الهيثم: النقير نقرة في ظهر النواة، منها تنبت النخلة {11}.وذكرنا طرفًا منه عند ذكر الفتيل {12}. وأصله أنه فعيل من النقر وهو النكت، ومن هذا يقال للخشب الذي ينبذ {13} فيه نقير لأنه ينقر {14}. والنقر ضرب الرحى {15} والحجر وغيره بالمنقار. والمنقار حديدة كالفأس يُقطع بها الحجارة {16}. ومنه منقار الطائر؛ لأنه ينقر به {17}.وقول أهل التفسير موافق لقول أهل اللغة في تفسير النقير، وقول أبي الهيثم مثل قول ابن عباس حرفًا بحرف {18}.قال الزجاج: وذكر النقير ههنا تمثيل، المعنى: لضنُّوا بالقليل {19}."
