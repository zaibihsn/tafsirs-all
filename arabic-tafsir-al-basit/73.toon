  73,13,"73:11"
  73,14,"73:11"
  73,15,"قوله: ﴿إِنَّا أَرْسَلْنَا إِلَيْكُمْ﴾ يعني أهل مكة. ﴿رَسُولًا﴾ يعني محمدًا -ﷺ- ﴿شَاهِدًا عَلَيْكُمْ﴾ بالتبليغ وإيمان من آمن وأجاب، وامتناع من امتنع وعصى.﴿كَمَا أَرْسَلْنَا إِلَى فِرْعَوْنَ رَسُولًا﴾ وهو موسى عليه السلام.قال مقاتل: إنما ذكر فرعون، وموسى دونَ سائر الأمم {1} والرسل؛ لأن أهل مكة ازدرؤوا محمدًا {2} -ﷺ-، واستخفوا {1} به؛ لأنه ولد فيهم، كما أن فرعون ازدرأ {1} موسى؛ لأنه رباه، وولد فيما بينهم، وهو قوله: ﴿قَالَ أَلَمْ نُرَبِّكَ فِينَا وَلِيدًا﴾ [الشعراء: 18]. {5}قوله تعالى: ﴿فَأَخَذْنَاهُ أَخْذًا وَبِيلًا﴾ الوبيل: الثقيل الغليظ جدًّا، ومنه قولهم: صار هذا عليه وبالاً، أي أفضى به إلى غاية المكروه، ومن هذا قيل للمطر {1} العظيم: وابل، وكلأ مُستوبل {7}، إذا أن عاقبته إلى مكروه.(قاله المبرد {8}، والزجاج {9}) {10}.وقال أبو زيد: الوبيل: الذي لا يُسْتَمْرأ {11}، (وماء وبيل، ووخيم: إذا كان غير مري) {12}. وقال المفسرون {13}: أخذًا وبيلاً: شديدًا، يعني: الغرق. قاله الكلبي {14}، وقتادة {15}، ومقاتل {16}.يخوف أهل مكة بالعذاب، ثم خوفهم يوم القيامة:قوله تعالى: ﴿فَكَيْفَ تَتَّقُونَ إِنْ كَفَرْتُمْ﴾. (وفي الآية تقديم وتأخير {17}، على تقدير: فكيف تتقون يومًا يجعل (¬11) الولدان شيبًا إن كفرتم، والمعنى على تقدير المضاف (¬12): أي عذاب يوم، أي: بأي شيء تتحصنون من عذاب ذلك اليوم) {18}﴿إِنْ كَفَرْتُمْ﴾ قال قتادة: والله لا يتقي من كفر بالله ذلك اليوم {19}.قوله تعالى: ﴿يَجْعَلُ الْوِلْدَانَ شِيبًا﴾. وصف لهول ذلك اليوم الشديد، وهذا كما يقال: قد حدث أمر تشيب فيه النواصي، وشيب الصغير، مَثل للشدة العظيمة {20}.قال المفسرون {21}: وذلك حين يقال لآدم: (قم فأبعث بعث النار) {22}وذكرنا ذلك عند قوله: ﴿يَوْمَ تَرَوُنَهَا﴾ {23}.ثم وصف من هول ذلك اليوم، فقال: ﴿السَّمَاءُ مُنْفَطِرٌ بِهِ﴾.أي بذلك اليوم، يعني فيه. قاله الفراء {24}، وأبو حاتم {25}، وهذا كما قال: ﴿إِذَا السَّمَاءُ انْفَطَرَتْ (1)﴾ ومعنى منفطر: منشق {26}، (قال أبو عبيدة) {27} قال أبو عمرو بن العلاء: السماء منفطر، ولم يقل: منفطرة؛ لأن مجازها مجاز السقف، تقول: هذا سماء البيت {28}.وقال الفراء: (السماء تؤنث وتذكر، وهي -هاهنا- في وجوه التذكير، وأنشد {29}:فلو رَفَع السماءُ إليه قومًا ... لَحِقْنا بالنجومِ مع السحاب {30}) قال أبو علي الفارسي: (﴿مُنْفَطِرٌ بِهِ﴾) {31} ليس البخاري على الفعل، ولكن الذي للنسب، ويجوز أن تكون السماء جميعًا، فتكون من باب (الجراد المنتشر {32})، و (الشجر الأخضر {33})، و (أعجاز نخل منقعر {34}) (ذكر ذلك في المسائل الحلبية {35}) {36}.وقوله: ﴿كَانَ وَعْدُهُ مَفْعُولًا﴾قال مقاتل: يقول وعده بالبعث كائن {37} لابد {38}.قوله تعالى: ﴿إِنَّ هَذِهِ﴾قال مقاتل: يعني آيات القرآن {8}. ﴿تَذْكِرَةٌ﴾ تذكير وموعظة. ﴿فَمَنْ شَاءَ اتَّخَذَ إِلَى رَبِّهِ سَبِيلًا﴾، أي: بالطاعة والتصديق {1}.قوله تعالى: ﴿إِنَّ رَبَّكَ يَعْلَمُ أَنَّكَ تَقُومُ أَدْنَى مِنْ ثُلُثَيِ اللَّيْلِ﴾ {41} قال ابن عباس {8}، ومقاتل {38}: أقلّ، كقوله: ﴿أَتَسْتَبْدِلُونَ الَّذِي هُوَ أَدْنَى بِالَّذِي هُوَ خَيْرٌ﴾ {44} [البقرة: 61] {45}، وقد مَرَّ.قوله تعالى: ﴿وَنِصْفَهُ وَثُلُثَهُ﴾ (عطف على قوله: (أدنى {1}) و (أدنى) في موضع نصب {47}، والتقدير: تقوم أدنى من ثلثي الليل {48}، وتقوم نصفه وثلثه.ومن قرأ بالجر {49} حمله على الحال في قوله: ﴿مِنْ ثُلُثَيِ اللَّيْلِ﴾ والمعنى: أدنى من ثلثي الليل، ومن نصفه، وثلثه) {1}، والوجه القراءة الأولى {51}.قال ابن عباس: يريد: وتقوم نصفه وثلثه {52}.(وقال أبو الحسن: الذي افترض الثلث، وأكثر من الثلث {53}، والذين جروا كأن المعنى على قولهم: إنكم (لم) {54} تؤدوا ما افترض عليكم، فقمتم أدنى من ثلثي الليل، ومن نصفه، ومن ثلثه، وليس المعنى على هذا) {55}.وقال صاحب النظم: الأقل الذي افترض عليهم: الربع، لم ينقصوا من الربع على قول من قرأ بالجر {8}.وقوله: ﴿وَطَائِفَةٌ مِنَ الَّذِينَ مَعَكَ﴾ قال ابن عباس {8}، ومقاتل {38}: يعني أصحابه الذين آمنوا به، كانوا يقومون معه ثلثًا ونصفًا.﴿وَاللَّهُ يُقَدِّرُ اللَّيْلَ وَالنَّهَارَ﴾ (فيعلم مقدار ثلثه {1}، ونصفه، وثلثيه {60}، وسائر أجزائه ومواقيته) [[و {1} ما بين القوسين نقله الواحدي عن ابن قتيبة من ""تأويل مشكل القرآن"" 264.]].ويعلم أنكم: ﴿لَنْ تُحْصُوهُ﴾ (أي لن تطيقوا معرفة حقائق ذلك، والقيام فيه) (¬7).قال مقاتل: كان الرجل يصلي الليل كله مخافة أن لا يصيب ما أمر الله به من قيام ما فرض عليه، فقال الله تعالى {62}: ﴿عَلِمَ أَنْ لَنْ تُحْصُوهُ﴾ {63} و (أن) مخففة من الثقيلة على تقدير: أنكم لن تحصوه {8}. ﴿فَتَابَ عَلَيْكُمْ﴾ فعاد عليكم بالعفو والتخفيف.قال ابن عباس: فعفا عنكم ما لم تحيطوا بعلمه (¬11).وقال مقاتل: فتجاوز عنكم بالتخفيف {65}.﴿فَاقْرَءُوا مَا تَيَسَّرَ مِنَ الْقُرْآنِ﴾ قال ابن عباس: يريد غير النبي -ﷺ-، فسقط عن أصحاب النبي -ﷺ- قيام الليل، وصار تطوعًا، وبقي ذلك فرضًا على رسول الله {66} (ﷺ) {10}.وقال مقاتل: فاقرؤوا ما تيسر عليكم في الصلاة من القرآن من غير أن يوقت شيئًا {65}.قال الحسن: يعني في صلاة المغرب والعشاء {69}.وقالت عائشة (رضي الله عنها) {54} في هذه الآية: صار قيام الليل تطوعًا بعد أن كان فرضًا {71}.وروي عن الحسن {72} (والسدي {73}) {10} في تفسير: ﴿مَا تَيَسَّرَ مِنَ الْقُرْآنِ﴾ أنه مائة آية. ثم عذرهم، وذكر عذرهم، فقال: ﴿عَلِمَ أَنْ سَيَكُونُ مِنْكُمْ مَرْضَى﴾ يعني فلا يطيقون قيام الليل. ﴿وَآخَرُونَ يَضْرِبُونَ فِي الْأَرْضِ يَبْتَغُونَ مِنْ فَضْلِ اللَّهِ﴾ {75} يعني المسافرين للتجارة يطلبون من رزق الله، فلا يطيقون قيام الليل. ﴿وَآخَرُونَ يُقَاتِلُونَ فِي سَبِيلِ اللَّهِ﴾ يعني المجاهدين لا يطيقون قيام الليل.﴿وَآخَرُونَ يُقَاتِلُونَ فِي سَبِيلِ اللَّهِ فَاقْرَءُوا مَا تَيَسَّرَ﴾ {76} عليكم. ﴿مِنْهُ﴾ أي من القرآن.وقال (عبد الله بن مسلم) {10} بن قتيبة: رخّص لهم أن يقوموا ما أمكن وخفّ لغير مدة معلومة، ولا مقدار، وكان هذا في صدر الإسلام، ثم نسخ بالصلوات الخمس.(كذلك قال المفسرون {78}) {10}.وقوله: ﴿وَأَقِيمُوا الصَّلَاةَ﴾. قال مقاتل: يعني وأتموها لوقتها، فنسخ قيام الليل عن المؤمنين، وثبت على النبي {80} -ﷺ- خاصة {65}.وقال ابن عباس في قوله: ﴿وَأَقِيمُوا الصَّلَاةَ وَآتُوا الزَّكَاةَ﴾ يريد هذه فريضة عليكم في محلها، وفي أوقاتها {8}.﴿وَأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾. قال ابن عباس: يريد سوى الزكاة من صلة الرحم، وقرى الضيف {83}.وقال مقاتل: يعني الزكاة {1} يعطيها طيبة بها نفسه، وهو معنى قوله: (حسنًا) {65}.﴿وَمَا تُقَدِّمُوا لِأَنْفُسِكُمْ مِنْ خَيْرٍ﴾ قال {86}: يعني من صدقة فريضة كانت أو تطوع {87}.﴿تَجِدُوهُ عِنْدَ اللَّهِ هُوَ خَيْرًا﴾ قال {86}: تجدوا ثوابه في الآخرة أفضل مما أعطيتم {8}.وقال ابن عباس: تجدوه عند الله هو خيرًا وأعظم أجرًا من الذي تؤخر إلى وصيتك عند الموت {8}.وقال أبو إسحاق: وما تقدموا لأنفسكم من طاعة تجدوه خيرًا عند الله لكم من متاع الدنيا {91}، (والقول ما قال ابن عباس {92}).قوله تعالى: ﴿وَاسْتَغْفِرُوا اللَّهَ إِنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾ {93}، أي: لذنوبكم، إن الله غفور الذنوب للمؤمنين، رحيم بهم. (قاله مقاتل {94}) {10}.وقال ابن عباس: غفور رحيم لمن لم يصر على ذنب {8}."
