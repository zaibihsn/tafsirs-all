tafsir[200]{c,v,t}:
  3,1,"﴿الم﴾ اجتمعت القرّاء على فتح الميم، وإدراج ألفِ اللهِ في الوصل {1}، إلا ما رُويت {2} شاذًا عن عاصم: أنّه سكّن الميمَ وقَطَعَ الألف {3}.واختلفوا في عِلَّةِ فتح الميم: فقال الفراء {4}: طُرِحت عليها فتحةُ الهمزة؛ لأن نيّة حروف الهجاء الوقف. فَلَمَّا كان يُنوى بها الوقفُ، نُوي بما بعده الاستئنافُ، فكانت الهمزةُ في حُكْم الثَّبات {5}.ومذهب سيبويه {6}: أنه حُرَّك لالتقاء الساكِنَينِ {7}، والساكن الذي حُرّك له الميمُ، لامُ التعريف؛ وذلك أنَّ حُكْمَ هذه الهمزة، أن تُجتلَبَ في الابتداء، إذا احتيجَ إلى اللفظ بحرفٍ ساكنٍ، دون الصِّلَةِ والإدْراج، فإذا اتَّصلَ الساكنُ المُجتَلَبُ له هذا الحرفُ بشيءٍ قبله، استُغنِيَ عنه، فحُذِفَ. فإن اتّصَلَ بمتحرِّكٍ، بُنيَ على حركته {8}، نحو: (ذهبَ ابْنُك). وإنْ كان حرفًا ساكنًا -غيرَ لَيِّنٍ- حُرّكَ، نَحْوَ: ﴿عَذَابٍ (41) ارْكُضْ﴾ {9} [ص:41 - 42]، و ﴿وَأَلَّوِ اسْتَقَامُوا﴾ {10} [الجن: 16].فكذلك {11} الهمزة في أسماءِ اللهِ عزّ وجلّ مِن قوله: ﴿الم﴾، إذا اتَّصَلَ بما قبلها لزم حذفُها، كما لزم إسقاطُها فيما {12} ذكرنا. وإذا لزم حذفها، لزم حذفُ حركتها أيضًا؛ لأنك لا تجدُ هذه الهمزة المُجْتَلَبَة في موضع ملقاةً، وحركتَها مبقاةً. فإذا لزم حذفها، لم يجُزْ إلقاؤها على الحرف الساكن. فليس حركةُ الميم إذن {13} حركةَ الهمزة، وإذا لم تكن حركةَ الهمزة، ثبت أنها حركةُ التقاء الساكنَيْنِ.وأمّا ما احتج به الفرّاءُ مِن أنّ هذه الحروف موضوعةٌ على الوقف، وإذا كان كذلك وجب أنْ تثبت الهمزةُ ولا تحذَف، كما تثبت في الابتداء، فإذا لزم أن لا {14} تحذف كما لا تحذف {15} في الابتداء، لم يمتنع أن تُلْقَى حركتُها على ما قبلها. قيل: إنَّ وضعَ هذه الحروف {16} على الوقف، لا توجب {17} قطعَ ألفِ الوصل وإثباته {18} في المواضع التي تسقط فيها. وأنت إذا ألقيت حركته على الساكن، فقد وصلت الكلمة التي هي فيها بما قبلها، وإنْ كان ما قبلها موضوعًا على الوقف.فقولك: (ألقيت حركته عليه) بمنزلة قولك: (وَصَلْتُه)، ألا ترى أنك إذا خفَّفْتَ (مَنْ أَبُوكَ)، قلتَ: (مَنَ بُوك) فَوَصَلْتَ، ولو {19} وَقَفْتَ لم تُلقِ الحركةَ عليها، فإذا {20} وصلْتَها بما قبلها، لَزِمَ إسقاطُها، وكان إثباتُها مخالفًا لأحكامها في سائرِ مُتَصَرفاتها {21}.ويقوي قولَ الفراء ما حكاه سيبويه {22} مِن قولهم: (ثَلَثَهَرْبَعَة) {23} ألاَ ترى أنهم أجروا الوصل في هذا مجرى الوقف؛ حيث ألقَوا حركة الهمزة على التاء التي للتأنيث، وأبقوها هاءً، كما تكون في الوقف، ولم يقلبوها تاءً {24}؛كما يقولون في الوصل: (هذه ثلاثتك) كذلك ههنا لَمّا كانت النيّةُ في الميم الوقفَ، وفيما بعدها الاستئنافَ، كانت الهمزةُ في حُكْمِ الثَبَات، فأُلقِيَت حَرَكَتُها على الميم. فله حُكْم الوقف مِن وَجْهٍ، وحُكْمُ الوَصْلِ مِن وَجْهٍ؛ كما كان في (ثَلَثَهَرْبَعَة) {23}، له حُكْمُ الوصل؛ من حيث إلقاء حركةِ الهمزة على (الهاء)، وحُكْم الوقف، حيث أبقوا الهاءَ على حالها {26}.والساكن الذي حُرِّكت لَهُ الميمُ في ﴿الم﴾، الساكنُ الثالث، وهو {27}: لام التعريف؛ وذلك أنّ حروف التَّهَجِّي يجتمع فيها ساكنان؛ كقوله: ﴿حم (1) عسق﴾ [الشورى:1 - 2]، ولا يُحرَّك الساكنُ الثاني منها. وجمعهم بين الساكِنَيْنِ في هذه الحروف، دليلٌ على أنها في ﴿الم﴾ ليس بمتحرك للساكن الثاني إذ لو كان للثاني {28} لم يُحرَّك كما لم يُحرَّك سائرُ ما ذكرنا {29}.قال الأخفش {30}: لو كسرت الميم لالتقاء الساكِنَيْن، فقيل: ﴿الم﴾، لَجَازَ.قال أبو إسحاق {31}: هذا غلط من أبي الحسن؛ لأن قبل الميم ياءً، مكسورًا {32} ما قبلها، فحقها الفتح؛ لالتقاء الساكنين؛ لِثِقَلِ الكَسْرِ مع الياء {33}.قال أبو علي {34}: كَسْرُ الميم لو ورد بذلك {35} سماعٌ، لم يدفعه قياس، بل كان يُثَبِّتُه ويُقَوِّيه؛ لأنَ الأصل {36} في التحريك لالتقاء الساكنين الكسرُ. وإنما يُترك الكسرُ {37} إلى غير ذلك؛ لِمَا يَعْرِضُ مِن عِلّةٍ وكراهةٍ. فإذا جاء الشيء على ما به فلا وجه لِرَدِّهِ، ولا مَسَاغ {38} لِدَفْعِهِ.وقول أبي إسحاق: (إنَّ ما قبل الميم ياءً مكسورًا {39} [قبلها] {40} فحقها الفتح)، ينتقضُ بقولهم: (جَيْرِ) وكان مِنَ الأَمْرِ) {41} (ذَيْتِ وذِيْتِ) {42} و (كَيْتِ وكِيْتِ) {43}. فَحُرِّك الساكنُ بعد الياء بالكسر، كما حُرِّك بعدها بالفتح في (أيْنَ).وكما جاز الفتح بعد الياء؛ لقولهم {44}: (أيْنَ)، كذلك يجوز الكسرُ بعدها؛ لقولهم: (جَيْرِ) {45}.ويدل على جواز التحريك بالكسر لالتقاء الساكنين في ما {46} كان قبله ياء جوازُ تحريكه بالضم؛ كقولهم {47}: (حيثُ). وإذا {48} جازَ الضمُّ، كان الكسرُ أسهلَ، وأجْوَزَ.وأما {49} ما رُوي عن عاصم، من قطعه الألف، فكأنّهُ قدّر الوقفَ {50} على الميم، واستأنف (الله). فقطع {51} الهمزة للابتداء بها.قال محمد بن إسحاق {52}، والكَلْبِي {53}، والرَّبِيع {54}:نزلت هذه الآية، إلى {55} نيّف وثمانين من هذه السورة، في وفْدِ نَجْران {56}، مِنَ النَّصَارَى، لَمّا جاءُوا يُحَاجُّونَ النبي ﷺ {57}.قال ابن عباس {58} في رواية عَطَاء، والضحاك في قوله: ﴿الم﴾ يريد بالألف: الله، واللام {59}: جبريل، والميم: محمد ﷺ {60}. وقد مضى الكلام في حروف التَّهَجِّي، وفي معنى ﴿الْحَيُّ الْقَيُّومُ﴾ [البقرة: 255]."
  3,2,""
  3,3,"قوله تعالى: ﴿نَزَّلَ عَلَيْكَ الْكِتَابَ﴾. إنّما قال: ﴿نَزَّلَ﴾، وقال: ﴿وَأَنْزَلَ التَّوْرَاةَ وَالْإِنْجِيلَ﴾؛ لأن التنزيل للتكثير. والقرآن نزل نجومًا، شيء بعد شيء، والتوراة والإنجيل نزلتا دفعةً واحدةً {1}.و ﴿وَالكِتَابِ﴾؛ يعني: القرآن {2}. فهو مصدرٌ، سُمِّي به المكتوب.وقوله تعالى: ﴿بِاَلحَقِّ﴾. أي: بالصدق في أخباره، وجميع دلالاته.وقوله تعالى: ﴿مُصَدِّقًا لِمَا بَيْنَ يَدَيْهِ﴾. أي: موافقًا لِمَا تقدم الخبرُ به في سائر الكتب. وفي ذلك دليل على صحة نبوة محمد ﷺ.وقيل {3}: مصدقًا لشرائع الأنبياء المتقدمين فيما أتوا به، خلاف مَن يقول: نؤمن ببعض ونكفر ببعض.وقوله تعالى: ﴿لِمَا بَيْنَ يَدَيْهِ﴾. مِن مَجَازِ الكلام؛ وذلك أنَّ ما بينَ يَدَيْك، فهو أمَامَك. فقيل لكل ما تقدم على الشيء: (هو بين يديه)؛ كما جاء في الحديث: ""إنَّ بينَ يَدَي الساعة سنين خَدّاعَة"" {4} ، أي: أمامها، تتقدم عليها.وقوله تعالى: ﴿وَأَنْزَلَ التَّوْرَاةَ﴾. قال الفراء {5}: أصل (التوراة): (تَوْرَيَةٌ)، على وزن (تَفْعَلَة)، فصارت الياءُ ألفًا، لِتَحَرُّكها وانفتاح ما قبلها. قال: ويجوز أن تكون (تَفْعِلَة)، فيكون أصلها: (تَوْرِيَة)، فتنقل الراء مِن الكَسْر إلى الفتح؛ كما تقول طَيِّئ {6} في (جاريَة): جَارَاة. وفي (ناصيةٍ): نَاصَاة {7}.قال الشاعر:بِحَرْبٍ كَنَاصاةِ الأغَرِّ المُشَهَّرِ {8} وأنشد الفراء:فَمَا الدنيَا بِبَاقَاةٍ لِحَيٍّ ... وما حَيٌّ على الدنيا بِبَاق {9}وقال الخليل {10} وهو مذهب البصريين {11}: (تَورَيَةٌ، أصلها: (فَوْعَلَةٌ)، وأصلها: (وَوْرَيَةٌ)، ولكنَّ الواو الأولى قُلِبت تاءً، كما قُلِبت في (تَوْلَج) {12}، فهو (فَوْعَل)، مِنْ (وَلَجْت). وقُلِبت الياء ألِفًا؛ لتحركها {13} وانفتاح ما قبلها، فصارت (تَوْرَاةً) {14}، وكُتِبَت بالياء على أصل الكلمة. قالوا: ولا يجوز أن يكون أصلها (تَفعَلَة) كما قال الفرّاء؛ لأن {15} هذا البناء يَقِل، وإن (فَوْعَلة) من الكثرة بحيث لا يتناسبان {16}.ولا إشكال في أن الحَمْل على الأكثر الأشْيع أولى، وأيضًا فإن التاء لم تكثر زائدةً أوّلًا، والواو إذا كانت أوّلًا فقد استمرّ البدل فيها؛ نحو: (وُجُوه)، و (أُجُوه) {17}، و (وُقِّتَتْ)، و (أُقِّتَتْ)، و (وشاح)، و (إشاح) {18}، و (وَنَاة)، و (أَنَاة) {19}. فإذا اجتمع واوان لزم الأوّلَ منهما البدلُ: إما همزة، وإما تاء؛ نحو: (أَوَاقٍ) {20} في جمع (واقِيَةٍ).وقد أُبدِلت التاءُ من الواو، إذا {21} كانت مفردةً؛ نحو: (تُجَاه) و (تُرَاث) {22} و (تُخَمَة) {23} و (تُكْلاَن).فإذا كثر {24} إبدال التاء مِنَ الواو هذه {25} الكثرة كانَ حملها على هذا الكثير {26}، أوْلى من حمله على ما لم يكثر ولم يتسع هذا الاتساع، ولا يقرب أيضًا حملُها على (تَفْعِلَة)؛ لأنه لا يخلو مِن أن يجعلها {27} اسمًا؛ نحو: (تَوْدِيَة) {28} أو مصدرًا؛ نحو: (تَوْصِية).فأما باب (تَوْدِيَةٍ) فقليل؛ كما أن (تَفْعَلَة) كذلك، وباب (تَوْصِيَة) فيه اتساع؛ لكن إذا حملها على لُغَةِ طَيِّئٍ، فقد حملها على لغةٍ لم نعلم شيئًا منها في التنزيل.فإذا لم يكن الوجهان اللّذان ذكرهما الفراءُ بالسّهلين، حَمَلْتَهُ على (فَوْعَلَةٍ) دونها؛ للكثرة؛ ألا ترى أنّ نحو: (صَومَعَة) {29} و (حَوجَلَة) {30} و (دَوسَرَة) {31} و (عَومَرَة) {32}، قد كثر؟.ونظير (التوراة) مِمّا قلبت الواوُ فيه تاءً {33}، قولُهم {34}: (التَّرِيَّة): لِمَا تَرَاهُ المرأةُ في الطُّهْرِ بعد الحَيْضِ {35}، وهي (فَعِيلةٌ) مِنَ (الوَرَاءِ)؛ لأنها تُرى بعد الصُّفْرَةِ والكُدْرَة. ويجوز أن تكون (فَعِيلَة) {36}؛ مِن: (وَريَ الزَّنْدُ)؛ فكأن الطُّهْرَ أَخرجه {37}.فأما اشتقاقها: فقال الفرّاءُ فيما حكاه ابنُ الأنباري: التوراة {38}؛ معناها: الضياءُ والنُّورُ؛ من قول العرب: (وَرِيَ الزَّنْدُ {39}، يَرِي): إذا قَدَحَ {40}، فَلَم يَكْبُ {41}، و (أورْيتُه أنا)؛ قال الله تعالى: ﴿فَالْمُورِيَاتِ قَدْحًا﴾ [العاديات: 2] ويقولونَ: (وَرِيتْ {42} بل زِنَادِي)، على مثال: (شَرِيَتْ) {43}.وزعم أبو عثمان {44}: أنه استُعْمِل في هذا الكلام فقط، لم يُجاوَزْ به غيره.ومعنى (وَرِيَت بك زِنَادِي)؛ أي: ظَهَر بك الخيرُ لي.فالتوراة سُمِّيت [بذلك] {45}؛ لظهور الحق بها. يدل على هذا المعنى قولُه: ﴿وَلَقَدْ آتَيْنَا مُوسَى وَهَارُونَ الْفُرْقَانَ وَضِيَاءً﴾ [الأنبياء: 48].وقال المُؤَرّج {46}: هو من (التَّوْرِيَةِ) {47}، وهي: التعريض بالشيء؛ وكان أكثر التوراة معاريضَ وتلويحًا، مِن غير إيضاحٍ وتصريح.وفي (التوراة) قراءتان: الإمالة، والتفخيم {48}.فَمَنْ فَخَّم؛ فلأن الراءَ {49} حَرفٌ يَمْنُعُ الإمالة؛ لِما فيه مِنَ التكرير، كما يمنعه المستعلي {50}، ولو كان مكان {51} الراء مُستَعْلٍ مفتوحٌ، لمْ تَحْسُنْ الإمالةُ، كذلك إذا كانت الرّاءُ مفتوحةً.ومَنْ أمالَهَا؛ فَلأنّ الألف لَمّا كانت رابعةً، لم تخلُ مِنْ أن تشبه ألِفَ التأنيث، أو الألف المنقلبةَ عن الواو، وعن {52} الياء.وألِفُ {53} التأنيث تُمالُ {54}، وإنْ كان قبلها مستعْلٍ؛ كقولهم: (فَوْضى) {55}، و (جَوْخَى) {56} وهي مدينة {57}، [فـ] {58} كما أمالوا المستعليةَ معها، كذلك يميلون الرَّاءَ {59} والألِفَ المنقلبةَ عن الياء والواو، وتمال نحو: ﴿رَمَى﴾ {60} و ﴿سَجى﴾ {61}، وأشباههما.وقوله تعالى: ﴿وَالْإِنْجِيلَ﴾. قال الزجَّاجُ {62}: الإنجيْل، (إفْعِيل)، مِنَ (النَّجْل)، وهو {63}: الأصل. هكذا كان {64} يقول جميع أهل اللغة في (إنجيل).قال ابن الأنباري {65}: معنى قولهم: (إنجيل) لِكِتاب الله: أصْلٌ للقوم {66} الذين {67} نزل عليهم؛ لأنهم يَعْمَلونَ بما فيه. ويقال {68}: (لَعَنَ اللهُ ناجِلَيْهِ)؛ أي: والِدَيْهِ. وأنشد قولَ الأعشى:إذْ نَجَلاهُ فَنِعْمَ مَا نَجَلا {69}أي: كان أصلًا له إذ وَلَدَاهُ.وقال قومٌ {70}: (الإنجيل)، مأخوذ من قول العرب: (نَجَلْتُ الشيء): إذا استخرجته وأظهرتُه. يقال للماء الذي يخرج من النَّزِّ {71}: (نَجْلٌ).ويقال: (قد استَنْجَلَ الوادي): إذا أخرج الماء من النزِّ. فسمّي الإنجيلُ إنجيلًا؛ لأن الله تعالى أظهره للناس بعد طموس الحق ودُرُوسِهِ.قال: وفي (الإنجيل) قولٌ ثالث: وهو أن يكون سُمّيَ إنجيلًا؛ لأن الناس اختلفوا فيه، وتنازعوا.قال أبو عمرو الشيباني {72}: التَّنَاجُل: التنازع. يقال: (تناجلَ القومُ): إذا تنازعوا {73}.وقال جماعة من أهل التحقيق: التوراة والإنجيل والزَّبُور، أسماء عُرِّبت مِنَ السريانية، وليس يُطّردُ فيها قياس الأسماء العربيّة؛ ألا تراهم يقَولون لها بالسريانية: (تُورَيْ)، (انْكِليُون) {74}، (زَفُوتَا) {75}."
  3,4,"وقوله تعالى: ﴿وَأَنزَلَ اَلفُرْقَانَ﴾. أي: ما فرق بين الحق والباطل {1}. قال ابن عباس في رواية عطاء {2}: يريد به جميع الكتب؛ لأنه فرّق فيها بين الحق والباطل {3}.وقال السُّدِّي {4}: في هذه الآية تقديم وتأخير، وتقديرها: ونَزَّلَ التوراة والإنجيل وأنزل الفرقان؛ هُدًى للناس.وقوله تعالى: ﴿ذُو انْتِقَامٍ﴾ أي: مِمَّن كَفَرَ به، (لأن) {5} ذِكْرَ الكافرين جرى ههنا.والانتقام: العقوبَة. يقال: (انتقم منه انتقامًا)؛ أي: عاقبه {6}.وقال اللَّيْث {7}: يقال: (لَمْ أرْضَ منه حتى نَقِمتُ، وانتقمْتُ): إذا كافأه؛ عقوبةً بما صنع."
  3,5,""
  3,6,"قوله تعالى: ﴿هُوَ الَّذِي يُصَوِّرُكُمْ﴾ {1}. التصويرُ: جعل الشيء على صورةٍ. والصورة: هيئة يكون {2} عليها الشيء بالتأليف.وأصلها مِن: (صارَه، يَصُوره): إذا أماله {3}. فهي صورَةٌ؛ لأنها مائلة إلى بِنْيَةٍ بالشَبَه لها.وقوله تعالى: ﴿فِي الْأَرْحَامِ﴾. جَمْعُ رَحِم. وأصلها مِنَ: الرَّحْمَة {4}؛ وذلك لأنها مما يُتَراحم بالاشتراك فيها، ويُتَعاطف.وقوله تعالى: ﴿كَيْفَ يَشَاءُ﴾. أي: ذكرًا (و) {5} أنثى؛ قصيرًا وطويلًا؛ أسودَ وأبيض؛ سعيدًا وشقِيًّا. ﴿لَا إِلَهَ إِلَّا هُوَ الْعَزِيزُ﴾ في مُلْكه، ﴿الْحَكِيمُ﴾ في خَلْقِه."
  3,7,"قوله تعالى: ﴿هُوَ الَّذِي أَنْزَلَ﴾ إلى قوله: ﴿مُتَشَابِهَاتٌ﴾ اختلف المفسرون في المُحْكَمِ والمُتَشابِه.واختلفت (فيهما) {1} الروايات عن ابن عبّاس، فقال في روايةِ عَطِيّة: المُحْكَم: الناسخ الذي يُعمل به. والمُتشابه: المَنْسُوخُ الذي يُؤمَنُ به، ولا يُعمل [به] {2}. وهذا قول قتادة، والربيع {3}.وقال في رواية عطاء: المُحْكَمَات: (هي) {4} الثلاثُ (الآيات) {5} في (آخر) {6} سورة الأنعام: ﴿قُلْ تَعَالَوْا﴾ [الأنعام: 151]، إلى آخر الآيات الثلاث {7}.﴿وَأُخَرُ مُتَشَابِهَاتٌ﴾ يريد: (التي) {8} تشابهت اليهود؛ وهي حُرُوف التَّهَجِّي في أوائل السُّوَرِ؛ وذلك أنهم أوَّلُوها على حِسَابِ الجُمَّلِ، وطلبوا أن يَسْتَخرِجوا منها مُدَّة بقاء هذه الأمَّةِ، فاختلط عليهم واشْتَبَه {9}.وهذا القول، اختيار الفرّاء {10}.وقال في رواية الوالبي {11}: محكمات القرآن: ما فيه من الحلال والحرام، والحُدُود والفرائض، مِمّا يُعمل به. والمتشابهات: مُقَدَّمُه ومُؤَخَّرُه، وأمثالُهُ وأقسامه، وما يُؤمَنُ به (ولا يُعمل به) {12}.وقال ابن كَيْسَان {13}: المُحْكَمَات: حُجَجُها واضحةٌ، ودَلائِلُها لائحة، (لا) {14} حاجة بمن سمعها إلى طلب معانيها. والمتشابه: ما يُدرَك عِلْمُهُ بالنظر. وهذا القول؛ اختيار أبي إسحاق؛ لأنه حكى هذا القول، وقال {15}: معنى ﴿مِنْهُ آيَاتٌ مُحْكَمَاتٌ﴾: أي: أُحكِمت في الإبانة، فإذا سمعها السامعُ لَمْ يَحْتَجْ إلى تأويلها؛ لأنها ظاهرة بَيِّنةٌ؛ نحو: ما قَصّ اللهُ تعالى مِنْ أقاصيص الأنبياء، مِمّا اعترف به أهلُ الكِتَاب، وما أخبر اللهُ جلّ وعزَّ به مِنْ إنشاءِ الخَلْقِ، في قوله: ﴿ثُمَّ خَلَقْنَا النُّطْفَةَ عَلَقَةً﴾ [المؤمنون: 14] الآية. ومِنْ خَلْقِهِ مِنَ الماءِ (كلَّ) {16} شيءٍ (حَيٍّ) {17}، وما خلق مِنَ الثمار، وهذا (ما) {18} لَمْ يُنْكِروا، (وأنكروا) {19} ما احتاجوا فيه إلى النَّظَرِ مِنْ أنَّ اللهَ يبعثهم بعد أنْ يَصِيروا تُرابًا، (ولُوْ نَظَرُوا وتَدَبَّروا) {20} لَصَارَ المُتَشابِهُ عندهم كالظاهر؛ لأنَّ مَنْ قَدَرَ على الإنشاء أوّلًا، قَدَرَ على الإعادَةِ.وقد نَبَّهَ اللهُ تعالى بِقَوْلِهِ: ﴿قُلْ يُحْيِيهَا الَّذِي أَنْشَأَهَا﴾ [يونس: 79].وقال محمد بن جعفر بن الزبير {21}: المُحْكَم: ما لا يَحْتَمِل مِنَ التأويل غير وَجْهٍ واحدٍ. والمُتَشابه: ما احتمل من التأويل أوجُهًا {22}. وهذا اختيار ابن الأنباري، وكثيرٍ مِنَ العلماء {23}.[و] {24} قال ابن الأنباري {25}: الآية المُحْكَمَةُ: التي مَنَعَتْ كَثْرَةَ التأويلات؛ لأنها لا تَحْتَمِلُ إلّا تفسيرًا واحدا.والعرب تقول {26}: (حَكَمتُ) و (أحكمتُ) و (حَكَّمْتُ)؛ بمعنى: (رَدَدْت) {27}، ومَنَعْتُ. والحاكم يَمْنَعُ (الظالمَ) {28} من الظُلْم.قال الأصمعي {29}: وأصلُ الحُكُومَةِ: رَدُّ الرَّجُلِ عَنِ الظُّلْمِ، ومِنْهُ قولُ لَبِيد:أَحْكَمَ الجِنْثِيَّ مِنْ عَوْراتِها ... كُلُّ حِرْباءٍ إذا أُكْرِهَ صَلْ {30} قال: (الجِنْثِيّ): السَّيْف {31}؛ أي: ردَّ السيفَ عن {32} عوراتِ (الدرع) {33} (وهي) {34} فُرَجُها، كلُّ حِرْباءٍ وهُوَ المِسْمَارُ الذي يُسَمَّرُ به حَلَقُها {35}.ومِنْهُ حديثُ النَّخَعِيِّ: (حَكّمْ اليتيمَ كما تُحَكِّم وَلَدكَ) {36}، أي: امنعه من الفَسَاد {37}.وقال جرير:.. أَحْكِمُوا {38} سُفهاءَكُمْ {39} ...يقول: امنعوهم {40} من التَعرُّض.قال أبو بكر {41}: والمُتَشَابِهُ، ما اعتَوَرَتْهُ تأويلات. وسُمِّيَ مُتشابهًا؛ لأن لفظَهُ يُشْبِهُ لفظَ غيره، ومعناه يخالف معناه.وقال بعضهم {42}: المُحْكَمُ: ما عرفَ العلماءُ تأويلَهُ، وفهموا معناه. والمتشابه: ما ليس لأحدٍ إلى عِلْمِهِ سبيلٌ، مِمَّا استأثرَ اللهُ بِعِلْمِهِ؛ وذلك نحو: وقت خروج يأجوج ومأجوج، وخروج الدجّال، ونزول عيسى، وقيام الساعة، وعِلْم الرُّوح.ويُسْأَلُ (فيقال) {43}: ماذا {44} أراد اللهُ بإنزال المُتشابِهِ في القرآن؛ وأراد بالقرآن لِعِبادِهِ الهُدَى والبيان؟ فيقال: إنَّ القرآن نَزَلَ بألفاظِ العَرَبِ ومذاهبها في: الإيجاز؛ (للاختصار) {45}، والإطالَةِ؛ (للتوكيد) {46}، والإشارة إلى الشيء، واغماض بعض المعاني؛ حتى لا يظهر عليه إلا اللَقِن {47}. ولو كانَ القرآنُ كلُّهُ ظاهرًا مكشوفًا، حتى يستوي في معرفته العالمُ والجاهلُ، لَبَطَلَ التفاضُلُ بين الناس، وسقطت المِحْنَةُ، وماتت الخواطرُ. ومَعَ الحاجَةِ تَقَعُ الفِكْرةُ {48} والحِيلَةُ، ومع الكفاية يقع العَجْزُ والبَلاَدَةُ {49}.وأصل التشابه {50}: أن يُشْبِهَ اللفظُ اللّفظَ في (الظاهر) {51}، والمَعْنَيَانِ مُخْتَلِفان. قال اللهُ عز وجل في وَصْفِ ثِمَارِ الجَنَّةِ: ﴿وَأُتُوا بِهِ مُتَشَابِهًا﴾ [البقرة: 25]؛ أي: مُتَّفِقَ المَنَاظِرِ، [و] {24} مُخْتَلِفَ الطُعُوم {53}.ثم يقال لكل ما غَمُضَ ودَقّ: (مُتشابهٌ)، وإنْ لم تقع الحَيْرَةُ فيه، مِنْ جِهَةِ (الشَّبَهِ) {54} بغيره ألا تَرَى أنه قد قيل للحروف المقَطَّعَةِ في أوائل السُّوَر: متشابهة؟ (وليس) {55} الشكُّ {56} فيها. والوقوف فيها؛ لمشاكَلَتِها غيرَهَا والتباسِها به. ومثل المتشابه: المُشكِلُ.واعلَمْ {57} أنَّ القرآن كُلَّهُ محكَمٌ مِنْ وَجْهٍ؛ على معنى: أنه (حقٌّ) {58} ثابت {59}. قال اللهُ تعالى: ﴿كِتَابٌ أُحْكِمَتْ آيَاتُهُ﴾ [هود: 1]. ومُتَشابِهٌ مِنْ وَجْهٍ؛ وهو أن يشبه بعضه بعضًا في الحُسْنِ، ويُصدّق بَعْضُه بعضًا {60}، وهو قوله تعالى: ﴿كِتَابًا مُتَشَابِهًا مَثَانِيَ﴾ {61} [الزمر: 23].وقوله تعالى: ﴿هُنَّ أُمُّ الْكِتَابِ﴾. أي: أصل الكتاب الذي يُعْمَل عليه {62}. فَمَنْ جَعَلَ (المُحْكَمَات): الآيات الثلاث في (الأنعام)، قال: يريد: هُنّ أم كلِّ كِتَابٍ أنزله الله على نَبِيٍّ، فيهن كلُّ ما أحلّ، وفيهن كلُّ ما حرّم. ووحَّد (الأمَّ) بعد قوله: ﴿هُنَّ﴾؛ لأن {63} الآياتِ كلَّها في تكامُلِها واجتماعها، كالآية الواحدة، وكلام الله واحد.وقال أبو العباس {25}: لأنهن بكمالِهِنَّ (أُمٌّ)، وليست كلُّ واحدِةٍ منهن (أُمَّ الكتاب)، على انفرادها.وقال الأخفش {65}: وَحَّدَ ﴿أُمُّ الْكِتَابِ﴾ بالحكاية؛ على تقدير الجواب؛ كأنه قيل {66}: ما أمُّ الكتاب؟ فقيل: هنّ أم الكتاب؛ كما تقول: مَنْ نَظِيرُ زيد؟ فيقول قومٌ: نحن نظيرُه {67}؛ كأنهم حَكَوا ذلك اللفظ. وهذا على قولهم {68}: دَعْنِى مِنْ (تَمْرَتان) {69}؛ أي: مِمَّا يقالُ له (تمرتان).قال أبو بكر {70}: وقولُ الأخفش بِعيدٌ مِنَ الصواب في الآية؛ لأن الإضمار لمْ يَقُمْ عليه دليلٌ، ولم تَدْعُ إليه حاجةٌ. وقيل {71}: أراد: كل آية منهنّ أمُّ الكتاب؛ كما قال: ﴿وَجَعَلْنَا ابْنَ مَرْيَمَ وَأُمَّهُ آيَةً﴾ [المؤمنون: 50]؛ أي: كلُّ واحدٍ منهما آية {72}.قال العلماءُ، وأصحابُ المعاني: معنى قوله: ﴿هُنَّ أُمُّ الْكِتَابِ﴾ أي: أصلُ الكتاب الذي يُسْتَدَلُّ به على المتشابه وغيره مِنْ أمور الدين. فإذا وردت الآية المتشابهة رُدَّت إلى المحْكَمَةِ، فكانت المُحْكَمَةُ {73} مُفَسِّرَةً لها، وقاضِيَةً على معناها.فـ ﴿أُمُّ الْكِتَابِ﴾ معناه: أصل الكتاب الذي ترجع إليه التأويلات، وتضم جميع المعاني، لأن الأم يرجع إليها بنوها فتضمهم.مثال ما ذكرنا: قوله تعالى: ﴿هَلْ مِنْ خَالِقٍ غَيْرُ اللَّهِ﴾ [فاطر: 3]. هذه آيةٌ {74} مُحْكَمَةٌ، لا تحتمل تأويلًا غير ظاهرها {75}، لأن معناها: لا ينشئ الصُّوَرَ {76}، ولا يُرَكِّبُ الأرواحَ في الأجسام غيره عز وجل.وأما الآية المتشابهة: فقوله عزَّ ذِكْرُه: ﴿فَتَبَارَكَ اللَّهُ أَحْسَنُ الْخَالِقِينَ﴾ [المؤمنون: 14]؛ يقع هذا متنافيًا عند الجاهل؛ إذْ كان قالَ في ذلك الموضع: ﴿هَلْ مِنْ خَالِقٍ غَيْرُ اللَّهِ﴾ [فاطر: 3]، وَجَعَلَ في {77} هذا الموضع مع الله خالِقِين، فاحتجنا إلى رَدِّ هذه الآية، إلى الآية المحكمة؛ لِتَحْكُمَ {78} عليها، فقلنا: قد نَفَت الآيةُ المُحْكَمة أن يكون مع الله تعالى خالق يُنْشئ وُيحْيي.ووجدنا العربَ تجعل (الخَلْقَ) على مَعْنيَيْن: أحدهما: (الإنشاء)، والآخر: (التقدير). {79} فنفت الآيةُ المُحْكَمة (الخَلْقَ) الذي بمعنى: (الإنشاء)، فبقي الذي معناه {80}: (التقدير). فَحَمَلْنا المُتشابِهَ عليه، وقلنا: تأويلُهُ: فتباركَ اللهُ أحْسَن المُقَدِّرِين؛ كما قال: ﴿وَتَخْلُقُونَ إِفْكًا﴾ [العنكبوت: 17]، أي: ويُقَدِّرُون {81}.ومن هذا القَبِيل أيضًا، قولُه: ﴿لَا يَضِلُّ رَبِّي وَلَا يَنْسَى﴾ [طه: 52]؛ هذه مُحْكَمَةٌ لا تَحْتَمِل التأويلات. ثم قال: ﴿نَسُوا اللَّهَ فَنَسِيَهُمْ﴾ [التوبة: 67]؛ فَأَثْبَتَ في المُتَشَابِهِ {82} ما نفاهُ في المحكمة؛ فكانت المُحْكَمة قاضيةً عليها؛ لأنا وجدنا النسيان في كلام العرب على مَعْنيَيْنِ: أحدهما: (الإغفال)، والآخر: (التَّعَمُّدُ والتَّرْكُ) {83}.فقلنا في قوله عز وجل: ﴿نَسُوا اللَّهَ فَنَسِيَهُمْ﴾ [التوبة: 67]: تركوا {84} العَمَلَ لله، فَتَرَكَ أنْ يُثِيبهم {85}؛ فكان في المُحْكَمِ بَيانُ المُتَشابِهِ.ومن هذا: قولُ اللهِ عز وجل: ﴿ثُمَّ اسْتَوَى عَلَى الْعَرْشِ﴾ {86}، احتمل في اللغة أنْ يكونَ كاستواءِ الجالِسِ على سَرِيرِهِ، واحتَمَلَ أن يكون بمعنى الاستيلاءِ؛ وأحَدُ الوَجْهَيْنِ لا يجوز على الله؛ لقوله تعالى: ﴿لَيْسَ كَمِثْلِهِ شَيْءٌ﴾ [الشورى: 11] وهذا من المُحْكم، الذي هو أصلٌ يُردُّ إليه المتشابهُ، فقلنا: إنَّ استواءَهُ بمعنى: الاستيلاء {87} ومثل هذا كثيرٌ، وفيما أوردتُهُ كِفَايَةٌ لِمَنْ رُزِقَ الفَهْمَ.وقوله تعالى: ﴿وَأُخَرُ﴾ زعم {88} سِيبَويه والخليلُ أنَّ (أُخَرَ) فارقت أخواتها، والأصلَ الذي عليه بِنَاءُ أَخَواتِها؛ لأن (أُخَرَ) أصلُها أن تكون بالألف واللّام {89}؛ كما تقول: (الصُّغْرى) و (الصُغَر)، و (الكُبْرَى) و (الكُبَر). فلما عُدِلَت عن مُجْرَى الألِفِ واللام، وأصلِ (أَفْعَلَ مِنْكَ) وهي مِمَّا لا يكونُ {90} إلا صِفَةً، مُنِعَت الصَّرْفَ. وقد شرحنا هذه المسألة عند قوله: ﴿فَعِدَّةٌ مِنْ أَيَّامٍ أُخَرَ﴾ {91} [البقرة: 184].قوله تعالى: ﴿فَأَمَّا الَّذِينَ فِي قُلُوبِهِمْ زَيْغٌ﴾. الزَّيْغُ: المَيْلُ. يعني: مَيْلًا عن الحقِّ؛ (زاغ، يَزِيغ، زَيْغًا، وزَيْغُوغَةً، وزَيَغانًا، وزيوغًا {92}.قال الفراء {93}: والعرب تقول في عامةِ ذوات الياء، مِمَّا يُشْبِهُ (زِغتُ)؛ مثل: (سِرْتُ)، و (صرْتُ)، و (طِرتُ): (سَيْرُورَةً)، و (صَيْرُورَةً)، و (طَيْرُورَةً)، و (حِدْتُ حَيْدُودَةً)، و (مِلْتُ مَيْلُولَةً)، لا أحصى ذلك، وهو كثير. فأمّا ذوات الواو؛ مثل: (قلتُ)، و (رُضْتُ)، فإنهم لمْ يقولوا ذلك إلا في أربعة أحْرُف، منها: الكَيْنُونة {94}، والدَّيْمُومَةُ، مِنْ: (دُمْتُ)، والهَيْعُوعَةُ، من: (الهُواع) {95}، والسيْدُودَةُ، من: (سُدْتُ).وكان ينبغي أن يكونَ -في القياس-: (كَوْنُونَة) بالواو {96}، ولكنها لَمَّا قَلَّت في مصادر الواو، وكثرت في مصادر الياء، ألحقوها بالذي هو أكثر مجيئًا منهما؛ إذ كانت الواوُ والياءُ مُتَقارِبَتَينِ في المَخْرَج.ومثل هذا: أنهم يقولون في ذوات الياء: (سَعَيْتُ به سِعَايةً)، و (رَمَيْتُهُمْ رِمَايَةً)، و (دَرَيْتُ بِهِ {97} دِرايةً)، فتأتي المصادرُ في ذوات الياء، على هذا النحو، كثيرةً، ولا تكاد تأتي في ذوات الواو؛ نحو: (خَلَوْتُ)، و (دَعَوْتُ). فَنَدَرَ حرفٌ مِنْ ذوات الواو فألْحِقَ بذوات الياء، وهو قولُهم: (شَكَوْتُ فُلانًا شِكَايَةً)، ولم يقولوا: (شِكاوَةً)، فألحقوها بالمصادر من الياء {98}.واختلفوا في هؤلاء الذي عُنُوا بقوله: ﴿فِي قُلُوبِهِمْ زَيْغٌ﴾: فقال الربِيع {99}: هم {100} وَفْدُ نَجْرَانَ؛ لَمَّا حَاجُّوا رسولَ الله ﷺ، في المَسِيح، فقالوا: أليسَ {101} هُوَ كَلِمَة اللهِ، وروح منه؟ قال: ""بَلَى"". قالوا: حَسْبُنا. فأنزلَ اللهُ تعالى: ﴿فَأَمَّا الَّذِينَ فِي قُلُوبِهِمْ زَيْغٌ﴾، الآية. ثمّ أنزل: ﴿إِنَّ مَثَلَ عِيسَى عِنْدَ اللَّهِ﴾ الآية.وقال الكَلْبِيُّ {102}: هم اليهود، طَلَبُوا {103} عِلْمَ أكْلِ {104} هذه الأُمَّةِ، واستِخْراجِهِ مِنَ الحُرُوف المُقَطَّعَةِ في أوائل السُّوَرِ {105}. وهذا معنى قول ابن عباس في رواية عطاء {106}.وقيل: هم جميع المُبْتَدِعَةِ، وكلُّ من احتَجَّ لِباطِلِهِ بالمتشابه {107}. وهذا معنى قول قتادة {108}.وقولُ الزَّجَّاج في هذه الآية، يَدُلُّ على أنّ هؤلاء، هم الكفار الذين يُنْكِرُون البَعْثَ، لأنه قال {109} في سياق الآية: معنى ابتغائهم تأويله: أنهم طلبوا تأويل بَعثِهِمْ وإحيائهم.وقوله تعالى: ﴿ابْتِغَاءَ الْفِتْنَةِ﴾. قال عطاءٌ، عن ابن عباس {110}: يريد: الكفر. وقال الرَّبِيع {111}، والسدي {112}: طلب الشرك {113}.وقال مجاهد {114}: اللَّبْسِ {115}؛ لِيُضِلُّوا به جُهَّالَهم.وقال أبو إسحاق {116}: الفِتْنَةُ في اللغة على ضُرُوب: فالضَّرْبُ الذي ابتغاه هؤلاء: إفسادُ ذوات {117} البَيْن في الدِين، والحرب. والفتنة في اللغة: الاستهتار بالشيء والغُلُوُّ فيه؛ يقال: (فلانٌ مَفْتُونٌ بِطَلَب الدُّنْيا)؛ أي: قد غلا في طَلَبِها، وتجاوز القَدر {118}.وقوله تعالى: ﴿وَابْتِغَاءَ تَأْوِيلِهِ﴾. التأويل: التفسير. وأصلُهُ في اللغة: المرجِعُ والمَصِيرُ؛ مِنْ قولهم: (آل الأمْرُ إلى كذا): إذا {119} صار إليه. و (أوَّلْته تأويلًا): إذا صَيَّرته إليه، فتأول {120}؛ أي: رَجَعَ، وصار.قال الأعشى:على أَنَّها كانتْ تَأوُّلُ حُبِّها ... تأؤُّلَ رِبْعيِّ السِّقابِ فَأَصْحَبَا {121} أي: كان حُبُّها صغيرًا، فآل إلى العِظَم، كما آل السَّقْبُ إلى الكِبَرِ {122}.هذا معنى (التأويل) في اللغة {123}.ثم تُسَمَّى (العاقبةُ): (تأويلا)؛ لأنَّ الأمرَ يصيرُ إليها. و (التفسير) يُسمَّى: (تأويلًا)، وهو قوله: ﴿سَأُنَبِّئُكَ بِتَأْوِيلِ مَا لَمْ تَسْتَطِعْ عَلَيْهِ صَبْرًا﴾ [الكهف: 78]؛ أي: بِعِلْمِهِ وتفسيره؛ لأن التَّأويل: إخبارٌ عَمَّا يَرْجِعُ إليه اللفظُ مِنَ المعنى.وذكرنا معنى التَّأوِيل [بأبلغ] {124} مِنْ هذا، في سورة النساء، عند قوله: ﴿وَأَحْسَنُ تَأْوِيلًا﴾ [النساء: 59] {125}.قال ابن عباس في رواية عطاء {126}: ﴿وَابْتِغَاءَ تَأْوِيلِهِ﴾ أي: طَلَبِ مُدَّةِ أُكْلِ مُحَمَّد ﷺ.وفي قول الزجاج {127}: المراد به: الكفار {128}؛ طلبوا متى يُبْعثون؟ وكيف يكون إحياؤُهم بعد الموت؟ وفي قول الباقِين: معناه: طَلَبُ تفسير المُتَشابِهِ، وعِلْمِهِ. قال الله تعالى: ﴿وَمَا يَعْلَمُ تَأْوِيلَهُ إِلَّا اللَّهُ﴾ يريد: ما يَعلَمُ انقضاءَ مُلْكِ أُمَّة {129} محمد ﷺ إلّا الله؛ لأن انقضاءَ مُلك هذه الأُمَّةِ مع قيام الساعَةِ، ولا {130} يَعْلَم ذلك مَلَكٌ مُقَرَّبٌ ولا نَبِيٌ مُرْسَلٌ. وهذا قولُ عطاء {25}. وعلى هذا؛ يَحْسُنُ الوقفُ على قوله: ﴿إِلَّا اللَّهُ﴾، وكذلك على قول الزجاج؛ لأن وقت البعثِ لا يَعلَمُهُ إلا الله. ثم ابتدأ، فقال: {وَالرَّاسِخُونَ فِي الْعِلْمِ} أي: الثابتون فيه. والرُّسُوخُ في اللغة {132}: الثُّبُوتُ في الشيء {133}. وعند أكثر المفَسِّرين {134}: المرادُ بـ (الراسخين علمًا): مُؤْمِني أهل الكتاب؛ دليله: قوله: ﴿لَكِنِ الرَّاسِخُونَ فِي الْعِلْمِ مِنْهُمْ﴾ [النساء: 162]. قال ابن عباس {135}، ومجاهد {136}، والسُّدِّي {137}: بقولهم: ﴿آمَنَّا بِهِ﴾، سَمَّاهُم اللهُ (راسخينَ في العِلْم). فَرُسُوخُهم {138} في العِلْمِ؛ قولُهم: ﴿آمَنَّا بِهِ﴾ أي: بالمُتَشَابِهِ.﴿كُلٌّ مِنْ عِنْدِ رَبِّنَا﴾ المُحْكَم والمُتشابه؛ الناسخُ والمنسوخ؛ وما عَلِمْناه وما لَمْ نعْلَمْه.وقال الزجاج {139}: أي: يقولون: صَدَّقنا بأن الله عز وجل يبعثنا، ويؤمنون بأنَّ البَعْثَ حَقٌّ، كما أنَّ الإنشاءَ حَقٌّ.وقوله تعالى: ﴿وَمَا يَذَّكَّرُ إِلَّا أُولُو الْأَلْبَابِ﴾. قال عطاء {25}: هذا ثَنَاءٌ مِن الله تعالى على الذين قالوا: ﴿آمَنَّا بِهِ﴾، معناه: ما يَتَّعِظُ [بما] {141} في القُرْآن، إلّا ذَوُو العُقُول.وقال الزَّجَّاج {142}: هذا دليلٌ على أن الأمرَ الذي اشْتَبَهَ عليه من البَعْثِ، لمْ يَتَدَبَّرُوه، ومعناه: ما يَتَدَّبر القرآنَ، وما أتَى به الرسولُ ﷺ، إلّا أوْلُوا الألباب. والأظهر في تفسير هذه الآية: قولُ عطاء: إنَّ هذا في اليهود، حين طلبوا تفسيرَ الحروف المُقَطَّعَة، والقولُ الذي حكاه الزجَّاج: إن هذه في منكري البعث.ويقال: هل يجوز أن يكون في القرآن شيءٌ، لا يعلمه إلا الله؟ فيقال: اختلف الصحابة والناسُ في هذا:فذهب الأكثرون: إلى أنَّ تَمَامَ الوَقْفِ على قوله: ﴿إِلَّا اللَّهُ﴾، وأن جميع المتشابه لا يعلمه إلا الله؛ مثل: وقت قيام الساعة، وطلوع الشمس من المغرب، ونزول عيسى، وخروج الدجَّال.وقال قومٌ: في القرآن أشياء لا يَعْرِف حقيقَتَها إلا الله؛ كالحروف المُقَطَّعة، وقوله: ﴿الرَّحْمَنُ عَلَى الْعَرْشِ اسْتَوَى﴾ [المائدة: 64]، وقوله: ﴿خَلَقْتُ بِيَدَيَّ﴾ [ص: 75]، وقوله: ﴿بَلْ يَدَاهُ مَبْسُوطَتَانِ﴾، وأشباه هذا. والله تعالى مُخْتَصٌّ {143} مُستأثِرٌ بِعِلْم هذه، والإيمانُ بها حَقٌّ، وحقائقُ عُلُومِها مُفَوَّضَةٌ إلى الله تعالى.وهذا مذهب: عائشة، وابن مسعود، وابن عباس، وأُبَي، وكثير من التابعين، واختيار {144} الفَرّاء، والكسائي {145}، والمُفَضَّل {146}، وابن الأنباري، وأَبي عُبَيد {147}، وأحمد بن يحيى {148}.ودليل هذا القول: قراءة عبد الله {149}: (إنْ تَأويلُهُ إلّا عِنْدَ الله. والرّاسخون في العِلْم يقولون آمَنّا به) {150}.وفي {151} حرف أُبَيٍّ، وابن عباس: (ويقول {152} الراسخون في العلم آمَنّا به) {153}. وهذا هو الأشبه بظاهر الآية؛ لأنه لو كان ﴿الرَّاسِخُونَ﴾ عَطْفًا، لَقَال: ويقولون آمنّا به.وفي قوله أيضًا: ﴿كُلٌّ مِنْ عِنْدِ رَبِّنَا﴾، دليلٌ على أنهم لَمْ يَعْرِفوا البعضَ فآمَنُوا بظاهره، وقالوا: إنه من عند الله.وقد رُوي عن ابن عباس، أنه قال: تفسير القرآن على أربعة أوجه: تفسيرٌ {154} لا يَسَعُ أحدًا جَهْلُه، وتفسيرٌ تَعرِفُهُ العربُ بألسنتها، وتفسيرٌ يَعْلَمُهُ العلماءُ، وتفسيرٌ لا يعلمه إلا الله {155}.وعلى هذا المذهب؛ إنما {156} أنزل الله -تعالى- ما {157} لا {158} يعلمه إلّا هو؛ اختبارًا {159} للعباد، لِيُؤمِنَ به المُؤْمِنُ فَيَسْعَد، ويكفر به الكافرُ فَيَشْقَى؛ لأن سبيلَ المُؤْمِنِ إذا قرأ من هذا شيئًا، أنْ يُصَدِّق رَبه عز وجل، ولا يعترض فيه بسؤال وإنكار؛ فَيَعْظُمَ -بذلك- ثوابُهُ على الله عز وجل.فإن {160} قيل: وأي {161} تخصيصٍ لِلرَّاسخين إذا {162} لم يَعرِفوا، فإنَّ غيرَهم أيضًا يقولون: ﴿آمَنَّا بِهِ﴾، فَلِمَ خَصَّ {163} الراسخينَ {164} بالذكر؟قلنا: المراد بـ (الراسخين): كلُّ مَنْ يقول: ﴿آمَنَّا﴾ وليس المراد بهم الذين يدأبون في التَّعَلُّمِ {165} ويَجْتَهِدُون. وقد ذكرنا عن ابن عباس، أنه قال: سمَّاهم (راسخين)، بقولهم: ﴿آمَنَّا﴾.وقال مجاهد {166}، والربيع {167}، ومحمد بن جعفر بن الزبير {137}: المتشابه يعلمه الله، ويعلمه الراسخون. ولا يجوز أن يكون في القرآن شيءٌ، لا يعرفه {169} أحدٌ مِنَ الأُمَّةِ. وهذا اختيار ابن قتيبة {170}، وزَعَمَ أنَّ الراسخينَ في العِلْمِ عَلِمُوا تأويل القرآن مع الله تعالى؛ لأنه لم يُنْزِلْ كتابَهُ، إلا لِيَنْفَعَ به عِبَادَه، ويدل على المعنى الذي أراده. وتأوَّلَ قولَهُ: ﴿يَقُولُونَ آمَنَّا بِهِ﴾، على أنه حالٌ صُرِفَت إلى المُضَارَعَةِ؛ أي {171}: (والراسخون {172} في العلم، قائلين {173} آمَنَّا به).قال: ومثله من {174} الكلام: (لا يَأتِيك إلا عبدُ الله، وزَيْدٌ يقول: أنا مسرورٌ بزيارتك)، تريد {175}: (لا يأتيك إلا عبدُ الله، وزيدٌ قائلًا: أنا مسرورٌ بزيارتك). فـ (زيد) عطفٌ على (عبد الله) {176}.واحتج لهذه الطريقة في كتابه (المُشْكل) بما يطول ذِكْرُه {177}."
  3,8,"قوله {1} تعالى: ﴿رَبَّنَا لَا تُزِغْ قُلُوبَنَا﴾. أي: ويقول الراسخون: ربنا، كقوله: ﴿وَيَتَفَكَّرُونَ فِي خَلْقِ السَّمَاوَاتِ وَالْأَرْضِ رَبَّنَا﴾ [آل عمران: 191].وقوله: ﴿لَا تُزِغْ قُلُوبَنَا﴾ أي: لا تُمِلْنَا {2} عن الهدى والقصد، كما أزغت قلوب اليهود والنصارى، والذين في قلوبهم زيغ، بعد إذ هديتنا للإيمان بالمُحْكَمِ والمُتَشَابِهِ مِنْ كِتَابِكَ.وروت أم سلمة {3}: أن النبي ﷺ كان يُكثر في دعائه أن يقول: ""اللهم مُقَلب {4} القلوب، ثبِّت قلبي على دينك"" {5}."
  3,9,"قوله {1} تعالى: ﴿رَبَّنَا إِنَّكَ جَامِعُ النَّاسِ لِيَوْمٍ لَا رَيْبَ فِيهِ﴾. تقديره: جامع الناس للجزاء في يوم لا ريب فيه {2}؛ فلما حذف لفظ الجزاء، دخلت اللام على ما يليه، وأغنت عن (في) {3}؛ لأن حروف الإضافة متآخية؛ لما يجمعها من معنى الإضافة {4}.قال الزجّاج {5}: وهذا إقرارٌ من المؤمنين بالبعث، ومخالفةٌ لمن اتبع المتشابه ممن ينكر أمر البعث.وقوله تعالى: ﴿إِنَّ اللَّهَ لَا يُخْلِفُ الْمِيعَادَ﴾ [يجوز أن يكون إخبارًا عن المؤمنين أنهم قالوا ذلك، فيكون متصلًا بما قبله، لكنه على تلوين الخِطاب {6}، و] {7} يجوز أن يكون استئنافًا، أخبر الله تعالى أنه لا يخلف الميعاد. ولا يدلُّ هذا على تخليد مرتكبي الكبائر من المسلمين في النار، وإنْ وعد ذلك بقوله: ﴿وَمَنْ يَعْصِ اللَّهَ وَرَسُولَهُ﴾ [النساء: 14]. الآية؛ لأن المراد بالميعاد {8} ههنا يوم القيامة {9} لأن الآية وردت في ذكره. أو يُحمل [هذا {10} على ميعاد الأولياء دون وعيد الأعداء؛ لأن خلف الوعيد كرم {11} عند العرب] {7}، والدليل: أنهم يمدحون بذلك، ومنه قول الشاعر: إذا وعد السرّاءَ أَنجز {13} وعدَه ... وإنْ وَعَدَ الضرّاءَ فالعَفْوُ مانَعُهْ {14}قال الأصمعي: جمعنا بين أبي عمرو بن العلاء، وبين محمد بن مسعود الفدكي {15}، فقال أبو عمرو: ما تقول؟ قال: أقول: إن الله وعد وعدًا، وأوعد إيعادًا {16}، فهو منجز إيعاده، كما هو منجز وعده. فقال أبو عمرو: إنك رجل أعجم، لا {17} أقول: أعجم اللسان، ولكن أعجم القلب. إن العرب تعُدُّ الرجوع عن الوعد لُؤمًا، وعن الإيعاد كرمًا، وأنشد:وإنِّي وإنْ أوْعَدْتُهُ أو وَعَدْتُهُ ... لَيَكذِبُ إيعادي ويصدقُ موعدي {18} أو تقول: هذا عامٌّ في وعيد الأولياء، ووعيد الكفار، فأما مرتكبو الكبائر، فهم مخصوصون بقوله تعالى: ﴿وَيَغْفِرُ مَا دُونَ ذَلِكَ لِمَنْ يَشَاءُ﴾ [النساء: 48]."
  3,10,"قوله تعالى: ﴿إِنَّ الَّذِينَ كَفَرُوا﴾ قال ابن عباس: يعني: اليهود من قُريظة والنضير {1}.﴿لَنْ تُغْنِيَ عَنْهُمْ﴾ أي: لن تنفع، ولن تدفع. وإنما ذُكرَ (عن) مع الإغناء؛ لأنه يراد به الدفع، و (الغِنَى): ما يدفع عن صاحبه الفقر.وقوله تعالى: ﴿مِنَ اللَّهِ﴾ قال الكلبي {2}: من عذاب الله {3}.وقال أبو عبيدة {4}: معناه: عند الله. {5}(مِنْ) بمعنى: (عند) وحروف الصفات تتعاقب {6}."
  3,11,"﴿كَدَأْبِ آلِ فِرْعَوْنَ﴾. الآية. يقال: (دَأبتُ، أَدْأَبُ، دَأبًا) {1}. و (دَأَبًا)، و (دُؤُوبًا): إذا اجتهدتَ في الشيء وتعبتَ فيه {2}.قال الفراء {3}: والعرب تُثقِّلُ {4} ما كان ثانيه أحد حروف الحلق {5}:كـ (النَعْلِ)، و (الصَخْرِ)، و (النَهْرِ)، و (الشأْمِ) {6}، وأنشدَ:قد سار شرقِيّهُمْ حتى أتى سبأَ ... وانساحَ غربِيُّهُمْ حتى هو الشأَمُ {7}ويقال: (سار فلان يومًا دائِبًا): إذا اجتهد في السير يومه كله. هذا معناه في اللغة. ثم يصير الدأْب عبارة عن: الحال، والشأن، والأمر، والعادة؛ لاشتمال العمل والجهد على هذا كله {8}.واختلفوا في معنى الكاف في قوله: ﴿كَدَأْبِ﴾: فقال ابن عباس، وعكرمة {9}، ومجاهد، والسدِّي، وابن زيد {10}: كفعل آل فرعون، وصنيعهم في الكفر والتكذيب.يريد: إن اليهود كفرت بمحمد ﷺ كعادة آل فرعون مع فرعون، عرفوا كَذِبَهُ وصِدْقَ موسى، وكذلك كفار الأمم الخالية.وعلى هذا التقدير: دأبهم في الكفر، كدأب آل فرعون، فيكون الكافُ في موضع رفعٍ بخبر الابتداء {11}.و (الدأب) على هذا التفسير والتقدير إن شِئت قلت: معناه: الأمر والشأن. وهو قول الأخفش {12}. وإن شئت قلت: العادة. وهو قول النضر {13} والمبَرِّد {14}.وأما الزجَّاج، فإنه أجرى (الدأب) على ما هو موضوع عليه في اللغة، فقال {15}: القول فيه عندي: إنَّ دأب هؤلاء أي {16}: اجتهادهم في كفرهم، وتظاهرهم على النبي ﷺ، كتظاهر آل فرعون على موسى عليه السلام.قال ابنُ الأنباري {17}: لم يخاطب الله تعالى العرب إلَّا بما تَعْقِل {18}، وقد يكون من عادتها أن تحذف المُشَبَّهَ، وتذكر المشَبَّهَ به {19}، وتكون كاف التشبيه دليلًا على المحذوف، كقول امرئ القيس:كَدَأبِك من أُمِّ الحْوَيْرِث .... البيت {20}.أي لَقِيتَ من هذه المنازل، كما لَقِيتَ من هاتين المرأتين {21}، فحذف، وهذا مشهور في الكلام.وقال بعض أهل المعاني {22}: يجوز أن يكون الكاف في محل النصب، متصلة بقوله: ﴿وَأُولَئِكَ هُمْ وَقُودُ النَّارِ (10) كَدَأْبِ آلِ فِرْعَوْنَ﴾؛ لأن (الوقود) وإن كان اسما، ففيه معنى الفعل، ويكون التقدير: تَتَّقد النارُ بأجسامهم [كما تَتَّقدم بأجسام] {23} آل فرعون، ولم تغن عنهم أموالهم ولا أولادهم عند حلول {24} النقمة والعقوبة، مثل آل فرعون، أخذناهم وعاقبناهم، فلم يغن عنهم أموالهم ولا أولادهم {25}.وعلى هذا القول: شُبِّه حال كفار اليهود بحال آل فرعون في العقوبة، وقلة غناء أسوالهم عنهم، وفي القول الأول: التشبيه وقع بين الحالتين في الكفر والتكذيب.قال النحويون: ولا يجوز أن تكون الكاف من صلة (كفروا) في قوله: ﴿إِنَّ الَّذِينَ كَفَرُوا﴾ لما وقع بينهما من الفصل بخبر (إنَّ) {26}.وقوله تعالى: ﴿فَأَخَذَهُمُ اللَّهُ بِذُنُوبِهِمْ﴾. قال بعض أهل اللغة: معنى الذَّنْب: التُّلُوُّ للشيء. (ذنَبَه، يذْنِبهُ، ذنْبًا): إذا تلاه. و (الذَّنُوبُ): الدَّلْو؛ لأنها تالية للحبل في الجذب، وأصله من (الذَّنَبِ)؛ لأنه تالٍ لصاحبه {27}.فالذَّنْب: الجُرْم {28}؛ لأن تبعته تتلو صاحبه من استحقاق الذم {29}.وقوله تعالى: ﴿شَدِيدُ الْعِقَابِ﴾. إنما سُمِّي عقابًا؛ لأنه يعقب الذنب."
  3,12,"قوله تعالى: ﴿قُلْ لِلَّذِينَ كَفَرُوا﴾. قال ابن عباس في رواية عكرمة، وسعيد بن جبير، وأبي صالح {1}، وعطاء {2}: يعني يهود المدينة {3}.وقال مقاتل {4}: هم مشركو مكة. واللفظ يحتمل الفريقين جميعًا. يدل على ذلك قوله: ﴿مَا يَوَدُّ الَّذِينَ كَفَرُوا مِنْ أَهْلِ الْكِتَابِ وَلَا الْمُشْرِكِينَ﴾ [البقرة: 105] فَفَسَّرَ ﴿إِنَّ الَّذِينَ كَفَرُوا﴾ بالقبيلين، وكذلك قوله: ﴿لَمْ يَكُنِ الَّذِينَ كَفَرُوا مِنْ أَهْلِ الْكِتَابِ وَالْمُشْرِكِينَ﴾ [البينة: 1].وقوله تعالى: ﴿سَتُغْلَبُونَ﴾. يقال: غَلَبَ، غَلَبةً، وغَلَبًا. والغَلَبة أكثر {5}.قال الفرَّاء {6}: وكان قوله: ﴿مِنْ بَعْدِ غَلَبِهِمْ﴾ [الروم: 3]، حُذفت منها الهاء لمَّا أُضيفت {7}، كما قال: ﴿وَإِقَامِ الصَّلَاةِ﴾ [النور: 37] فحُذفت منها الهاء للإضافة. وفيه قراءتان: الياء والتاء {8}، وكذلك قوله: ﴿تُحْشَرُونَ﴾. فمن قرأ بالتاء: فللمخاطبة. ويدل {9} على حُسن {10} التاء {11}: قوله تعالى {12}: ﴿وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ النَّبِيِّينَ لَمَا آتَيْتُكُمْ﴾ [النور: 3].ومن قرأ بالياء، فالمعنى: بلِّغهم أنهم سيُغلَبون. ويدل على صحة الياء: قوله: ﴿قُلْ لِلَّذِينَ آمَنُوا يَغْفِرُوا﴾ [الجاثية: 14]، وقوله: ﴿قُلْ لِلْمُؤْمِنِينَ يَغُضُّوا مِنْ أَبْصَارِهِمْ﴾ [النور: 30]، ولم يقل: (غُضُّوا).قال الفرَّاء {13}: مَن {14} قرأ بالتاء: جعل اليهود والمشركين {15} داخلين في الخطاب، ثم يجوز في هذا المعنى: الياء، والتاء؛ كما تقول في الكلام: (قل لعبد الله إنه قائم، وإنك قائم) {16}.وفي حرف عبد الله {17}: (قل للذين كفروا إن ينتَهوا {18} يُغفَر لكم {19} ما قد سلف) {20}.ومن قرأ بالياء: فإنه ذهب إلى مخاطبة اليهود، وإلى أن الغلبة تقع على المشركين، كأنه قيل: (قل يا محمد لليهود: سَيُغلَبُ المُشركون، ويُحشَرون) فليس يجوز في هذا المعنى {21} إلَّا الياء؛ لأن المشركين غَيبٌ.وقال غير الفرَّاء {22}: جعل المخاطبة للفريقين أحسن؛ لجواز وقوع (الذين كفروا) عليهما ولأنهما جميعًا مغلوبان: فاليهود غُلِبوا بوضع الجِزْيِ {23} عليهم، والمشركون غُلِبوا بالسيف.وقال صاحب النظم {24}: من قرأ بالتاء، فالأمر واقع على هذه اللفظة بعينها، أي {25}: قل لهم هذا القول، ومن قرأ بالياء، فالأمر واقع على المعنى دون اللفظ أي قل لهم ما يكون هذا معناه، وإن لم تكن هذه اللفظة بعينها {26}.قال مقاتل {27}: لما نزلت هذه الآية، قال النبي ﷺ للكفار يوم بدر: ""إن الله غالبكم وحاشركم إلى جهنم"".وقوله تعالى: ﴿وَبِئْسَ الْمِهَادُ﴾ قال مجاهد {28}: بئس ما مَهَدوا لأنفسهم.وقال الحسن {29}: بئس القرار.وقيل {30}: بئس الفراش المُمَهَّدُ لهم. وقال ابن عباس في رواية عطاء {31}: بئس ما مُهِّدَ لكم، وبئس ما مَهَّدتم لأنفسكم.وقال أصحاب المعاني: ليس {32} هناك تمهيد، ولكن المعنى: إنها بدلُ المهاد؛ كما أن البشارة بالعذاب بدل البشارة بالنعيم في قوله: ﴿فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ﴾ {33}."
  3,13,"قوله تعالى: ﴿قَدْ كَانَ لَكُمْ آيَةٌ﴾ قال الفراء {1}: أراد بالآية البيان {2}؛ فلذلك ذَكَّرَ الفِعْلَ كأن ذهب إلى المعنى، وترك اللفظ كقول الشاعر:كَخُرْعُوبَةِ البانَةِ المنفطرْ {3} [ولم يقل المنفطرة] {4} لأنه ذهب إلى القضيب.ويجوز أن يكون التذكير للفصل [الواقع] {5} بينهما بحرف الصفة؛ كقول الشاعر:إنَّ {6} امرءَّاَ غرَّه مِنْكُنَّ واحدةٌ {7} ... بعدي وبعدك في الدنيا لَمَغْرُورُ {8} والخطاب في هذه الآية للمعنيِّينَ بقوله: ﴿قُلْ لِلَّذِينَ كَفَرُوا﴾ وأراد بالآية عَلاَمَةً تدل على صدق النبي ﷺ.وقوله تعالى: ﴿فِي فِئَتَيْنِ﴾ أراد بالفئتين: رسول الله ﷺ وأصحابه يوم بدر، ومشركي مكة حين خرجوا لقتاله، في قول جميع المفسرين.وقوله تعالى: ﴿فِئَةٌ تُقَاتِلُ﴾ الرفع {9}، وجْه الكلام، لأن المعنى: إحداهما تقاتل في سبيل الله، فهو رفع على استئناف من الكلام كما أنشدهُ {10} الفرَّاء:إذا مُتُّ كانَ الناسُ صِنْفَيْنِ {11}: شامتٌ ... وآخرُ مُثْنٍ بالذي كنت أفعل {12} ابتدأ الكلام بعد الصنفين، ولو كُسِرت على البدل من {13} ﴿فِئَتَيْنِ﴾ جاز؛ كما قال كُثَيِّر {14}:وكنت كذي رِجلين: رجلٍ صحيحة ... ورِجْلٍ رَمى فيها الزمانُ فَشَلَّت {15} [يُنشَدُ البيتُ على وجهين {16}.ومما فُسِّر به الأول، فتبعه في الإعراب، ما أنشده] {17} الفرَّاء:حتى إذا ما استقلَّ النجمُ {18} في غَلَسٍ ... وغُودر البقْلُ {19} مَلْويٌّ ومحصودُ {20} ففسر، فقال: بعض البقل كذا، وبعضه كذا، والنَّصْب جائز {21}.وقوله تعالى: ﴿يَرَوْنَهُمْ مِثْلَيْهِمْ رَأْيَ الْعَيْنِ﴾ الرؤية {22} ههنا متعدية إلى مفعول واحد، يدلك على ذلك تقييده بـ ﴿رَأْيَ الْعَيْنِ﴾. وإذا كان كذلك كان انتصاب ﴿مِثْلَيْهِمْ﴾ على الحال {23}، لا على أنه مفعول ثانٍ كما تقول: (رأيت زيدًا راكبًا).وقوله (مثليهم): المِثْل: يجوز إفراده في موضع التثنية والجمع؛ كقول الشاعر:وساقِيَيْنِ مثلِ زيدٍ وجُعَلْ {24} وقال الله تعالى: ﴿إِنَّكُمْ إِذًا مِثْلُهُمْ﴾ {25} [النساء: 140] ولم يقل: أمثالهم. وقد جمع في قوله ﴿ثُمَّ لَا يَكُونُوا أَمْثَالَكُمْ﴾ [محمد: 38].وقوله تعالى: ﴿رَأْيَ الْعَيْنِ﴾. يقال: (رَأَيْتُه {26} رَأيًا)، و (رُؤْية)، و (رأيته في المنام رُؤيا حَسَنَةً) غَيْر مُجْراةٍ {27}. فالرؤيا تختص بالمنام، وهو مصدرٌ لـ (رأيت) {28}، ويقول: (هو منى رأْيَ العَيْنِ) أي: حيث يقع عليه بصري. فقوله: ﴿رَأْيَ الْعَيْنِ﴾ يجوز {29} أن يَنْتَصِبَ عدى المصدر {30}، ويجوز أن يكون ظرفًا للمكان {31}، كما تقول: (تروْنهم أَمامَكم). ومثله: (هو مِنِّى مَزْجَرَ الكَلْبِ) {32}، و (مَنَاطَ العَيُّوقِ) {33}.وفي قوله: ﴿يَرَوْنَهُمْ﴾ قراءتان: التَّاءُ {34}، والياء {35}. فمن قرأ بالتَّاء؛ فلأن ما قبله خطاب لليهود؛ والمعنى: تَرَوْن أيها اليهود المسلمينَ مِثْلي ما كانوا، أي: مِثْلي الفئة الكافرة؛ وذلك أن الله تعالى كَثَّر المسلمين في أعينهم يوم بَدْر. فذلك الآية، والأُعجوبة، وهو أنهم رَأَوا القليلَ كثيرًا. ويجوز أن تكون الكناية عن الفئة الكافرة، وهم المشركون، والمعنى: تَرَوْنَ المشركين ضِعفي المؤمنين.ونذكر بعد هذا كيف رأَوْهم مِثْلَيهم، وهم كانوا ثلاثةَ أمثالهم؟! {36}.ومن قرأ بالياء؛ فَلِلْمُغايَبَةِ {37} التي جاءت بعد الخطاب، وهو قوله: ﴿فِئَةٌ تُقَاتِلُ فِي سَبِيلِ اللَّهِ وَأُخْرَى كَافِرَةٌ﴾. فقوله: ﴿يَرَوْنَهُمْ﴾ يعود إلى الإخبار عن إحدى الفِئتين: يجوز أن يكون خَبرًا عن الفئة المسلمة، ويجوز {38} أن يكون خبرًا عن الفئة الكافرة {39}. فإن جعلته خبرًا عن الفئة المُسْلمة {40}، فالمعنى: يرى المسلمونَ المشركينَ مِثْلَيهم.فإن قيل: المسلمون يوم بَدر كانوا ثلاثمائة وثلاثةَ عشر رجلًا، والكفار كانوا تسعمائة وخمسين رجلًا {41}، فكيف رأى المسلمون {42} المشركين مِثْليهم، وهم كانوا ثلاثة أمثالهم؟!فزعم الفرَّاءُ {43}: أن المعنى: يرونهم ثلاثة أمثالهم. قال: لأنك إذا قلت: (عندي ألف، وأحتاج إلى مِثليه). فأنت تحتاج إلى ثلاثة {44} آلاف {45}؛ لأنك لمَّا نَوَيْتَ أن يكون الألف الذي عندكَ داخلًا في المِثْل، كان (المِثْل): اثنين، و (المثلان): ثلاثة. وعلى هذا {46} الآية كانت في أن المسلمينَ رَأَوْا المشركين على ما هم عليه مِنْ وُفُورِ العَدَدِ، ومع ذلك كانت قلوبهم مملوءةً جُرْأةً عليهم، واحتقارًا لهم، وشهوةً لملابستهم {47}.قال الزجاج {48}: وهذا غلط؛ لأنَّا إنما نعقل (مِثْل الشيء): مساويًا له، و (مثليه): ما يساويه مَرَّتَيْن. والذي قاله الفرَّاءُ يَبْطُل في معنى الدلالة على الآية المعجزة؛ لأن المسلمين إذا رأوهم على هيئتهم، فليس في هذا آيةً، وإنما المعنى في هذا: أن الله عز وجل أرى المسلمين أنَّ المشركين إنما هم {49} ستمائة وكَسْر، وذلك {50}، ان الله عز وجل كان قد أعلم المسلمين أن المائة منهم تغلب المائتين من الكفار {51}، فأراهم المشركين على قَدْرِ ما أعلمهم أنهم يغلبونهم؛ ليُقَوِّي قلوبَهم.والدليل على صحة هذا المعنى: قوله: ﴿وَإِذْ يُرِيكُمُوهُمْ إِذِ الْتَقَيْتُمْ فِي أَعْيُنِكُمْ قَلِيلًا وَيُقَلِّلُكُمْ فِي أَعْيُنِهِمْ﴾ [الأنفال: 44]، فرأى كلُّ واحدٍ من الفريقين الآخرَ أقلَّ مِمّا كانوا؛ لِيَطْمَعَ كلُّ واحد منهما في الآخر، فيتقدم ويُلابِسَ. وهذا {52} هو الذي فيه الآية المعجزة، وهو رؤية الشيء بخلاف صورته. انتهى كلامه {53}.هذا إذا جعلنا قوله: ﴿يَرَوْنَهُمْ﴾ إخبارًا عن المؤمنين، فإنْ جعلته إخبارًا عن الفئة الكافرة {54}، فيكون المعنى: يُرِي الفئةَ الكافرةَ الفئةَ المقاتلةَ في سبيل الله مِثْلَيهم أي: مِثْلي ما كانوا، أو {55} مِثْلي أنفسهم، على ما ذكرنا مِنْ تكثير الله إيَّاهم.فإن قيل: كيف يصح تكثير الله المسلمينَ في أعينِ الكافرين، وقد قال: ﴿وَيُقَلِّلُكُمْ فِي أَعْيُنِهِمْ﴾ [الأنفال: 44].فالجواب: ما قاله أبو عبيد {56}، وهو إنَّ التقليل كان في حالة أخرى، فالله {57} تعالى كثَّر المسلمين في أعين الكافرين، كما قَلَّل الكافرين في أعينهم، ثم في حالة أخرى، قَلَّل المسلمين في أعينهم؛ لِيَطْمَعوا {58} فيهم، فإذا لابسوهم، كانت العاقبةُ للمسلمين عليهم. فَكِلا {59} الأمرين فيه دلالة على لُطْف الله عز وجل للمؤمنين {60}، وحُسْن مَعُونَتِه إياهم.والقراءة الصحيحة الموافقة للآية التي في الأنفال من غير اختلاف حالين: قراءة العامة، وهي الياء المُعْجَمة، على المعنى الذي ذكره الزجَّاج.على أنَّ الفرَّاء {61} قال: يجوز أن يكون التقليل الذي ذُكِر {62} في الأنفال لم يكن من طريق تقليل العَدَد، ولكن معناه: التهوين، كما تقول: (إني لأرى كثيرَكم قليلًا)، أي: قد هُوِّن علي، لا {63} أنك ترى الثلاثةَ اثنين {64}. وإذا كان كذلك صَحَّ تكثيرُ الله المسلمين في أعين الكافرين، على ما ذكرنا.وقوله تعالى: ﴿وَاللَّهُ يُؤَيِّدُ بِنَصْرِهِ مَنْ يَشَاءُ﴾ نَصْرُ الله تعالى المسلمين على وجهين: نَصْرٌ بالغَلَبَةِ، كنصرهم يوم بدر. ونَصْرٌ بالحُجَّة. ولو هُزِمَ قومٌ مِنَ المؤمنين لجاز أن يقال: هم المنصورون بالحُجَّة، ومحمودِ العاقبة.وقوله تعالى: ﴿إِنَّ فِي ذَلِكَ لَعِبْرَةً﴾ العِبْرَة: الاعتبار {65}، وهي: الآية التي يُعْبَر {66} بها من منزلة الجهل إلى العلم؛ لأن المعتبر بالشيء، تاركٌ جهلَه، وواصلٌ إلى عِلْمِهِ بما رأى.وأصلُه من: (العُبُور)، وهو: النفوذ من أحد {67} الجانبين إلى الآخر. ومنه: (العِبارة) وهو: الكلام الذي يَعْبرُ {68} بالمعنى إلى المخاطَب، و (عبارة الرُّؤْيا) من ذلك؛ لأنه تفسير لها، يَعْبُر بها من حال النَوْم إلى حال اليَقَظَةِ بإظهار التأويل {69}.وقوله تعالى: ﴿لِأُولِي الْأَبْصَارِ﴾ أي: لأولي {70} العقول؛ كما يقال: (لِفُلانٌ {71} بَصَرٌ بهذا الأمر)، أي: على علم ومعرفة. وليس بالأبصار التي يشترك فيها سائرُ الحيوان."
  3,14,"قوله تعالى: ﴿زُيِّنَ لِلنَّاسِ حُبُّ الشَّهَوَاتِ﴾. يقال: مَن الذي زَيَّن للناس ذلك؟ فيقال: اللهُ تعالى زَيَّن للناس؛ بما جعل {1} في الطِبَاع من المنازعة إلى هذه الأشياء محنةً، كما قال الله عز وجل: ﴿إِنَّا جَعَلْنَا مَا عَلَى الْأَرْضِ زِينَةً لَهَا لِنَبْلُوَهُمْ﴾ [الكهف: 7].وقال بعضهم {2}: الشيطان زينها؛ لأن الله تعالى زهَّد فيها؛ بأنْ أعلم وأرى زوالها {3}، ولو زهَّد فيها {4} حقيقةً؛ لوُجد ذلك في الخَلْقِ كلِّهم، كما وُجِد التزيين؛ فإنَّ حُبَّ هذه الأشياء موجودٌ في طِبَاع البَشَر {5}.والشهوة: تَوَقان النفس إلى الشيء، وقد ذكرناها في سورة الأعراف، عند قوله: ﴿شَهْوَةً مِنْ دُونِ النِّسَاءِ﴾ [الأعراف: 81].وقوله تعالى: ﴿وَالْقَنَاطِيرِ﴾. جَمْعُ (قِنْطار)، وكثر الاختلاف في معنى (القنطار): فروى أبو هريرة {6} عن النبي ﷺ، أنه قال: ""القنطار: اثنا {7} عشر ألف أوقية"" {8}.وروى أنس عنه أيضًا: أن القنطار: ألف دينار {9}.وروى أُبَيُّ بن كعب، أنه قال: القنطار {10}: ألف ومائتا أوقية {11} وهو قول ابن عمر {12}، ومعاذ بن جبل {13} وابن عبَّاس في {14} رواية عَطيَّة {15}.وقال في رواية الوالبي: القنطار: اثنا {16} عشر ألفَ درهم، أو ألفُ دينار، دِيَةُ أحدِكم {17}.وبه قال: الحسن {18} [وقتادة] {19}.وقال الكلبي {20}: القنطار بلسان الروم: مِلْءُ {21} مَسْكِ ثَوْر {22}، من ذهب أو فضة. وهو قول أبي نَضْرة {23}.ويقال: إنَّه في التوراة كذا. وبلسان أفريقية، وأندلس: ثمانية ألف {24} مثقال من ذهب أو فضة {25}.قال الزجَّاج {26}: والذي يخرج من اللغة أن (القنطار) مأخوذ من عَقْدِ الشيء وإحكامه، و (القَنْطَرة) من ذلك؛ لتوثيقها بعَقْدِ الطَّاق {27}. وكأن القنطار {28}: هي الجملة التي تكُونُ عقْدَةً وثيقةً منه {29}.وهذا قول الربيع {30}، وابن كيسان {31}، وأبي عبيدة {32}؛ فإنهم لم يحدُّوا القنطار، فقالوا: إنه المال {33} الكثير.وحكى أبو عبيدة عن العرب: أنهم يقولون: هو وزن لا يُحَدُّ {34}.وقوله تعالى: ﴿الْمُقَنْطَرَة﴾ قال أهل اللغة: {35} هو (مُفَعْلَلَة)، من: (القنطار)؛ كما قالوا: (إبلٌ مُؤبَّلةٌ)؛ أي: مجموعة، و (ألفٌ مؤلَّفٌ).فمعنى: ﴿الْمُقَنْطَرَة﴾: أنها جُمعت حتى صارت قناطير؛ كما يقال: (دراهم مُدَرْهَمَة)؛ أي: مجعولة كذلك.وقال يَمَان {36}: قَنطر، أي: كَنَزَ {37}.وقال أبو العباس {38}: اختلف الناس في القنطار، والمعمول عليه عند العرب: أنه أربعة آلاف {39} دينار [قال: وقوله ﴿الْمُقَنْطَرَة﴾، يقال: (قد قنطر فلان): إذا مَلَكَ أربعةَ آلاف دينار] {40}، فإذا قالوا: مقنطرة؛ فمعناها: ثلاثة أدوار؛ دَوْرٌ، ودور، ودور. فمحصولها: اثنا عَشَرَ ألف دينار.وقوله تعالى: ﴿مِنَ اَلذَّهَبِ﴾ الذهب: التِّبْر. والقِطْعَةُ ذَهَبَة {41}. ﴿وَالْفِضَّةِ﴾ الفَضُّ في اللغة معناه: التفريق، والكسر {42}. ومنه: (لا يَفْضُض {43} الله فاكَ) {44}، فالفضة سُمِّيت؛ لأن من شأنها أن تُفَرَّق بضرب الدراهم.وقوله تعالى: ﴿وَالْخَيْلِ الْمُسَوَّمَةِ﴾ الخيل: جَمْعٌ لا واحد له من لفظه، كـ (القَوْلِ)، و (النساءِ)، و (الرَّهْطِ) {45}.سُمِّيت الأفراسُ (خيلًا)؛ لاختيالها في مِشْيتها بطول أذنابها؛ ألا ترى إلى قول امرئ القيس:لها ذَنَبٌ مِثْلُ ذيلِ العروسِ ... تَسُدُّ {46} به فَرْجَها من دُبُرْ {47}.والاختيال: مأخوذ من (التَّخَيُّل)، والتخيُّل: التَّشَبُّه بالشيء {48}، ومنه يقال: (أخال عليه الأمرُ): إذا اشتبه، فالمختال {49}، يَتَخيَّل في صورة من هو أعظم منه كِبْرًا، والخيال: صورة الشيء.والأخْيَلُ {50}: الشِّقِرَّاقُ {51}؛ لأنه يَتَخيَّلُ، مرةً أخضر، ومرةً أحمر.واختلفوا في معنى ﴿الْمُسَوَّمَةِ﴾: فقال ابن عباس في رواية عطية {52}: هي الراعية؛ يقال: (أَسَمْتُ الماشيةَ)، و (سوَّمتُها): إذا رَعَيتُها، فهي (مُسَامةٌ)، و (مُسَوَّمة) {53}، ومنه ﴿فِيهِ تُسِيمُونَ﴾ [النحل: 10].وقال في رواية الوالبي {54}: هي المُعْلَمَةُ. وأصلها من: (السِّيْما)، التي هي: العلامة.ومعنى العلامة ههنا: (الكَيُّ) في قول المؤرِّج {55}، والبَلَقُ {56} في قول ابن كَيْسان {57}، والشِّيَةُ {58}، في قول قتادة {59}.وقال مجاهد {60}، وعكرمة {61}: الخيل المُسوَّمة: هي الحسان المُطَهَّمَةُ {62}، يُراد: أنها ذات سيما؛ أي: ذات حُسن. يقال: (لفلان سِيما)، و (له شارةٌ حَسَنة) {63}.وقوله تعالى: ﴿وَالْأَنْعَامِ﴾ جمع (نَعَم)، والنَّعَم: الإبل والبقر والغنم. ولا يُقال لجنس منها: (نَعَمٌ)، إلَّا للإبل خاصة؛ لأنه غلب عليها {64}. ومضى فيما قبل اشتقاق (النَعَم).وقوله تعالى: ﴿حُسْنُ الْمَآبِ﴾ المآب في اللغة: المرجعُ. يقال: (آب الرَّجُلُ، إِيابًا)، و (أَوْبَةً)، و (أبيَةً) {65}، و (مآبًا) {66}. قال الله تعالى: ﴿إِنَّ إِلَيْنَا إِيَابَهُمْ﴾ [الغاشية: 25].قال الفرَّاء {67}: ولا يجوز التشديد {68} في (الإياب)، وقارِئُه {69} لعله ذهب على الإفعال، والإفعال من (أُبْتُ)، إنما {70} يأتي على مثل: (أقَمْتُه إقامَةً)، و (أزَغتُه إزاغةً).فلو أردت ذلك، قلتَ: (أَأَبْتهُ إآبَةً) {71}، ولو أردت أن تُخرجَ المصدرَ {72} تامًا، قلت: (إيوابًا). ثم أعلم الله عز وجل أن خيرًا من جميع ما في الدنيا ما أعدَّه الله لأوليائه، فقال:"
  3,15,"﴿قُلْ أَؤُنَبِّئُكُمْ بِخَيْرٍ مِنْ ذَلِكُمْ﴾ الذي ذَكَرتُ {1}.قوله تعالى: ﴿لِلَّذِينَ اتَّقَوْا﴾ قال ابن عباس في رواية عطاء {2}: يريد: المهاجرين والأنصار، أراد الله أن يعزِّيَهم، ويشوقهم إلى المعاد.قال العلماء: ويدخل تحت هذا الخطاب كلُّ {3} من اتقى الشرك، بظاهر هذا الكلام {4}.وقوله تعالى: ﴿جَنَّاتٌ﴾ يرتفع على وجهين:أحدهما: بخبر الصفة، ويكون تمام الكلام عند قوله: ﴿بِخَيْرٍ مِنْ ذَلِكُمْ﴾.والثاني: على تقدير الجواب، ويكون تمام الكلام عند قوله {5}: ﴿عِنْدَ رَبِّهِمْ﴾، فكأنه قيل: ما ذلك الخير؟ فقيل: هو جنَّات، ومثله: ﴿قُلْ أَفَأُنَبِّئُكُمْ بِشَرٍّ مِنْ ذَلِكُمُ النَّارُ﴾ [الحج: 72]؛ أي: هو النار.وقوله تعالى: ﴿وَأَزْوَاجٌ مُطَهَّرَةٌ﴾ قد ذكرنا ما فيه عند قوله: ﴿وَلَهُمْ فِيهَا أَزْوَاجٌ مُطَهَّرَةٌ﴾ [البقرة: 25].وقوله تعالى: ﴿وَرِضْوَانٌ مِنَ اللَّهِ﴾. ويُقرأ {6} بضم الراء {7}، وهو لغة قيس وتميم {8}.قال الفراء {9}: يقال: (رضيت رضًا)، منقوص، و (رِضوانًا، ورُضوانًا {10}، ومَرْضاةً).ومثل (الرِّضوانِ) بالكسر من المصادر: (الرِّئْمان) {11}، و (الحِرْمان).وبالضمِّ: (الطُّغْيان)، و (الرُّجْحان)، و (الكُفْران). وقال {12} سيبويه {13}: (الشُّكْران)."
  3,16,"قوله تعالى: ﴿الَّذِينَ يَقُولُونَ﴾ موضع ﴿الَّذِينَ﴾ {1}: خفض؛ صفةً ﴿الَّذِينَ اتَّقَوا﴾. [و] {2} المعنى: للمتقين القائلين {3}."
  3,17,"[و] {1} قوله تعالى: ﴿الصَّابِرِينَ﴾ قال ابن عباس {2}: يريد: على دينهم، وعلى [ما] {3} أصابهم.﴿وَالصَّادِقِيَن﴾: قال قتادة {4}: هم قوم صدقت نيَّاتهم، واستقامت قلوبُهم وألسنتهم، فصدقوا في السرِّ والعلانية.ومعنى الصدق: الإخبار بالشيء على ما هو به {5}، وذكرنا أصله في اللغة عند ذكر اشتقاق الصدقة في سورة البقرة.﴿وَالْقَانِتِينَ﴾ {6} الطائعين لله، عن أكثر المفسرين {7}. ومضى الكلام في معنى القانتين.﴿وَالْمُنْفِقِينَ﴾ قال ابن عباس {2}: يريد: الذين ينفقون الحلال في طاعة الله [تعالى] {1}.﴿وَالْمُسْتَغْفِرِينَ بِالْأَسْحَارِ﴾. السَّحَر: الوقت الذي قبيل {10} طلوع الفجر. و (تَسَحَّر): إذا أكل في ذلك الوقت. و (استَحَرَ)؛ أي {11}: سار فيه {12}.قال زهير {13}:بَكَرْنَ بُكورًا، واسْتَحَرْنَ بسُحْرَةٍ {14}والمُسْتَحِرُ من الطَّيْرِ: ما يَصيحُ {15}، ويتحرك فيه {16}.قال امرؤ القيس:إذا طَرَّبَ الطائرُ المُسْتَحِرْ {17} وأسْحَرَ {18} دخل {19} في وقت السَّحَر {20}.ونذكر كلام النحويين في ترك إجراء (سحر) عند قوله: ﴿نَجَّيْنَاهُمْ بِسَحَرٍ﴾ [القمر: 34] إن شاء الله.قال ابن عباس {2} في قوله: ﴿وَالْمُسْتَغْفِرِينَ بِالْأَسْحَارِ﴾: يريد: المصلين صلاة الصبح {22}، وهو قول زيد بن أسلم {23}، وابن كيسان {24}.وقال مجاهد {25}، وقتادة {26}: يعني: المصلين بالأسحار {27}.قال الزجَّاج {28}: وصف الله - تعالى {29} هؤلاء بما وصف، ثمَّ بيَّن أنهم مع ذلك لشدة خوفهم ووجلهم يستغفرون بالأسحار."
  3,18,"قوله تعالى: ﴿شَهِدَ اللَّهُ أَنَّهُ لَا إِلَهَ إِلَّا هُوَ﴾ قال أبو إسحاق {1}، وأبو العباس {2}: معنى ﴿شَهِدَ اللَّهُ﴾: بيَّن وأظهر {3}؛ لأنَّ الشاهد {4}: هو العالم الذي يبين ما علمه. فالله عز وجل قد دلَّ على توحيده بجميع ما خلق، فبيِن أنه لا يقدر أحدٌ أن ينشيء شيئًا واحدًا مما أنشأ.قال أبو العباس {5}: ونظير هذا في القرآن مما أُريد فيه بالشهادةِ: التبيينُ، وإن لم يقارنه القولُ: قولُه عز وجل: ﴿مَا كَانَ لِلْمُشْرِكِينَ أَنْ يَعْمُرُوا مَسَاجِدَ اللَّهِ شَاهِدِينَ عَلَى أَنْفُسِهِمْ بِالْكُفْرِ﴾ [التوبة: 17]، معناه: مبيِّنين على أنفسهم الكفر؛ وذلك أنهم يؤمنون بأنبياء {6}، كلهم شاهد لمحمدٍ ﷺ بالصِّدق، فلما آمنوا بأنبياء {6} بشَّروا بمحمد، وحثُّوا على اتباعه، ثم خالفوا عليه فكذبوه وحاربوه، بيَّنوا بذلك الكفر على أنفسهم، فوُصفوا بأنهم شَهِدوا به، وإنْ لم يكونوا قالوا: نحن كفار {8}.وقوله تعالى: ﴿وَالْمَلَائِكَةُ﴾ أي: وشهدت الملائكة، بمعنى: أقرَّت بتوحيد الله -تعالى-؛ لما عاينت من عظيم قدرته؛ كقوله: ﴿شَهِدْنَا عَلَى أَنْفُسِنَا﴾ [الأنعام: 130]؛ أي: أقررنا. فَنَسَق شهادة الملائكة وأولي العلم على شهادة الله سبحانه، والشهادتان مختلفتان معنًى لا لفظًا، كقوله عز وجل: ﴿إِنَّ اللَّهَ وَمَلَائِكَتَهُ يُصَلُّونَ عَلَى النَّبِيِّ﴾ [الأحزاب: 56]، والصلاة من الله: الرحمة، ومن الملائكة: الاستغفار والدعاء {9}.وقال ابن الأنباري {10}: إنما عَطَف الملائكةَ وأولي {11} العلمِ على اسمه؛ لأن الشهادة معناها في اللغة: إظهارُ المعلوم وتبَيُّنُه. فلمَّا بيَّن أولوا العلم المعلومَ {12} [عندهم؛ كما بيَّنه الله عز وجل، عطفهم على اسمه؛ للاتفاق في إظهار المعلوم] {13}.وقوله تعالى: ﴿وَأُولُو الْعِلْمِ﴾ أي: وشهد بتوحيده أولوا العلم؛ بما ثبت عندهم. وشهادة أولي {14} العلم: يجوز أن تكون بمعنى: الإقرار، ويجوز أن تكون بمعنى: التبيين {15}.واختلفوا في المعنيين بـ (أولي العلم) ههنا: فقيل {16}: هم الأنبياء، وقال مقاتل {17}: هم مؤمنو أهل الكتاب؛ لأن الله تعالى وصفهم بالعلم في مواضع من كتابه، كقوله: ﴿إِنَّ الَّذِينَ أُوتُوا الْعِلْمَ مِنْ قَبْلِهِ﴾ [الإسراء: 107]، وقوله: ﴿بَلْ هُوَ آيَاتٌ بَيِّنَاتٌ فِي صُدُورِ الَّذِينَ أُوتُوا الْعِلْمَ﴾ [العنكبوت: 49].قال ابن كيسان {18}: يعني: المهاجرين والأنصار، وهو قول ابن عباس فى رواية عطاء {19}.وقال السدي والكلبي {20}: يعني {21}: علماء المؤمنين كلهم {22}.وقوله تعالى: ﴿قَائِمًا بِالْقِسْطِ﴾. ينتصب على الحال من اسم الله جل وعز، على تقدير: شهد الله قائمًا بالقسط. ويجوز أن يكون حالًا من: هو؛ تقديره: لا إله إلَّا هو قائمًا بالقسط {23}.وقال الفراء {24}: هو نصب على القطع {25}، لأنه نكرة نُعِت {26} به معرفة، كان {27} أصلها: (القائم بالقسط)؛ فلما {28} قُطعت الألفُ واللامُ نصب {29}.ومعنى قوله: ﴿قَائِمًا بِالْقِسْطِ﴾: قائمًا بالعدل {30}، كما يقال: (فلان قائم بالتدبير)؛ أي: يُجْرِيه على الاستقامة. فالله {31} تعالى يُجري التدبير على الاستقامة في جميع الأمور {32}."
  3,19,"قوله تعالى: ﴿إِنَّ الدِّينَ عِنْدَ اللَّهِ الْإِسْلَامُ﴾ [آل عمران: 19]. القُرَّاءُ على كسرِ (إنَّ)، إلَّا الكسائي؛ فإنه فتح (أنَّ) {1}.والوجه {2}، الكسر {3}؛ لأن الكلام الذي قبله قد تمَّ {4}، وهذا النحو من الكلام الذي يراد به التنزيه، أن يكون بجُمَلٍ متباينة أحسن؛ من حيث كان أبلغ في الثناء {5}، وأذهب في باب المدح؛ ومن ثمَّ جاء: ﴿وَالْمُوفُونَ بِعَهْدِهِمْ إِذَا عَاهَدُوا وَالصَّابِرِينَ﴾ [البقرة: 177].فأما وجه قراءة الكسائي، فإن النحويين ذكروا فيه ثلاثة أوجه:أحدها: أن تكون الشهادة واقعة على ﴿إِنَّ الدِّينَ﴾ {6}، وفَتح ﴿أَن﴾ في قوله: ﴿أَنَّهُ لَا إِلَهَ إِلَّا هُوَ﴾ على تقدير: حذف حرف الجر؛ كأنه قيل: (شهد الله؛ لأنه {7} لا إله إلَّا هو، أنَّ الدين عند الله الإسلام). وهذا معنى قول الفرَّاء، حيث يقول {8} - في الاحتجاج للكسائي: إن شِئتَ جعلتَ (أنه) على الشرط {9}، وجعلت الشهادة واقعة على قوله: ﴿إِنَّ الدِّينَ عِنْدَ اللَّهِ الْإِسْلَامُ﴾. وتكون ﴿أَن﴾ {10} الأولى يصلح فيها الخفض، كقولك: شهد الله بتوحيده، أنَّ الدين عند الله الإسلام.الوجه الثاني: أنه فتحهما على أن الواو تُراد {11} في قوله: ﴿إِنَّ الدِّينَ﴾؛ كأنه قيل: (شهد الله أنه لا إله إلَّا هو: وأنَّ الدين عند الله الإسلام). فيكون قوله {12}: (أنَّ الدين عند الله الإسلام) جملةً استغني فيها عن حرف العطف؛ بما تضمنت من ذكر الأول المعطوف عليه، وهو التوحيد، كما استغني عنه بذلك في قوله: ﴿ثَلَاثَةٌ رَابِعُهُمْ كَلْبُهُمْ﴾ [الكهف: 22]، ولو كانت (الواو) لكان ذلك حسنًا {13}، كما قال: ﴿وَيَقُولُونَ سَبْعَةٌ وَثَامِنُهُمْ كَلْبُهُمْ﴾ {14} [الكهف:22].الوجه الثالث: وهو مذهب البصريين: أن تجعل (أنَّ) الثانية بدلًا من الأولى، فكأنَّ {15} التقدير: (شهد الله أنَّه، أنَّ الدِّينَ عند الله الإسلام). فيكون هذا من الضرب الذي الشيء فيه، هو هو {16}، نحو قولك: (ضربت زيدًا نفسَه). ألا ترى أنَّ الدين الذي هو الإسلام، يتضمنُ التوحيد، وهو هو في المعنى.وإن {17} شئت، جعلته مِنْ بدل الاشتمال؛ لأن الإسلام يشتمل على التوحيد {18}، فيكون كقولك: (ضربت زيدًا، رأسَه) {19}. فإن قيل: على هذه القراءة، لو جاز إيقاع الشهادة على (أنَّ الدين)، لم يحسن إعادة اسم الله، ولكان: (أنَّ الدين عنده {20} الإسلام)؛ لأن الاسم قد سبق، فالوجه الكِنَايةُ عنه. قيل: إنَّ العرب ربما أعادت الاسم في موضع الكناية {21}؛ كقول الشاعر:لا أرى الموتَ، يسبقُ الموتَ شيءٌ {22} ومثله كثير {23}.فأما المعنى: فقال ابن عباس {24}: افتخر المشركون بآبائهم، فقال كلُّ فريق منهم: لا دين إلَّا ديننا، وهو دين الله منذ بعث الله {25} آدَم، فكذبهم الله -تعالى-، فقال: ﴿إِنَّ الدِّينَ عِنْدَ اللَّهِ الْإِسْلَامُ﴾، يعني الذي جاء به محمد ﷺ {26}.وأصل الدين في اللغة: الجزاء. ثم الطاعة تسمى دينًا؛ لأنها {27} للجزاء، وكل ما {28} يطاع الله تعالى به فهو دين {29}، فاليهود يدَّعون أنهم يطيعون {30} بما أتاهم به موسى، فذلك دين اليهودية، وكذلك النصارى، وكل فرقة. والمسلمون يطيعونه بما أتاهم به محمد ﷺ، فهو دين الإسلام {31}، والله تعالى يقول: ﴿إِنَّ الدِّينَ عِنْدَ اللَّهِ الْإِسْلَامُ﴾ ومعنى (الإسلام) في اللغة: الدخول {32} في السَّلَمِ؛ أي: في الانقياد والمتابعة. قال الله عز وجل: ﴿وَلَا تَقُولُوا لِمَنْ أَلْقَى إِلَيْكُمُ السَّلَامَ﴾ {33} [النساء: 94]؛ أي: انقاد لكم وتابعكم {34}.وقيل: أصله: السِّلْم {35}. فـ (أَسْلَمَ): دخل في السِّلْم؛ كقولهم: (أشْتى)، و (أَقْحَطَ)، و (أرْبَعَ) {36}. وأصل السِّلْم: السَّلامة؛ لأنه انقياد على السلامة.ثم من {37} الإسلام {38} ما هو متابعة وانقياد باللسان دون القلب، وهو قوله: ﴿قَالَتِ الْأَعْرَابُ آمَنَّا قُلْ لَمْ تُؤْمِنُوا وَلَكِنْ قُولُوا أَسْلَمْنَا﴾ {39} [الحجرات: 14]؛ أي: انقدنا {40}؛ من خوف السيف.ومنه، ما هو متابعة وانقياد باللسان والقلب، وهو قوله: ﴿قَالَ أَسْلَمْتُ لِرَبِّ الْعَالَمِينَ﴾، فهذا معنى الإسلام.وذكر ابن الأنباري {41} في المسلم قولًا آخر، وهو: أنَّ المسلم معناه: المُخْلِصُ لله العبادة. من قولهم: (سَلَّمَ الشيءَ لفلان)؛ أي: خلَّصه {42} له، و (سَلِمَ له الشيءُ) {43}؛ أي: خَلصَ له.فعلى هذا الإسلام معناه: إخلاص الدين والعقيدة لله تعالى، وهو التبريء عن الشرك.وأصله أيضًا من السلامة؛ لأنه يعود إلى أن يُسْلِم دينَه لله، حتى يكون له سالمًا من غير شريك.وقوله تعالى: ﴿وَمَا اخْتَلَفَ الَّذِينَ أُوتُوا الْكِتَابَ إِلَّا مِنْ بَعْدِ مَا جَاءَهُمُ الْعِلْمُ بَغْيًا بَيْنَهُمْ﴾.معنى الاختلاف في اللغة، هو: ذهابُ أحدِ النَفسَيْنِ إلى نقيض ما ذهب إليه الآخر {44}.والاختلاف في الأجناس: امتناعُ أحدِ الشيئين أن يَسُدَّ مَسَدَّ الآخر.وأراد بـ ﴿الَّذِينَ أُوتُوا الْكِتَابَ﴾: اليهود {45}. قال ابن عباس {24}: يعني: قريظة والنضير وأتباعهم. يقول: لم يختلف اليهود {47} في صدق نبوَّةِ محمد ﷺ لما كانوا يجدونه في كتابهم من نعته وصفته.﴿إِلَّا مِنْ بَعْدِ مَا جَاءَهُمُ الْعِلْمُ﴾ قال ابن عباس {48}: يريد: النبي ﷺ. وعلى هذا؛ سَمَّى النبي ﷺ (العِلْمَ)، وهو يريد المعلوم. والمصدر يقع على المفعول كثيرًا.والمعنى: أنهم كانوا يصدقونه بنعته وصفته قبل بعثه {49}، فلما جاءهم اختلفوا فآمن به بعضُهم، وكفر به الآخرون، فقالوا: لست الذي وُعِدْناهُ {50}، كقوله تعالى: ﴿فَلَمَّا جَاءَهُمْ مَا عَرَفُوا كَفَرُوا بِهِ﴾ [البقرة: 89].ويجوز أن يريد بـ (العِلْم): بيان ما جاء في التوراة من نعت محمد ﷺ وصفته، وبيان ما جاء في شأنه.يعني: أنهم ما اختلفوا إلَّا بعد صحة علمهم بنبوَّتِه، وإذا كان الاختلاف بعد العِلْم، كان ذلك أبلغ في الكفر والعناد، ودليل هذا التأويل قوله في سورة البقرة: ﴿وَمَا اخْتَلَفَ فِيهِ إِلَّا الَّذِينَ أُوتُوهُ مِنْ بَعْدِ مَا جَاءَتْهُمُ الْبَيِّنَاتُ بَغْيًا بَيْنَهُمْ﴾ [البقرة: 213].وقوله تعالى: ﴿بَغْيًا بَيْنَهُمْ﴾ معنى البغي: طَلَبٌ للاستعلاء {51} بالظلم. أخبر الله تعالى عن عِلَّةِ اختلافهم، فقال: فعلوا ذلك طلبًا للرئاسة، وحسدًا له على النُبُوَّةِ. فانتصب {52} ﴿بَغْيًا﴾ في قول الأخفش {53} على تقدير: ﴿وَمَا اخْتَلَفَ فِيهِ إِلَّا الَّذِينَ أُوتُوهُ مِنْ بَعْدِ مَا جَاءَتْهُمُ الْبَيِّنَاتُ بَغْيًا بَيْنَهُمْ﴾ {54}.وقال الزجَّاج {55}: والذي هو الأجود؛ أن يكون ﴿بَغْيًا﴾ منصوبًا بما دلَّ عليه: ﴿وَمَا اخْتَلَفَ﴾. فيكون المعنى: اختلفوا بغيًا بينهم.قال أبو علي {56}: وجهُ قولِ الأخفش: أنَّ ﴿بَغْيًا﴾ انتصب {57} على أنه مفعول له؛ أي: للبغي؛ كقولك: (جئتُ مَخافةَ الشرِّ، وابتغاءَ الخير). [قال] {14}:وأَغْفِرُ عَوْراءَ الكريمِ ادِّخارَهُ {59} ووجه قول الزجَّاج: أنَّه انتصب على المصدر؛ كأنه لمَّا قيل: ﴿وَمَا اخْتَلَفَ الَّذِينَ أُوتُوا الْكِتَابَ﴾ دلَّ {60} على: (وما بغى {61} الذين أوتوا الكتاب). فحُمِلَت ﴿بَغْيًا﴾ عليه {62}. فإن قيل: ما الفصل {63} بين ما ينتصب على المصدرة نحو: ﴿صُنْعَ الله﴾ {64}، وما ينتصب على أنَّه مفعول له؛ نحو: (ادِّخاره)، وبابه؟فالقول: إنَّ الجميع وإن كانا يجتمعان في أنهما ينتصبان عن تمام الكلام؛ فالمفعول له؛ معناه: الإخبارُ بالغرض الذي من أجله فُعِل الفعلُ، والسبب له. والعامل فيه؛ هو هذا الفعل {65} الظاهر.وأما {66} المصدر: فالنحويون يُسَّمونه مفعولًا مطلقًا؛ لأن الفاعل أحدثه.وقوله تعالى: ﴿وَمَنْ يَكْفُرْ بِآيَاتِ اللَّهِ فَإِنَّ اللَّهَ سَرِيعُ الْحِسَابِ﴾. هذا شرطٌ وجوابُ، يتضمن وعيدًا لليهود الذين كفروا بمحمد ﷺ. وذكرنا معنى ﴿سَرِيعُ الْحِسَابِ﴾ في سورة البقرة {67}."
  3,20,"قوله تعالى: ﴿فَإِنْ حَاجُّوكَ فَقُلْ أَسْلَمْتُ وَجْهِيَ لِلَّهِ﴾ [آل عمران: 20]. قال ابنُ عباس {1}: نزلت في يهود المدينة، ونصارى نَجْرَان، والأمِّيِّين من العرب.قال الكلبي {2}: وذلك أن اليهود والنصارى قالت: لسنا على ما سميتنا به يا محمد، إنما اليهودية والنصرانية نَسَبٌ، والدِّين هو الإسلام، ونحن عليه.قال الزَّجَّاج {3}: فأمر الله تعالى نبيَّه بأن يحتجَّ عليهم؛ أنه اتَّبع أمرَ اللهِ، الذي هم مُجْمِعون {4} مُقرُّون بأنه خالقُهم، وأمَرَه بقوله: ﴿وَقُلْ لِلَّذِينَ أُوتُوا الْكِتَابَ وَالْأُمِّيِّينَ﴾ الآية بأن يدعوهم إلى ما هو عليه من الإسلام.قال أهل المعاني {5}: وإنما لزمتهم الحُجَّة من حيث إن النبي ﷺ أراهم الدلالة على صدقه ونبوَّته، ثم دعاهم إلى اتباع أمر من أقروا بأنه خالقهم، فإذا لم يطيعوه، صاروا محجوجين.فهذا وجه الحجة للنبي ﷺ في قوله: ﴿فَقُلْ أَسْلَمْتُ وَجْهِيَ لِلَّهِ﴾. ومعنى ﴿أَسْلَمْتُ وَجْهِيَ لِلَّهِ﴾: أي: انقدت له بقلبي ولساني وجوارحي.وذكرنا أن الإسلام معناه -في اللغة-: الانقياد {6}. وذُكِرَ (الوجه) هاهنا؛ لأنه أكرم جوارح الإنسان، فإذا خضع وجهُهُ لشيء، فقد خضع له سائرُ جوارحه {7}.وقال ابن عباس في هذه الآية {8}: يريد: كما قال أبوك إبراهيم: ﴿إِذْ قَالَ لَهُ رَبُّهُ أَسْلِمْ قَالَ أَسْلَمْتُ لِرَبِّ الْعَالَمِينَ﴾ [البقرة: 131]. وقد ذكرنا هناك معنى (أسلم) و (أسلمْتُ).وقال الفرَّاء {9}: معنى [أسلمت وجهي لله: أخلصت عملي لله؛ يقال {10}] {11}: (أسلمتُ الشيءَ لفلان)؛ أي: أخلصته لهُ، فسلم له الشيء، ولم يشاركه غيره {12}.قال: ومعنى (الوجه) ههنا: العمل، كقوله: ﴿يُرِيدُونَ وَجْهَهُ﴾ [الأنعام: 52 - الكهف: 28]، أي: قصده والعمل.وقول الشاعر:... إليه الوجهُ والعَمَلُ {13}نسق بالعمل على الوجه، وهما واحدٌ؛ لاختلاف اللفْظَيْن. ومضى الكلام في هذا عند قوله: ﴿بَلَى مَنْ أَسْلَمَ وَجْهَهُ لِلَّهِ﴾ [البقرة: 112]، الآية.وقوله تعالى: ﴿وَمنِ اَتَّبَعَنِ﴾. ﴿مَنِ﴾ عطف على الضمير في ﴿أَسْلَمْتُ﴾ من غير أن يؤكده؛ لأن الكلام طال بقوله: ﴿وَجْهِىَ للهِ﴾، فصار عِوَضًا من تأكيد الضمير المُتَّصِل.ولو قيل: (أسْلَمْتُ وزيدٌ)، لم يَحْسُن حتى يقول: (أسلمتُ أنا وزيدٌ).فإن قال: (أسلمتُ اليوم {14} بانشراح صدرٍ ومن جاء معي)، جاز وحَسُنَ {15}.[قال أبو إسحاق {16}: حذفت الياء من (اتبعن)، وهذه الياء إذا وقعت في آخر آية، حسن] {17} حذفها {18}؛ لأن أواخر الآي تُشَبَّهُ {19} بقوافي الشِّعْر، وأهل اللغة يسمونها الفواصل.قال الأعشى:ومن شانئٍ كاسِفٍ بالُهُ ... إذا ما انتسَبْتُ له أنكَرَنْ {20} فإذا لم يكن آخر آيةٍ أو قافيةٍ، فالأكثر إثبات الياء، وحذفها جيد، خاصة مع النونات؛ لأن أصل (اتبعني) {21}: (اتبعي) {22}، فزيدت النونُ؛ لِتَسْلَم فتحةُ العيْن. فالكسرة {23} من النون، تنوب عن الياء، فإذا لم تكن النون؛ نحو: (غلامي)، (وصاحبي)، فالأجود إثباتها، وحذفها قليل، إلا أنه جائز؛ لأن {24} الكسْرَة دالة عليه.قال ابن عباس {25}: ﴿وَمَنِ اتَّبَعَنِ﴾: يريد: المهاجرين والأنصار.وقوله تعالى: ﴿وَقُلْ لِلَّذِينَ أُوتُوا الْكِتَابَ وَالْأُمِّيِّينَ﴾. يعني: العرب {26} ﴿أَأَسْلَمْتُمْ﴾.قال الفرَّاء {27}، والزجَّاج {28}: معناه: الأمر؛ أي: أسلموا؛ لأنه استفهام في معنى التوقيف والتهديد، وفي ضمنه الأمر؛ كما تقول للإنسان، بعد أن تأمره وتُؤكِّد عليه: أقَبِلْتَ؟ فأنت تسأله متوعدًا، وفي مسألتك دليلٌ أنك تأمره أن يفعل، ومثله قوله {29}: ﴿فَهَلْ أَنْتُمْ مُنْتَهُونَ﴾ [المائدة: 91]؛ أي: انتهوا.قال النحويون: إنما جاء الأمر في سورة الاستفهام؛ لأنه بمنزلته في طلب الفعل، والاستدعاء إليه، فذكر ذلك؛ للدلالة على الأمر، من غير تصريح به؛ ليُقِرَّ المأمورُ بما يلزمه من الأمر.وقوله تعالى: ﴿عَلَيْكَ الْبَلَاغُ﴾. البلاغُ: اسمٌ {30} للمصدر، بمنزلة التبليغ؛ كـ (السَّراح) {31} و (الأداء)، أي: تبليغ الرسالة.وقوله تعالى: ﴿وَاللَّهُ بَصِيرٌ بِالْعِبَادِ﴾. قال ابن عباس {8}: ممن {33} آمن بك وصدَّقَكَ، ومن كفر بك وكذبك {34}. وفي هذه الآية تسلية للمصطفى ﷺ حين أُخبر أنه ليس عليه هداهم، إنما عليه التبليغ، فإذا بلَّغ فقد أدَّى ما عليه.وقال بعض المفسرين: حكم هذه الآية قبل أن يُؤمر النبي ﷺ بالسيف {35}."
  3,21,"قوله تعالى: ﴿إِنَّ الَّذِينَ يَكْفُرُونَ بِآيَاتِ اللَّهِ وَيَقْتُلُونَ النَّبِيِّينَ بِغَيْرِ حَقٍّ﴾ نزلت في اليهود {1}، ومعنى هذه الآية، قد ذكرنا في سورة البقرة، عند قوله: ﴿وَبَاءُوا بِغَضَبٍ مِنَ اللَّهِ ذَلِكَ بِأَنَّهُمْ كَانُوا يَكْفُرُونَ بِآيَاتِ اللَّهِ﴾ [البقرة: 61].وقوله تعالى: ﴿وَيَقْتُلُونَ الَّذِينَ يَأْمُرُونَ بِالْقِسْطِ مِنَ النَّاسِ﴾. روى أبو عبيدة بن الجرَّاح {2}: أن النبي ﷺ قال: قَتَلَت بنو إسرائيل ثلاثة وأربعين {3} نبيًا من أول النهار في ساعة واحدة، فقام مائة واثنا {4} عَشَرَ رجلًا، من عبَّاد بني إسرائيل، فأمروا مَنْ قَتَلَهم بالمعروف، ونَهَوْهم عن المنكر، فقُتِلُوا جميعًا من آخر النهار، في ذلك اليوم، فهم الذين ذكر الله عز وجل في كتابه، وأنزل الآية فيهم {5}.وقرأ حمزةُ {6}: (ويُقاتِلون الذين)، لأنه {7} اعتبر قراءةَ عبد الله {8}: (وقاتَلوا الذين يأمرون)، فقرأ {9}: ﴿يُقَاتِلُونَ﴾، وهو يريد: (قاتَلُوا)، كما روي في حرف عبد الله.ويجوز أن يكون المضارع، بمعنى الماضي؛ كقوله تعالى: ﴿إِنَّ الَّذِينَ كَفَرُوا وَيَصُدُّونَ عَنْ سَبِيلِ اللَّهِ﴾ [الحج: 25]، وقال في أخرى: ﴿إِنَّ الَّذِينَ كَفَرُوا وَصَدُّوا﴾ {10}، فالأول جاء على لفظ المضارع؛ حكاية للحال، كذلك {11} قراءة حمزة: (ويقاتلون)، يجوز {12} أن يكون مراده: (قد قاتَلوا)، إلا أنه جاء على لفظ المضارع، حكايةً للحال.والمعنى في قراءة حمزة: أنهم لا يوالون الذي يأمرون بالقسط؛ ليقلَّ نهيُهم {13} إيَّاهم عن العدوان عليهم، فيكونون متباينين لهم {14} مُشاقِّينَ؛ لأمرهم بالقسط، وإن لم يقتلوهم {15} كما قتلوا الأنبياء، ولكن يقاتلونهم {16} قتال المُبايِنِ، المُشاقِّ لهم. والصحيح الموافق لتفسير الآية: قراءةُ العامَّةِ {17}.وقوله تعالى: ﴿فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ﴾. ذكرنا معنى التبشير، وجواز إطلاقه فيما [لا] {18} يَسُر، عند قوله: ﴿وَبَشِّرِ الَّذِينَ آمَنُوا﴾ [البقرة: 25].وأما {19} دخول الفاء في قوله: ﴿فَبَشِّرْهُمْ﴾ وهو خبر الابتداء، فقد {20} ذكرنا ما فيه عند قوله: ﴿وَمَنْ تَطَوَّعَ خَيْرًا فَإِنَّ اللَّهَ شَاكِرٌ عَلِيمٌ﴾ [البقرة: 158]."
  3,22,"قوله تعالى: ﴿أُولَئِكَ الَّذِينَ حَبِطَتْ أَعْمَالُهُمْ فِي الدُّنْيَا وَالْآخِرَةِ﴾ هو يريد بـ ﴿أَعْمَالُهُمْ﴾: ما هم عليه من ادِّعائهم التمسك بالتوراة، وإقامة شريعة موسى. وأراد ببطلانها في الدنيا: أنها لم تحقن دماءَهم، وأموالهم {1}؛ وفي الآخرة: لم يستحقوا بها مثوبة، فصارت كأنها لم تكن ولم توجد."
  3,23,"قوله تعالى: ﴿أَلَمْ تَرَ إِلَى الَّذِينَ أُوتُوا نَصِيبًا مِنَ الْكِتَابِ﴾ الآية إنما قال: ﴿نَصِيبًا﴾؛ لأنهم كانوا يعلمون بعض ما في الكتاب {1}. والمراد بهؤلاء: اليهود.وقوله تعالى: ﴿يُدْعَوْنَ إِلَى كِتَابِ اللَّهِ﴾. قال ابن عباس في رواية الضحَّاك {2}: المرادبـ (كتاب الله) ههنا: القرآن، والله [تعالى] {3} جعل القرآن حَكَماً بينهم وبين رسول الله ﷺ {4}، فَحَكمَ القرآن عليهم بالضلالة، فأعرضوا عنه.فإن قيل: كيف دُعوا إلى حكم كتابٍ لا يؤمنون به؟قيل: إنَّما دُعوا إليه بعد {5} أن ثبت أنه {6} من عند الله، بموافقته التوراة في الأنباء والقصص، ورصانته {7}، بحيث لم يقدر بشرٌ أن يعارضَه، وهذا قول قتادة {8}، وقال في رواية سعيد بن جُبَير، وعكرمة: إنَّ النبي ﷺ قال لليهود: ""أنا على ملَّة {9} إبراهيم، وملَّته: الإسلام""، فقالوا: إن إبراهيم كان يهودياً، فقال لهم رسول الله ﷺ: ""فَهَلُمُّوا إلى التوراة"". فأبوا عليه. فأنزل الله هذه الآية {10}.وقال في رواية أبي صالح: أنكروا آية الرجْمِ من التوراة، وكان قدزنى منهم رجل {11} وامرأة، فكرهوا {12} رجمَهما {13} وسألوا النبي ﷺ ما يلزمهما {14}، فحكم بالرجْمِ. فقالوا: جُرْتَ {15} يا محمد! فقال: ""بيني وبينكم التوراة"". ثم أتوا بابن صُورِيا {16}، فقرأ التوراة، فلما أتى على آية الرجم سترها بكفِّهِ، فقام {17} ابنُ سَلام، فرفع كفه {18} عنها، ثم قرأ على رسول الله ﷺ وعلى اليهود الرجْمَ، فغضب اليهودُ لذلك {19} غضباً شديداً، وانصرفوا؛ فأنزل الله هذه الآية {20}.وقوله تعالى: ﴿ثُمَّ يَتَوَلَّى فَرِيقٌ مِنْهُمْ﴾. إن قيل: كيف خصَّ بالتولِّي فريقاً، ثم جمعهم في الإعراض، فقال: ﴿وَهُمْ مُعْرِضُونَ﴾؟.فالجواب، ما قال ابن الأنباري {21}، وهو: أنَّ الفريق المتولِّي، هم: المعرضون. وأراد بـ (الفريق المتولي): الرؤساء الذين تدين السَّفَلَةُ لهم، فأفردهم الله تعالى بالذكر، وخصَّهم بالتولي، لأنهم سببٌ لإضلال أتبَّاعهم.قال {22}: ويحتمل أن يكونَ المتولُّون: العلماء والرؤساء، والمعرضون: الباقون منهم؛ كأنه قيل {23}: ثم يتولى العلماءُ. والتُبَّاعُ معرضون عن القبول من النبي ﷺ لتولي علمائهم. ويجوز أن يكون الفريق اختصه الله {24}؛ لأن عبد الله بن سَلام، وغيره من مؤمني أهل الكتاب، كانوا ممن قبلوا حكم النبي ﷺ فكان {25} المتولِّي بعض مَن أوتي {26} الكتاب."
  3,24,"قوله تعالى: ﴿ذَلِكَ بِأَنَّهُمْ﴾. {1} اختلف أهل المعاني في المُشارِ إليه بـ ﴿ذَلِكَ﴾، فقال بعضهم {2}: ﴿ذَلِكَ﴾ راجعة إلى قوله: ﴿أُولَئِكَ الَّذِينَ حَبِطَتْ أَعْمَالُهُمْ﴾ [آل عمران: 22]؛ يعني: ذلك الحُبُوطُ؛ بكذبهم على الله؛ وهو قولهم: ﴿وَقَالُوا لَنْ تَمَسَّنَا النَّارُ إِلَّا أَيَّامًا مَعْدُودَات﴾.و {3} قال ابن الأنباري {4}: معنى قوله {5}: ﴿ذَلِكَ بِأَنَّهُم﴾ أي: ذلك الاجتراء عليك، وعلى الإعراض عن حكمك يا محمد بسبب اغترارهم، ومقالتهم؛ حيث قالوا: ﴿وَقَالُوا لَنْ تَمَسَّنَا النَّارُ إِلَّا أَيَّامًا مَعْدُودَات﴾، وظنوا {6} أنفسهم على قِلَّةِ العذاب وقِصَرِ مُدَّته {7}، فتجاسروا على تكذيب الرسل {8}.وهذا معنى قول الزجَّاج {9}: أخبر الله تعالى عن اليهود، أنهم يُعرضون عن حكم كتاب الله، ثم أنبأ وبيّن ما حملهم على ذلك، وخبَّر بما غرَّهم، فقال: ﴿ذَلِكَ بِأَنَّهُمْ قَالُوا﴾ {10}. قال: وموضع: ﴿ذَلِكَ﴾ رفعٌ. المعنى: شَأنُهُم ذلك، وأَمْرُهُم ذلك {11}. ومضى القول في تفسير قولهم: ﴿وَقَالُوا لَنْ تَمَسَّنَا النَّارُ إِلَّا أَيَّامًا﴾ في سورة البقرة.وقوله تعالى: ﴿وَغَرَّهُمْ فِي دِينِهِمْ﴾ الغُرور: الإطماع {12} فيما لا يصح {13}. وقوله تعالى: ﴿مَا كَانُوا يَفْتَرُونَ﴾. يعني قولهم: لن تَمَسَّنا النار."
  3,25,"قوله {1} تعالى: ﴿فَكَيْفَ إِذَا جَمَعْنَاهُمْ لِيَوْمٍ﴾. الآية. (كيف): معناه: السؤال عن الحال. والحال المسئولة عنها محذوفة؛ وتقديره: فكيف حالهم إذا جمعناهم؟ وتحذف الحال كثيراً مع كيف؛ لدلالته عليها؛ نحو قولك: (كنت أكْرِمُه وهو لم يزرني؛ فكيف إذا زارني؟)؛ أي: كيف حالُهُ إذا زارني في عِظَمِ الإكرام؟. ويُحذف أيضاً جوابُ هذا السؤال من الكلام؛ لأن في حذفه بلاغة تزيد على الإفصاح بذكره؛ لما فيه من تحريك النفس على استحضار كل نوع من أنواع الكرامة في قول القائل: فكيف إذا زارني؟ وكل نوع من أنواع العذاب في الآية.وتأويل الكلام: أي حالة تكون {2} حال من اغتر بالدعاوى الباطلة، إذا جُمعوا ليوم الجزاء {3}؟ وقوله ﴿لِيَوْمٍ﴾ {4}، ولم يقل: (في يوم)؛ لأن المراد: لجزاء يوم، أو لحساب يوم؛ فحذف المضاف، ودلت اللاَّمُ عليه. قاله الزجَّاج {5}.وقال الفرَّاء {6}: اللاَّمُ، لفعل مُضْمَرٍ؛ إذا قلت: (جُمعوا ليوم الخميس)؛ كان المعنى: جُمعوا لما يكون يوم الخميس. وإذا قلت: (جُمعوا في يوم الخميس)، لم تُضْمِرْ فِعْلاً {7}.وقوله تعالى: ﴿لِيَوْمٍ﴾. أي: لما يكون في ذلك اليوم من الحساب والجزاء. وهذا قريب من القول الأول، بل هو تفسير له {8}.وقوله تعالى: ﴿وَوُفِّيَتْ كُلُّ نَفْسٍ مَا كَسَبَتْ﴾. أي: جزاء ما كسبت {9} من خيرٍ أو شرٍّ. فهذا يكون على حذف المضاف، ويجوز أن يكون المعنى: ووُفِّيَت كل نفس ما كسب من الثواب والعقاب، بالطاعة والمعصية، فلا يكون في الكلام مضافٌ محذوف، ويجوز أن يُسمَّى الثوابُ والعقابُ كسباً للعبد؛ على معنى {10}: أنهما جزاء كسبه، وأنه اجتلبهما بأعماله {11} الصالحة والطالحة {12}.وقوله تعالى: ﴿وَهُمْ لَا يُظْلَمُونَ﴾. أي: لا يُنقص من حسناتهم، ولا يزاد على سيِّئاتهم."
  3,26,"وقوله تعالى: ﴿قُلِ اللَّهُمَّ﴾ اختلف النحويون في إعراب (اللهمَّ)؛ فقال الخليل {1}، وسيبويه {2}: (اللهمَّ)، بمعنى: يا الله. والميم {3} المشدَّدَة عِوَضٌ {4} من (يا)؛ لأنهم لم يقولوا: (يا) مع هذه الميم في هذه الكلمة. والضمة التي في الهاء {5}: ضمة الاسم المنادى المفرد {6}، والميم مفتوحة؛ لسكونها، وسكون الميم التي قبلها.وأنكر الفرَّاء هذا القول؛ فقال {7}: لم نجد العرب زادت مثل هذه الميم في نواقص الاسم إلَّا مخففة؛ مثل: (الفمُ)، و (هذا ابْنُمٌ)، و (سُتْهُمُ) {8}.فلو {9} كانت الميم بدلاً من (يا)، لم يُجمع بين الميم و (يا)، وقد أنشدني بعضهم:وما عليكِ أنْ تَقُولي كُلَّمَاصَلَّيتِ أو سَبَّحتِ: يا اللَّهمااردُدْ علينا شَيخَنا مُسَلَّما {10}فقال: (يا اللهُمَّ). ثم قال: ونرى أنها كانت في الأصل كلمةً ضُمَّ إليها (أُمَّ)؛ يريد: (يا الله؛ أُمَّنا بخير)، فكثرت في الكلام حتى اختلطت {11} به، فحذفت الهمزة استخفافاً، فقيل: (اللهمَّ) {12}، ثم كثرت هذه اللفظة حتى قالوا: (لاهُمَّ)؛ بمعنى: اللهمَّ.قال الشاعر:لاهُمَّ إنَّ عامِرَ بن جَهْمِ ... أوْذَمَ {13} حَجّاً في ثِيَابٍ {14} دُسْمِ {15}وقال آخر:لاهُمَّ إن جُرْهُماً {16} عِبادكا ... الناس طُرْفٌ {17} وهمُ تِلادُكا {18} فحذفوا الألف واللاَّم، لَمَّا كَثُرَ في كلامهم.قال {19}: وقد خُفِّفت ميمها في بعض اللغات. أنشدني بعضهم:كحَلْفَةٍ من ابن {20} رباح ... يَسْمَعها اللهُمُ {21} الكُبارُ {22} قال: والرفعة التي في الهاء من همزة (أُمَّ) لمَّا تركت، انتقلت إلى ما قبلها. قال: ونرى {23} أن قول العرب: (هَلُمَّ) مثلها؛ إنما كانت: (هل) فضُمَّ إليها (أُمَّ) {24}.وأنكر أبو إسحاق هذا القول إنكاراً شديداً، فقال {25}: لو كان الأمر على ما قال، لجاز أن يقال: (الله أُمَّ)، فيُتَكلم به على أصله، كما يقال: (ويلُ أمِّه)، ثم يُتَكلم به على الأصل، فيقال: (ويلُ أُمِّهِ) {26}، ولجاز أيضاً: (الله أُؤمُمْ) {27}.فلمَّا لم {28} يُسمع أحدٌ من العرب تكلم به على الأصل الذي [هو] {29} ذَكَر {30}، علم أنه ليس بأصل، وأيضاً لم يُسمع {31} أحدٌ {32} يقول: (يا اللهُمَّ)، والله عز وجل يقول: ﴿وَإِذْ قَالُوا اللَّهُمَّ﴾ [الأنفال: 32]، وقال: ﴿قُلِ اللَّهُمَّ فَاطِرَ السَّمَاوَاتِ﴾ [الزمر: 46].وما احتجَّ به الفرَّاء من قوله: (أنشدني بعضهم) {33}، فليس يعارض الإجماعَ، وما أتى به كتابُ الله عز وجل، ووُجد في ديوان العرب. يقول قائل: (أنشدني بعضهم)، وليس ذلك البعضُ بمعروفٍ ولا مُسمَّى.وقال غير أبي إسحاق مِمَّن نصر مذهبَ الخليل {34}: لو كان الأمر على ما ذكره الفرَّاء، لما صحَّ أن يقال: (اللهُمَّ افعل كذا)، إلَّا بحرف العطف؛ لأن قوله: (اللهُمَّ) حصل عنده في ضمنه الدعاء؛ لأن تأويله: (الله {35}؛ أُمَّنا بخير)، فالدعاء الثاني يجب أن يكون معطوفاً عليه بحرف العطف. ولم نجد أحداً يقول: (اللهُمَّ اغفر).وأجابَ الفرَّاءَ عن قوله: (هذه الميم، إنما تُزاد مُخفَّفةً)؛ بأن قال: إنما شُدِّدت الميمُ في (اللهمَّ)؛ لأنها عِوضٌ من حرفين {36} فشُدِّدت، كما قيل: (قُمتُنَّ) و (ضَربتُنَّ)؛ لمَّا كانت النون عِوضاً من حرفين في: (قُمتُموا) و (ضَربتُموا)، شُدِّدَت. فأما (قُمْنَ) و (ذَهبْنَ) فَعِوَضٌ من حرف واحد.وما ذَكَر من قوله: (فَمُ) {37} و (سُتْهُمُ) و (ابْنُمُ) {38}، فإنما خُفِّفت الميم؛ لأنها عِوَضٌ من حرف واحد.وليس حكمُ قولِكَ: (الله)، حكمَ (الفمُ) و (الابنُ)؛ لأنهما ناقصان أُتمَّا بالميم، و (اللهُمَّ) ليس زيادتها {39} تتميما للاسم، إنما هي لمعنىً آخر غير المعنى الذي في (الفمُ).وأمّا ما احتَجَّ به من البيت؛ فجاز إدخال (يا) مع الميم لضرورة الشعر {40}.فأما {41} احتجاجه بقوله: (هلُمَّ)، فعند الخليل {42}: أنَّ الأصل فيه: (ها) التي [هي] {43} للتنبيه، دخلت {44} على (لمَّ) {45}، فلما كثر {46}، حُذِفت الألف {47}.وأمَّا البيت الذي ذكر أنه جاء في (اللهُمُ)، بتخفيف الميم، فهو خطأ فاحشٌّ خصوصا عنده {48}؛ لأن الميم في (اللهُمُ)، هو الميم الذي في (أُمَّنا)، وإنشاده بالتخفيف يفسد عليه مذهبه؛ لأنه لا يحتمل في البيت ذكر أن يكون (أُمَّنا)، إنما هو بمنزلة قولك: (يسمعهُ اللهُ الكبارُ)، فالرواية الصحيحة: يَسمعها لاهُهُ الكبارُ قال أبو إسحاق {49}: وقوله: إنَّ الضمَّةَ [التي] {50} في الهاء من قوله: (اللهُم)، ضمةُ الهمزِة التي كانت في (أُمَّ) محالٌ؛ لأنه لا يُترك الضمُ الذي هو دليل على النداء المفرَد {51}، ويُجعل في اسم الله ضمةُ (أُمَّ) {52}.وقوله تعالى: ﴿مَالِكَ الْمُلْكِ﴾. في نصبه، وجهان: أحدهما: وهو قول سيبويه {53}: أنه منصوب على النداء، وكذلك قوله: ﴿قُلِ اللَّهُمَّ فَاطِرَ السَّمَاوَاتِ﴾ [الزمر: 46]، ولا يجوز عنده أن يكون ﴿مَالِكَ الْمُلْكِ﴾ نصباً على النعت للنداء المفرد، الذي هو قوله: ﴿اللَّهُمَّ﴾؛ لأن هذا الاسم عنده لا يُوصَف.الوجه الثاني: وهو قول أبي العباس {54}: أنَّ (مالِكَ) وصف للمنادى المفرد. وهذا الوجه اختيار الزجَّاج؛ قال {55}: لأن هذا الاسم ومعه {56} الميم، بمنزلته ومعه (يا) {57}، فلا تمتنع الصفة مع الميم، كما لا تمتنع مع {58} (يا) {59}.ونَصَر أبو علي الفارسي قولَ سيبويه، وقال {60}: هو عندي أصح، وإن كان أغمض، وذلك {61}، لأنه ليس في الأسماء الموصوفة شيء {62} على حد (اللهُمَّ)، فإذا خالف ما عليه الأسماء الموصوفة، ودخل في حيّز ما لا يوصف من الأصوات، وجب أن لا يوصف.والأسماء المناداة المفردة المعرَّفة، القياس فيها: أن لا توصف، كما ذهب إليه بعض الناس؛ لأنها واقعة موقع ما لا يوصف؛ وكما {63} أنه لمَّا وقع موقع ما لا يُعرب لم يعرب، كذلك لمَّا وقع موقع ما لا يوصف، وجب أن لا يوصَف {64}.فأما قوله: يا حَكَمُ الوارثُ عن عبد الملكْ {65}.يا حَكَمُ بن {66} المنذرِ بنَ {67} الجارودْ {68}و:....... يا عُمَرُ الجَوادَ {69}فإن الأول، على: (أنت)، والثاني، على: نداء ثانٍ، والثالث، على: (أعني)، فلمَّا كان هذا الاسم، الأصل فيه: أن لا يُوصَف لِما ذكرنا، كان (اللهم) أولى أن لا يوصف؛ لأنه قبل ضم الميم إليه، واقعٌ موقع ما لا يوصف، فلمَّا ضُمَّت الميمُ إليه، وصيغ معه صياغة مخصوصة، صار حكمُهُ حكمَ الأصوات، وحكم الأصوات: أن لا يوصف {70}؛ نحو: (غاقِ) {71}.قال {72}: وهذا المضموم إليه مع ما ضُمَّ إليه، بمنزلة صوتٍ مضموم إلى صوت؛ نحو: (حَيَّهَل) {73}، فحقُّهُ أن لا يوصفَ؛ كما لا يوصف (حَيَّ هلْ).فأما التفسير: فقال ابن عباس {74}: لما فتح رسول الله ﷺ مكة، ووعد أمَّتَه مُلكَ فارسَ والرومَ، قالت المنافقون واليهودُ: هيهات، هيهات {75}! فأنزل اللهُ هذه الآية.وقيل: إنَّ الله عز وجل أمر النبي ﷺ في هذه الآية، أن يسأله نقل عزِّ فارس إلى العرب، وذلِّ العرب إلى فارس {76}.وقوله تعالى: ﴿تُؤْتِي الْمُلْكَ مَنْ تَشَاءُ وَتَنْزِعُ الْمُلْكَ مِمَّنْ تَشَاءُ﴾. قال ابن عباس {77}: تؤتي ملكَ قيصر أمةَ محمدٍ ﷺ، وتنزع الملكَ منه.الكلبي {78}: ﴿تُؤْتِي الْمُلْكَ مَنْ تَشَاءُ﴾: محمداً وأصحابَه، ﴿وَتَنْزِعُ الْمُلْكَ مِمَّنْ تَشَاءُ﴾: أبي جهل {79}، وصناديدَ قريش.وقال بعضهم: ﴿تُؤْتِي الْمُلْكَ مَنْ تَشَاءُ﴾: العرب، ﴿وَتَنْزِعُ الْمُلْكَ مِمَّنْ تَشَاءُ﴾: الروم، والعجمِ، وسائرَ الأمم {80}.وذكر أبو إسحاق {81} في ﴿الْمُلْكَ﴾ المذكور ههنا، قولين:أحدهما: أن المراد بـ ﴿الْمُلْكَ﴾ ههنا: المال، والعبيد، والحَفَدَة {82}. والله تعالى يؤتيها من يشاء، وينزعها ممن يشاء.الثاني: أن ﴿الْمُلْكَ﴾ ههنا: ظهور الدين، والغَلَبة. فمعنى ﴿تُؤْتِي الْمُلْكَ مَنْ تَشَاءُ﴾ أي ترزق الغَلَبةَ والظَّفَرَ الذين يطيعونك، ويعبدونك. والله تعالى قد جعل كل ما {83} في مملكة {84} مَلِكٍ غير مسلم للمسلمين مُلكاً وغنيمة، ولهم أن يُطالِبُوا به حتى يَحُوزوه، كما يُطالِبُ المَسْلوبُ ثَوْبَهُ {85} بِثَوْبِه، والمأخوذ مالُهُ بما غلب عليه منه {86}.وقال أهل المعاني {87}: معنى قوله ﴿تُؤْتِي الْمُلْكَ مَنْ تَشَاءُ﴾؛ أي مَنْ تشاءُ أن تُؤْتِيَه، وكذلك {88} ﴿وَتَنْزِعُ الْمُلْكَ مِمَّنْ تَشَاءُ﴾ أي: ممن تشاء أن تنزعه، إلاَّ أنه حذف؛ لأن في الكلام ما يدل عليه.قال الفرَّاء {89}: ومثله: قولك: (خذْ ما شئت)؛ أي: ما شئت أن تأخذه. وكذلك {90} قولك: (إن شئت؛ فَقُمْ، وإن {91} شئت؛ فلا تَقُمْ) {92}، وكذلك قوله: ﴿فَمَنْ شَاءَ فَلْيُؤْمِنْ وَمَنْ شَاءَ فَلْيَكْفُرْ﴾ [الكهف: 29] [فهذا بيَّن أنَّ] {93} المشيئة واقعة على الإيمان والكفر، وهما متروكان {94}.وقوله تعالى: ﴿وَتُعِزُّ مَنْ تَشَاءُ﴾ قال ابن عباس {95}: يريد: المهاجرين والأنصار، ﴿وَتُذِلُّ مَنْ تَشَاءُ﴾، يريد: الروم وفارس: وقيل {96}: ﴿وَتُعِزُّ مَنْ تَشَاءُ﴾ {97}: محمداً {98} وأصحابه، حتى دخلوا مكة ظاهرين عليها، ﴿وَتُذِلُّ مَنْ تَشَاءُ﴾: أبا جهل وأصحابه، حتى حُزَّت {99} رؤوسهم وأُلقوا في القليب. ويدخل تحت هذا كلُّ ما به يُعِزُّ اللهُ ويذل، من الإيمان والكفر، والتوفيق والخذلان وأشباهها {100}.وقوله تعالى: ﴿بِيَدِكَ الْخَيْرُ﴾ أي: الخير والشر، فاكتفى بالخير؛ لأن الرغبة إليه فعل الخير بالعبد دون الشر {101}، وهذا كقوله: ﴿سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾ [النمل: 81] أي: [تقيكم] {102} الحَرَّ والبرد.وقال ابن عباس في تفسير ﴿الْخَيْرُ﴾ ههنا {103}: إنه عِزُّ الدنيا والآخرة."
  3,27,"قوله تعالى: ﴿تُولِجُ اللَّيْلَ فِي النَّهَارِ﴾ الإيلاج في اللغة {1}: الإدخال. والوُلُوجُ: الدخول. يقال: (وَلَجَ)، (وُلُوجاً)، و (لِجَةً) [و] {2} (وَلْجاً)، و (اتَّلَجَ، اتِّلاجاً)، و (توَلَّجَ، تولُّجاً) {3}.قال الشاعر:فإنَّ القوافي يَتَّلِجنَ موالِجاً ... تَضايَقُ عنه أن تَولَّجَهُ {4} الإبَرْ {5}وفي التنزيل: ﴿حَتَّى يَلِجَ الْجَمَلُ﴾ [الأعراف: 40]، والوُليجَةُ: الدَّخيلَةُ، والبطانة {6}، ومنه قوله تعالى: {وَلَم يَتخِذُوا من دوُنِ اللَّهِ وَلَا رَسُولِهِ وَلَا ﴿الْمُؤْمِنِينَ وَلِيجَةً وَاللَّهُ خَبِيرٌ بِمَا تَعْمَلُونَ﴾ [التوبة: 16].ومعنى الآية: تجعل ما نقص من أحدهما، زيادة في الآخر، في قول جميع المفسرين {7}.وذكر ابن الأنباري {8} قولاً آخر، وهو: أن المعنى: تدخل أحدهما في الآخرة بإتيانه به {9} بدلاً {10} منه. قال: وذلك أن الليل إذا {11} دخلت ظلمتُهُ، وظهرت نجومُهُ وقمرُه، كان النهار داخلاً فيه، ومستتراً تحته، وكذلك {12} والنهار، إذا دخل ضوؤه، وطلعت شمسُه، كان الليل داخلاً فيه، ومستترا تحته {13}.وقوله تعالى: ﴿وَتُخْرِجُ الْحَيَّ مِنَ الْمَيِّتِ وَتُخْرِجُ الْمَيِّتَ مِنَ الْحَيِّ﴾. أكثر المفسرين على أنَّ معناه: تخرج الحيوان من النطفة، وتخرج النطفة من الحيوان {14}.وقال الكلبي {15}: تخرج الفرخ من البيضة، وتخرج البيضة من الطير، وهذا كالأول؛ لأن البيضة للطير بمنزلة النطفة لسائر الحيوانات {16}.وقال ابن عباس في رواية عطاء، والحسن {17}: تخرج المؤمن مِنَ الكافر، والكافر من المؤمن. والمؤمنُ حَيُّ الفؤاد، والكافرُ ميِّت الفؤاد. دليله: قوله: ﴿أَوَمَنْ كَانَ مَيْتًا فَأَحْيَيْنَاهُ﴾ {18} [الأنعام: 122].وفي (الميِّت) قراءتان: التشديدُ، والتخفيفُ {19}. والتشديد الأصل؛ لأنه في الأصل: (مَيْوِت)، فلما اجتمعت الواو والياء {20}، وسبقت {21} إحداهما بالسكون، قُلِبت الواوُ ياءً {22}، وأُدغمت الياءُ فيه {23}. ومن خَفَّفَ: حَذَفَ الواوَ التي {24} أُعِلَّت في التشديد بالقلب {25}، فأعِلَّت {26} الواوُ في التخفيف بالحذف، كما أعلَّت في التشديد بالقلب.وقول من قال: إن (المَيْت) بالتخفيف: الذي قد مات، وبالتشديد: الذي لم يمت بعدُ {27}، ليس {28} بشيء؛ لأنه قد ورد في الشعر على عكس قوله.أنشد أبو العباس {29} لابن {30} الرَّعْلاء الغسَّاني {31}.ليس من مات فاستراح بمَيْتٍ ... إنَّما المَيْتُ ميِّتُ الأحْياءِ إنَّما المَيْتُ من يعيشُ كثيبا ... كاسفاً بالُهُ {32} قليلَ الرَّخاء {33}فهذا بيَّن أنَّ الأمر فيهما سواء.وقوله تعالى: ﴿وَتَرْزُقُ مَنْ تَشَاءُ بِغَيْرِ حِسَابٍ﴾. قال الزجَّاج {34}: أي: بغير تقتير. وهذا مستعمل في اللغة، يقال: (فلان ينفق بغير حساب)؛ أي: بُوسِّع في النفقة؛ فكأنه لا يحسب ما ينفقه.وقال الحسن {35}، والربيع {36}: أي: بغير {37} نقصان، وذلك؛ لأنه غير متناهي المقدور، فما يؤخذ منه {38} لا ينقصه، ولا هو على حساب جزءٍ من كذا وكذا {39} جزءا {40}، فهو بغير حساب التجزئة.وقيل معناه {41}: بغير حساب الاستحقاق؛ لأنه يرزق ويعطي تفضلاً لا استحقاقاً."
  3,28,"قوله تعالى: ﴿لَا يَتَّخِذِ الْمُؤْمِنُونَ الْكَافِرِينَ أَوْلِيَاءَ﴾ قال ابن عباس {1}: نزلت الآية في قوم من المؤمنين، كانوا {2} يباطنون اليهود ويوالونهم {3}.وقال المُقاتِلان {4}: نزلت في حاطب بن أبي بَلْتَعَة {5}، وغيره ممن كانوا يوالون كفار مكة.قال الفرَّاء {6}: ﴿لَا يَتَّخِذِ الْمُؤْمِنُونَ﴾: نهيٌ؛ فجُزم على ذلك. ولو رُفِع على الخبر كقراءة من قرأ: ﴿لَا تُضَارَّ وَالِدَةٌ بِوَلَدِهَا﴾ {7} [البقرة: 233] جازَ.قال الزجَّاج {8}: ويكون المعنى على الرفع: أنه من كان مؤمنًا، فلا بنبغي أنْ يتَّخذَ الكافرَ وَلِيًّا؛ لأن وَلِيَّ الكافرِ راضٍ بِكُفْرِهِ، فهو كافر، وقد ذكرنا معنى (الوليَّ) و (المولى) فيما تقدم.ومعنى (الأولياء) ههنا: الأنصار، والأعوان، أو {9} الذين يوالونهم ويلاطفونهم بالمحبَّةِ والقُرْبَةِ.وقوله تعالى: ﴿مِنْ دُونِ الْمُؤْمِنِينَ﴾. (مِنْ) ههنا معناه: ابتداء الغاية، على تقدير {10}: لا تجعلوا ابتداء الولاية مكاناً دون المؤمنين {11}. وهذا {12} كلام جرى على المثل في المكان، وهو كما تقول: (زيدٌ دونك)؛ لست تريد: أنَّه في موضعٍ مُسْتَفِلٍ {13}، وأنك في موضع مرتفع، ولكن جعلت الشَّرف بمنزلة الارتفاع في المكان، وجعلت الخِسَّةَ كالاستفال {14} في المكان.والمعنى {15}: أنَّ المكان المرتفع في باب الولاية: مكانُ المؤمنين، ومكان الكافرين الأدنى. فهذا معنى ﴿مِنْ دُونِ الْمُؤْمِنِينَ﴾، وتحقيق له.والتأويل: أولياء من غير المؤمنين وسواهم؛ كقوله تعالى ﴿وَادْعُوا شُهَدَاءَكُمْ مِنْ دُونِ اللَّهِ إِنْ كُنْتُمْ صَادِقِينَ﴾ [البقرة: 23] أي: غير الله. وقد مرَّ.وقد ثبت بهذه الآية تحريمُ موالاة الكافرين: والله تعالى قد قطع بيننا وبينهم أصلَ الموالاة.قال ابن عباس في هذه الآية {16}: نهى الله سبحانه المؤمنين أن يلاطفوا الكفارَ في آيات كثيرة، منها قوله: ﴿لَا تَتَّخِذُوا بِطَانَةً مِنْ دُونِكُمْ﴾ [آل عمران: 118] وقوله: ﴿لَا تَجِدُ قَوْمًا يُؤْمِنُونَ بِاللَّهِ وَالْيَوْمِ الْآخِرِ يُوَادُّونَ مَنْ حَادَّ اللَّهَ وَرَسُولَهُ﴾ [المجادلة: 22]، وقوله: ﴿لَا تَتَّخِذُوا الْيَهُودَ وَالنَّصَارَى أَوْلِيَاءَ﴾ {17} [المائدة: 51].وقوله تعالى: ﴿وَمَنْ يَفْعَلْ ذَلِكَ﴾ أي: اتِّخاذ الأولياء منهم {18}.﴿فَلَيْسَ مِنَ اللَّهِ فِي شَيْءٍ﴾. أي: من دين الله، فحذف الدينَ اكتفاءً بالمضاف إليه، والمعنى: أنه قد برئ من الله، وفارق دينه، ثمَّ استثنى، فقال: ﴿إِلَّا أَنْ تَتَّقُوا مِنْهُمْ تُقَاةً﴾. ذكرنا معنى الاتقاء وحقيقته في قوله: ﴿هُدًى لِلْمُتَّقِينَ﴾ [البقرة: 2]. و (التُّقاة) ههنا مصدر، ووزنها: فُعَلَة، مثل: (تُخَمَة)، و (تُؤَدَة)، و (تُكَأَة)، و (تُهمَة). والتَّاء في كل هذا مبدلة من الواو {19}، ويقال {20}: (تَقَيْتُهُ تُقاةً، وتُقىً، وتَقِيَّةً، وتَقْوى). وإذا قلت {21}: (اتَّقَيت)، كان مصدره (الإتقاء) {22}.وإنما قال: (تتَّقوا)؛ من: الاتِّقاء، ثم قال: (تُقاةً)، ولم يقل: اتِّقاءً: لأن العرب قد تَذْكُر المصدرَ من غير لفظ الفعل، إذا كان ما ذُكِر من المصدر يوافق {23} مصدر الفعل المذكور، فيقول: (التقيت فلاناً لقاءً حسناً)، قال القُطامي {24}: وليس بأنْ تتَّبعه اتِّباعا {25}وقال أيضًا:ولاح بجانب {26} الجبلين منه ... ركامٌ يَحْفِر التُّربَ {27} احتفارا {28}وقال بعض النحويين {29}: (تقاة) اسم وضع موضع المصدر {30} كما يقال: (جَلَسَ جَلْسَةً)، و (رَكِبَ رِكْبَةً) {31}، وكما قال: وبَعْدَ عطائِكَ المائةَ الرِّتاعا {32}فأجراه مجْرَى الإعطاء {33}.قال: ويجوز أن تجعل (تُقاة) ههنا مثل: (رُماة)، فتكون حالاً مؤكدة {34}.قال المفسرون {35}: هذا في المؤمن، إذا كان في قوم كفَّار، ليس فيهم غيره، وخافهم على نفسه وماله، فله أن يخالفهم {36}، ويُداريهم باللسان، وقلبه مطمئنٌ بالإيمان دفعا عن نفسه {37}، من غير أن يَستحِلَّ مُحرَّماً؛ من: دمٍ، أو مالٍ، أو إطْلاع للكافرين على عَوْرة {38} المسلمين.قال ابن عباس في هذه الآية {39}: يريد: مُدَاراةً ظاهرةً. والتقيَّة لا تحل إلاَّ مع خوف القتل. وهي رخصة من الله تعالى. ولو أفصح بالإيمان؛ حيث يجوز له التَقِيَّة، [فيُقْتَل لأجلِ إيمانِهِ] {40}، كان ذلك فضيلةً له {41}.وظاهر الآية يدل على أن التقيَّة إنما تَحلُّ مع الكفار الغالبين، غير أن مذهب الشافعي رحمه الله: [أنَّ الحالةَ بين] {42} المسلمين {43}، إذا شاكلت {44} الحالةَ بين المسلمين والمشركين، حَلَّت التقِيَّةُ، محاماةً عن المُهْجَةِ {45}.[وأمال] {46} الكسائي، وحمزة ﴿تُقَاةً﴾ ههنا {47}. والقافُ حرفٌ مُسْتَعْلٍ {48}، فالأحسن ترْكُ الإمالة مع القاف، كما لم يُميلوا (قادم). و (قاة) من (تقاة)، بمنزلة: (قادم).وحُجَّة {49} من أمالَ: أنَّ سيبويه ذكر {50}: أنَّ قوماً قد أمالوا مع المستعلي، ما لا ينبغي أن يُمال في القياس؛ وذلك قولهم: (رأيت غَرْقى) {51}. قال: وهو قليل. وأيضاً فإنهم قد أمالوا: (سَقى)، (وصَغى) {52}؛ طلباً للياء التي الألِفُ في موضعها، فلمَّا أُميلت هذه الألِفُ مع المستعلي، كذلك أميلت {53} التي في (تقاة).وقوله تعالى: ﴿وَيُحَذِّرُكُمُ اللَّهُ نَفْسَهُ﴾. أي: يخوفكم الله على موالاة الكفار عذابَ نَفْسِهِ، وعقوبَتَه، فحذف المضاف، وهو قول ابن عباس {54} و (النفس) عند العرب، عبارة عن: ذات الشيء ووجوده. يقولون: هذا نفس كلامك {55}. وإلى هذا ذهب أهل المعاني.قال الزجَّاج {56}: معنى ﴿نَفْسَهُ﴾: إيَّاه، كأنه قال: ويحذركم الله إيَّاه. وقال بعضهم {57}: النفس ههنا: تعود إلى اتِّخاذ الأولياء من الكفار؛ [أي] {58}: ينهاكم الله عن نفس هذا الفعل {59}."
  3,29,"قوله تعالى: ﴿قُلْ إِنْ تُخْفُوا مَا فِي صُدُورِكُمْ﴾. أي: مِن مودة الكفار، وموالاتهم. هذا قول أكثر المفسرين {1}.وقال الكلبي {2}: يعني: تكذيب محمد ﷺ، يقول: إن أخفيتموه أو أظهرتم تكذيبه، بحربه وقتاله، يعلمه الله.وقال عطاء {3}: يريد: الضمير، وهذا يعم كل ما في قلب الإنسان.قال أهل المعاني: لَمّا نَهَى اللهُ في الآية الأولى عن موالاة الكفار، خوَّفَ وحذَّر في هذه الآية {4} عن إبطان {5} موالاتهم؛ بأنه يعلم الإسرار، كما يعلم الإعلان.[فإن قيل: لِمَ جاء] {6} ﴿يَعْلَمْهُ اللَّهُ﴾ بالجَزْم؛ على جواب {7} الشرط، ولا يَفْتَقِرُ في علمه إلى وجود {8} شرطٍ متقدمٍ؛ كقول القائل: (إنْ تأتِني؛ أُكْرِمْكَ!)، فالإتيان سببٌ للإكرام، ولا يجوز أنْ يكون الإخفاء ولا الإبداء سبباً لعلمه. فالقول في ذلك إنَّ المعنى: يعلمه كائنًا، [ولا يعلمُهُ اللهُ تعالى {9} كائناً، إلا بعد كَوْنِهِ، وقبل {10} الكَوْنِ لا يُوصَفُ بأنه {11}: يعلَمُه كائنا] {12}، والتأويل: إنْ تبدوا ما في صدوركم، يعْلَمْهُ مبدىً، أو تُخْفوه يَعْلَمْهُ مُخْفىً.وقوله تعالى: ﴿وَيَعْلَمُ مَا فِي السَّمَاوَاتِ﴾. رفع {13}؛ على الاستئناف؛ كقوله: ﴿قَاتِلُوهُمْ يُعَذِّبْهُمُ اللَّهُ﴾ [التوبة: 14]، جزم الأفاعيل {14}، ثم قال: ﴿وَيَتُوُبُ اَللَّهُ﴾ [التوبة: 15]، فرفع. ومثله، قوله: ﴿فَإِنْ يَشَإِ اللَّهُ يَخْتِمْ عَلَى قَلْبِكَ وَيَمْحُ اللَّهُ الْبَاطِلَ﴾ [الشورى: 24]، ورفعاً {15}.وفي قوله: ﴿يَعْلَمُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ﴾، إتمامٌ؛ للتحذير؛ لأنه إذا كان لا يخفى عليه شيءٌ منهما، فكيف يخفى عليه الضميرُ؟.وقوله تعالى: ﴿وَاللَّهُ عَلَى كُلِّ شَيْءٍ قَدِيرٌ﴾. تحذيرٌ مِنْ عِقَابِ مَن لا يعْجِزَهُ شىءٌ."
  3,30,"قوله تعالى: ﴿يَوْمَ تَجِدُ كُلُّ نَفْسٍ﴾ اختلفوا في العامل في ﴿يَوْمَ﴾، فقال ابن الأنباري {1}: اليوم معلق بـ ﴿الْمَصِيرُ﴾ {2}، والتقدير: (وإلى اللهِ المصير، يومَ تَجِدُ).وقال الزجَّاج {3}: العامل: قوله: ﴿وَيُحَذِّرُكُمُ اللَّهُ نَفْسَهُ﴾، في الآية {4} السابقة؛ كأنه قال: ويحذِّرُكُم اللهُ نفسَهُ في ذلك اليوم {5}.قال أبو بكر: ولا يجوز أن يكون (اليوم) منصوباً بـ ﴿وَيُحَذِّرُكُمُ﴾، المذكور في هذه الآية، لأن واو النَّسَقِ {6} لا يعمل ما بعدها فيما قبلها.قال: ويجوز أن يكون (اليوم) متَصلًا بـ ﴿قَدِيرٌ﴾ {7} منصوباً به، والتأويل: (والله على كلِّ شيءٍ قديرٌ في هذا اليوم).وخصَّ هذا [اليوم] {8}، وإنْ كان غيرُه من الأيام بمنزلته في قدرة الله تعالى؛ تفضيلاً له؛ لِعِظَمِ شأنِه؛ كقوله: ﴿مَالِكِ يَوْمِ الدِّينِ﴾ {9}.وقوله تعالى: ﴿مَا عَمِلَتْ مِنْ خَيْرٍ مُحْضَرًا﴾. يريد: بيان ما عملت؛ بما يرى من صحائف الحسنات. ويجوز أن يكون المعنى: جزاء ما عملت؛ بما يرى من الثواب.وقوله تعالى: ﴿وَمَا عَمِلَتْ مِنْ سُوءٍ﴾. الأظهر: أن تجعل ﴿مَا﴾ ههنا بمنزلة (الذي)، فيكون معطوفاً على ﴿مَا﴾ الأولى، ويكون ﴿عَمِلَتْ﴾ صلةً لها. ويصلح أن تكون بمعنى: الجزاء فتكون مُسْتَأنَفَةً. وكان الأجود؛ إذا جعلت ﴿مَا﴾ بمعنى الجزاء، أن تنصب ﴿تَوَدُّ﴾، أو تخفضه، ولَمْ يقرأ أحدٌ إلا رفعاً، فكان هذا دليلاً [على] {10} أنَّ ﴿مَا﴾ بمعنى (الذي) {11}.وقوله تعالى: ﴿أَمَدًا بَعِيدًا﴾. معنى (الأمد): الغاية التي يُنتَهى إليها {12}.قال مقاتل {13}: أي: كما بين المشرق والمغرب.وقال الحسن {14}: يَسُر أحدَهم أن لا يلقى عملَهُ أبدا.وقوله تعالى: ﴿وَيُحَذِّرُكُمُ اللَّهُ نَفْسَهُ﴾. قد ذكرنا ما فيه {15}.وقوله تعالى: ﴿وَاللَّهُ رَءُوفٌ بِالْعِبَادِ﴾. قال الحسن {16}: مِن رأفته بهم أن حذَّرهم نفسه."
  3,31,"قوله تعالى: ﴿قُلْ إِنْ كُنْتُمْ تُحِبُّونَ اللَّهَ﴾ قال ابن عباس في رواية الضحاك {1}: وقف النبي ﷺ على قريش وهم في المسجد الحرام يسجدون للأصنام، فقال: ""يا معشرَ قريش: والله لقد خالفتم ملَّة أبيكم إبراهيم! "". فقالت قريش: إنما نعبد هَّذه حبًا لله؛ ليقربونا إلى الله. فقال الله: قل يا محمد: إن كنتم تُحبُّون الله وتعبدون الأصنامَ لِتُقَرِّبكم إلى الله فاتَّبعوني، يُحْبِبْكم اللهُ، فأنا رسوله إليكم، وحجَّتُه عليكم، وأنا أولى بالتعظيم من أصنامكم {2}.وقال في رواية أبي صالح {3}: إنَّ اليهود لمَّا قالت: نحن أبناءُ اللهِ وأحبَّاؤه، أنزل الله تعالى هذه الآية، فعرضها عليهم رسول الله ﷺ فأَبَوا أن يقبلوها {4}.قال أهل العلم: معنى (مَحبَّة العبدِ لله): إرادته طاعته، وإيثاره أمره، ورضاه بشرائعه. ومعنى (مَحبَّة الله للعبد): إرادته لِثَوَابِهِ، وعفوه عنه، وانعامه عليه {5}."
  3,32,"قوله تعالى ﴿قُلْ أَطِيعُوا اللَّهَ وَالرَّسُولَ﴾ قيل: لمّا نزل {1} قوله: ﴿قُلْ إِنْ كُنْتُمْ تُحِبُّونَ اللَّهَ﴾، الآية، قال عبد الله بن أُبَي {2}: إنَّ محمداً يجعل طاعتَه كطاعة الله، ويأمرنا أن نحبه كما أحبَّت النصارى عيسى، فنزلت هذه الآية {3} وبين فيها أنَّ طاعة الله معلقةٌ بطاعة الرسول، ولا يتمُّ لأحد طاعةُ الله، مع عصيان الرسول؛ ولهذا قال الشافعي - رضي الله عنه -: كل أمرٍ أو نهيِ، ثبت عن رسول الله ﷺ، جرى ذلك في الفريضة واللزوم، مجرى ما أمر الله به في كتابه، ونهى عنه {4}.قال عطاء، عن ابن عباس، في قوله: ﴿قُلْ أَطِيعُوا اللَّهَ وَالرَّسُولَ﴾، يريد: محمداً ﷺ فإن طاعتكم [لمحمدٍ طاعةٌ {5}] {6} لي، فأما أن تطيعوني وتعصوا محمداً، فلن أقبل طاعتكم {7}.وقوله تعالى: ﴿فَإِنْ تَوَلَّوْا فَإِنَّ اللَّهَ لَا يُحِبُّ الْكَافِرِينَ﴾. قال الزجَّاج {8}: أي {9}: فإنَّ الله لا يحبهم {10}؛ لأن من تَوَلَّى عن النبي ﷺ، فقد تَوَلَّى عن الله عز وجل. ومعنى ﴿لَا يُحِبُّ الْكَافِرِينَ﴾: لا يغفر لهم، ولا يُثْنِي عليهم خيراً {11}."
  3,33,"قوله تعالى: ﴿إِنَّ اللَّهَ اصْطَفَى آدَمَ وَنُوحًا﴾ معنى (اصطفى) في اللغة: اختار. وتأويله: جعلهم صفوة خَلْقِه {1}.قال أهل المعاني {2}: هذا تمثيل المعلومِ بالمرئيِّ، والعرب تفعل ذلك، فإذا سمع السامع ذلك المعلوم، كان عنده بمنزلة ما يشاهده عَياناً؛ وذلك أن الصافي هو: النَّقيُّ من شائب الكَدَر فيما يُشاهَد. فمُثِّلَ به خُلُوص هؤلاء القوم من الدنس؛ لأنهم خلصوا كخلوص {3} الصافي من شائب الأدناس. وقيل في معنى (اصطفائه إيَّاهم)، قولان:أحدهما: اصطفى دينهم على سائر الأديان؛ لأن دين الجماعة الإسلامُ، وقد قال الله عز وجل: ﴿إِنَّ الدِّينَ عِنْدَ اللَّهِ الْإِسْلَامُ﴾ [آل عمران: 19]، وهذا اختيار الفرَّاء، قال {4}: وهو من باب حذف المضاف، كقوله: ﴿وَاسْأَلِ الْقَرْيَةَ﴾ [يوسف: 82].القول الثاني: أنه اصطفاهم بالنبوَّة والرسالة، على عالمي زمانهم. وأراد بـ ﴿آلَ إِبْرَاهِيمَ﴾ إسماعيل، وإسحاق، ويعقوب، والأسباط {5}.وبـ ﴿وَآلَ عِمْرَانَ﴾: موسى وهارون {6}. قالوا: وإنما خصَّ هؤلاء بالذكر؛ لأنَّ الأنبياء بأسرهم من نسلهم.وقوله تعالى: ﴿عَلَى الْعَالَمِينَ﴾. قال صاحب ""النَّظْمِ"": ظاهر هذا اللفظ على العموم، وتأويله على الخصوص؛ لأنه يتضمَّنُ أخباراً منفصلاً بعضها من بعض، وأُجْمِلَت في الإخبار عنها؛ لأنه عز وجل إنْ كان عنى بالاصطفاء: أولادَ آدم، فمن سواه من العالمين الذين فُضِّل عليهم قد خرجوا من أن يكون لهم على العالمين فضل؛ لأن آدم من جملة العالمين، وكذلك نوحٌ، وإبراهيم، وآل عمران، إذا دخل أحد هؤلاء في التفضيل خرج الآخرون منه {7}؛ لأن كلاً من (العالَمين).فتأويل ذلك: أنَّ الله اصطفى كلاً منهم على عالَم لا يدخله من قد فُضِّل منهم على عالَم آخر، كما جاء في التفسير: على عالَمي زمانهم."
  3,34,"قوله تعالى: ﴿ذُرِّيَّةً بَعْضُهَا مِنْ بَعْضٍ﴾ قال أبو إسحاق {1}: المعنى اصطفى ذرِّيَةً بعضها من بعض؛ فيكون نصب (ذريةً) على البدل {2}، وجائز {3} أن ينتصب {4} على الحال، المعنى: اصطفاهم في حال كون بعضهم مِن بعض {5}.وقوله: ﴿بَعْضُهَا مِنْ بَعْضٍ﴾ فيه قولان: أحدهما: بعضها من ولد بعض؛ لأنَّ الجميع {6} ذُرِّية آدمَ ثم ذُرِّية نوح {7}.الثاني: (بعضها [من بعض)] {8}، أي: في التناصر {9} في الدين {10}، فيكون المعنى: أنَّ بعضها يوالي {11} بعضاً، ولا يَتَبَرَّأُ بعضهم من بعض، كما يتبرأ الكافرون؛ ألا تراه {12} قال: {إِذْ تَبَرَّأَ الَّذِينَ اتُّبِعُوا مِنَ الَّذِينَ اتَّبَعُوا} [البقرة:166].فقوله: ﴿بَعْضُهَا مِنْ بَعْضٍ﴾، أي: هم على غير صفة الكافرين؛ لأنهم إخوان متوالون {13}، وهذا كقوله: ﴿الْمُنَافِقُونَ وَالْمُنَافِقَاتُ بَعْضُهُمْ مِنْ بَعْضٍ﴾ [التوبة: 67]؛ أي: بعضهم يُلابس {14} بعضاً، ويوالي بعضاً وليس المعنى: على النسل والولادة، [لأنه قد يكون من نَسْلِ] {15} المنافقِ مُؤمنٌ، ومِنْ نَسْلِ المؤمنِ مُنافقٌ. قال عُبَيْد الرَّاعي {16}:فَقلتُ ما أنا مِمَّن لا يُواصِلُنِي ... ولا ثَوائِيَ {17} إلا رَيْثَ أحْتَمِلُ {18}.أي: لا [أُلابس مَنْ لا] {19} يواصلني، ولا أُواليهِ.والعرب تقول: (هو مِنْ بني فلان)؛ إذا كان يواليهم ويُلابسهم، وإن لم يكن من نسلهم. وهذا القول يُحكى معناه عن أبي رَوْق {20}.وقوله تعالى: ﴿وَاللَّهُ سَمِيعٌ عَلِيمٌ﴾. قال عطاء عن ابن عباس {21}: هذا مخاطبة لليهود الذين قالوا: نحن أبناءُ الله وأحبَّاؤه، وأبناء {22} الأنبياء الذين اصطفاهم. فأنزل فيهم قوله: ﴿قُلْ إِنْ كُنْتُمْ تُحِبُّونَ اللَّهَ﴾، الآيات إلى قوله: ﴿وَاللَّهُ سَمِيعٌ عَلِيمٌ﴾، ويريد: ﴿سَمِيعٌ﴾ لقولكم الذي تقولون: إنكم من ولد إبراهيم، وإسحاق، ويعقوب، ومن آل عمران. وإنَّما فضَّلت أولئك، ورفعتهم واصطفيتهم؛ بطاعتهم، ولو عصوني، لأنزلتهم منازل العاصين. ﴿عَلِيمٌ﴾ بما في قلوبكم من تكذيب محمد، وعصيانه، بعد إقراركم بالتوراة، وتصديقكم بما فيها من صفته.وذكر أهل المعاني في هذا قولين آخرين:أحدهما: أنَّ المعنى: ﴿وَاللَّهُ سَمِيعٌ﴾ لما تقوله (الذرية) المصطفاة ﴿عَلِيمٌ﴾ بما تضمره {23}؛ فلذلك فضلها على غيرها، لما في معلومه من استقامتها في فعلها وقولها {24}.القول الثاني: أنَّ هذه الآية تتصل بما بعدها، تقديرها: ﴿وَاللَّهُ سَمِيعٌ﴾ لما تقوله امرأة عمران، ﴿عَلِيُمٌ﴾ بما تضمره، إذْ قالتْ: ﴿رَبِّ إِنِّي نَذَرْتُ﴾ [آل عمران: 35]، الآية، وفيه إشارة إلى أنه لا يضيع لها شيء من جزاء عملها {25}."
  3,35,"قوله تعالى {1}: ﴿إِذْ قَالَتِ امْرَأَتُ عِمْرَانَ﴾. اختلف النحويون في وجه ﴿إِذْ﴾ ههنا: فزعم أبو عبيدة {2} أنها زائدة، لَغْوٌ؛ والمَعنى: (قالت امرأة عمران)، ولا موضع لها من الإعراب {3}.قال الزَّجاج {4}: ولم يصنع أبو عبيدة في هذا شيئاً، لأن (إذ) تدل على ما مضى من الزمان، وكيف يكون الدليل على ما مضى من الوقت لغواً.وقال ابن الأنباري {5} منكراً لهذا القول أيضاً {6}: إنَّا لا نُلغي حرفاً من كتاب الله عز وجل إذا وجدنا سبيلاً إلى أن لا يكون مُلغىً {7}.قال الأخفش، والمبرِّد {8}: المعنى: (اذكر إذ قالت امرأة عمران). وقد {9} مضى مثل هذا كثيراً.وقال أبو إسحاق {10}: المعنى عندي: (واصطفى آل عمران ﴿إِذْ قَالَتِ امْرَأَتُ عِمْرَانَ﴾) {11}. فالعامل في ﴿إِذْ﴾: معنى الاصطفاء {12}.وأنكر أبو بكر هذا، وقال: الله تعالى قَرَنَ اصطفاءه [آل عمران] {13} باصطفائه آدم ونوحاً، واصطفاؤه آدم ونوحاً قبل قول إمرأة عمران. وأيضاً فإن (عمران) هذا غير عمران المذكور في قوله: ﴿وَآلَ عِمْرَانَ﴾، لأنه {14} عمران أبو موسى وهارون، وهذا عمران بن ماتان {15}، وبينهما ألف وثمانمائة سنة. كذلك ذكره ابن عبّاس {16}، ومقاتل {17}.وذكرنا أيضاً عن بعض أهل المعاني أن هذه الآية متصلة بما قبلها، فيكون العاملُ في ﴿إِذْ﴾ على هذا القول: معنى قوله ﴿سَمِيعٌ عَلِيمٌ﴾.وقوله: ﴿امْرَأَتُ عِمْرَانَ﴾ هي: حَنَّةُ {18}، أمُّ مريمَ، جَدَّةُ عيسى عليه السلام، دعت الله أنْ يَهَبَ لها ولداً، وقالت: الَّلهم لك عَلَيَّ إن رزقتني ولداً، أن أتصدق به على بيت المقدس، فيكون من {19} سَدَنَتِه {20} وخَدَمِه، شكراً لك. وكان على أولادهم فرضاً أن يطيعوهم في نذورهم، وكان الرجل ينذُرُ في ولده أن يكون خادماً في مُتعّبَّدِهم {21}.وقوله تعالى: ﴿نَذَرْتُ لَكَ مَا فِي بَطْنِي مُحَرَّرًا﴾ معنى ﴿نَذَرْتُ﴾: [أَوْجَبتُ] {22}.والنذر: ما يوجبه الإنسان على نفسه بِشَرِيطة كان، أو بغير شَرِيطة {23}.قال أهل اللغة: معنى النَّذْر: استدفاع المَخُوفِ، بما يُعقَد على النفس من عمل البِّر. وأصله، من: الإنذار، وهو: الإعلام بموضع المخافة {24}.وانتصب ﴿مُحَرَّرًا﴾ على الحال من ﴿مَا﴾ تقديره: نذرت لك الذي في بطني محرراً {25}.وقال ابن قتيبة {26}: أرادت نذرت لك أن أجعل {27} ما في بطني محرراً، أي: عتيقاً {28} خالصاً لله، خادماً للكنيسة، مفرغاً للعبادة ولخدمة الكنيسة. وكل ما أُخْلِصَ فهو مُحَرَّر. يقال: (حرَّرتُ العبدَ). إذا أعتقته، و (حَرَّرْتُ الكتابَ) إذا أصلحته، وأخلصته، فلم يبق فيه ما يحتاج إلى إصلاحه {29}.و (رجل حُرٌّ): إذا كان خالصاً لنفسه، ليس لأحد عليه مُتَعَلَّق. و (الطينُ الحُرُّ): الذي خَلَصَ من الرملِ والحَمْأَةِ {30} والعيوب.وقوله تعالى: ﴿فَتَقَبَّلْ مِنِّي﴾. معنى التَّقَبُّلِ {31}: أخذُ الشيءِ على الرِضى {32} به {33}. وأصله، من: المقابلة؛ لأنه يقابل بالجزاء ما يؤخذ.وقوله تعالى: ﴿إِنَّكَ أَنْتَ السَّمِيعُ﴾. أي: لدعاي {34}. ﴿الْعَلِيمُ﴾ بما في قلبي."
  3,36,"قوله تعالى: ﴿فَلَمَّا وَضَعَتهَا﴾. قال المفسرون {1}: هلك عمرانُ أبو مريمَ، وامرأته (حَنَّة) حاملٌ {2} بمريمَ، ﴿فَلَمَّا وَضَعَتهَا﴾ أي: ولدتها. و (الهاء): راجعة إلى ﴿مَا﴾، في قوله: ﴿نَذَرْتُ لَكَ مَا فِي بَطْنِي﴾، و (ما) يقع على المؤنث، وقوعُهُ على المُذَكَّر {3}، وكان ما في بطنها، أُنْثى.وقوله تعالى: ﴿قَالَتْ رَبِّ إِنِّي وَضَعْتُهَا أُنْثَى﴾. اعتذار منها إلى الله حين فعلت ما لا يجوز من تحرير الأنثى للكنيسة {4}.وقوله تعالى: ﴿وَاللَّهُ أَعْلَمُ بِمَا وَضَعَتْ﴾. قُرئ بإسكان التَّاء وضمها {5}:فمن {6} ضم التاء؛ جعل هذا من كلام أمِّ مريم، وهو كقول القائل: (ربِّ قد كان كذا وكذا، وأنت أعلم بما كان). ليس يريد بقوله: (ربِّ قد كان كذا)، إعلام الله سبحانه [وتعالى] {7}، ولكنه كالخضوع منه، والاستسلام لله تعالى، لذلك قالت: ﴿وَاللَّهُ أَعْلَمُ بِمَا وَضَعَتْ﴾ {8}، لأنها لم ترد بقولها: ﴿رَبِّ إِنِّي وَضَعْتُهَا أُنْثَى﴾، إخبارًا لله تعالى.ومن قرأ بإسكان التَّاء وهو أَجْوَدُ القراءتين، كان قوله: ﴿وَاللَّهُ أَعْلَمُ بِمَا وَضَعَتْ﴾، مِن {9} كلام الله تعالى، ولو كان من قول أمِّ مريم، لكان: (وأنت أعلم بما وَضَعْتُ)؛ لأنها تخاطب الله سبحانه [وتعالى] {7}؛ ولأنها قد قالت: ﴿رَبِّ إِنِّي وَضَعْتُهَا أُنْثَى﴾، [فليست] {11} تحتاج {12} بعد هذا [القول] {13} أن تقول: والله أعلم بما وضعْتُ {14}.وقوله تعالى: ﴿وَلَيْسَ الذَّكَرُ كَالْأُنْثَى﴾. أي: في خِدْمَة الكنيسة والعِبِّادِ الذين فيها؛ لما يلحقها من الحَيْضِ والنفاس، والصيانة عن التَّبَرُّجِ [للناس] {15}.قال عبد الله بن مُسْلِم {16}: قوله: ﴿وَلَيْسَ الذَّكَرُ كَالْأُنْثَى﴾، مؤخَّرٌ، معناه التقديم على قراءة العامة كأنه قال: إنِّي وضَعتها أُنثى وليس الذكر كالأنثى؛ لأنه من قول أمِّ مريم {17}.قوله تعالى: ﴿وَإِنِّي أُعِيذُهَا بِكَ﴾. يقال: (عاذ فلانٌ بالله)؛ أي: التجأ إليه، وامتنع به، فأعاذه؛ أي: أجارَهُ، ومنعه {18}. فمعنى: ﴿أُعِيذُهَا بِكَ﴾ أي: أمنعها، وأجيرها بك.وذكرنا معنى (العوذ) في قوله: ﴿قَالَ أَعُوذُ بِاللَّهِ أَنْ أَكُونَ مِنَ الْجَاهِلِينَ﴾ {19} {20} [البقرة: 67].وقوله تعالى: ﴿مِنَ الشَّيْطَانِ الرَّجِيمِ﴾. أي: المطرود، المَرْمِيِّ {21} بالشُّهُبِ. وقال ابن عباس: ﴿الرَّجِيمِ﴾: الملعون {22}. ويجوز أن يكون ﴿الرَّجِيمِ﴾ بمعنى: المسبوب المشتوم {23}. وذكرنا معاني (الرَّجْمِ) في سورة الحِجْر عند قوله: ﴿مِنْ كُلِّ شَيْطَانٍ رَجِيمٍ﴾ [الحجر: 17]. ومعنى هذه الإعاذة، وإجابة الله تعالى إيَّاها إلى ما سألت؛ هو: ما رواه أبو هريرة: أنَّ النبي ﷺ قال: ""ما من مولود، إلاَّ والشيطان يَمَسُّهُ حين يُولَد، فيستَهِلُ صارخاً من مَسِّ الشيطان إيَّاه، إلا مريمَ وابنَها""، ثمَّ يقول أبو هريرة: (اقرأوا إنْ شِئْتُم: ﴿وَإِنِّي أُعِيذُهَا بِكَ وَذُرِّيَّتَهَا مِنَ الشَّيْطَانِ الرَّجِيمِ﴾ {24}."
  3,37,"قوله تعالى: ﴿فَتَقَبَّلَهَا رَبُّهَا بِقَبُولٍ حَسَنٍ﴾ التَّقَبلُ، والقَبُولُ، معناهما سواء، وهو: أن ترضى بالشيء، وتأخذه؛ ولهذا قال: ﴿بِقَبُولٍ﴾ ، ولم يقل: (بتَقَبُّلٍ)؛ لأن معناهما واحدٌ.قال الفراء {1}: والعرب قد تترك المصدر للفعل المذكور، وتأتي بمصدر آخر في معنى الأول، وإن اختلف بالزيادة والنقصان؛ كقولك: (تكلَّمْتُ كلاما). وهذا النوع يقال له المصدر على غير المصدر.وذكرنا هذا عند قوله: ﴿إِلَّا أَنْ تَتَّقُوا مِنْهُمْ تُقَاةً﴾ [آل عمران: 28]. والقَبُول: مصدر قولهم: (قَبِلَ فلانٌ الشيءَ): إذا رضِيَهُ.قال أبو عمرو بن العَلاء {2}: وليس في المصادر (فَعُولٌ) بفتح الفاء، إلَّا هذا، قال: ولم أسمع فيه الضَّمَّ.وقال سيبويه {3}:خمسة {4} مصادر، جاءت على (فَعُول): (قَبُولٌ)، و (وَضُوءٌ) {5}، و (طَهُورٌ)، و (وَلُوعٌ)، و (وَقُود)، إلاَّ أنَّ الأكثر في (وَقُود) {6} إذا كان مصدراً {7} الضَّم. وأجاز الفرَّاء {8}، والزجَّاج {9} (قُبُولا) بالضَّمِّ.ثَعْلَب، عن ابن الأعرابي {10}: يقال: قَبِلْتُهُ (قَبُولاً)، و (قُبُولاً) {11}، و (على وجهِهِ قَبُولٌ)، لا غير {12}، قال الشاعر: قد يُجهدُ {13} المرء إنْ لم يُنل {14} ... بالبشر والوجه عليه القَبُول {15}.قال المفسِّرون {16}: معنى قوله: ﴿فَتَقَبَّلَهَا رَبُّهَا بِقَبُولٍ حَسَنٍ﴾ أي: رَضِيَها مكان المُحَرَّرِ الذي نذَرتْه (حَنَّةُ)، ولم يقبل قبلها أنثى في ذلك المعنى.وقال ابن عباس في رواية الضحَّاك: معناه: سَلَك بها طريقَ السُّعداء. وقوله تعالى: ﴿وَأَنْبَتَهَا نَبَاتًا حَسَنًا﴾.قال الزجَّاج {17}: جاء لفظُ {18} ﴿نَبَاتًا﴾ على غير لفظِ (أَنْبَتَ)، على معنى: نبتت نباتاً حَسنَاً.وقال ابن الأنباري {19}: لمَّا كان (أَنْبَتَ) يدل على [نَبَتَت] {20} حمل {21} الفعل على المعنى؛ كأنه قال: (وأنبتها، فَنبَتَتْ هي نباتاً حَسَناً)؛ كقول امريء القيس:[ورُضْتُ] {22} فَذَلَّت {23} صعبةً أيَّ إذْلالِ {24} أراد: أيَّ رياضة. فلمَّا دلَّ (رُضْتُ) على (أذْلَلْت) {25}، حمله {26} على المعنى، وخلَّى {27} اللفظَ.قال ابن عباس في رواية عطاء {28}، في قوله: ﴿وَأَنْبَتَهَا نَبَاتًا حَسَنًا﴾؛ يريد: في صلاحٍ ومعرفةٍ بالله، وطاعةٍ له، وخدمةٍ للمسجد.وقال في رواية الضحَّاك {29}: يعنى: سوَّى خَلْقَها من غير زيادة، ولا نقصان، فكانت تنبت في اليوم ما ينبت المولود في عام واحد.وقوله تعالى: ﴿وَكَفَّلَهَا زَكَرِيَّا﴾ {30} أي: ضَمَّها {31} إلى نَفْسِهِ وقام بأمرها.قال الزجَّاج {32}: ومعناه في هذا: ضَمِنَ القيامَ بأمرها، يقال {33}: (كَفَلَ {34}، يَكْفُلُ، كَفالة، وكَفْلاً) {35}، فهو كافِل؛ وهو: الذي قد كَفَلَ إنساناً يَعُولُه {36} ويُنفِقُ عليه.و ﴿زَكَرِيَّا﴾، رُفعَ بفعله {37}، لأن الكفالة نُسِبت إليه. وفيه قراءتان: القَصر، والمَدُّ، وهما لغتان فيه، كقولهم: (الهَيْجاء)، و (الهَيْجا)، والألِفُ فيه أَلِفُ تأنيثٍ؛ ولهذا لا ينصرف في معرفة ولا نَكِرة؛ لأن (زكريا) {38}؛ بالمَدِّ، مثل: (حمراءَ)، و (سوداءَ) {39}؛ وبالقصر، مثل: (حُبْلى) {40}، و (سَكْرى) {41}، و (ذِفْرى) {42} وهذا النوعُ لا ينصرفُ في مَعْرفة ولا نَكِرَة؛ لأن الاسم {43} بُني على أَلِفِ التأنيث، وحقُّ التأنيثِ أن يكون داخلاً على لفظ المُذَكَّر؛ نحو: (قائم)، و (قائمةٌ)؛ فلما بُنِي الاسمُ على علامة التأنيث، ولَزِمَت {44} الاسمَ حتى صارت كبعض حروفه، صار كأن التأنيثَ قد تكرر فيه، فقامت العِلَّةُ مَقامَ العِّلَّتين {45}، فلم ينصرف {46} في النَّكرة والمعرفة.وقرأ حمزةُ والكسائيُ: (وكَفَّلَها) مشَدَّدا، ومصدره: التَّكْفِيلُ، والتَّكْفِلةُ {47} و ﴿زَكَرِيَّا﴾ {48} على هذه القراءة منصوب؛ لأنه المفعول الثاني للتَّكفيل، ومعناه: ضَمَّنها الله زكريا {49}، وضَمَّها إليه؛ وذلك أنَّ (حَنَّةَ) لمَّا ولدت مريمَ، أتت بها سَدنَةَ بيت المقدس، وقالت لهم: دونكم هذه النذيرة {50}. فتنافس فيها الأَحْبارُ {51}، حتى اقترعوا عليها، فخرجت القُرعة لزكرياءَ {52} عليه السلام. ونذكر ما فيه عند قوله: ﴿إِذْ يُلْقُونَ أَقْلَامَهُمْ﴾ [آل عمران: 44]. فمعنى قوله: ﴿وَكَفَّلَهَا زَكَرِيَّا﴾ {53}: أنَّ الله تعالى {54} ضمَّها {31} إلى زكريا {56} بالقُرْعَة التي قَرعها {57}.وقوله تعالى: ﴿كُلَّمَا دَخَلَ عَلَيْهَا زَكَرِيَّا الْمِحْرَابَ وَجَدَ عِنْدَهَا رِزْقًا﴾. قال المفسرون {58}: لمَّا ضمَّ زكريا مريمَ إلى نفسه، بنى لها مِحْرابا في المسجد، وبابه في وسطها، لا يُرقى إليها إلا بسُلَّم، ولا يَصعَد إليها غيره.و (المِحْرابُ) في اللغة: أشرف المجالس. وكانت محاريب بني إسرائيل مساجدَهم {59}.و (المِحْراب): الغُرْفَة أيضاً، قال عمر {60} بن أبي ربيعة {61}:رَبَّةُ مِحْرابٍ إذا جِئْتها ... لم أَدْنُ حتى أرْتَقي سُلَّما {62}.أي: رَبَّة غُرفةٍ. وقال الأصمعي {63}: (المِحْراب): الغُرْفة؛ ألا تراه يقول: ﴿إِذْ تَسَوَّرُوا الْمِحْرَابَ﴾ [سورة ص: 21].وقال الزجاج {64}: (المحراب): أرفع بيت في الدار، وأرفع مكان في المسجد، قال: و (المحراب) ههنا كالغرفة، وأنشد بيت عمر {65}.وقال أبو عبيدة {66}: (المحراب) عند العرب سيِّدُ المجالس، ومُقَدَّمُها، وأشرفها، وإنما قيل للقبلة: محرابٌ؛ لأنها أشرف موضع في المسجد. ويقال للقصر محرابٌ؛ لأنه سيِّد المنازل {67}.قال امرؤ {68} القيس:كغزلان وَحْشٍ في محاريبِ أَقْوال {69} أراد بـ (المحاريب): القصور {70}. قال ابن عباس في رواية عطاء {71}: صارت عنده لها غرفة تصعد إليها تصلي فيها الليل والنهار.وقوله تعالى: ﴿وَجَدَ عِنْدَهَا رِزْقًا﴾.قال {72} ابن عباس {73}، والربيع {74}: كان زكريَّا كلما دخل عليها غرفتها وجد عندها رزقاً؛ أي: فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، تأتيها به الملائكة من الجَنَّةِ.قال محمد بن إسحاق {75}: كان هذا كله، بعد أن بلغت مريمُ مبلغ النساء.وقال الحَسَنُ {76}: كان هذا في صغرها، ولم ترضع ثدياً قط، بل {77} كان يأتيها رزقها من الجَنَّة، وتكلَّمت وهي صغيرة، حين أجابت زكريا بقولها: ﴿هُوَ مِنْ عِنْدِ اللَّهِ﴾ {78}.قال أبو إسحاق {79}: ونصب ﴿كُلَّمَا﴾ بقوله: ﴿وَجَدَ﴾ {80}؛ أي: يَجِدُ عندها الرزقَ في كل وقت يدخل عليها المحرابَ، فيكون (ما) مع (دَخَلَ)، بمنزلة: الدخول {81}، أي: في كل وقت دخول {82}.وقوله تعالى: ﴿أَنَّى لَكِ هَذَا﴾. قال ابن عباس {83}: يريد: من أين لك هذا؟ وانما سألها؛ لأنه خاف أن يأتيها الرزقُ من غير جهته، فتبيَّن أنه من عند الله، لا من عند الناس {84}.وقوله: ﴿إِنَّ اللَّهَ يَرْزُقُ مَنْ يَشَاءُ بِغَيْرِ حِسَابٍ﴾. قد فَسَّرنا هذا في موضعين: من {85} سورة البقرة، ومن هذه السورة {86}. وهذا يحتمل أن يكون من كلام مريمَ، ويحتمل أنَّه على {87} الابتداء، والأَوْلى به الاستئناف {88}؛ لأنه ليست {89} من معنى الجواب عمَّا سئلت في شيء."
  3,38,"قوله تعالى: ﴿هُنَالِكَ دَعَا زَكَرِيَّا رَبَّهُ﴾ قال أهل اللغة {1}: (ههنا) و (هنا) تقريب (ثَمَّ) {2}.ومعنى (هنالك)؛ أي: عند ذلك. و (وهنالك): مَحَلٌّ ومَوْضِعٌّ؛ كما أنَّ (حيث): مَحَلٌّ، و (عِنْدَ)، و (حِينَ): وقتان.فلو قال عز وجل: (عند ذلك دعا زكريا) لكان جائزاً {3}، بمثل {4} معنى (هنالك). ولكن العرب تضع المحل موضع اسم الوقت في مثل هذا، فيقولون: (كان ذلك حيث وَليَ زيدٌ) بمعنى حين وَليَ، وكذلك (هنالك): مَحَلٌ يوضع {5} موضع (عند)، وقد يكون مجاز (هنالك) في هذا الموضع مَحَلاًّ؛ لأن ما ذَكَرَه عز وجل من هذه القصة، يكون مضمناً لوقت {6} ومحل؛ لأنه لا يكون إلا في محل؛ كما لا يكون إلا في وقت؛ فلما لم يجز أن يكون {7} إلا {8} في محل؛ احتمل أن يومئ إلى ذلك المحل بقوله: ﴿هُنَالِكَ﴾، و (هناك)، و (هنالك) لأصلُ فيهما: [هنا] {9}، ثم {10} زيدت الكاف؛ للخطاب، كما قالوا في (ذا) {11}: (ذاك).ومن قال: (هنالك) فتقديره تقدير (ذلك)، والكاف فيهما للخطاب {12}. وقول زهير:هنالك إنْ تُسْتَخبَلُوا {13} المالَ تُخبِلُوا {14} يحتمل (هنالك) أن يكون {15} لمحل، وأن يكون لوقت.و (هنالك)، و (هناك) و (هنا) {16}، و (ههنا)، شيء واحد، إلا أن (هنا)، و (ههنا)، لم يُذكرا في شيء من الأوقات، وإنما ذُكرا في المحالِّ {17} القريبة منك.قال الزجَّاج {18}: و (هنالك) في موضع نصب، لأنه ظرف؛ ويقع في المكان من الزمان والحال {19}.[ومعنى قوله: ﴿هُنَاِلكَ دَعَا﴾؛ أي: في ذلك المكان من الزمان والحال] {20} دعا.قال أهل التفسير: لمَّا رأى زكريا ما أوتي {21} مريم من فاكهة الصيف في الشتاء، وفاكهة الشتاء في الصيف على خلاف مجرى العادة، طمع في رزق الولد من العاقر، على خلاف مجرى العادة، فدعا الله عز وجل، فقال: ﴿هَبْ لِي مِنْ لَدُنْكَ﴾. أي: من عندك {22}. و (لَدُن) اسمٌ غير متمكن {23}، ونذكر حقيقته، وما قيل فيه، في سورة الكهف إن شاء الله.وقوله تعالى: ﴿ذُرِّيَّةً طَيِّبَةً﴾. أي {24}: نسلاً مباركاً تقياً {25}. والذُّرِّية)؛ يكون {26} واحدًا وجمعًا، وذكرًا وانثى {27}.والمراد بـ (الذُّرِّيَّة) ههنا: ولدٌ واحدٌ؛ لقوله: ﴿فَهَبْ لِي مِنْ لَدُنْكَ وَلِيًّا﴾ [مريم: 5].قال الفرَّاء {28}: وأنَّث الـ (طَيِّبَة)؛ لتأنيث لفظ الذرية؛ كما قال الشاعر:أبوك خليفةُ وَلَدَتْهُ أخرى ... وأنت خليفةٌ، ذاك الكمال {29}فأنَّثَ فعل الخليفة؛ لتأنيث لفظهِ {30}. وقال آخرُ: فَمَا تَزْدَري مِنْ حَيَّةٍ جَبَلِيَّةٍ ... سُكاتٍ {31} إذا ما عَضَّ ليس بِأَدْرَدا {32}فجمع التأنيث، والتذكير: مرَّة على اللفظ، ومرةً على المعنى.قال: وهذا يجوز في أسماء الأجناس، دون التي معناها: فلانٌ؛ نحو: (طَلْحَة)، و (حَمْزَة)، و (مُغِيرَة). لا يجوز (جاءت طلحة)؛ من قِبَل أنَّ التذكيرَ الحقيقي يغلب على تأنيث اللفظ.وقوله تعالى: ﴿إِنَّكَ سَمِيعُ الدُّعَاءِ﴾. قيل {33}: مجيب الدعاء في التفسير؛ وذلك أن مَنْ لا يُجابُ {34} كلامه، صار بمنزلة من لم يُسمع {35}، فقيل لمن أجيب في سؤاله: سُمع دعاؤه. وعلى هذا دلَّ كلام ابن عباس في تفسير هذه الآية؛ لأنه قال في قوله {36}: ﴿إِنَّكَ سَمِيعُ الدُّعَاءِ﴾ يريد: لأنبيائك، وأهل طاعتك {37}.وهذا يدل على أنه أراد بالسمع: الإجابة؛ لأن دعاء غير هؤلاء مسموع لله تعالى على الحقيقة."
  3,39,"قوله تعالى: ﴿فَنَادَتْهُ الْمَلَائِكَةُ﴾ يقال: نادى، مُناداةً، ونِداءً. فالكسر: مصدرٌ {1}، والضم اسمٌ {2}. وأكثر ما جاءت الأصوات على ضَمِّ أولها؛ نحو: (الرُّغاء) {3}، و (البُكاء)، و (الصُّراخ)، و (الهُتاف) {4}.وفي قوله: ﴿فَنَادَتْهُ الْمَلاَئِكَةُ﴾، قراءتان: التذكير، والتأنيث {5}.قال الفرَّاء {6}: (الملائكة)، وما أشبههم من الجمع، يُذَكَّر وُيؤَنَّث.وقرأت القُرَّاءُ: ﴿يَعرُجُ الملائكة﴾، و ﴿تَعرُجُ﴾ {7} [المعارج: 4]، و ﴿تَتَوَفَّاهُمُ الْمَلَائِكَةُ﴾ و ﴿ويَتَوفَّاهم الملائكة﴾ {8} {9} [النحل: 28]، فمن ذكَّر؛ ذهب إلى معنى التذكير، ومن أنَّث؛ فلِتأنيث الاسم.قال الزجَّاج {10}: الجماعة، يلحقها التأنيث؛ للفظ الجماعة، ويجوز أن يُعبَّر عنها بلفظ التذكير؛ لأنه يقال: جَمْعُ الملائكة، وهذا كقوله: ﴿وَقَالَ نِسْوُةُ﴾ [يوسف: 30].وقال أهل المعاني {11}: أراد بالملائكة {12} ههنا: جبريل، وحده {13}، وذلك جائز في العربية أن تخبر عن الواحد بمذهب الجمع؛ كما تقول في الكلام: (ركب السفنَ)، و (خرجَ على البِغالِ)، وإنما ركب بغلاً واحدًا. وهذا {14} جائز فيما لم يُقْصد فيه قَصْد {15} واحدٍ بعينه.قال الزجَّاج {16}: المعنى: أتاه النداءُ من هذا الجنس، الذين هم الملائكة {17}، كما تقول: (ركب فلانٌ في السُّفُن) وإنما ركب في سفينةٍ واحدةٍ؛ تريد بذلك: جَعْلَ ركوبه في هذا الجنس.ومثل {18} هذا مما في القرآن قوله: ﴿الَّذِينَ قَالَ لَهُمُ النَّاسُ﴾ [آل عمران: 173]، وهو نعيْمُ بن مَسعود {19}، ﴿إِنَّ النَّاسَ﴾، يعني: أبا سُفيان {20}.قال المفضَّل: إذا كان القائل رئيسًا، فيجوز الإخبار عنه بالجمعِ؛ لاجتماع أصحابه معه، فلمَّا كان جبريل عليه السلام رئيس الملائكة، وقلَّما يُبْعثُ إلاَّ ومعه جَمعٌ منهم، جُرِيَ على هذا. وهذا قول ابن عباس {21}، والأكثرين {22}: إنَّ المنادى جبريل وحده.وقال غيره: ناداه جماعةٌ من الملائكة {23}.وقوله تعالى: ﴿أَنَّ اللهَ يُبَشِرُكَ﴾ يُقْرأ بـ ﴿إِنَّ﴾ {24}: مكسورًا ومفتوحاً {25}؛ فمن فتح {26}، كان المعنى: (فنادته بِأَنَّ اللهَ)، فلمَّا حذف الجارّ منها {27}، وصل الفعلُ إليها فنصبها؛ فـ (أَن) {28} في موضع [نصب] {29}. وعلى قياس قول الخليل: في موضع {30} [جَرٍّ] {31}. وقد ذكرنا هذه المسألة فيما تقدم.ومن كَسَرَ، أضمر القولَ؛ كأنه: (ناداه، فقال: إنَّ الله) فحذف القولَ. وإضمار القول كثير في هذا النحو، كما قال: ﴿وَالْمَلَائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِنْ كُلِّ بَابٍ (23) سَلَامٌ عَلَيْكُمْ﴾ [الرعد:23 - 24]، ﴿وَالْمَلَائِكَةُ بَاسِطُو أَيْدِيهِمْ أَخْرِجُوا﴾ [الأنعام: 93]، ﴿فَأَمَّا الَّذِينَ اسْوَدَّتْ وُجُوهُهُمْ أَكَفَرْتُمْ﴾ [آل عمران: 106]، فأضمر القول في ذلك كلِّه {32}.وقوله تعالى: ﴿يُبَشِّرُكَ﴾ قد {33} ذكرنا معنى التبشير في قوله: ﴿وَبَشِّرِ الَّذِينَ آمَنُوا﴾ [البقرة: 25].وقرأ حمزةُ والكسائيُّ {34}: ﴿يُبَشِّرُكَ﴾ {35}، مُخَفَّفاً، من (البَشْرِ) {36} وهو بمعنى: التبشير {37}.قال أبو زيد: يقال: (بَشَّرَ، يُبَشِّرُ)، [و (أبْشَرَ يُبْشِرُ] {38} إبْشارا)، و (بَشَرَ، يَبْشُرُ، بَشْرا)، ثلاث لغات {39}. ونحو هذا قال ابن الأعرابي فيما روى عنه ثَعْلَب {40}.وقال أهل اللغة {41}: أصل معنى (البَشْرِ): إصابة البَشَرَةِ يقال: (بَشَرتُ الأديمَ) {42}: إذا أخذتُ بَشَرَتَه بشَفْرةٍ، و (بَشَرَ الجرادُ الأرض): إذا أكلَ ما عليها، [فأخذ بَشَرَتها {43}، فاستُعمِلَ هذا في إيراد الخبرِ {44} السَّارِّ؛ لأنه يصيب البَشَرَة بالهَشاشَةِ {45}] {46}.وقال الزجَّاج {47}:معنى ﴿يُبَشِّرُكَ﴾ {48} بالتخفيف: يسُرُّكَ، ويُفرِحُكَ، يقال: (بَشَرْتُ الرَّجُلَ، أبْشُره): إذا أفرحته، فـ (بَشِرَ {49}، يَبْشَرُ): إذا فرِحَ.وقال ابن الأعرابي {50}: (بَشِرتُ بكذا، وأبْشَرْتُ به) أي: فرحت {51}، ومنه قوله تعالى: ﴿وَأَبْشِرُوا بِالْجَنَّةِ﴾ [فصلت: 30].وقوله تعالى: ﴿بِيَحْيَى﴾. (يحيى) {52}، لا ينصرف، عَربيّاً كان، أو عجمِيًّا {53}: لأنه إن كان عجميَّا: فقد اجتمع فيه العُجْمةُ والتعريف، وإن كان عربيًّا: لا {54} ينصرف؛ لِشِبهه {55} بالفعل، وأنه معرفة.قال المفسرون: سمَّاه الله تعالى بهذا الاسم قبل مولده {56}.قال الحسين {57} بن الفضل {58}: إنَّما سُمِّيَ (يَحْيى) {59}، لأن الله [تعالى] {60} أحياه بالطاعة، حتى لم يَعْصِ، ولم يَهم بمعصية. فمعنى (يحيى): أنه يعيش مطيعاً لله عمره، ألا ترى أنَّ الكافر يُسمَّى (مَيْتاً)؛ قال الله تعالى: ﴿أَوَمَنْ كَانَ مَيْتًا فَأَحْيَيْنَاهُ﴾ [الأنعام: 122]، قيل في تفسيره: ضالاً فهديناه {61}.وقوله تعالى: ﴿مُصَدِّقًا بِكَلِمَةٍ مِنَ اللَّهِ﴾. نصب على الحال؛ لأنه نكرة، و (يَحيى) معرفة.قال ابن عباس {62}: يريد: مُصدِّقاً بعيسى أنه روح الله، وكلمته.وسُمِّيَ (عيسى) كلمةُ الله؛ لأنه حدث عند قوله: ﴿كُن﴾، فوقع عليه اسم (الكلمة)؛ لأنه بها كان.قال المفسرون: وكان (يحيى) أول من آمن بـ (عيسى) عليهما السلام، وصدَّقه، وكان (يحيى) أكبر من (عيسى) {63}.قوله تعالى: ﴿وَسَيِّدًا﴾. (السَّيِّد) من باب: (الصَّيِّب)، و (المَيِّت). وقد ذكرنا ما فيهما {64}. ويقال {65}: (سادَ فلانٌ قومَه، يَسُودُهم، سُؤْدَداً، وسِيادَةً): إذا صار رئيسهم {66}.قال أبو {67} إسحاق {68}: (السيِّد): الذي يفوق في الخير قومَه.وقال بعض أهل اللغة: (السيد): المالك الذي {69} يجب {70} طاعته؛ ولهذا يقال: (سيِّد الغلام)، ولا يقال: سيِّد الثوب.سَلَمَة {71} عن الفرَّاء {72}: (السيِّد): المالك {73}، و (السيِّد): الرئيس، و (السيِّد): الحليم، و (السيِّد): السَّخي، و (السيِّد): الزوج، ومنه قوله: ﴿وَأَلْفَيَا سَيِّدَهَا﴾ [يوسف: 25]، [أي: زوجها] {74}.وقال أبو خيرة {75}: سُمِّيَ (سَيِّدا)، لأنه يَسُودُ سَوادَ الناسِ، أي: عُظْمَهم {76}. هذا قول أهل اللغة في معنى (السيِّد).فأما أهل {77} التفسير: فقال ابن عباس {78}: السَّيِّد: الكريم على رَبِّهِ عز وجل. وقال قتادة {79}: السيِّد، هو: العابد، الورع، الحليم. وقال عِكرمَة {80}: السيد: الذي لا يغلبه غضبُهْ.وقوله تعالى: ﴿وَحَصُورًا﴾ (الحَصْرُ) في اللغة: الحَبْسُ {81}. يقال: (حَصَرَه، يَحْصُرُه، حَصْراً). و (حُصِرَ الرجلُ): إذا اعتُقِل بطنه {82}، و (حَصرَ {83} الرجلُ عن النساء)، فهو (حَصُورٌ).والحَصُورُ: الضَّيِّقُ {84}، البخيل، الذي يمنع مالَهُ، فلا يُخرِجُ مع النَّدامى {85} شيئاً للشراب {86}، ومنه:لا بالحَصُورِ ولا فيها بِسَوَّارِ {87} و (الحَصور)، و (الحَصِرُ) أيضاً: الذي يكتم السِّرَّ، ويحبسه في نفسه.قال جرير:ولقَدْ تَسَقَطني الوُشاةُ فصادفوا ... حَصِرًا بِسِرِّكِ {88} يا أمَيْمَ ضَنينا {89} قال ابن قتيبة {90}: الحَصُور: الذي لا يأتي النساء، وهو (فَعُولٌ) بمعنى: (مفعول)؛ كأنه {91} محصور عنهن، أي: مأخوذ {92}، محبوس {93}، ومثله: (رَكوب)، بمعنى: مَرْكُوب {94}، و (حَلوب)، بمعنى: مَحْلُوب {95}. ويجوز أن يكون (فَعُولاً) بمعنى: (فاعل)؛ يعني: أنه حَصَرَ نفسه عن الشهوات.وجميع المفسرين: على أن (الحَصُور) ههنا: الذي لا يأتي النساءَ، ولا يقربهن {96}.قال ابن عباس: هو الذي لا يجامع النساءَ، إنما له فَرْجٌ كفَرْجِ الصَّبِيِّ الصغير {97} وقال سعيد بن المُسَيِّب {98}: هو العِنِّين.وروي عن النبي ﷺ، أنه ذكر يحيى بن زكريا ثم أهوى بيده إلى قَذَاةٍ {99} من الأرض فأخذها، وقال: ""كان ذَكَرُهُ مثلَ هذه القذاةِ"" {100}.فعلى هذا القول: (الحَصور)، بمعنى: (المحصور)، وهو الذي حُصر عنهن، على {101} قول الجمهور، وهو (فَعُول) بمعنى (فاعل)؛ لأنه حَبَس نفسه عنهن. وقد استقصينا هذا الحرف عند قوله: ﴿فَإِنْ أُحْصِرْتُمْ﴾ [البقرة: 196]."
  3,40,"قوله تعالى: ﴿قَالَ رَبِّ أَنَّى يَكُونُ لِي غُلَامٌ﴾ ذهب كثير من المفسرين إلى أن زكريَّا خاطب بهذا جبريل عليه السلام، فقال: (رَبِّ)؛ أي: يا سيِّدي {1}. وذهب جماعة إلى أنه خاطب الله تعالى {2}.وقوله: ﴿أَنَّى يَكُونُ﴾ إنْ قيل: كيف أنكر زكريَّا الولدَ مع تبشير الملائكة إيَّاه به؟ وما معنى هذه المراجعة؟ ولِمَ عجب {3} من ذلك بعد إخبار الله تعالى بأنه يكون، إذ يقول عز وجل: ﴿أَنَّ اللَّهَ يُبَشِّرُكَ بِيَحْيَى﴾؟ فالقول في ذلك: ﴿أَنَّى يَكُونُ لِي﴾ {4} أن معنى قوله ﴿أَنَّى يَكُونُ﴾ على أيِّ حالٍ يكون ذلك؛ أيَرُدُّني إلى حال الشباب، وامرأتي؟ أم من حال الكِبَرِ؟. فقال ما قال من هذا مستثْبِتاً، ومستعْلِماً، لا متعجباً، ولا منكِراً {5}.والغُلامُ: الشابُّ من الناس. وأصله من (الغُلْمَةِ). و (الاغتلام)؛ وهو: شِدَّة طَلبِ النِّكاح. ويقال: (غُلامٌ بّيِّن {6} الغُلُومِيَّةِ، والغُلُومَةِ، والغُلامِيَّةِ) {7}.قال الفرَّاء {8}: والعرب تجعل مصدرَ كلِّ اسمٍ ليس له فعلٌ {9} معروف على هذا المثال. فتقول: (هذا [عبدٌ] {10} بَيِّن {11} العبودية، والعبدِيَّةِ {12}، والعبودَةِ).وقوله تعالى: ﴿وَقَدْ بَلَغَنِيَ الْكِبَرُ﴾. (الكِبَرُ)، مصدرُ: (كَبِرَ الرجلُ، يَكْبَرُ): إذا أسَنَّ {13}.قال أهل المعاني {14}: معنى ﴿وَقَدْ بَلَغَنِيَ الْكِبَرُ﴾: وقد بَلَغتُ الكِبَرَ؛ وذلك أن كلَّ {15} شيءٍ صادَفْته وبلغته، فقد صادفك وبلغك. وكان نسبةُ الفعلِ إلى الكبر، كنسبته {16} إلى الرجل؛ يدل على هذا قولُ العرب: (تلقَّيْتُ الحائطَ)، و (تلقَّاني {17} الحائطُ).فإن قيل: أيجوز {18} (بلغني البلدُ) في موضع (بلغْتُ البلدَ)؟ قيل: إنما جاز في الكِبَرِ؛ لأن الكبَر بمنزلة الطالب، فهو يأتيه بحدوثه {19} فيه، والإنسان {20} أيضاً يأتيه بمرور السنين عليه، ولا يجوز مثل ذلك في البلد، وليس الكبَر بمنزلة البلد، إنما هو بمنزلة: القول، والعطاء، والإفضال {21}، والعقاب؛ فكما يجوز: (بلغني عطاؤك)، و (بلَغَتْ زيداً {22} جائزتُكَ)، (وبلغ عبدَ اللهِ عقابُكَ)، جاز أن يكون {23} البلوغُ منسوباً {24} إلى الكِبَر {25}.قال ابن عباس في رواية الضحاك {26}: كان زكريا يوم بُشِّر بالولد ابن عشرين ومائة سنة، وكانت امرأته بنت ثمانٍ وتسعين سنةً.وقوله تعالى: ﴿وَامْرَأَتِي عَاقِرٌ﴾. العاقِر {27} من النساء: التي لا تلد. يقال: (عَقُرَت، تعْقُرُ، عُقْراً، وعَقارةً) {28}.أنشد الفراء: إرْزامَ نابٍ عقُرت أعواماً ... فَعَلِقَتْ بُنَيَّها {29} تَشْماما {30}ويقال أيضًا: (عَقُرَ الرجلُ، وعَقَرَ، وعَقِرَ) {31}: إذا لم يُحمل له. و (رجلٌ عاقرٌ) {32}.قال عامرُ بن الطُّفَيْل {33}: لبئس الفتى إنْ كنتُ أعورَ عاقرًا ... جبانًا فما عذري لدى كلِّ مَحْضَرِ {34}قال أبو إسحاق {35}: قوله: ﴿وَامْرَأَتِي عَاقِرٌ﴾، في هذا دليل على أن (عاقرًا) {36} وقع على جهة النَّسَب {37}؛ لأنَّ (فَعُلَت) أسماء {38} الفاعلين فيه على (فَعِيلَة) نحو: (ظَريفة) {39}، و (كَريمة)؛ وإنما (عاقر) على: (ذات عُقْرٍ) {40}، و (رجالٌ ونساءٌ عُقُرٌ) {41} وفي الحديث: (عُجُزٌ عُقُرٌ) {42}.ويقال: (أعقَر اللهُ [رحِمَها]) {43}، فهي (مُعْقَرَةٌ). و (رملٌ {44} عاقِر): لا يُنبِت شيئاً {45}.وذَكر {46} زكريا عليه السلام عُقْرَ زوجته مع كِبَر نفسه؛ لزيادة ترجيحٍ في الاستبعاد، فلمَّا استفهم عن {47} كيفيَّة حال الولادة؛ قيل له: ﴿كَذَلِكَ اللَّهُ يَفْعَلُ مَا يَشَاءُ﴾؛ أي: مثل ذلك من الأمر، وهو: هبة الله الولدَ على الكِبَر، يفعل الله {48} الذي يشاؤه، فسبحان من لا يعجزه شيء."
  3,41,"قوله تعالى: ﴿قَالَ رَبِّ اجْعَلْ لِي آيَةً﴾ قال المفسرون: إنَّ زكريا عليه السلام لمَّا بُشِّر بالولد، سأل الله تعالى علامةً يعرف بها وقت حمل امرأته؛ ليزيد في العبادة؛ شكراً {1} على هبة الولد {2}، فقال الله تعالى: ﴿آيَتُكَ أَلَّا تُكَلِّمَ النَّاسَ ثَلَاثَةَ أَيَّامٍ إِلَّا رَمْزًا﴾. أي {3}: علامة ذلك أن تمسك {4} لسانك عن الكلام، وأنت صحيح سَوِيٌ، لأنه قال في موضع آخر: ﴿أَلَّا تُكَلِّمَ النَّاسَ ثَلَاثَ لَيَالٍ سَوِيًّا﴾ [مريم: 10]؛ أي: وأنت سَوِي.قال الحسنُ {5}، وقتادة {6}، والربيع {7}: أُمسِك لسانُه ثلاثةَ أيام، فلم يقدر أن يكلم الناس إلاَّ إيماءً، وجعل ذلك علامةَ حملِ امرأتِه.و (الرَّمْزُ): الإيماء بالشَّفَتين، والحاجِبَيْن، والعينين؛ يقال: (رَمَزَ، يَرمُزُ، وَيرْمِزُ)، ومنه قيل للفاجرة: (رامِزَةٌ)، و (رمَّازَةٌ) {8}؛ لأنها تَرمُز وتُومِئ {9}، ومنه الحديث: أنه (نهى عن كسب الرَّمَّازة) {10}.قوله تعالى: ﴿وَاذْكُرْ رَبَّكَ كَثِيرًا﴾. إن {11} قيل: إذا مُنع من {12} الكلام، واضطُرَّ إلى الإشارة، كيف يقدر على التسبيح؟ قيل {13}: إنَّ الله تعالى حبس لسانه عن التَّكلم بأمور {14} الدنيا، وما يدور بين الناس، ولم يُحبس لسانه عن التسبيح. فكانت هذه أبلغ في الأعجوبة من أن يُمنع من {15} كلِّ ما يجري به اللسانُ {16}.وقوله تعالى: ﴿وَسَبِّحْ بِالْعَشِيِّ وَالْإِبْكَارِ﴾ أي: صَلِّ لله تعالى. والصلاة تُسَمَّى تسبيحا {17}، لأن الصلاة يُوَحَّد فيها الله تعالى، وُينَزَّه، ويُوصف بكلِّ ما يُبَرِّئه من السوء {18}.و (العَشيُّ): آخر النهار، جمع (عَشِيَّة) {19}. و (الإبكار) مصدر: (أَبْكَرَ: إذا صار في وقت البُكرة {20}، أو سار {21} فيه، ومثله: (بَكَر)،و (ابتَكَر) {22} ، و (بَكَّر)، قال عمر بن {23} أبي ربيعة:أمِنْ آل نُعْمٍ أنت غادٍ {24} فَمُبْكِرُ {25}وقال أيضًا:أيُّها الرائِحُ المُجِدُّ ابتكارا {26} وقال زُهير:بَكَرَنَ بُكوراً واسْتحَرْنَ بِسُحْرةٍ {27}و (باكرت الشيء): إذا بكَّرت له، قال لَبيد:[باكرْتُ حاجَتَها الدجاجَ بسُحرةٍ {28}هذا معنى (الإبكار)، ثمَّ يُسَمَّى ما بين طُلوعِ] {29} الفجر إلى الضحى:إبكاراً، كما يُسَمَّى: إصباحاً {30}."
  3,42,"قوله تعالى: ﴿وَإِذْ قَالَتِ الْمَلَائِكَةُ يَا مَرْيَمُ﴾. هذا عطف على قوله: ﴿إِذْ قَالَتِ امْرَأَتُ عِمْرَانَ﴾ {1}، وذكرنا العامل في ﴿إذْ﴾ هناك. وأراد بـ ﴿الْمَلَائِكَةِ﴾: جبريل وحده كما ذكرنا {2}. وهذا كقوله: ﴿يُنَزِّلُ الْمَلَائِكَةَ بِالرُّوحِ مِنْ أَمْرِهِ﴾ [النحل: 2]، يعني: جبريل وحده {3}.وقوله تعالى: ﴿إِنَّ اللَّهَ اصْطَفَاكِ﴾. أي: بما لطف لكِ [حتى] {4} انقطعتِ إلى طاعته، وصرت متوفرة {5} على اتباع مرضاته.﴿وَطَهَّرَكِ﴾. قال ابن عباس {6}: أي: من ملامسة الرجال. وقيل: من الحيض، والنفاس، كانت مريم لا تحيض {7}. ﴿وَاصْطَفَاكِ عَلَى نِسَاءِ الْعَالَمِينَ﴾.قال الأكثرون {8}: معناه: على عالَمي زمانها؛ بأن فضلت عليهن {9}.قال أبو إسحاق {10}: وجائز أن يكون على نساء العالمين كلِّهم؛ لأنه ليس في النساء امرأة وَلَدت من غير أبٍ {11} غير مريم؛ ولأنها {12} قُبِلت في التحرير للمسجد {13}، ولم يكن التحرير في الإناث، فهي مختارة على النسوان كلِّهنَّ، بما لها من الخصائص {14}. وكرَّر الاصطفاء {15}، لأن كلا {16} الاصطفائين مختلفٌ {17} معناهما: فالاصطفاء الأول: عمومٌ يدخل فيه صوالحُ النساء، والثاني: اصطفاء بما اختُصَّت به من خصائصها."
  3,43,"قوله تعالى: ﴿يَا مَرْيَمُ اقْنُتِي لِرَبِّكِ﴾. ذكرنا معنى القنوت فيما تقدم {1}. قال مجاهد: معناه: أطيلي القيام في الصلاة {2}.وقال ابن عباس: يريد: قومي للصلاة بين يدي ربِّكِ {3}.وقوله تعالى: ﴿وَاسْجُدِي وَارْكَعِي﴾. يقال: لم قدَّم الأمرَ بالسجود على الركوع، وهو قبل السجود؟ قيل: (الواو) عند النحويين للجمع لا للترتيب {4}، وليس فيه دليل على المبدوء به.قال أبو الفتح الموصلي {5}:واوُ العطفِ {6}، ليس فيها دليل على المبدوء به في المعنى؛ لأنها ليست مُرَتِّبةً، يدلُّ على ذلك قولُ لَبيد:أُغْلي السِّباءَ {7} بكلِّ أدكنَ عاتقٍ {8} ... أو جَوْنَةٍ قُدِحتْ وفُضَّ خِتامُها {9}.وإنما يُفتح ويفض: الختم قبل الغَرْف {10}، فقد علمت أن (قُدِحت) مُقَدَّم في اللفظ، مُؤَخَّرٌ في المعنى، كذلك ههنا بدأ بالسجود لفظاً، وهو مؤَخَّرٌ معنى، والكلام في هذه المسألة يُذكر {11} عند قوله: ﴿إِذَا قُمْتُمْ إِلَى الصَّلَاةِ فَاغْسِلُوا﴾ [المائدة: 6] الآية.قال {12} ابن الأنباري {13}: أمَرها أمراً عاماً، وحضَّها على أفعال الخير، فكأنه قال: استعملي السجود في حال، واستعملي الركوع في حال، ولم يذهب إلى أنهما يجتمعان، ثمَّ يُقدَّم السجودُ على الركوع؛ بل أراد العموم بالأمر على اختلاف الحالين {14}.وقوله تعالى: ﴿مَعَ الرَّاكِعِينَ﴾. ولم يقل مع الراكعات؛ لأن الراكعين أعمُّ؛ لوقوعه على الرجال والنساء إذا اجتمعوا، والراكعات يختصُّ بالنساء، فكان {15} الأعم أولى.ومعنى قوله: ﴿مَعَ الرَّاكِعِينَ﴾ أي: افعلي كفعلهم. وقيل: المراد به: الصلاة في الجماعة {16}.قال المفسرون {17}: كلَّمت الملائكةُ بهذا مريَم شفاها، فقامت مريمُ في الصلاة حتى ورمت قدماها، وسالتا دماً، وقيحاً."
  3,44,"قوله تعالى: ﴿ذَلِكَ مِنْ أَنْبَاءِ الْغَيْبِ﴾. أشار إلى ما قصَّ من حديث زكريا، ومريم، ويحيى.وقوله تعالى: ﴿نُوحِيهِ إِلَيْكَ﴾ [أي] {1}: نلقيه إليكَ {2}. و (الإيحاء) في اللغة: إلقاء معنى الكلام إلى من تريد إعلامه؛ إما بإرسال رسول، أو بإلهام، أو بكتابة، أو بإشارة {3}. فمن الإرسال: قوله عز وجل: ﴿إِنَّا أَوْحَيْنَا إِلَيْكَ كَمَا أَوْحَيْنَا إِلَى نُوحٍ﴾ {4} [النساء: 163].ومن الإلهام: قوله: ﴿وَأَوْحَى رَبُّكَ إِلَى النَّحْلِ﴾ [النحل: 68]، وقوله: ﴿وَأَوْحَيْنَا إِلَى أُمِّ مُوسَى أَنْ أَرْضِعِيهِ﴾ [القصص: 7]، ومن الإشارة: قوله: ﴿فَأَوْحَى إِلَيْهِمْ أَنْ سَبِّحُوا﴾ [مريم: 11]، أي: أشار إليهم، وقوله: ﴿وَإِنَّ الشَّيَاطِينَ لَيُوحُونَ إِلَى أَوْلِيَائِهِمْ﴾ [الأنعام: 121]، أي: يُلْقون إليهم بالوَسْوَسَة {5}.وقوله تعالى: ﴿وَمَا كُنْتَ لَدَيْهِمْ إِذْ يُلْقُونَ أَقْلَامَهُمْ﴾. الأقلام: جمع (القَلَم)، و (القَلَم) {6} أصله من: (القَلْمِ)، وهو: قطع للطَّرَفِ {7}، يقال منه: (قَلَمْتُ الظُفُرَ) {8}. والقَلَمُ: الذي يُكْتب به؛ بمعنى: مَقْلُوم؛ لأنه يُبْرى طرفُهُ. والقَلَمُ: القِدْحُ {9}، لانه يُسَوَّى بأن يُقْطع طرفاه {10}.قال ابن عباس في رواية عطاء {11}: هؤلاء كانوا جماعة من الأنبياء، اختلفوا واختصموا في مريم، كل واحد يقول: أنا أَوْلى بها، فقال زكريا: هي بنت عمِّي، وخالتها عندي. قالوا: فتعالوا حتى نَسْتَهِم {12}. فجمعوا سهامهم، ثم أَتَوا بها إلى العَيْنِ، وقالوا: اللَّهمَّ، مَنْ كان أَوْلى بها فَلْتقُم سَهْمُهُ، ويغرق {13} البقيَّة. وأَلْقَوا سهامَهم، فارتَزَّ {14} قلَمُ زكريا، وانحدرت {15} أقلامُ الآخرين {16}، فقرعهم زكريا {17}.وقال الزجَّاج {18}: هي قِداحٌ جعلوا عليها علامات، يعرفون بها مَنْ يَكْفل مريمَ على جهة القرعة.وقوله تعالى: ﴿أَيُّهُمْ يَكْفُلُ مَرْيَمَ﴾. مختصر {19}؛ أي: لينظروا أيُّهم تجب له كفالة مريم {20}."
  3,45,"قوله تعالى: ﴿إِذْ قَالَتِ الْمَلَائِكَةُ﴾ قال ابن عباس: يريد: جبريل {1}.﴿يَا مَرْيَمُ إِنَّ اللَّهَ يُبَشِّرُكِ بِكَلِمَةٍ مِنْهُ﴾. يعني: عيسى، لأنه في ابتداء أمره كان كلِمَةً من الله ألقاها إلى مريم، ثمَّ كوَّن تلك الكلمة بَشَراً. قال الحسنُ {2}، وقتادةُ {3}: لأنه كان بكلمة الله [تعالى] {4}، وهو: ﴿كُنْ﴾، ومعنى هذا: أنه أوجده بالكلمة، وكونه بها، وهي قوله: ﴿كُنْ﴾ من غير توليد من فَحْلٍ، أو تنسيل من ذَكَرٍ، وهو معنى قوله: ﴿إِنَّ مَثَلَ عِيسَى عِنْدَ اللَّهِ كَمَثَلِ آدَمَ خَلَقَهُ مِنْ تُرَابٍ ثُمَّ قَالَ لَهُ كُنْ﴾ [آل عمران: 59]، ولم يُردْ -والله أعلم- أنَّ عيسى هو الكلمة نفسها، ألا تراه يقول: ﴿اسمُهُ المَسِيحُ﴾، ولو أراد الكلمة لقال {5}: (اسمها المسيح) {6}.وقيل: إنما سمَّاه كلمةً؛ لأن الله تعالى بشَّر به في الكتب السالفة، فلمَّا أوجده سمَّاه كلمة، كما يقول الذي يُخْبِرُنا بأمر كائن -إذا وُجِدَ ذلك الأمر-: (قد جاء قولي {7} وكلامي)، وقيل: لأن الله عز وجل يهدي به كما يهدي {8} بكلمته.وقيل: لأنه كان (يُكلِّم) {9} عن الله تعالى فيُبشِّر، ويُنْذر {10}.وقوله تعالى: ﴿اسْمُهُ الْمَسِيحُ﴾. ذَكَر {11} الكنايةَ {12}؛ لأنه عنى بـ (الكلمة): عيسى، أو الولد، فرجعت الكناية إلى معنى الكلمة، لا إلى اللفظ.فإن قيل: كيف أخبر أن اسمه المسيح، وقدمه على اسمه المعروف، وهو: عيسى، وإنما لُقِّب بـ (المسيح) بعد نفاذ التسمية له بـ (عيسى)؟قيل: إنَّ الأسماء ألقاب عُلِّقت على المُسمَّيات؛ للفصل بين الأعيان فإذا عُلِّق الاسم على المولود في وقت ولادته، ثمَّ شُهر بعد عُلُوِّ سنِّه {13} بلقب، كان اللقبُ أغلبَ عليه من الاسم، لأن من يعرفه به أكثر ممن يعرفه باسمه الحقيقي، فلهذه العلَّة قُدِّم المسيح على عيسى، ألا ترى أنَّ ألقاب الخلفاء أشهر وألزم لهم من أسمائهم {14}.فأما معنى المسيح؛ فقال أبو عبيد {15} والليث {16}: المسيح أصله بالعبرانية: [(مشيحا). فعرَّبته العربُ وغيرت لفظه، وكما قالوا {17}: موسى، وأصله: (موشى)، أو (ميشى) بالعبرانية] {18}، فلمَّا أعربوه {19} غيَّروه {20}، فعلى هذا لا اشتقاق {21} له، وأكثر العلماء على أنه مشتق.قال ابن عباس في رواية عطاء والضحاك {22}: وإنما {23} سُمِّيَ عيسى عليه السلام مسيحاً؛ لأنه كان لا يمسح بيده ذا عاهة إلا برئ {24}.وقال أحمد بن يحيى {25}: سمي مسيحاً؛ لأنه كان يمسح الأرض؛ أي: يقطعها.فعلى قول هؤلاء، هو: (فعيل) بمعنى: (فاعل)، وقيل: إنه {26} (فعيل) بمعنى: (مفعول) {27}، على أنه مُسِح من الأوزار، وطُهِّر {28}.وقيل: لأنه خرج من بطن أمِّه ممسوحاً بالدهن {29}.وقال الحسن {30}، وسعيد {31}: لأنه مُسح بالبركة. وبهذا {32} قال مِنْ {33} أهل اللغة: شَمِر {34}. وقال ابن الأعرابي {35}، وأبو الهيثم {36}: المسيح بن مريم: الصدِّيق.قال أبو الهيثم {37}: وضدُّ الصديق: المسيحُ الدجال؛ أي: الضلِّيل، الكذاب؛ خلق الله المسيحين، أحدهما ضد الآخر، فكان {38} المسيح بن مريم يُبْرِئ الأَكْمَهَ، والأبْرَصَ {39}، ويحيى الموتى بإذن الله، وكذلك الدجال، يحيي الميتَ، ويميت الحيَّ، وينشئ السحائب {40} [وينبت] {41} النبات، فهم المسيحان {42}: مسيح الهدى، ومسيح الضلالة.قال [المنذري] {43}: فقلت {44} له: بلغني أن عيسى [عليه السلام] {45}، إنما سُمِّي مسيحاً، لأنه [مُسح بالبركة، وسُمِّيَ الدجال مسيحا؛ لأنه] {46} ممسوح العين. فأنكره، وقال: إنما المسيح ضدَّ المسيح، يقال: مَسَحَه الله؛ أي: خلقه حَسناً مباركاً، ومَسَحَه {47}، أي: خلقه قبيحاً ملعوناً.وكان إبراهيم النخعي يذهب أيضاً {48} إلى أن المسيح، معناه: الصِّدِّيق {49}.قال ابن الأنباري {50}: وهذا القول لا يعرف {51} اللغويون مذهبه؛ إذ {52} كانت لا تصف كلَّ صِدِّيق بـ (المسيح)، ولعل كان هذا مستعملاً {53} في بعض الأوقات في وصف الصدِّيقين، فدَرَسَ مع ما دَرَسَ من الكلام؛ لأن الكسائي قال {54}: قد درس من كلام العرب شيء كثير. ثمَّ فسَّر المسيح وبيَّنه من هو، فقال: ﴿عِيسَى ابْنُ مَرْيَمَ وَجِيهًا فِي الدُّنْيَا وَالْآخِرَةِ﴾. معنى (الوجيه): ذو الجاه والشرف والقدْر، يقال: (وجُهَ الرجلُ، يَوْجُهُ، وَجاهةً)، فـ (هو وَجِيْهٌ): إذا صارت له منزلة رفيعة عند السلطان والناس {55}.وقال بعض أهل اللغة {56}: الوجيه: الكريم، عند من لا يسأله؛ لأنه لا يردُّه لكرم {57} وجهه عنده {58}، خلاف من يبذل وجهه للمسألة {59}، فيرده {60}.قال الزجَّاج {61}: ﴿وَجِيهًا﴾، منصوب على الحال، المعنى: إنَّ الله يبشِّرك بهذا الولد، وجيهاً في الدنيا والآخرة. والفرَّاء {62} يسمي هذا قطْعاً، كأنه: كان {63} عيسى بن مريم الوجيه، قُطِع منه التعريف {64}.وقوله تعالى: ﴿وَمِنَ الْمُقَرَّبِينَ﴾. أي: إلى ثواب الله وكرامته."
  3,46,"قوله تعالى: ﴿وَيُكَلِّمُ النَّاسَ فِي الْمَهْدِ﴾ موضع ﴿وَيُكَلِّمُ﴾ منصوب؛ في التأويل بالنَّسَقِ {1} على (وجيه)، كأنه قال: (وجيها، ومُكَلِّماً الناسَ)، ولا يُنكَرُ وضعُ {2} المستقبل موضعَ الحال. ومثله قوله: ﴿فَهَبْ لِي مِنْ لَدُنْكَ وَلِيًّا يَرِثُنِي﴾ [مريم: 5 - 6]، في قراءة مَنْ رَفَعَ {3}. وهذا أحدُ ما يضارعُ به الفعلُ المستقبلُ الاسمَ.وأنشد النحويُّون على هذا: بتُ أُعَشِّيها {4} بَعضْبٍ باتِرِ ... يَقْصِدُ {5} في أَسْوُقِها وجائِرِ {6} على معنى: قاصدٌ {7}، وجائزٌ.وقوله تعالى: ﴿فِي الْمَهْدِ﴾. أي: صغيراً. والمَهْدُ: الموضع الذي مُهِّدَ لنوم الصبي {8}.قال ابن عباس في رواية عطاء {9}: يريد: الحَجْرَ {10}. ويعني بكلامه ﴿فِي الْمَهْدِ﴾: تبرئة أمِّهِ ممَّا قُرِفَت {11} به {12}.وقوله تعالى: ﴿وَكَهْلاً﴾. هو عطف على الظرف من قوله: ﴿فِي الْمَهْدِ﴾، كأنه قيل: (ويكلِّم الناس صغيراً وكهلاً) {13}.و (الكَهْلُ) في اللغة: الذي اجتمع [فيه] {14} قوَّتُه، وتَمَّ {15} شبابُه، وهو من قول العرب: (اكْتَهَلَ النَّباتُ): إذا قَوِيَ وتَمَّ {16}.قال الأعشى:يُضاحكُ الشمسَ منها كوكبٌ شَرِقٌ ... مُؤَزَّرٌ، بعَميمِ النَبْتِ مُكْتَهِلُ {17}أراد بـ (المكْتَهِل): المتناهي في الحسن والكمال.واختلفوا في كهولة عيسى عليه السلام، فقال بعضهم: إنه رفع إلى السماء حين {18} دخل في الكهُولة؛ وذلك، أنه كان قد أرْبى {19} على الثلاثين، ومن أَرْبى {20} عليها فقد دخل في الكُهُولة، وتقَضَّى أكثرُ شبابه {21}. وعلى هذا القول: يكلِّم الناس كهلاً، قبل أن يرُفع إلى السماء. وهذا معنى قولِ مقاتل {22}، وابن عباس في رواية عطاء {23}، لأنه قال {24} في قوله: (وكهلاً) {25}؛ يريد: أنه يتكلم بكلام النبَّوة.وقال بعضهم: المراد بقوله: ﴿وَكَهْلاً﴾ {26}: بعد أن ينزل من السماء يكلِّم الناس بعد نزوله إلى الأرض، كهلاً {27}. وهذا اختيار الحسين بن الفضْل {28}، قال {29}: وفي هذا بيان نزوله في نصِّ القرآن {30}.وقوله تعالى: ﴿وَمِنَ اَلصَّالِحِينَ﴾. قال عطاء {31}: يريد: مثل: موسى، وإسرائيل {32}، وإسحاق، وإبراهيم {33}."
  3,47,"قوله تعالى {1}: ﴿قَالَتْ رَبِّ أَنَّى يَكُونُ لِي وَلَدٌ وَلَمْ يَمْسَسْنِي بَشَرٌ﴾ قال أهل المعاني {2}: إنَ مريم لا تستنكر في قدرة الله تعالى خلقَ الولد من غير مَسِيس بَشَرٍ {3}، وإنَّما قالت هذا؛ لأنَّ في البشرية التعجب مما خرج عن العادة، كما يقول الإنسان: (كيف تَهَبُ ضيعتَك، وهي أنفَس أملاكك.؟!) ليس يشك في هبته، وإنما يتعجب من وجوده. و (البَشَر): الخَلْق. واحدُهُ وجمعُه سواء؛ لأنه بمنزلة المصدر {4}، نحو {5}: الخَلْق، يقال {6}: هذا خَلْق، وهؤلاء خَلْق {7}. وإنما وجب في المصدر ذلك؛ لأنه جنس في الفعل، كما وجب في الماء والرمل، وما هو من أسماء الأجناس.وأصله من (البَشَرَة) التي هي ظاهر الجِلْدِ؛ لأنه الذي من شأنه أن يَظْهَرَ الفرحُ والغمُّ في بشَرَته {8}.وقوله تعالى: ﴿كَذَلِكِ اللَّهُ يَخْلُقُ مَا يَشَاءُ﴾. أي: يخلق الله {9} ما يشاء مثل ذلك من الأمر، وهو: خَلْق الولد من غير مَسِيس.وقوله تعالى: ﴿وَإِذَا قَضَى أَمْرًا﴾. إلى آخر الآية. ذكرنا ما فيه في سورة البقرة، عند قوله: ﴿بَدِيعُ السَّمَاوَاتِ وَالْأَرْضِ وَإِذَا قَضَى أَمْرًا﴾ [البقرة: 117]. الآية."
  3,48,"قوله {1} تعالى: ﴿وَيعَلِمُهُ الكِتَابَ﴾. الآية. قال ابن جُرَيج، وغيره: أراد: الكتابة والخط {2}. وقيل: أراد كتابًا آخر غير التوراة والإنجيل، من نحو: الزَّبُور وغيره {3}."
  3,49,"[و] {1} قوله تعالى: ﴿وَرَسُولًا إِلَى بَنِي إِسْرَائِيلَ﴾. قال أبو إسحاق {2}: ينتصب على وجهين: أحدهما: (ويجعلُهُ {3} رسولاً). قال: والاختيار عندي: أنه (ويكَلِّمُ الناسَ رسولاً)؛ لقوله: ﴿أَنِّي قَدْ جِئْتُكُمْ﴾؛ والمعنى: يكلِّمُهم رسولاً بأني {4} قدْ جئتكم {5}.وقال الأخفش {6}: إن شئت جعلت الواو في ﴿وَرَسُولًا﴾ مُقْحَمَةً {7}، و (الرسولا) {8} حالاً للهاء {9}، تقديره: ونُعَلِّمُهُ الكتابَ رسولا {10}.وقوله تعالى: ﴿أَنِّي قَدْ جِئْتُكُمْ بِآيَةٍ مِنْ رَبِّكُمْ﴾ هو ذكر آية واحدة، وإنما جاءهم {11} بآيات، وهي: خلق الطير، وإبراء الأكْمَه والأبرص، وإحياء الموتى، وإنباء {12} بما يأكلونَ؛ وذلك، أنه أراد بالآية: خلق الطير، ثم عطف عليه إبراء {13} الأكمه والأبرص على جهة الاستئناف.وقوله تعالى: ﴿أَنِّي أَخْلُقُ لَكُمْ مِنَ الطِّينِ﴾ مَنْ {14} فتح ﴿أَنِّي﴾ {15}، جعلها بدلاً من ﴿آيَةٍ﴾ {16}، كأنه قال: (وجئتكم بأني أخلق لكم من الطين)، ويكون موضع ﴿أَنِّي﴾ خفضاً على البدل من ﴿آيَةٍ﴾ {17}، ويجوز أن يكون رَفعاً على معنى: الآيةُ أنِّي أخلق لكم) {18}. ومَنْ كَسَرَ {19}، فله وجهان: أحدهما: الاستئناف، وقَطْع الكلامِ مما قبله.والوجه الآخر: أنه {20} فسر الآية بقوله: {إنِّي أخلق [لكم من الطين] {21}}، ويجوز أن يفسِّر الجملة المقدمة بما يكون على وجه الابتداء، كقوله تعالى: ﴿وَعَدَ اللَّهُ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ﴾ [المائدة: 9]، ثمَّ فسَّر الموعود بقوله: ﴿لَهُم مَّغفِرَةٌ﴾ {22}، وكقوله: ﴿إِنَّ مَثَلَ عِيسَى عِنْدَ اللَّهِ كَمَثَلِ آدَمَ﴾ {23} [آل عمران: 59]، ثمَّ فسَّر المَثَلَ بقوله: ﴿خَلَقَهُ مِنْ تُرَابٍ﴾. وهذا الوجه أحسن؛ لأنه في المعنى كقراءة مَنْ فتح (أنِّي)، وأبدل من آية {24}.وقوله تعالى: ﴿أَخْلُقُ لَكُمْ مِنَ الطِّينِ﴾ أي: أقَدِّر، وأصوِّر. والخلْقُ، معناه: التقدير في اللغة {25}.وقوله تعالى: ﴿كَهَيْئَةِ الطَّيْرِ﴾ الهيئةُ: الصورة المُهَيَّأة؛ من قولهم: (هيَّأتُ الشيءَ): إذا قدَّرُته {26}.وقوله تعالى: ﴿فَأَنْفُخُ فِيهِ﴾ أي: في الطَّيْر. و (الطَّيْر): يجوز تذكيره، على معنى الجمع، وتأنيثه، على معنى الجماعة.ولا يجوز أن تعود {27} الكناية {28} إلى الطين؛ لأن النفخ إنَّما يكون في طِينٍ مخصوص، وهو: ما كان مُهَيَّأ منه، والطينُ المتقدِّمُ ذكرهُ، عامٌ، فلا تعود إليه الكناية؛ ألا ترى أنه لا يَنْفخ في جميع الطِّينِ {29}؟. ويجوز أن تعود الكناية على ذي الهيئة. وأريد بـ (الهيئة): ذو الهيئة، كما أريد بـ (القسمة): المقسوم، في قوله: ﴿وَإِذَا حَضَرَ الْقِسْمَةَ﴾ [النساء: 8] لأنه قال: ﴿فَارْزُقُوهُمْ مِنْهُ﴾ {30} {31}.كذلك أراد بـ (الهيئة): المُهيَّأ، وذا {32} الهيئة.و {33} يجوز أن تعود الكناية إلى ما وقعت الدلالة {34} عليه في اللفظ، وهو {35}: أنَّ (يَخْلُق) يدل على الخَلْقِ، فيكون قوله: ﴿فَأَنْفُخُ فِيهِ﴾؛ أي: في الخَلْقِ، ويكون الخلق بمنزلة المخلوق.ويجوز أن تعود إلى ما دلَّ عليه الكافُ من معنى المِثْل؛ لأن المعنى: أخلق من الطين مِثْلَ هيئة الطير، ويكون الكافُ في موضع نصب على أنه صفة {36} للمصدر المُرادِ، تقديره: (أنِّي أخلق لكم من الطينِ خَلْقاً مثلَ هيئةِ الطَّيْرِ). وهذه الوجوه ذكرها أبو علي الفارسي {37}.وقوله تعالى: ﴿فَيَكُونُ طَيْرًا بِإِذْنِ اللَّهِ﴾ وقرأ {38} نافع {39}: ﴿طائراً﴾ {40}، على معنى: يكون {41} ما أنفخ فيه طائراً، أو {42} ما أخلُقُهُ طائراً، أو أراد أن {43} يكون كلَّ واحد من ذلك طائراً، كما قال تعالى: ﴿فَاجْلِدُوهُمْ ثَمَانِينَ جَلْدَةً﴾ [النور: 4] أي: كلَّ واحد منهم.وقال بعضهم {44}: ذهب نافع {45} إلى نوع واحد من الطير؛ لأنه لم يَخْلُق غير الخَفَّاش. وإنَّما خصَّ الخفَّاش {46}؛ لأنه أكمل الطير خَلْقاً. وقد زدنا بيانا على هذا في سورة المائدة {47}.قال وَهْبٌ: كان يطير ما دامَ الناسُ ينظرون، فإذا غاب عن أعينهم سقط ميتا {48}.قوله تعالى: ﴿وَأُبْرِئُ الْأَكْمَهَ وَالْأَبْرَصَ﴾. قال الأصمعي {49}: بَرِئْتُ من المرض: لغةُ تميم، وبَرَأْتُ: لغةُ أهل الحِجاز {50}.وقال أبو زيد {49}: بَرَأْتُ من المرض: لغة أهل الحجاز. وسائرُ العرب: بَرِئْتُ {52}.والأكمَهُ {53}، قال ابن عباس، وقتادة {54}: هو الذي وُلِد أعمى، لم يبصر ضوءاً قط {55}.يقال: كَمِهَ الرجلُ، يَكْمَهُ، كَمَهًا {56}. والأبْرَصُ: الذي به وَضَحٌ {57}.وقوله تعالى: ﴿وَأُحْيِ الْمَوْتَى بِإِذْنِ اللَّهِ﴾ قال الكلبي {58}: كان {59} عيسى عليه السلام يحيي الأموات بـ (يا حيُّ يا قَيُّوم)، أحيا عازَرَ {60}، وكان صديقاً له، ودعا سام بن نوح من قبره، فخرج حيًّا، ومُرَّ عليه بابن عجوز على سريرٍ مَيْتًا، فدعا اللهَ عيسى، فنزل عن سريره حيَّاً، ورجع إلى أهله، وبقي ووُلدَ له {61}.وقوله تعالى: ﴿وَأُنَبِّئُكُمْ بِمَا تَأْكُلُونَ وَمَا تَدَّخِرُونَ فِي بُيُوتِكُمْ﴾. (ما) بمعنى: الذي؛ أي: بالذي تأكلونه، والذي تدَّخِرونه {62}.وجاء {63} في التفسير: بما تأكلون في غُدُوِّكم [وتدَّخرون لباقي يومكم] {64}. و (تدَّخِرون): (تفتعلون)، من (الذُّخْر) {65}.يقال: (ذَخَر، يَذْخَر، ذُخْراً)، و (اذَّخَرَ اذِّخِارا): وأصله: (اذْتَخَرَ) {66}، فأُبْدِل {67} التَّاءُ دالاً {68}؛ لأن الذَّالَ حَرْفٌ مَجْهُورٌ {69} والتَّاءَ مهموسٌ {70}، فأُبدِلَ بحرفٍ يُشْبِهُ الذَّالَ {71} في الجَهْرِ، وهو الدَّال، ثم أُدْغِمتْ الذَّالُ {72} في الدَّال فصار: (تَدَّخِرونَ) {73}، وهذا أصل الإدغامِ؛ وهو: أن يدغم {74} الأولى في الثانية، ومثل {75} هذا في التعديل بين الحروف {76}: (ازدُجِر) {77}، و (اضطُرَّ)، و (اصْطَبِر) {78}.قال الخليل {79}: الحرف {80} المجهور: الذي أُشبع {81} الاعتمادُ {82} عليه في موضعه، ومَنَعَ {83} النَّفَسَ أن يخرج معه، والمهموس: حرف أُضْعِفَ الاعتماد عليه في موضعه، وجرى معه النفس {84}."
  3,50,"قوله تعالى: ﴿وَمُصَدِّقًا لِمَا بَيْنَ يَدَيَّ﴾. [قال الفرَّاءُ {1}، والزجَّاج {2}: نصب ﴿مُصَدِّقًا﴾ على الحال، المعنى: (وجئتكم مصدِّقاً لِما بين يَدَيَّ)] {3}. وجاز إضمارُ (جئتكم)؛ لأن أول الكلام يدلُّ عليه، وهو قوله: ﴿أَنِّي قَدْ جِئْتُكُمْ بِآيَةٍ مِنْ رَبِّكُمْ﴾ [آل عمران: 49]. ومثله في الكلام: (جئتُه بما يُحِب، ومُكْرِماً لهُ) {4}.قال الفرَّاء {5}: ولا يجوز أن يكون ﴿مُصَدِّقًا﴾ عطفاً على ﴿وَجِيهًا﴾؛ لأنه لو كان كذلك، لقال: (ومُصدِّقاً لِمَا بين يَدَيْهِ) {6}، ولا يحسن أيضاً أن يتابع قوله: ﴿وَرَسُولًا﴾ {7}؛ لأنه لو كان مردودًا عليه؛ لقال: (ومُصَدِّقاً لما بين يديكِ)، لأنه خاطب بذلك مريمَ، أو قال: (بين يديهِ) {8}.ومعنى ﴿لِمَا بَيْنَ يَدَيَّ﴾: أي: للكتاب {9} الذي أُنزِلَ قَبْلِي {10}. وإذا كان يُصَدِّقُ التوراةَ، كان أحرى أن يُتَّبع.وقوله تعالى: ﴿وَلِأحِلَّ لَكُمْ﴾ قال الفرَّاء {11}: الواوُ ههنا زائدةٌ مُقْحَمةٌ، كهي في قوله: ﴿وَكَذَلِكَ نُرِي إِبْرَاهِيمَ مَلَكُوتَ السَّمَاوَاتِ وَالْأَرْضِ وَلِيَكُونَ [مِنَ الْمُوقِنِينَ]﴾ {12}، المعنى: يُرِيهِ {13} لِيَكونَ {14}.وأهل التحقيق من النحويين قالوا: الواو لا تُقْحَمُ إلا معَ (حتى إذا)، ومع (لَمَّا) {15}.قالوا: أو، والواو ههنا للعطف على معنى الكلام الأول {16}، لأن معناه: (وجئْتُكم لأُصَدِّقَ ما بين يديَّ من التوراة، ولأُحِلَّ لكم). ومثله من الكلام: (جئتُ مُعتذِرًا إليه، لأجتَلِبَ رِضاه)؛ أي: لأعتذر، ولأجتلب {17}.وقال ابن الأنباري {18}: الَّلام في قوله: ﴿وَلِأُحِلَّ لَكُمْ﴾ {19} صِلَةٌ لفعلِ مضمرٍ؛ كأنه قال: (ولأحلَّ لكم جئتكم)، وكذلك قوله: ﴿وَلِيَكُونَ مِنَ الْمُوقِنِينَ﴾، تقديره: ولِيكون من الموقنين نُرِيهِ {20} ذلكَ {21}.- قوله تعالى: ﴿بَعْضَ الَّذِي حُرِّمَ عَلَيْكُمْ﴾. قال المفسرون {22}: أُحِلَّ لهم على لسان المسيح: لحومُ الإبل، والثُّرُوبُ {23}، وأشياءُ مِنَ الطَّيْر، والحيتان، مما كان مُحرَّما في شريعة موسى عليه السلام. قال الله تعالى: ﴿فَبِظُلْمٍ مِنَ الَّذِينَ هَادُوا حَرَّمْنَا عَلَيْهِمْ طَيِّبَاتٍ أُحِلَّتْ لَهُمْ﴾ {24}. وإنَّما قال {25}: ﴿بَعْضَ الَّذِي حُرِّمَ عَلَيْكُمْ﴾؛ لأن عيسى لم يأتهم بتحليل الفواحش من: القتل، والسَّرِقِ، والزِّنا.وذهب أبو عبيدة {26} إلى أنَّ (بعضَ) ههنا بمَعنى: الكُلِّ، واحتجَّ ببيت لَبِيد:أو يعتَلِقْ {27} بعضَ النفُوسِ حِمامُها {28} وأنكر عليه الآخرون أشدَّ {29} الإنكارِ {30}.وسنستقصي الكلام في (بعض) عند قوله: ﴿وَإِنْ يَكُ صَادِقًا يُصِبْكُمْ بَعْضُ الَّذِي يَعِدُكُمْ﴾ [غافر: 28]، وأنه هل يجوز أن يكون بمعنى الكلِّ، أم لا؟. إنْ شاء الله.وقوله تعالى: ﴿وَجِئْتُكُمْ بِآيَةٍ مِنْ رَبِّكُمْ﴾ قال أبو إسحاق {31}: أي: لم أُحلَ لكم شيئًا بغير برهان، فهو حقيق {32} عليكم اتِّباعي؛ لأنَّني أتيتكم {33} ببرهان، وتحليل طيِّباتٍ كانت {34} حُرِّمَتْ عليكم.وإنَّما وحَّد {35} الآية، وكان قد أتاهم بآيات؛ لأنها كلُّها جنسٌ واحدٌ في الدلالة على رسالته."
  3,51,"وقوله تعالى: ﴿هَذَا صِرَاطٌ مُسْتَقِيمٌ﴾. أي: طريق من طرق الدين مستوي. ومضى الكلام في معنى (الصراط المستقيم) {1}."
  3,52,"قوله تعالى: ﴿فَلَمَّا أَحَسَّ عِيسَى مِنْهُمُ الْكُفْرَ﴾. معنى (الإحْساس) في اللغة: وُجودُ الشيء بالحاسة، من جهة المُلابَسة. هذا أصله ثم يختلف في الفرع، والأصل واحد {1}.قال الفرَّاء {2}: معنى ﴿أَحَسَّ عِيسَى مِنْهُمُ الْكُفْرَ﴾ {3}؛ أي: وجد.والإحساس {4}: الوجود.وقال ابن المُظَفَّر {5}: ﴿أَحَسَّ عِيسَى مِنْهُمُ الْكُفْرَ﴾: أي رأى. يقال: أحسَسْتُ من فلان أمرًا؛ أي: رأيت.وقال معْمَر {6}: أحسَّ؛ أي: عرفَ.وقال الزجَّاج {7}: أحسَّ في اللغة: عَلِمَ، ووجَدَ، ورأى {8}. يقال {9}: (هل أحسَسْتَ صاحبَكَ)؟؛ أي: هل رأيته. هذا كلام أهل اللغة.وقال ابن عباس في رواية عطاء: أحسَّ: عَلِمَ {10}.وقال مقاتل {11}: رأى، نَظِير {12} قوله {13}: ﴿هَلْ تُحِسُّ مِنْهُمْ مِنْ أَحَدٍ﴾ [مريم: 98].وقوله تعالى: ﴿مِنْهُمُ الْكُفْرَ﴾. يريد: القتل؛ وذلك أنَّهم أرادوا قتلَهُ حين دعاهم إلى الله {14} [تعالى] {15}، فاستنصر عليهم، وقال:﴿مَنْ أَنْصَارِي إِلَى اللَّهِ﴾. و (الأنصارُ): جمع (نَصِير)، مثل: (شَرِيف)، و (أشراف) {16}.قال الحسن {17}، ومجاهد {18}: إنَّما استنصر طلبًا للحماية من الكافرين، الذين أرادوا قتله عند إظهار الدعوة، ولم يستنصر للقتال؛ لأنه لم يُبْعث بالحرب.وقوله تعالى: ﴿إِلَى اللَّهِ﴾. أكثر أهل التفسير على أن المعنى: مع الله {19}.قال الفرَّاء {20}: وهو وجه حسن، وإنَّما يجوز أن تجعل (إلى) في موضع (مع)؛ إذا ضممت الشيءَ إلى الشيءِ {21}، مما لم يكن معه؛ كقول العرب: (الذَّوْدُ إلى الذَّودِ؛ إبِل) {22}؛ أي {23}: إذا ضممت الذَّوْدَ إلى الذَّودِ {24}، صارت إبِلًا. فإذا كان الشيءُ مع الشيءِ، لم يصلح مكان (مع) (إلى) {25}، ألا ترى أنَّك تقول: قَدِمَ فلانٌ ومعه مالٌ كثيرٌ، ولا تقول في هذا الموضع: وإليه مالٌ كثير {26}. وكذلك تقول: قَدِمَ فلانٌ إلى أهله، ولا تقول: مع أهله، ومنه قوله {27}: ﴿وَلَا تَأْكُلُوا أَمْوَالَهُمْ إِلَى أَمْوَالِكُمْ﴾ [النساء: 2] معناه: لا {28} تُضيفوا {29} أموالهم إلى أموالكم في الأكل {30}.وقال أبو إسحاق {31}: (إلى) ههنا إنما قاربت معنى (مع)، بأن صار اللفظ لو {32} عُبِّرَ عنه بـ (مع) {33} أفاد مثل هذا المعنى، لا أنَّ (إلى) في معنى (مع) {34}. لو قلت: (ذهب زيد إلى عمرو)، لم يجز أن تقول: (مع عمرو) في {35} هذا الموضع؛ لأن (إلى) غاية، و (مع) تضمُّ الشيءَ إلى الشيءِ، والمعنى في الآية: من يضيف نُصْرَته إيَّايَ إلى نُصْرةِ الله. والحروف {36}، إنما يقع بعضها مكان بعض؛ لنوع تقارب في المعنى؛ لا أنَّ {37} أحدهما يقوم مقام الآخر، كقوله: ﴿وَلَأُصَلِّبَنَّكُمْ فِي جُذُوعِ النَّخْلِ﴾ [طه: 71]؛ أي: على. وأصل (في): إنما هو للوعاء {38}، وأصل (على): لما علا [على] {39} الشيء، تقول: (التمرُ في الجِراب)؛ المعنى فيه: أنَّ الجِراب مشتمل عليه، ولو {40} قلت: (التمرُ على الجِرابِ)، لم يصلح {41} في هذا المعنى.وجاز ﴿وَلَأُصَلِّبَنَّكُمْ فِي جُذُوعِ النَّخْلِ﴾، بمعنى: على، لأن الجِذْع مشتمل على المصلوب، ولو قلت: (زيدٌ في الجبل)، و (على الجبل). [يصلح] {42}؛ لأن {43} الجبل قد اشتمل على زيد، فعلى هذا مَجاز هذه الحروف {44}.وقوله تعالى: ﴿قَالَ الْحَوَارِيُّونَ نَحْنُ أَنْصَارُ اللَّهِ﴾ اختلفوا في (الحواريِّين): فقال ابن عباس في رواية سعيد بن جبير {45}: كانوا صيَّادين، سُمُّوا حواريين؛ لبياض ثيابهم.قال السُدِّي {46}: وذلك أنَّ عيسى [عليه السلام] {15} مرَّ بهم وهم يصطادون السمكَ، فقال: ما تصنعون؟ فقالوا {48}: نصطاد السمك. قال: أفلا تمشون حتى نصطاد الناس؟ قالوا: وكيف ذاك؟ قال: من أنصاري إلى الله؟ قالوا: ومن أنت؟ قال: أنا عيسى بن مريم، عبد الله ورسوله، فآمنوا به، وانطلقوا، فهم الحواريُّون.قال ابن الأنباري {49}: وهذا قول بعض اللُّغَويِّين {50}، يقول: الحواريُّون: النِظَافُ الثِّياب؛ من قول العرب: (قد حُرْت الثوبَ): إذا غسلته، ونَظَّفته، قال: وإنما يراد بنظافة الثياب: نظافةُ الأديان والأعمال. يقال: (فلانٌ نظيف الثياب): إذا كان صالحًا، و (دَنِسُ الثياب): إذا كان غادرًا و {51} فاجرًا. قال امرؤ القيس:ثِيابُ بني عَوْفٍ طَهارى نقِيَّةٌ {52} أراد بـ (الثياب): الأفعال.وقال [ابن عباس] {15} في رواية عَطَاء {54}: كانوا قَصَّارين {55}، وكانوا يُحَوِّرُون الثياب؛ أي: يُبَيِّضونَها {56}.وهو قول مصعب {57}، قال {58}: كانوا مع عيسى، اتَّبعوه وصدَّقوه {59}، وكانوا إذا احتاجوا إلى الطعام أو {60} الشراب، دعا الله تعالى، فيخرج {61} من الأرض ما يأكلون، وما يشربون، أينما كانوا. فقالوا له {62}: من {63} أفضل منَّا؟ إذا شئنا أطعمتنا، وإذا شئنا سقيتنا، وقد آمنَّا بك!؟ فقال: أفضل {64} منكم من يعمل بيده، ويأكل من [كسبه] {65}. قال: فصاروا يغسلون الثياب بالكراء، ثمَّ صار هذا الاسم مُستعمَلا فيمن أشبههم {66} من المُصدِّقين بأنبيائهم {67}؛ تشبيهًا بهم.وروى جُوَيْبِر {68} عن الضحَّاك، قال {69}: مرَّ عيسى عليه السلام بغسَّالين، يغسلون الثياب، فدعاهم إلى عبادة الله عز وجل، فآمنوا، فسمَّاهم الله: حواريين. قال: وهي {70} بلغة النَّبَط {71}: هواري {72}.قال أبو بكر {73}: فمن أخذ بهذا القول، قال: هذا حرفٌ اشتركت فيه لغة العرب ولغة {74} النَّبَطٍ. وهذا قول مقاتل بن سليمان: إنَّ الحواريِّين القصَّارون {75}. قال أبو بكر {76}: ويقال {77}: الحوارُّيون: المجاهدون، وسُمِّيَ أصحابُ عيسىحواريين؛ لمجاهدتهم معه، وصبرهم على منازعة أهل الكفر، وأنشد:ونحن أناسٌ يملأُ البَيْضَ هامُنا ... ونحنُ حَواريُّون حينَ نُزاحِفُ.جماجمُنا يومَ اللقاءِ تِراسُنا ... إلى الموت نمشي {78} ليس فيها تَجانُفُ {79} والمختار من هذه الأقوال عند أهل اللغة: أنَّ هذا الاسم لزمهم للبياض. قال {80} أبو عبيد {81}: سُمَّي أصحاب عيسى الحواريين، للبياض، وكانوا قصَّارين.قال الفرزدق {82}:فقلت إنَّ الحوارِيَّات مَعْطَبَةٌ ... إذا تَفَتَّلْنَ {83} من تَحْتِ الجَلابِيبِ {84}يعني: النساء {85}.ورُوي عن النبي ﷺ أنه قال: ""الزُّبَير {86} ابنُ {87} عمَّتي، وحَواريَّ من أمَّتي"" {88}.قال أبو عبيد {89}: أصل هذا إنما كان {90} بُدُوَّهُ {91} الحواريُّون {92}، أصحاب عيسى؛ سُمُّوا بذلك لأنهم كانوا يحوِّرون الثياب، وهو {93}: التبييض، فلما كانوا هؤلاء أنصار عيسى دون الناس، قيل لكلِّ ناصرٍ نَبِيَّهُ: (حواريٌ)، تشبيها بأولئك.وروى {94} ثَعْلَب عن ابن الأعرابي: الحوارُّيون: الأنصار، وهم خاصَّة الصحابة {95}، وهذا معنى قول قتادة {96}، والكلبي {97}، وأبي رَوْق {98}، قالوا: الحواريُّون: خَواصُّ عيسى، وأصفياؤه {99}. واختاره الفرَّاء {100}.وروى شَمِر عن ابن الأعرابي، أنه قال {101}: الحواري: الناصح، وأصله: الشيء الخالص. وكلُّ شيءٍ خَلَصَ لونُهُ، فهو: حَواري. والحواريَّات من النساء: النَّقِيَّاتُ الألوان والجلود.قال أبو عبيدة {102}: يقال لنساء الأمصار: حواريات؛ لأنهنَّ تباعدن عن قَشَفِ الأعرابيات، وأنشد:فَقُلْ للحواريَّات يَبكِينَ غيرَنا ... ولا يبْكِينا إلاَّ الكلابُ النَّوابِحُ {103}واختار الزجَّاج هذا القول، وقال {104}: الحُذَّاقُ باللغة يقولون: الحواريون: صفوة الأنبياء، الذين خَلَصوا {105}، وأخْلصوا في التصديق بهم، ونُصرتهم {106}.وقوله تعالى: ﴿نَحْنُ أَنصَارُ الله﴾. أي: أنصار دين الله، آمنَّا بالله، واشهد يا عيسى بأنَّا مسلمون."
  3,53,"وقوله تعالى: ﴿فَاكْتُبْنَا مَعَ الشَّاهِدِينَ﴾ قال عطاء، عن ابن عبَّاس {1}: يريد: مِن النبيِّين {2}؛ لأن كل نبي شاهدُ أمتِّهِ.قال: فنبَّأهم الله -تعالى- أجمعين، إجابة {3} لهم، فأحيوا الموتى، وصنعوا كل ما صنع عيسى {4}.وقال أكثر أهل التفسير {5}: (اكتبنا [مع الشاهدين] {6}): مع الذين شهدوا للأنبياء بالصدق. ومعنى (اكتبنا معهم): أَثبِت أسماءَنا مع أسمائهم؛ لنفوز بمثل {7} ما فازوا، وننال مِن الكرامة مثل ما نالوا."
  3,54,"[و] {1} - قوله تعالى: ﴿وَمَكَرُواْ﴾. أصل (المَكْر) في اللغة: السعي في الفساد {2} في خفية، ومُداجاة {3}.قال الزجاج {4}: يقال: (مَكَرَ الليلُ، وأمْكَر): إذا أظلم {5}.قال ابن عباس {6}: يريد: أنَّ عامَّة بني إسرائيل كفروا به، وهَمَّوا بقتله، وتواطئُوا على الفتك به، فذلك مكرهم به.وقوله تعالى: ﴿وَمَكَرَ اللَّهُ﴾. قال أهل المعاني {7}: المَكْرُ مِنَ {8} المخلوقين: خِبٌّ {9} وخِداعٌ، وهو مِنَ الله: استدراجه العِبادَ. قال الله تعالى: ﴿سَنَسْتَدْرِجُهُمْ مِنْ حَيْثُ لَا يَعْلَمُونَ﴾ {10}.قال ابن عباس في تفسيره {11}: كلَّما أحدثوا خطيئةً، جدَّدْنا {12} لهم نعمةً. وليس المراد بـ (مَكْرِ اللهِ) في هذه الآية، هذا الوجه. ووجه (مكرِ اللهِ) بهم في هذه القصَّة، ما قال الزجاج، وهو أنه قال {13}: المكر من الله عز وجل: المجازاة على ذلك، فسُمِّي باسمه، كقوله: ﴿اللَّهُ يَسْتَهْزِئُ بِهِمْ﴾، وقد مرَّ {14} قال المفسرون: ومكْرُ اللهِ بهم في هذه القصَّه: إلقاءُ شَبَهِ عيسى على {15} من دَلَّ عليه، حتى صُلِب بَدَلَه. قال ابن عباس: وذلك أن أحد الإنجيلية {16} ممن آمن به، نافَقَ، فدلَّ {17} عليه، فجعله {18} الله تعالى في سورة عيسى، فأُخِذ فَصلِبَ {19}.وقوله تعالى: ﴿وَاللَّهُ خَيْرُ الْمَاكِرِينَ﴾. أي: أفضل المُجازين بالسيِّئَة العقوبة."
  3,55,"قوله تعالى: ﴿إِذْ قَالَ اللَّهُ يَا عِيسَى﴾. الآية. العامل في (إذ): قوله: ﴿وَمَكَرَ اللَّهُ﴾ {1}.واختلف أهل التأويل في هذه الآية على طريقين: أحدهما: إجراء الآية {2} على سياقها من غير تقديم ولا تأخير. وهو قول الحسن {3}، والكلبي {4}، وابن جُريج {5}، وابن زيد {6}، ومَطَر {7}، قالوا: معنى ﴿مُتَوَفِّيكَ﴾: قابضك من غير موت. و (التَّوَفِّي): أخذُ الشيء وافيًا {8}. وقد ذكرنا هذا فيما تقدم {9}.يدل على هذا القول: قوله: ﴿فَلَمَّا تَوَفَّيْتَنِي﴾ [المائدة: 117]، أي: قبضتني إلى السماء {10}.فعلى هذا، معنى قوله: ﴿مُتَوَفِّيكَ﴾: قابضك وافيا، لم ينالوا منك شيئًا {11}.وقال {12} الربيع {13}: معناه: متوفيك وفاة نومٍ {14}، للرفع {15} إلى السماء، يدلُّ عليه: قوله: ﴿وَهُوَ الَّذِي يَتَوَفَّاكُمْ بِاللَّيْلِ﴾ [الأنعام: 60]. قال ابن عباس في رواية الوالبي {16}: معناه: إنِّي مميتك. ووجه هذا القول؛ ما قال وهبٌ {17}: توفَّى اللهُ عيسى ثلاثَ ساعات من النهار، ثمَّ أحياه، ورفعه إليه {18}.وقال الواسطي {19}: معناه: إنِّي متوفيك عن شهواتك و [عن] {20} حظوظ نفسك؛ وذلك {21} أن عيسى لمَّا رُفع إلى السماء، صارت حالُهُ {22} كحالِ الملائكةِ {23} والطريق {24} الآخر في هذه الآية: أنها على التقديم والتأخير.قال ابن عباس في رواية عطاء {25}: هذا مقدَّمٌ ومؤخَّرٌ، يريد: إني رافعك إليَّ، ومتوفيك بعد أن أُهبِطك إلى الأرض حتى تكون فيها، وتتزوج، وُيولَد لك، وتكون في أمَّة محمد، ومعهم حتى تموت. {26} وفي حديث أبي هريرة: أنه يُدفن في حجرة النبي ﷺ، فيقوم أبو بكر وعمر يوم القيامة بين رسولين: محمد وعيسى عليهما السلام {27}.قال الفرَّاء {28}: يقال: إنَّ هذا مقَدَّمٌ ومؤَخرٌ؛ المعنى {29}: إني رافعك إليَّ، ومُطَهِّرُكَ من الذين كفروا، ومتوفيك بعد إنزالي إيَّاك إلى {30} الدنيا.ومثله من المقدَّم والمؤخر، قوله: ﴿أَنْزَلَ عَلَى عَبْدِهِ الْكِتَابَ﴾ [الكهف: 1] {31} [الآية] {32}، وقوله: ﴿وَلَوْلَا كَلِمَةٌ سَبَقَتْ مِنْ رَبِّكَ لَكَانَ لِزَامًا وَأَجَلٌ مُسَمًّى﴾ {33}.وقوله تعالى: ﴿وَرَافِعُكَ إِلَيَّ﴾ [أي] {34}: و {35} إلى سمائي ومحل كرامتي. فجعل ذلك رَفْعًا إليه؛ للتفخيم {36} والتعظيم، ومثله، قوله: ﴿إِنِّي ذَاهِبٌ إِلَى رَبِّي﴾ [الصافات: 99]، وإنما ذهب إبراهيم عليه السلام من العراق إلى الشام، والتقدير: إلى أمر ربي، لأنه أمره بذلك المكان.وقوله تعالى: ﴿وَمُطَهِّرُكَ مِنَ الَّذِينَ كَفَرُوا﴾. أي: مُخرِجُك مِن بينهم؛ لأن كونه في جملتهم، بمنزلة التنجيس له بهم.وقوله تعالى: ﴿وَجَاعِلُ الَّذِينَ اتَّبَعُوكَ فَوْقَ الَّذِينَ كَفَرُوا إِلَى يَوْمِ الْقِيَامَةِ﴾.قال ابن عباس في رواية عطاء {37}: يعني بـ (الذين اتَّبعوه): الحواريّين ومن كان على دينهم.وقال قتادة {38}، والربيع {39}، والكلبي {40}، ومقاتل {41}: هم أهل الإسلام من أمَّة محمد ﷺ، اتَّبعوا دين المسيح، وصدَّقوه بأنَّه {42} رسول الله وكلمته ألقاها إلى مريم، وروح منه. فوالله ما {43} اتَّبعه من دعاه {44} ربًّا.وقوله تعالى: ﴿فَوْقَ الَّذِينَ كَفَرُوا﴾. يحتمل أن يكونوا فوقهم بالبرهان والحُجَّة، ويحتمل بالعِزِّ والغَلَبَةِ.وقال ابن زيد {45}: وجاعل النصارى فوق اليهود، فاليهود: مُسْتذلُّون مقهورون، والنصارى وأهل الروم: لهم الملك والبسطة.و (الاتِّباعُ) على هذا القول، بمعنى: الادِّعاءُ والمحبَّة، لا بمعنى: اتِّباع الدين والمِلِّة {46}. والاختيار: ما سبق من القولين.وقوله تعالى: ﴿ثُمَّ إِلَيَّ مَرْجِعُكُمْ﴾. عَدَل عن الغَيْبَة إلى الخطاب؛ لتَغليب الحاضر على الغائب، لمَّا دخل معه في المعنى، وهو محمد ﷺ. ووجه اتصال هذا الكلام بما قبله من المعنى: كأنَّه قيل: أمَّا الدنيا: فالحال فيها ما ذكرنا، وأما الآخرة: فيقع فيها الحكم في {47} اختلافكم في الدين وأمر عيسى."
  3,56,"قوله تعالى: ﴿فَأَمَّا الَّذِينَ كَفَرُوا فَأُعَذِّبُهُمْ﴾ الآية. العذاب {1} في الدنيا: القتل الذي نالهم {2}، وينالهم {3}، وسَبْي الذراري، وأخذ الجزية. ﴿وَمَا لَهُمْ مِنْ نَاصِرِينَ﴾. أي: مالهم مَن يمنعهم مِن عذاب الله."
  3,57,"قوله تعالى: ﴿فَيُوَفِّيهِمْ أُجُورَهُمْ﴾ التَوْفِيَةُ: التكميلُ {1} في الأداء.وقوله: ﴿وَاللَّهُ لَا يُحِبُّ الظَّالِمِينَ﴾. أي {2}: يعذِّبهم، ولا يرحمهم، ولا يُثْنِي عليهم {3}."
  3,58,"قوله تعالى: ﴿ذَلِكَ نَتْلُوهُ عَلَيْكَ﴾ ﴿ذَلِكَ﴾: إشارة إلى ما تقدَّم من النبأ عن {1} عيسى ومريم والحواريِّين.وقوله تعالى: ﴿نَتْلُوهُ عَلَيْكَ﴾. قال ابن عباس {2}: يريد: نخبرك به. جَعَلَ إخبارَه به {3}، وإظهارَهُ له {4}: تِلاوَةً، لأن التلاوة: إظهار وإخبار {5}.ويجوز أيضًا أن تكون {6} التلاوة {7} لجبريل عليه السلام، والله تعالى يضيفها إلى نفسه {8}؛ لأن تلاوة جبريل بأمر الله [تعالى] {9}.ومثله: ﴿نَحْنُ {10} نَقُصُّ عَلَيْكَ﴾ {11}، وأمثاله كثيرة. ومعنى ﴿مِنَ الْآيَاتِ﴾: أي {12}: من العلامات الدالة على تثبيت رسالتك {13}؛ لأنها أخبار لا يعلمها إلا قارئ كتاب أو من يوحى إليه، وقد علموا أنك أمِّيٌّ لا تقرأ.وقوله تعالى: ﴿وَالذِّكْرِ الْحَكِيمِ﴾. يعني: القرآن. ولـ ﴿الْحَكِيمِ﴾ {14} ههنا معنيان:أحدهما: أنه بمعنى: الحاكم، مثل: القدير، والعليم، ومعناه: ذو الحِكْمَةِ {15} في تأليفه ونظمه، وإبانة {16} الفوائد فيه. [والحِكْمَة: أصله في اللغة: المنع عن الفساد. والقرآنُ حاكمٌ، على معنى: أنه بما فيه] {17} من العِبَرِ والدِّلالات، مانع عن الكفر والفساد. وهذا كما وُصِفت الدِّلالةُ بأنَّها الدليلُ؛ لأنها بمنزلة الناطق بما فيها من البيان. وهذا الوجه، اختيار الزجَّاج {18}.الثاني: أنَّه بمعنى: المُحكَم، (فَعِيل) بمعنى: (مُفعَل).قال الأزهري {19}: وهو سائغ {20} في اللغة؛ لأن (حَكَمتُ) يجري مجرى (أَحْكَمت) في المعنى، فَرُدَّ إلى الأصل.ومعنى (المُحْكَم) في القرآن: أنه أُحكِم بالأمر والنهي، وبيان الحلال والحرام. قال الله تعالى: ﴿كِتَابٌ أُحْكِمَتْ آيَاتُهُ﴾ [هود: 1]. وهذا قول مقاتل {21}. قال: الحكيم: هو المُحكَمُ من الباطل. قال الليثُ {22}: وسمَّى الأعشى القصيدَةَ المحكَمةَ: (حكيمةً)؛ فقال {23}:وغَرِيبَةٍ تأتي المُلوكَ حكيمةٍ ... قد قُلتُها ليُقالَ مَنْ ذا قالَها {24}."
  3,59,"و {1} قوله تعالى: ﴿إِنَّ مَثَلَ عِيسَى عِنْدَ اللَّهِ كَمَثَلِ آدَمَ﴾ {2} الآية.نزلت في وَفْدِ نجران، حين قالوا للنبي ﷺ: (وهل رأيت ولدًا من غير ذكرٍ؟)؛ فأنزل الله تعالى هذه الآية {3}. وقد ذكرنا معنى (المَثَل) فيما تقدم {4}، وأن المراد به بيان أنَّ سبيلَ الثاني سبيلُ الأول.فالله تعالى قد ذكر في القرآن قصَّهَ آدَمَ، وإنشاءه إيَّاه من غير والدٍ، ثم دلَّ في هذه الآية على أنَّ سبيلَ الثاني {5} وهو عيسى، في إنشائِه، وخَلْقِهِ من غير ذَكَرٍ سبيلُ الأول، وهو آدَم.وفي هذه الآية حجةٌ على من أنكر القياس؛ لأن الله تعالى احتجَّ فيها على المشركين، ولا يجوز أن يدلَّهم إلاَّ بما فيه دليلٌ. فقياس {6} خَلْقِ عيسى من غير ذَكَرٍ، كقياسِ خَلْقِ آدم، بل الشأن فيه أعجب؛ لأنه خُلِقَ من غير ذَكَرٍ ولا أنثى.وقوله تعالى: ﴿عِنْدَ اللَّهِ﴾. أي: في الخَلْق والإنشاء. خَلَقَ عيسى من غير أب، كما خَلَقَ آدمَ من غير أبٍ ولا أُمٍ. وتمَّ الكلام عند قوله: ﴿كَمَثَلِ آدَمَ﴾ {7}، وهو جملةُ تامَّةٌ، وتشبيهٌ كاملٌ. ولو اقتصر عليه حصل المراد. قال: ﴿خَلَقَهُ مِنْ تُرَابٍ﴾ وهذا ليس بِصِلَه لـ ﴿آدَمَ﴾، ولا صِفَةٍ، لأن الصلة للمبهمات {8}، والصفة للنكرات {9}، ولكنَّهُ خبرٌ مستأنَفٌ على جهة التفسير لحال آدم {10}.قال الزجَّاج {11}: وهذا كما تقول في الكلام: (مَثَلُك، مَثلُ زيدٍ). تريد: أنك تشبهه في فِعْلٍ، ثم تخبر بقصَّة زيد، فتقول: كذا وكذا.وقوله تعالى: ﴿ثُمَّ قَالَ لَهُ كُنْ فَيَكُونُ﴾. اختلفوا في المَقُولِ له ﴿كُنْ﴾: فالأكثرون {12}: على أنه (آدَمُ)، وعلى هذا يقع الإشكال في لفظ الآية؛ لأنه إنما يقول له: (كُنْ) قبل أن يخلقه لا بعده، وههنا يقول: ﴿خَلَقَهُ﴾ ، ﴿ثُمَّ قَالَ لَهُ كُنْ﴾. والجواب:إنَّ الله تعالى أخبرنا أوَّلًا أنه خلق آدم من غير ذَكَر ولا أنثى، ثم ابتدأ خبرًا آخَرَ، أراد أَنْ يُخبرنا به، فقال: ثم {13} إني أخبركم أيضًا بعد خبري الأول: أني قلت له ﴿كُنْ﴾، فكان، [فجاء] {14} [(ثم)] {15} لمعنى {16} الخبر الذي تقدم، والخبر الذي تأخر في الذِّكْر، لا أن {17} الخَلْقَ تقدم على قوله: ﴿كُنْ﴾، وهذا كما تقول للرجل: أخبرك أني أعطيتك اليوم ألفا، ثم إني أخبرك [أني] {18} قد أعطيتك {19} أمس قبلَ هذا ألفا، فـ (أمس) متقدم {20} لـ (اليوم)، وإنما جاء (ثم)؛ لأن خبَرَ اليومِ متقدمٌ خبرَ {21} أمس، وجاء خبرُ أمس بعد مُضِيِّ {22} خبرِ اليوم، ومثله قوله: ﴿خَلَقَكُمْ مِنْ نَفْسٍ وَاحِدَةٍ ثُمَّ جَعَلَ مِنْهَا زَوْجَهَا﴾ [الزمر: 6]، وقد خُلِقت {23} بعد خلق زوجها، ولكن هذا واقع على الخبر دون الخلق؛ لأن التأويل: أخبركم أني قد خلقتكم من نفس واحدة؛ لأن حوَّاء أيضًا خُلِقت من ضلعه، ثم إني أخبركم أني {24} خلقت زوجها منها، ومثل هذا مما جاء في الشعر، قوله:قُلْ لِمَن سادَ ثمَّ سادَ أبوهُ ... ثم قد سادَ قبلَ ذلك جدُّهْ {25} ومعلوم أن الأبَ متقدم له، والجدَّ متقدم للأب، ولكنه أخبر عن سيادته أولًا، ثم عن سيادة أبيه، ثم عن سيادة جدِّه؛ فالترتيب يعود إلى الخبر، لا إلى الوجود. ويجوز أن يكون المراد: أنه خلقه قالَبًا من تراب، ثم قال له: (كن بَشَرًا)، فيصح النظم {26}. وقال بعضهم: المقول له ﴿كُنْ﴾: عيسى عليه السلام {27}، ولا إشكال على هذا.وفي قوله: ﴿ثُمَّ قَالَ لَهُ كُنْ﴾، وجهان من التأويل: أحدهما: أن هذا دلالة على أنه تعالى يخلق الشيء من غير نصب ولا تعب؛ لا أنَّه يختلقه بقوله ﴿كُنْ﴾؛ لأنه لو أراد خلق شيء وُجد ذلك الشيء، وإن لم يقل له: (كن).والثاني: أن قولَه: ﴿كُنْ﴾، علامةٌ لما يريد خلقه وإنشاءه.وقوله تعالى: ﴿فَيَكُونُ﴾. قال بعض النحويين {28}: هو بمعنى: كان. وكذا فسَّره ابن عباس، فقال {29}: ﴿ثُمَّ قَالَ لَهُ كُنْ﴾، فَكانَ، فجرى عليه {30} الروح. وقد ذكرنا أنه يجوز أن يراد بمثال المستَقبَلِ الماضي، مستقصىً عند قوله: ﴿تَتْلُواْ الشَّيَاطِينُ﴾ {31}.وقال آخرون {32}: المعنى: ﴿ثُمَّ قَالَ لَهُ كُنْ﴾، فيكون كما يأمر الله تعالى. وقوله: ﴿فَيَكوُنُ﴾، حكاية لتلك الحالة التي يكون فيها آدمُ كما شاءَ اللهُ."
  3,60,"قوله تعالى: ﴿الْحَقُّ مِنْ رَبِّكَ﴾ ارتفع ﴿الْحَقُّ﴾ عند الفراء {1} والزجاج {2} بخبر ابتداءٍ محذوف. المعنى: [(الذي أنبأناك من قصة] {3} عيسى، الحَقُّ). أو: (ذلك النبأ في أمر عيسى، الحقُّ). فحُذِفَ؛ لتقدم ذِكْره، وأغنى حضورُ المعنى للنفس عن الإشارة إليه.وقال أبو عبيدة {4}: هو استئنافٌ بعد انقضاء الكلام، وخبره: في قولك {5}: ﴿مِنْ رَبِّكَ﴾ [و] {6} هذا كما تقول: الحقُّ من الله تعالى {7}، والباطل من الشيطان {8}.وقوله تعالى: ﴿فَلَا تَكُنْ مِنَ الْمُمْتَرِينَ﴾ الخطاب للنبي ﷺ، والمراد: نهي غيره عن الشكِّ، كما قال: ﴿يَا أَيُّهَا النَّبِيُّ إِذَا طَلَّقْتُمُ النِّسَاءَ﴾ {9} ويحتمل أن يكون المعنى: فلا تكن من الممترين أيُّها السامع للبرهان، من المكلفين كائنًا مَنْ كان.والامْتِراءُ: الشكُّ {10}. قال ابن الأنباري {11}: وهو مأخوذ من قول العرب: (مَرَيْتُ الناقةَ والشاةَ): إذا حَلَبْتهما {12}. فكأنَّ الشاكَّ يجتذب بِشَكِّه {13} سِرًّا، كاللبن {14} الذي يُجتذَب {15} عند الحلب. ويقال: (قد مارى فلانٌ فلانا): إذا جادله واستخرج غضبه {16}."
  3,61,"قوله تعالى: ﴿فَمَنْ حَاجَّكَ فِيهِ﴾ أي: في عيسى عليه السلام. وقيل {1}: الهاء تعود إلى ﴿الْحَقُّ﴾، في قوله: ﴿الْحَقُّ مِنْ رَبِّكَ﴾. ﴿مِنْ بَعْدِ مَا جَاءَكَ مِنَ الْعِلْمِ﴾. أنَّ عيسى عبد الله ورسوله. ﴿فَقُل تَعَالَواْ﴾. أصله: (تعالَيُوا)؛ لأنه (تَفاعَلُوا)؛ من: (العُلُوِّ)، فاستُثْقِلت الضمة على الياء، فسُكِّنت، ثم حُذِفَت لاجتماع الساكِنَيْن. وأصله: العُلُوُّ والارتفاع.فمعنى (تعالَ): ارتفع. إلاَّ أنه أكثر {2} في الاستعمال حتى صار لكل مجيء، وصار بمنزلة (هَلُمَّ) {3}.وقوله تعالى: ﴿نَدْعُ أَبْنَاءَنَا وَأَبْنَاءَكُمْ﴾. فقال المفسرون {4}: لمَّا احتجَّ الله تعالى على النصارى من طريق القياس بقوله: ﴿إِنَّ مَثَلَ عِيسَى﴾ [آل عمران: 59]، الآية؛ أمر {5} النبي ﷺ، أن يحتجَّ عليهم من طريق الإعجاز وهو: المباهلة.ومعنى المباهلة: الدعاء على الظالم من الفريقين {6}. فلما نزلت هذه الآية، دعا رسول ﷺ وفد نجران إلى المباهلة، وخرج رسول الله ﷺ محتضنًا الحسينَ {7}، آخذًا بيد الحَسَن {8}، وفاطمة {9} تمشي خلفه، وعَلِيٌّ خلفها، وهو يقول لهم: إذا أنا دعوت فَأَمِّنوا. فقال: أُسْقُفُّ {10} نَجْران: يا معشر النصارى: إني لأرى وجوهًا لو سألوا الله أن يزيل جبلًا عن مكانه لأزاله، فلا تبتهلوا فتهلكوا، ولا يبقى على وجه الأرض نصراني إلى يوم القيامة. ثمَّ قبلوا الجِزْيَةَ وانصرفوا. فقال رسول الله ﷺ: ""والذي نفسي بيده، إنَّ العذاب قد تدلَّى على أهل نجران، ولو تلاعنوا، لمُسِخوا قِرَدَةً وخنازيرَ، ولا ضطَرَبَ عليهم الوادي نارًا، ولاستأصل الله نجرانَ وأهلَهُ، حتى الطيرَ على الشجر، ولَمَا حالَ الحولُ على النصارى حتى هلكوا"" {11}.وقوله تعالى: ﴿وَأَنْفُسَنَا وَأَنْفُسَكُمْ﴾. قال أهل المعاني: يعني بـ (الأنفس): بني العم. والعرب لا تستنكر أن تخبر عن ابن العم بأنه نفسُ ابن عمِّهِ، وقد قال الله تعالى: ﴿وَلَا تَلْمِزُوا أَنْفُسَكُمْ﴾ {12}؛ أراد: إخوانكم من الدين {13}، فأجرى {14} الأخوَّةَ في {15} الدين، مجرى الأخوَّةِ في {15} القرابةِ {17}. وإذا {18} وقعت النفس على البعيد في النسب، كان أجدر أن تقع على القريب في النسب والدين؛ وإنَّما قلنا هذا؛ لأن المتكلم لا يقول ادعوا فلانا وفلانا ونفسي؛ لأنه يكون حاضرًا.وقوله تعالى: ﴿ثُمَّ نَبْتَهِلْ﴾ الابتهال في اللغة يكون على معنيين:أحدهما: التضرع إلى الله.والثاني: الالتعان، والدعاء بـ (البَهْلَةِ)، وهي: اللَّعْنَةُ. يقال: (عليه بَهْلَةُ اللهِ)؛ وبَهلتهُ؛ أي: لعنته {19}.قال لَبِيد:في قُرومٍ سادةٍ مِن قومِهم ... نَظَرَ الدهرُ إليهم فابْتَهَلْ {20}.أي: دعا عليهم بالهلاك، وكلا {21} المعنيين مروي عن ابن عباس.قال {22} في رواية الكلبي {23}: قوله ﴿نَبْتَهِلْ﴾ أي: نجتهد في الدعاء.وقال في رواية عطاء {24}: ندعُ {25} الله باللَّعنة على الكاذبين."
  3,62,"وقوله تعالى: ﴿إِنَّ هَذَا لَهُوَ الْقَصَصُ الْحَقُّ﴾ الآية. أي {1}: هذا الذي أوحيناه إليك من الآيات والحُجَجِ.فـ ﴿هُوَ﴾ {2} ههنا يصلح أن يكون فَصْلًا وعِمادًا {3}، ويكون ﴿الْقَصَصُ﴾ خَبَرَ ﴿إِنَّ﴾. ويصلح أن يكون ﴿هُوَ﴾ ابتداءً، وخَبرُه: ﴿الْقَصَصُ﴾. وهما جميعًا خبرُ إنَّ {4}.والقَصَصُ: مصدر قولهم: (قَصَّ فلانٌ الحديثَ، يقصُّه قَصًّا، وقَصَصًا) {5}. وأصله {6}: اتِّباعُ الأثر؛ يقال: (خرج فلانٌ قَصَصًا في أثر فلان)، و (قَصًّا) {7}؛ وذلك إذا اقتصَّ أثَره، ومنه قوله تعالى: [﴿وَقَالَتْ لِأُخْتِهِ قُصِّيهِ﴾ [القصص: 11]. وقيل للقاصِّ يقصُّ {8} لأتباعه خبرًا بعد خبر] {9}، وسَوقه الكلامَ سَوقًا.فمعنى {10} (القَصَص): الخبر الذي تَتَابَعُ {11} فيه المعاني.وقوله تعالى: ﴿وَمَا مِنْ إِلَهٍ إِلَّا اللَّهُ﴾. (مِن) {12} دخلت توكيدا {13} لنفي جميع من ادَّعى المشركون أنَّهم آلهة {14}، أي: أن عيسى ليس بإلهٍ كما زعموا، وإنَّما اقتضت (مِن) توكيد النفي؛ لأن أصلها لابتداء الغاية، فدلت {15} على استغراق النفي لابتداء الغاية إلى انتهائها {16}.وقوله تعالى: ﴿وَإِنَّ اللَّهَ لَهُوَ الْعَزِيزُ الْحَكِيمُ﴾. معناه ههنا {17}: أنه لا أحد يستحقُّ إطلاق هذه الصفة {18} له إلا هو."
  3,63,"قوله تعالى: ﴿فَإِن تَوَلَّوْاْ﴾ الآية. أي {1}: فإن أعرضوا عمَّا أتيت به من البيان، فإنَّ الله يعلم من يُفسِد {2} خلقه فيجازيه على إفساده."
  3,64,"قوله تعالى: ﴿قُلْ يَا أَهْلَ الْكِتَابِ تَعَالَوْا﴾ الآية {1}. الخطاب لنصارى نجران؛ عند الحسن {2}، والسُدِّي {3}، وابن زيد {4}، ومحمد بن جعفر بن الزبير {5}.وليهود المدينة؛ عند قتادة {6}، والربيع {7}، وابن جُرَيج {8}. وعند بعضهم {9}: الخطاب لهما جميعًا {10}.وقوله تعالى: ﴿إِلَى كَلِمَةٍ﴾. معنى {11} الكلمة: كلامٌ فيه شرح قِصَّة، وإن طال؛ ولذلك يقول {12} العرب للقصيدة: (الكلمة) {13}.وقوله تعالى: ﴿سَوَاءٍ بَيْنَنَا وَبَيْنَكُمْ﴾. [يريد بـ (السواء): العدل، وكذلك في قراءة عبد الله (إلى كلمة عدل بيننا وبينكم)] {14}.قال ابن قتيبة {15}: ﴿سَوَاءٍ بَيْنَنَا وَبَيْنَكُمْ﴾؛ أي: نَصَفٍ. يقال: (دعا إلى السواء)؛ أي: إلى النَّصَفَةِ؛ وإنَّما قيل و (النَّصَفَة): (سواءٌ)؛ لأنَّ أعدل الأمور أوساطها {16}.وقال الزجاج {17}: ﴿سَوَاءٍ﴾: نعتٌ للكلمة، يريد: ذات سواء. وذكرنا الكلام في معنى ﴿سَوَاءٌ﴾ في ابتداء سورة البقرة.والمعنى: إلى كلمة عادلة مستقيمة مستوية، إذا أتيناها نحن وأنتم كنَّا على السواء والاستقامة. ثمَّ قال: ﴿أَلَّا نَعْبُدَ إِلَّا اللَّهَ﴾. موضع {18} ﴿أَنْ﴾: خَفْضٌ على البدل من ﴿كَلِمَةٍ﴾ المعنى: تعالوا إلى أن لا نعبد إلاَّ الله. وهذا تفسير للكلمة {19}.قال الزجاج {20}: وجائز أن تكون في موضع (رفع)؛ كأن قائلًا قال: ما الكلمة؟ فأجيب، فقيل: هي: ﴿أَلَّا نَعْبُدَ إِلَّا اللَّهَ﴾ {21}.وقوله تعالى: ﴿وَلَا نُشْرِكَ بِهِ شَيْئًا﴾. أي: لا نعبد معه غيره. يقال: أشرك معه فلانًا: أي: جعله شريكه، وأشرك باللهِ غيره؛ أي: عبده معه عبادة الله؛ فمعنى الباء، معنى (مع) {22}، وفي الباء وجه آخر، ذكرنا {23} عند قوله: ﴿سَنُلْقِي فِي قُلُوبِ الَّذِينَ كَفَرُوا الرُّعْبَ بِمَا أَشْرَكُوا بِاللَّهِ﴾ [آل عمران: 151].وقوله تعالى: ﴿وَلَا يَتَّخِذَ بَعْضُنَا بَعْضًا أَرْبَابًا مِنْ دُونِ اللَّهِ﴾. قال عطاء عن ابن عباس {24}: يريد: كما اتخذت النصارى عيسى، واتخذت بنو إسرائيلَ عُزَيْرًا.قال الزَّجاج {25}: أي: نرجع إلى أنَّ {26} معبودَنا الله عز وجل، وأن عيسى بشر، كما أننا بشر، فلا نتَّخذه {27} ربًّا.وقال بعضهم {28}: معناه: لا نطيع في المعاصي أحدًا. والله تعالى أخبر عن اليهود والنصارى لمَّا {29} أطاعوا في معصيته {30} علماءَهم، فإنهم اتخذوا {31} من دونه آلهةً، فقال: ﴿اتَّخَذُوا أَحْبَارَهُمْ وَرُهْبَانَهُمْ أَرْبَابًا مِنْ دُونِ اللَّهِ﴾ {32}. وفي الخبر: (من أطاع مخلوقًا في معصية الله، فكأنما سجد سجدة لغير الله) {33}.وقوله تعالى: ﴿فَإِنْ تَوَلَّوْا﴾. أي: إنْ أعرضوا عن الإجابة {34}، فقابلوا أنتم إعراضَهم عن الحقِّ بِخِلافِهِ؛ للإنكار عليهم، وقولوا: ﴿اشْهَدُوا بِأَنَّا مُسْلِمُونَ﴾. أي: مقرون بالتوحيد مستسلمون لما أتتنا به الأنبياءُ."
  3,65,"قوله تعالى: ﴿يَا أَهْلَ الْكِتَابِ لِمَ تُحَاجُّونَ فِي إِبْرَاهِيمَ﴾. الآية {1}.قال ابن عباس {2}، والسدِّي {3}، وقتادة {4}: اجتمعت اليهود،ونصارى نجران عند رسول الله ﷺ، فتنازعوا في إبراهيم، فقالت اليهود: ما كان إلا يهوديا، وقالت النصارى: ما كان إلا نصرانيًّا، فنزلت هذه الآية.وقوله {5} تعالى: ﴿وَمَا أُنْزِلَتِ التَّوْرَاةُ وَالْإِنْجِيلُ إِلَّا مِنْ بَعْدِهِ﴾. يريد: إنَّ اليهودية حدثت بعد نزول التوراة، والنصرانية، بعد نزول الإنجيل.وإنما أنزلت التوراة والإنجليل بعد مهلك إبراهيم بزمان طويل، وليس في الكتابين اسمه بواحد من [دين] {6} اليهود والنصارى.وقوله تعالى: ﴿أَفَلَا تَعْقِلُونَ﴾. أي: فساد هذه الدعوى؛ إذ العقل يزجر عن الإقامة على دعوى بغير حُجَّة، فكيف بما ظهر فساده بالمناقضة؟."
  3,66,"وقوله تعالى: ﴿هَا أَنْتُمْ﴾. اختلفوا فيه: فقرأ ابن كثير {1} من طريق قُنْبُل {2}: ﴿هَا أَنْتُمْ﴾ {3}، بِوَزْنِ (هَعَنْتُم) {4}، أُبْدِلَ {5} من همزة الاستفهام الهاءُ؛ أراد: أأنتم {6}. والهمزة قد تُبدل هاءً {7}، كقولهم: (أرقت الماء) و (هرقته) {8}، و (إبرِيَة) و (هِبرِيَة) {9}.وهذا كإبدالهم من الباء {10}، الواوَ، في قولهم: (والله)، ومن الواوِ التَّاءَ في (تالله) {11}، فهذه حروف مفردة قد وقع الإبدال منها.ولا {12} يجوز أن يكون أراد ﴿هَا أَنْتُمْ﴾، و (ها) للتنبيه، ثم حَذَف الألفَ، فصار: (هأنتم)، كما حذف الألف من (ها) في (هَلُمَّ)؛ لأن الحروف لا يحذف منها إلَّا إذا كان فيها تضعيف، وليس ذلك في (ها)، وإنَّما حُذِف من (هَلُمَّ)؛ لأن الَّلام التي هي فاءٌ، في تقدير السكون، لأن (تَلُمَّ)؛ {13} كان في الأصل: (تلْمُمْ) {14}، و (لَمَّ) أصله {15}: (الْمُم)، فهي {16} متحركة بحركة منقولة إليها، والحرف المتحرك بالحركة المنقولة، قد تكون في نيَّة السكون؛ كقولهم: (اَلَحْمَرْ) {17}، فالَّلام {18} في تقدير {19} سكون؛ بدلالة تقدير الهمزة التي للوصل معها، فكذلك الَّلام في (هَلُمَّ)، وإذا كان في نية سكون، استقام حذف الألف من (ها) كما يُحذف لالتقاء الساكِنَيْنِ، وليس ذلك في (هأنتم) {20}؛ فإذا كان كذلك لم يستقم الحذف فيه، كما جاء في (هَلُمَّ).ومعنى الاستفهام في (أنتم) {21}: تقرير {22}.وقرأ نافع وأبو عمرو (ها انتم) {23} استفهامًا من غير همزٍ ولا مَدٍّ {24}.و (ها) {25} في هذه القراءة للتنبيه، دخلت على (أنتم)، وخُفِّفت {26} الهمزةُ في (أنتم)؛ لوقوعها بعد أَلِفٍ، كما تقول في (هَبَاءَةٍ): (هَبَايَة) {27} مليَّنة الهمزة، وفي (المسائل) {28}: (المسايل). ويجوز أيضًا على {29} هذه القراءة: أن يكون {30} الهاءُ بدلًا من همزة الاستفهام، كما ذكرنا في قراءة ابن كثير، ودخلت الأَلِفُ التي تدخل للفصل بين الهمزتين في مثل قولك: ﴿أَأَنْتُمْ﴾ {31}، و ﴿قُلْ آلذَّكَرَيْنِ﴾ {32} [الأنعام 143] في قراءة أبي عمرو {33}.فإن قيل: إن الألف إنما تدخل للفصل بين المِثْلين، واجتماع المِثْلين قد زال ههنا بإبدال الهاء من الهمزة {34}، فلا يُحتاج إلى الألف؛ ألا ترى أنَّ من قال: (هَراقَ)، قال: (أُهْرِيق)، ولم يحذف {35} الهاء مع الهمزة، كما يحذف {36} إذا قال: (أُرِيق)؛ لزوال اجتماع المثلين؟ قيل: إن البدل قد يكون في حكم المُبدَل عنه، ألا ترى أنَّك لو سميت رجلًا: بـ (هَرِق)، لم تصْرفْهُ كما لا تصرفُ مع الهمزة؛ لأن حكم الهاء حكم الهمزة، وكذلك في كثير من المواضع، البَدَلُ يكون في حكم المُبدَلِ عنه.وقرأ أهل الكوفة {37}: (ها أنتم) {38} بالمدِّ في (ها)، وتحقيق الهمزة في (أنتم)، ويكون {39} (ها) في قولهم، حرف التنبيه، ولا يكون الهاءُ بدلًا من همزة الاستفهام، كما يجوز {40} أن يكون بدلًا منها في قراءة أبي عمرو؛ ولأنهم {41} لا يرون إدخال الألف بين الهمزتين.فإن قيل: ما وجه التنبيه {42} بـ ﴿هَا أَنْتُمْ﴾ مع أنه لا يُنبَّهُ الإنسان على نفسه، وإنما يُنبَّه على ما أغفله؟. قيل: إنَّ التنبيه {43} وإن كان على ما أغفله من حاله فإنه يُنبَّه بذكر ما يعلم على ما لا يعلم، فلذلك خرج التنبيه على النفس؛ والمعنى: على حال النفس.وقوله تعالى: ﴿هَؤُلَاءِ﴾. في موضع النداء؛ يعني: يا هؤلاء {44}. وقد ذكرنا زيادة بيان عند قوله ﴿هَا أَنْتُمْ أُولَاءِ تُحِبُّونَهُمْ﴾ [آل عمران: 119].وقوله تعالى: ﴿حَاجَجْتُمْ﴾. أي: جادلتم، وخاصمتم {45}. ويُسَمَّى الجدال بِحُجَّةٍ أو شبهة: حِجاجًا؛ لأن صاحب الشبهة {46} يُوهِم أن معه حُجَّة.وقوله تعالى: ﴿فِيمَا لَكُمْ بِهِ عِلْمٌ﴾. قال السدِّي {47}: هو ما وجدوه في كتبهم، وأنزل عليهم [بيانه] {48} وقصته {49}.وقال آخرون {50}: يعني: في أمر محمد عليه السلام {51}؛ لأنهم كانوا يعلمونه بما يجدون من نعته في كتابهم، وحاجُّوا {52} فيه بالباطل.وقوله تعالى: ﴿فَلِمَ تُحَاجُّونَ فِيمَا لَيْسَ لَكُمْ بِهِ عِلْمٌ﴾. أي: لِمَ تجادلون في شأن إبراهيم، وليس في كتابكم أنَّه كان يهوديًّا أو نصرانيًّا، والله يعلم شأن إبراهيم، وأنه لم يكن يهوديًّا ولا نصرانيًّا، وأنتم لا تعلمون. فينبغي أن [تلتمسوا] {53} حقَّهُ من باطله؛ إذ لا تعلمون أنه كان يهوديًّا ونصرانيًّا. ثم بيَّن حال إبراهيم، فقال:"
  3,67,"﴿مَا كَانَ إِبْرَاهِيمُ يَهُودِيًّا وَلَا نَصْرَانِيًّا﴾ الآية. نزَّهه وبرأه من الدِّينَينِ، ووصفه بدين الإسلام.واليهودية والنصرانية صفتا ذَمِّ، ما تعبَّد {1} بهما قط؛ [لأنَّ موسى لم يكن يهوديا {2}] {3}، وعيسى لم يكن نصرانيًا، مع قوله: ﴿إِنَّ الدِّينَ عِنْدَ اللَّهِ الْإِسْلَامُ﴾ [آل عمران: 19].فاليهودية {4} مِلَّةٌ محرَّفة عن شريعة موسى، والنصرانية مِلَّةٌ مُحرَّفةٌ عن شريعة عيسى عليهما السلام.فإن قيل: الله تعالى أخبر {5} أن {6} إبراهيم كان {7} مُسْلِمًا، فهل كان إبراهيم على جميع ما نحن عليه من شريعة الإسلام؟ قيل: إنه كان مسلما، وإن كان على بعض شريعتنا؛ لأنَّ تلاوة القرآن واجبة في صلاتنا، ولم ينزل القرآن إلاَّ على نبينا ﷺ {8}، والدليل على أنه كان مسلما بإقامة بعض الشريعة: أن أصحاب النبي ﷺ كانوا مسلمين في الابتداء قبل استكمال الشريعة {9}."
  3,68,"قوله تعالى: ﴿إِنَّ أَوْلَى النَّاسِ بِإِبْرَاهِيمَ لَلَّذِينَ اتَّبَعُوهُ﴾. أَوْلَى: أفْعَل؛ من (الوَلْي)؛ الذي هو: القُرْبُ {1}؛ أي: أقرب الناس إلى إبراهيم، وأحقهم به: الذين {2} اتَّبعوه على دينه ومِلَّتِه. ﴿وَهَذَا النَّبِيُّ﴾. يعني: محمدًا ﷺ. ﴿وَالَّذِينَءَامَنُوا﴾ يعني: بمحمد {3} ﷺ. من المهاجرين والأنصار والتابعين.قال الزجاج {4}: أي: فهم الذين ينبغي أن يقولوا: إنَّا على دين إبراهيم.وفي هذا بيان أنَّ {5} الأَوْلَى بالإنسان: المُوافق له في دينه، دون ولده، ومن يرجع إليه في نسبه، ممن يخالفه في مذهبه، ولا يُعتَدُّ {6} بالولادة أو نحوها من القرابة في عقد الولاية.وقوله تعالى: ﴿وَاللَّهُ وَلِيُّ الْمُؤْمِنِينَ﴾. ذكرنا ما فيه عند قوله: ﴿اللَّهُ وَلِيُّ الَّذِينَ آمَنُوا﴾ {7} الآية {8}."
  3,69,"قوله تعالى: ﴿وَدَّتْ طَائِفَةٌ مِنْ أَهْلِ الْكِتَابِ﴾. أي: تَمَنَّت {1}. وذكرنا الكلام فيه عند قوله: ﴿يَوَدُّ أَحَدُهُم﴾ {2} الآية {3}.﴿طَائِفَةٌ﴾؛ الطائفةُ، معناها في اللغة: القطعة من كل شيء. يقال: (طائفةٌ من الناس)، (وطائفة من الليل) {4}.قال بعض أهل اللغة: الطائفة: الفِرْقَة؛ سُمِّيَت بها لتصرفها في الإقبال والإدبار؛ كأنها تطوف {5}؛ كقولهم: (الإنسان {6}، دَيُّور وديَّار)؛ لكثرة دورانه {7}.وقوله تعالى: ﴿لَوْ يُضِلُّونَكُمْ﴾. ولم يقل: أنْ يُضِلُّونكم، لأن (لو) {8} أوفق مع التمني {9}، فإنَّ {10} قولك: (لو كان كذا)، تَمَنٍّ [منك] {11} تمنيته {12} لِكَوْنِه {13}. ومثله: قوله: ﴿يَوَدُّ أَحَدُهُمْ لَوْ يُعَمَّرُ﴾ [البقرة: 96]، وقد مرَّ.والإضلال {14} في كلام العرب ضد الهداية والإرشاد. يقال: (أضللتُ فلانا): إذا وجَّهته للضلال عن الطريق فلم ترشده.نزلت هذه الآية في نَفَرٍ من اليهود. قال ابن عباس {15}: هم قُرَيظَة والنَّضير وبنو قَيْنُقاع؛ أرادوا أن يَسْتَنزِلوا {16} المسلمين عن دينهم ويردوهم إلى الكفر {17}.وقوله تعالى: ﴿وَمَا يُضِلُّونَ إِلَّا أَنْفُسَهُمْ﴾ {18} لأن المؤمنين لا يقبلون فولهم، وما يدعونهم إليه فيحصل عليهم الإثم بتمنيهم إضلال المؤمنين.وقوله تعالى: ﴿وَمَا يَشْعُرُونَ﴾ أي: وما يعلمون أن هذا يضرهم، وما يضر المؤمنين."
  3,70,"قوله تعالى: ﴿يَا أَهْلَ الْكِتَابِ﴾ الخطاب لليهود {1}. وقوله: ﴿لِمَ﴾ أصلها: (لِمَا)؛ لأنها {2} (ما) التي للاستفهام، دخلت عليها الَّلام فحُذِفت الألِفُ استخفافًا؛ لأن حرف الجرِّ صار عِوَضًا منها، مع وقوعها طَرَفًا {3}، تدل {4} عليها الفتحةُ {5}، وعلى هذا قوله: ﴿عَمَّ يَتَسَاءَلُونَ﴾ [النبأ:1]، و {فَبِمَ تُبَشِّرُونَ} [الحجر: 54].والوقف على هذه الحروفِ يكون بالهاء {6}، نحو: (فِبْمَهْ)، و (لِمَهْ). ولا يجوز حذفُ الأَلِفِ [من (ما)، إذا كانت موصولة] {7}؛ لأن [الألِفَ في] {7} الموصولةِ [بِمَنْزِلَة حرفٍ في وسط الاسم؛ لأن الموصولة] {7} لا تتم {10} إلا بِصِلَتِها، والطَّرَف {11} أقوى على التغيير من وسط الاسم، كما قوي على التغيير بالإعراب {12} والتنوين {13}.وزعم الكسائيُّ {14}، أن أصل (كَمْ) {15} كما، وهذا غلط منه عند البصريين؛ لمخالفة {16} (كَمْ) (ما) في اللفظ، والمعنى؛ أما في اللفظ: فكان يجب أن تبقى الفتحة {17} لتدل على الألِفِ، كما باقيت في (لِمَ) ونحوه. وأما في المعنى: فإن (كم) سؤالٌ عن العدد، و (ما) سؤال عن الجنس، فليس بينهما مشابهة، ولا لكاف التشبيه في (كَمْ) معنًى.وقوله تعالى: ﴿بِآيَاتِ اللَّهِ﴾. يعني: القرآن {18}.﴿وَأَنْتُمْ تَشْهَدُونَ﴾، قال قتادة {19}، والربيع {20}، والسُّدِّي {20}: أي: تشهدون بما يدل على صحة القرآن من كتابكم؛ لأن فيه نعت محمد وذكره.وقيل {22}: ﴿وَأَنْتُمْ تَشْهَدُونَ﴾ بمثلها من آيات الأنبياء التي تقرون بها. فحذف من الكلام ما يشهدون به ويقرون؛ لأن الكلام كان توبيخًا، فَدَلَّ على: (وأنتم تشهدون بما عليكم فيه الحجة)، فحُذِف؛ للإيجاز، مع الإستغناء عنه بالتوبيخ.والحجة عليهم: إقرارهم بالبشارة لمحمد ثم الكفر به، والإقرار بمثل آياته للأنبياء، ثم كفرهم بما جاء به محمد وجحدهم؛ فكان {23} ذلك مناقَضَةً منهم."
  3,71,"قوله تعالى: ﴿يَا أَهْلَ الْكِتَابِ لِمَ تَلْبِسُونَ الْحَقَّ بِالْبَاطِلِ﴾ ذكرنا معنى (اللَّبْس) فيما تقدم {1}.و (الحَق) ههنا: التوراة التي أنزل على موسى، و (الباطِلُ): ما كتبوه بأيديهم وغيروه وحرفوه من نعت محمد ﷺ، وخبره {2}، في قول: الحسن {3}، وابن زيد {4}.وقال قتادة {5}: لِمَ تخلطون {6} الإسلام باليهودية والنصرانية؛ وذلك أنهم تداعوا إلى إظهار الإسلام في صدر النهار، والرجوع عنه في آخره؛ لتشكيك الناس فيه.وقوله تعالى: ﴿وَتَكْتُمُونَ الْحَقَّ﴾ يعني أمر محمد ﷺ. قاله [قتادة] {7}، ومقاتل {8}.وقال عطاء {9}: يريد بـ ﴿الْحَقَّ﴾: النبي ﷺ.وقوله تعالى: ﴿وَأَنْتُمْ تَعْلَمُونَ﴾ يعني: تعلمون الحق، وأنه رسول الله، وأن الإسلام دين الله. ونظير هذه الآية: قوله في البقرة: ﴿وَلَا تَلبِسُواْ اَلحَقَّ بِالبَاطِلِ﴾ {10} الآية."
  3,72,"قوله تعالى: ﴿وَقَالَتْ طَائِفَةٌ مِنْ أَهْلِ الْكِتَابِ﴾ الآية، قال الحسنُ {1}، والسدِّيُّ {2}: تواطأ اثنا عشرَ حَبْرًا من اليهود، وقال بعضهم لبعض: أظهروا الإيمان بمحمد ﷺ، في أول النهار، وارجعوا عنه في آخر النهار؛ فإنه أحرى أن ينقلب أصحابه عن دينهم ويشكوا فيه؛ إذا قلتم: نظرنا في كتبنا فوجدنا محمدًا ليس بذاك، وقال مجاهد {3}، ومقاتل {4}، والكلبي {5}: قال بعض اليهود لبعض: أظهروا الإيمان بالذي {6} [أنزل] {7} على محمد في أمر الكعبة، والصلاة إليها، أولَ النهار، ثم اكفروا به آخرَ النهار {8}، وارجعوا إلى قبلتكم؛ لعلهم يَشُكُونَ فيرجعون إلى قبلتكم؛ فأطلع اللهُ نبيَّه على سرِّ اليهود ومكرهم.وقوله تعالى: ﴿وَجْهَ النَّهَارِ﴾ قال ابن عباس {9}: أول النهار. والوَجْهُ في اللغة: مُسْتَقْبَلُ كلِّ شيء؛ لأنه أول ما يُواجَهُ منه، كما يقال لأول الثَّوْبِ: (وَجْهُ الثوب) {10}.روى {11} ثعلب عن ابن الأعرابي: (أتيته بوجهِ نَهارٍ)، و (صدر نهار)، و (شباب نهار)؛ أي: أول النهار؛ وأنشد للربيع بن زياد {12}:مَنْ كان مسرورًا بِمَقتَلِ مالِكٍ ... فَلْيَأتِ نِسْوَتَنا بِوَجْهِ نهارِ {13}.وقوله تعالى: ﴿لَعَلَّهُمْ يَرْجِعُونَ﴾ أي: عن دينهم {14}. وقال الكلبي {15}: إلى القبلة الأولى."
  3,73,"قوله تعالى: ﴿وَلَا تُؤْمِنُوا إِلَّا لِمَنْ تَبِعَ دِينَكُمْ﴾ الآية.قتادةُ {1}، والرَّبيعُ {2}، والسُّدي {3}، والحسنُ {4}، وابن زيد {5}، وأكثرهم: على أن هذا من كلام اليهود بعضهم لبعض؛ والمعنى: لا تصدِّقوا إلا لِمَن تبع دينكم اليهودية، وقام بشرائعكم.﴿أَنْ يُؤْتَى أَحَدٌ مِثْلَ مَا أُوتِيتُمْ﴾ من: العلم، والحكمة، والكتاب، والحجة، والمَنِّ والسَّلْوَى، والفضائل والكرامات. والتقدير: {6} لا تُصَدِّقوا بأن يؤتى أحدٌ مثل ما أوتيتم، إلا لِمَنْ تبع دينكم.وقوله تعالى: ﴿قُلْ إِنَّ الْهُدَى هُدَى اللَّهِ﴾ اعتراضٌ بين المفعول وفعله، وهو من كلام الله تعالى.قال ابن عباس {7}: ومعناه: إنَّ الدينَ دينُ اللهِ. ومثله في سورة البقرة: ﴿قُلْ إِنَّ هُدَى اللَّهِ هُوَ الْهُدَى﴾ {8} [البقرة: 120].وقوله تعالى: ﴿أَنْ يُؤْتَى أَحَدٌ﴾ التقدير: (بأن يُؤتى)؛ لأن الإيمان يتعدَّى بالجارِّ، فلمَّا حذفَ الجار من ﴿أَنْ﴾، كان موضع ﴿أَنْ﴾ على ما ذكرنا من الخلاف؛ في قول الخليل: يكون جَرًّا {9}، وفي قول سيبويه: يكون نصبًا {10}. وقد ذكرنا هذا الخلاف في مواضع.فأما الَّلام في ﴿لِمَنْ تَبِعَ دِينَكُمْ﴾، فقال أكثر النحويين {11}: إنها دخلت صِلَةً وتأكيدًا {12}؛ كهي في قوله: ﴿رَدِفَ لَكُمْ﴾ {13}؛ والمعنى: رَدِفَكم. وأنشد ابن الأنباري {14} على هذا:ما كنتُ أَخدَعُ للخليلِ بِخُلَّةٍ ... حتى يكونَ ليَ الخليلُ خَدوعا {15}قال: أراد: ما كنت أَخدَعُ الخليلَ، فزاد الَّلام.وقال الآخر:يَذمُّونَ للدنيا {16} وهم يَحْلِبونها ... أَفَاوِيقَ {17} حتى ما يَدُرُّ لها ثُعْلُ {18}أراد: يذمون [الدنيا. فأكَّدَ الكلامَ بالَّلام. وُيروى: (يَذُمُّونَ لِي الدنيا) بالياء.وقال] {19} أبو علي الفارسي {20}: (الإيمان) لا يتعدَّى إلى مفعولين، فلا يجوز أيضًا أن يَتعَلَّقَ {21} بجارَّيْنِ، وقد تعلق بالجارِّ المحذوف من قوله: ﴿أَنْ يُؤْتَى﴾ فلا يتعلق بالَّلام من {22} قوله: ﴿لَمَنْ﴾، إلا أن يُحمَل (الإيمان) على معناه، فيَتَعدَّى إلى مفعولين، ويكون المعنى: ولا تقرُّوا بأنْ يؤتَى أحدٌ مثلَ ما أوتيتم، إلا لِمَن تبع دينكم؛ كما تقول: (أقررت لِزيدٍ بألف)، فيكون اللامُ متعلقًا بالمعنى، ولا تكون زائدةً {23} على حَدِّ ﴿رَدِفَ لَكُمْ﴾ {24}، و ﴿إِنْ كُنْتُمْ لِلرُّؤْيَا تَعْبُرُونَ﴾ {25}.وقوله تعالى: ﴿أَنْ يُؤْتَى أَحَدٌ﴾ (أحَدٌ) {26} إنَّما يُستعمل {27} لتعميم النفي؛ كقولك: (ما رأيت أحدًا مِنَ الناس) {28}. وههنا دخل (أَحَدٌ) للنفي الواقع في أول الكلام، وهو قوله: ﴿وَلَا تُؤْمِنُوا﴾؛ كما دخلت {29} (مِنْ) في صِلَةِ (أنْ يُنَزَّلَ) في قوله: ﴿مَا يَوَدُّ الَّذِينَ كَفَرُوا مِنْ أَهْلِ الْكِتَابِ وَلَا الْمُشْرِكِينَ أَنْ يُنَزَّلَ عَلَيْكُمْ مِنْ خَيْرٍ﴾ [البقرة: 105]. فكما دخلت (مِنْ) في صلة (أنْ يُنَزَّلَ)؛ لأنه مفعول للنَّفي الَّلاحق لأوَّلِ الكلام {30}، كذلك دخل (أحدٌ) في [صِلَةِ (أنْ) في] {19} قوله: ﴿أَنْ يُؤْتَى أَحَدٌ﴾؛ لدخول النفي في أول الكلام. والكلام في معنى (أحد)، قد تقدم عند قوله: ﴿وَمَا يُعَلِّمَانِ مِنْ أَحَدٍ﴾ [البقرة: 102].وقوله تعالى: ﴿أَوْ يُحَاجُّوكُمْ﴾ عطف على قوله: ﴿أَنْ يُؤْتَى أَحَدٌ﴾؛ المعنى: ولا تؤمنوا بأن يحاجُّوكم عند ربكم؛ لأنكم أصح دينًا منهم، فلا يكون لهم الحجة عليكم عند الله.قوله: ﴿يُحَاجُوكُمْ﴾، الضمير {32} فيه ضمير الجماعة، وهو خبر عن ﴿أحدٌ﴾ في قوله: ﴿أَنْ يُؤْتَى أَحَدٌ﴾، وجاز ذلك؛ لأن الأسماء المنفردة قد تقع للشياع {33} في المواضع التي يراد بها الكثرة؛ كقوله: ﴿يُخرِجُكم طِفْلاً﴾ {34}، وقوله: ﴿وَاجْعَلْنَا لِلْمُتَّقِينَ إِمَامًا﴾ {35} [الفرقان: 74]، وقوله: ﴿فَمَا مِنْكُمْ مِنْ أَحَدٍ عَنْهُ حَاجِزِينَ﴾ {36}.وقد مضى مثل هذا في قوله: ﴿لَا نُفَرقُ بَينَ أَحَدٍ﴾ {37}.وقرأ ابن كثير: ﴿أَنْ يُؤْتَى﴾ {38} بالمدِّ {39}. وعلى هذه القراءة يحتاج أن يستأنف الآية في بيان المعنى والنظم. فقوله: ﴿وَلَا تُؤْمِنُوا إِلَّا لِمَنْ تَبِعَ دِينَكُمْ﴾؛ معناه على هذه القراءة: ما ذكره الزجَّاجُ، قال {40}:قالت اليهود بعضهم لبعض: لا تجعلوا تصديقكم للنبي ﷺ في شيء مما جاء به، إلا لليهود؛ أي: لا تخبروا أحدًا بصدق ما أتى به، إلا أن يكونَ منكم؛ فإنكم {41} إن قلتم ذلك للمشركين كان {42} عونًا لهم على تصديقه، ويكون معنى (الإيمان): الإقرار، كما ذكرنا، وأحد مفعوليه محذوف، والتقدير: لا تقروا إلا لليهود {43} بصدق محمد.وقوله تعالى: ﴿قُلْ إِنَّ الْهُدَى هُدَى اللَّهِ﴾ هو من كلام الله، معترض من كلام اليهود على ما ذكرنا.وقوله تعالى: ﴿أَنْ يُؤْتَى أَحَدٌ﴾ ﴿أَنْ﴾ {44} في موضع رفع بالابتداء {45}، ولا يجوز أن يُحمل على ما قبله؛ لقطع الاستفهام بينهما، وخبره محذوف؛ والمعنى: أأنْ {46} يُؤتَى أحَدٌ، يا معشر اليهود، مثل ما أوتيتم من الكتاب والعلم، تصدقون به، أو تعترفون، أو تذكرونه لغيركم، أو تشيعونه في الناس؟ أو نحو هذا مما دلَّ عليه قوله: ﴿وَلَا تُؤْمِنُوا إِلَّا لِمَنْ تَبِعَ دِينَكُمْ﴾. وهذا في قول من قال: (أزيدٌ ضربته) {47}؟ومن قال: (أزيدًا ضربته؟)، كان (أنْ) عنده في موضع نصب {48}.ومِثْلُ حَذْفِ خبر المبتدأ لدلالة ما قبل الاستفهام عليه: حَذْفُ الفعل في قوله: ﴿آلْآنَ وَقَدْ عَصَيْتَ﴾ [يونس: 91] التقدير {49}: آلآن أسلمتَ حين لا ينفعك الإيمانُ من أجل المعاينة؟. فحذف الفعل لدلالة ما قبل الاستفهام عليه. ومثل هذه الآية في المعنى: قوله: ﴿أَتُحَدِّثُونَهُمْ بِمَا فَتَحَ اللَّهُ عَلَيْكُمْ لِيُحَاجُّوكُمْ بِهِ عِنْدَ رَبِّكُمْ أَفَلَا تَعْقِلُونَ﴾ [البقرة: 76]، وبَّخ بعضهم بعضًا بالحديث بما علموه من أمر النبي ﷺ، وعرفوه من صفته.ولعل ابن كثير اعتبر هذه الآية في قراءته {50}.فإن قيل: فكيف وجْهُ دخول ﴿أحدٌ﴾ في هذه القراءة، وقد انقطع من النفي [بِلحاقِ] {51} الاستفهام {52}، وإذا انقطع، كان {53} الكلام إيجابًا وتقريرًا، فلا يجوز دخول ﴿أحدٌ﴾؟قيل: يجوز أن يكون ﴿أحدٌ﴾ في هذا الموضع (أحدًا) الذي في نحو: (أحدٌ وعشرون)، وهذا يقع في الإيجاب، ألا ترى أنه بمعنى واحد؟.وقال أبو العباس {54}: إن (أحدًا)، و (وَحَدًا)، و (واحدًا) بمعنىً.وقوله تعالى: ﴿أَوْ يُحَاجُوكُمْ﴾ (أو) في هذه القراءة {55} بمعنى: حتىَّ {56}؛ ومعنى الكلام: أأن {57} يُؤتَى أحدٌ مثل ما أوتيتم، تذكرونه لغيركم؛ حتى يحاجُّوكم عند ربكم؟.قال الفرَّاء {58}: ومثله في الكلام: قولك: (تعلَّقْ به، أو يُعْطِيَكَ حقَّكَ)؛ أي: حتى. وقال امرؤ القيس:فقلتُ له لا تَبْكِ عينُكَ إنَّما ... نُحاوِلُ {59} مُلْكًا أو تَموتَ فنُعْذَرا {60}أي: حتى تموت. ومن هذا قوله تعالى: ﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ أَوْ يَتُوبَ عَلَيْهِمْ﴾ [آل عمران: 128]، وسنذكره إن شاء الله.فهذا {61} وجهٌ، وأجود منه: أن نجعله عطفًا على الاستفهام؛ والمعنى: أنْ يؤتى أحدٌ مثلَ ما أوتيتم، أو يُحاجَّكم {62} أحدٌ عند الله، تصدِّقون به؟. وهذه الآية من مشكلات القرآن، وأصعبه تفسيرًا، ولقد تدبَّرت أقوال أهل التفسير والمعاني في هذه الآية، فلم أجدْ قولًا يطرد في الآية من أولها إلى آخرها مع بيان المعنى، وصحة النظم. وقد يسر الله تعالى بفضله ههنا سوق الآية في القراءتين على تفسيرٍ بيِّن، ونظمٍ صحيحٍ، وله المِّنة في ذلك.وقوله تعالى: ﴿قُلْ إِنَّ الْفَضْلَ بِيَدِ اللَّهِ﴾ قال ابن عباس {63}: يريد: ما تفضَّل به عليك، وعلى أمَّتك."
  3,74,"قوله تعالى: ﴿يَخْتَصُّ بِرَحْمَتِهِ﴾ قال الحسن {1}، ومجاهد {2}، والربيع {3}: بنُبُوَّتِه. وقال {4} ابن عباس: بدينه {5}.وقال ابن جريج {6}: بالقرآن والإسلام.[و] {7} قال عطاء {8}: يريد: اختصَّك وتفضل عليك وعلى أمَّتِك، بدينه ورحمته.﴿وَاللَّهُ ذُو الْفَضْلِ﴾. {9} على أوليائه وأهل طاعته.﴿الْعَظِيمِ﴾. لأنه لا شيء أعظم عند الله من الإسلام.والفَضْلُ في اللغة: الزيادة. وأكثر ما يُستعمل في زيادة الإحسان {10}.والفاضل: الزائد على غيره في خصال الخير. ثم كثر استعمال الفضل حتى صار لكل نفعٍ قَصَد به فاعلُهُ أن ينفع صاحبَهُ."
  3,75,"قوله تعالى: ﴿وَمِنْ أَهْلِ الْكِتَابِ مَنْ إِنْ تَأْمَنْهُ﴾ الآية.قال عُظْمُ {1} أهلِ التفسير: أخبر الله تعالى في هذه الآية اختلاف أحوال أهل الكتاب، في الأمانة والخيانة؛ ليكون المؤمنون على بصيرة في ترك الركون إليهم؛ لاستحلال أموالهم {2}.قال {3} مقاتل {4}: يعني بـ (الذي يُؤَدِّي): مؤمني أهل الكتاب؛ وبـ (الذي لا يُؤَدِّي): كُفَّارَهم.وقال ابن عباس في رواية الضحاك {5}: أودع رجلٌ عبدَ الله بن سَلامَ ألفًا ومائتي أوقية من ذهب، فأدَّاهُ إليه، فمدحه الله عز وجل. وأودع رجلٌ فنحاصَ {6} بن عازورا {7} دينارًا فخانه.وقوله تعالى: ﴿تَأْمَنْهُ بِقِنْطَارٍ﴾.يقال: (أمنتهُ بكذا، وعلى كذا)، كما يقال: (مررت به، وعليه) {8}. فمعنى الباءِ: إلصاقُ الأمانة {9}. ومعنى (على): استعلاء الأمانة {10}. وهما يتعاقبان {11} ههنا لتقارب المعنى.وفي قوله: ﴿يُؤَدِّهِ إِلَيْكَ﴾ وجوه من القراءة:تسكين الهاء {12}، وهو رديء عند أهل النحو، خطأ عند الزجاج {13}؛ لأن الجزم {14} ليس في الهاء وإنما هو فيما قبل الهاء، والهاء اسم {15} المَكْنِي {16}، والأسماء لا تجزم في الوصل {17}.وقال الفراء {18}: من العرب من يجزم الهاء، إذا تحرك ما قبلها، فيقول: (ضربتُهْ ضربًا شديدًا)، كما يسكنون ميم (أنتمْ) و (قمتمْ)، وأصلها الرفع، وأنشد:لمَّا رَأَى أَنْ لا دَعَهْ ولا شِبَعْ {19} وقرئ باختلاس {20} حركة الهاء، اكتفاءً بالكسرة من الياء {21}، وأنشدوا على هذا:أنا ابنُ كلابٍ {22} وابنُ أوْسٍ فمَنْ يَكُنْ ... قِنَاعُهُ مَغْطِيًا فإنِّي لَمُجْتَلِي {23} وقُرئ بإشباع الكسرة في الهاء، وهو الأصل {24}.وقوله تعالى: ﴿إِلَّا مَا دُمْتَ عَلَيْهِ قَائِمًا﴾.أي: بالإلحاح {25} والخصومة والتقاضي والمطالبة. عن ابن عباس {26} وقتادة {27} ومجاهد {28}.قال ابن قتيبة {29}: أصله: أن المطالب للشيء، يقوم فيه ويتصرف، والتارك له يقعد عنه. دليله: قوله [عز وجل] {30}: ﴿أُمَّةٌ قَائِمَةٌ﴾ [آل عمران:113]؛ أي: عاملة بأمر الله، غير تاركة. ثم قيل لكل من واظب على مطالبة أمر: (قامَ به)، وإن لم يكن ثَمَّ {31} قيامٌ. ومثله قال ابن الأنباري {32} وأنشد {33} للأعشى:يقومُ {34} على الوَغْمِ في قومِهِ ... فَيَعْفُو إذا شاءَ أوْ يَنْتَقِمْ {35}أراد: يحققه ويتمسك بالمطالبة به، وليس ثَمَّ قيامٌ على الرِّجْل.وقال أبو علي الفارسي {32}: (القيام) في اللغة بمعنى: الدوام والثبات. وذكرنا ذلك في قوله: ﴿يُقِيمُونَ الصَّلَاةَ﴾ [البقرة: 3]. ومِنْ هذا قولُه: ﴿دِينًا قِيَمًا﴾ {37}؛ أي: دائمًا ثابتًا، لا يُنسَخ كما نُسِخت الشرائعُ التي قبله. فمعنى قوله: ﴿إِلَّا مَا دُمْتَ عَلَيْهِ قَائِمًا﴾؛ أي: دائمًا ثابتًا في اقتضائك له، ومطالبتك إياه.ومن المفسرين من يجعل القيام ههنا حقيقةً. قال السدِّي {38}: يعني: إلا ما دمت قائمًا على رأسهِ {39}، بالاجتماع معه، والملازمةِ له. وهو اختيار أبي رَوْق؛ قال {32}: [يعترِف بما] {41} دفعت إليه، ما دمت قائمًا على رأسه، [فإنْ أنظرته وأخَّرت] {42}، أنكر وذهب به. والقول الأول: اختيار الفراء {43} والزجاج {44}.وقوله {45} تعالى: ﴿ذَلِكَ بِأَنَّهُمْ قَالُوا لَيْسَ عَلَيْنَا فِي الْأُمِّيِّينَ سَبِيلٌ﴾ أي: ذلك الاستحلال والخيانة، بأنهم يقولون: ليس علينا فيما اؤتُمِنَّا {46} من أموال العرب سبيل؛ [لأنهم مشركون. فـ (الأميُّون) على هذا القول: العرب كلهم] {47}. وهو {48} قول قتادة {49} والسدِّي {50}.وكانت اليهود تستحل ظلم من خالفهم في دينهم، وتقول {51}: لا حرج علينا في جنس {52} أموال العرب، قد {53} أحلها الله لنا؛ لأنهم ليسوا على ديننا {54}.و {55} روي في الخبر: أنَّه {56} لَمَّا نزلت هذه الآية، قال النبي ﷺ: "" [كذَّب اللهُ أعداءَ اللهِ] {57}، ما من شيء كان في الجاهلية، إلاَّ وهو [تحت] {58} قَدَمَيَّ، إلاَّ الأمانة. فإنها مُؤَدَّاةٌ إلى البَرِّ والفاجر"" {59}.وقال ابن عباس في رواية عطاء {60}: الأمِيُّون ههنا: أصحاب النبي ﷺ، والمسلمون.وهو قول: الحسن {61} ومقاتل {62} وابن جريج {63}، قالوا: إن اليهود كانوا استدانوا من العرب وبايعوهم، ولزمتهم الأثمانُ، فلمَّا أسلم أصحابُ الحقوق، [قالت] {64} اليهودُ حين تقاضوهم {65} ليس لكم علينا شيءٌ، لأنكم تركتم دينَكم، وتحولتم، فسقطت عنَّا ديونُكم، وادَّعوا أنَّ ذلك في التوراةِ، فكذبهم الله عز وجل، فقال: ﴿وَيَقُولُونَ عَلَى اللَّهِ الْكَذِبَ وَهُمْ يَعْلَمُونَ﴾. أنهم يكذبون."
  3,76,"قوله تعالى: ﴿بَلَى مَنْ أَوْفَى بِعَهْدِهِ﴾ في ﴿بَلَى﴾ وجهان: أحدهما: أنه جواب متصل بالجَحْدِ المتقدم، وهو قوله: ﴿لَيْسَ عَلَيْنَا فِي الْأُمِّيِّينَ سَبِيلٌ﴾، فقال الله عز وجل رادًّا عليهم {1}: ﴿بَلَى﴾، [أي: بَلَى] {2} عليهم سبيل في ذلك. وهذا اختيار الزجاج؛ قال {3}: وعندي وقف التمام على ﴿بَلَى﴾. وما بعده استئناف {4}.والوجه الثاني: أن ﴿بَلَى﴾ ابتداء كلامٍ، أتى به بيانا [وتصديقًا لما بعده] {5}، وهي {6} كلمة مصححة لحب اللهِ عز وجل، من اتَّقاهُ وعبدَه وخاف عقابه. وعلى هذا الوجه لا يحسن الوقف على ﴿بَلَى﴾.وقوله تعالى: ﴿مَنْ أَوْفَى بِعَهْدِهِ﴾. مضى الكلام في معنى (الوفاء)، و (العهد) {7}.قال المفسرون: أي: بما {8} عهد {9} اللهُ إليه في التوراة، مِنَ الإيمان بمحمد، والقرآن، وأداء الأمانةِ {10}.والهاء {11} في (عهده)، تعود على اسم الله، في قوله: ﴿وَيَقُولُونَ عَلَى اللَّهِ الْكَذِبَ﴾. ويجوز أن تعود على ﴿مِّن﴾ لأن العهد مصدر يضاف إلى الفاعل وإلى المفعول {12}.وقوله تعالى: ﴿وَاَتَّقَى﴾ أي: الكفر {13}، والخيانة، ونقض العهد. ﴿فَإِنَ اَللَّهَ يُحِبُّ اَلمُتَّقِينَ﴾. يريد: مَن كانت هذه صفته."
  3,77,"قوله تعالى: ﴿إِنَّ الَّذِينَ يَشْتَرُونَ بِعَهْدِ اللَّهِ﴾ الآية. أكثر أهل التفسير على أن هذه الآية نزلت في اليهود {1}.قال عكرمة {2}: إن جماعة من علمائهم {3} كتموا ما عهد الله إليهم في التوراة من شأن محمد ﷺ، وبدَّلُوه، وكتبوا غيره بأيديهم من عندهم، فيما ادَّعوه أنه ليس عليهم في الأميين سبيل، وحلفوا أنه من عند الله؛ لئلا تفوتهم الرِّشَى {4} والمآكل.ودليل هذا: قوله في سورة البقرة: ﴿إِنَّ الَّذِينَ يَكْتُمُونَ مَا أَنْزَلَ اللَّهُ مِنَ الْكِتَابِ وَيَشْتَرُونَ بِهِ ثَمَنًا قَلِيلًا﴾ {5} الآية.وقال ابن عباس في رواية باذان {6}: نزلت في رجلين اختصما إلى النبي ﷺ في ضَيْعَةٍ، فَهَمَّ المدَّعَى عليه أن يحلف، فنزلت هذه الآية، فَنَكَلَ المدَّعَى عليه عن اليمين، وأقر للمدَّعِي بحقه، ودفعه إليه {7}.ومعنى ﴿يَشْتَرُونَ﴾: يستبدلون {8}. وذكرنا هذا في قوله: ﴿اشْتَرَوُا الضَّلَالَةَ﴾ {9}.وقوله تعالى: ﴿وَلَا يُكَلِّمُهُمُ اللَّهُ﴾. جاز {10} أن يكون {11} إسماع الله جلَّ وعز أولياءَهُ كلامَهُ بغير سفير، خصوصيةً يَخُصُّ بها أولياءَه، فهو لا [يكلم هؤلاء أصلا. ويكون المحاسبة معهم بكلام الملائكة.وجائز أن يكون معنى] {12} ﴿وَلَا يُكَلِّمُهُمُ اللَّهُ﴾ أي: لا يكلمهم بكلامٍ يَسُرُّهم. ونفى الكلامَ أصلًا لأنه يتضمن {13} معنى الغضب؛ كما يقال: (فلان لا يكلم فلانًا)، تأويله: أنه غضبان عليه، وإنْ كلمه بكلام سوء، لم ينقض ذلك.وقوله تعالى: ﴿وَلَا يَنْظُرُ إِلَيْهِمْ﴾. أراد: نظر الرحمة؛ كما يقال: (نظر فلان لفلان)، و (نظر الأمير لرعيته): إذا رحمهم، وبهذا فسره ابن عباس، فقال {14}: يريد: لا {15} يرحمهم.وروى جعفر بن سليمان الضُّبَعِي {16} عن أبي عِمْران {17} الجَوْني {18}، أنه قال {19}: ما نظر الله عز وجل إلى شيء إلاَّ رَحِمَه، ولو قضى أن ينظر إلى أهل النار لرحِمَهُم؛ ولكن قضى أن لا ينظرَ إليهم. ومضى الكلام في معنى تزكية الله."
  3,78,"قوله تعالى: ﴿وَإِنَّ مِنْهُمْ لَفَرِيقًا﴾. يعني: من اليهود {1}. وفي هذا دليل: أن الآية المتقدمة نازلةٌ {2} في اليهود، حيث عطف عليها بهذه [الآية] {3} التي هي {4} نازلة فيهم بلا خلاف.وقوله تعالى: ﴿يَلْوُونَ أَلْسِنَتَهُمْ بِالْكِتَابِ﴾. قال مجاهد {5}، وقتادة {6}، والربيع {7}، وابن جريج {8}: يحرفونه {9} بالتغيير والتبديل.وأصل (اللَّيِّ): [الفَتْلُ؛ من قولك: (لَوَيْتُ يدَهُ): إذا فتلتها {10}، و] {11} تحريف الكلام [وتقليبه] {12} عن وجهه، [و] {13} لَيُّ اللِّسانِ به؛ لأن المُحرِّفَ {14} لَوَى لسانَهُ {15} عن سَنَنِ {16} الصواب، بما يأتي به من عند نفسه {17}.ويحتمل أن يكون المعنى: يَلْوُونَ بألسنتهم الكتابَ {18}؛ لأنهم {19} يحرفون الكتاب عما هو عليه، بألسنتهم، فأتى به على القلْب. والقَلْبُ سائغٌ في كلام العرب. ولهذا نظائر وأشباه.وقوله تعالى: ﴿لِتَحْسَبُوهُ﴾. أي: لتحسبوا ما لَوَوا ألسنتَهم به، وما حرفوه من الكتاب.فرجعت {20} الكناية {21} إلى مفعول ﴿يَلْوُونَ﴾، وهو غير مذكور {22} ولكن الفعل يدل عليه {23}."
  3,79,"قوله تعالى: ﴿مَا كَانَ لِبَشَرٍ أَنْ يُؤْتِيَهُ اللَّهُ الْكِتَابَ﴾ الآية. لمَّا ادعت اليهود والنصارى أنهم على دين إبراهيم، أخبرهم النبي ﷺ أنهم ليسوا على دينه، غضبوا، وقالوا: ما يرضيك منا يا محمد إلا أن نتخذك ربًّا ونعبدَك؟. فقال رسول الله ﷺ: ""معاذ الله أن نعبد غير الله، أو نأمر بعبادة غير الله، ما بذلك بعثني ربي"". فأنزل الله عز وجل هذه الآية. هذا قول ابن عباس {1}.وقال الضحاك {2}، ومقاتل {3}: كانت النصارى تقول: إن عيسى إلهٌ معبودٌ، وزعموا أن عيسى قال لهم ذلك، فنزلت الآية فيهم.فقوله {4}: ﴿مَا كَانَ لِبَشَرٍ﴾ {5}؛ يعني: محمدًا عليه السلام على قول ابن عباس. وعلى قول مقاتل، يعني: عيسى.و (الحُكْم) {6} في اللغة وفي التفسير: العلم والفقه؛ قال الله تعالى: ﴿وَآتَيْنَاهُ الْحُكْمَ صَبِيًّا﴾ [مريم: 12]، يعني: العلم والفقه.و (الحُكْم): القضاء بالعدل {7} أيضًا؛ ومنه قول النابغة:واحْكُم كحُكْمِ فتاةِ {8} الحَيِّ. {9} .. البيت.وقوله تعالى: ﴿ثُمَّ يَقُولَ للِنَّاسِ﴾. عطف على قوله: ﴿أَنْ يُؤْتِيَهُ اللَّهُ﴾ أي: ما كان لبشرٍ أن يجمع بين هذين: بين النُّبُوَّة، وبين دعاء الخلق إلى عبادة غير الله.قال الزجاج {10}: أي: الله عز وجل لا يصطفي لنبوته الكَذَبَةَ {11}، ولو فعل ذلك بشَرٌ، لَسَلَبَهُ الله عز وجل آياتِ النُّبُوّة، و {12} علاماتها. ونصب ﴿ثُمَّ يَقُولُ﴾ على الاشتراك {13} بين أن يُؤتِيَه وبين أن يقولَ {14}؛ أي: لا يجتمع لنبي إتيانُ {15} النُّبوَّةِ والقولُ للناس: ﴿كُونُوا عِبَادًا لِي﴾.وقال صاحبُ النَّظْمِ: ﴿مَا كَانَ لِبَشَرٍ﴾: نفيٌ، والنفي واقع غير موقعه؛ لأن التأويل ما كان لبشر يُؤتِيَه الله الكتابَ والحكمَ والنبوةَ. وقوله تعالى {16}: ﴿يُؤتِيَهُ اَللَّهُ﴾ {17} صفة للنكرة {18}؛ على تأويل: (ما كان لِبَشَرٍ يكون بهذه الحال، أن يقول للناس: كونوا عبادًا لي من دون الله).فالمنفي {19}: قوله: (أن يقول الناس). فلمَّا {20} وقع ﴿أَنْ﴾ في غير موقعه، نسق {21} عليه بـ ﴿ثُمَّ﴾. ففي الآية تقديم حرف حقُّهُ أن يُؤَخَّرَ، ومثله من تقديم ما وجب أن يؤخر في النظم: قوله تعالى {16}: ﴿وَلَوْلَا رِجَالٌ مُؤْمِنُونَ وَنِسَاءٌ مُؤْمِنَاتٌ لَمْ تَعْلَمُوهُمْ أَنْ تَطَئُوهُمْ {23}﴾ [الفتح: 25]، التأويلُ: ولولا أن تطؤوا رجالًا مؤمنين ونساءً مؤمناتٍ لم تعلموهم؛ أي: لم تعرفوهم.وقوله تعالى: ﴿كُونُوا عِبَادًا لِي﴾. قال ابن عباس {24}: هذه لغة مُزَيْنَة {25}، تقول للعبيد: (عِبَاد) {26}.وقوله تعالى: ﴿وَلَكِنْ كُونُوا رَبَّانِيِّينَ﴾. أي: ولكن تقول: كُونُوا، فحذف القول؛ لدلالة الأولى عليه.و (الرَّبّانِي): العالم، في قول كلهم.أخبرني العَرُوضِيُّ، عن الأزهري، قال {27}: أخبرني المُنْذِري، عن أبي طالب {28}، قال: الرَّبّاني: العالم. والجماعة {29}: الربّانِيُّون. وقال أبو العباس {30}: الربَّانِيُّون: العلماء.وقال سيبويه: زادوا ألِفًا ونونًا في (الرَّبّاني)، إذا {31} أرادوا تخصيصًا بعلم الرَّبِّ، دون غيره من العلوم، وهذا كما قالوا: (شَعْراني)، و (لِحْيانِي)، و (رَقَباني): إذا خُصَّ بكثرة الشَّعْر، وطول اللِّحْيَة، وغِلظ الرَّقَبَة. فإذا نسبوا إلى الشَّعْر، قالوا: (شَعْرِي)، وإلى الرَّقَبَة: (رَقَبِي)، وإلى اللِّحْيَة: (لِحْيِي) {32}.وقال ابنُ الأعرابي: الرباني: العالم المُعَلِّم، الذي يَغْدُوا الناسَ {33} بصِغار العلوم قبل كبارها.وقال المبرد {34}: الربّانِيُّون: أرباب العلم، وأحدهما: رَبّاني، وهو: الذي يَرُبُّ العِلم، ويَرُبُّ الناسَ؛ أي: يعلمهم ويصلحهم، ويقوم بأمورهم {35}.والأَلِف والنُّونُ: للمبالغة؛ كما قالوا: (رَيّان) {36}، و (عطشان)، و (شبعان)، و (عُرْيان) {37}، و (نَعْسان)، و (وَسْنان) {38}، ثم ضمَّت إليه ياءُ النسبة، كما قيل: (لِحياني)، و (رَقَبانِي).فعلى قول سيبويه؛ الرَّبّاني: منسوب إلى الرَّبِّ؛ على معنى التخصيص بعلم الرَّبِّ، أي: يَعْلَم الشريعة، وصفات الرب. وعلى قول ابن الأعرابي، والمبرد؛ الرّبّانِي: من الرَّبِّ، الذي هو بمعنى: التربية، على البيان الذي ذكر.وقال أبو عبيدة {39}: لم تعرف العرب (رَبّانِيِّين) {40}. هذا قول أهل اللغة في معنى {41} هذا {42} الحرف.قال ابن عباس في رواية سعيد بن جبير {43}: ربانيين؛ أي: معلِّمِين {44}. وهو قول مُرَّة الهَمْداني {45}، واختيار عبد الله بن مُسْلِم {46}، ويقوى هذا قول ابن الأعرابي والمبرد {47}.وقوله تعالى: ﴿بِمَا كُنْتُمْ تُعَلِّمُونَ الْكِتَابَ﴾ {48}. ويُقرأ: ﴿تُعَلِّمُونَ﴾ {49}، من: العلم. والباء {50} في ﴿بِمَا﴾، متعلقة بقوله: ﴿كُونُوا﴾. و (ما) في القراءتين، هي التي بمعنى المصدر مع الفعل، والتقدير: كونوا رَبَّانِيِّين، بكونكم عالمين؛ [أو: معلِّمين] {51}.وعلى هذا التقدير أيضًا قوله تعالى {52}: ﴿وَبِمَا كُنْتُمْ تَدْرُسُونَ﴾. ومثل هذا مِنْ كَوْن {53} (ما) مع الفعل بمنزلة {54} المصدر؛ قوله [تعالى] {55}: ﴿فَالْيَوْمَ نَنْسَاهُمْ كَمَا نَسُوا لِقَاءَ يَوْمِهِمْ هَذَا وَمَا كَانُوا بِآيَاتِنَا يَجْحَدُونَ﴾ [الأعراف: 51]؛ أي: كنسيانهم لقاء يومهم، وككونهم {56} بآياتنا جاحدين.فأما قوله: ﴿تُعَلِّمُونَ الكِتَابَ﴾، من قرأه {57} بالتخفيف؛ فهو من (العِلم) الذي يراد {58} به: المعرفة، فيتعدى إلى مفعول واحد؛ كقوله: ﴿وَلَقَدْ عَلِمْتُمُ الَّذِينَ اعْتَدَوْا مِنْكُمْ فِي السَّبْتِ﴾ [البقرة: 65]، وقوله: ﴿وَاللَّهُ يَعْلَمُ الْمُفْسِدَ مِنَ الْمُصْلِحِ﴾ [البقرة: 220]، وحجته: ما رُوي عن عمرو {59} أنه احتج بقوله: ﴿تَدْرُسُونَ﴾ ولم يقل: (تُدَرِّسُون)، وأيضًا فإن التشديد يقتضي مفعولين، والمفعول ههنا واحد، فالتخفيف أولى.ومن قرأ بالتشديد: فالمفعول الثاني محذوف، تقديره: بماكنتم تُعَلِّمونَ الناسَ الكتابَ، أو غيرَكم الكتابَ. وحُذِف؛ لأن المفعول به قد يُحذَف من الكلام كثيرًا.وحجته في التشديد: أن التعليم {60} يَدُل على العِلْم؛ لأن الذي يُعَلِّم لا يكون إلا عالمًا بما يُعَلِّم، والعِلْم لا يدل على التعليم، فالتشديد أبلغ في هذا الموضع. وأيضًا فإن الرَّبّانِيّين لا يقتصرون على أن يَعْلَموا لأنفسهم حتى يتقربوا إلى الله بالتعليم، يدل عليه: قول مُرَّة بن شَراحيل {61}: كان عَلْقَمَةُ من الربّانيين الذي يُعَلِّمون الناسَ القرآن.قال الزجاج {62}: معنى قوله: ﴿كُونُوا رَبَّانِيِّينَ بِمَا كُنْتُمْ تُعَلِّمُونَ الْكِتَابَ﴾: كونوا معلِّمِي الناس بعِلْمِكم ودَرْسِكم، عَلِّموا الناسَ وبَيِّنوا لهم؛ كما تقول: انفعوهم بمالِكم. وقيل {63}: كونوا ممن يستحق أن يُطلق {64} له صفة عالم بعلمه؛ لإخلاصه وقيامه بحقه.وقوله تعالى: ﴿وَبِمَا كُنْتُمْ تَدْرُسُونَ﴾. أي: تقرأون {65}. ومنه قوله تعالى: ﴿وَدَرَسُوا مَا فِيهِ﴾ [الأعراف: 169]. وشَرْحُ معنى الدَّرسِ والدراسة، يُذكر عند قوله: ﴿وَلِيَقُولُوا دَرَسْتَ﴾ [الأنعام: 105]."
  3,80,"قوله تعالى: ﴿وَلَا يَأْمُرَكُمْ﴾. الآية. أكثر القراء على رفع ﴿ولا يأمُرُكُم﴾ {1}.قال سيبويه {2}: ﴿وَلَا يَأَمُرُكم﴾: منقطعة مما قبلها؛ لأن المعنى: ولا {3} يأمُرُكم الله.وقال ابن جريج {4}، وجماعة {5}: ولا يأمُرُكم محمدٌ. ومما يدل على الانقطاع من الأول: ما روي عن ابن مسعود، أنه قرأ: (ولن يأمُرَكم) {6}.قال الفراء {7}: فهذا دليل على انقطاعها من النَّسَقِ، وأنها مستأنفة؛ فلما وقعت (لا) موقع (لن) رفعت، كما قال: {إِنَّا أَرْسَلْنَاكَ بِالْحَقِّ بَشِيرًا وَنَذِيرًا وَلَا تُسْأَلُ عَنْ أَصْحَابِ الْجَحِيمِ} [البقرة: 119]، وفي قراءة عبد الله: (ولن تُسأَلَ) {8}.ومَن نَصَبَ ﴿وَلَا يَأْمُرَكُمْ﴾ كان {9} وجهه ما قال سيبويه: إن المعنى: وما كان لِبَشَرٍ أن يأمرَكم أن تتخذوا الملائكة. فيكون نصبًا بالنَّسَقِ على قوله: ﴿أَنْ يُؤْتِيَهُ﴾. ويقوي هذا الوجه ما ذكرنا: أن اليهود قالت للنبي ﷺ: أتريد يا محمدُ أن نتخذك ربًّا؟! فقال الله سبحانه: ما كان لِبَشَرٍ أن يأمر بذلك {10}.قال الزجاج {11}: معنى الآية {12}: ولا يأمركم أن تعبدوا الملائكة والنبيين؛ لأن الذي قالوا: إن عيسى إلهٌ، عبدوهُ واتخذوهُ ربًّا. وقال قوم من الكفار: إن الملائكة أربابُنا {13}؛ يقال {14}: إنهم الصابئون {15}.وقوله تعالى: ﴿أَيَأْمُرُكُمْ بِالْكُفْرِ﴾. استفهام معناه: الإنكار؛ أي: لا يفعل {16} ذلك، وإنما جاز أن يُنقَلَ إلى الإنكار؛ لأنه مما أقَرَّ بِهِ المخاطَبُ، [و] {17} ظهر افتضاحه، وبان سقوطه؛ لأنه مما لا يَخفى فسادُه؛ فلذلك {18} جاء الكلام على السؤال، وإنْ لم يكن معناه تَعَرُّف الجواب.وقوله تعالى: ﴿بَعْدَ إِذْ أَنْتُمْ مُسْلِمُونَ﴾. أي: بعد إسلامكم."
  3,81,"قوله تعالى: ﴿وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ النَّبِيِّينَ﴾ قال أبو إسحاق {1}: موضع (إذْ): نَصبٌ؛ المعنى: واذكر في أقاصيصك: إذ أخذ اللهُ ميثاقَ النَّبِيِّين.وقوله تعالى: ﴿لَمَا آتَيْتُكُمْ مِنْ كِتَابٍ وَحِكْمَةٍ﴾ قرأ {2} حمزة: ﴿لِمَا﴾ بكسر اللاَّم {3}. ووجهُ {4} هذه القراءة: أنَّ اللاَّم في ﴿لِمَا﴾ متعلق بالأخذ؛ كأنَّ {5} المعنى: أخذ ميثاقهم لهذا؛ لأن من يؤتَى الكتابَ والحكمة، يُؤخَذُ عليهم الميثاقُ؛ لِما أوتوهُ {6} من الحكمة، وأنهم الأفاضل، وأماثل {7} الناس. و (ما) على هذه القراءة تكون موصولةً؛ بمعنى: الذي. والراجع إلى (ما) مِن صِلَتِها محذوفٌ؛ تقديره: لِما آتيتكموه. فَحُذِفَ الراجعُ، كما حُدفَ من قوله: ﴿أَهَذَا الَّذِي بَعَثَ اللَّهُ رَسُولًا﴾ [الفرقان: 41]. ونحو ذلك.فإن قيل] {8}: إذا كانت (ما) موصولةً، لزم أن يرجع من الجملة المعطوفة {9} على الصلة، ذِكرٌ إلى الموصول، وإلاّ لم يَجُز. ألا ترى أنك لو قلت: (الذي قام أبوه {10} ثم انطلق زَيْدٌ، ذاهبٌ) {11}؛ لم يَجُز إذ لم يكن [راجعٌ مذكورٌ] {12}.وقوله تعالى: ﴿ثُمَّ جَاءَكُمْ رَسُولٌ مُصَدِّقٌ لِمَا مَعَكُمْ [لَتُؤْمِنُنَّ بِهِ] {13}﴾ ليس فيه {14} راجعٌ إلى الموصول. قيل: يجوز {15} أن يكون المُظهرُ بمنزلة المُضْمَر. فقوله: ﴿لِمَا مَعَكُمْ﴾، هو في المعنى: ما أُوتوهُ {16} مِنَ الكتاب والحكمة؛ فكأنه {17} قال: ثم جاءكم رسولٌ مُصدِّقٌ له؛ أي {18}: لِمَا آتيتكم مِنْ كتابٍ وحِكْمَةٍ، وهو ما معكم.والصلة المُظهَرَة تقوم مقام المُضمَرَة {19}، عند أبي الحسن الأخفش؛ ومثل هذا: قوله: ﴿إِنَّهُ مَنْ يَتَّقِ وَيَصْبِرْ فَإِنَّ اللَّهَ لَا يُضِيعُ أَجْرَ الْمُحْسِنِينَ﴾ [يوسف: 90]، المعنى: كأنه قال: لا يضيع أجرهم؛ لأن الذي يتقي {20} ويصبر يكون من المحسنين، وكذلك قوله: ﴿إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ إِنَّا لَا نُضِيعُ أَجْرَ مَنْ أَحْسَنَ عَمَلًا﴾ {21} [الكهف: 30]، المعنى عنده: إنا لا نضيع أجرهم؛ لأن مَنْ أحسن عملًا، هم: الذين آمنوا وعملوا الصالحات {22}.ووجه آخر، وهو: أنَّ الراجعَ ههنا محذوفٌ، وحَسُن الحذف للطول، كما حكاه الخليل {23} من قولهم: (ما أنا بالذي قائل لك شيئًا)، والتقدير: بالذي هو قائل.كذلك ههنا يكون التقدير: ثم جاءكم رسولٌ به؛ أي: بتصديقه، أي: بتصديق ما أتيتكم.وأما من قرأ ﴿لَمَا﴾ بفتح اللام {24}؛ فـ (ما) {25} في هذه القراءة، يحتمل {26} تأويلين:أحدهما: أن تكون موصولة. والآخر: أن تكون للجزاء {27}. فمن قدَّرها موصولةً: كان القول فيها كما ذكرنا في قراءة حمزة.واللاّم في (لَمَا)، لام الابتداء، وهي المتلقية {28} لِما أُجري مجْرى القَسَم، لأن قوله: ﴿وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ النَّبِيِّينَ﴾، بمنزلة القَسَم، كأنَّ المعنى: استحلفهم.وموضع (ما) رفع بالابتداء. والخَبَرُ: ﴿لَتُؤْمِنُنَّ بِهِ﴾. و ﴿لَتُؤْمِنُنَّ﴾ {29}، متعلق بِقَسَم محذوف؛ المعنى: والله لتؤمنن به. فإن قدرت (ما) للجزاء، كانت (ما) في موضع نصب بـ ﴿آتَيْتُكُمْ﴾. و ﴿جَاءَكُمْ﴾ في موضع جزمٍ بالعطف على ﴿آتَيْتُكُمْ﴾، واللاّم الداخلةُ على (ما) لا تكون المتلقية {30} للقسم، ولكن تكون بمنزلة اللّام في قوله: ﴿لَئِنْ لَمْ يَنْتَهِ الْمُنَافِقُونَ﴾ [الأحزاب: 60] [والمتلقية للقسم؛ قوله {31}: ﴿لَتُؤْمِنُنَّ بِهِ﴾، كما أنها في قوله ﴿لَئِنْ لَمْ يَنْتَهِ الْمُنَافِقُونَ﴾] {32}، قوله {33} ﴿لَنُغْرِيَنَّكَ﴾ [الأحزاب: 60].وهذه اللاّم الداخلة على (إنْ) في ﴿لَئِنْ﴾، لا يعتمد القَسَمُ عليها؛ فلذلك جاء حذفها تارةً، وإثباتها تارة؛ كما قال {34}: ﴿وَإِنْ لَمْ يَنْتَهُوا عَمَّا يَقُولُونَ﴾ [المائدة: 73]، فَتَلْحَقُ هذه اللاّم مرة [(إنْ)] {35}، ولا تَلْحَقُ أخرى، كما أنّ (أنْ) كذلك في قولهم: (واللهِ أَنْ لو فعلتَ لفعلتُ)، [و] {36} (واللهِ لو فعلتَ لفعلتُ) {37}. وهذه اللاّم بمنزلة (أَنْ) الواقعة مع (لو). وهذا مذهب سيبويه {38}، وهو يُقدِّر (ما) ههنا للجزاء {39}، وانما لم يحمله على أن (ما) موصولة، بمنزلة الذي؛ لأنه لو حمله على ذلك، للزم أن يكون في الجملة المعطوفة على الصلة، ذِكرٌ يعود على الموصول، فلما لم ير {40} ذلك، ولم ير أن يضع المُظْهَر موضع المُضْمَر كما يراه أبو الحسن عَدَلَ عن القول: بأن (ما) موصولة، إلى أنها للجزاء، ولم يحملها على الحذف من المعطوف على الصلة؛ لأنه ليس بالكثير، ولا بموضع {41} يليق به الحذف. و (ما) إذا كانت للجزاء، لا تحتاج إلى عائدِ ذِكرٍ، كما تحتاج إليه (ما) التي بمنزلة (الذي)؛ لأن (ما)، إذا كانت جزاءً، مفعولٌ بها، والمفعولُ لا يحتاج إلى عائدِ ذكرٍ. وهذا الوجه اختيار الزجاج؛ لأنه قال {42}: أجوَد الوجهين: أن يكون {43} (ما) للشرط والجزاء؛ لأن الشرط يوجب أن كل ما وقع من أمر الرسول {44} فهذه طريقته.وأبو عثمان المازني أيضًا اختار هذا الوجه، فقال {45}: الوجه عندي: أن يكون {46} (ما) للجزاء؛ لأن الفعل الماضي إنما يكون في معنى المستقبل، في الجزاء لا في غيره، والمعنى: أنه أخذ ميثاقهم على أن ينصروه ويؤمنوا بما يأتيهم فيما يستقبل من كتاب وغيره.والدليل على أن ﴿آتَيْتُكُمْ﴾، ﴿ثُمَّ جَاءَكُمْ﴾، معناه مستقبل: قوله: ﴿لَتُؤْمِنُنَّ بِهِ وَلَتَنْصُرُنَّهُ﴾، وإذا كان جزاءً كانت اللاّمُ توكيدا.وقد قال سيبويه {47}: ومثل هذه الآية؛ قوله: ﴿لَمَنْ تَبِعَكَ مِنْهُمْ لَأَمْلَأَنَّ جَهَنَّمَ﴾ [الأعراف: 18]، فهذا جزاء، والفعل {48} الماضي في معنى المستقبل، ولام القسم التي تعتمد عليها اللاّم في ﴿لَأَمْلَأَنَّ﴾ وهي وإن كانت مؤخرة فمعناها التقديم.وقوله تعالى: ﴿لَتُؤْمِنُنَّ بِهِ﴾ تقديره {49}: أول الكلام في قول من قدّر (ما) جزاء، والتمثيل: (وإذ أخذ اللهُ ميثاق النبيين لتؤمنن به)، وجواب الشرط، محذوف مستغنى عنه؛ لدلالة لتؤمنن به، الذي هو جواب القسم عليه، كما أن قولك: (لآتِيَنَّك إنْ أتيتني)، كذلك؛ والمعنى: (واللهِ، لآتِيَنَّك إنْ أتيتني). فيكفي جوابُ القسم من جواب الجزاء، وإذا كانت بمعنى الجزاء على ما {50} وصفنا فيكون تقدير المعنى: لأَنْ آتيتكم شيئًا من كتاب وحكمة، -ومهما آتيتكم- ثم جاءكم رسول، لتؤمنُنَّ به.فإن قيل: ميثاق الإيمان بمحمد ﷺ، وسائر الرسل، مأخوذ على جميع النبيين ما {51} أوتوا الكتاب، وانما أوتي {52} بعضهم؟.قيل: هذا على التغليب؛ فالذكر ذكر الأنبياء الذين أوتوا الكتاب، والمراد: هم، وغيرهم ممن لم يُؤتَ الكتاب، ودخلوا في جملتهم؛ لأنهم بمنزلة من أوتى الكتاب بما أوتوا من الحُكْم والنبوة، وأيضًا فإن الذين لم ينزل عليهم الكتاب أمروا بأن يأخذوا بكتاب نَبِيٍّ {53} قبلهم، ورُزِقوا علمَ ذلك الكتاب، فدخلوا تحت صفةِ أبناء الكتاب.وقرأ {54} نافع: ﴿آتَيْنَاكُم﴾ {55}، وحجته قوله: ﴿وَآتَيْنَا دَاوُودَ زَبُورًا﴾ [الإسراء:55]، ﴿وَآتَيْنَاهُ الْحُكْمَ صَبِيًّا﴾ [مريم: 12]، ﴿وَآتَيْنَاهُمَا الْكِتَابَ الْمُسْتَبِينَ﴾ [الصافات: 117].ومن قرأ: ﴿آتَيْتُكُم﴾، فحجته قوله: ﴿هُوَ الَّذِي يُنَزِّلُ عَلَى عَبْدِهِ آيَاتٍ بَيِّنَاتٍ﴾ [الحديد: 9]، و ﴿نَزَّلَ عَلَيْكَ الْكِتَابَ بِالْحَقِّ﴾ [آل عمران: 3]، و ﴿الْحَمْدُ لِلَّهِ الَّذِي أَنْزَلَ عَلَى عَبْدِهِ الْكِتَابَ﴾ [الكهف: 1].والقراءة الأولى: أشبه بكلام البلغاء والملوك، ومن الفصاحة تغيير العبارة عن الواحد إلى الجمع، وعن الجمع إلى الواحد، كقوله: {وَجَعَلْنَاهُ هُدًى لِبَنِي إِسْرَائِيلَ أَلَّا تَتَّخِذُوا مِنْ دُونِي وَكِيلًا} {56} [الإسراء: 2] ولم يقل: من دوننا، كما قال: ﴿وَجَعَلْنَاهُ﴾.والقراءة الثانية: أشبه بما قبله مِنْ قولِهِ: ﴿وَإِذْ أَخَذَ اللَّهُ﴾، وبما بعده من قوله: ﴿إِصْرِى﴾.وقوله تعالى: ﴿وَأَنَا مَعَكُمْ مِنَ الشَّاهِدِينَ﴾ قال ابن الأنباري {57}: وإنّما خاطب، فقال: ﴿آتَيْتُكُمْ﴾ بعد أن ذكر النبيين وهم غيب؛ لأن في الكلام معنى قول وحكاية، يراد: واذ أخذ الله ميثاق النبيين، فقال مخاطبًا لهم: ﴿لَمَا آتَيْتُكُمْ مِنْ كِتَابٍ وَحِكْمَةٍ﴾.قال {58}: ونظائر هذا كثيرة {59}.وقوله تعالى: ﴿مِنْ كِتَابٍ وَحِكْمَةٍ﴾.دخلت ﴿مِنْ﴾ تبيينًا لـ (ما)؛ كقولك: (ما عندي من الوَرِقِ {60} والعَيْنِ) {61}.وقوله تعالى: ﴿ثُمَّ جَاءَكُمْ رَسُولٌ مُصَدِّقٌ لِمَا مَعَكُمْ﴾.يقال: ما وَجْه {62} قوله: ﴿ثُمَّ جَاءَكُمْ﴾، والنَّبِيُّون لم يأتهم الرسولُ، وإنما يُبْعَثُ الرُّسُلُ إلى الأمم، لا إلى الرُّسُلِ؟.قيل: يجوز أن يُعْنى بذلك أهل الكتاب في المعنى {63}؛ لأن الميثاق إذا أُخذ على النبيين، فقد أُخذ على الذين أوتوا {64} كُتُبَهُمْ من أممهم.وعامَّة ما يُشْرع للأنبياء {65}، قد {66} شُرعَ لأممهم وأتباعهم؛ يبين ذلك: أن الفروض التي تلزمنا تلزمُ نبينا {67} عليه السلام؛ وإذا كان كذلك؛ فأخذ {68} الميثاق على النبيين، كأَخْذ الميثاق على الذين أوتوا كتبهم من أممهم، ومن ثَم جاء ﴿يَا أَيُّهَا النَّبِيُّ إِذَا طَلَّقْتُمُ النِّسَاءَ﴾ [الطلاق: 1]، فجُمع النبي ﷺ ومن تبعه في الخطاب الواحد، وهذا من جهة المعنى.قال ابن الأنباري {57}: إنما أخذ الله ميثاق النبيين {70}، بأن يؤمنوا برسل الله جل وعز بعدهم، فإذا آمنوا بهم، لزم أُمَمَهم الاقتداءُ بهم، والسلوكُ لمنهاجهم.وجواب آخر من طريق اللفظ {71}، وهو: أن يكون المراد: وإذ أخذ ميثاق أممِ النَّبِيِّين وأتباع النَّبِيِّين، شَرط عليهم أنبياؤُهم أن يؤمنوا بكل نَبِيٍّ يبعثه الله عز وجل ولا يكذبوه، ولا يدخلوا في جملة أعدائه، وأخذوا بذلك عهودهم، فقال الله تعالى: ﴿وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ النَّبِيِّينَ﴾، وهو يريد: ميثاقَ تُبّاع النَّبيين، فحَذَف المضاف.وقال صاحب النظم: معنى النَّبِيِّين ههنا: معنى أُمَمِهم، وصار ذكرهم كالقبيلة للأمم، كما يقال: قَيْس، وتَمِيم، وبَكْر، وهي أسماء رجال بأعيانهم، نُسِب أولادهم إليهم، فصاروا قبائل.ومنه قول الشاعر:أتَسأَلُني السويَّةَ وَسْطَ زَيْدٍ ... ألا إنَّ السَّوِيَّةَ أنْ تُضامُوا {72}فـ (زيد) ههنا قبيلة لأصحابه؛ لذلك قال: (وَسْطَ زيد).وقوله تعالى: ﴿لَتُؤْمِنُنَّ بِهِ وَلَتَنْصُرُنَّهُ﴾.إن قيل: ما معنى: أخْذَ ميثاق النبيين بِنُصْرَةِ مَن لم يَلْقَوْهُ، ولم يدركوا زمانَه؟.قلنا: قد بَيَّنّا {73} أن المراد بـ ﴿النَّبِيِّينَ﴾: أتباعهم وأممهم. فعلى هذا؛ لا كلام.وإن {74} قلنا: المراد: هُم، ثم {75} تتبعهم الأُممُ؛ فمعنى النصر ههنا: أن ينصروه بتصديقه عند قومهم.قال المفسرون في هذه الآية: إن الله تعالى أخذ الميثاق على الأنبياء بتصديق بعضهم بعضًا. وهذا قول: سعيد بن جبير {76}، وقتادة {77}، وطاوس {78}، والحسن {79}، والسدّي {80}.وقال علي بن أبي طالب رضي الله عنه {81}: لم يبعث الله عز وجل؛ {82} نَبِيًّا، آدَمَ ومَن بَعده، إلا أَخَذَ {83} عليه العهد في محمد وأمره {84}، وأخذ العهدَ على قومه لَيُؤمِنُنَّ به، ولَئِن بُعث وهم أحياء لَيُنْصُرُنَّهُ.وقال ابن عباس: يريد بـ ﴿مِيثَاقَ النَّبِيِّينَ﴾: عَهْدَهُم؛ ليشهدوا بمحمد ﷺ، بأنه رسول الله.وقوله تعالى: ﴿ثُمَّ جَاءَكُمْ رَسُولٌ﴾. يريد: محمدًا ﷺ.﴿لَتُؤْمِنُنَّ بِهِ وَلَتَنْصُرُنَّهُ﴾، يريد: إن أدركتموه. فالآية {85} عامة في جميع النبيين؛ على قول: سعيد بن جبير ومَن تابَعَهُ، وخاصَّة في النبي ﷺ، على قول: عَلِيٍّ، وابن عباس رضي الله عنهما. وهذا هو الأصح؛ لأن المراد بالآية: التَنْوِيه بذكر محمد ﷺ بما أُخِذ على النبيين مِن التصديق به، واعتماد النصرة له، مع الاحتجاج على أهل الكتاب باتِّبَاع سبيلِ النبيبن فيه {86}.وقوله تعالى: ﴿قَالَ أَأَقْرَرْتُمْ﴾ أي: قال الله تعالى للنبيين: أأقررتم بالإيمان به والنصرة له.و (الإقرار) في اللغة منقول بالألف {87}، من: (قَرّ الشيءُ، يَقِرُّ) {88}: إذا ثبت، ولزم مكانه، و (أَقَرَّهُ غيرهُ). والمُقِرُّ بالشيء: يُقِرُّهُ على نفسه؛ أي: يُثْبِتُهُ {89}.وقوله تعالى: ﴿وَأَخَذْتُمْ عَلَى ذَلِكُمْ إِصْرِي﴾ أي: قبلتم عهدي {90}. والأخذ؛ بمعنى (القَبُول) {91}، كثيرٌ في الكلام؛ كقوله: ﴿وَلَا يُؤْخَذُ مِنْهَا عَدْلٌ﴾ [البقرة: 48]؛ أي: لا يُقبل فِدْيَةٌ {92}. وقال: ﴿وَيَأْخُذُ الصَّدَقَاتِ﴾ [التوبة: 104]، أي: يقبلها.ومضى الكلام في معنى (الإصْر) {93}.وقوله تعالى: ﴿قَالَ فَاشْهَدُوا﴾ أي {94}: قال الله عز وجل للنبيين: فاشهدوا {95} أنتم على أنفسكم، وعلى أتباعكم، وأنا معكم من الشاهدين عليكم وعليهم. وهذا القول، يُروى عن عَلِي - رضي الله عنه - {96}.وقال الزجاج {97}: ﴿فَاَشْهَدُوا﴾ أي: فبينوا {98}؛ لأن الشاهد هو الذي يصحح دعوى المدعي، ولبينها، وشهادة الله عز وجل للنبيين: تبيينه {99} أمر نبوتهم بالآيات المعجزات {100}.وحكي عن سعيد بن المُسَيّب أنه قال {101}: هذا الخطاب للملائكة، قال الله تعالى للملائكة) {102}: اشهدوا عليهم بإقرارهم؛ فيكون خطابًا لمن لم يتقدم ذِكْرُهُ {103}."
  3,82,"قوله تعالى: ﴿فَمَنْ تَوَلَّى بَعْدَ ذَلِكَ﴾ هذا شرط {1}؛ وقد ذكرنا أن الفعل الماضي معناه: الاستقبال في الشرط والجزاء، وإنما جاز وقوع الماضي موقع المستقبل في الجزاء؛ لأن حرف {2} الجزاء لمّا كان يعمل في الفعل، قوي على نقله من معنى المضي إلى الاسقبال، وذلك إشارة إلى أخذ الميثاق.قال ابن عباس {3}: يريد: فمن أعرض عما جئت به، وأنكر ما عاهد الله عليه.وقال الزجاج {4}: فمن تولى؛ أي: أعرض عن الإيمان بعد أخذ الميثاق، وظهور آيات النبي ﷺ.وقوله تعالى: ﴿فَأُولَئِكَ هُمُ الْفَاسِقُونَ﴾ دخلت الفاء في (أولئك)؛ لأنه جواب الشرط؛ وإنما تدخل {5} الفاءُ في جواب الشرط؛ لأن الثاني يجب بوجود الأول بلا فصل؛ كقولك: (إنْ تأتِنِي فَلَكَ درهمٌ)، فوجوب الدرهم، بالإتيان عقيبَه بلا فصل؛ فلذلك جاء بالفاء.و ﴿أُولَئِكَ﴾: ابتداء؛ و {6} ﴿هُمُ﴾: ابتداءً ثانٍ، و ﴿الْفَاسِقُونَ﴾: خبره، و ﴿هُمُ﴾ {7} مع خبره: خَبَرُ ﴿أُولَئِكَ﴾، ويصلح أن يكون ﴿أُولَئِكَ﴾: ابتداء؛ و ﴿الْفَاسِقُونَ﴾: خبرَهُ، و ﴿هُمُ﴾: عِمَاد وفَصْلٌ؛ لا موضع له. ومعنى (الفاسقين) ههنا؛ أي: الذين خرجوا عن القصد، وعن جملة الإيمان. قاله الزجاج {8}."
  3,83,"قوله تعالى: ﴿أَفَغَيْرَ دِينِ اللَّهِ يَبْغُونَ﴾ دخلت الفاءُ في ﴿أَفَغَيْرَ﴾ لأنه عطف جملة على جملة {1}، وكذلك {2} لو قيل: (أَوَغَير)، إلّا أَنَّ الفَاءَ تُرتِّبُ {3}؛ كأنه قيل: أَبَعد أَخْذِ الميثاق، غَيرَ دينِ الله يبغون؟.واختلفوا في الياءِ والتّاءِ، من قوله: ﴿تَبغُون﴾:فمن قرأ بالتاء {4}؛ فلأن ما قبله خطاب؛ كقوله: ﴿أَأَقْرَرْتُمْ وَأَخَذْتُمْ﴾.ومن قرأ بالياء {5}؛ فوجهه: أن الله تعالى أخبر في الآية السابقة، عن أخذ الميثاق على اليهود والنصارى وغيرهم، فلما كفروا، أخبر عنهم على جهة الاستنكار، فقال {6}: ﴿أَفَغَيْرَ دِينِ اللَّهِ يَبْغُونَ﴾.وقرأ أبو عمرو: ﴿يَبْغُونَ﴾ بالياء، و ﴿تُرجَعُونَ﴾ بالتاء {7}؛ لأن الأول: خاص لليهود {8} وغيرهم {9}، والثاني: عامٌّ لجميع المكلفين {10}.وقوله تعالى: ﴿وَلَهُ أَسْلَمَ مَنْ فِي السَّمَاوَاتِ وَالْأَرْضِ طَوْعًا وَكَرْهًا﴾.روى {11} أنس بن مالك أن رسول الله ﷺ، قال في هذه الآية: ""الملائكة، أطاعوه في السماء؛ وعبد القيس في الأرض"" {12}.وبهذا {13}؛ قال ابن عباس في رواية عطاء {14}: قال: يريد بأهل السموات: الملائكة. وبأهل الأرض: المهاجرين والأنصار وعبد القيس، طوعًا، والناس كرهًا. وهذا قول الحسن {15}.وقال قتادة {16}: المؤمن، أسلم طائعًا فنفعه {17} ذلك، وقبل منه، والكافر، أسلم كَرْهًا في وقت البأس والمعاينة، حين {18} لا ينفعه ذلك، ولا يُقبَل منه، يدل عليه قولُه: ﴿فَلَمْ يَكُ يَنْفَعُهُمْ إِيمَانُهُمْ لَمَّا رَأَوْا بَأْسَنَا﴾ [غافر: 85].وقال ابن كَيْسان {19}، والزجاج {20}: أي: خضعوا وانقادوا من جهة ما فطرهم عليه، ودَبَّرَهُم به، لا يمتنعُ مُمْتَنِعٌ مِن جِبِلَّةٍ جُبِلَ {21} عليها، ولا يَقدِرُ على تغييرها، أحب تلكَ الجِبِلَّةِ أو كرهها؛ يدل على تصديق هذا القول: قوله تعالى: ﴿وَإِلَيْهِ يُرْجَعُونَ﴾ لأن المعنى: أنه بدأكم على إرادته، شئتم أو أبيتم، وهو يبعثكم كما بدأكم، والتأويل: أتبغون دينا غير دين {22}؛ الذي هذه صفته.وفي قوله: ﴿وَإِلَيْهِ يُرْجَعُونَ﴾ وعيد لهم؛ أي: أتبغون غير دين الله، وتزيغون عن الله، مع أن مرجعهم إليه، فيجازيهم على رفضهم دينه، وأخذهم سواه.وقوله: ﴿طَوْعًا وَكَرْهًا﴾ الطَّوْعُ: الانقياد؛ يقال: (طاعَهُ، يَطُوعُه، طوعًا) {23}: إذا انقاد له، وخضع. فإذا مضى لأمره (فقد أطاعَهُ)، وإذا وافقه، (فقد طاوَعَهُ) {24}.وقال ابنُ السِّكِّيت {25}: يقال: (طاعَ لهُ، وأطاعَهُ)، سواء، فَمَن قال: (طاعَ)، قال: (يَطَاعُ)، ومن قال: (أطاعَ)، قال: (يُطيعُ). فحصل في (الطَّوْع) لغتان: (طاعً يَطُوعُ)، و (طاعَ يَطاعُ).وانتصب ﴿طَوْعًا وَكَرْهًا﴾؛ على أنه مصدرٌ وقع موقع الحال؛ وتقديره: طائعًا {26} أو كارهًا {27}؛ كقولك: (أتاني رَكضًا)؛ أي: راكضا؛ ولا يجوز: (أتاني كلاما)؛ أي: متكلمًا؛ لأن الكلام ليس بِضَرْبٍ للإتْيَانِ."
  3,84,"قوله تعالى ﴿قُلْ آمَنَّا بِاللَّهِ﴾ الآية. في هذه الآية إنكارٌ {1} على الكفار من اليهود والنصارى، فيما ذهبوا إليه {2} من الإيمان ببعض النبيين دون بعض، وأمْرٌ للنبي ﷺ، وأمته، أن يقول: آمنا بالله وبجميع الرسل، وما أنزل عليهم: لا نفرق بين جميع الرسل في الإيمان {3} بهم، كما فعلت اليهود والنصارى.وأجرى أوَّلَ الآية على التوحيد، وآخِرَها على الجمع، في قوله: ﴿لَا نُفَرِّقُ﴾، ﴿وَنَحْنُ﴾ لدخول أمة محمد ﷺ في هذا الإقرار معه."
  3,85,"قوله تعالى: ﴿وَمَنْ يَبْتَغِ غَيْرَ الْإِسْلَامِ دِينًا﴾ الآية.قال ابن عباس {1}: يريد: خَسِرَ {2} ثوابَ الله، وصارَ إلى عذابِهِ؛ وخَسِرَ الحُورَ العِيْنِ.وقال الزجاج {3}: يعني: خَسِرَ عَمَلَهُ؛ حيث لم يُجازَ بِهِ {4} الجنَّة والثوابَ."
  3,86,"قوله تعالى: ﴿كَيْفَ يَهْدِي اللَّهُ قَوْمًا كَفَرُوا بَعْدَ إِيمَانِهِمْ﴾.قال ابن عباس {1}: نزلت في اليهود {2}: قَرَيظة والنَّضِير، ومَن دانَ بدينهم؛ كفروا بالنبي ﷺ بعد أن كانوا قبل مَبْعَثِهِ مؤمنين، وكانوا يَشهَدُون له بالنبوة، فلما بُعِثَ، وجاءهم بالآيات المعجزات، كفروا بغيًا وحَسَدًا {3}.وأصل (كيف): أنها للاستفهام والاستخبار عن الحال. ودخلت ههنا للإنكار؛ وذلك أن المسئول يُسألُ لأغراضٍ مختلفة، فقد يُسأل للتعجيز عن إقامة البرهان، وقد يُسأل لتوبيخ، بما يظهر من معنى الجواب.وقد ذكرنا فيما مضى {4}: لِمَ جازَ أن يَقَعَ الاستفهام موقعَ الإنكار؟ ومثل هذا قول ابن الرُّقَيّات {5}: كيفَ نَوْمِي عَلَى الفِراشِ وَلَمّا ... يَشْمَلِ الشامَ غارَةٌ شَعْوَاءُ. {6}.أي: لا نوم لي، ولا أنام. ومثله قوله: ﴿كَيْفَ يَكُونُ لِلْمُشْرِكِينَ عَهْدٌ عِنْدَ اللَّهِ﴾ [التوبة: 7] أي: لا يكون لهم عهد.قال {7} الزجاج {8}: أعلم الله عز وجل أنه لا جهة لهدايتهم؛ لأنهم قد استحقوا أن يُضلُّوا بكفرهم؛ لأنهم قد كفروا بعد البَيِّنات.وقوله تعالى: ﴿وَشَهِدُوا أَنَّ الرَّسُولَ حَقٌّ﴾.عطف بالفعل على المصدر؛ لأنه أراد بالمصدر الفعل؛ تقديره: (كفروا بالله بعد أن آمنوا). فهو عطفٌ على المعنى؛ كما قال:لَلُبْسُ عَبَاءَةٍ وَتَقَرَّ عَيْنِي ... أَحَبُّ إليَّ مِن لُبْسِ الشُّفُوفِ {9}معناه: لأن ألبس عباءة، وتَقَرَّ عيني {10}.وزاد {11} صاحبُ النظم لهذا بيانا، فقال {12}:قوله: ﴿وَشَهِدُوا﴾ منسوق على ما يمكن في التقدير؛ وذلك أن قوله: ﴿بَعْدَ إِيمَانِهِمْ﴾ يمكن أن يكون: (بعد أن آمنوا)، و (أَنْ) الخفيفة مع الفعل، بمنزلة المصدر، كقوله: ﴿وَأَنْ تَصُومُوا خَيْرٌ لَكُمْ﴾ [البقرة: 184]، أي: والصوم.ومثل هذا ممّا حُمِلَ عَلَى الإمكان {13} قوله: ﴿وَمَا كَانَ لِبَشَرٍ أَنْ يُكَلِّمَهُ اللَّهُ إِلَّا وَحْيًا أَوْ مِنْ وَرَاءِ حِجَابٍ أَوْ يُرْسِلَ﴾ {14}، فهو {15} عطف على قوله: ﴿إِلَّا وَحْيًا﴾، ويمكن فيه: إلا أَنْ يوحى إليه. فلمّا كان قوله {16}: ﴿إِلَّا وَحْيًا﴾ بمعنى: يوحى إليه، حمله على ذلك. ومثله من الشعر، قوله:فَظَلَّ طُهاةُ اللَّحْمِ مِنْ بَيْنِ مُنْضِجٍ ... صَفِيفَ {17} شِواءٍ أو [قَدِيرٍ مُعَجَّلِ] {18} خَفَضَ قولَه: (قَدِيرٍ) {19}؛ لأنه عَطْفٌ على ما يمكن في قوله: (مُنْضِجٍ)، لأنه أمكن أن يكون مضافًا إلى الصَّفِيفِ {20}، فحمله على ذلك {21}.وقوله {22} تعالى: ﴿وَجَاءَهُمُ الْبَيِّنَاتُ﴾.يجوز أن يريد بـ ﴿الْبَيِّنَاتُ﴾: ما بُينَ في التوراة والإنجيل. وهو قول ابن عباس {23}.ويجوز أن يريد: ما أتى به {24} النبي ﷺ من الكتاب والآيات المعجزات. وفي هذا تبعيد لهم من حال الهداية، وبيان لاستحقاقهم الكفر بفعلهم.وقوله تعالى: ﴿وَاللَّهُ لَا يَهْدِي الْقَوْمَ الظَّالِمِينَ﴾ قال ابن عباس {23}. يريد: لا يرشد من نقض عهود {26} الله، وظلم نفسه.وهذا خاص فيمن {27} علم الله عز وجل منهم أنهم لا يؤمنون، وأراد ذلك منهم."
  3,87,"قوله تعالى: ﴿أُولَئِكَ جَزَاؤُهُمْ أَنَّ عَلَيْهِمْ لَعْنَةَ اللَّهِ وَالْمَلَائِكَةِ وَالنَّاسِ أَجْمَعِينَ﴾ [آل عمران: 87].قال ابن عباس {1}: يريد: المؤمنين {2}. فعلى هذا؛ ﴿النَّاسِ﴾، خاصٌ؛ ولكنَّه لمَّا ذكر الثلاثة، قيل: ﴿أَجْمَعِينَ﴾.وقال الزجاج {3}: معنى (لَعْن الناسِ أجمعين لهم): أن بعضَهم يوم القيامةِ يَلعَنُ بعضًا، ومَن خالَفَهم؛ يلعنهم في الدنيا. فقد استقرَّت عليهم لعنةُ الجميع، وإن كان على التفريق."
  3,88,"قوله تعالى: ﴿خَالِدِينَ فِيهَا﴾ نصبٌ على الحال مما قبله، وهو قوله: ﴿عَلَيْهِمْ لَعْنَةُ اللَّهِ﴾ {1}.وقوله تعالى: ﴿فِيهَا﴾ قال ابن عباس {2}: في جهنم.فعلى هذا؛ الكنايةُ {3} عن {4} غيرِ مَذْكورٍ {5}.وقال الزجاج {6}: أي: فيما توجبه اللعنة؛ [أي: في عذاب اللعنة] {7}.وقال بعضهم {8}: الكناية راجعة إلى اللعنة.ومعنى (خلودهم في اللعنة): استحقاقهم دائمًا لها، مع ما {9} توجبه من أليم العقاب، بدوامها.وقوله تعالى: ﴿وَلَا هُمْ يُنْظَرُونَ﴾ معنى (الإنظار): تأخير العبد، ليُنظَرَ في أمره {10}؛ أي: لا {11} يُؤخرون عن وقتهم المؤقت {12} لعذابهم."
  3,89,"قوله تعالى: ﴿إِلَّا الَّذِينَ تَابُوا مِنْ بَعْدِ ذَلِكَ﴾ موضع ﴿الَّذِينَ﴾: نصبٌ، استثناء من قوله: ﴿عَلَيْهِمْ لَعْنَةَ اللَّهِ﴾، ﴿إِلَّا الَّذِينَ تَابُوا﴾.وقوله تعالى: ﴿مِنْ بَعْدِ ذَلِكَ﴾ والتوبةُ لا تكون إلا بعد الذنْبِ، ولكنْ فيه دلالةٌ على معنًى تابوا منه؛ وذلك أن التوبة مِن غير الرِّدَّةِ لا ينفع {1} في التَّخَلُّصِ منها {2}، كما أن التوبةَ من ذَنْبٍ لا ينفعُ في التخلص من ذَنْب آخر {3}.وقوله تعالى: ﴿وَأَصْلَحُوا﴾ قال ابن عباس {4}: يريد: راجعوا الإيمان بالله، والتصديق بِنَبِيِّهِ، وأَصلَحُوا أعمالَهم.وقال الزجاج {5}: معنى ﴿وَأَصْلَحُوا﴾: أظهروا للناس أنهم كانوا على ضلال، وأصلحوا ما كانوا أفسدوهُ مِن تَغْرِيرِهم مَن تَبِعَهم {6}، مِمَّن لا علم عنده. وشَرَطَ مع {7} التوبةِ الإصلاحَ؛ لإزالة الإيهام أنهم إذا تابوا من الارتداد، [لم] {8} يضرهم غيرُهُ مِنَ الفساد؛ وعلى ذلك، قال {9}: {إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ} {10}؛ لإزالة الإيهام: أنَّ مَن كان مؤمنًا {11}، لم {12} يضره ما عمل بعد ذلك مِن الجُرْمِ.وقوله تعالى: ﴿فَإِنَّ اللَّهَ﴾ دخلت الفاءُ في: ﴿فَإِنَّ اللَّهَ﴾؛ لِشَبَهِ الجزاء، إذ {13} كان الكلامُ قد تضمن معنى: (إنْ تابوا؛ فإنَّ الله يغفر لهم).وقوله تعالى: ﴿غَفُورٌ رَحِيمٌ﴾ وقال الزجاج {5}: أعلم الله أنَّ مِن سَعَةِ {15} رحمته وتفضله، أنْ يغفرَ لِمَن اجترأ عليه هذا الاجتراء؛ وذلك أنَّ الذي {16} فعلوا، لا غايةَ وَرَاءَهُ فِي الكفر، وهو: أنَّهم كفروا بعد {17} تبَيُّنِ الحقِّ."
  3,90,"قوله تعالى: ﴿إِنَّ الَّذِينَ كَفَرُوا بَعْدَ إِيمَانِهِمْ﴾ قال ابن عباس {1}: نزلت في اليهود؛ كفروا بعد إيمانهم بمحمد، وتصديقِهم إيّاهُ قَبْلَ {2} بِعثتِهِ {3}.﴿ثُمَّ ازْدَادُوا كُفْرًا﴾ بالإقامة على كفرهم حتى هلكوا عليه. قاله مجاهد {4}.وقال الحسن {5}: ﴿ثُمَّ ازْدَادُوا كُفْرًا﴾ أي: كلَّما نزلت آية على محمد ﷺ، كفروا بها.وقال قتادة {6}: إنَّ اليهود كفروا بعيسى والإنجيل، بعد إيمانهم بأنبيائهم وكتبهم، ثم ازدادوا كفرًا، بكفرهم بمحمد والقرآن.﴿لَنْ تُقْبَلَ تَوْبَتُهُمْ﴾.قال الحسن {7}، وقتادة {8}، وعطاء {9}: لأنهم لا يتوبون إلا عند حضور الموت، والله تعالى يقول: ﴿وَلَيْسَتِ التَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ السَّيِّئَاتِ﴾ {10}، الآية.وقال ابن الأنباري {1}: لن تُقبل توبتهم التي تقدمت في حال إيمانهم وتصديقهم محمدًا ﷺ لأن الله عز وجل لا يَقبَلُ مع الإقامة على الشرك توبَةً متقادمةً {12}، ولا عَمَلًا حَسَنًا ماضيًا مرجوعًا عنه إلى ضدِّه."
  3,91,"قوله تعالى: ﴿إِنَّ الَّذِينَ كَفَرُوا وَمَاتُوا﴾ إلى قوله: ﴿مِلْءُ الْأَرْضِ﴾ (مِلْءُ {1} الشيء): قدر ما يَمْلؤه، وهو اسمٌ يُثَنَّى وُيجمع؛ يقال: (مِلْءُ القَدَح)، و (مِلآهُ)، و (ثلاثة أملائِهِ) {2}. والفرق بين (المِلْءِ) و (المَلْءِ) {3}، كالفرق بين (الرِّعْي) و (الرَّعْي) {4}.وانتصب ﴿ذَهَبًا﴾ على التفسير {5}.قال المُفضَّل {6}: ومعنى التفسير: أن يكون الكلامُ تامًّا وهو مُبْهَم؛ كقولك: (عندي عشرون)؛ فالعدد {7} معلوم، والمعدود {8} مبْهَم.فإذا قلت: (درهمًا) {9}، فَسَّرت العددَ. وكذلك إذا قلت: (هو أَحْسَنُ الناسِ)، فقد أخبرت عن حُسْنِه، ولم يبين {10} في أي شيء هو، فإذا قلت: (وَجْهًا)، أو [(فِعْلًا)] {11}، فقد بينته، ونصبته [على التفسير، وإنما نصبته] {12}، لأنه ليس له ما يخفضه ولا ما يرفعه، فلما خلا من هذين، نُصِبَ؛ لأن النصب أخفُّ {13} الحركات، فجعِل لكل ما لا عامل فيه.وقال سيبويه {14}: انتصب (ذهبًا)؛ لأن الاسم المخفوض قد حال بين الذهب وبين المِلْءِ أن يكون جَرًّا {15}؛ ومعنى هذا: أنَّ العاملَ {16} اشتغل بالإضافة في ﴿مِلْءُ الْأَرْضِ﴾ {17}، وبما يعاقِبُ الإضافة من النون الزائدةِ في (عشرون درهمًا)، فجرى ذلك مجرى الحالِ في اشتغال العامل بصاحبها {18}، ومجرى المفعول في اشتغال العامل عنه بالفاعل.وقوله تعالى: ﴿وَلَوِ افْتَدَى بِهِ﴾.قال الفرّاء {19}: الواو زائدةٌ، كهي في قوله: ﴿وَلِيَكوُنَ مِنَ المُوقِنِينَ﴾ [الأنعام: 75]؛ المعنى: لن يُقَبلَ مِن أحَدِهم مِلْءُ الأرضِ ذهبًا، لو افتدى به.وغَلّطَهُ الزجاجُ وغيرُه {20}، وقالوا: الواو ههنا للعطف؛ لأن المعنى: لو {21} عمل مِنَ الخَيْرِ، وقَدَّمَ مِلْءَ الأرضِ ذهبًا؛ يتقرب به الله عز وجل، لم ينفعه ذلك مع كفره، ولو افتدى من العذابِ بِمِلْءِ الأرضِ ذهبًا، لم يُقْبَل منه. فالواو دخلت لفعلٍ مُضْمَرٍ، وهو {22}: (القَبُولُ)؛ أي: ولا يُقبل منه لو افتدى به {23}.قال ابن الأنباري: وهذا آكَدُ في التغليظ عليهم، إذْ كانوا لا يُقبل منهم [مِلْء الأرضِ ذَهَبًا، على جهة الصَّدَقَةِ والتَّقْرُّبِ إلى الله جل وعز، ولا يُقبل منهم] {24} أيضًا على جهة فِدْيَةٍ {25}.وقد أشار الفراء إلى هذا القول أيضًا، فقال {19}: والواو [ههنا كأنَّ لها فِعْلًا] {27} مُضْمَرًا بعدها.وقال بعض النحويين {28}: الواو ههنا دخلت لتفصيل نفي القَبول بعد الإجمال؛ وذلك {29} أنَّ ﴿فَلَنْ يُقْبَلَ مِنْ أَحَدِهِمْ مِلْءُ الْأَرْضِ ذَهَبًا﴾ [قد عمَّ وجوهَ القَبول] {30} بالنفي، ثم أتى بالتفصيل، لِئَلّا يتَطَرَّق عليه سوءُ التأويل {31}."
  3,92,"قوله تعالى: ﴿لَنْ تَنَالُوا الْبِرَّ﴾ قال شَمِر {1}: اختلف العلماء في تفسير ﴿الْبِرَّ﴾: فقال بعضهم: البِرُّ: الصلاح. وقال بعضهم: الخير، ولا أعلم تفسيرًا [أجمع منه؛ لأنه] {2} يُحيط بجميع ما قالوا.قال: وجعل لَبِيد {3} (البِرَّ): التُّقَى؛ حيث يقول: وما البِرُّ إلا مُضْمَراتٌ مِنَ التُّقى {4}وقول الشاعر:تُحَزُّ رُؤوسُهم في غَيْرِ بِرِّ {5}معناه: في غير طاعة وخير. وعلى هذا دار كلام المفسرين.قال عطاء {6} ومقاتل {7}: البِرُّ: التقوى، في هذه الآية. وقال أبو رَوْق {8}: الخير.ورُوِيَ عن ابن عباس، ومجاهد، والسدِّي، أنهم قالوا {9}: [البِرُّ؛ المرادُ به ههنا: الجنة. وقال بعض أهل المعاني {10}: معنى الآية: لَنْ تَنالوا] {11} البِرَّ من الله عز وجل بالثواب في الجنة.وقوله تعالى: ﴿حَتَّى تُنْفِقُوا مِمَّا تُحِبُّونَ﴾ قال ابن عباس في رواية الضحاك {12}: أراد بهذه الآية: الزكاةَ؛ يعني: حتى تُخرجوا زكاةَ أموالكم.وقال الحسن {13}: كل شيء أنفقهُ المُسْلِمُ مِن مالِهِ؛ يبتغي به وجْهَ الله عز وجل، فإنّه من الذي عَنَى الله سبحانه بقوله: ﴿لَنْ تَنَالُوا الْبِرَّ حَتَّى تُنْفِقُوا مِمَّا تُحِبُّونَ﴾، حتى التَّمْرَةَ.وقال مجاهد، والكلبي {14}: هذه الآية منسوخة، نسختها آيةُ الزَّكاةِ {15}.وقوله تعالى: ﴿وَمَا تُنْفِقُوا مِنْ شَيْءٍ فَإِنَّ اللَّهَ بِهِ عَلِيمٌ﴾.[تأويلها {16} تأويل الشرط والجزاء، وموضعها نَصْبٌ بـ ﴿تُنْفِقُوا﴾، والفاء في ﴿فَإِنَّ اللَّهَ بِهِ عَلِيمٌ﴾] {17}، جوابُ المجازاة.وتأويل الآية: وما تنفقوا من شيء فإنَّ اللهَ يجازيكم به قَلَّ أو كَثُرَ، فإنه عليم به، لا يخفى عليه شيء منه.نَظِير هذه الآية {18} في المعنى: قوله: ﴿وَمَا تَفْعَلُوا مِنْ خَيْرٍ يَعْلَمْهُ اللَّهُ﴾ [البقرة: 197]، وقوله تعالى {19}: ﴿وَمَا أَنْفَقْتُمْ مِنْ نَفَقَةٍ أَوْ نَذَرْتُمْ مِنْ نَذْرٍ فَإِنَّ اللَّهَ يَعْلَمُهُ﴾ [البقرة: 270] {20}."
  3,93,"قوله تعالى: ﴿كُلُّ الطَّعَامِ كَانَ حِلًّا لِبَنِي إِسْرَائِيلَ﴾ الآية.قال أهل التفسير: لما ادَّعى النبي ﷺ أنه على مِلَّةِ إبراهيم؛ قالت اليهود: كيف وأنت تأكل لُحومَ الإبِلِ وألبانها؟ فقال النبي ﷺ: ""كان ذلك حلالاً {1} لإبراهيم، فنحن نحله"".فقالت اليهود: كلُّ شيءٍ أصبحنا اليوم نُحرِّمُهُ، فإنه كان مُحرَّمًا على نوح وإبراهيم؛ فأنزل الله عز وجل تكذيبًا لهم: ﴿كُلُّ الطَّعَامِ كَانَ حِلًّا لِبَنِي إِسْرَائِيلَ﴾ {2} [الآية] {3} و (الحِلُّ)، و (الحَلالُ)، و (المُحَلَّلُ): واحد. قال ابن عباس في زمزم {4}: (هي حِلٌّ وَبِلّ) {5}. رواه سُفْيَان بن عُيَيْنَة {6}، عن عَمْرو بن دينار عنه، فسُئِل سفيانُ: ما (حِلٌّ) {7}؟ فقال: مُحَلَّلٌ.وروى ابن عباس {8}: أن النبي ﷺ قال: ""إنَّ يعقوبَ مرض مرضًا شديدًا {9}، فنذر لَئِن عافاه الله؛ ليُحرِّمَنّ أحبَّ الطعام والشراب إليه. وكان أحب الطعام إليه: لُحْمان الإبل، وأحب الشراب إليه: ألبانها"".وهذا قول: أبي العالية {10}، وعطاء {11}، ومقاتل {12}، والكلبي {13}: أن الذي حرَّم إسرائيلُ {14} على نفسه كان {15} لحومَ الإبلِ وألبانَها {16}.قالت العلماء {17}: إنما حرَّمَ إسرائيلُ ذلك على نفسه بإذن الله عز وجل {18} له {19} [فيه] {20}، كما جاز {21} الاجتهاد في الأحكام لما أَذِنَ اللهُ فيه {22}.وللنبي {23} أن يجتهد في الأحكام؛ لأنه إذا كان بالدين أعلم، ورأيُه أفضل، كان بالاجتهاد أحق، ولا {24} يجوز لأمته أن يخالفوه في اجتهاده، كما لا يجوز مخالفة الإجماع {25}.وإن {26} كان من طريق الاجتهاد. فعلى هذا؛ لم تكن لحومُ الإِبِل محرمة عليهم في التوراة، وإنما لزمهم ذلك التحريم من جهة يعقوب.وقال الحَسَنُ {27}: حَرَّم إسرائيلُ على نفسه لحم الجَزُور، تَعَبُّدًا لله عز وجل، فسأل ربه أن يجيز ذلك له، فحرَّمَه اللهُ على ولده.وقال عَطِيَّةُ {28}: إنما كان ذلك حرامًا عليهم، بتحريم إسرائيل ذلك عليهم؛ وذلك أنَّه {29} قال: لئن عافاني الله؛ لا يأكل لي ولدٌ لحم الجزور {30}. ولم يكن ذلك محرمًا عليهم في التوراة.وقال الضَّحّاك {31}: لم يكن شيءٌ من ذلك عليه {32} حرامًا، ولا حَرّمَهُ اللهُ عليهم في التوراة، وإنما هو شيء حرموه على أنفسهم؛ اتِّباعًا لأبيهم، ثم أضافوا تحريمَهُ إلى الله عز وجل، فكذبهم الله عز وجل، فقال: ﴿قُلْ فَأْتُوا بِالتَّوْرَاةِ فَاتْلُوهَا﴾.وقال السُدِّي {33}: إنَّ الله تعالى {34} لما أنزل التوراة، حرَّم عليهم ما كانوا يُحرِّمونه قبل نزولها؛ اقتداءً بأبيهم يعقوب عليه السلام.فالمفسرون مختلفون كما ترى في أن هذا التحريم: هل ثبت عليهم من الله تعالى في التوراة، أم لا؟.وكيفما {35} كان، ففي التوراة بيان أن ابتداء هذا التحريم من جهة يعقوب، وقبله كان حلالًا لإبراهيم عليه السلام. والنبي ﷺ كان يَدَّعي دين إبراهيم."
  3,94,"قوله تعالى: ﴿فَمَنِ افْتَرَى عَلَى اللَّهِ الْكَذِبَ﴾ الافتراء: اختلاق الكذب {1}. والفِرْيَةُ: الكذِبُ والقَذْفُ {2}. وأصلُهُ مِنْ: (فَرْيِ الأديم)، وهو: قَطْعُهُ {3}، فقيل للكَذِبِ: افتراء؛ لأن الكاذب يقطع به على التقدير، من غير تحقيق.وقوله تعالى: ﴿مِنْ بَعْدِ ذَلِكَ﴾ أي: من بعد ظهور الحُجَّة: بأنَّ التحريم إنما كان من جهة يعقوب، ولم يكن محرمًا قبله.﴿فَأُولَئِكَ هُمُ الظَّالِمُونَ﴾ أنفسهم ومن يدعونهم إلى مذهبهم."
  3,95,"قوله تعالى: ﴿قُلْ صَدَقَ اللَّهُ﴾ أي: في جميع ما أخبر به، وفيما أخبر {1} مِنْ أنَّ ﴿كُلُّ الطَّعَامِ كَانَ حِلًّا لِبَنِي إِسْرَائِيلَ﴾. [الآية] {2}."
  3,96,"قوله تعالى: ﴿إِنَّ أَوَّلَ بَيْتٍ وُضِعَ لِلنَّاسِ﴾. الآية. قال أبو إسحاق {1}: معنى (الأول) في اللغة: ابتداء الشيء. ثم جائزٌ أن يكون له ثانٍ، وجائزٌ أن لا يكون؛ كما تقول: (هذا أوَّلُ مالٍ {2} كَسَبْتُهُ). جائزٌ أن يكون بعده كسبٌ، وجائزٌ أن لا يكون، ولكن إرادتك: (هذا ابتداءُ كَسْبِي).ومضى الكلامُ في معنى (الأول) واشتقاقه، عند قوله: ﴿وَلَا تَكُونُوا أَوَّلَ كَافِرٍ بِهِ﴾ [البقرة: 41].واختلفوا في تأويل قوله: ﴿إِنَّ أَوَّلَ بَيْتٍ﴾ فقرأت على الشيخ أبي حسَّان، محمد بن أحمد بن جعفر، فقلت: أخبركم أبو سَهْل، هارون بن محمد {3} بن هارون الإسْتَرَاباذي {4} أبنا {5} أبو محمد، إسحاق بن أحمد الخزاعي {6}، أبنا {7} أبو الوليد، محمد بن عبد الله الأَزْرَقي {8}، حدثنى مهدي بن أبي المهدي {9}، ثنا أبو أيوب البصري {10}، ثنا هشام {11}، عن حميد {12}، قال: سمعت مجاهدًا يقول: (خلق الله هذا البيت قبل أن يخلق شيئًا من الأرضين) {13}.وبه عن الأزرقي، قال: حدثني يحيى بن سعيد {10}، عن محمد بن عمر بن إبراهيم {15}، عن عثمان بن عبد الرحمن {10}، عن هشام، عن مجاهد، قال: (لقد خلق الله موضع هذا البيت، قبل أن يخلق شيئًا من الأرض بألفي سنة، وإنَّ قواعده لفي الأرض السابعة السفلى) {17}.وبه عن الأزرقي، ثنا علي بن هارون العجلي {10}، ثنا [عن أبيه] {19}، [قال] {20}: ثنا [القَاسم] {21} بن عبد الرحمن الأنصاري {22}، حدثني محمد بن علي بن علي بن أبي طالب {23}، عن أبيه {24}، قال: (إنَّ الله بعث ملائكته، فقال: ابنوا لي في الأرض بيتًا بمثال البيت المعمور وقَدْرِهِ، وأمر الله مَنْ في الأرض مِنْ خَلْقِه، أن يطوفوا به، كما يطوف أهل السماء بالبيت المعمور، وهذا كان قبل خَلْق آدم) {25}.وقال ابن عباس {26}: هو أول بيتٍ بناه آدمُ في الأرض.وقال علي بن أبي طالب رضي الله عنه {27}: هو أول بيت مبارك وهدى وُضِع {28} للناس. وهو قول الضحاك {29}.وروي عن ابن عباس أيضًا قال {30}: هو أول بيت وُضِع للناس يُحَجُّ إليه. واختاره الزجاج {31}.وأخبرنا أبو الحسين بن أبي عبد الله الفَسَوي {32}، أبنا أحمد {33} بن محمد البُسْتي، ثنا {34} إسماعيل بن محمد الصفّار {35}،ثنا {34} سعدان {37}، ثنا {34} أبو معاوية {39}، ثنا الأعمش عن إبراهيم التَيْمي {40} عن أبيه {41}، عن أبي ذر {42}، قال: قلت: يا رسول الله ﷺ {43}؛ايُّ مسجد وُضِعَ في الأرض أوَّلا؟ قال: ""المسجد الحرام"". قال: قلت {44}: ثم أي؟ قال: ""المسجد الأقصى"". قال: قلت كم بينهما؟ قال: ""أربعون سنة"". قال: ""فأينما {45} أدركتك الصلاةُ فَصَلِّ {46}، فهو مسجدٌ"" {47}.وقوله تعالى: ﴿لَلَّذِي بِبَكَّةَ﴾.بَكّة: هي {48} مكة، في قول الضحاك {49}، ومجاهد {50}، والمُؤَرّج {51}. فأبدِلَت الميمُ باءً، كقوله {52}: (سَبَّدَ {53} رأسَهُ)، و (سَمَّدَ رأسَه) {54}، و (أَغْبَطَت الحُمَّى)، و (أَغْمَطَت) {55}، و (ضَرْبة لازِمٍ)، و (لازِبٍ) {56}. ومَكَّة سُمِّيَت بذلك؛ لقلة مائها، وعدم الزرع والضَرْع بها، من قولهم {57}: (مَكَّ الفَصِيلُ ضرْعَ {58} أُمِّهِ)، و (امْتَكَّهُ) {59}: إذا امتص كلَّ ما فيه.وقال [ابن الأنباري {60}: سُمِّيَت مكة، لاجتذابها الناس إليها من كل أُفُقٍ وفجٍّ، من قولهم] {61}: (وقال تَمَكَّكْتُ المُخَّ من العَظْم): إذا استقصيت عليه في جِذْيه {62}، وكذلك (تَمَكُّك {63} الفَصِيلِ ما في الضرع) {64}.وقال الآخرون {65}: (مكَّة): اسم البلد كله {66}، و (بَكَّة): موضع البيت والمطاف. سميت بكّة؛ لازدحام الناس بها، يَبُكُّ بعضهم بعضًا، أي: يدفع ويصلي بعضهم بين يدي بعض، وَيمُرُّ بعضهم بين يدي بعض، لا يصلح ذلك إلا هناك.وقال الليث {67}: سميت مكَّةُ: بَكَّةَ {68}؛ لأنها تَبُكُّ أعناقَ الجبابرة، إذا ألحدوا فيها؛ أي: تَدُقُّ. و (البَكُّ): دَقُّ العُنُقِ {69}.وقوله تعالى: ﴿مُبَارَكًا﴾ معناه {70}: كثير الخير؛ أنْ جعل فيه وعنده البَرَكَة، ومعنى البَرَكَةِ: الكثرة في كل خير.وقال بعض أهل المعاني: أصل البَرَكَة: الثُّبُوت، من قولك: (بَرَكَ بَرْكًا، وبُرُوكًا): إذا ثبت على حاله {71}. فالبَرَكَة: ثُبُوت الخير؛ بِنُمُوِّهِ وتَزَيُّدِه.ومنه: (البَراكاء) في القتال {72}، ومنه: (البِرْكة)، شِبْهُ الحوض؛ لثبوت الماء فيها. و (تبارك الله)، لثبوته، لم يزل ولا يزال {73}.وقال اللِّحْياني {74}: (باركت على التجارة، وغيرها)، أي: داومت وواظبت عليها {75}.وانتصب ﴿مُبَارَكًا﴾ على الحال. قال الزجاج {76}: المعنى: لَلَّذي {77} استقر بمكة في حال بَرَكَتِه، وقال {78}: هو حال مِنْ ﴿وُضِعَ﴾، أي: وُضِعَ مباركًا.وقوله تعالى: ﴿وَهُدًى لِلْعَالَمِينَ﴾ قال أبو إسحاق {79}: المعنى: وذا هُدَى {80}. قال: ويجوز أن يكون ﴿وَهُدًى﴾ في موضع رفع، على معنى: وهو هُدَى.ومعنى كونه ﴿وَهُدًى لِلْعَالَمِينَ﴾: أنه قِبْلةُ صلاتهم، ودلالة على الله تعالى من حيث هو المدبر له {81} بما لا يقدر عليه غيره، مِن أَمْنِ الوحوش فيه، حتى يجتمع الكلبُ والظَبْي {82} فلا يعدوا عليه، وحتى يأنَسَ الطيرُ فلا يمتنع كما يمتنع في غيره، إلى غير ذلك من الآثار البينة فيه، مع البَرَكة التي يجدها من حج البيت."
  3,97,"قوله تعالى: ﴿فِيهِ آيَاتٌ بَيِّنَاتٌ﴾ قال ابن عباس {1}: يريد: المناسك والمشاعر كلها. وقال آخرون {2}: الآيات التي فيها: أَمْنُ الخائف، وإمحاقُ الجِمَارِ {3} على كثْرةِ الرَّامي، وامتناع الطَيْرِ مِنَ العُلُوِّ عليه {4}، واستشفاءُ المريض به، وتعجيلُ العقوبة لمن انتهك فيه حُرْمة {5}، وإهلاكُ أصحاب الفِيل لَمَّا قصدوا [لإحْراقِه] {6}.فعلى {7} هذا؛ تفسير الآيات {8} وبيانها {9}، غير مذكور {10} في الآية. ومذهب جماعة من المفسرين {11}: أنَّ تفسير الآيات مذكورة، وهي قوله: ﴿مَقَامُ إِبْرَاهِيمَ﴾ أي: هي: مقامُ إبراهيم؛ يعني: الآيات. وقال بعضهم {12}: المعنى: منها مقام إبراهيم.فإن قيل: (الآيات) جماعة، ولا يصح تفسيرُها بشيء واحد. قلنا: يجوز ذلك؛ كما يقول القائل: (في بلدة كذا، لي أصدقاء وقرابات)، ثم يقتصر على ذكر واحدٍ منهم، على معنى تخصيص له.وعند الزجاج: أن قوله: ﴿وَمَنْ دَخَلَهُ كَانَ آمِنًا﴾، مِن تفسير الآيات؛ لأنه قال {13}: ومن الآيات {14} أيضًا: أَمْنُ مَنْ دَخَلَه. قال: ومعنى (أَمْن مَن دخله): أن إبراهيم عليه السلام سأل الله عز وجل أَنْ يُؤَمِّنَ سكانَ مكةَ، قال: ﴿رَبِّ اجْعَلْ هَذَا بَلَدًا آمِنًا﴾ [البقرة: 126]، فجعل [عز وجل] {15} أَمْنَ مكةَ آيةً لإبراهيم، فلم يطمع في أهلها جبَّار، فكان فيما {16} عطف الله تعالى من قلوب العرب في الجاهلية على مَنْ لاذَ بالحَرَمِ حتى يُؤْمَّنوا {17}، آيةً بَيِّنَةً، يدل على هذه الجملة قولُ قتادة في قوله: ﴿وَمَنْ دَخَلَهُ كَانَ آمِنًا﴾، قال {18}: كان ذلك في الجاهلية، فأما اليوم، فإنْ سرقَ فيه [أحدٌ] {19} قُطِعَ، وإن قَتَلَ فيه قُتِلَ.وقد ذكرنا الحُكمَ في هذا عند قوله: ﴿وَإِذْ جَعَلْنَا الْبَيْتَ مَثَابَةً لِلنَّاسِ وَأَمْنًا﴾ [البقرة: 125].وقال الضحاك في قوله: ﴿وَمَنْ دَخَلَهُ كَانَ آمِنًا﴾ قال {20}: مَن حَجَّهُ فدخله كان آمنا من الذنوب التي اكتسبها قَبْلَ ذلك.وعن يحيى بن جعدة {21} في قوله: ﴿وَمَنْ دَخَلَهُ كَانَ آمِنًا﴾ قال: مِنَ النَّارِ.وقوله تعالى: ﴿وَلِلَّهِ عَلَى النَّاسِ حِجُّ الْبَيْتِ﴾ [ويقرأ ﴿حِج البيت﴾] {22} بالكسر {23}. فالمَفتوح: مصدرٌ، وهو لغة أهل الحجاز. والمكسور: اسم العَمَلِ {24}.قال سيبويه {25}: ويجوز أن يكون مصدرًا كـ (الذِكْرِ) و (العِلْم).وقوله تعالى: ﴿مَنِ اسْتَطَاعَ إِلَيْهِ سَبِيلًا﴾.قال الزجّاج {26}: موضع ﴿مَنِ﴾: خفض على البدل من ﴿النَّاسِ﴾؛ المعنى هو {27}: [و] {28} لله على من استطاع [إليه سبيلا] {29} مِنَ الناس، حِجُّ البيت {30}.قال الفرّاء {31}: وإنْ نويت الاستئناف بـ ﴿مَن﴾، كان جزاء، وكان الفعل به بعدها جزمًا، واكتفيتَ بما جاء قبله من جوابه، [والتأويل] {32} فيه: [من استطاع] {33} إلى الحج سبيلًا، فلِلّهِ {34} عليه حِجُّ البيت {35}. فقدم الجوابَ وهو مؤخر في المعنى، على مذهب العرب في التقديم والتأخير.وقال ابن الأنباري {36}: ويجوز أن يكون في موضع رَفْعٍ؛ على الترجمة للناس؛ على معنى: (هُمْ {37}: مَن استطاع إليه سبيلا).وأما معنى الاستطاعة في اللغة:فالاستطاعة مأخوذة مِن: (طاع له {38} الشيءُ يَطُوعُ)، و (طاع يُطيع): إذا انقاد له {39}. يقال: (فَرَس طَوْعُ العِنَانِ) {40}: إذا انقاد لك. و (تطاوع لي الأمرُ)؛ أي: سهل حتى تمكنت منه. فمعنى قولهم: (استطعت): استمكنت منه ووجدت السبيلَ إلى فعله؛ لمطاوعته لي وسهولته عَلَيّ {41}. وكلّ من تَوصَّلَ إلى مُرامِهِ، وتمكَّنَ من مطلبه، قالوا: (قد استطاعة، واسْطاعَه) {42}؛ لانقياد ذلك المطلوب له. والعرب تستعمل لفظ الاستطاعة {43} فيمن يصل إلى مرادهِ مِن غير مباشرة لذلك الفعل؛ كما يقولون: استطاع الأمير فتحَ بلدِ كذا، وإنْ لم يَتَوَلَّ بنفسه، وإنما توصل إليه برجاله وأمواله، فليس كل الاستطاعة بالمباشرة بالأعضاء.وأما التفسير: فقال ابن عباس في رواية عطاء {44}: يريد بـ (الاستطاعة) القوة. واختلف الناس في الاستطاعة الموجبة للحج: [فالذي عليه الجمهور أن معنى (الاستطاعة) ههنا، هو: القوة. والمستطيع للحج] {45}: هو القوي الذي لا يلحقه مشقة غير محتملة في الكَوْنِ على الراحلة، فهذا إذا ملك الزاد والراحلة، لزمه فرضُ الحج بنفسه. وإن {46} عدم الزاد والراحلة أو أحدَهما سقط فرضُ الحج عنه، فوجودُهُ {47} الزادَ والراحلةَ شرطٌ في وجوب الحج {48}. وهذا قول عمر بن الخطاب {49}، وابنه {50}، وابن عباس {51}، وسعيد بن جبير {52}، ومجاهد {53}، ومذهب الشافعي {54}، وابي حنيفة {55}، وأحمد بن حَنْبل {56}، وإسحاق {57}.[وروى جماعة من الصحابة] {58} عن النبي ﷺ أنه فسَّر استطاعة السبيل إلى الحَجِّ، بوجود الزاد والراحلة {59}.. . . . . . . . . . . . . . . . . . . . . .. . . . . . . . . . . . . . . . . . . . . .وقوله تعالى: ﴿وَمَنْ كَفَرَ﴾ قال ابن عباس {60}، والحسن {61}، وعطاء {62}: جَحَد فرضَ الحَجِّ.وقال الضحّاك {63}: لمّا نزلت آية الحج، جمع رسول الله ﷺ، أهلَ الأديان كلَّهم، فخطبهم، وقال: ""إن الله عز وجل كتب عليكم الحجَّ فحُجُّوا"". فآمَنَ بِهِ المسلمون، وكفر [بِهِ] {22} الباقون، فأنزل الله قولَه: ﴿وَمَنْ كَفَرَ فَإِنَّ اللَّهَ غَنِيٌّ عَنِ الْعَالَمِينَ﴾."
  3,98,"قوله تعالى: ﴿قُلْ يَا أَهْلَ الْكِتَابِ لِمَ تَكْفُرُونَ بِآيَاتِ اللَّهِ وَاللَّهُ شَهِيدٌ عَلَى مَا تَعْمَلُونَ﴾.وقال في هذه السورة: ﴿يَا أَهْلَ الْكِتَابِ لِمَ تَكْفُرُونَ بِآيَاتِ اللَّهِ] {1} وَأَنْتُمْ تَشْهَدُونَ﴾ {2} [آل عمران: 70].هناك خاطبهم تَلَطُّفًا في استدعائهم {3} إلى الحق؛ بأن وجه الخطاب إليهم، وههنا وجَّهَ الخطابَ إلى غيرهم إهانة لهم لصدهم عن الحق.فإن قيل: لم جاز أن يقال لليهود والنصارى (أهل الكتاب)، وهم لا يعملون {4} به، ولم يجز {5} مثلُ ذلك في أهل القرآن؟قيل: إن القرآن [اسمٌ] {6} خاصٌ لِما أَنزل الله على محمد ﷺ، فأما الكِتاب فيجوز أن يذهب به إلى معنى: يا أهل الكتاب المحرف عن جهته!.وأيضًا فإنهم نُسبوا إلى الكتاب، احتجاجًا عليهم بالكتاب لإقرارهم به كأنه قيل يا من يُقِرُّ بأنه من أهل الكتاب لم تكفرونَ بآيات الله؟.وقوله تعالى: ﴿لِمَ تَكْفُرُونَ بِآيَاتِ اللَّهِ﴾ توبيخٌ {7} لهم، على لفظ الاستفهام، لأنه كسؤال التعجيز عن إقامة البرهان. وقد ذكرنا مثل هذا {8}.والمراد بـ (الآيات) ههنا: الآياتُ التي أنزلها على نبيه محمد ﷺ، والمعجزات التي كانت له، والعلامات التي وافقت في صفته ما تقدمت البشارة به {9} وقوله تعالى: ﴿وَاللَّهُ شَهِيدٌ عَلَى مَا تَعْمَلُونَ﴾ قال ابن عباس {10}: يريد: حاضرٌ لأعمالكم.ومعنى الآية يؤول إلى أن {11} الله وبخهم على الكفر {12}، وأخبر أنَّه لا ينفع [الاستسرارُ به] {13}؛ لأن الله شهيدٌ عليه، مع أن شهادته توجب ردعهم عن الكفر."
  3,99,"قوله تعالى: ﴿قُلْ يَا أَهْلَ الْكِتَابِ لِمَ تَصُدُّونَ عَنْ سَبِيلِ اللَّهِ﴾.قال الفرّاء {1}: [يقال] {2}: (صَدَدْتُهُ، أصده صَدًّا)، و (أَصْدَدْتُه، إصْدادًا) {3}، وأنشد:أُناسٌ أَصَدُّوا الناسَ بالسيف عنهمُ ... صُدُودَ السَّواقِي عن أُنُوفَ الحَوائِمِ {4} وقرأ الحَسَنُ: (تُصِدُّون) بضم التاء، مِن: أَصَدَّ {5}.قال المفسرون {6}: وكان صدهم عن سبيل اللهِ بالتكذيب بالنبي ﷺ، وأنَّ صفَتَهُ ليست في كتابهم، ولا البِشَارَة به متقدِّمَةٌ عندهم.وقوله تعالى: ﴿تَبْغُونَهَا عِوَجًا﴾ قال اللِّحْيانِي {7}: (بَغَى الرجلُ في كل ما يطلبه من خير وشر، يَبْغِي، بُغاءً وبِغْيَة) {8}.وقال الفرّاء {9}: العرب تقول: (ابغني كذا)؛ يريدون: ابتغه لي. فإذا أرادوا: ابْتَغ معي، وأَعِنِّي على طلبه، قالوا: (أَبْغِنِي)، ففتحوا الألف، وكذلك يقولون: (أُحْلُبْنِي وأَحْلِبني) {10}، و (احْمِلْنِي وأَحْمِلْنِي)، و (اعْكُمْنِي وأَعْكِمْنِي) {11}، على هذا القياس.و (العِوَجُ) {12} بكسر العين، في الأَمْرِ، وفي الدين والقول: المَيْلُ عن الاستواء في الطريق، وفي كلِّ ما لا يُرى. وكلُّ قائمٍ مُنْتصِبٍ يُرَى عَوَجُهُ، يقال: (فيه عَوَج)، بالفتح؛ كالحائط، والقَنَاة {13}، والشجرة.يقال: (عَوِجَ الشيءُ، يَعوَجُ، عَوَجًا)، فهو (أَعْوَجُ) لكل ما يُرى، [و (عِوَجًا)] {14} لما لا يرى.وأما المعنى، فقال ابن الأنباري {15}: قوله تعالى: ﴿تَبْغُونَهَا عِوَجًا﴾، (البَغْيُ): يُقتَصَرُ {16} له على مفعول واحد، إذا لم يكن معه اللَّام، كقولك: (بَغَيْتُ المالَ والأجرَ والثوابَ). [وأريد ههنا] {17}: تَبغون لها عِوَجًا. فلما سقطت اللّامُ، عمل الفعلُ فيما بعدها، كما قالوا: (وَهَبْتُك {18} درهمًا)، وأصله: وهبت {19} لك درهما، ومثله: (صدْتُكَ ظَبْيًا)، يعنون: صدْتُ لك. وكذلك: (جئْتُكَ)، كما قد {20} (وَرَّثْتُكَ من المال جملة)، وأنشد:فَتَولَّى غلامُهم ثُمّ نادَى {21} ... [أَظَلِيمًا أَصِيدُكُم] {22} أم حِمَارا {23} أراد: أصيد لكم.والهاء في قوله: ﴿تَبْغُونَهَا﴾ عائدةٌ على السبيل؛ لأن السبيلَ يُؤَنَّثُ ويُذَكَّرُ {24}. و (العِوَجُ)، يعنى به: الزَيْغ والتحريف {25}؛ أي: تَلتمسون لسبيله الزيغ والتحريف بالشبه التي تُلَبِّسون بها، وتُوهِمون أنها تقدح فيها، وأنها مُعوَجَّة بتناقضها {26}.ويجوز أن يكون ﴿عِوَجًا﴾ في موضع الحال؛ والمعنى: تبغونها ضالِّين؛ وذلك {27} أنهم كانوا يَدَّعون أنهم على دين اللهِ وسبيلِه، فقال الله: إنكم تبغون سبيلَ اللهِ ضالِّين عنها. وهذا قول أبي إسحاق {28}، ذكر ذلك في سورة إبراهيم، عند قوله: ﴿وَيَبْغُونَهَا عِوَجًا أُولَئِكَ فِي ضَلَالٍ بَعِيدٍ﴾ {29}. وعلى هذا القول، لا يحتاج إلى إضمار اللّام في ﴿تَبْغُونَهَا﴾.وقال بعض أهل المعاني {30}: تأويل {31} الآية: يطلبون أن يُعْوِجُوا {32} سبيل الله، وأن يكون فيها عِوَج؛ لأن معنى (سبيل الله): الطريق التي هي الوُصْلَة {33} إلى رضا الله، فهم يطلبون أن يُعْوِجوا هذا الطريق؛ حتى لا يصل إلى رضا الله من سلكها بدلالة اليهود.وقوله تعالى: ﴿وَأَنْتُمْ شُهَدَاءُ﴾ قال ابن عباس {34}: يريد بها: في التوراة. [قال المفسرون] {35}: يعني: أنتم شُهداء أنَّ في التوراة مكتوبًا أنَّ دينَ اللهِ الذي لا يقبل غيره، هو الإسلام. وهذا معنى قول ابن عباس.وقال الزجاج {36}: أي: أنتم تشهدون بما قد ثبت في نفوسكم أن أمر النبي ﷺ حقٌ.وقيل {37}: معناه: وأنتم شهداء أن لا يجوز الصَدُّ عن سبيل الله."
  3,100,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا إِنْ تُطِيعُوا﴾ الآية.قال المفسرون: نزلت في الأوس والخزرج، حين أَغْرَى قومٌ من اليهود بينهم؛ ليفتنوهم {1} عن دينهم {2}."
  3,101,"وقوله تعالى: ﴿وَكَيْفَ تَكْفُرُونَ وَأَنْتُمْ تُتْلَى عَلَيْكُمْ﴾ هذا خطاب للمسلمين {1}، من الأوس والخزرج، في قول ابن عباس، وأكثر المفسرين {2}.﴿وَكَيْفَ﴾ ههنا [استفهام في معنى] {3} التعجب، وإنِّما [تَضَمَّنَت صيغةُ الاستفهام معنى] {4} التعجب؛ لأنها طلبٌ للجواب عَمَّا حَمَلَ على الفساد مما لا يصح فيه اعتذار.قال الزجاج {5}: أي: على أي حال يقع منكم الكفر، وآياتُ الله التي تدل على توحيده ونُبُوَّة نَبِيِّه {6} محمد ﷺ تتلى عليكم.وقوله تعالى: ﴿وَفِيكُمْ رَسُولُه﴾ قال الزجاج {7}: جائزٌ أن يقال: [فيكم رسوله، والنبي ﷺ شاهد، وهذا مختصٌّ بأيَّامه. وجائزٌ أن يقال لنا] {8} الآن: فيكم رسول الله؛ لأن آثاره، ومعجزته القرآن الذي أتى به، فِينا. فعلى هذا، كونُه فينا، لا يختص بزمان دون زمان.وقال الحسن {9}: نزلت الآية في مشركي العرب.وقوله تعالى: ﴿وَكَيْفَ تَكْفُرُونَ﴾ خطاب لهم، وهو توبيخٌ لهم على الكفر بعد نصب الحُجَّةِ، وبعثة الرسول.وقوله تعالى: ﴿وَمَنْ يَعْتَصِمْ بِاللَّهِ﴾ الاعتصام في اللغة: الاستمساك بالشيء، وأَصله مِن: (العِصمة). و (العِصْمَةُ): المَنْع في كلام العَرب. و (العاصِمُ): المانع. و (اعتصم فلانٌ بالشيء): إذا امتنع به {10}.قال ابن عباس {9} في قوله: ﴿وَمَنْ يَعْتَصِمْ بِاللَّهِ﴾، يريد {12}: يمتنع بسبيل الله. وقال الزجاج {13}: يستمسك بحبل الله.وقال ابن جريج {14}: ﴿وَمَنْ يَعْتَصِمْ بِاللَّهِ﴾؛ أي: يؤمن بالله."
  3,102,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا اتَّقُوا اللَّهَ حَقَّ تُقَاتِهِ﴾ قد ذكرنا ما في (التُقاة) عند قوله: ﴿إِلَّا أَنْ تَتَّقُوا مِنْهُمْ تُقَاةً﴾ [آل عمران: 28].ومعنى ﴿حَقَّ تُقَاتِهِ﴾، هو: أنْ يُطاعَ فلا يُعصى، ويذكَرَ فلا يُنْسى، ويُشْكَرَ فلا يُكْفَر. وهذا يروى عن عبد الله مرفوعًا، ورُوي موقوفًا عليه {1}.واختلفوا في هذه الآية: فقال ابن عباس في رواية الوالِبي {2}: لَمْ تُنسَخ هذه الآيةُ، ولكن ﴿حَقَّ تُقَاتِهِ﴾: أن يجاهدوا في الله حق جهاده، ولا تأخذهم {3} في الله لومةُ لائم، ويقوموا {4} بالقسط ولو على أنفسهم وآبائهم {5}.واختار الزجاج هذا الوجه، وهو أن الآية مُحكَمَةٌ غير منسوخة؛ لأنه قال {6} في قوله: ﴿اتَّقُوا اللَّهَ حَقَّ تُقَاتِهِ﴾: أي: اتَّقُوهُ فيما يحقُّ عليكم أن تتَّقُوهُ فيه.وقال {7} في رواية عطاء {8}: هذا منسوخٌ؛ لانهم قالوا: يا رسولَ الله! وما حَقُّ تُقاتِهِ؟ قال: ""يُذكر فلا ينسى، ويُطاع فلا يُعصى"" قالوا: ومَن يَقوَى على هذا؟ وشَقَّ {9} عليهم؛ فأنزل الله: ﴿فَاتَّقُوا اللَّهَ مَا اسْتَطَعْتُمْ﴾ [التغابن: 16].وإلى هذا القول، ذهب: قتادة {10} والرَّبِيع {11} والسُّدِّي {12} وابن زيد {13}، وقال مقاتل {14}: ليس {15} في آل عمران من المنسوخ إلا هذا {16}.. . . . . . . . . . . . . . . . . . . . . . . .وقوله تعالى: ﴿ولَا تَمُوتُنَّ إِلَّا وَأَنْتُمْ مُسْلِمُونَ﴾ لفظ {17} النَّهْي واقعٌ على الموت، والمعنى واقعٌ على الأمر بالإقامة {18} على الإسلام.المعنى: كونوا على الإسلام فإذا أورد {19} عليكم الموت، صادفكم على ذلك {20}.وقال بعض أهل المعاني {21}: هذا في الحقيقة، نَهْيٌ عن ترك الإسلام؛ المعنى: لا تتركوا الإسلام فإن الموت لابد منه، فمتى {22} صادفكم، [صادفكم] {23} عليه، إلّا أنه وضع كلامًا موضع كلام؛ لِحُسْنِ الاستعارة؛ لأنه لَمَّا كان يمكنهم الثبات على الإسلام، حتى إذا أتاهم الموت، لاقاهم وهم على الإسلام، صار الموت على الإسلام، بمنزلة ما {24} قد [دَخَلَ] {25} في إمكانهم. وقد مضى الكلام في هذا عند قوله: ﴿إِنَّ اللَّهَ اصْطَفَى لَكُمُ الدِّين﴾ [البقرة: 132]، الآية."
  3,103,"وقوله تعالى: ﴿وَاعْتَصِمُوا بِحَبْلِ اللَّهِ﴾. الآية. ذكرنا معنى (الاعتصام) {1}. وأما (الحَبْل)؛ فقال أبو عبيد {2}: أصل الحَبْل في كلام العرب، ينصرف على وجوهٍ منها: (العَهْدُ) وهو الأمان {3}، وذلك أن العرب كانت تخفيف بعضها بعضًا في الجاهلية، فكان {4} الرجل إذا أراد سفرًا أخذ عهدًا مِن {5} سيِّد القبيلة {6}، فَيَأمَن به ما دام في تلك القبيلة، حتى ينتهي إلى الأخرى، فيأخذ مثلَ ذلك أيضًا، يريد به الأمان. وربما أعطاه حَبْلًا أو سَهْمًا {7}.و {8} هذا المعنى ذَكَرَهُ الأعشى في قوله يذكر مَسِيرا له {9}:وإذا تُجَوِّزُها حِبَالُ قَبِيلةٍ ... أَخَذَتْ مِنَ الأخْرَى إليكَ حِبَالَها {10} قال أبو عبيد: {11} فالاعتصام بحبل الله؛ هو: ترك الفرقة، واتباعُ القرآن؛ لأن المؤمن إذا اتبع القرآن، أَمِنَ العذابَ {12}، كما أن الآخذ [عهد] {13} سيِّد القبيلة يأمَنُ به.قال ابن الأنباري {14}: لمَّا ذَكَرَ اللهُ عز وجل الاعتصامَ، ذكر الحبلَ، إذ كان العهد في التمسك به والتوصل، يجري مجرى الحبل، فأقامه الله تعالى مقامه، وأجراه مُجراهُ، ولم تزل العربُ تُشَبِّهُ العهودَ بالحبالِ.قال الشاعر: مازلتُ معتَصِمًا بِحَبْلٍ منكُمُ ... مَن حَلَّ ساحَتَكم بأسبابٍ نَجَا {15}أي: بعهد وذِمَّةٍ.فَسُمَي عهدُ الله حبلًا؛ لأنه سبب النجاة، كالحبل الذي يُتمسك به للنجاة من [سبي] {16}. ونحوها {17}.قال ابن عباس {18}: أي: تمسكوا بدين الله {19}. وقال قتادة {20}، والسدي {21}، والضحاك {22}: حبل الله، هو: القرآن {23}.. . . . . . . . . . . . . . . . . . . . . . .والخطاب في هذه الآية للأوس والخزرج {24}.وقوله تعالى: ﴿جَمِيعًا﴾ منصوب {25} على الحال؛ المعنى: اعتصموا بحبل الله، مجتمعين على الاعتصام به.وقوله تعالى: ﴿وَلَا تَفَرَّقُوا﴾ قال ابن عباس {14}: أي: كما كنتم في الجاهلية مقتتلين على غير دين الله.وقال قتادة {27}: لا تفرقوا عن دين الله الذي أمر فيه بلزوم الجماعة، والائتلاف على الطاعة.وقال الزجاج {28}: أي: تناصروا على دين الله، ولا تتفرقوا {29}.وقوله تعالى: ﴿وَاذْكُرُوا نِعْمَتَ اللَّهِ عَلَيْكُمْ﴾ قال ابن عباس {14}: يريد: دين الإسلام.﴿إِذْ كُنْتُمْ أَعْدَاءً﴾ يريد: ما كان بين الأوس والخزرج من الحرب التي {31} تطاولت عشرين {32} ومائة سنة، إلى أن ألَّفَ اللهُ عز وجل بين قلوبهم بالإسلام، فزالت تلك الأحقاد، وصاروا إخوانًا في الإسلام، مُتَوادِّينَ على ذلك {33}.قال الزجاج {34}: وأصل (الأخ) في اللغة [مِن] {35} [(التَّوَخِّي)، وهو] {36}: الطَّلَبُ. فالأخ [مقصده مقصد] {37} أخيهِ، وكذلك هو في الصداقة: أن تكون إرادةُ كلِّ واحدٍ من الأَخَوَيْنِ موافقةً {38} لِمَا يُريد صاحِبُه {39}.قال أبو حاتم {40}: قال أهل البصرة: (الإخوَةُ؛ في النَّسَبِ، و (الإخوان)؛ في الصَّداقة. قال: وهذا غلط {41}. يقال {42} للأصدقاء، و [الأنسباء] {43}: (إخوةٌ) و (إخوانٌ). قال الله سبحانه: ﴿إِنَّمَا الْمُؤْمِنُونَ إِخْوَةٌ﴾ [الحجرات: 10]، ولم يعْنِ {44} النَّسَبَ.وقال عز وجل: ﴿أَوْ بُيُوتِ إِخْوَانِكُمْ﴾ [النور: 61]، وهذا في النَّسَبِ. وقوله تعالى: ﴿وَكُنْتُمْ عَلَى شَفَا حُفْرَةٍ مِنَ النَّارِ﴾ (شَفَا الشيءِ): حَرْفُهُ، مقصورٌ {45}، مثل: شَفَا البئر. والجمع: (الأشفاء). ويقال لِمَا بين الليل والنهار، عِند غُروب الشَّمس، إذا غاب بعضها: (شَفَا).قال الراجز:أدركتُهُ قَبْلَ شَفًا أو بِشَفَا ... والشمسُ {46} قدكادت تَكُونُ دَنَفَا {47}.ومِن هذا، يقال: (أشفى على الشيء): إذا أشرف عليه؛ كأنه بلغ شَفَاهُ؛ أي: حَدَّهُ وَحَرْفَه {48}.قال ابن عباس {49}: يريد: لو مُتُّمْ على ما كنتم عليه في الجاهلية، لكنتم من أهل النار.وقوله تعالى: ﴿فَأَنْقَذَكُمْ﴾ قال الأزهري {50}: يقال: (نَقَذْتُهُ)، و (أنقَذتُه)، و (استَنْقذتُه)، و (تَنَقّذتُه)؛ أي: خلَّصته ونجَّيته. ومنه يقال {51}: (النقائِذ)، للخيل التي {52} تُنُقِّذَت مِن أيدي الناس {53} وقوله تعالى: ﴿مِنْهَا﴾.الكناية {54} راجعةٌ إلى النار، لا إلى الشَّفا؛ لأن القصد: الإنجاء مِن النَّارِ لا مِن شَفَا الحفرة. هذا قول الزجاج {55}.وقال غيره {56}: الكِناية تعود إلى الحفرة، فإذا أنقذهم الله من الحفرة، فقد أنقذهم من شَفَاها؛ لأن شفاها منها. على أنه يجوز أن يُذكَر المضافُ، والمضافُ إليه، ثم تعود الكنايةُ إلى المضاف إليه دون المضاف، فذكر الشفا، وعادت الكناية إلى الحفرة. كقول {57} جرير:[أَرَى مَرَّ] {58} السِّنِين أَخَذْنَ مِني ... كما أخَذَ السِّرَارُ مِنَ الهِلالِ {59} فَذَكَرَ (مَرَّ السِّنِين)، ثم أخبر عن السنين.وكذلك قول العَجَّاج:طُولُ اللَّيالي أسرعت في نَقْضِي ... طَوَيْنَ طُولِي وطَوَيْنَ عَرْضِي {60} وهذا إذا كان المضاف من جنس المضاف إليه {61}. فإن (مَرَّ السنين)، هو السنون. وكذلك (شَفَا الحفرة). فَذَكَرَ الشَّفَا وعادت الكناية إلى الحفرة {62}.وقوله تعالى: ﴿كَذَلِكَ يُبَيِّنُ اللَّهُ﴾ الكاف {63} في موضع نصب {64}؛ أي: مِثْلَ البَيَانِ الذي يُتلى عليكم، يُبَيِّنُ اللهُ لكم آياته لعلكم تهتدون؛ أي: لتكونوا على رجاء هدايته."
  3,104,"قوله تعالى: ﴿وَلْتَكُنْ مِنْكُمْ أُمَّةٌ﴾. الآية. (مِنْ) دخلت لتخص المُخاطَبِين مِن سائر الأجناس، و [ليس المُراد] {1} به التبعيض {2}، [وهذا] {3} كما تقول: (لِفُلان من أولادِهِ جُهْدٌ)، و (للأمير مِن غِلْمانِهِ عِدَّةٌ)؛ تريد بذلك: جميعَ أولاد وغلمانه، لا بعضهم. وقد قال الله تعالى {4}: ﴿فَاجْتَنِبُوا الرِّجْسَ مِنَ الْأَوْثَانِ﴾ [الحج: 30]، ليس {5} يأمرهم باجتناب بعضِ الأوثان، ولكن المعنى: اجتنبوا الأوثان، فإنها رِجْسٌ {6}. ومثله من الشعر، قولُ الأعشى {7}:أخُو رغائِبَ يُعْطِيها ويُسْأَلُها ... يأبَى الظُّلامَةَ مِنْهُ النّوْفَلُ الزُّفَرُ {8} وهو النَّوْفَلُ الزُّفَرُ لا بعضه {9}.وفيه قول آخر، وهو: إنَّ المراد: تخصيص للعلماء والأمراء، والذين هم أعلامٌ، في الأمر بالمعروف، فهو أمر لجماعة من جملة المسلمين، على الكفاية؛ كأنه قيل: لِيَقُمْ بذلك بعضكم، فأيُّ بعضٍ قام به سقط عن الآخر. ولو كان الأمر للجميع على غير الكفاية لم {10} [تسقط] {11} الفريضةُ بقيام البعض به {12}."
  3,105,"قوله تعالى: ﴿وَلَا تَكُونُوا كَالَّذِينَ تَفَرَّقُوا﴾ يعني: اليهود والنصارى في قول أكثر المفسرين {1}. ومعنى ﴿تَفَرَّقُوا﴾، أي: بالعداوةوقوله تعالى: ﴿وَاخْتَلَفُوا مِنْ بَعْدِ مَا جَاءَهُمُ الْبَيِّنَاتُ﴾ يعني: اختلفوا في الديانة. ولاختلافهم وجوهٌ: أحدها: أن اليهود اختلفوا مِن بعد موسى، فصاروا فِرَقًا، والنصارى اختلفوا من بعد عيسى، فصارت {2} فِرَقًا، فأمر الله عز وجل بالاجتماع على كتابه، وأعلَمَ أنَّ التَّفَرُّقَ {3} فيه، يُفضي بأهله إلى مثل ما أفضى بأهل الكتاب إليه من الكفر.والثاني: أن المراد بالاختلاف ههنا: اختلاف {4} أهل الكتاب في الإيمان {5} بمحمد ﷺ {6}: فبعضهم آمَنَ، وبعضهم كفر.والثالث: أنَّ الاختلاف ههنا: اختلاف اليهود والنصارى، و {7} كتابهم جميعًا {8} التوراة، وهم يختلفون، كل فرقة {9} منهم ليست على شريعة الأخرى.فإن قيل {10}: إذا {11} كان الاختلاف في الدِّين مذمومًا منهيًا عنه، فَلِمَ اختلفت هذه الأُمَّةُ في المذاهب والدِّيانات؟.قلنا: ذاك اختلافٌ في المُجْتَهَدَاتِ، وجميع ذلك مدلولٌ على صحته، فيصير كاختلاف الأحكام المنصوص عليها، مثل: حُكْم المقيم والمسافر، في الصلاة والصيام، ونحو ذلك من الأحكام، في أنَّ كلًّا منها مأذون فيه بالشرع.وقوله تعالى: ﴿مِنْ بَعْدِ مَا جَاءَهُمُ الْبَيِّنَاتُ﴾ ولم يقل (جاءت)؛ لجوازِ حذفِ علامَةِ التأنيث من الفعل في التقديم؛ تشبيهًا بعلامة التثنية والجمع {12}.وقد فسَّرنا ﴿الْبَيِّنَاتُ﴾ في مواضع {13}."
  3,106,"قوله تعالى: ﴿يَوْمَ تَبْيَضُّ وُجُوهٌ﴾ انتصاب اليوم على الظرف، والعامل فيه معنى قوله: ﴿لَهُمْ عَذَابٌ عَظِيمٌ﴾ أي: يثبت لهم العذاب يوم تبيض وجوه، و {1} يعذبون يوم تبيض وجوه {2}.ومعنى ابيضاض الوجوه: إشراقها {3} واستنارتها وسرورها واستبشارها {4}؛ لما تصير إليه من ثواب الله ورحمته؛ كقوله: ﴿وُجُوهٌ يَوْمَئِذٍ نَاضِرَةٌ﴾ [القيامة: 22]، وقوله: ﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ (38) ضَاحِكَةٌ مُسْتَبْشِرَةٌ﴾ [عبس:38 - 39].ومعنى اسْوِدادِها: حزنها، وكآبتها، وكسوفها؛ لما تصير إليه من العذاب؛ كقوله: ﴿وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ﴾ [عبس: 40]، وقوله تعالى: ﴿وَتَرْهَقُهُمْ ذِلَّةٌ﴾ [يونس: 27].قال ابن عباس في رواية عطاء {5}: تبيض وجوه المهاجرين والأنصار، وتسود وجوه بني قريظة والنضير والذين كذبوا بمحمد ﷺ.وقال في رواية سعيد بن جبير {6}: تَبْيَضُّ وجوهُ أهل السُنَّة، وتَسْوَدُّ {7} وجوهُ أهل البدعة.وقوله تعالى: ﴿فَأَمَّا الَّذِينَ اسْوَدَّتْ وُجُوهُهُمْ أَكَفَرْتُمْ﴾ قال الفرَّاء {8} والزجاج {9}: جواب (أمَّا) محذوفٌ مع القول، وهو: [الفاء] {10} مع قولٍ مُضمَرٍ، فلما سقط القول، [سقط] {11} الفاء معه {12}، والمعنى:(فيقال لهم: اكفرتم بعد إيمانكم؟)، وحَذَف القولَ؛ لأن في الكلام دليلًا عليه.ومثله كثير في التنزيل؛ كقوله: ﴿وَالْمَلَائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِنْ كُلِّ بَابٍ (23) سَلَامٌ عَلَيْكُمْ﴾ {13}، وقوله: {وَإِذْ يَرْفَعُ إِبْرَاهِيمُ الْقَوَاعِدَ مِنَ الْبَيْتِ وَإِسْمَاعِيلُ رَبَّنَا} {14}، وقوله: ﴿وَلَوْ تَرَى إِذِ الْمُجْرِمُونَ نَاكِسُو رُءُوسِهِمْ عِنْدَ رَبِّهِمْ رَبَّنَا﴾ {15} الآية.وقوله تعالى ﴿أَكَفَرْتُمْ بَعْدَ إِيمَانِكُمْ﴾ قال ابن عباس في رواية عطاء {16}: يعني: اليهود؛ شهدوا لمحمد عليه السلام {17} بالنُّبُوَّةِ، فَلمَّا قَدِمَ عليهم كذَّبوه وكفروا به. وهذا قول عكرمة {18} واختيار الزجاج {19}.وقال قتادة: هم أهل البدع كلهم {20}.وقد روي عن النبي ﷺ مرفوعًا في قوله: ﴿أَكَفَرْتُمْ بَعْدَ إِيمَانِكُمْ﴾؛ أي: بعد الإقرار بالميثاق الأول {21}.أخبرنا أبو علي ابن أبي القاسم المذكِّر {22}، أبنا محمد بن حمدوية النيسابوري {23}، [حدَّثنا علي بن حَمْشَاذ {24}، ثنا حُمَيد بن حَكيم الدقَّاق {25}، ثنا عباس بن الوليد الخلَّال {26} {27}، ثنا] {28} أبو صفوان، القاسم بن [يزيد العامري] {29}، ثنا يحيى بن كثير، أبو النضر {30}، ثنا عاصم الأحول {31} وداود بن أبي هند {32}، عن أبي العالية الرِّيَاحِي، قال:قال أُبَيُّ بن كعب {33}: (قال) {34} النبي {35} ﷺ في قوله، فذكره {36}."
  3,107,"قوله تعالى: ﴿وَأَمَّا الَّذِينَ ابْيَضَّتْ وُجُوهُهُمْ فَفِي رَحْمَةِ اللَّهِ﴾ قال ابن عباس {1}: يريد: ففي جنة الله.قال أهل المعاني {2}: وإنما قيل [لـ (الجَنَّةِ): رحمةُ] {3} الله؛ إعلامًا أنً العبدَ لا يدخلها إلا برحمته {4}، وإنْ اجتهد في طاعته.وقال آخرون {5}: رحمة الله ههنا: ثوابهُ لأهل طاعته.وقوله تعالى: ﴿هُمْ فِيهَا خَالِدُونَ﴾ قال أبو إسحاق {6}: كرَّر (في)؛ للتأكيد، الذي هو تمكين المعنى في النفس.وقال غيره {7}: كرَّر (في)؛ للبيان عن الصفتين {8}؛ المعنى: أنهم في رحمة الله، وأنهم خالدون فيها، فكل واحدةٍ منهما قائمةٌ بنفسها."
  3,108,"قوله تعالى: ﴿تِلْكَ آيَاتُ اللَّهِ﴾ أي {1}: تلك التي جرى ذكرها، حُجَجُ اللهِ وعلاماتُه.وصَلح ﴿تِلْكَ﴾ ههنا في موضع (هذه)؛ لانقضاء الآيات؛ فلمَّا انقضت، صارت كأنها بَعُدَت، فقيل فيها: ﴿تِلْكَ﴾ {2}.وقال ابن عباس {3}: ﴿تِلْكَ آيَاتُ اللَّهِ﴾، يعنى: القرآن {4}.وقوله تعالى: ﴿نَتْلُوهَا عَلَيْكَ﴾ أي: نُعرِّفُك إيَّاها. قال ابن عباس {5}: نُبَيّنها.وقوله تعالى: ﴿بِالْحَقّ﴾ أي: بأنَّها {6} حقٌ؛ كما تقول: أعامِلُك بالحَقِّ؛ أي: معاملتي حقٌّ.ويجوز أنْ يكون المعنى: نتلوها بالمعنى الحق؛ لأن معنى المَتْلُوِّ حقٌّ.﴿وَمَا اللَّهُ يُرِيدُ ظُلْمًا لِلْعَالَمِينَ﴾ فيعاقبهم بلا جُرْمٍ. (قاله) {7} ابنُ عبَّاس. وقال أبو إسحاق {8}: أعلم الله جل وعزَّ أنَّهُ {9} يُعذِّبُ مَن يُعذِّبُهُ باستحقاقٍ.[وحَسُنَ] {10} ههنا نفيُ إرادةِ الظلم للعالمين؛ لأن ذِكْرَ العقوبةِ قد تقدم، فبيَّنَ أنَّه لا يُعاقِب أحدًا {11} ظالمًا إيَّاهُ.فإنْ قيل: أليس لو فعل ذلك، لم يكن ظالمًا عندكم؟ فلِمَ {12} قال: ﴿وَمَا اللَّهُ يُرِيدُ ظُلْمًا لِلْعِبَادِ﴾ [غافر: 31]؟ ولو أراده لم يكن ظُلمًا؟ {13}.قلنا: سمَّاه ظلمًا؛ لأنه في سورة الظُّلْم {14}، ولو عَذَّبَ غير {15} مُستَحِقٍّ {16} للعذاب، لم يكن منه ظلمًا حقيقيًّا، ولكنه يكون في صورة الظلم، وقد يُسمَّى الشيءُ بالشيء، إذا أشبهه، وكان في صورته؛ كجزاء السيِّئة، يُسَمَّى: (سيئةً) {17}، وجزاء الاستهزاء، يُسمَّى {18}: (استهزاءً) في التنزيل {19}، ومثله كثير."
  3,109,""
  3,110,"قوله تعالى: ﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾ اختلف قول أهل المعاني في هذا:فقال الفرَّاء {1} والزجاجُ {2}، وغيرُهما {3}: كنتم خير أُمَّةٍ عند الله، في اللَّوْح المحفوظ. وقالا {4} أيضًا: معنى ﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾: أنتم خير أمة؛ كقوله: ﴿وَاذْكُرُوا إِذْ كُنْتُمْ قَلِيلًا فَكَثَّرَكُمْ﴾ [الأعراف: 86]، وقال في موضع آخر: ﴿وَاذْكُرُوا إِذْ أَنْتُمْ قَلِيلٌ مُسْتَضْعَفُونَ﴾ [الأنفال: 26]. وإضمارُ (كان) {5} وإظهارُها في مثل هذا، سواءٌ، إلّا أنها إذا ذُكِرت كانت للتأكيد، ووقوع الأمرِ لا مَحالة.قال ابن الأنباري {6}: وهذا القول ظاهرُ الاختلال؛ لأن (كان) يُلغى {7} مُوسَّطًا ومُؤَخَّرًا، ولا يُلغَى {7} مُقدَّما؛ تقول العرب: (عبدُ الله كان قائمٌ) و (عبدُ الله قائمٌ، كان)؛ على أنَّ (كان) مطروحة، ولا يقولون: (كانَ عبدُ الله قائمٌ)، على إلغائها، لأنَّ سبيلهم أن يبدأوا بما [تنصرف الغايةُ إليه، والمُلْغَى غير معني به، على أنَّه لا يجوز] {9} إلغاءُ الكَوْنِ في الآية؛ لانتصاب خبره، وإذا (أُعْمِلَ) {10} الكَوْنُ في الخَبَرِ، فنصبه، لم يكن مُلغًى.وقال بعضُ النحويين {11}: إنما قال: ﴿كُنْتُمْ﴾، ولم يقل: (أنتم)؛ لتَقَدُّمِ {12} البِشَارَةِ بهذه الأُمَّة، ولِمَا قد {13} كان يُسمَعُ مِنَ الخير في هذه الأمَّةِ؛ فكأنَّه {14} قيل: كنتم خير أُمَّةٍ بُشِّرَت بها. وهذا القول، يُروى معناه عن الحَسَنِ {15}.وقال بعضهم {16}: الكَوْنُ ههنا بمعنى: الوقوع والحُدُوث، وهي التَّامَّةُ التي لا تحتاج إلى خبر، فمعنى ﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾: حَدَثْتم خَيْرَ أُمَّةٍ، ووُجِدْتُم وخُلِقْتُم خَيرَ أمَةٍ، فيكون ﴿خَيْرَ أُمَّةٍ﴾ حينئذ بمعنى الحَالِ. وهذا معنى قولِ [ابن] {17} جَرِير {18}.وحكى الزجاجُ {19} عن بعضهم: كنتم [منذ] {20} آمنتم خيرَ أُمَّةٍ {21}.فأمَّا المُخاطَبون بهذا: فقال ابن عباس في رواية سعيد بن جبير {22}: هم الذين هاجروا مع النبي ﷺ إلى المدينة. وعلى هذا {23}: عِكْرِمة {24}، ومقاتل {25}، والضَّحَّاك {26}: أن هذا خاصة لأصحاب محمد {27} ﷺ. يدل على هذا القول:ما روي عن عمر رضي الله عنه، أنه قال في هذه الآية {28}: هي لأوَّلِنا، ولا تكون لآخرنا.وقال {29} في رواية عطاء {30}: يريد: أُمَّةَ محمد ﷺ. فعلى هذا: هم جميع المؤمنين من هذه الأمَّة.قال الزجاج {31}: هذا الخطاب، أصلُه: أنه خوطب به أصحابُ رسول الله ﷺ، وهو يَعُمُّ سائرَ أُمَّتِهِ.وقوله تعالى: ﴿أُخْرِجَتْ لِلنَّاسِ﴾ يُحتَمَلُ أنْ يكون ﴿للِنَّاسِ﴾، مِنْ صِلَةِ ﴿أُمَّةٍ﴾، أي: كنتم خير أمةٍ للنَّاسِ أُخْرِجَت، يعني: أفهم {32} خير أمَّة للنَّاس، تجيئون بهم في السلاسل، فتُدْخِلُونَهم في الإسلام. وهذا المعنى يُروى عن أبي هريرة {33}.وقال قتادة {34}: لم يُؤْمَرْ نَبِيٌّ وأمَّتُهُ بالقتال، إلّا هذه الأمَّة ونَبِيها، يُقاتِلُونَ، فَيَسْبُونَ الرُّومَ والتُّرْكَ والعَجَمَ، فَيُدْخِلونهم في دينهم، فهم خير أمَّة للنَّاس.ويُحتَمَلُ {35} أن يكون ﴿للِنَّاسِ﴾ {36} مِن {37} صِلَةِ ﴿أُخْرِجَتْ﴾؛ ومعناه: ما أَخرَجَ {38} [اللهُ] {39} للنَّاسِ أمَّةً، خيرًا {40} مِنْ أمَّةِ أحمد {41}؛ فهم {42} خير أمَّةٍ أُظْهِرَت {43} وأُخْرِجَت للنَّاس.وقوله تعالى: ﴿تَأْمُرُونَ بِالْمَعْرُوفِ وَتَنْهَوْنَ عَنِ الْمُنْكَرِ﴾ الظاهرُ أنَّ {44} هذا مَدْحٌ لهذه الأمَّة بهذه الخصال، وإخبارٌ عنهم بهذه الجملة، وحُكِي عن مجاهد أنه قال {45}: الخَيْرِيَّةُ في هذه الأمَّةِ على هذه الشَّرِيطَةِ {46}؛ يعني: كنتم خيرَ أُمَّةٍ، ما أَمَرْتُم بالمعروف، ونَهَيْتُم عن المنكر، وآمنتم بالله، وهذا أيضًا اختيار الزجاج {47}.والمَعْرُوفُ: كلُّ حَسَنٍ جميل، يُعرَفُ بجلالته، وعُلُوِّ قَدْرهِ {48}. ولا يجوز إطلاق هذه الصفة على القبيح، وإنْ كان يُعرَف، لأنه بمنزلة ما لا يُعْرَف؛ لخُمُولِهِ وسُقُوطِهِ."
  3,111,"قوله تعالى: ﴿لَنْ يَضُرُّوكُمْ إِلَّا أَذًى﴾ هذا وعْد مِنَ الله تعالى {1} للمؤمنين، في أهل الكتاب، أنَّهم منصورون عليهم، وأنَّه لا ينالهم منهم غَلَبَةٌ. ومعنى ﴿إِلَّا أَذًى﴾؛ أي: أذًى باللِّسانِ، مثل {2}: الوعيد، والبُهْت {3}.وقال الحسن {4} وقتادة {5}: أي: دعاء إلى الضلالة.وموضع ﴿إِلَّا أَذًى﴾ نصبٌ بالاستثناء المتصل؛ المعنى: لن يضروكم إلا ضَرَرًا يسيرًا. فـ (الأذى) وقع موقع الضَّرَر {6}.والأذى: مصدر (أَذِيْتُ بالشيء أذًى) {7}.وقوله تعالى: ﴿وَإِنْ يُقَاتِلُوكُمْ يُوَلُّوكُمُ الْأَدْبَارَ﴾ قال أبو على {8}: (وَلَّى) منقول مِن (فَعل)؛ تقول: (داري تَلِي دارَهْ)، وَ (وَلِيَتْ {9} داري دارَه)، فإذا {10} نَقَلْتَ {11} إلى (فَعَّلَ)، قلت: (ولّاني مآخيرَهُ) {12}، و (ولّاني مَيَامِنَه) {13}، فهو مثل: (فَرِحَ) و (فَرّحْتُه) {14}، ومثل هذا: قوله: ﴿لَيُوَلُّنَّ الْأَدْبَارَ﴾ [الحشر: 12]، وقوله: ﴿وَيُوَلُّونَ الدُّبُرَ﴾ [القمر: 45]، إلّا أنّ المفعول الثاني الزائِد في نَقل (فَعِلَ) {15} إلى (فَعَلَ) محذوفٌ من الآيتين، ولو لم يُحذَفْ لكان كقوله: ﴿يُوَلُّوكُمُ الْأَدْبَارَ﴾ {16}.وقوله تعالى: ﴿ثُمَّ لَا يُنْصَرُونَ﴾ محمول {17} على الاستئناف، لا على العطف {18}. والتقدير: ثم هم لا ينصرون.وإنَّما لم يُحتملْ {19} على العطف؛ لأنه غير مشاكل للمعطوف عليه؛ وذلك أن سبب التولية: القتال، وليس كذلك منعُ النصر؛ لأن {20} سببه: الكفر {21}. وأيضًا فإنه آخر آية، فكان الرفعُ فيه أقوى؛ ليشاكل {22} سائرَ الفواصل بالنُّون {23}، كما قال: ﴿وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾ [المرسلات: 36] {24}.قال المفسرون: صدق الله وعْدَه بالنصر، فلم يقاتل يهودُ {25} المدينة رسولَ الله ﷺ والمسلمين {26}، إلّا ولَوا منهزمين، وكانت الدَّبْرَةُ {27} عليهم، ففيه أعظم دلالة على (صحة) {28} نبوة محمد ﷺ."
  3,112,"قوله تعالى: ﴿ضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ﴾ قد مضى الكلام في معنى ضَرْبِ الذِّلَّةِ والمَسْكَنَةِ على اليهود، في سورة البقرة {1}.وقوله تعالى: ﴿أَيْنَ مَا ثُقِفُوا﴾ أي: وُجِدوا، وصُودِفوا {2}. ومضى الكلام في هذا عند قوله: ﴿حَيثُ ثَقفتُمُوهُم﴾ [البقرة: 191].وقوله تعالى: ﴿إِلَّا بِحَبْلٍ مِنَ اللَّهِ﴾ قال الفرّاء {3}: يقول: (إلَّا أنْ يَعتَصموا بحبل من الله)، فأضمر ذلك، وأنشد:رأتني بحَبْلَيْها فَصدّتْ مَخَافَةً ... وفي الحَبْلِ رْوْعاءُ الفُؤادِ فَرُوقُ {4} قال أراد: أقْبَلْتُ {5} بحبليها {6}.وقد نُعي هذا عليه، فقيل: لا يجوز حذف الموصول وإبقاء صلته {7}؛ وذلك أن الموصول لمّا احتاج إلى الصِّلَةِ للبيان عنه، فالحاجة إلى ذِكْرِهِ أشدُّ {8}، وإنَّما يجوز حذفُ الشيء للاستغناء بدلالة غيره عليه، فلو دَلّ دليل عليه لحُذف مع صلته؛ لأنه معها بمنزلِةِ شيءٍ واحد. ويجوز حذف الصلة دون الموصول؛ لأن الموصول [هو المعتمد عليه، والصلة تبع له؛ لأنها للبيان عنه، فإذا حُذِفَ الموصول] {9} وجب حذفُ الصلة معه؛ [لأنها تَبَعٌ] {10} له.وقد أخبرني العَرُوضي رحمه الله، عن الأزهري، قال {11}: أخبرني المُنْذِريُّ، عن ثعلب، أنه قال: هذا الذي قاله الفرّاء {12}، بعيدٌ {13}، ولكن المعنى إن شاءَ الله: ضربت عليهم الذِّلَّة أينما ثُقِفُوا؛ أي: بكلِّ مَكان إلّا بموضِع حَبْلٍ مِنَ الله، وهو استثناء مُتَّصل، كما تقول: (ضُرِبت عليهم الذِّلَّة في الأمكنة، إلّا في هذا المكان)، ثمّ حذف المضافُ {14}.قال: وقول الشاعر: (رأتني بحبليها)؛ هو كما تقول: (أنا بالله، وبك) {15}؛ أي: مُتَمَسِّك. فتكون الباءُ مِن صِلَة (رأتني متمسكًا بحبليها) {6}، فاكتفى بالرُّؤيَةِ {17} مِن التمسك.قال الأزهري: والقول، ما قال أبو العباس {18}.وقال الأخفش {19}: قوله: ﴿إِلَّا بِحَبْلٍ مِنَ اللَّهِ﴾ استثناء خارج عن {20} أول الكلام {21}، ومعنى (إلّا): لكِنْ {22}.واختار الزَّجَّاج هذا الوجه، فقال {23}: ما بعد الاستثناء {24} ليس من الأول؛ المعنى {25}: أنهم أذلَّاءُ، إلَّا أنهم يعتصمون بالعهد إذا أُعطوه.ونَصَرَ محمدُ بن جَرِير هذه الطريقة أيضًا، فقال {26}: إن أهل الكتاب (قد) {27} ضربت عليهم الذلة، سواء كانوا على عهد من الله، أو لم يكونوا على عهد، فلا يخرجون بالاستثناء {28} عن الذِّلة إلى العِزَّة.قال {29}: وتمام الكلام عند قوله: ﴿أَيْنَ مَا ثُقِفُوا﴾، ثم قال: ﴿إِلَّا بِحَبْلٍ مِنَ اللَّهِ﴾ أراد {30}: لكن قد يعتصمون بحبل من الله، أو قد يُثْقَفُونَ بحبل من الله، وحَبْلٍ مِنَ الناس كما قال: ﴿وَمَا كاَنَ لِمُؤمِنٍ أَن يَقتُلَ مُؤْمَنًا إِلا خَطأ﴾ [النساء:92]، فـ (الخَطَأ) وإن كان منصوبًا بما عمل فيِه ما قبل الاستثناء، فليس باستثناء مُتَّصل حتى يَدُلَّ على أنَّ قتلَه خطأ مباحٌ {31}، ولكن معناه: قد يقتله خطأ {32}.ومَن نَصرَ طريقة أبي العباس، قال {33}: إنَّ عِزَّ {34} المسلمين عِزٌّ لأهلِ الذِّمَةِ؛ لأنَّ أخْذَهم عَهْدَ المسلمين يَحقِنُ دماءَهم، ويمنع فُرُوجَهم وأموالهم عن الاغتنام بالسَّبْي، ثم هذا [العِزُّ] {35} لا يخرجهم عن الذِّلَّة في أنفسهم، فهم على ما وصفهم الله من الذِّلَّة أينما ثقفوا، وإنْ اعتصموا بالذِّمَة {36}.وأما التفسير: فقد ذكرنا معضى (الحبل) عند قوله: ﴿وَاعتَصِمُوا بِحَبْلِ اللَّهِ﴾ [آل عمران: 103] وبعض المفسرين يذهب إلى أن حبلَ الله ههنا الإسلام {37}؛ يعني [إلّا] {9} أنْ يُسْلِمُوا. وهذا بعيدة لعطف (حبل الناس) عليه، وإذا أسلموا، استغنوا عن حَبْلِ الناس، ولو أرادَ الله تعالى بالحبلَ الأوَّل: الإسلام، وبالثاني: الذِّمَّة؛ لقالَ: (أو حبل من الناس)، ولكن الصحيح: أن كلا {39} الحبلين؛ المراد به العهد، والذِّمَّة، والأمان، كما قال ابن عباس {40} يريد: بعهد مِنَ الله، وعهد مِنَ المؤمنين، وانما ذكر الله تعالى حبلَ الله مع حبل المؤمنين؛ لأن الأمان الذي يأخذونه {41} من المؤمنين، هو بإذن الله تعالى، فهو أمانٌ مِن جهته.وباقي الآية مشروح في سورة البقرة {42}."
  3,113,"قوله تعالى: ﴿لَيْسُوا سَوَآءً﴾ قال أبو الهيثم {1}: يقال: (فلانٌ وفلانٌ سَواء) {2}؛ أي: متساويان، و (قوم سَواء)؛ لأنه مصدر لا يُثَنّى ولا يُجمع. ومضى الكلام في (سواء) في أول سورة البقرة {3}.قال ابن الأنباري {4}: يريد: ليس أهل الكتاب الذين سبق ذكرُهم وتقدم وصفُهم، سواءً؛ أي: متساوين في دينهم ومذهبهم. ثمّ ابتدأ فقال {5}:﴿مِنْ أَهْلِ الْكِتَابِ أُمَّةٌ قَائِمَةٌ﴾ إنقطع الكلامُ عند (سواءً)، ورفع (الأُمة) بـ (مِنْ) {6}، وأضمر {7} (الأمَّة) المذمومة؛ لأن القائمة تكفي من التي ليست بقائمة، على مذهب العرب من الاكتفاء بالشيء من ضده، كما قال أبو ذؤيب {8}:عَصاني إليها القَلْبُ إِنّي لأمرها ... مطيعٌ فما أدري أَرُشْدٌ طِلابُها؟ {9} أراد: أم غيٌّ؟. فاكتفى بالرُّشد مِن غيره {10}.وقال آخر:وما أدري إذا يَمَّمْتُ أرضًا ... أُريدُ الخيرَ أيُّهُما يَلِيني {11} أراد {12}: أريد الخير والشر، فاكتفى بالخير من الشر {13}.ويجوز أن يرتفع (الأُمَّة) {14} بـ (سواء)، ويكون المعنى: لا يستوي من أهل الكتاب أمَّةٌ قائمةٌ، وأخرى غيرُ قائمةٍ.وهذا الذي ذكر {15} ابنُ الأنباري، كُلُّهُ مذهبُ الفرّاء في هذه الآية {16}.قال [أبو إسحاق] {17}: هذا الذي قاله {18}، خطأ فاحش في هذا المكان {19}؛ لأن ذِكْرَ أهلِ الكتابِ قد جرى في هذه القصة، وأنهم كانوا يكفرون بآيات الله، ويقتلون [الأنبياء] {20}، فأعلمَ اللهُ عز وجل أنَّ منهم المؤمنين، الذين هم {21} أمةٌ قائمةٌ، فما الحاجَةُ إلى أن يقال: غير قائمة؟ وإنما [المبدوء] {22} به ما {23} كان مِن فِعْلِ أكثرِهم؛ من الكفر والمُشَاقَّةِ للنبي ﷺ.فّذَكَرَ مَنْ كان منهم مباينًا لهؤلاء.فعند الزجّاج: لا يحتاج إلى إضمار الأمَّةِ المذمومة؛ لأن ذِكْرَ أهلِ الكتاب قد جرى، ثُمّ أخبر الله تعالى أنهم غير متساوين، بقوله: ﴿لَيْسُوا سَوَاءً﴾، وههنا وقف التمام. ثُمّ أنبأ بافتراقهم، فقال: ﴿مِنْ أَهْلِ الْكِتَابِ أُمَّةٌ قَائِمَةٌ﴾ {24}قال أبو بكر {25}: وقول الفرّاء هو الحق، واحتجاج الزّجاج عليه مُخْتَلٌّ {26} فاسد، لأنه لو اكتفى بقوله: ﴿ذَلِكَ بِأَنَّهُمْ كَانُوا يَكْفُرُونَ بِآيَاتِ اللَّهِ وَيَقْتُلُونَ﴾ [آل عمران: 112] من إضمار الأُمَّة الكافرة بعد ذِكْرِ الأُمَّة المؤمنة، لاكتفى بقوله عز وجل: ﴿مِنْهُمُ الْمُؤْمِنُونَ وَأَكْثَرُهُمُ الْفَاسِقُونَ﴾ [آل عمران: 110]، مِن ذِكْر الأُمَّتين جميعًا؛ فلما لم يكتفِ بالمؤمنين من الأُمَّة القائمة، لم يكتفِ بالفاسقين من الأُمَّة الكافرة، إذْ كان الله جل وعلا أتى بإخبار بعد إخبار، وَوَصْفٍ لهم إثْرَ وَصْفٍ؛ للزيادة {27} في الإفهام، والمبالغة في الإيضاح والبيان. والله أعلم.وكان أبو عبيدة يذهب مذهب الفرّاء: من إضمار الأُمَّة المذمومة، إلّا أنه لا يجعل تمامَ الوقف عند قوله: ﴿لَيْسُوا سَوَاءً﴾، ويقول {28}: (الأُمَّة) رُفِع بـ ﴿لَيْسُوا﴾.قال: وجُمِعت (ليس) وهي مُقَدَّمة، على لغة مَن يجمع الفعلَ وإن يقدم، كقولهم: (أكلوني البراغيثُ) {29}، واحتج بقول الفرزدق:ولكنْ دِيافِيٌّ أَبُوهُ وأُمُّهُ ... بِحَوْرانَ {30} يَعْصِرْنَ السَّلِيطَ أقارِبُهُ {31} ولم يرتض هذا القولَ أحدٌ مِن النحويين، وقالوا: هذا الذي قاله، لغة رديئة في القياس والاستعمال.أما القياس؛ فلأن الجمعَ عارِضٌ، والعارِضُ لا تُؤكَّد عَلامَتُه؛ لأنه بمنزلة ما لا يُعتَدُّ بِه، وليس كالتأنيث؛ للزومه، فَتُقَدَّم [له] {32} العَلامَةُ؛ لِتُؤذِنَ به قبل ذِكْرِهِ. ومع {33} [هذا؛ فجائز] {34} تركها فيه، فكيف {35} بالعارض {36}؟ ولزوم {37} الفعل للفاعل يغني عن التثنية والجمع فيه، فلا يدخل جمعٌ على جمع، كما لا يدخل تعريفٌ على تعريف.وأما الاستعمال؛ فإن أكثر العرب تَرَك هذه اللغة، وهي من لغة من لا يُرتَضى لغتُه، ولم ينزل الله عز وجل كتابَه إلا بأعرب اللغات، وأقربها من البيان. ومتى جُمع الفعلُ مُقدَّمًا [أوْهَمَ] {38} أسماءً {39} قبله، ولم يَقِفْ المخاطَبُ على معنى الكلام، إلّا بعد تفكر [من التَّوَهُّم] {32}.ومعنى ﴿أُمَّةٌ قَائِمَةٌ﴾: قال ابن عباس {41}: يريد: قائمة على الحَقِّ، وعلى أمر الله، لم تتركه كما تركه الآخرون.وقال مجاهد {42}: عادلة. وقال السُدِّي {43}: قائمة بطاعة الله. وقال ابن قتيبة {44}: مواظبة على أمر الله.وقوله تعالى: ﴿يَتْلُونَ آيَاتِ اللَّهِ﴾. أي: يقرأون كتاب الله.﴿آنَاءَ اللَّيْلِ﴾. ساعاته. والواحد: (إنًى)، مقصورٌ؛ مثل: (مِعًى) {45}. قال الراجز:لله درُّ جعفرٍ أيَّ فتًى ... مُشَمِّرٍ عن ساقه كُلَّ إنًى {46}ويجوز: (إنْيٌ)، مثل: (نِحْيٌ) {47}، و (حِسْيٌ) {48}.قال الأعشى:في كلِّ إنْيٍ حَذَاهُ الليلُ يَنْتَعِلُ {49} قال المفسرون: يعني بـ (الأُمَّة القائمة) ههنا: عبد الله بن سلام، ومن آمَنَ معه من أهل الكتاب. هذا قول ابن عباس {50}، وقتادة {51}، وابن جريج {52}.وقوله تعالى: ﴿وَهُمْ يَسْجُدُونَ﴾ قال الفرَّاء {53}، والزجاج {54}: أي: يُصلُّون؛ لأن التلاوة لا تكون في السجود ولا في الركوع. فالمراد بـ (السجود) (هنا) {55}: الصلاة، وإنَّما ذكرت بلفظ السجود؛ لأن السجود نهاية ما فيها من التواضع.فعلى ما ذكروا {56}؛ الواو في (وهم) واو الحال؛ أي: يقرأون القرآن مُصَلِّينَ.وقال غيرهما {57}: يجوز أن يكون المراد: حقيقة السجود، لا الصلاة؛ فيكون التأويل: يتلون آيات الله آناء الليل {58}، وهم مع ذلك يَسجدون. فليست الواوُ حالًا، وإنَّما هي عطف جملةٍ على جملة {59}. وعلى هذا؛ لم يعدل بالسجود عن ظاهره.وقال ابن مسعود {60}: هذه في صلاة العَتَمَة؛ يصلونها، ومن سواهم من أهل الكتاب لا يصليها."
  3,114,"قوله تعالى ﴿يُؤْمِنُونَ بِاللَّهِ وَالْيَوْمِ الْآخِرِ وَيَأْمُرُونَ بِالْمَعْرُوفِ﴾ قال ابن عباس {1}: يريد: بتوحيد الله. ﴿وَيَنْهَوْنَ عَنِ الْمُنْكَرِ﴾: يريد: عن الشرك بالله.وقال الزجاج {2}: أي: يأمرون باتِّباع {3} النبي ﷺ، وينهون عن الإقامة على مُشَاقَّتِه.وقوله تعالى: ﴿وَيُسَارِعُونَ فِي الْخَيْرَاتِ﴾ فيه وجهان لأصحاب المعاني:أحدهما: أنهم يبادرونها خوف الفَوْتِ بالموت {4}. والآخر: [يعملونها] {5} غير متثاقلين {6} فيها {7}.والسُّرْعة محمودةٌ، بخلاف العَجَلَة؛ وذلك أنَّ (السرعة): التقدم فيما ينبغي أن تتقدم {8} فيه. ونقيضها مذموم، وهو: (الإبطاء) {9}.و (العَجَلَة) مذمومة، وهي: التقدم فيما لا ينبغي أن تتقدم {10} فيه {11}. ونقيضها: (الأَنَاة) {12}، وهي محمودة."
  3,115,"قوله تعالى: ﴿وَمَا يَفْعَلُوا مِنْ خَيْرٍ فَلَنْ يُكْفَرُوهُ﴾ موضع ﴿يَفْعَلُوا﴾: جزم بالشرط، وجوابه: ﴿فَلَنْ يُكْفَرُوهُ﴾.وفيهما قراءتان {1}: الياءُ؛ للكناية عن الأُمَّةِ القائمة، ثم سائر الخلق داخل في هذا الشرط.ومن قرأ بالتَّاء؛ فلأن نظائره جاءت بالتَّاء؛ مخاطبة لجميع الخلائق، من غير تخصيص قوم دون قوم؛ كقوله: ﴿وَمَا تَفْعَلُوا مِنْ خَيْرٍ يَعْلَمْهُ اللَّهُ﴾ [البقرة: 197]، ﴿وَمَا تُنْفِقُوا مِنْ خَيْرٍ يُوَفَّ إِلَيْكُمْ﴾ {2} [البقرة: 272].ومعنى ﴿فَلَنْ يُكْفَرُوهُ﴾: فلن تعدموا {3} ثوابه، ولن تُجحَدوا جزاءَه {4} وسُمِّيَ منعُ الجزاء على عمل الخير كفرًا؛ لأنه بمنزلة الجَحْدِ له، والسَّتْر {5}؛ لئلا يقع الجزاء عليه. ولمَّا جعل ثواب الطاعة من الله تعالى شُكْرًا لأن معنى الشاكر في {6} صفته: أنَّه يُثِيب {7} على الطاعة {8} جعل منع الثواب كفرًا.ومعنى {9} قوله تعالى: ﴿وَاللَّهُ عَلِيمٌ بِالْمُتَّقِينَ﴾ أي: لا يُضيع شيئًا من أعمالهم {10}؛ لأن المُجازي به عليمٌ بهم."
  3,116,"قوله تعالى: ﴿إِنَّ الَّذِينَ كَفَرُوا﴾ قال ابن عباس {1}: يريد: قريظة والنضير {2}.﴿لَنْ تُغْنِيَ عَنْهُمْ﴾ أي: لن تدفع عنهم الضَّررَ إذا نزل بهم أموالُهم ولا أولادُهم. خُصَّا بالذكر؛ لأنهما مُعتَمَد ما يقع به الاغترارُ، فإذا لم يغنيا، فغناء مَن دونهما أبعد.وقال الزجّاج {3}: لأن رؤوساء اليهود مالوا إلى الأموال في معاندتهم النبي ﷺ، وإنما قامت لهم الرياسة، واكتسبوا الأموالَ بمعاندته.والدليل على ذلك: قوله تعالى: ﴿فَوَيْلٌ لِلَّذِينَ يَكْتُبُونَ الْكِتَابَ بِأَيْدِيهِمْ﴾ [البقرة: 79] الآية.وخص الأولاد؛ لأنهم أقرب أنسبائهم {4} إليهم.وقال بعض المفسرين {5}: لن تغني عنهم أموالُهم في الصدقات، ولا أولادُهم في الشفاعات، بخلاف المؤمن، فإنَّ المؤمنَ ينفعه مالُه في الكَفَّارات والصدقات؛ وأولاده في الشفاعة. والدليل على صحة هذا التفسير: ما ذكر مِن بُطلان نفقاتهم عقيب هذه الآية في:"
  3,117,"قوله تعالى: ﴿مَثَلُ مَا يُنْفِقُونَ فِي هَذِهِ الْحَيَاةِ الدُّنْيَا﴾ الآية.قال يَمَان {1}: نزلت في إنفاق أبي سفيان والمشركين في بدر وأحد، على عداوة النبي ﷺ.وقال مقاتل {2}: يعني: نفقة سَفَلَة اليهود على علمائهم {3}.وقال مجاهد {4}: يعني جميع نفقات الكفار في الدنيا، وصدقاتهم.الزجّاج {5}: كل ما أُنفق في التظاهر على عداوة الدين.ومعنى (المَثَل): الشَّبَهُ الذي يصير كالعَلَمِ؛ لكثرة استعماله فيما يُشَبَّه به {6}. ولا بُدَّ من تقدير محذوفٍ من الكلام، حتى يتقابل المثلان في التشبيه {7}، وهو: مَثَل إهلاك ما ينفقون، كَمَثَل إهلاك ريح. فحذف الإهلاك؛ لدلالة آخر الكلام عليه {8}.وقوله تعالى: ﴿كَمَثَلِ رِيحٍ فِيهَا صِرٌّ﴾ اختلفوا في (الصّر): فقال أكثر المفسرين، وأهل اللغة {9}: الصِّرُّ: البَرْد الشديد.وهو قول ابن عباس في رواية عطاء {10}، وقتادة {11}، والربيع {12}، والسدّي {13}، وابن زيد {14}.ومعنى الآية: أن إنفاقهم في الدنيا على عداوة الدين، أفسد عليهم أعمالَهم في الآخرة، كما أفسدت هذه الريحُ -التي فيها الصِّرُّ- الزرعَ الذي وقعت به {15}.وقال الزّجاج {16}: أعلم الله -تعالى-: أن ضَرَرَ نفقتهم عليهم، كضَرَرِ هذه الريح على {17} هذا الزرع.وقال ابن عباس {18}: الصِّرُّ: السَّمُومُ الحارَّةُ التي تقتل {19}.وإلى قريبٍ من هذا القول ذهب ابنُ كيسان، وابن الأنباري {20} (فقالا) {21}: الصِّرُّ: النار. وهو قول مجاهد -في رواية ابن أبي نَجِيح- {22}.قال ابن الأنباري {23}: وإنما وُصِفت النارُ أنها صِرٌّ؛ لتَصْرِيَتِها {24} عند الالتهاب.قال الزجاج {25}: وهذا غير ممتنع. وصوت لهيب النار يُسمَّى صِرًّا {26}، ومن هذا: (صرير الباب). ويقال: (صَرْصَرَ الأخطَبُ {27} صَرْصَرَةً) {28}. و (الصَّرَّةُ): الصَّيْحة {29}، ومنه قوله تعالى: ﴿فَأَقْبَلَتِ امْرَأَتُهُ فِي صَرَّةٍ فَصَكَّتْ﴾ {30} [الذاريات: 29]. وقول ابن عباس على هذا يتوجه، فإن السموم الحارة لها صوت، ألا ترى إلى قول الراعي:فَعُجْنَا على رَبْعٍ بِرَبْعٍ تَعُودُهُ ... مِنْ الصَّيفِ جَشَّاءُ الحَنِينِ نَؤُوجُ {31} فعلى هذا، قوله: ﴿رِيحٍ فِيهَا صِرٌّ﴾ أي: سَمُوم؛ كالنار أحرقت الزرع، أو نارٌ لها صوت {32}.وروى ابن الأنباري -بإسناده- عن السُّدِّيّ، عن أبي مالك {33}، عن ابن عباس، في قوله: ﴿فِيهَا صِرٌّ﴾، قال: فيها نار {34}.وقوله تعالى: ﴿ظَلَمُوا أَنْفُسَهُمْ﴾ قال ابن عباس {35}: جحدوا نعمة الله عندهم. وقال آخرون {36}: ظلموا أنفسهم بالكفر والمعصية.﴿وَمَا ظَلَمَهُمُ اللَّهُ﴾ لأنَّ كلَّ ما فعله بخلقه فهو منه عدلٌ، ومَن تَصَرَّف في حقيقة مُلْكِهِ، لا يُوصَفُ تصرفُهُ بأنه ظلم.﴿وَلَكِنْ أَنْفُسَهُمْ يَظْلِمُونَ﴾ لأنَّ الإنسان -بالكفر والعصيان- هو الذي يَظلِمُ نفْسَه.قال أهل المعاني: وفي هذا حسرة شديدة لهؤلاء المنفقين، ومصيبة عظيمة؛ لأنهم رجوا {37} فائدة نفقاتهم، وعائدتها، فعادت عليهم بالمَضَرَّة {38}، كما رجا أصحابُ الزرع عائدةَ زرعِهم، فضربته {39} الريحُ وأهلكته {40}."
  3,118,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا لَا تَتَّخِذُوا بِطَانَةً مِنْ دُونِكُمْ﴾ الآية. قال المفسرون: نزلت في النهي عن مداخلة اليهود والمنافقين {1}.و (البِطَانَة): قال أبو حاتم، عن الأصمعي {2}: (بَطَن فلانٌ بفلان، يَبْطُنُ به بُطُونًا، وبِطَانَةً) {3}: إذا كان خاصًّا به، داخلًا في أمره. فـ (البِطانة) {4} مصدرٌ يُسَمَّى به الواحد والجمع.قال الشاعر:أولئك خُلْصاني نَعَمْ وبِطانَتِي ... وهُمْ عَيْبَتِي {5} مِن دونِ كلِّ قَرِيبِ {6} وبِطَانة الرجل: خاصَّتُه الذين يَسْتَبْطنون {7} أمْرَهُ. وأصله من: (البَطْنِ) خلاف الظهر، ومنه {8}: (بِطانَة الثوب)، خلاف (ظهارته) {9}.وقوله تعالى: ﴿مِنْ دُونِكُمْ﴾ أي: مِن دون المسلمين، ومِن غير أهل ملَّتكم، وظاهر هذا للمخاطَبِين، وهو يريد: جميع المسلمين. يعني لا تتخذوا بطانة مِن دون {10} المسلمين {11}.وصلح أن يُعَبَرَ ﴿مِنْ دُونِكُمْ﴾ عن هذا. كما يقول الرجل: (قد قتلتمونا [وهزمتُمُونا] {12}؛ وهو يريد قتلتم إخواننا. وقد تقدم لهذا نظائر {13}.وقوله تعالى: ﴿لَا يَأْلُونَكُمْ خَبَالًا﴾ يقال {14}: (أَلَوْتُ في الشيء، أَلْوًا {15}؛ أي: قَصَّرت.قال امرؤ {16} القيس:وما المَرْءُ ما دامت حُشَاشَةُ {17} نَفْسِهِ ... بِمُدْرِكِ أطرافِ الخُطُوبِ ولا آلِي {18}قال أبو الهيثم {19}:يقال: (أَلاَ، يَألُوا): إذا فَتَرَ {20}، وضعُف، وقَصَّر {21}، ومثله: (أَلَّى {22}، وائْتَلَى)، وأنشد: فما أَلَّى بَنِيَّ ولا أساؤوا {23}أي: ما قصَّروا {24}.قال امرؤ القيس:أَلاَ رُبَّ خَصْمٍ فيكِ أَلْوَى رَدَدْتُهُ ... نَصِيحٍ على تَعْذالِهِ غيرِ مُؤْتَلِي {25}أي: غير مقصر.و (الخَبَالُ) -في اللغة-: الفساد والشر. ومنه قوله تعالى: ﴿مَّا زَادُوكُم إِلَّا خَبَالًا﴾ {26}؛ أي {27}: يريد {28}: [إلَّا] {29} شرًّا {30}.ويقال: (في قوائم الدابَّة خَبَالٌ)، و (في عَقْلِهِ خبالٌ)؛ أي: و (رجلٌ مُخَبَّلُ الرأي): فاسدُهُ، [و] {31} مُضْطَرِبُهُ. و (خَبَلَهُ {32} الحُبَّ)؛ أي: أفسده {33}.ومعنى قوله: ﴿لَا يَأْلُونَكُم خَبَالًا﴾ أي: لا يَدَعُونَ جهدَهم في مضرَّتِكم، وفسادكم {34}.يقال: (ما أَلَوْتُهُ نُصْحًا)؛ ما قصَّرت في نصيحته {35}، و (ما أَلَوْتُه شَرًّا)، مثله. قال الزجَّاج {36}: ﴿لَا يألُونَكُم خَبَالًا﴾ أي: لا يُبْقون {37} غايةً في إلقائكم فيما يضركم {38}.ومحل قوله: ﴿لَا يأْلُونَكُمْ﴾: النَّصْبُ، لأنه صفة البطانة {39}.وانتصب {40} (الخَبَالُ) بـ (الأَلْوِ)؛ لأنه يتعدى إلى مفعولين، كما ذكرنا {41}. وإن شئت نصبته {42} على المصدر؛ لأن معنى قوله: ﴿لَا يَأْلُونَكُمْ خَبَالًا﴾: يُخبلونكم خَبَالًا {43}.وقوله تعالى: ﴿وَدُّوا مَا عَنِتُّمْ﴾.قال المفسرون {44}: ودُّوا عَنَتَكم {45}. والعَنَت {46}: دخول المشقة على الإنسان، ووقوعه فيما لا يستطيع الخروج منه. يقال: (عَنِتَ الرجل): إذا صار إلى هذه الحالة. و (عَنِتَ) -أيضًا-: إذا أثم {47}.و (ما) {48} -ههنا- (ما) المصدر، كقوله: ﴿عَزِيزٌ عَلَيْهِ مَا عَنِتُّمْ﴾ {49}؛ أي {50}: عزيز عليه عنَتُكم {51}، وهو: لقاء الشِّدَّةِ والمَشَقَّةِ {52}.وقيل {53} في قوله: ﴿وَدُّوا مَا عَنِتُّمْ﴾، أي: ما أعنتكم من مكروه، وضُرٍّ {54}. وهو معنًى وليس بتفسير.وقال السُّدِّي {55}: ودُّوا ضلالكم عن دينكم؛ وذلك أن الحَيْرَة بالضلال مشقة.ومضى الكلام في (العَنَتِ)، و (الإعْنَاتِ) عند قوله: ﴿وَلَوْ شَاءَ اللَّهُ لَأَعْنَتَكُمْ﴾ [البقرة: 220].ولا محل لقوله: ﴿وَدُّوا مَا عَنِتُّمْ﴾؛ لأنه استئنافٌ بالجملة. وقيل {56}: إنَّه من صِفَةِ البِطَانَةِ، ولا يصح هذا؛ لأن البطانة قد وصفت بقوله: ﴿لَا يألُونَكُم خَبَالًا﴾.فلو رجع هذا إلى البطانة، لأدخل حرف العطف؛ لأنك لا تقول في الكلام: (لا تَتَّخذ صاحبًا يَشْتِمُكَ، أحبَّ مُفارقَتَكَ) {57}.وقوله تعالى: ﴿قَد بَدَتِ اَلبغضَاَءُ مِن أَفوَاهِهِم﴾ البَغْضاءُ: شِدَّةُ البُغْضِ {58} قال الفراءُ {59}: البغضاء: مصدرٌ مؤنثٌ.ومعنى الآية: قد ظهرت العداوةُ من أفواههم، بالشتِيمَةِ والوَقِيعَةِ في المسلمين، وإطلاع المشركين على أسرارهم {60}.وواحد (الأفواه): فَمٌ. وأصله {61}: (فَوْهٌ)، بوزن: (سَوْطٍ)، فحُذِفت الهاءُ تخفيفًا، كما حذفت من (سَنَةٍ)، فيمن قال:لَيْسَتْ {62} بِسَنْهاء ... {63}.و (عملت {64} معه مُسَانَهَةً) {65}، ومن: (شاةٍ) {66}، و (شَفَةٍ) {67}، فصار التقدير: (فَوْ) {68}. فلما صار الاسم على حرفين، لا ثاني منهما {69} حرف لين، كرهوا حذفه للتنوين، فَيُجْحِفُوا به، فأبدلوا من الواوِ مِيْمًا لقرب الميم من الواو؛ لأنهما {70} شفويتان {71}، وفي الميم هُوِىٌّ في الفَمِ يضارع امتداد الواو.والدليل على أن أصله (فَوْه): جمعه على (أفواه)، نحو: (سَوْطٍ، وأسواط)، و (حَوْضٍ، وأحواض)، و (طَوْقٍ، وأطواق).وقال أُمَيَّةُ {72}:وما فَاهُوا بِهِ أبدًا مُقِيمُ {73}.وقالوا: (رجلٌ مُفَوَّهٌ): إذا أجادَ {74} القولَ، و (أَفْوَهُ): إذا كان واسع الفَمِ. وجمعه: (فُوْهٌ) {75}.قال الشَّنْفَرَى {76}:مُهَرَّتَةٌ {77} فُوْهٌ كأنَّ شُدُوقَها ... شُقُوقُ العِصِيِّ {78} كالِحاتٌ {79} وبُسَّلُ {80}ذكر ذلك أبو الفتح الموصلي {81}.قوله تعالى: ﴿وَمَا تُخْفِي صُدُورُهُمْ أَكْبَرُ﴾ {82} أي: من العداوة والخيانة {83}. وقيل {84}: من الكفر بالله ومحمد ﷺ.وقوله تعالى: ﴿قَدْ بَيَّنَّا لَكُمُ الْآيَاتِ﴾ قال عَطَاء {85}: يريد: ما أمرهم به مِن طاعته، وما نهاهم عنه من معصيته.وقال السُّدِّي {85}: قد بيَّنَّا آياتهم؛ لتعرفوهم بها.وقوله تعالى: ﴿إِنْ كُنْتُمْ تَعْقِلُون﴾ قيل {87}: إن كنتم تعقلون موقعَ يقع {88} البيان، ومبلغَ عائدتِهِ عليكم {89}.وقيل {90}: إن كنتم تعقلون الفَصْلَ بينَ ما يستحقه العدوُّ، والوَلِيُّ."
  3,119,"قوله تعالى: ﴿هَا أَنْتُمْ أُولَاءِ تُحِبُّونَهُمْ﴾ الآية. مضى الكلام في (ها) مع (أنتم) عند قوله: ﴿هَا أَنْتُمْ هَؤُلَاءِ حَاجَجْتُمْ﴾ [آل عمران: 66].قال الفراء {1}: العرب إذا جاءت إلى اسمٍ مَكنيٍّ قد وُصِفَ بـ (هذا) و (هذان) و (هؤلاء)، فَرَّقوا بينَ (ها) وبين (ذا)، المَكنِيَّ بينهما، وذلك في جهة التقريب {2}، فيقولون: (أين أنت؟) فيقول القائلُ:(ها أنا ذا) {3}. ولا يكادون يقولون: (هذا أنا) {4}. و-كذلك-: التثنية والجمع، ومنه {5}: ﴿هَا أَنْتُمْ أُولَاءِ تُحِبُّونَهُمْ﴾، وربَّما أعادوا (ها) فوصلوها بـ (ذا)، و (ذان)، و (أولاء) {6}، فيقولون: (ها أنت هذا)، و (ها أنتم هؤلاء). قال الله -تعالى-: ﴿هَا أَنْتُمْ هَؤُلَاءِ جَادَلْتُمْ﴾ [النساء: 109].قال {7}: وإنَّما فعلوا ذلك؛ ليفصلوا بين (التقريب) وغيره. ومعنى (التقريب) عنده: أنك لا تقصد أن تخبر {8} عن (هذا) بالاسم {9}، فيقولون {10}: (هذا زيد).وإذا {11} كان الكلام على غير تقريبٍ، وكان {12} مع اسم ظاهر، جعلوا (ها) موصولةً بـ (ذا)؛ فقالوا {13}: (هذا زيد)، و (هذان الزيدان) {14}، إذا كان على خَبَرٍ يكتفي كلُّ واحدٍ بصاحبه بلا [فِعْلٍ] {15}. فقد {16} أنشد ابنُ الأنباري {17} على هذا قولَ أُمَيَّة بن أبي الصَّلْت:لَبَّيْكُما لَبَّيْكُما ها {18} أنا ذا لَدَيْكُما {19} فَجَعَل (أنا) بين (ها) و (ذا)؛ لتقريبه طاعتهما، والانقياد لأمرهما.وقال الزَّجاجُ {20}: (ها) -ههنا- تَنْبيهٌ {21} دَخَلَ على (أنتم) و {22} (أولاء) في معنى: (الذين)، كأنه قيل: (ها أنتم الذين تُحِبُّونَهم ولا يُحِبُّونَكم). فيكون ﴿تُحِبُّونَهُمْ﴾ صِلَةً {23}.قال {24}: وكُسِرت (أولاء)؛ لأن أصلها السكون، لكن الهمزة كُسِرت؛ لسكونها وسكون الألف. وإنما كان أصلُها السكون؛ لأنها بمنزلة حَرْفِ الإشارة، والحروفُ أصلها السكون.وسنذكر الفرقَ بين (أولاء) و (أولئك) عند قوله: ﴿فَأُولَئِكَ عَسَى اللَّهُ أَنْ يَعْفُوَ عَنْهُمْ﴾ [النساء: 99].قال المفسرون: هذا خطاب للمؤمنين، أُعلِموا فيه أن منافقي أهلِ الكتابِ {25} لا يُحِبُّونَهم، وأنهم يَصْحَبونَ هؤلاء المنافقين بالبِرِّ، والنصيحة التي يفعلها المُحِبُّ.قال المُفَضَّلُ {26}: معنى ﴿تُحِبُّونَهُمْ﴾: تريدون لهم الإسلام، وهو خير الأشياء. ﴿وَلَا يُحِبُّونَكُمْ﴾؛ لأنهم يريدونكم على الكفر، وهو الهلاك.قوله تعالى: ﴿وَتُؤْمِنُونَ بِالْكِتَابِ كُلِّهِ﴾ أي: بالكتب كلها، وهو اسم جنس؛ كقولهم: كثر الدرهم في أيدي الناس، أو لأن الكتاب مصدر، فيجوز أن يسمى {27} به الجمع.قال ابن عباس {28}: يريد: الذي أُنزل على محمد، والذي أنزل على عيسى، والذي أنزل على موسى، وهم لا يؤمنون بشيء منه؛ لأنهم {29} يَنتحِلون {30} التوراةَ، ولم يعلموا بما {31} فيها.وقوله تعالى: ﴿وَإِذَا خَلَوْا عَضُّوا عَلَيْكُمُ الْأَنَامِلَ مِنَ الْغَيْظِ﴾ يقال: عَضَّ، يَعَضُّ، عَضًّا، وعَضِيضًا) {32}.قال امرؤ القَيس:كَفَحْلِ الهِجَانِ يَنْتَحِي لِلعَضِيض {33}والأنامِل: جمع أَنْمُلَة {34}؛ وهي: أطراف الأصابع {35}.[والغَيْظُ: الإغضابُ {36}، يقال؛ (غاظَهُ الشيءُ)؛ أي: أغضبه {37}.وعَضُّ الأصابع] {38}، والأنامِل، واليد {39}: مِن فِعْلِ المُغضَبِ {40}، الذي فاته ما لا يقدر [على] {38} أن يتداركه، أو يرى شيئًا يكرهه، ولا يقدر على أن يُغيِّره. ثم كثر استعمال {42} [هذا] {38} فيه، حتى استُعمِلَ مَثَلًا، مجازًا، فيقال للمُغضبِ: (هو يَعَضُّ يدَهُ غَضَبًا وحَنَقًا) {44}، وإنْ لم يكن هناك عَضٌ. قال الشاعر:قَدَ أَفْنَى أنامِلَهُ أَزْمُهُ ... فأَضْحى يَعَضُّ عَلَيَّ الوَظِيفا {45} وقال أبو طالب {46}:يَعَضُّونَ غَيْظًا خلفَنا بالأَنَامِلِ {47}قال المفسرون {48}: وإنما ذلك لِما يَرَوْنَ من ائتلاف المؤمنين، واجتماع كلمتهم، وصَلاح ذات بَيْنِهم.وفي الآية تقديم وتأخير؛ لأن التقدير: وإذا خَلَوْا عَضُّوا الأنامِلَ مِنَ الغَيْظِ عليكم.وقوله تعالى: ﴿قُلْ مُوتُوا بِغَيْظِكُمْ﴾ خرج هذا مخرج الأمر، وليس معناه الأمرَ، لكنَّه دعاء عليهم، أمر اللهُ نَبِيَّهُ ﷺ بأن يَدْعُوَ عليهم بهذا {49}.ومعنى موتِهم بِغَيْظِهم: هو أن يَدُوم غيظُهم إلى أن يموتوا، أو {50} يصير الغيظُ قاتِلَهم، وسببَ موتهم {51}.وقوله تعالى: ﴿إِنَّ اللَّهَ عَلِيمٌ بِذَاتِ الصُّدُورِ﴾ أي: بما فيها من خير وشر. قال {52} النحويون {53}: (ذات) تأنيث (ذو). وإذا وقَفْتَ {54} على (ذات): فمنهم مَن يَدَعُ التَّاء على حالها؛ لكثرة ما جرى على اللسان بالتَّاء، ومنهم من يردها إلى هاء {55} التأنيث. وهو القياس.وقال ابن الأنباري {56}: ﴿عَلِيمٌ بِذَاتِ الصُّدُورِ﴾، أي: بما فيها {57} من خير وشر {58}. معناه: بحقيقة القلوب من المضمرات. فتأنيث (ذات) {59} لهذا المعنى؛ كما قال: ﴿وَتَوَدُّونَ أَنَّ غَيْرَ ذَاتِ الشَّوْكَةِ تَكُونُ لَكُمْ﴾ [الأنفال: 7]، فَأَنَّثَ؛ لمعنى (الطائفة)؛ كما يقال: (لقيته ذات يوم)، فيؤنثون؛ لأن مقصدهم: لقيته مرَّةً في يوم. وقد ذكرنا زيادة في الشرح والبيان عند قوله ﴿إِنَّ الَّذِينَ تَوَلَّوْا مِنْكُمْ يَوْمَ الْتَقَى الْجَمْعَانِ﴾ [آل عمران: 155]."
  3,120,"قوله تعالى: ﴿إِنْ تَمْسَسْكُمْ حَسَنَةٌ تَسُؤْهُمْ﴾ الآية. (المَسُّ)، أصله باليد، ثم يُسَمَّى المُقارِبُ والمخالِطُ: (ماسًّا)؛ تشبيهًا بالمتناوِلِ للشيء، فيقال: (أمْرُكَ يَمَسُّنِي)؛ أي: يَكْرِثُني {1}، ويهمني، ويَقْرُبُ مِن قلبي. فأشبه بذلك المَسَّ بالأصابع {2}.ومعنى (الحسنة) -ههنا-: النصر {3}، والغنيمة، والخِصْب {4}.و (تسؤْهم)، أي: تُخْزِيْهم، يقال: (ساءَهُ، يَسُوءُهُ، مَسَاءَةً {5}، ومَسَائِيَةً) {6}، فـ (استاءَ) {7}؛ أي: اهتم {8}.وقوله تعالى: ﴿وَإِنْ تُصِبْكُمْ سَيِّئَةٌ﴾ أي: نالكم ضد ذلك.ويقال: (ساء {9} الشيءُ)، (يسوء {10}، فهو سيِّء)، والأنثى: (سيِّئةٌ)؛ أي: قَبُحَ {11}. ومنه قوله: ﴿سَاَءَ مَا يَعمَلُونَ﴾ [المائدة: 66]. و (سَوَّأتُ على الرجل {12} فعلَهُ)؛ أي: قَبَّحْتُهُ عليه، وعِبْتُهُ به. و (السُّوْءَى) {13}: ضد الحُسْنَى، و (السَّوْءاءُ) {14}: المرأةُ القبيحة {15}.وقوله تعالى: ﴿وَإِنْ تَصْبِرُوا﴾. أي: على ما تسمعون منهم، وعلى أذاهم.﴿وَتَتَّقُوا﴾. قال ابنُ عباس {16}: وتخافوا ربَّكم، في سِرِّكم وعلانِيَتِكم. وقال غيره {17}: وتتقوا مقاربتهم في دينهم، والمحبة لهم.﴿لَا يَضُرُّكُمْ كَيْدُهُمْ شَيْئًا﴾ يقال: (ضارَهْ، يَضِيرُهُ، ضَيْرًا)، و (يَضُورُهْ ضَوْرا): إذا ضرَّهُ {18}.وقرئ: ﴿لَا يَضُرُّكُمْ﴾ مُشَدَّدا {19} من: الضَّرِّ {20}. وأصله: (يَضْرُرْكُمْ) -جَزْمًا-، وأُدغِمَت {21} الرَّاءُ في الرَّاءِ، ونقلت ضَمَّةُ الرَّاء الأولى إلى الضاد، وضُمَّت الرَّاءُ الأخيرةُ؛ إتْباعًا لأقرب الحركات إليها، وهي: حركة الضادُ، كقولهم: (مُدُّ يا هذا) {22}.واعلم أنه إذا كان قبل الحرف المُدْغم {23}، حرفٌ مضمومٌ، فلك في تحريك الأخير ثلاثة أوجه: الضمُّ؛ للإتْباع، والكسرُ؛ على أصل ما يجب {24} في التقاء الساكنين، والفتحُ؛ للخفة.قال جرير:فَغُضّ الطَرْفَ إنك مِن نُمَيْرٍ {25}يُنشَد باللغات الثلاث {26}. ولا يجوز في القراءة إلّا الرفع، على ما قرأته القُرَّاءُ المُتَّبَعون {27}.قال أبو إسحاق {28}: ضمن الله -عز وجل- للمؤمنين النصرَ إن صَبَروا، وأَعلَمَهم أَنَّ عَدَاوَتَهم {29} وكَيْدَهُم غَيْرُ ضَارٍّ لهم.والكَيْدُ -في اللغة-: الاحتيال بغير ما يبدي {30}، وهو: أن يحتال ليَغْتَالَ صاحِبَهُ، ويوقِعَهُ في مكروه {31}، وابن عباس فَسَّرَ الكيْدَ بالعداوة {32}.[ورُدَّ على الفرَّاء] {33} [في هذه الآية شيئان:أحدهما: أنه قال {34}: ولو] {35} قرئ: (لا يَضُرْكم) -بضم الضاد-، جازَ؛ فقد سمع الكسائيُّ بعضَ أهل العالِيَةِ {36} يقول: [(لا ينْفَعُني ذاك {37} ولا يَضُورُني) {38}.قال الزجاج {39}: وهذا غير جائز، لا يُقرأ حرفٌ من كتاب الله -عز وجل- بخلاف الإجماع، على قول رجل من أهل العالية. وهذا كما قاله؛ لأن القراءةَ بالسَّمَاع والتَّوْقِيف، لا بالجَوَازِ في اللغة.والآخر: أنه قال {40} في قوله: ﴿لَا يَضُرُّكُمْ﴾ -على قراءة من قرأ بالتشديد-: يجوز أن يكون جواب الشرط: فَاء مُضْمَرَة {41}، ويكون (لا) بمعنى (ليس) والتقدير: (فليس يَضُرُّكُمْ كيدُهم شيئا).وأنشد {42} على هذا بيتًا {43}.قال النحويون: وهذا غلطٌ، مَن حَذَفَ الفاءَ، إنما {44} يجوز لِضرُورة الشعر {45}، والقرآن لا يُحْتَمل {46} على ضرورة الشعر {47}، سِيَّما إذا كان لرفع الراء في ﴿يَضُرُّكُمْ﴾ وجهٌ حسن.وقوله تعالى: ﴿إِنَّ اللَّهَ بِمَا يَعْمَلُونَ مُحِيطٌ﴾ أي: عالم به؛ على معنى: أنه باقتداره عليه، وعلمه به {48}، قد {49} حَصَرَه مِن {50} جميع جهاته، كما حَصَرَه {51} المحيطُ به. هذا معناه وحقيقته؛ لأن المحيط بالشيء، هو المحيط به من حواليه، وهذا من صفة الإحكام {52}] {53}."
  3,121,"قوله تعالى {1}: ﴿وَإِذْ غَدَوْتَ مِنْ أَهْلِكَ﴾ {2} الآية. مضى {3} الكلام [في (إذ) في مواضع؛ {4} والعامل فيه -ههنا- محذوف، وهو: اذكر. وحُذِفَ؛ لأن الحال تدل على أن {5}] {6} المعنى تذكير لتلك الحال.قال ابن عباس {7}، وقتادة {8}، والربيع {8}، والسدي {8}، وأكثر المفسرين {11}: هذا كان يوم أُحُد، غدا رسول الله ﷺ من منزل عائشة إلى أُحُد {12}، فجعل يصف أصحابَه للقتال.قال ابن عباس {13}: ﴿مِنْ أَهْلِكَ﴾؛ يريد: مِن {14} منزل عائشة {15}.وقوله تعالى: ﴿تُبَوِّئُ الْمُؤْمِنِينَ﴾ يقال: (بَوَّأتُه مَنْزِلًا)، و (بَوَّأتُ له منزلًا)؛ أي: أنزلته إيَّاهُ {16}.قال ابن هَرْمَة {17}:وبُوِّئَتْ في صَميمِ مَعْشَرِها ... فَتَمَّ في قومِها مُبَوَّؤُها {18} وفي قراءة عبد الله: (تبوِّئُ للمؤمنين) {19}. و (المَبَاءَة) {20}، و (البَاءَة) {20}: المنزل {22}.قال أبو علي {13}: (بَوَّأتُ فُلانًا {24} منزلًا)، تُعدِّيْهِ إلى مفعولين، وكأنه منقول من قولك: (باءَ فلانٌ منزِلَهُ)؛ أي: لَزِمَه. وإن كنّا لا نرى ذلك؛ ولكن يدل على ذلك قولهم: (المَبَاءَة) {25} - وهي: المُرَاحُ {26} الذي تبيت فيه النَّعَم {27} -: [اسمٌ] {28} للمكان {29}.وقوله تعالى: ﴿مَقَاعِدَ لِلْقِتَالِ﴾ أي {30}: مواطن. قال ابن عباس {13}: كل رجل لِمَقعَدِه الذي يصلح له.وقد بيّنّا أن معنى القُعُود -في أصل اللغة-: الثُّبُوت، على أي حال كانت، عند قوله: ﴿الْقَوَاعِدَ مِنَ الْبَيْتِ﴾ [البقرة: 127].فمعنى: ﴿مَقَاعِدَ لِلْقِتَالِ﴾ مراكز {32}، ومَثابِتَ، لا مَجَالِس {33}.وقوله تعالى: ﴿وَاللَّهُ سَمِيعٌ عَلِيمٌ﴾. قال ابن عباس {13}: يريد: سميعٌ لقولكم، عليمٌ بما في قلوبكم؛ وذلك أن رسول الله ﷺ استشار أصحابه في ذلك الحرب {35}، فمنهم من أشار عليه بأن يقيم في المدينة، ومنهم من أشار عليه بالخروج إليهم، فقال الله -تعالى-: أنا ﴿سَمِيعٌ﴾ لِمَا يقوله المُشيرون عليك {36}، ﴿عَلِيُمٌ﴾ {37} بما يُضْمِرُون."
  3,122,"قوله تعالى: ﴿إِذْ هَمَّتْ طَائِفَتَانِ مِنْكُمْ أَنْ تَفْشَلَا﴾ قال الزّجاج {1}: العامل في (إذ) {2}: التَّبْوِئَة؛ المعنى: كانت التَّبْوِئَةُ في ذلك الوقت. و ﴿هَمَّتْ﴾؛ أي: قَصَدَت وأرادت. يقال: (هَمَمْتَ بالشيء)، (أَهَمُّ به هَمًّا) {3}. والطائفتان -في قول ابن عباس وأكثر المفسرين- {4}: بَنُو سَلِمَة {5} مِن الخزرج، وبنو حَارِثَة من الأنصار {6}.وكان سبب ذلك أن {7} عبد الله بن أُبَيٍّ انْخَزَلَ {8}، فرجع عن الطريق في ثلاثمائةٍ، وهمت الطائفتان بالانصراف معه، فعصمهم الله، فلم ينصرفوا ومضوا مع رسول الله ﷺ {9}.والفَشَل: الجُبْنُ، والخَوَرُ {10}.وقوله تعالى: ﴿وَاللَّهُ وَلِيُّهُمَا﴾ قال ابن عباس {11}: يريد: ناصِرُهما، ومُوَالٍ لهما على مَنْ عاداهما {12}.وقوله تعالى: ﴿وَعَلَى اللَّهِ فَلْيَتَوَكَّلِ الْمُؤْمِنُونَ﴾ التَوَكُّل: تَفَعُّل، مِن: (وَكَلَ أمْرَهُ إلى فلان): إذا اعتمد في كفايته عليه، ولم يَتَوَلَّهُ بنفسه {13}. وفي الآية إشارة إلى أنَّه ينبغي أن يستدفع {14} الإنسان ما يعرض له مِن حَرْفٍ {15} ومكروهٍ بالتوكل على الله، وأن {16} يَصْرِفَ الجَزَعَ {17} عن نفسه بالتوكل."
  3,123,"قوله تعالى: ﴿وَلَقَدْ نَصَرَكُمُ اللَّهُ بِبَدْرٍ﴾. الآية {1}.النَّصْرُ: حُسْنُ المَعُونة {2}. وبَدْرٌ: بِئْرٌ {3} لرجل [يقال] {4} له: بَدْر {5}، سُمِّيَت باسم صاحبها، في قول الشعبي {6}.يدل على هذا قولُ حَسَّان {7}:وبِبِئْرٍ إذْ يَرُدُّ وجوهَهُم ... جبريلُ تحت لِوائِنا ومُحَمَّدُّ {8}وقال الواقِدِيُّ {9} -عن شيوخه- {10}: (بدر) {11}، هو اسمٌ لِمَوضِعٍ {12}.وقيل: هو ماءٌ {13} لبني غِفَار {14}، بين مكة والمدينة {15}.وقوله تعالى: ﴿وَأَنتُم أَذِلَّةٌ﴾ في موضع الحالِ، وإنّما كانوا أذلةً؛ لقلة العَدَدِ، وضعف الحال {16}؛ لقلة {17} السلاح والمال عن مقاومة العدو {18}.ومعنى الذلِّ: الضَّعْف عن المقاومة. ونقيضه: العِزُّ، وهو: القوة والغَلَبَة {19}.و ﴿أَذِلَّةٌ﴾ {20}: جمع ذليل. والأصل في (فَعِيل) إذا كان صفةً، أن يجمع على (فُعَلاَء، نحو: (ظَرِيف وظُرَفَاء)، و (شَرِيك وشُرَكَاء)، ولكن لفظ {21} (فُعَلاَء) [اجتُنِبَ] {22} في التضعيف؛ لأنه [لو قيل: (خُلَلاَء) {23}، و (قُلَلاَء)، في جمع: خَلِيل {24} وقَلِيل، لا جتمع حرفان من جنسٍ واحد، فَعُدِل به] {25} إلى (أفْعِلَة)؛ لأن (أفْعِلَة) مِن جمْع الأسماء في (فَعِيل) {26}، [نحو: جَرِيب] {27} وأَجْرِبَة) {28}، و (قَفِيز {29} وأَقْفِزَة) {30}.قال أبو إسحاق {31} في هذه الآية {32}: أعلم الله -جَلَّ وعَزَّ- أنَّهم حين لَزِمُوا الطاعةَ، نصرهم اللهُ، وهم قليل، ويوم أُحُد نَزَلَ بهم ما نزل؛ بمخالفة أمرِ النبي ﷺ، فجعل ذلك عقوبة.وقوله تعالى: ﴿فَاتَّقُوا اللَّهَ لَعَلَّكُمْ تَشْكُرُونَ﴾ أي: اتقوا معاصي الله بالعمل بطاعته، أو اتَّقوا عقابَ اللهِ بالعمل بطاعته؛ لتقوموا بشكر نعمته. وهذا {33} معنى قول محمد بن إسحاق بن يَسَار في هذه الآية {34}: اتَّقُونِي فإنَّه شكر نعمتي {35}."
  3,124,"قوله تعالى: ﴿إِذْ تَقُولُ لِلْمُؤْمِنِينَ﴾ الآية. قال الشَّعْبيُّ {1}: حُدِّثَ المسلمون أن كُرْز بن جابر المُحَارِبي {2} يريد أن يُمِدَّ {3} المشركين، فَشَقَّ ذلك عليهم، فقيل لهم: ﴿أَلَنْ يَكْفِيَكُمْ﴾.ومعنى الكِفَايَةِ، هو: سَدُّ الخَلَّةِ {4}، والقيام بالأمر، يقال: (كفاهُ أمْرَ كذا): إذا قامَ {5} بِهِ دونه، وسَدَّ خَلَّتَهُ {6}.ومعنى الإمْدَاد: إعطاء الشيء حالًا بعد حال {7}.قال المُفَضَّلُ {8}: ما كان على جهة القوة والإعانة، قيل فيه: (أَمَدَّهُ، يُمِدُّهُ) {9}، وما كان على جهة الزيادة، قيل فيه: (مَدَّةُ، يَمُدُّهُ، مَدًّا) {10}، ومنه قوله: ﴿وَالْبَحْرُ يَمُدُّهُ﴾ {11}."
  3,125,"قوله تعالى: ﴿بَلَى إِنْ تَصْبِرُوا وَتَتَّقُوا﴾ الآية. ﴿بَلَى﴾: تصديق لوعد الله. ومضى الكلامُ فيه {1} إذا وقع في ابتداء الآية.وقوله تعالى: ﴿إِنْ تَصْبِرُوا﴾ {2}. أي: على لقاء العدو.﴿وَتَتَّقُوا﴾ معصية الله، ومخالفة النبي ﷺ {3}.﴿وَيَأْتُوكُمْ مِنْ فَوْرِهِمْ هَذَا﴾ قال ابنُ عبَّاس -في رواية العَوْفي- {4}: مِن وجههم هذا. وهو قول: الحسن {5}، وقتادة {5}، والربيع {7}، والسّدِّي {5}، وابن زيد {9}.وقال {10} في رواية باذان: من غَضَبِهم هذا {11}. وهو قول: مجاهد {12}، والضَّحَّاك {13}.وأصل الفَوْرِ: غَلَيانُ القِدْرِ. يقال: (فارت القِدْرُ، تَفُورُ فَوْرًا)، وهو غليانها عند شدة الحَمْي {14}. ومنه: فَوْرُ الغَضَبِ؛ لأنه كَفَوْرِ القِدْرِ بالحَمْي. ومنه، يقال: (جاء على الفَوْر)؛ أي: على ابتداء الحَمْي، قبل أن تَبْرُدَ نَفْسُه عنه {15}.وقوله تعالى: ﴿مُسَوِّمِينَ﴾ مَنْ فَتَحَ الواو {16}، معناه: مُعْلَمِين، قد سُوِّمُوا، فهم مُسَوَّمِين.والسُّوْمَة: العَلاَمَةُ يُفْرَقُ بها الشيءُ مِن غَيْرِه. ومضى شيءٌ من هذا في قوله: ﴿وَالْخَيْلِ الْمُسَوَّمَةِ﴾ {17}.وهذه {18} العَلامَةُ يُعْلِمُها الفارسُ يوم اللقاء؛ ليُعْرَفَ بها.قال عنترة {19}:فَتَعَرَّفوني إنَّنِي أنا ذِلكُم ... شاكٍ سِلاحي في الحوادِثِ مُعْلَمُ {20} ومَن كَسَرَ الواو {21}، نَسَبَ الفِعْلَ إليهم؛ لِمَا جاء في الخبر: أن النبي ﷺ قال يوم بدر: ""سَوَمُوا، فإن الملائكة قد سَوَّمَتْ"" {22}.قال ابن عباس: كانت الملائكة قد سَوَّمت يوم بدر بالصُّوف الأبيض في نواصي الخيل، وأذنابها {23}.وقال الربيعُ {24}، وهشامُ بن عُرْوة {25}: كانت عليهم عمائم صُفْرٌ، وروي عن علي {26} وابن عباس {27}: كانت عليهم عمائمُ بِيضٌ، قد أرسلوها بين أكتافهم.قال المفسرون: فصبر المسلمون يوم بَدْرٍ، واتَّقوا اللهَ، فأَمَدَّهم {28} الله بخمسة آلافٍ من ملائكته {29} على ما [وَعَدَهم] {30}. قال الحسن {31}: فهؤلاء الخمسة آلاف رِدْءٌ {32} للمؤمنين إلى يوم القيامة.وقال ابن عباس {33}، ومجاهد {34}: لم تقاتل الملائكة إلا يوم بدر، وفيما سوى ذلك، يشهدون القتال ولا يُقاتِلُون."
  3,126,"قوله تعالى: ﴿وَمَا جَعَلَهُ اللَّهُ إِلَّا بُشْرَى﴾ الكناية {1} تعود على المَصْدَرِ؛ كأنه قال: وما جعل الله المَدَدَ والإمْدادَ إلّا بُشْرى. فَدَلَّ ﴿يُمْدِدْكُمْ﴾ على الإمداد، فَكَنَى عنه {2}، كما قال: ﴿وَلَا تَأْكُلُوا مِمَّا لَمْ يُذْكَرِ اسْمُ اللَّهِ عَلَيْهِ وَإِنَّهُ لَفِسْقٌ﴾ [الأنعام: 121]؛ معناه {3}: وإن أكلَهُ لَفِسْقٌ. فَدَلَّ ﴿تَأْكُلُوا﴾ على الأكل، فكنى عنه، والعرب تقول: (مَنْ صَدَقَ؛ كان خيرًا له، ومَن كَذَبَ؛ كان شرًا له). فدل الفعلان على المَصْدَرَيْنِ {4}. هذا كلام ابن الأنباري {5}. وكذلك قال الزجاج {6}؛ أي: وما جَعَلَ اللهُ ذِكْرَ المَدَدِ إلّا بُشْرَى {7}.والبُشْرى: اسم من (الإبشار)، و (التبشير) {8}.ومضى الكلام في معنى التبشير {9}، وسيأتي الكلام في (بُشْرى) في سورة يوسف إن شاء الله {10}.وقوله تعالى: ﴿وَلِتَطْمَئِنَّ قُلُوبُكُمْ﴾ فلا تجزع من كثرة العَدُوِّ {11}، وقِلَّةِ عَدَدِكم. وإنما قال: ﴿وَلِتَطْمَئِنَّ﴾، ولم يقل: واطْمِئْنانًا، كما قال ﴿بُشْرَى﴾، لأن ذِكْر المَدَدِ سببٌ لاطمئنان القلوب، ولم يكن نفس الاطمئنان، وكان ذكر المَدَدِ نفس البُشْرَى.وقال صاحب النظم {12}: هذا على تأويل: وما جعله الله إلّا لِيُبَشِّركم {13}، ولِتَطمئنَّ به قلوبُكم.ومن أجاز إقحام الواو -وهو مذهب الكوفيِّين {14} - جعلها مقحمةً في ﴿وَلِتَطْمَئِنَّ﴾ فيكون التقدير: وما جعله الله إلا بُشْرَى لكم؛ لِتَطمئنَّ قلوبكم به.قال: وزعم بعضهم أنَّ الواو لإضمارٍ بعده، على تأويل: (ولتطمئن قلوبكم به، جَعَل ذلك). واحتج بقوله: ﴿وَزَيَّنَّا السَّمَاءَ الدُّنْيَا بِمَصَابِيحَ وَحِفْظًا﴾ [فصلت: 12]، على تأويل: (وحفظًا لها، جَعَل ذلك). ومثله: قوله: ﴿وَلَوْ تَوَاعَدْتُمْ لَاخْتَلَفْتُمْ فِي الْمِيعَادِ وَلَكِنْ لِيَقْضِيَ اللَّهُ أَمْرًا كَانَ مَفْعُولًا﴾ [الأنفال: 42]، على {15} تأويل: ليقضي اللهُ أمرًا كان مفعولًا، فَعَلَ ذلك.ونحو هذا قوله: ﴿وَكَذَلِكَ نُرِي إِبْرَاهِيمَ مَلَكُوتَ السَّمَاوَاتِ وَالْأَرْضِ وَلِيَكُونَ مِنَ الْمُوقِنِينَ (75)﴾ {16} [الأنعام: 75].وقوله تعالى: ﴿وَمَا النَّصْرُ إِلَّا مِنْ عِنْدِ اللَّهِ﴾ قال المفسرون: أرادَ الله تعالى: أنْ لا يَرْكَن المؤمنون إلى الملائكة، وأَعْلَمَ أنهم وإنْ {17} حضروا وقاتلوا، فما النصر إلا من عند الله؛ ليستعينوا به [و] {18} يَتَوَكَّلوا عليه. والإمداد بالملائكة؛ بُشرَى لهم [وطُمَأنِينة] {19} لقلوبهم {20}؛ لما في البَشَرِ من الضَّعْف، فأما حقيقة النصرِ والاستعلاءِ في العرب، فهو من عند الله العزيز الحكيم {21}."
  3,127,"قوله تعالى: ﴿لِيَقْطَعَ طَرَفًا مِنَ الَّذِينَ كَفَرُوا﴾ اللّام تعود إلى قوله: ﴿وَلَقَد نَصَرَكُمُ اللَّهُ بِبَدرٍ﴾ {1}.﴿لِيَقْطَعَ طَرَفًا﴾؛ أي: لِيُهلك طائفةً، ولِيَقْتُلَ قِطْعَةً. قال السُّدِّي {2}: معناه: لِيَهدِمَ رُكْنًا مِن أركان الشرك، بالقتل والأَسْرِ، فقُتِلَ من قادتهم وسادتهم يومَ بَدْرٍ، سبعون، وأُسِرَ سبعون {3}.وقال بعضهم {4}: المعنى: وما النصر إلا من عند الله، ليقطع طرفًا {5}. وقيل {6}: إنَّ هذا راجعٌ إلى [معنى قوله] {7}: ﴿وَلِتَطْمَئِنَّ قُلُوبُكُمْ بِهِ﴾، و ﴿لِيَقْطَعَ طَرَفًا﴾، ولكنه ذُكِر بغير حرفِ العطف؛ لأنَّ الكلامَ إذا كان بعضُه ملتبسًا ببعضٍ، جاز حذفُ العاطف؛ كقوله: ﴿ثَلَاثَةٌ رَابِعُهُمْ كَلْبُهُمْ﴾ [الكهف: 22].وإنما قال: ﴿طَرَفًا﴾ ولم يقل: (وَسَطًا)؛ لأنه لا يُوصَلُ إلى الوَسَطِ الا بعد قطع الطَّرَفِ، وهذا القَطْعُ إنما هو بأيدي المؤمنين، وإنما يقطعون الطَّرَفَ الذي يليهم مَنَ الكافرين، وهذا يوافق قوله: ﴿قَاتِلُوا الَّذِينَ يَلُونَكُمْ مِنَ الْكُفَّارِ﴾ [التوبة: 123]، وعلى هذا -أيضًا- قولُه: ﴿أَوَلَمْ يَرَوْا أَنَّا نَأْتِي الْأَرْضَ نَنْقُصُهَا مِنْ أَطْرَافِهَا﴾ [الرعد: 41].وقوله تعالى: ﴿أَوْ يَكْبِتَهُمْ﴾ الكَبْتُ -في اللغة-: صَرْعُ الشيء على وجهه؛ يُقال: (كَبَتَهُ، فانْكَبَتَ) {8}. هذا تفسيره، ثم قد {9} يُذكرُ {10} المرادُ به: الإخزَاءُ، والإهلاكُ، واللَّعْنُ، والهَزِيمَةُ، والغَيْظُ، والإذلالُ. وكلُّ هذا ذكره المفسرون في تفسير (الكَبْتِ) {11}.وقوله تعالى: ﴿خَائِبِينَ﴾ الخَيْبَةُ: حِرْمانُ البُغْيَة {12}، ولا تكون إلّا بعد الأَمَلِ. واليَأْسُ قد يكون قبل الأَمَلِ، وقد يكون بعده. فنقيض اليَأْسِ: الرَّجَاءُ، ونقيض الخَيْبَةِ: الظَّفَرُ.وقد أنجز الله وَعْدَهُ يوم بَدْرٍ؛ بِقَطْع {13} طَرَفٍ مِن الكفار بالقتال والأسر، وَرَدَّ الباقين منهزمين، خائبين مِمّا أَمَّلُوا مِن الظَّفَرِ، فتحقق نصرُه، وعَلَت كلمَتُهُ."
  3,128,"قوله تعالى: ﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ أَوْ يَتُوبَ عَلَيْهِمْ﴾ الآية.ذَكَرَ النحويون -الفرّاء {1}، والزّجاج {2}، وغيرُهما {3} - في هذه الآية قولين: أحدهما: أنَّ قوله: ﴿أَوْ يَتُوبَ عَلَيْهِمْ﴾ عَطْفٌ عَلَى قوله: ﴿لِيَقْطَعَ طَرَفًا مِنَ الَّذِينَ كَفَرُوا أَوْ يَكْبِتَهُمْ﴾، ﴿أَوْ يَتُوبَ عَلَيْهِمْ﴾، ويكون قولُه: ﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ﴾ اعتراضًا بين المعطوف والمعطوف عليه؛ كما تقول: (ضَرَبْتُ زيدًا -فاعْلَمْ ذلك- وعَمْرًا) {4}. فعلى هذا القول: هذه الآية متصلة بما قبلها.القول الثاني: وهو أنَّ الموافق لِمَا ذُكِرَ في تفسير هذه الآية: أنَّ معنى (أو) -ههنا- معنى (حتَّى) و (إلّا أنْ)؛ وذلك أنَّ أكثر المُفَسِّرِين -ابنَ عباس {5}، والحسنَ {6}، وقتادةَ {7}، والربيع {7} - قالوا: لَمّا كان من المشركين يوم أحد ما كان {9}، مِنْ كَسْرِ رَبَاعِيّةِ {10} النبي ﷺ، وشَجِّهِ حتَّى جَرَت الدِّماءُ على وجهه، قال: ""كيف يُفْلِحُ قومٌ خَضَبُوا وَجْهَ نَبِيِّهم، وهو يدعوهم إلى ربهم؟! "" {11}، فأنزل اللهُ هذه الآية، لِعِلْمِهِ أنَّ كثيرًا منهم سيؤمِنُونَ، فَكَفَّ عن ذلك {12}.وقوله تعالى: ﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ﴾ مختَصَرُ معناه: ليس لَكَ مِنَ الأمْرِ في عقابهم، أو {13} استصلاحهم شيءٌ، حتى تقَعَ إنابَتُهم {14} أو تعذيبهم. فيكون أمْرُكَ -حينئذٍ - تابعًا لأمْرِ اللهِ، بِرِضَاكَ بتدبيرهقال الفرّاء {15}: ومِثْلُ هذا مِن الكلام: (لأَذُمَّنَّكَ {16} أو تُعْطِيَنِي)؛ على معنى: (إلّا أنْ تُعْطِيَني)، و (حتى تُعْطِيَنِي) {17}.وأنشد ابن الأنباري {18} على هذا:فَقُلْتُ لَهُ لا تَبْكِ عيْنُكَ إنَّما ... نُحاوِلُ مُلْكًا أو نَمُوتَ فَنُعْذَرَا {19}أراد: (حتَّى)، و (إلّا أنْ نموت) {20}."
  3,129,"وقوله تعالى: ﴿وَلِلَّهِ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ﴾ قال أهلُ المعاني {1}: لَمَّا نَفَى [اللهُ] {2} الأمرَ عَنْ نَبِيِّهِ ﷺ، ذَكَرَ أنَّ جميع الأمر له؛ كأنه قال: الأمر ليس لك منه شيءٌ، فمن شاء عَذَّبَهُ، ومَن شاءَ غَفَرَ له.وقوله تعالى: ﴿مَا فِي السَّمَاوَاتِ﴾ ولم يقل: (مَنْ)؛ لأنه ذهب به مَذْهَب الجنس، فَدَخَلَ فيه الجميع {3}.وقوله تعالى: ﴿يَغْفِرُ لِمَنْ يَشَاءُ﴾ قال ابنُ عَبَّاس، في رواية عطاء {4}: الذنْبَ العظيمَ للمُوَحِّدِينَ {5}.﴿وَيُعَذِّبُ مَنْ يَشَاءُ﴾ يريد: المشركين {6}، على الذنب الصغير {7}.﴿وَاللَّهُ غَفُورٌ﴾ لأوليائه، ﴿رَحِيمٌ﴾ بهم."
  3,130,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا لَا تَأْكُلُوا الرِّبَا أَضْعَافًا مُضَاعَفَةً﴾ قال ابن عباس {1}، وسعيد بن جبير {2} هو أنهم كانو يزيدون على المال، وُيؤَخِّرُونَ الأَجَلَ، كلَّما أخّر عن أَجَلٍ إلى غيره، زِيد زيادة.وانتصب ﴿أَضْعَافًا﴾ على الحال.وقوله تعالى: ﴿لَعَلَّكُمْ تُفْلِحُونَ﴾ قال عطاء {1}: يريد: كي تسعدوا، وتبقوا في الجنة. وقال الزّجاج {4}: المُفْلِحُ: الذي أدرك ما أمَّلَ مِنَ الخير. وذكرنا معنى (الإفلاح) فيما تقدم {5}."
  3,131,"قوله تعالى: ﴿وَاتَّقُواْ النَّارَ﴾ الآية. قال أبو إسحاق {1}: أي: اتَّقُوا أن تُحِلُّوا ما حَرَّمَ اللهُ، فإنَّ مَنْ أَحَلَّ شيئًا مِمَّا حَرَّمَ اللهُ، فهو [كافرٌ] {2} بإجماع.وهذا معنى قول ابن عبَّاس، قال {3}: يُهَدِّدُ المؤمنين إن استحلوا ما حَرَّمَ اللهُ عَلَيْهِم مِنَ الرِّبَا وغيره، مِمَّا أوجَبَ الله فيه النَّارَ؛ والتقدير: واتَّقُوا النَّارَ التي أُعِدَّت للكافرين، أن تستحلوا الرِّبا، فتستحقوها {4}.وفي الآية تَقْويَةٌ لِرَجاءِ المؤمنين، رحمةً من الله -تعالى-؛ لأنه قال: ﴿أُعِدَّت لِلكَافِرِينَ﴾. فَجَعلها مُعَدَّةً للكفار، دونَ أهلِ الإيمان."
  3,132,"قوله تعالى: ﴿وَأَطِيعُوا اَللَّهَ وَاَلرَّسُولَ﴾ لَمَّا نَهَى عن أكل الرِّبَا، أمَرَ بطاعة الرسولِ فيما يأمرهم به، وينهاهم عنه، مِن أكلِ الرِّبَا وغيره.وذُكِر عن محمد بن إسحاق بن يَسَار، أنَّه قال {1}: [في] {2} هذه الآية معاتَبة للذين عَصَوا رسولَ الله ﷺ حين أمرهم بما أمرهم به يوم أُحُد."
  3,133,"قوله تعالى: ﴿وَسَارِعُوا إِلَى مَغْفِرَةٍ مِنْ رَبِّكُمْ﴾ قُرِئ بالواو، وبغير الواو {1}. فَمَن {2} قرأ بالواو؛ فلأنه عَطَفَ الجملة على الجملة، والمعطوف عليها قوله: ﴿وَأَطِيعوا اللَّهَ وَالرَّسُولَ﴾، ﴿وَسَارِعُوَاْ﴾.ومَن تَرَكَ الواو؛ فلأن الجملة الثانيةَ مُلْتَبسَةٌ بالأولى {3}، مستغنية بالتباسها عن عطفها بالواو {4}.وقد جاء الأمران في التنزيل، في قوله: ﴿سَيَقُولُونَ ثَلَاثَةٌ رَابِعُهُمْ كَلْبُهُمْ﴾ [الكهف: 22] الآية {5}، وقوله -تعالى-: {أُولَئِكَ أَصْحَابُ النَّارِ هُمْ فِيهَا خَالِدُونَ} [البقرة: 39] {6}.ورُوِي عن الكِسائي الإمالة في {7} ﴿وَسَارِعُواْ﴾ و ﴿أُولَئِكَ يسُارِعُونَ﴾ [المؤمنون: 61] و ﴿نُسَارِعُ﴾ {8} [المؤمنون: 56]. وذلك مُستَحسَنٌ لِمَكان الرَّاءِ المكسورة؛ فكما تمنع المفتوحةُ الإمالةَ، فكذلك المكسورةُ تَجلِبُها {9}.وفي الكلام محذوف، والمعنى على: وسارعوا إلى مُوجِبِ {10} مغفرة مِن رَبِّكم.واختلفوا في ذلك الذي إذا سارع إليه، فقد سارع إلى مغفرة: فقال عطاء عن ابن عباس {11}: يريد: لا تُصِرُّوا على الذنب. إذا أذنب أحدٌ فلْيُسْرع الرجوع، يغفر الله له.وقال ابن عباس -أيضًا- {12}: سارعوا إلى الإسلام. وروي عن علي - رضي الله عنه -، أنه قال {13}: إلى أداء الفرائض. وعن أنس بن مالك، قال {14}: هو التكبيرة الأولى {15}.وقوله تعالى: ﴿وَجَنَّةٍ عَرْضُهَا السَّمَاوَاتُ وَالْأَرْضُ﴾ أي: عرضها عَرْضُ السَّموات والأرض، فحذف المضاف، كقوله: ﴿مَا خَلْقُكُمْ وَلَا بَعْثُكُمْ إِلَّا كَنَفْسٍ وَاحِدَةٍ﴾ {16}. يدل على هذا قوله في سورة الحديد: ﴿عَرْضُهَا كَعَرْضِ السَّمَاءِ وَالْأَرْضِ﴾ [الحديد:28].قال ابن عباس {17}: تُقرَنُ السَّمواتُ السبعُ والأرَضُونَ السَّبْعُ، كما يُقرن {18} الثيابُ بعضها إلى بعض، فذلك عَرْضُ الجنَّةِ.قال أهل المعاني {19}: إنَّمَا خَصَّ العَرْضَ دون الطول، لأن طولَ كلِّ شيءٍ في الأغلب أكثر من عَرْضِه. يقول: هذه صفة عرضها، فكيف طولُها؟. كما قال الزُّهْري {20}: إنما وصف عرضها، فأما طولها فلا يعلمه إلَّا الله. وهكذا قوله: ﴿بَطَائِنُهَا مِنْ إِسْتَبْرَقٍ﴾ [الرحمن: 54]، وصَفَ {21} البِطَانَةَ وتَرَكَ الظِّهارَةَ؛ إذ مِنَ المعلوم {22} أنها {23} أحسن وأنفس من البطائن.وقال عطاء عن ابن عباس {24} - في قوله: ﴿وَجَنَّةٍ عَرْضُهَا السَّمَاوَاتُ وَالْأَرْضُ﴾، يريد: لِرَجُلٍ واحدٍ مِن أوليائه.[و] {25} قال جماعة من أهل المعاني {26}: لم يُرِدْ العَرْضَ الذي هو ضِد الطُوْلِ، وإنما أراد بالعرض: السَّعَةَ. والعرب تقول: (بلاد عَرِيضةٌ)، أي: واسعة. (وفي الأرض العريضة مذهبٌ) {27} [و] {25} قال:كأنَّ بِلادَ اللهِ وَهْيَ عَرِيضةٌ ... على الخائفِ المَطْلُوبِ كِفَّةُ حابِلِ {29}وإنما يقال للشيءِ الواسع: (عَرِيض)؛ لأن الشيء إذا عَرُضَ اتَّسَعَ، وإذا لم يَعْرُضْ، ضاقَ وَرَقَّ.قالوا {30}: وتشبيه عرض الجنة بعرض السَّموات والأرض على التمثيل لا على التحقيق؛ معناه: عرضها كعَرْضِ السموات والأرض عند ظَنِّكم؛ لأنه لا شيء عندنا أعرض منها، فهو كقوله: ﴿خَالِدِينَ فِيهَا مَا دَامَتِ السَّمَاوَاتُ وَالْأَرْضُ﴾ {31}؛ يعني: عند ظنكم؛ لأنَّهما لابد زائلتان. فَلمَّا كانَ قوله: {مَا دَامَتِ السَّمَاوَاتُ وَاَلأَرضُ} عندنا -في عادة الاستعمال- من ألفاظ التأبيد، خُوطِبْنا على ما نَعْرِف {32}؛ كذلك في هذه الآية.وسُئِل أنسُ بن مالك عن الجَنَّة: أفي الأرض أم في السماء؟ فقال: وأيُ أرضٍ وسماءٍ تَسَعُ الجَنَّة؟! قيل: فأين هي؟ فقال: فوق السَّموات السَبْع، تحت العَرْش {33} {34}."
  3,134,"قوله تعالى: ﴿الَّذِينَ يُنْفِقُونَ فِي السَّرَّاءِ وَالضَّرَّاءِ﴾ قال ابن عباس {1}: يعني: في اليُسْرِ والعُسْر. كأنه يريد: السَّرَّاء؛ بكثرة المال، والضَّراء، بِقِلَّتِهِ.وهذه الآية من صفة المُتَّقِين الذين أعِدت لهم الجَنَّة. وأول ما وصفهم الله تعالى به: الإنفاق في كل حال. وهو من أقسام السَّخَاء.وقوله تعالى: ﴿وَالْكَاظِمِينَ الْغَيْظَ﴾ يقال: (كَظَمَ غَيْظَه): إذا سكت عليه، ولم يُظْهِرْهُ بقول أو فِعْلٍ {2}.قال المُبَرِّد {3}: تأويله: أنه كتمه على امتلائه منه. ويقال: (كظَمتُ [السِّقَاءَ): إذا ملأتُه] {4}، وَشَدَدْتُ عليه. ويقال: ما يَكْظِمُ فلانُ على (جِرَّةٍ) {5}: إذا كان لا يحتمل شيئًا.قال أبو زيد {3}: وكل ما سددت {7} من مجرى ماءٍ أو طريق؛ فهو (كَظْمٌ). ويُدعَى الذي تَسُدُّه {8} به: (الكاظِمَة) و (السَّدَادَة).و (فلانٌ كَظِيْمٌ)، و (مَكْظُومٌ): إذا كان ممتلئا {9} حُزْنًا، مُمْسِكًا عليه. وهما في التنزيل {10}.ويقال للقناة {11} التي تجري في بطن الأرض: [كِظَامَة] {12}؛ لامتلائها بالماء كامتلاء القِرْبَةِ المكظومة. ومنه الحديث: (كيف بك إذا بُعِجَتْ مَكَّةُ كظَائِمَ) {13}.ومنه يقال: (أَخَذَ بكَظْمِهِ): إذا أخذ بمجرى نَفَسِهِ؛ لأنه موضع الامتلاء بالنَّفَسِ. و (كَظَمَ البعِيرُ والنَّاقَةُ، كُظُومًا): إذا أَمْسَكا على ما في جَوْفِهما ولم يَجْتَرَّا {14}.قال الراعي:فَأَفَضْنَ {15} بعد كُظُومِهِنَّ بِجِرَّةٍ ... مِن ذِي الأَبَاطِح إذْ رَعَيْنَ حَقِيلاَ {16} وإنَّما تفعل ذلك الإِبِلُ مِنَ الفَزَع أو الجهد. قال الأعشى {17} -ووصف رجلًا نَحَّارًا للإبل، وهي {18} تفزع منه-:قَد تَكْظِمُ البُزْلُ مِنه حين تُبْصِرهُ ... حتَّى تَقَطَّعَ في أجوافها الجِرَرُ {19}ومعنى ﴿وَالْكَاظِمِينَ الْغَيْظَ﴾: الكافِّينَ غَضَبَهم {20} عن إمضائه، يَردُّون غيظهم في أجوافهم، ويصبرون فلا يُظِهرون {21}. وهذا الوصف من أقسام الصبر والحِلْم {22}.وقوله تعالى: ﴿وَالْعَافِينَ عَنِ النَّاسِ﴾ قال ابن عباس {23}: يريد: المَمَالِيك؛ إذا أذنب واحد منهم ذنبًا، عفوت عنه؛ لما يرجو من ثواب الله.وقال زيد بن أسلم {24}، ومقاتل {25}: أي: عمَّن ظَلَمَهم وأساء إليهم.وقوله تعالى: ﴿وَاللَّهُ يُحِبُّ الْمُحْسِنِينَ﴾ قال ابن عباس {3}: يريد: المُوَحِّدِين، الذين هذه الخِصَال فيهم.قال الثَّوْرِي في هذه الآية {27}: الإحسان: أن تُحْسِن إلى مَن أساء إليك؛ فإنَّ الإحسانَ إلى المُحسِنِ مُتَاجَرَةٌ {28}، كَنَقْدِ السُّوقِ: خذْ مِنِّي وهات {29}.وصدَقَ؛ فإنَّ الله -تعالى- عقَّبَ وَصْفَ هؤلاء بالكَظْمِ والعَفْوِ، بِحُبِّهِ المحسنين. وفي ذلك دليل على أن هؤلاء محسنون، والأوصاف التى وُصِفوا بها، كلُّها إحسانٌ إلى مَن أساء إليهم."
  3,135,"قوله تعالى: ﴿وَالَّذِينَ إِذَا فَعَلُوا فَاحِشَةً﴾ الآية. الظاهر أنَّ هذا عطفٌ على ﴿المُتَّقِينَ﴾ {1}. فيكون موضع (الذين): جَرًّا {2}. ويُحتمل أنْ يكون موضِعُه: رفْعًا على الاستئناف؛ بعطف جملة على جملة. وهو قول أكثر المفسرين.قال ابن عباس -في رواية عطاء- {3}: نزلت الآيةُ في نَبْهان التَّمَّار؛ أتته امرأة حسناء، تَبْتَاعُ منه تَمْرًا، فَضمَّها إلى نَفْسِه وقَبَّلَها، ثم ندمَ على ذلك، فأتى النبي ﷺ، وذَكَر له ذلك، فنزلت هذه الآية {4}.وقال ابنُ مسعود {5}: قال المؤمنون للنبي ﷺ: كانت بنو إسرائيلَ أكرَمَ على اللهِ مِنَّا؛ كان أحدُهم إذا أذنب ذَنْبًا، أصبحت كفَّارةُ ذَنْبِهِ مكتوبةً {6} في عَتَبَةِ بابِهِ {7}: (اجْدَعْ أنفَكَ)، (افعل كذا)! فأنزل اللهُ هذه الآيةَ، وبَيَّنَ أنَّهم أكرم على اللهِ منهم؛ حيث جعل كفّارةَ ذنوبهم الاستغفار.وقوله تعالى: ﴿فَعَلُواْ فَاحِشَةً﴾ يعني: الزِّنَا -ههنا- {8}. وهي-في اللغة-: كلُّ قَبِيحةٍ خارِجَةٍ عَمَّا أذِنَ اللهُ فيه {9}. وذكرنا معنى (الفُحْش) و (الفحشاء) فيما تقدم.والفاحشة -ههنا- نعتُ محذوفٍ؛ التقدير: فعلوا فِعْلَةً فاحشةً {10}.وقوله تعالى: ﴿أَوْ ظَلَمُوا أَنْفُسَهُمْ﴾ قال ابنُ عباس {11}، ومقاتل {12}، والكلبي {13}: هو ما دون الزِّنَا، مِن قُبْلَةٍ أو لَمْسَةٍ، أو نَظَرٍ فيما [لا يَحِلُّ؛ مثل الذي {14} فَعَلَ نَبْهانُ التَّمَّار.وقوله تعالى: ﴿ذَكَرُوا اللَّهَ﴾ فيه وجهان: أحدهما: أن المعنى: ذكروا وعيد الله. فيكون من باب حَذْفِ المضاف.والذِّكْرُ -ههنا- يكون: هو الذي ضد النسيان. وهذا معنى قول: الضحاك، ومقاتل، والواقدي. فإن الضَّخَاكَ قال {15}: ذكروا العَرْضَ الأكبر على الله. ومقاتل والواقدي قالا {16}: تَفكَّرُوا أنَّ اللهَ سائِلُهُم عنه.الوجه الثاني: ذكروا الله بأن قالوا: اللهُمَّ اغفر ذنوبنا، فإنَّا تُبْنا إليك، ونَدِمْنا. وهذا معنى قولِ مُقاتل بن حَيَّان {17}. والذكْر -ههنا- ليس الأولوقوله تعالى: ﴿وَمَنْ يَغْفِرُ الذُّنُوبَ إِلَّا اللَّهُ﴾ قال الفَرَّاءُ {18} هذا محمولٌ على المعنى؛ تأويله: ما يَغْفِرُ الذنوبَ أحَدٌ إلّا اللهُ؛ فلذلك رفعت ما بعد (إلّا) {19}.وقوله تعالى: ﴿وَلَمْ يُصِرُّوا عَلَى مَا فَعَلُوا﴾ يقال: (أصَرَّ {20} على الشيء): [إذا قام عليه] {14}، ودام. ومِن هذا يقال للعَزِيمَةِ {22} التي لا تُنْقَضُ: (صِرِّي) {23}.قال المفسرون {24}: معناه: لم يُقِيموا، ولَمْ يَدُومُوا، [بل تابوا، وأَقَرُّوا] {25}، واستغفروا. والذي يُؤَكِّد هذا القول {26}: أنه تعقب {27} قوله: ﴿ذَكَرُوا اللَّهَ فَاسْتَغْفَرُوا لِذُنُوبِهِمْ﴾ فوَصَفَ الذَّاكرَ بأنه غير مُصِرٍّ {28}. ورُوِيَ عن [النبي] {29} ﷺ أنه قال: ""ما أصَرَّ مَن استَغْفَرَ، وإنْ عادَ في اليوم سبعينَ مَرَّةً"" {30}.وقوله تعالى: ﴿وَهُمْ يَعْلَمُونَ﴾ قال عطاء {31}: يعلمون أنَّ اللهَ يُعذِّب على الإصْرارِ.وقال ابن عباس {32}، والحسن {33}، ومقاتل {34}، والكلبي {35}: وهم يعلمون أن الذي أَتَوْهُ معصية.وقال الحسين بن الفَضْل {36}: وهم يعلمون أنَّ لهم رَبًّا يغفر الذنوب، وكان هذا من قوله- عليه السلام-: ""من أذنب ذَنْبًا، وعَلِمَ أنَّ له رَبًّا يغفر الذنوبَ، غُفِرَ له وإنْ لم يَستَغْفِر"" {37}."
  3,136,"قوله تعالى: ﴿وَنِعْمَ أَجْرُ الْعَامِلِينَ﴾ مختصر المعنى {1}: ونِعْمَ أجْرُ العاملين؛ المغْفِرَةُ. فحُذِفَ؛ لدلالة ما قبله عليه."
  3,137,"قوله تعالى: ﴿قَدْ خَلَتْ مِنْ قَبْلِكُمْ سُنَنٌ﴾ أصل {1} (الخُلُوِّ) -في اللغة-: الانفراد. والمكان الخالي {2}: المنفرد عن الساكن. والخَلِيَّةُ من النُوْقِ: التي ذُبح ولَدُها، فَخَلَت عن الوَلَدِ {3}.ويستعمل في الزمان، والقُرُون، بمعنى: المُضِيِّ، لأن ما مضى انفرد عمَّا يأتي بعده. فالأيَّام الماضية: التي انفردت بالمُضِيِّ عن غيرها، كذلك الأمَم الخالية {4}.والسُّنَنُ: جمع: سُنَّة {5}. والسُّنَّة {6}: الطريقة المستقيمة {7}. ويقال للخط الأسود على مَتْنِ الحِمَار: سُنَّة.و (سَنَّ اللهُ سُنَّةً)؛ أي: بَيَّنَ طريقًا قويمًا. ويقال: (هذه سُنَّةْ اللهِ)؛ أي: أمْرُهُ ونَهْيُهُ وحُكْمُهُ. و (سُنَّةُ النبي ﷺ): طريقته.والسُّنَّةُ {8}: المِثالُ المُتَّبَعُ، والإمام المُؤتَمُّ به. يقال: (سَنَّ سُنَّةً حَسَنَةً، و [سَنَّ] {9} سُنَّةً سيِّئَةً): إذا عمل عملًا اقتُدِيَ به {10}، مِن خيْرٍ أو شَرٍّ.قال لَبِيد:مِنْ مَعْشَرٍ سَنَّت لهمْ آباؤُهُمْ {11} ... ولِكلِّ قَوْمٍ سُنَّةٌ وإمَامُها {12}واختلفوا في اشتقاق (السُّنَّةِ):فقال بعضهم: هي (فُعْلَة)، من: (سَنَّ الماءَ، يَسُنُّهُ): إذا والَى صَبَّهُ. والسَّنُّ: صَبُّ الماءِ، والعَرَقِ، وغيره {13}. قال زُهَيْر: تعودها الطرادَ {14} فَكلَّ {15} يومٍ ... يُسَنُّ على سَنَابِكِها قُرُونُ {16}أي: يُصَبُّ عليها دُفَعٌ {17} من العَرَقِ. يريد: أنهم يُضَمِّرُونها.شُبِّهَ فِعْلُ النبي ﷺ، الذي كان يأتيه مَرَّةً بعد أخرى، بالماءِ المَسْنُون؛ وهو {18}: المصبوب صَبًّا مُتَوَالِيًا. فهي (فُعْلَة) بمعنى: (مفعول)، كـ (الغُرْفَة) {19} من الماء وأشباهها. فَمَا رَسَمَهُ النبي ﷺ: (سُنَّة)، و (مسنون).ويجوز أن يكون من قولهم: (سَنَنْتُ النَّصْلَ والسِّنَانَ، أسُنُّهُ سَنًّا)، فهو (مَسْنُون): إذا أحْدَدْتُهُ على المِسَنِّ {20}. فالفعل {21} الذي كان تهذيبُه منسوبًا إليه، سُمِّيَ (سُنَّة)؛ على معنى: أنه (مَسْنُون).ويجوز أن يكون من قولهم: (سَنَّ الإِبِلَ): إذا أحْسَنَ رِعْيَتَها {22}. فالفعل الذي كان النبي ﷺ يتولَّى رِعايَتَه وإدامَتَه مِن العبادات سُمِّيَ: (سُنَّةً ومسنونًا)؛ ذهابًا إلى أنَّه كان يَتَوَفَّرُ عليها بإقامةِ شروطِها، تَوَفُّرَ الرَّاعِي على الإِبِلِ بإِحْسانِ رَعْيَها. هذا كلامُ أهلِ اللغة في (السُّنَةِ).فأما معنى الآية وتفسيرها؛ فقال أكثر المفسِّرين {23}:معنى الآية: قد مضت منِّي-فيمن {24} [قد] {25} كان قبلكم، من الأمم الماضية المكذِّبَةِ الكافرة-، سُنَنٌ؛ بإمهالي واستدراجي إيَّاهم، حَتَّى يبلغَ الكتابُ فيهم أجَلِي الذي أجلته، في إهلاكهم واستئصالهم، وبَقِيَت لهم آثارٌ في الدنيا، فيها {26} أعظمُ الاتِّعاظِ والاعتبار، فَسِيرُوا في الأرض فانظروا كيف كان [آخِرُ أمْرِ] {27} المكذِّبِين منهم.والمعنى: أنكم إذا سِرْتُم في أسفاركم، عرفتم أخبارَ قومٍ أُهْلِكُوا؛ بتكذيبهم، ورأيتم مصارِعَهم، وما بقي بعدَهم مِن آثارِ مساكنهم، التي [خربت] {28}، فاعتبرتم، وكنتم على حَذَرٍ بما تَرَون {29} في غيرِكم مِن المَثُلاتِ {30} التي نزلت بهم على قبيحِ فِعْلِهم. وهذا في يوم أُحُد، يقول الله: فأنا أمهلهم {31} [حتى يبلغ أجلي الذي] {28} أجَّلْتُ في نُصْرَةِ النبي وأوليائِه، وهلاكِ أعدائِهِ.فـ (السُّنَنُ) -على هذا- جمع: (سُنَّة)، وهي سُنَّة الله عز وجل في [إهلاكِ الأُمَمِ الضالَّةِ] {28}. وهذا تفسير الآية من غير إضمار.وقال {34} ابن عباس -في رواية عطاء- {35}: قد خلت سُنَنٌ مِن قبلِكُم؛ يريد: شرائعُ.قال ابن الأنباري {36}: يعني: شرائع مذمومة؛ لأن باقي الآية يدل على ذَمِّها، وإنَّ المُعَاقَبِينَ بالتكذيب كانوا مُسْتَعْمِلِينَ لها، وجارِينَ {37} على منهاجها، فأقامَ المذكورَ في آخرِ الآيةِ، مقامَ النَّعْتِ لها.وتلخيص الآية: قد خَلَت مِن قبلكم طرائقُ سَلَكها {38} قومٌ، فأهْلِكُوا بِمَعاصيهم وخِلافِهم على أنبيائهم.وقالَ أبو إسحاق {39}: معنى الآية: قد خَلَت [مِن قَبْلِكم] {40} أهلُ سُنَنٍ، وأصحاب سُنَن في الشَّرِّ، [فحذف المضاف] {28}، ولم يذكر (في الشَّرِّ) {42}؛ لأن في الآية دليلًا عليه، فهو {43} إهلاك من اتَّبَعَها.و (العاقبة): آخر الأمر {44}. يقال: (عَقَبَهُ، يَعْقُبُهُ، عَقْبًا، وعُقُوبًا)، وعاقَبَهُ: إذا {45} جاءَ بعده {46}. فالعاقب {47}: الذي يَخْلُف مَن كان قَبْلَهُ {48}.ومنه قيل للنبي ﷺ: (العاقب) {49}."
  3,138,"قوله تعالى: ﴿هَذَا بَيَانٌ لِلنَّاسِ﴾ أي: هذا القرآن. عن أكثر المفسِّرِين {1}.وقال ابن {2} إسحاق {3}: ﴿هَذَا﴾؛ أي: ما ذَكَرْت؛ يعني قولَه: ﴿قَدْ خَلَتْ مِنْ قَبْلِكُمْ سُنَنٌ﴾ [آل عمران: 137]، أي: هذا {4} الذي {5} عَرَّفْتُكم، بيانٌ للناس. قال ابن عباس {6}: يريد: لجميع الخَلْقِ.﴿وَهُدًى﴾. ذَكَرَهُ بعد ذِكْرِ البَيَان؛ لأن البَيَان: ظُهور المعنى للنَفْسِ {7}، كائنًا ما كان {8}. والهُدَى: بَيَانٌ لِطَريق الرُّشْد؛ لِيُسْلَكَ دُونَ {9} طَرِيق الغَيِّ {10}.وقوله تعالى: ﴿وَمَوْعِظَةٌ لِلْمُتَّقِينَ﴾ عَمَّ في أَوَّلِ {11} الآية، عند ذِكْرِ البَيَان؛ لِيَدُلَّ [على] {12} أنَّ الخِطَابَ في التكليف، شَامِلٌ لِلمُشْرِكِ والمُسْلِم. وخَصَّ بـ (الهدى)؛ لأنه يهدي بالقرآن مَن يشاء مِن عِبَادِهِ بفضله."
  3,139,"قوله تعالى: ﴿وَلَا تَهِنُوا وَلَا تَحْزَنُوا﴾ الآية.قالَ الزُهْرِيُّ {1}، وقتادة {2}، وابن أبي نَجِيح {3}: هذه الآية تَسْلِيَةٌ مِن الله -تعالى- للمسلمين، لِمَا نالَهُمْ يومَ أُحُد مِنَ القتل والجَرْح.ومعنى ﴿وَلَا تَهِنُوا﴾: لا تضْعُفُوا. والوَهْنُ {4}: الضَعْفُ في العَمَلِ، وفي العَظْمِ. يقال: (وَهِنَ {5}، يَهِن، وَهْنًا)، فهو (واهِنٌ): إذا ضَعُفَ في العمل. و (مَوْهُونٌ) في العَظمِ والبَدَنِ، و (وهِنَ وَهَنًا)، لُغَةٌ {6}. و (أَوْهَنَهُ اللهُ) {7}، فهو (مَوْهُونٌ)؛ مثل: (أَحَمَّهُ)، فهو (مَحْمُوم)، و (أزْكَمَه) فهو (مَزْكُوم) {8}. ومنه قول طَرَفَة: إنَّنِي لَسْتُ بِمَوْهُونٍ فَقِرْ {9}قال المفسِّرُون: ﴿وَلَا تَهِنُواْ﴾ عن جهاد عدوِّكم، بما نالَكُم مِنَ الهزيمة {10}، ﴿وَلَا تَحْزَنُوا﴾ على ما فاتكم من الغَنِيمَةِ {11}؛ فإنَّكم ﴿وَأَنْتُمُ الْأَعْلَوْنَ﴾؛ أي: لكم تكون العاقِبَةُ بالنَصْرِ والظَّفَرِ.قال ابن عباس {12}: يريد: في الدنيا والآخرة.وقوله تعالى: ﴿إِنْ كُنْتُمْ مُؤْمِنِينَ﴾ يعني: أَنَّ الإيمانَ يُوجِب ما ذكر مِن تَرْكِ الوَهْنِ والحُزْن. فقيلَ: إنْ كُنتم مؤمنين؛ فَلا تَهِنوا ولا تحزنوا؛ أي {13}: من كان مؤمنًا فيجب ألّا {14} يَهِنَ، ولا يَحْزَن؛ لثقته باللهِ -جل وعَزَّ-. وإلى هذا أَشَار ابنُ عبَّاس، فقال {12} في قوله: ﴿إِنْ كُنْتُمْ مُؤْمِنِينَ﴾ يريد: مُصَدِّقِينَ؛ تحريضًا مِنَ اللهِ تعالى لهم.وفيه وجْه آخر، وهو: أن {16} المعنى: إنْ كنتم مؤمنين بِصِدْق {17} وَعْدِي إيَّاكُمْ بالنَصر؛ حتى تَسْتَعْلُوا على عَدُوِّكُم، وتَظْفَرُوا بِبُغْيَتِكُم.وفي قوله: ﴿وَأَنْتُمُ الْأَعْلَوْنَ﴾ وجهان:أحدهما: أنه في موضعُ الحَال؛ كأنَّهُ قيل: لا تَحْزَنوا عَالِينَ؛ أي: منصورين على عَدُوِّكُم {18} بالحُجَّةِ {19}.الثاني: أنه اعتراضٌ بِوَعْدٍ مؤكد؛ كأنه قيل: ولا تَهِنُوا ولا تَحْزَنُوا إنْ كُنْتُم مؤمنين، وأنتم الأَعْلَوْن {20}.وفي هذه الآية إشارَهٌ إلى أنَّ {21} مَنْ كان مؤمنًا، لا يَنْبَغِي له أن يَضْعُفَ لِمَا يَنَاله مِن مُصِيبَةٍ في الدُّنْيَا، بل يجب أن يسكن نفسُهُ، وينتفي حزْنُهُ بما هو عليه مِن الاستعلاء، والفوز بالأُمْنِيَةِ في العاقِبة."
  3,140,"قوله تعالى: ﴿إِنْ يَمْسَسْكُمْ قَرْحٌ﴾ الآية.مَعْنَى ﴿يَمْسَسْكُمْ﴾: يُصِبْكم {1}. يقال: (مَسَّهُ أَمْرُ كذا)، [أو] {2} (مَسَّتْهُ الحَاجَة)؛ أي: أصابته. وتأويله: لَصِقَ بِهِ، وأصابَهُ في ذاته {3}.و (القَرْحُ): قُرِئ بِضَمِّ القَافِ، وفَتْحِه {4}.قال أهل اللغة {5}: هُمَا لُغَتَانِ في عَضِّ السِّلاح ونَحْوِهِ، مِمَّا يَجْرَحُ [الجَسَدَ] {6}، مثل: (الوَجْد، والوُجْد) {7}، و (الضَّعْف، والضُّعْف)، وبابه {8}.قال الفراء {9}: وكأن (القُرْح): أَلَمُ الجِرَاحات، وكأن (القَرْح): الجراحات {10} بأعيانها.وقال الزجاج {11}: هما عند أهل اللغة بمعنى واحد؛ ومعناهما: الجراح وألَمُهَا. يقال: (قَرَحَهُ): إذا جَرَّحهُ {12}.قال الشاعر:لا يُسلِمُونَ قَرِيحًا حَلَّ وَسْطَهُمُ ... يَوْمَ اللِّقَاءِ ولا يُشْوُونَ مَنْ قَرَحُوا {13} و (قَرِحَ الرَّجُلُ، يَقْرَحُ): إذا صَارَ قَرِيحا {14}.قال المفسِّرُون {15}: يقول: إنْ أصابكم جُرْحٌ يوم أُحُد، فقد أصابَ المشركين {16} مثْلُهُ يومَ بَدْر.وقوله تعالى: ﴿وَتِلْكَ الْأَيَّامُ﴾.قال ابنُ عبَّاس {17}: يعني: أيَّام الدُّنْيَا، نُداوِلُها [بَيْنَ النَّاس] {18}. [قال الحَسَنُ] {19}، وقَتادة {20}، والرَّبِيع {21}، والسُّدِّي {22}: نصرفها مَرَّةً لِفِرْقَةٍ ومَرَّةً عليها.والدَوْلَةُ: الكَرَّةُ {23}. و (أَدَالَ اللهُ فُلانًا مِن [فُلان): إذا جَعَلَ الكَرَّةَ لَهُ عليه؛ يريد] {24}: أَنَّهُ أدالَ المسلمينَ مِنَ المُشْرِكين يَوْمَ بَدْر، وأدال المشركين مِنَ المسلمين يوم أُحُد.وقوله تعالى: ﴿وَلِيَعْلَمَ اللَّهُ الَّذِينَ آمَنُوا﴾. اختلفوا في العامل في اللام، فذكروا فيه وجهين:أحدهما: أن اللام صِلَةٌ لِفِعْلٍ مُضْمَر {25}، يدل عليه أولُ الكلام، بتقدير: ولِيَعلم اللهُ الذين آمنوا؛ نُدَاولها {26}.الوجه الثاني: أن العامل فيه: ﴿نُدَاوِلُهَا﴾ {27} المذكور؛ بتقدير: نداولها بين الناس؛ ليظهر أمرهم، وليَتَبَيَّنَ {28} أعمالَهم، وليعلم الله الذين آمنوا.فَلَمَّا انكشف معنى اللّامِ المُضمَرة في (لِيظهر)، و (لِيَتبيَّن)، جرت مجرى الظاهرة؛ فأمكن {29} العطْفُ عليها. [و] {30} الوجهان، ذكرهما ابنُ الأنباري {31}، وغيرُهُ مِن أهلِ النَّحْو.و (العِلْمُ) إذا لم يتعلق بالذَّاتِ، اقتَضَى مَعْلُومَيْنِ؛ كما تقول: (عَلِمْتُ زَيْدًا عاقلًا، وَجَوادا). فلا {32} تقول: (عَلِمْتُ زَيْدًا) فقط؛ إلّا أن تريد به: عَرَفْتَهُ، وعَلِمْتَ مَنْ هُوَ {33}.والمفعول الثاني -ههنا- محذوف. والتقدير: وَلِيَعلمَ اللهُ الذين آمنوا [مُمَيَّزينَ] {34} بالإيمان مِنْ غيرهم؛ أي: إنما يجعل الدَّولةَ للكفارِ على المسلمين، لِيُميِّزَ {35} [المؤمن] {34} المخلص {37}، مِمَّن يرتد عن الدين إذا أصابته نكبةٌ.ويحتمل أن يكون (العِلْمُ) -ههنا- بمعنى: معرفة الذات؛ والتأويل: وَلِيَعلمَ اللهُ الذين آمنوا بما يظهر من صبرهم على جهاد عدوِّهم؛ أي: لِيَعرِفَهم بأعيانهم. إلَّا أنَّ سَبَبَ العِلْم، -وهو: ظهور الصبر -حذف ههنا-.وقال الفراء {38}: هذا في مذهب [(أيّ)] {39} و (مَنْ)؛ التأويل: ليعلم الله مَن المؤمن، وأيّهُم المؤمن؛ كما قال: ﴿لِنَعْلَمَ أَيُّ الْحِزْبَيْنِ أَحْصَى﴾. وجاز ذلك؛ لأنَّ في (الذي)، وفي الأَلِفِ واللَّامِ تأويل (مَن) و (أيّ)؛ كما قال: ﴿فَلَيَعْلَمَنَّ اللَّهُ الَّذِينَ صَدَقُوا وَلَيَعْلَمَنَّ الْكَاذِبِينَ﴾ [العنكبوت: 3].وتأويل قوله: ﴿وَلِيَعْلَمَ اللَّهُ الَّذِينَ آمَنُوا﴾، واللهُ تعالى يعلم الشيءَ قبلَ وُجُودهِ، ولا يحتاج إلى سَبَبٍ حَتى يعلم؛ وإنما المعنى: وَلِيَعْلَمَ ذلك واقِعًا منهم.أي: لِيَقَعَ ما عَلِمَهُ غَيْبًا، مُشَاهَدَةً للناس. والمُجَازاة إنَّمَا تَقَع بِما يعلمه موجودًا كائِنًا، لا {40} بِمَا عَلِمَهُ غَيْبًا {41}. وهذا كقوله: ﴿وَلَنَبْلُوَنَّكُمْ حَتَّى نَعْلَمَ الْمُجَاهِدِينَ مِنْكُمْ وَالصَّابِرِينَ﴾ [محمد: 31]. وقد استقصينا ما في هذا عند قوله: ﴿إِلَّا لِنَعْلَمَ مَنْ يَتَّبِعُ الرَّسُولَ﴾ [البقرة: 143].وقوله تعالى: ﴿وَيَتَّخِذَ مِنْكُمْ شُهَدَاءَ﴾ أي: وَلِيُكْرِمَ قَوْمًا بالشَّهَادةِ؛ وذلك أنَّ المسلمين تَمَنَّوْا لِقَاءَ العَدُوَّ، وأنْ يَكُونَ لهم يومٌ كيوم بَدْر، يقاتِلُوا فيه العَدُوَّ، ويَلْتَمِسُوا الشهادة {42}.والشُّهَدَاء: جمع شَهِيد؛ كـ (الكُرَمَاء)، و (الظُّرَفَاء). والمقتول مِنَ المسلمين بِسَيْفِ الكُفَّار، يُسَمَّى: شهيدًا.واختلفوا فيه: لِمَ سُمِّيَ شهيدًا؟:فقال النَضْرُ بن شُمَيْل {43}: الشَّهِيد: الحَيُّ. قال الأزهري {44}: أراه تَأَؤَّلَ قولَ اللهِ جلَّ وَعَزَّ: {وَلَا تَحْسَبَنَّ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللَّهِ أَمْوَاتًا بَلْ أَحْيَاءٌ عِنْدَ رَبِّهِمْ} {45}، كأنَ أرواحَهُم أُحْضرَت {46} دارَ السَّلام [أحياءً، و] {47} أرواحَ غيرهم لا يَشهَدها {48}. وهذا قولٌ حَسَنٌ.وقال ابنُ الأنباري {49}: سُمَّي شهيدا، لأن الله وملائكته شُهُودٌ له. فهو (فَعِيل)، بمعنى: (مَفْعُول له).وقال قومٌ {50}: سُمُّوا شُهَداء؛ لأنهم يُسْتَشْهَدُونَ يومَ البَعثِ {51}، مع الأنبياء والصِّدِّيقِينَ على الأمم؛ كما ذَكَرَهُ اللهُ تعالى في قوله: ﴿لِتَكُونُوا شُهَدَاءَ عَلَى النَّاسِ﴾ [البقرة: 143].قالَ أبو منصور {52}: والشهادة -يومئذ- تكون للأفضل {53} فالأفضل مِنَ الأُمَّةِ. فأفضلهم مَن قُتِلَ في سبيل الله؛ أَبَانَهم اللهُ من غيرهم -بالفضل الذي يميَّزوا به- مِن جَمَاعَةِ المؤمنين. {54} وبَيَّن أنَّهم ﴿أَحْيَاءٌ عِنْدَ رَبِّهِمْ﴾ [آل عمران: 169]، الآية. ثم يتلوهم في الفضل مَنْ عَدَّه النبيُّ ﷺ مِنَ المسلمين شهيدا؛ فإنه قال: ""المَبْطْونُ شَهِيد {55}، والغرِيق شَهيد {56} "" {57}.وذَكَرَ -أيضًا- غيرَ هذين. ويدل على هذا ما رُوي أنَّ النَبِيَّ ﷺ قال: ""مالَكُمْ إذا رَأَيتم الرَّجلَ يُخَرِّقُ {58} أغرَاَض الناس، ألآ تُعَرِّبُوا عليه {59} ""؟ فقالوا: نَخَاف لِسَانَهُ يا رَسُولَ الله. فقال: ""ذلك [أدْنَى] {60} أنْ لا تَكُونوا شُهَداء"" {61} معناه: أنكم إذا لَمْ تُعَرِّبُوا على مَن يتناول أعراضَ المسلمين؛ مَخَافَة لِسَانِهِ، لم تَدْخُلُوا في جُمْلَةِ المُسْتَشْهَدِين يومَ القيامة على الأمم التي كَذَّبَتْ أنبياءَها.وقيل في الشَّهِيد: إنَّه سُمِّيَ (شَهِيدا) {62}: لأنه شَهِد الجَنَّة؛ أي: حَضَرَها حين استشهد. فهو على هذا التأويل، بمعنى {63}: (شاهد)، وهو: الحاضر؛ كما يقال: (سميع وسامع)، و (عليمٌ وعالِم) {64}. وهذا قريب مِمَّا قاله ابنُ شميل {65}.وقوله تعالى: ﴿وَاللَّهُ لَا يُحِبُّ الظَّالِمِينَ﴾ قال ابن عباس {66}: أي: المشركين.وفي هذا [إشارة] {18} إلى أنه إنَّما [يُدِيل] {68} الكافرين على المؤمنين؛ لِمَا ذَكَرَ {69}، لا {70} لأنَّهُ يُحِبُّهم. وإذْ {71} أَدَالَ المؤمنين، أدَالَهُمْ نُصْرَةً لهم، ومَحَبَّةً منه إيَّاهم.وجملة معنى الآية: أنها [تَسْلِيَة] {18} للمؤمنين [عَمَّا نالَهُم مِنَ الجِرَاح] {18} بِأَنَّ عَدُوَّهم قد نَالَ مِثْلَهُ، وأَنَّ سُنَّةً لَهُ في عِبَادِهِ أنْ يَبْلُوهم مَرَّةً بالخير، ومَرَّةً بالشَّرِّ [كما قال] {18}: ﴿وَنَبْلُوكُمْ بِالشَّرِّ وَالْخَيْرِ فِتْنَةً﴾ {75}] {18}."
  3,141,"قوله تعالى: ﴿وَلِيُمَحِّصَ اللَّهُ الَّذِينَ آمَنُوا﴾ أي: لِيُظْهِرَهم {1} مِن ذنوبهم، وُيسْقِطَها عنهم. وتأويل (المَحْص) [-في اللغة-: التَّنْقِيَةُ والتَّخْلِيص {2}] {3}.قرأت على سَعِيد بن محمد الحِيري، فقلت: أَخْبَرَكم أبو علي الفارسي، عن الزجَّاج، قال: سمعت المبَرِّد يقول: (مَحَصَ {4} الحبْلُ، يَمْحَصُ، مَحْصًا) {5}: إذا ذهب زِئْبِرُهُ {6} حتَّى [يَمَّلِصَ] {7}و (حبْلٌ مَحِصٌ، ومَلِصٌ)، بمعنًى واحدٍ {8}.قال {9}: ويُسْتَحَبُّ مِن الفَرسِ أنْ تَمْحَصَ {10} قوائِمُهُ؛ أي {11}: تَخْلُصَ من الرَّهَلِ {12}. وأنشد {13} ابنُ الأنباريِّ {14} -على هذا- لأبي دُوَاد {15}، يَصِف قوائمَ الفرس:صُمِّ النُّسُورِ صِحاحٌ غيرُ عاثِرَةٍ ... رُكِّبْنَ في مَحِصَاتٍ مُلْتَقَى العَصَبِ {16} قوله: (في مَحِصَات)؛ معناه: في قوائمَ مُتَجَرِّداتٍ عن اللحم، ليس فيها إلا العَظْمُ، والعَصَبُ، والجِلْدُ {17}.قال المُبرِّد {18}: وتأويل قول الناس: (مَحِّصْ عنَّا ذُنُوبَنا)؛ أي: أذهب {19} ما تَعَلَّقَ بنا مِنَ الذُّنُوب.وهذا الذي ذكره المبرِّدُ، تأويل (المَحَصِ) -بفتح الحاء-، وهو واقعٌ {20}، و (المَحْص) -بسكون الحاء- مطاوع {21}.قال الخليل {22}: يقال: (مَحَصْتُ الشيءَ، أَمْحَصُه، مَحْصًا): إذا خَلَّصته من كلِّ عَيبٍ. قال رُؤبَةُ -يصف فَرَسا {23} -:[شَدِيدُ] {24} جَلْزِ الصُّلْبِ مَمْحُوصُ الشَّوَى {25} ومِن هذا؛ يُقال للسِّنَانِ المَجْلُوِّ: (مَمْحُوص) {26}. قال أُسَامَةُ الهُذَلِيُّ {27}:وَشَقّوا {28} بمَمْحُوصِ القِطَاعِ {29} فُؤَادهُ {30}يعني: بِمَجْلُوِّ النِّصَالِ {31}.فمعنى قوله: ﴿وَلِيُمَحِّصَ اللَّهُ الَّذِينَ آمَنُوا﴾ أي: لِيُخَلِّصهم مِن ذُنوبهم. وإلى هذا ذَهَب أكثرُ أهلِ المعاني والتفسير.وقال {32} ابن عباس {33}: يريد {34}: يُمَحِّصَ ذنوبَهم حتى يَلْقَوْهُ؛ وليس لهم قَبْلَهُ سَيِّئَةٌ يعذبهم عليها. ووجه هذا القول: ما قاله أبو عَمْرُو الشيباني {35}: معنى التمحيص في اللغة: الكشف. و (مَحِّصْ عنَّا ذنوبَنا)؛ معناه: واكشف {36} عنَّا ذنوبَنا. و (تَمَحَّصَ الشيءُ): إذا تَكَشَّفَ. وأنشد:حتى بَدَتْ قَمْرَاؤُهُ وتَمَحَّصَتْ ظَلْمَـ ... ـاؤُهُ {37} ورَأَىَ الطريقَ المُبْصِرُ {38}وهذا اختيار الفرَّاء؛ لأنه قال {39}: يريد: لِيُمَحِّصَ {40} اللهُ الذنوبَ عن الذين آمنوا.وعلى هذا القول؛ تقدير الآية: وَلِيُمَحِّصَ الله ذنوبَ الذين آمنوا. فحذف المضاف {41}.وروى أبو عُبَيْد {42}، عن أبي عَمْرو، قال {43}: التَّمْحِيص: الابتلاء والاختبار {44}. وإلى هذا القول ذهب جماعة من المفسرين: السُّدِّي {45}، ومجاهد {46}، وروي ذلك عن ابن عباس -في بعض الروايات- {47}، قالوا: ﴿وَلِيُمَحِّصَ﴾ أي: لِيَبْتَلِي. وهذا اختيار القُتَيْبِيِّ {48}.وقوله تعالى: ﴿وَيَمْحَقَ الْكَافِرِينَ﴾.(المَحْقُ) في اللغة معناه: النُّقْصَان.يقال: (مَحَقَهُ اللهُ، فامْتَحَقَ، وامَّحَقَ) {49}.وقال أبو زيد {50}: (مَحَقَهُ اللهُ)، و (أَمْحَقَهُ). والأصمعي يأبى إلّا (محَقَه) {51}. وأما (أَمْحَق) {52}، فقال أبو عمرو {53}: هو أن يَنْقُصَ ويَدِقَّ {54}، كَمُحَاقِ {55} الهِلالِ.وأنشد ابن السِّكِّيت {56}:... حتى أنسَّ وأَمْحَقَا {57} وقال ابن الأعْرَابي -عن المفَضَّل- {58}: (المَحْقُ) -عند العرب {59} -: أن يذهب الشيءُ كلُّهُ، حتى لا يُرَى مِنْهُ شيءٌ. ومنه ﴿يَمْحَقُ اللَّهُ الرِّبَا﴾ {60}، أي: يستأصله.قال أبو إسحاق {61}: ومعنى الآية: جَعَلَ اللهُ الأيَّامَ مُدَاوَلَةً بين الناس؛لِيُمَحِّصَ اللهُ المُؤْمنينَ، إذا أدَالَ عليهم، بما يقع عليهم {62} مِنْ قَتْلٍ وَجُرْحٍ وذَهابِ مَالٍ. و ﴿وَيَمْحَقَ الْكَافِرِينَ﴾: يستأصلهم، إذا أدال عليهم، ويهلكهم بذنوبهم.فَقَابَلَ {63} تَمْحِيصَ المؤمنين بِمَحْقِ الكافرين، لأن تمحيص هؤلاء، بإهلاك ذنوبهم، نَظِير مَحْقِ أولئك، بإهلاك أنْفُسِهِمْ. وهذا مُتقابِلٌ في المعنى، حَسَنٌ."
  3,142,"قوله تعالى: ﴿أَمْ حَسِبْتُمْ أَنْ تَدْخُلُوا الْجَنَّةَ﴾ الآية {1}.معنى ﴿أَمْ حَسِبْتُمْ﴾: (بَلْ حَسِبْتُم)، على جهة الإنكار {2}، أي: لا تحسبوا ذلك. ومضى الكلام في هذا، في مواضع {3}.وقوله تعالى: ﴿وَلَمَّا يَعْلَمِ اللَّهُ الَّذِينَ جَاهَدُوا مِنْكُمْ﴾.قال أبو إسحاق {4}: (لَمَّا) جوابٌ لقولِ القائل: (قَدْ فَعَلَ فُلان). فجوابه: (لَمَّا {5} يَفْعَل)؛ لأن (لَمَّا) مُؤَكَّدٌ بِحَرْفٍ؛ كما أُكِّدَ الابتداءُ بـ (قد).وإذا قال: (فَعَلَ فلان)، فجوابه: (لَمْ يَفْعَل). وإذا قال: (لَقَد فَعَل)، فجوابه: (ما فَعَل) {6} كأنه قال: (واللهِ لَقَد فَعَل) {7}، وقال المُجِيبُ: (واللهِ ما فَعَل) وإذا قال هو يفعل فجوابه و (لا يَفْعَل) {8} وإذا قال سيفعل فجوابه (لن يفعل) و (لا يفعل).والنَفْيُ في الآية، واقِعٌ على العِلْمِ. والمعنى: على نَفْي الجِهَادِ دونَ العِلْم؛ وذلك لِمَا فِيهِ مِنَ الإيجاز في انتفاءِ جهادٍ؛ لَوْ كانَ؛ لَعَلِمَهُ.والتقدير: (ولَمَّا لم {9} يكن المعلوم من الجهاد الذي أَوْجَبَ عليكم). فجرى النفيُ على العِلْمِ؛ للإيجاز؛ على سبيل التوسع في الكلام؛ إذ المعنى مفهومٌ مِن غير إخلال.وقال الزجاج {10}: المعنى: وَلَمَّا يقع العِلْمُ بالجهاد، والعِلْمُ بِصَبْرِ الصابرين؛ أي {11}: وَلمَا يَعْلَمِ اللهُ ذلك واقِعًا منكم {12}؛ لأنه يَعْلَمُه غَيْبًا {13}، وإنما يجازيهم على عَمَلِهِم.وقوله تعالى: ﴿وَيَعْلَمَ الصَّابِرِينَ﴾ انتصب على الصَّرْفِ {14} عن العطف {15}. إذ ليس المعنى على نفي الثاني والأول، وإنما هو على نفي اجتماع الثاني والأول؛ على نحو: (لا يَسَعُنِي {16} شيءٌ، وَيعْجَزَ {17} عنك). ومثله:لاَ تَنْهَ عَنْ خُلُقٍ وَتَأتِيَ مِثْلَهُ {18} قال الفراء {19}: ومعنى (الصرف): أن يجتمع فِعْلان ببعض حروف النَّسَقِ {20}، وفي أوَّلِهِ ما لا يَحْسُنُ إعادَتُه في حروف النَّسَقِ {21}، فتنصب الذي بعد حرف العطف، لأنه مَصرُوفٌ عن معنى الأول. وذلك يكون مع جْحدٍ أو استفهامٍ أو نَهْيٍ في أول الكلام. كقولهم: (لا يَسَعُنِي مكانٌ، ويَضِيقَ عنك) بفتح (ويضيقَ)، لأن (لا) التي مع (يَسَعُنِي)، لا يَحْسُن أن يذكرها مع (يضيقَ عنك) {22}.وقال ابن الأنباري {23}: قوله تعالى: ﴿وَيَعْلَمَ الصَّابِرِينَ﴾ معناه: الحال لِمَا قبله. وهذه الواو، يُسَمُّون {24} النحويون: (واو الصرف)، والذي بعدها يُنْصَبُ {25} على خلافِ ما قبلها. كما تقول العربُ: (لا تأكل السَّمَكَ، وتَشْرَبَ اللَّبَنَ {26})؛ أي: لا تجمع بينهما، ولا تأكلِ السَّمَكَ، في حال شُرْبِكَ اللَّبَنَ.قال: وقَرَأ الحَسَنُ: ﴿وَيَعْلَمَ الصَّابِرِينَ﴾ -بالكسر- {27}، وهو جزمٌ بالعطف على الأول، وليس بحالٍ لما قبله.وهذه الآية خطابٌ للذين انهزموا يوم أحد، فقيل لهم: أَحَسِبتم أنْ تدخلوا الجَنَّةَ، كما دَخَلَ الذين قُتِلوا، وبَذَلُوا مُهَجَهُم {28} لِرَبِّهم، وثَبَتُوا على أَلَمِ الجِرَاح والضَّرْبِ، مِن غير أنْ تَسْلُكُوا {29} طَرِيقهم، وتصبروا صَبْرَهُمْ."
  3,143,"قوله تعالى: ﴿وَلَقَدْ كُنْتُمْ تَمَنَّوْنَ الْمَوْتَ﴾ الآية.قال الحسن {1}، ومجاهد {2}، ..................وقتادة {3}، والرَّبِيع {4}، والسُدِّي {5}، ومحمد بن إسحاق {6}: كانوا يَتَأسَّفُون {7} على ما فاتهم مِن [بَدْر] {8}، ويَتَمَنَّون يوما مع رسول الله ﷺ، ويقولون: لَنَفْعَلَنَّ ولَنَفْعَلَنَّ، ثم انهزموا يوم أُحُد، واستحقوا العِتَاب {9}.وقوله تعالى: ﴿مِنْ قَبْلِ أَنْ تَلْقَوْهُ﴾. يعني: مِن قَبْلِ يوم أُحُد.وقوله تعالى: ﴿فَقَدْ رَأَيْتُمُوهُ﴾ أي: رأيتم أسبابَهُ، وما يتولَّدُ منه الموتُ {10}؛ كالسَّيْفِ، والأَسِنَّةِ، ونحوِها {11}.وقوله تعالى: ﴿وَأَنْتُمْ تَنْظُرُونَ﴾.قال الأخفش {12}: هو تَوْكيدٌ {13} لقوله: ﴿فَقَدْ رَأَيْتُمُوهُ﴾.وقال أبو إسحاق {14}: المعنى: فقد رأيتموه، وأنتم بُصَرَاء؛ كما تقول: (رأيت كذا وكذا)، وليس في عينيك {15} عِلَّة {16}؛ أي: قد رأيته رؤيةً حقيقية، وهو راجع إلى معنى التوكيد.وقال غيره {17}: لِئَلَّا يُتَوَهَّم رؤية القَلْبِ؛ كما يقال: (رأيته عِيَانًا)، و (سمعته بأذني)؛ لئلا يتوهم سَمْع العِلْمِ.وقيل {17}: ﴿وَأَنْتُمْ تَنْظُرُونَ﴾؛ أي: تَتَأَمَّلُون الحالَ في ذلك، كيف هي؟ {19} وفي الآية محذوفٌ، لأن المعنى: (فقد رأيتموه، وأنتم تنظرون، فَلِمَ انهزمتم)؟ وهذا موضعُ العِتَاب. وهو قول ابن عباس {20}."
  3,144,"وقوله {1} تعالى: ﴿وَمَا مُحَمَّدٌ إِلَّا رَسُولٌ﴾ الآية.قال أهل التفسير {2}: لَمَّا نُعِيَ رَسُولُ الله ﷺ يومَ أُحُد، وأُشِيعَ أنه قد قُتِل، قال بعضُ المسلمين: لَيْتَ لَنَا رَسُولًا إلى عبد الله بن أُبَيّ، فيأخذ لنا أَمَانًا مِنْ أَبِي سُفْيان!وقال أناسٌ مِنْ أهل النِّفَاق: إنْ كان محمدٌ قد قُتِلَ، فالْحَقُوا بدينكم {3} الأَوَّل؛ فأنزلَ الله هذه الآية {4}.و (مُحَمَد) {5} هو المُسْتَغْرِقُ لجميع المَحَامِدِ؛ لأن الحَمْدَ لا يَسْتَوْجِبُهُ إلَّا الكامِلُ. و (التَحْمِيد) فوق {6} (الحَمْدِ) {7}، فلا يستحقه إلا المستولي على الأَمَدِ {8} في الكمال.و (الرَّسُول) -قال ابن الأنباري، فيما حكى عنه الأزهري- {9}: معناه في اللغة: الذي يُتَابع أخبار مَنْ {10} بَعَثَهُ {11}؛ أُخِذَ مِنْ قولهم: (جاءت {12} الإِبِلُ رَسَلًا) {13}؛ أي: متتابعة {14}.فمعنى {15}: ﴿وَمَا مُحَمَّدٌ إِلَّا رَسُولٌ﴾ أي: إلَّا مُتَابع للأخبار عن الله.وقال الأخفش {16}: (الرسول): هو {17} الرِّسَالة، وهو اسمٌ مِنْ (أَرْسَلْتُ) {18}.وقال أبو علي {19}: (الرسول)، جاء على ضربين: أحدهما: يراد به المُرْسَلُ، والآخر: الرِّسَالة.وقوله تعالى: ﴿وَمَا مُحَمَّدٌ إِلَّا رَسُولٌ﴾، يريد: المُرْسَل. يُقَوِّي ذلك قوله: ﴿إِنَّكَ لَمِنَ الْمُرْسَلِينَ﴾ [يس: 3]. ومثل {20} هذا في (فعُول)، يراد به (المفعول): (الرَّكُوب)، و (الحَلُوُب): لِمَا يُحْلَبُ، ويُرْكَبُ {21}.والرسول بمعنى الرسالة كقوله:لَقَدَ كَذَبَ الواشُوُنَ مَا {22} بُحْتُ عِنْدَهُمْ ... بِسِرٍّ وَلاَ أَرْسَلْتُهُمْ بِرَسُولِ {23}أي: برسالة. ومِنْ هذا قولُهُ تعالى: ﴿أَنَا رَسُولُ رَبِّكِ﴾ [مريم: 19] {24}.وسنذكره {25} في موضعه إن شاء الله.وقوله تعالى: ﴿قَدْ خَلَتْ مِنْ قَبْلِهِ الرُّسُلُ﴾ معناه: أنه يموت كما ماتت الرُّسُلُ قَبْلَهُ. وقوله تعالى: ﴿أَفَإِنْ مَاتَ أَوْ قُتِلَ﴾ ألِفُ {26} الاستفهام دخلت على حرف الشرط؛ ومعناها: الدخول على الجزاء. المعنى: (أتنقلبون على أعقابكم؛ إن مات محمَّدٌ {27} أو قُتِلَ)، إلّا أنَّ الشرط والجزاء مُعَلَّقٌ أحدُهُما بالآخَرِ، فانعقدا جملةً واحدةً، وخَبَرًا واحدًا؛ فدخلت أَلِفُ الاستفهام على الشرط، وأَنْبَأَت عن معنى الدخول على الجزاء؛ كما أنك إذا قلت: (هل زيدٌ قائمٌ؟)؛ فإنما تستفهم عن قيامِهِ، إلّا أنك أَدْخَلْتَ (هَلْ) على الاسم؛ لِيُعْلَمَ الذي استفهمتَ عن قيامه، مَنْ هُوَ؟ وكذلك قولك {28}: (ما زيدٌ قائما)، إنما نَفَيْتَ القيامَ، ولم تَنْفِ زيدًا، ولكنك أدخلت (ما) على (زيد)؛ ليُعْلَمَ مَن الذي نُفِيَ عنه القيامُ. يوضح هذا: أن هذا الاستفهام للإنكار، ولم ينكر عليهم الموت، وإنما أنكر عليهم الانقلاب.وقوله تعالى: ﴿انْقَلَبْتُمْ عَلَى أَعْقَابِكُمْ﴾ أي: ارْتدَدْتُم كُفَّارًا بعد إيمانكم؛ وذلك؛ لأن الرجوع عن الحق إلى الباطل، بمنزلة رجوع القَهْقَرَى {29}، في القُبْح والتنكيل بالنفس.ويقال لكلِّ مَن عادَ إلى ما كان عليه، ورَجَعَ ورَاءَهُ {30}: انقَلَبَ على عَقِبِهِ {31}.وقوله تعالى: ﴿وَمَنْ يَنْقَلِبْ عَلَى عَقِبَيْهِ فَلَنْ يَضُرَّ اللَّهَ شَيْئًا﴾ فيه معنى الوعيد؛ أي: فإنما يَضُرُّ نَفْسَهُ؛ باستحقاق العِقَاب.﴿وَسَيَجْزِي اللَّهُ الشَّاكِرِينَ﴾ بِمَا يستحقونه مِنَ الثَّوَاب. قال ابن عباس {19}: يريد: الطائعين لله من المهاجرين والأنصار."
  3,145,"وقوله تعالى: ﴿وَمَا كَانَ لِنَفْسٍ أَنْ تَمُوتَ إِلَّا بِإِذْنِ اللَّهِ﴾ الآية.قال الأخفش {1}، والزجَاجُ {2}: اللَّام في (لِنَفْسٍ) {3}؛ معناها: النقل؛ بتقدير: وما كانت نفسٌ لِتَموتَ إلّا بِإذْنِ اللهِ {4}.قال ابن عباس {5}: يريد: بقضائه وَقَدَرِهِ. وفي هذا رَدٌّ على القَدَريَّةِ؛ حيث قالوا: إنَّ المقتول لا يكون مَيتًا بِأَجَلِهِ {6}.واختلفوا في المراد بهذا: فقال بعض {7} أهل المعاني {8}: المراد به التَّسْلِيَةُ عَمَّا يلحق النفسَ بموت النبي ﷺ إذا {9} وَقعَ. من جهة أنه إذا وَقَعَ كان بإذن الله.وقال بعضهم {10}: المراد به: الحَضُّ على الجهاد، من حيث لا يموت أحدٌ فيه إلّا بإذن الله. وقال ابن الأنباري {5}: عاتب اللهُ تعالى {12} بهذا المُنْهَزِمينَ يوم أُحُد؛ رَغْبَةً في الدنيا، وَضَنًّا بالحياة، وأخبرهم أن الحياة [لا تزيد] {13} ولا تنقص، وأنَّ الموتَ بِأَجَلٍ عنده، لا يتقدم ولا يتأخر.وقوله تعالى: ﴿كتَابًا مُؤَجَّلًا﴾ إنتصب ﴿كِتَابًا﴾ بالفعل الذي دلّ عليه ما قبله، وذلك أن قوله: ﴿وَمَا كَانَ لِنَفْسٍ أَنْ تَمُوتَ إِلَّا بِإِذْنِ اللَّهِ﴾، يدل على: (كَتَبَ). وكذلك قوله: ﴿كِتَابَ اللَّهِ عَلَيْكُمْ﴾ [النساء: 24]، لأن في قوله: ﴿حُرِّمَتْ عَلَيْكُمْ أُمَّهَاتُكُمْ﴾ [النساء: 23]، دِلاَلَةً على: (كَتَبَ هذا التحريمَ عليكم). ومثله: ﴿صُنْعَ اللَّهِ﴾ [النمل: 88]، و ﴿وَعَدَ اللَّهُ﴾ [النساء: 122].و (المُؤَجَّلُ): ذو الأَجَلِ. و (الأَجَلُ): الوقت المعلوم {14}.[و] {15} قال عطاء {5}، ومقاتل {17}: يريد مُؤَجَّلًا إلى أجله الذي هو في اللوح المحفوظ.وقوله تعالى: ﴿وَمَنْ يُرِدْ ثَوَابَ الدُّنْيَا نُؤْتِهِ مِنْهَا﴾ قال المفسرون {18}: أي: من يُرِدْ بطاعته وعمله زينةَ الدنيا، وزُخْرُفَهَا؛ نُؤْتِهِ منها.قال أهل المعاني {19}: هو مُجْمَلٌ {20}، ومعناه: نؤته منها ما نشاء، مِمَّا قَدَّرناه له {21} كقوله: ﴿مَنْ كَانَ يُرِيدُ الْعَاجِلَةَ عَجَّلْنَا لَهُ فِيهَا مَا نَشَاءُ لِمَنْ نُرِيدُ﴾ [الإسراء: 18].يعني بهذا: الذين تركوا المَرْكَزَ يوم أُحُد طلبًا للغنيمة، ورَغْبَةً في الدنيا {22}.﴿وَمَنْ يُرِدْ ثَوَابَ الْآخِرَةِ﴾ أي: مَنْ كانَ قَصْدُهُ بِعِمْلِهِ ثَوَابَ الآخرة. قال عطاء {5}: يعنى: زينَتَها ومُلْكَها وسُرُورَهَا.﴿نُؤْتِهِ مِنْهَا﴾. يعني بهذا: أولئك الذين ثَبَتُوا يومَ أُحُد حتى قُتِلُوا {24}.أعْلَمَ الله -تعالى- أنَّهُ يُجازي كُلًّا على قَصْدِهِ وإرادته، فَمَنْ نَصِبَ للدنيا، و {25} عمل لها، أُعْطِيَ منها حظًّا على قَدْرِما قُسِمَ له، ومَن عَمِلَ للآخرة فاز بها {26}، كما رُوِيَ عن {27} النبي ﷺ في قوله: ""الأعمال بالنيَّاتِ"" {28}، الحديث المعروف.وأَنَّثَ الكِنَاية {29} في ﴿مِنْهَا﴾، -وهي {30} في المعنى راجعةٌ إلى الثواب-؛ لأن ثوابَ الدنيا، هو: الدنيا، وثوابَ الآخرة، هو: الآخرة. فرجوع الكِنَايَةِ إليها، كرجوعها {31} إلى الثواب. ويقول القائل: (اللهم ارزقني الآخرة)؛ وهو يريد: ثوابَها.وقوله تعالى: ﴿وَسَنَجْزِي الشَّاكِرِينَ﴾ قيل {32}: إنَّه تكريرٌ للتأكيد الذي يُوجِبُ تمكين المعنى في النَّفْسِ؛ لأنه قد قال في الآية الأولى: ﴿وَسَيَجْزِي اللَّهُ الشَّاكِرِينَ﴾.وقال محمد بن إسحاق {33}: فيه إشارةٌ إلى أنَّ مَنْ أرادَ بِعَملِهِ الآخرةَ، أُعْطِيَ ثوابَها، ولَمْ يُحْرَمْ مِن الدنيا ما يُعطَاه مِنْ عَمَلِ الدنيا {34}، مِمَّا قُسِمَ له."
  3,146,"قوله تعالى: ﴿وَكَأَيِّنْ مِنْ نَبِيٍّ﴾.اجتمعوا {1} على أنَّ معنى (كَأَيِّنْ): كم {2}؛ وتأويلها: التكثير لعدد الأنبياء الذين هذه صفتهم. والكاف {3} في (كَأَيِّنْ) كافُ التَّشْبِيه، دخلت على (أيٍّ)، التي هي الاستفهام-، كما دخلت على (ذا) مِن (كَذَا {4}، و (أَنَّ) مِن (كَأَنَّ)، ولا معنى للتشبيه فيه، كما أنه لا معنى للتشبيه في (كَذَا)؛ لأنك تقول: (لي عليه كَذَا وكَذَا)؛ معناه: لي عليه عددٌ مَّا. فلا معنى للتشبيه. إلا أنها زيادةٌ لازمةٌ، لا يجوز حذفُها.ولم يقع للتنوين صورةٌ في الخط، إلا في هذا الحرف خاصَّةً.وكَثُرَ استعمالُ هذه الكلمة، فصارت كَكَلِمَةٍ واحدةٍ، موضوعة للتكثير؛ كقول الشاعر:كأيِّنْ في المَعَاشِرِ مِنْ أُنَاسٍ ... أخُوهُم فوقَهْمْ وهُمُ كِرَامُ {5}أي: كَم مِن أُنَاسٍ.وقرأ ابنُ كَثِير {6}: ﴿وَكَائِنْ﴾ {7}، في وزن: (كاعِنْ).ووجه هذه القِرَاءةِ: أن {8} (كأيِّنْ) لَمَّا جُعِلَت كلمةً واحدةً، قُلِبت قَلْبَ الكلمة الواحدة؛ كما فُعلَ ذلك، فيما حكاه أحمد بن يحيى {9} مِن قولهم: (لَعَمْري)، و (رَعَمْلِي)، فصارت بالقَلْبِ (كَيَّإن). فَحُذِفت {10} الياءُ الثانيةُ تخفيفًا؛ كما حُذِفَت مِن (مَيْت) و (هَيْن) و (لَيْن) {11}، فصارت: (كَيْإنْ) {12} بعد الحذف، ثم أبْدِلت من الياء الألف؛ كما أبدلت في (طَائِيٍّ) {13}، وكما أبدلت في (آيَةٍ) عند سيبويه {14}، وكانت (أَيَّةً) {15}، وقد حُذِفَت الياءُ مِن (أَيٍّ) في قول الفرزدق:تَنَظَّرْتُ نَضرًا والسِّماكَيْنِ أيْهُمَا {16} ... عَلَيَّ مِنَ الغَيثِ اسْتَهَلَّتْ مَواطِرُهْ {17} فَلَمَّا أُبْدِلَت الألفُ مِن الياء، صارت: (كَائِنْ)، على وزن: (كاعِنْ). وأكثر ما جاء في الشعر، على هذه اللغة.قال جرير:وكايِنْ في الأَبَاطِحِ مِن صَدِيقٍ ... يَرَانِي لَوْ أُصِيبَ {18} هو المُصَابَا {19} وأنْشَدَ المُفَضّل {20}:وكائِنْ {21} تَرَى {22} في الحَيِّ مِنْ ذِي قَرَابَةٍ ... وغَيْرَان يَدْعُو ويلَهُ مِنْ حِذَارِيَا {23}فإنْ وقفت على هذه الكلمة؛ فَلَكَ في الوَقْفِ على قِرَاءةِ ابن كثير، ثلاثة أوجه:أحدها: أنْ تحذف التنوين الدَّاخِلَ الكلمة مع الجرِّ، فيقول {24}: (كاءْ). فَتُسَكِّنْ {25} الهمزةَ المجرورةَ للوقف.الثاني: أن يقول: (كائِي) {26}؛ على لغة من يقول: (مَرَرْتُ بِزَيْدِيْ)، في الوقف، فَيُبْدِل {27} مِنَ التَّنْوِين الياءَ.الوجه الثالث: أنْ تَقِفَ على التنوين، وتترك الحركة {28}؛ فتقول: (كَائِنْ) {29}؛ وذلك أنَّ التنوين -بالقَلْبِ الذي حدث في هذه الكلمة-، صارت بمنزلة النون التي من نَفْسِ الكلمة [فَتُقِرُّهُ نُونًا في الوَقْفِ] {30}، بمنزلة [ما هو من نفس الكلمة؛ كما أنهم جعلوا ما هو من نفس الكلمة] {30}، [التنوينَ] {32} الزائدَ {33}، في قول من قال: (لَدُنْ غُدْوَةً) {34}.فأما الوقف في القراءة {35} الأولى، فتقف على الياء، وتترك التنوين، ولا تقف على النون؛ لأنه لم يُقْلَبْ، كما ذكرنا من القَلْبِ في قراءة ابن كثير {36}.وقوله تعالى: ﴿قَاتَلَ مَعَهُ رِبِّيُّونَ كَثِيرٌ﴾. ﴿قُتِلَ﴾، و ﴿قَاتَلَ﴾ {37}. فمن قرأ: ﴿قُتِلَ﴾ {38}، احتمل وجهين:أحدهما: أن يكون القَتْلُ مُسْنَدًا إلى ﴿نَبِيٍّ﴾. [وقوله: ﴿مَعَهُ رِبِّيُّونَ﴾]، {30} صِفَة لـ ﴿نَبِيٍّ﴾. و (الرِّبِّيُّون) -على هذا- مرتَفِعٌ بالظَّرْفِ {40}.والثاني: أنْ يُسْنَدَ القَتْلُ إلى قوله: ﴿رِبِّيُّونَ﴾. ويكون معنى قوله: ﴿فَمَا وَهَنُوا﴾ أي: مَا وَهَنَ باقِيهم بَعْدُ، بِمَنْ {41} قُتِلَ منهم في سبيل الله. فَحُذِفَ المُضَافُ، وأقُيِمَ المضافُ إليه مقامه؛ والمعنى: ما وَهَنَ مَنْ بَقِيَ منهم لِقَتْلِ {42} مَن قُتِلَ مِنَ الرِّبَيِّينَ، لأن مَنْ قُتِلُوا لا يُوصَفُونَ بِأَنَّهُمْ (ما وَهَنُوا).وحُجّة هذه القراءة: أنَّ هذا الكلامَ، اقتصاصُ ما جرى عليه سَيْرُ {43} أُمَمِ الأنبياء -عليهم السلام- قبلهم؛ لِيَتَأَسَّوا بهم. وقد قال: ﴿أَفَإِنْ مَاتَ أَوْ قُتِلَ انْقَلَبْتُمْ عَلَى أَعْقَابِكُمْ﴾ [آل عمران: 144].ومَنْ قَرَأَ: ﴿قَاتَلَ﴾، جاز فيه الوجهان اللذان ذكرنا في ﴿قُتِلَ﴾، مِن إسناد القِتَالِ إلى ﴿نَّبيٍّ﴾، أو إلى ﴿الرِّبِّيِّينَ﴾.وحُجَّةُ هذه القراءة: أنَّ المُراد بهذه الآية مدح الطائفة الذين مع النَّبِيِّ، بالقتال والثَّبَاتِ على ما كان عليه نَبِيُّهُمْ. والقتال أَلْيَقُ بهذا المعنى مِنَ القَتْلِ، فَحَصلَ مِن هذا أنَّ قوله: ﴿وَكَأَيِّنْ﴾، موضع الكاف الجَارَّةِ مع المجرور، رَفْعٌ بالابتداء، كما أنَّ موضع (لَهُ كَذَا وَكَذَا)، رَفْعٌ. وخَبَرُهُ: ﴿قُتِلَ﴾؛ إذا أسندت القَتْلَ إلى ﴿نَبِيٍّ﴾. وإذا لم يُسنَدْ القَتلُ إليه، كان قولُه: ﴿قُتِلَ مَعَهُ رِبِّيُّونَ﴾: صِفَةً لـ ﴿نَبِيٍّ﴾، وتُضمِرُ للمبتدإ خَبَرًا؛ بتقدير: (كَأيِّنْ مِنْ نَبِيٍّ قُتِلَ معه رِبِّيُّونَ كثيرٌ قبلكم أو مضى). وما أشبهه من التقدير.وهذا الذي ذكرنا في هذه الآية: قولُ الفَرَّاء {44}، والزجَّاج {45}، وأبي علي {46}، وجميع مَن يُوثَقُ بِعِلْمِهِ في النحو {47}.وقوله تعالى: ﴿رِبِّيُّونَ﴾.قال الفَرّاء {48}: الرِّبِّيُّون: الأُلُوف. وهو قول ابن مسعود {49}، والضحاك {50}، والكلبي {51}.وقال الزّجاج {52}: هم الجماعة الكثيرة.أخبرنا العَرُوضي {53}، عن الأزهري، عن المنذري، عن أبي طالب، قال {54}: الرِّبِّيُّونَ: الجماعات الكثيرة. الواحد: (رِبِّيٌّ).وهو قول ابن عباس {55}، ومجاهد {56}، وقتادة {57}، والرَّبِيع {58}، والسُّدِّي {59}.[و] {30} قال ابن قتيبة {61} وأصله مِن (الرِّبَّةِ)، وهي: الجَمَاعة، يقال {62}: (رِبِّيّ)؛ كأنه نُسِبَ {63} إلى (الرِّبَّةِ) {64}، ثم يُجمَع (رِبِّيّ) بالواو {65}.وقال الأخفش {66}: الرِّبَيُّونَ: الذين {67} يعبدون الرَّبَّ، واحِدُهم: (رِبِّيُّ).قال أحمد بن يحيى {68}: ينبغي أن يُفتَحَ [الرَّاءُ] {69} على قول الأخفش، فيقال: (رَبِّي) {70}؛ لِيَكونَ منسوبًا إلى الرَّبِّ.فقال مَنْ نَصَرَ الأخفشَ {71}: العرب تنسب الشيءَ إلى الشيء، فتغيِّر حَرَكَتَهُ؛ كما قالوا: (بِصْرِي)، في النسبة إلى البَصْرَةِ.وقوله تعالى: ﴿فَمَا وَهَنُوا لِمَا أَصَابَهُمْ فِي سَبِيلِ اللَّهِ وَمَا ضَعُفُوا﴾ جَمَعَ بين الوَهْنِ والضَّعْفِ؛ لأن (الوَهْنَ): انكسارُ الحَدِّ بالخوف {72}.و (الضَّعْفُ): نُقْصانِ القوة. أي: لم يَهِنْوا بالخوف، ولا ضَعُفُوا بنُقْصان القُوَّة. هذا معنى قول أبي إسحاق {73}: ما جَبُنُوا عن قِتَال عَدُوِّهم، وَمَا فَتَرُوا {74}وقوله تعالى: ﴿وَمَا اسْتَكَانُوا﴾ الاسْتِكَانَةُ: الخُضُوعُ. وهو أنْ يَسْكنُ لصاحِبِهِ، لِيَفْعَلَ {75} بِهِ ما يريد؛ أي: وما خضعوا لِعَدُوِّهم {76}.قال المفسرون: هذه الآية احتجاجٌ على المنهزِمِينَ يومَ أُحُد، وذلك أنَّ صائِحًا صاحَ: قد قُتِلَ مُحمَد! فاضْطَرَبَ أمرُ المسلمينَ؛ كما ذكرنا القصة في قوله: ﴿وَمَا مُحَمَّدٌ إِلَّا رَسُولٌ﴾ [آل عمران: 144]، الآية.واختلفوا فيما بينهم، فأنزل الله هذه الآية، يعاتبهم على ما كان مِن فِعْلِهم، وَيحَضُّهم على الجهاد في سبيل الله؛ لِسُلُوك طريقة العلماء مِن صَحَابَةِ الأنبياء، لِيَقْتَدِيَ الخَلَفُ بالسَّلَفِ في الصَّبْرِ، حتى يأتي اللهُ عز وجل بالفتح {77}.وقال ابنُ الأنباري {78} في هذه الآية: أي: وقد كان واجبًا عليكم، أن تُقاتلوا على أَمْرِ نَبِيِّكُمْ لو قُتِلَ؛ كما قَاتَلَ أُمَمُ الأنبياء بعد قَتْلِهِم، وَلَمْ يَرْجِعُوا عَنْ دِينِهم."
  3,147,"قوله تعالى: ﴿وَمَا كَانَ قَوْلَهُمْ إِلَّا أَنْ قَالُوا﴾ قال ابن عباس {1}: يريد: عند لِقَاء العدو. وهذا بعد أنْ قُتِلَ نَبِيُّهُم.وقوله {2} تعالى: ﴿وَإِسْرَافَنَا﴾ الإسْرَافُ -في اللغة-: مُجَاوَزَةُ الحَدِّ. ومثله: السَّرَفُ {3}.قال ابن الأعرابي {4}: هو تَجَاوُزُ ما حُدَّ لك. قال ابن عباس {5} -في قوله: ﴿وَإِسْرَافَنَا فِي أَمْرِنَا﴾ -: يريد: في المَعَاصِي.وقوله تعالى: ﴿وَثَبِّتْ أَقْدَامَنَا﴾ قال ابن عباس {1}: يريد: بالقُوَّةِ مِن عِندك، والنُّصرَةِ. وعلى هذا أكثر المفسرين؛ أَنَّ المراد بهذا: سؤال [القوة و] {7} المعونة التي تَقَوَّى {8} بها قُلُوبُهم على جهاد عدوهم، حتى يقع معها ثُبُوت {9} أقدامهم {10}.وقال {11} أبو إسحاق {12}: معنى ﴿وَثَبِّتْ أَقْدَامَنَا﴾ أي: ثَبِّتْنَا على دينك. قال: فإذا {13} ثَبَّتَهُمْ على دينهم، ثَبَتُوا في حربهم. واحتج بقوله: ﴿فَتَزِلَّ قَدَمٌ بَعْدَ ثُبُوتِهَا﴾ [النحل: 94]، قال: المعنى: تَزِلَّ عن الدِّينِ.وهذا تعليم لدعاء الاستفتاح والاستنصار على الكُفَّار، وتعريضٌ بالعِتابِ معهم، حين أخبر عن غيرهم من الأمم بهذا."
  3,148,"قوله تعالى: ﴿فَآتَاهُمُ اللَّهُ ثَوَابَ الدُّنْيَا﴾ قال ابن عباس {1}: يريد: النَّصْر {2} والظَّفَر والغنيمة.﴿وَحُسْنَ ثَوَابِ الْآخِرَةِ﴾ يعنى: الأجر والمغفرة، وما يَلْقَوْنَه مِنَ النَّعِيم."
  3,149,"قوله تعالى: ﴿إِنْ تُطِيعُوا الَّذِينَ كَفَرُوا﴾ يعني: اليهود؛ في قول ابن عباس {1}، والأكثرين.وقال السُّدِّي {2}: يعني: أبا سفيان، وأصحابه.وقال علي {3}: يعني: المنافقين؛ في قولهم للمؤمنين عند الهزيمة: ارجِعُوا إلى دِينِ آبائكم.وقوله تعالى: ﴿يَرُدُّوكُمْ عَلَى أَعْقَابِكُمْ﴾ أي: يُرْجعوكم إلى أَوَّلِ أمْرِكم؛ الشركِ بالله {4}."
  3,150,"وقوله تعالى: ﴿بَلِ اللَّهُ مَوْلَاكُمْ﴾ أي: ناصِرُكُم ومُعِينُكم. والمعني في هذه الآية: يقول: أنا مولاكم؛ فاسْتَغْنُوا عن مُوَالاةِ الكفَّار، وناصِرُكُمْ؛ فلا تَسْتَنْصِرُوهم."
  3,151,"[و] {1} قوله تعالى: ﴿سَنُلْقِي فِي قُلُوبِ الَّذِينَ كَفَرُوا الرُّعْبَ﴾.قال المفسرون: هذا وَعْدٌ مِنَ الله تعالى للمؤمنين، بِخذلان أعدائِهم بالرُّعْب {2}.وقال السُّدِّي {3}: لَمَّا انصرَفَ أبو سفيان وأصحابه مِن أُحُد إلى مَكَّةَ، هَمُّوا بالرجوع لاستئصال المسلمين، فألقى اللهُ في قلوبهم الرُّعْبَ، فَمَضوا ولم يرجعوا.و (الإلقاء) {4}: أصلُهُ في الأعيان؛ كقوله: ﴿وَأَلقَى اَلأَلوَاحَ﴾ [الأعراف: 150]، ﴿فَأَلْقَوْا حِبَالَهُمْ وَعِصِيَّهُمْ﴾ [الشعراء: 44]، ﴿إِذْ يُلْقُونَ﴾ [آل عمران: 44].ويُسْتَعْمَلُ في غير الأعيان؛ تَوَسُّعًا؛ كقوله: ﴿وَأَلْقَيْتُ عَلَيْكَ مَحَبَّةً مِنِّي﴾ [طه: 39]، ويقال: ألقَى عليه مَسْئلةً).ومِثْلُ (الإلقاء) -في أنه يُسْتَعْمَلُ في الأعيان حقيقةً، وفي غير الأعيان تَوَسُّعًا-: (القَذْفُ)، و (الرَّجْمُ)، و (الرَّمْيُ)؛ يقال: (رَمَاهُ بالزِّنَا)؛ قال الله -عز وجل-: ﴿وَالَّذِينَ يَرْمُونَ أَزْوَاجَهُمْ﴾ [النور: 6] أي: بالزِّنَا. وهذا اتِّسَاعٌ؛ لأن هذا ليس بِعَيْنٍ، وكذلك: (القَذْفُ).قال الشاعر:قَذَفُوا سَيِّدَهُم في وَرْطَةٍ ... قَذْفَكَ المَقْلَةَ وَسْطَ المُعْتَرَكْ {5} فالأوَّل: على الاتِّسَاع، والثاني: على الأصل؛ ألا تَرَى أنَّ المَقلَةَ تُلقَى للتَّصَافُنِ {6}.وقوله تعالى: ﴿الرُّعْبَ﴾ يُقرأ {7} بالتَّثْقِيلِ، والتخفيف {8}، وهما لُغَتَانِ، كـ (الطُّنْبِ {9} والطُّنُبِ)، و (العُنْقِ والعُنُقِ)، ومثله كثير {10}.والرُّعْبُ، بمعنى: الرَّوْع {11}. يقال: (رَعَّبْتُهُ {12} رَعْبًا، وَرُعْبًا) {13} -لغتان-، فهو (مَرْعُوبٌ)، وَ (رَعِيبٌ) {14}. ويَجوز أنْ يكون (الرَّعْبُ) {15} مصدرًا، و (الرُّعْبُ) اسم منه {16}. وهو: الخوف الذي يحصل [في القلب.(رَعَبْتُ] {17} الشيءَ، أَرْعَبُهُ رَعْبًا). و (سَيْلٌ راعِبٌ): يملأ الأوديةَ والأنْهَارَ {18}. ثم قالوا: (رَعَبْتُهُ فارْتَعَبَ)؛ أي: أفْزَعْتُهُ فَفَزعَ؛ كأنك قلت: ملأتُ قَلْبَهُ فَزَعًا. ومعنى الآية: يملأ قلوبَهُم فَزَعًا.وقوله تعالى: ﴿بِمَا أَشْرَكُوا بِاللَّهِ﴾ (ما) ليست بموصولة؛ لأنها للمصدر؛ أي: بإشراكهم بالله.والباء في ﴿بِاللَّهِ﴾، مِنْ صِلَةِ معنى الإشراك، لا لَفْظه؛ لأن لفظَ الإشراك لا يقتضي الباء.قال الأزهري {19}: إنَّمَا دَخَلَتْ البَاءُ في قوله: ﴿لَا تُشرِك بِاَللَّهِ﴾ [لقمان:13]؛ لأن معناه: لا تَعْدِلْ به غَيْرَه، فتجعله شريكًا له، وذلك {20} قوله -تعالى-: ﴿بِمَا أَشْرَكُوا بِاللَّهِ﴾؛ أي: بِمَا عَدَلُوا باللهِ، ومَنْ عَدَلَ بالله شيئًا مِنْ خَلْقِهِ، فهو كافرٌ {21}.وقوله تعالى: ﴿مَا لَمْ يُنَزِّلْ بِهِ سُلْطَانًا﴾.أي: حُجَّةً، وَبَيَانًا. و (السُّلْطَانُ)؛ معناه: الحُجَّةُ، في قول أكثر المفسِّرينَ، وأهلِ اللغة {22}.قال الزَّجَّاجُ {23}: واشتقاق (السُّلْطانِ) مِنَ (السَّلِيط)، وهو: ما يُضَاءُ به {24} السِّرَاجُ {25}. وقيل {26} للأمراء: سلاطين؛ لأنهم الذين يُقامُ {27} بهم الحُجَجُ، والحُقُوقُ.وقال في موضع آخر {28}: السُّلْطانُ -في اللغة-: الحُجَّةُ. وإنَّمَا قيل للخليفة والأمير: (سُلْطان)؛ لأن معناه: أنه ذو الحُجَّةِ. والعَرَبُ تُؤنِّثُ (السلطان) وتُذَكِّرُ {29}؛ فتقول: (قَضَتْ {30} بِهِ عَلَيْكَ السُّلْطَانُ {31})، و (أمَرَتْكَ السُّلْطَانُ)؛ أي: قَضَتْ بِهِ عليك الحُجَّةُ، وَقَضَتْ به عليك حُجَّةُ الوَالِي.ومَنْ قال: (قَضَى به عليك السُّلطانُ)؛ ذَهَبَ إلى معنى: (صاحبُ السُّلطانِ)؛ أي: صاحب الحُجَّةِ. وجائزٌ أنْ يذهب بـ (السُّلطان) إلى معنى: الاحتجاج والبرهان.قال ابن السِّكِّيت {32}: السُّلْطان: مؤنَّثَةٌ {33}؛ يُقَال: (قَضَت {30} به عليهم {35} السُّلْطانُ)، وقد (آمَنَتْهُ {36} السُّلْطَانُ).قال الأزهريُّ {37}: ورُبمَا ذُكِّرَ (السُّلْطانُ)، لأن لفظه {38} مُذَكَّرٌ؛ قال الله تعالى: ﴿وَسُلْطَانٍ مُبِينٍ﴾ {39}.وقال اللَّيْثُ {40}: السُّلْطان: القُدْرَةُ. يقال: (جعلت لِفُلانٍ سُلْطانا على كذا). والنُّونُ فيه زيادة؛ لأن أصل بِنَائِهِ {41} مِنَ (التَّسْلِيط). وعلى هذا: (سُلْطان المَلِكِ): قُوَّتُهُ وقُدْرَتُهُ.والسُّلْطانُ: البُرْهان، لِقُوَّتِهِ على دفع الباطل. والتَّسْلِيطُ على الشيء: التَّقْوِية عليه.وقال ابن دُرَيد {42}: سلْطان كلِّ شيء: حِدَّتُه. مِن {43} اللِّسَان السَّلِيط الحدِيد. و (السَّلاَطَةُ)، بمعنى: الحِدَّة، قد جَاءَ، ومنه قول الشاعر -يَصِفُ نَصْلًا {44} مُحَدَّدَة {45} -:سلاَطٌ حِدَادٌ أَرْهَقَتْهَا المَوَاقِعُ {46}هذا كلام أهل اللغة في معنى (السلطان) واشتقاقه.قال أهل التفسير: لم [يُنْزل] {47} اللهُ حُجَّةً ولا بَيَانًا في عِبَادَةِ غَيْرِهِ، والإشْرَاكِ به؛ فهم يُشْرِكون بالله الأوثانَ مِنْ غيْرِ حُجَّةً ولا بُرْهان {48}.وقوله تعالى: ﴿وَمَأْوَاهُمُ النَّارُ﴾. أي مرجعهم ومصيرهم.﴿وَبِئْسَ مَثْوَى الظَّالِمِينَ﴾ المَثْوَى: المكان الذي {49} يُقِيم به؛ مِن قولهم: (ثَوَى، يَثْوِي، ثَوَاءً) {50}.ويقال للمقتول: (ثَوَى) {51}؛ لإقامته حيث قُتِل. وجَمْعُ الـ (مَثْوَى) {52}: مَثَاوِي {53}."
  3,152,"قوله تعالى: ﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾ الآية.قال القُرَظِيُّ {1}: لَمَّا رَجَعَ رسولُ الله ﷺ، وأصحابُه إلى المدينة، وقد أصابهم ما أصابهم بِأُحُد، قال ناسٌ مِن أصحابه: مِنْ أين أصابَنَا هذا، وقد وَعَدَنا اللهُ النصرَ؟ [فأنزل اللهُ] {2}: ﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾؟.وقال بعضهم: كان رسولُ اللهِ ﷺ، رَأَى في المنام أنَّه {3} يذبح كَبْشًا، فصدَق رُؤياهُ بقتل {4} طَلْحَةَ بن عثمان {5}، صاحبِ لِوَاءِ المشركين، يوم أُحُد، وقَتْلِ تِسْعَة نَفَرٍ بعده على اللواء {6}، فذلك قوله: ﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾؛ يريد: تصديق رؤيا رسول الله ﷺ.والصِّدق يتعدى إلى مفعولين؛ تقول: صَدَقْتُهُ الوَعْدَ، والوَعِيدَ {7}.قوله تعالى: ﴿إِذْ تَحُسُّونَهُمْ بِإِذْنِهِ﴾.قال اللَيْثُ {8}: الحَسُّ: القَتْلُ الذَرِيع. قال: و ﴿تَحُسُّونَهُمْ﴾، أي: تقتلونهم قَتْلًا شديدًا كثيرًا.وروى الحَرَّانيُّ {9} عن ابن السِّكِّيت {10}: الحَسُّ: مصدرُ (حَسَسْتُ القومَ، أَحُسُّهُمْ، حَسًّا): إذا قتلتهم.وقال أبو عبيدة {11}، والزَّجَّاجُ {12}، وابنُ قُتَيْبَة {13}: الحَسُّ: الاستئصال بالقتل؛ يقال: (جَرَادٌ مَحْسُوسٌ): إذا قَتَلَه البَرْدُ. و (سَنَةٌ حَسُوسٌ): إذا أتَتْ على كلِّ شيء {14} ومعنى ﴿تَحُسُّونَهُمْ﴾: تستأصلونهم قَتْلًا {15}.وقال أصحاب الاشتقاق: (حَسَّهُ، يَحُسُّهُ): إذا قَتَلَه؛ لأنه أبطل حِسَّهُ بالقتل، وأصابَهُ {16}؛ كما يقال: (بَطَنَهُ): إذا أصاب بَطْنَهُ {17}، و (رَأَسَهُ): إذا أصاب رَأسَهُ {18}. والتَّحَسُّسُ: طَلَبُ الأخبار بحَاسَّةِ السَمْعِ {19}.وقوله تعالى: ﴿بِإِذْنِهِ﴾ أي: بِعِلْمِهِ {20}قال المفسرون {21}: كان المسلمون يوم أُحُد، يقتلون المشركين قتلا ذريعًا حتى وَلَّوْا هاربين، وانكشفوا منهزمين؛ فذلك قوله: ﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ إِذْ تَحُسُّونَهُمْ بِإِذْنِهِ﴾.ثم أَخَلَّ الرُّمَاةُ {22} بالمكان الذي ألزمهم رسولُ الله ﷺ إيَّاهُ، فَحَمَلَ -حينئذ- خالدُ بنُ الوَلِيد {23}، مِن وَرَاء المسلمين، وتَرَاجَعَ المشركون، وقُتِلَ مِن المسلمين سبعونَ رجلًا، ثم هُزِمُوا {24}.وقوله تعالى: ﴿حَتَّى إِذَا فَشِلْتُمْ﴾ أي: جَبنْتُم عن عَدُوِّكم {25}.قال الليث {26}: يقال: (فَشِلَ الرَّجُلُ، يَفْشَلُ) - عند الحَرْبِ والشِّدَّةِ: إذا ضَعُفَ، وذهبَتْ قُوَاهُ {27}. ويقال: (إنه لفَشْلٌ)، و (فَشِلٌ) {28}.واختلفوا في جواب ﴿حَتَّى إِذَا﴾ {29}:فقال الفراء {30}: جوابه: ﴿وَتَنَازَعْتُمْ﴾، والواو فيه مُقْحَمَةٌ، معناها السقوط؛ كما قال: ﴿فَلَمَّا أَسْلَمَا وَتَلَّهُ لِلْجَبِينِ (103) وَنَادَيْنَاهُ﴾ {31}؛ المعنى: نَادَيْنَاه. واحتج بقول الشاعر:حَتَّى إذا قَمِلَتْ بُطُونُكُمُ ... ورَأَيْتُمُ أبْنَاءَكُمْ شَبُّوا وقلبتمُ ظَهْرَ المِجَنِّ لَنَا ... إنَّ اللَّئِيمَ العاجِزُ الخَبُّ {32}قال: يريد: قَلَبْتُم. هذا مذهب الكوفيين.وعند البصريين: لا يجوز زيادةُ الواو. ويتأولون هذه الآيةَ وأمثالَها، على حذف الجواب، والتقدير عندهم: (حتى إذا فَشِلْتُمْ، وتَنَازَعْتُم في الأمر، وعَصَيْتُم، امْتُحِنْتُمْ {33}؛ بأن نِيلَ منكم، وعُوقِبْتُم بِظَفَرِ أعدائكم بكم)، فحذف الجواب؛ لبيان {34} معناه؛ كما حذف في قوله -عز وجل-: ﴿فَإِنِ اسْتَطَعْتَ أَنْ تَبْتَغِيَ نَفَقًا فِي الْأَرْضِ أَوْ سُلَّمًا فِي السَّمَاءِ﴾ [الأنعام: 35]؛ معناه: فافْعَلْ. فأسقط الجواب؛ إذْ أُمِنَ {35} اللَّبْسُ {36}.والآية -عند الفراء- على التقديم والتأخير؛ لأنه يذهب إلى أن الفَشَلَ مُؤَخَّرٌ بعد التَّنازُع؛ والمعنى عنده: (حتى إذا تنازعتم في الأمر وعَصَيْتُم؛ فَشِلتم). فقدم المؤخر وأخر المقدم؛ كقوله: ﴿إِنِّي مُتَوَفِّيكَ وَرَافِعُكَ إِلَيَّ﴾ {37}.وغيره يقول: الفَشَل في موضعه، غَيْرُ مَنْوِيٍّ به التأخير. والتنازع والعصيان كانا بعد الفَشَلِ {38}.والتنازع {39}: الاختلاف. وأصله مِنْ: (نَزَعَ القومُ الشيءَ، بعضُهُم مِن بَعْضٍ). وسنذكر شرحه عند قوله: ﴿فَإِنْ تَنَازَعْتُمْ فِي شَيْءٍ﴾ [النساء: 59]، إن شاء الله.وكان اختلاف القوم {40}: أن المشركين لَمَّا انكشفوا؛ قال بعضُ الرُّمَاةِ: ما مُقَامُنا هاهنا، قد انْهَزَمَ القومَ. وقال بعضُهم: لا نُجَاوِزُ أمْرَ رَسُولِ الله ﷺ {41}.وقوله تعالى: ﴿وَعَصَيْتُمْ﴾. أي {42}: بِتَرْكِ المَرْكَزِ {43}.وقوله تعالى: ﴿مِنْ بَعْدِ مَا أَرَاكُمْ مَا تُحِبُّونَ﴾ يعني: الظَّفَرَ والنَّصْرَ والفَتْحَ، حين كان الدَّبْرَةُ {44} على المشركين {45}.وقوله تعالى: ﴿مِنْكُمْ مَنْ يُرِيدُ الدُّنْيَا﴾ يعني {46}: الذين تَرَكُوا المَرْكَزَ، وأقْبَلُوا إلى النَّهْبِ.﴿وَمِنْكُمْ مَنْ يُرِيدُ الْآخِرَةَ﴾ يعني: الذين ثَبَتُوا مَعَ عبد الله بن جُبَيْر -وهو أمير الرُّمَاةِ {47} - حتى قُتِلُوا.وقوله تعالى: ﴿ثُمَّ صَرَفَكُمْ عَنْهُمْ﴾ [أي] {48}: بالهزيمة؛ على معنى: صَرَفَ وجوهَكُم عنهم {49}.وقال عَطَاء {50}: يريد: صرف حدكم {51} عنهم. وهذا صريح في أن [المعصيةَ مَخْلُوقَةٌ لله] {52} عز وجل؛ حيث أضاف انهزامهم وتَوَلِّيهم إلى نفسه؛ فقال: ﴿صَرَفَكُمْ عَنْهُمْ﴾، ولم يقل: (انْصَرَفْتُمْ) {53}.وقوله تعالى: ﴿لِيَبْتَلِيَكُمْ﴾. أي: لِيَخْتَبِرَكُمْ بِمَا جَعَلَ عليكم مِنَ الدَّبْرَةِ والهزيمةِ، فَيَتَبَيَّنَ الصابرُ {54} مِنَ الجازع، والمُخْلِصُ مِنَ المنافق {55}.وقوله تعالى: ﴿وَلَقَدْ عَفَا عَنْكُمْ﴾ أي: ذَنْبَكُمْ {56}؛ حيث عصيتم رسولَ اللهِ ﷺ وحيث {57} انهزمتم، فَلَمْ يُؤاخِذْكُمْ بذَنْبِكُمْ.وقال بعضُ المُفَسِّرِينَ {58}: ولقد عفا عنكم، فَلَمْ يَسْتَأصِلْكُم بعد المعصية والمخالفة، نظيره: ﴿ثُمَ عَفَوْنَا عَنْكُمْ﴾ {59}.وقوله تعالى: ﴿وَاللَّهُ ذُو فَضْلٍ عَلَى الْمُؤْمِنِينَ﴾ قال ابن عباس {60}: يريد: بالمَغْفِرَةِ."
  3,153,"قوله تعالى: ﴿إِذْ تُصْعِدُونَ﴾ (إذْ) مُتَعَلِّق بـ (عَفَا)؛ يعني: ولقد عَفَا عنكم إذْ تُصْعِدُونَ.و (الإصْعَادُ)، قال الفَرَّاءُ {1} والزَّجَّاجُ {2}: هو الابتداء في كلِّ سَفَرٍ؛ يقال: (أَصْعَدْنَا مِن بَغْدادَ إلى خُرَاسانَ وإلى مَكَّةَ): إذا خرجنا إليها، وأَخَذْنا {3} في السَّفَرِ نحوها {4}.وأَقْرَأَني العَرُوضِيُّ، عن الأزهري، عن المُنْذِري، عن الحَرَّانِيِّ، عن ابن السِّكِّيت، قال {5}: يقال: (صَعِدَ في الجَبَلِ)، و (أَصْعَدَ في البلاد).وقال الأخفش {6}: (أَصْعَدَ في البلاد): سار ومَضَى {7}.أبو عُبَيْد، عن أبي زيد، وأبي عمروٍ: يقال: (أَصْعَدَ الرجلُ في البلاد): حيث تَوَجَّهَ. {8} قال الأعشى:ألا أيُّهذا السَّائِلِي أينَ أَصْعَدَتْ ... فإنَّ لَهَا في أهلِ يَثْرِبَ مَوْعِدَا {9} وقال ابن قُتَيبة {10}: ﴿تُصْعِدُونَ﴾: تُبْعِدُونَ في الهَزِيمَةِ؛ يقال: أَصعَدَ في الأرض: إذا أَمْعَنَ فيها {11} في الذَّهَاب {12}.وقوله تعالى: ﴿وَلَا تَلْوُونَ عَلَى أَحَدٍ﴾ أي: لا تُعَرِّجُونَ ولا تُقِيمون ولا تَلْتَفِتون هَرَبًا. يقال: (مَضَى ولم يَلْوِ على شيءٍ)؛ أي: لم يُعَرِّجْ. وأصله: أنَّ المُعَرِّجَ على الشيء، يَلْوِي إليه عُنُقَهُ، أو عِنَانَ {13} دابَّتِهِ. فإذا مضى، ولمْ يُعَرِّج، قيل: (لم يَلْوِ). ثم استُعْمِلَ في تَرْكِ التَّعْرِيج على الشيء.فإن قيل: أليس اللهُ قد أخبَرَ أنَّه عَفَا عنهم -إذْ هُزِمُوا-، فكيف ذلك العَفْو، مع ما ابتلاهم به مِنَ القَتْلِ والجَرْح، وإدَالَةِ العَدُوِّ عليهم؟.قيل: لولا عَفْوُ اللهِ، ما نَجَا منهم أحدٌ {14}، ولَصَارُوا في الآخرةِ من الخاسرين؛ حين عَصَوا رسولَهُ في تَرْكِ المَرْكَزِ والهزيمة، وهو يناديهم مِن وَرَائِهم: (إلَيَّ عِبَادَ اللهِ! إلَيَّ عِبَادَ الله!) وهم لا يَلْتَفِتُون إليهِ. وذلك قوله: ﴿وَالرَّسُولُ يَدْعُوكُمْ فِي أُخْرَاكُمْ﴾.قال ابن عباس {15}: يريد: مِن خَلْفِكُم. يقال {16}: (جاءَ فلانٌ في آخِرِ النَّاسِ)، و (آخِرَةِ {17} النَّاس)، و (أُخْرَى الناس)، و (أُخْرَاة الناس) {18}.وقوله تعالى: ﴿فَأَثَابَكُمْ﴾ الإثَابَةُ: أكثر ما تُسْتَعمل {19} في الخير، ويجوز استعمالُه في الشَّرِّ، لأن أصله: ما يَرْجِعُ مِنَ الجَزَاء على الفِعْل، طاعةً كان أو معصيةً، ولكنه كَثُرَ في جَزَاء الطاعة {20}، كما تقول في (الطَّرَب)، فإنَّ أصْلَهُ: خِفَّةٌ تأخذ الإنسانَ، مِنْ فَرَحٍ أو حُزْنٍ {21}، كما قال {22}: طَرَبَ الوَالِهِ أوْ كالمُخْتَبَلْ {23}إلا أنَّه كَثُرَ استعمالُهُ في خِفَّةِ الفَرَحِ، وَنَشَاطِ السُّرُورِ {24}.وقال أصحابُ المعاني {25}: معنى قوله: ﴿فَأَثَابَكُمْ غَمًّا بِغَمٍّ﴾؛ أي: جَعَلَ مكانَ مَا تَرْجُونَ مِنَ الثَّوَابِ، الغَمَّ؛ كما تقول: (تَحِيَّتُكَ الضَّرْبُ)، و (عِتَابُكَ السَّيْفُ) {26}؛ أي: تجعل هذا مكانَ ذاك. قال عَمْرو بن مَعْد يكَرِب {27}:وَخَيْلٍ قَدْ دَلَفْتُ لَهَا بِخَيْلٍ ... تَحِيَّةُ بَيْنهمْ ضرْبٌ وَجِيعُ {28} أي: جَعَلُوا الضربَ الوجِيعَ، مَكَانَ التَّحِيَّةَ بين القَوْمِ.وقال الفَرّاء {29}: الإثابة -ههنا- في معنى: (عِقَاب)، ولكنه كما قال الشاعر:أَخَافُ زِيَادًا أنْ يَكُونَ عَطَاؤُهُ {30} ... أدَاهِمَ سُودًا أوْ مُحَدْرَجَةً فُتْلا {31} يعني بـ (السُّودِ): القيود {32}، وبـ (المحَدْرَجَة): السِّيَاط. وأرادَ: أخافُ أنْ يَجْعَلَ {33} مَكانَ عَطائِهِ، القُيُودَ والسِّيَاطَ.قال {34}: وقد يقول الرَّجُلُ [لـ] {35} الذي اجترم {36} إليه {37}: [(لَئِنْ] {38} أتَيتَنِي {39}؛ لأُثِيبنَّك ثَوَابَكَ)، معناه: لأعاقبنَّكَ. وهذا راجعٌ إلى ما ذكرنا مِن قَوْلِ أصحابِ المعاني.وقوله تعالى: ﴿غَمًّا بِغَمٍّ﴾ أي: أثَابَكم غَمًّا، وهو: الهَزِيمَة، وظَفَر المشركين بكم. ﴿بِغَمٍّ﴾، يعني: بِغَمِّكمْ رَسول الله ﷺ؛ إذْ عَصَيْتموهُ وَضَيَّعتم أمرَهُ. فالغَمُّ الأوّل لهم، والغَمُّ الثاني للنبي ﷺ. وهذا القول، اختيار الزجاج {40}.وقال الحسن {41}: غَمّ يومِ أحُد للمسلمين، بغَمِّ يومِ بَدْرٍ للمشركين {42}.وقيل: الغَمُّ الأَوَّل: ما أصابهم مِنَ الهزيمة والقتل. والغَم الثاني: إشْرافُ خالد بن الوَلِيد عليهم، في خَيْلِهِ، فَرَعَبَهم ذلك، وزَادَ مِنْ قَلَقِهم. وهذا قول أكثر المفسرين {43}، واختيار الفراء {44}.وقيل: الغَمّ الأوَّل: ما أصابهم مِنَ القتل والجرح. والغَمّ الثاني: ما سَمِعوا أنَّ مُحَمَّدًا قد قُتِلَ. وهذا قول: قَتَادة {45}، والرَّبِيع {46}، وابنِ عبَّاس -في رواية عطاء- {47} فإنَّه قال في قوله: ﴿غَمَّا بِغَمٍّ﴾؛ يريد: الهزيمة، وحيث قال ابنُ قَمِيئَةُ {48}: قد قتلتُ محمدا.والباء في قوله: ﴿بِغَمٍّ﴾ -في القولين المتأخرين-؛ بمعنى: [(مع)] {49} أو بمعنى: (عَلَى)؛ كما يقال {50}: (نزلتُ بِبَنِي {51} فلان)، و (على بَنِي فلان)، و (ما زِلْتُ به حتى فَعَلَ)، و (ما زِلْتُ معه حتى فَعَل) {52}.قوله تعالى: ﴿لِكَيْلَا تَحْزَنُوا عَلَى مَا فَاتَكُمْ وَلَا مَا أَصَابَكُمْ﴾.اختلفوا {53} في اللّام في قوله: ﴿لِكَيْلَا﴾:فقال بعضَ النحويِّين {54}: إنها مُتَّصِلَة بقوله: ﴿وَلَقَدْ عَفَا عَنْكُمْ﴾ [كأنه قال: ﴿وَلَقَدْ عَفَا عَنْكُمْ﴾] {55}، {لِكَيْلَا تَحْزَنُوا عَلَى مَا فَاتَكُمْ}، [لأن] {56} في {57} عَفوِهِ -جلَّ وعَزَّ-، ما يُذْهِبُ كُلَّ غَمٍّ وَحُزْنٍ {58}. وقال آخرون: إنها مُتَّصِلَةٌ بقوله: ﴿فَأَثَابَكُمْ﴾.ثُمْ اختلفوا:فَقَالَ [أبو إسحاق] {59}: المعنى: أثابكم غَمَّ الهزيمة، بِغَمِّكُمْ النبيَ ﷺ بِمُخَالَفتِهِ {60}، ليكون غَمُّكُمْ، بأن خالفتموه فقط، لا على ما فاتكم مِنْ غَنِيمة، ولا ما أصابكم من هزيمة وجِرَاحٍ؛ وذلك أنَّ غَمَّ مُخَالَفَةِ الرَّسُولِ، يُنْسيهم غَمَّ فَوْتِ الغَنِيمَةِ.وقال غيره: كان أصحاب رسول الله ﷺ، يَتَأَسَّفُونَ على ما فاتهم مِنْ غَنائم المشركين، وعلى ما حَلَّ بهم مِنَ القَتْلِ والجراح، فأنزلَ اللهُ بقلوبهم غَمَّ قَتْلِ الرسول ﷺ، ثمّ أزال ذلك الغم عنهم؛ لِيَفرحوا ببقائه، ولا يحزنوا مع بقائه على شَيءٍ {61} فَاتَهُمْ {62}.وقولُ أبي إسحاق ألْيَقُ بَظَاهِرِ الآية؛ لأنه ليس في الآية ذِكْرُ إزَالَةِ غَمِّ قتلِ النبيِّ ﷺ، إلّا بأنْ {63} يُقال: إنَّ ذلك الغَمَّ، لَمْ يتحققْ؛ لأنَّهُ لَم يَصْدُقْ نعْيُ الرسول.وحُكي عن المُفَضَّلِ {64} أنه كان يَجْعَلُ (لا) -في هذه الآية- صِلَةً {65}، ويقول: المعنى: لِكَيْ تَحْزَنُوا على ما فاتكم وما أصابكم؛ عُقُوبَةً لكم في خِلافِكُمْ إيَّاهُ؛ كقوله: ﴿لِئَلَّا يَعْلَمَ﴾ {66} [الحديد: 29].وقوله تعالى: ﴿وَاللَّهُ خَبِيرٌ بِمَا تَعْمَلُونَ﴾. تذكيرٌ؛ للتَّحْذِير {67}."
  3,154,"قوله تعالى: ﴿ثُمَّ أَنْزَلَ عَلَيْكُمْ مِنْ بَعْدِ الْغَمِّ أَمَنَةً نُعَاسًا﴾ الآية.قال المُفسِّرون {1}: إنَّ المشركين لَمَّا انصرفوا يوم أُحُد، كانوا يتوَعَّدُون المسلمينَ بالرجوع، ولم يَأمَن المسلمون {2} كَرَّتَهم، وكانوا تحت الحَجَفِ {3}؛ مُتَأَهِّبِينَ للقتال، فأنزَل اللهُ -تعالى-[عليهم] {4} -دونَ المنافقين- أمَنَةً؛ فأخذهم النُّعَاسُ.قال ابن عباس {5}: آمَنَهُم {6} -يومئذ- بِنُعَاس يَغْشاهم بعد خوف، وإنَّمَا يَنْعُسُ مَنْ يَأمَنُ، والخائف لا ينام.قال أبو طَلْحَة {7}: رَفَعْتُ رَاسِي يوم أُحُد، فَجَعَلْتُ {8} ما {9} أرى أحَدًا مِنَ القوم، إلّا وَهُوَ يَمِيد تحت حَجَفَتِهِ؛ مِنَ النُّعَاس. قال {10}: وكنت مِمَّن أُلْقيَ عليه النُّعَاس -يومئذٍ -، فكان السَّيْفُ سقُطُ مِن يدِي فَآخُذُهُ، ثم يَسْقُطُ السَّوْطُ من يدي فَآخُذُه.وقال أبو إسحاق {11} -في قوله: ﴿ثُمَّ أَنْزَلَ عَلَيْكُمْ مِنْ بَعْدِ الْغَمِّ أَمَنَةً نُعَاسًا﴾: أي: أعْقَبَكم- بما نالكم {12} مِنَ الرُّعْب-؛ أنْ آمَنَكم {13} أمْنًا تنامون معه؛ لأنَّ الشَّدِيدَ الخوفِ لا يكاد يَنَام.والأَمَنَةُ: مصدرٌ، كـ (الأمْنِ). ومثله من المصادر: (العَظَمَةُ)، و (الغَلَبَةُ).وقال اللِّحْيانيُّ {14}: يُقال: (أَمِنَ فلانٌ، يَأمَنُ، أَمْنًا، وأَمَنَةً، وأَمْنَةً {15}، وأمَانًا). والنعاس: بَدَلٌ مِنَ (الأمَنَة) {16}.وقوله تعالى: ﴿يَغْشَى طَائِفَةً مِنْكُمْ﴾ قُرِئ بالياء والتَّاءِ {17}. فَمَن قرأ بالياء؛ فلأن النُّعَاسَ هو الغاشي، والعرب تقول: (غَشِيَنِي النُّعاسُ)، وقلّما تقول: (غَشِيَني الأمْنُ).و-أيضًا- فإنَّ النعاسَ مذكورٌ بالغِشْيَانِ في قوله: ﴿إِذْ يُغَشِّيكُمُ النُّعَاسَ أَمَنَةً مِنْهُ﴾ [الأنفال: 11] ولأن النعاسَ يَلِي الفِعْلَ، وهو أقرب في اللفظ إلى ذِكْرِ الغِشْيانِ مِنَ الأمَنَة. فالتذكير أولى.ومن قرأ بالتَّاءِ: جعل الأمَنَةَ هي الغاشِيَةَ.والأَمَنَةُ والنُّعاسُ، أحدهما بَدَلٌ عن الثاني، فيجوز وَيحْسُن رَدُّ الكِنَايَةِ {18} إلى أيِّهما شئت؛ كقوله: ﴿إِنَّ شَجَرَتَ الزَّقُّومِ (43) طَعَامُ الْأَثِيمِ (44) كَالْمُهْلِ يَغْلِي﴾ [الدخان:43 - 45]، وَ ﴿وتَغْلِي﴾ {19}.ومِمَّا يُقَوِّي القراءة بالتَّاء: أنَّ الأصل: الأَمَنَةُ، و (النُّعَاس): بَدَلٌ. وَرَدُّ الكناَيَةِ إلى الأصْلِ أحْسَنُ. والأَمَنةُ هي المقصودة، فإذا حَصَلَتْ {20} الأمَنَةُ، حَصلَ {21} النُّعَاسُ، لأنها سَبَبُهُ، فإنَّ الخائفَ لا يكادُ يَنْعُسُ.وقوله تعالى: ﴿طَائِفَةً مِنْكُمْ﴾ قال ابن عباس {22}: هم المهاجرون، وعامَّةُ الأنْصَارِ {23}.وقوله تعالى: ﴿وَطَائِفَةٌ قَدْ أَهَمَّتْهُمْ أَنْفُسُهُمْ﴾ هؤلاء هم المنافقون: عبد الله بن أُبَي، ومُعَتِّبُ بن قُشَيْر {24}، وأصحابُهُما، كان هَمُّهُم خَلاَصَ أنفسِهِم {25}. يقال: (أهَمَّنِي الشيءُ): إذا كان مِنْ هِمَّتِي وقَصْدِي.والواو في قوله ﴿وَطَاَئِفَةٌ﴾، واو الحال.قال سيبويه {26}: المعنئ: إذْ طائِفةٌ قد أهَمَّتْهُم أنفُسُهم، وهو {27} رَفْعٌ بالابتداء، وخبرُهُ: ﴿قَدْ أَهَمَّتْهُمْ أَنْفُسُهُمْ﴾. وجائزٌ أن يكون الخَبَرُ: ﴿يَظُنُّونَ﴾، ويكون ﴿قَدْ أَهَمَّتْهُمْ أَنْفُسُهُمْ﴾: مِنْ صِفَةِ النَّكِرَةِ، ويكون المعنى: وطائفةٌ مُهِمَّتُهُمْ أنفُسُهم، يَظنُّونَ.قال أبو الفَتْحِ المَوصِلِيُّ {28}: هذه الواو للحال، وهي وما بعدها في مَوْضِعٍ نَصْب، على تقدير: يَغْشَى طائفَةً منكم، مُهِمَّةً {29} طائفةً أخرى منكم أنفُسُهم، في وقت غِشْيَانِهِ تلكَ الطائفة {30} الأولى. ولا بُدَّ مِن هذا التقدير؛ كما أنَّ قولك: (جاءت هند، وعمرٌو ضاحكٌ)، في تقدير: (جاءت هند ضاحكًا {31} عمرو في وقت مجيئها)، حتى يعود من الجملة التي هي حالٌ، ضميرٌ على صاحب الحال، ولهذا شبَّهَهَا سيبويه بـ (إذ) {32}.قال أبو علي {33}: إنما فَعَلَ ذلك من حيث كانت (إذْ) منتصبةَ المَوْضعِ في الحال {34}، وأنَّ ما بعد (إذْ) لا يكون إلّا جملةً، كما أنّ ما بعد واو الحال لا يكون إلّا جملةً مرَكَّبَةً مِن مبتدأ وخَبَر، كقولك: (مَرَرْتُ بزَيْد، وعمرٌو قائمٌ) {35}.وقوله تعالى: ﴿يَظُنُّونَ بِاللَّهِ غَيْرَ الْحَقِّ﴾ أي: يظنون أنَّ أمرَ النبي ﷺ مضمَحِلٌّ، وأنّه لا يُنْصر {36}.وقوله تعالى: ﴿ظَنَّ الْجَاهِلِيَّةِ﴾. الجاهلية: زَمَان الفَتْرَةِ، قبل الإسلام {37}. والمعنى: إنهم على جاهليتهم في ظنهم هذا. وتقدير الكلام: يَظنُّونَ ظَنَّ أهلِ الجاهلية {38}.وقوله تعالى: ﴿يَقُولُونَ هَلْ لَنَا مِنَ الْأَمْرِ مِنْ شَيْءٍ﴾ أي: ما لنا. استفهام يتضمن الجَحْدَ.قال الحَسَنُ {39}: يقولون: أُخْرِجْنَا كَرْهًا، ولو كان الأمرُ إلينا ما خَرَجْنَا {40} وقال الأكثرون {41}: أي: ليس لَنا مِنَ النَّصْرِ والظَّفَرِ شيءٌ كما وعدنا، بل هو للمشركين. يقولون ذلك {42} على جهة التكذيب. فقال الله: ﴿إِنَّ الْأَمْرَ كُلَّهُ لِلَّهِ﴾، أي: النَّصْرُ بيد الله عز وجل.وقال عطاء، عن ابن عباس {43}: يريد: القضاء والقدر، والنُّصْرَةُ والشَّهادة. واختلف القرّاء {44} في قوله: ﴿كُلَّهُ﴾:فَنَصَبَهُ [أكثرُهُم] {45}؛ لأن {46} الكُلَّ بمنزلة (أجمعين)، وجُمَعَ؛ في أنه للإحَاطَةِ والعُمُوم.ولو قيل: (إن الأمرَ أجْمَعَ)، لم يكن إلّا النَّصبُ، -كذلك- إذا {47} قال ﴿كُلَّهُ﴾ {48}.وقرأ أبو عمروٍ بالرَّفْعِ {49}، وذلك أنه لم يُجْرِهِ على ما قَبْلَهُ، ورَفَعَهُ على الابتداء، و ﴿لِلَّهِ﴾: الخَبَر.قال الفَرّاءُ {50}: ومثله مِمَّا قُطِعَ مِمَّا {51} قبلَهُ: قوله تعالى: ﴿وَيَوْمَ الْقِيَامَةِ تَرَى الَّذِينَ كَذَبُوا عَلَى اللَّهِ وُجُوهُهُمْ مُسْوَدَّةٌ﴾ {52} [الزمر: 60]، ومِنْ هذا -أيضًا-: ما أجازه سيبويه مِن قولِهِم: (أينَ تَظُنُّ زيدٌ ذاهِبٌ).وقوله تعالى: ﴿يُخْفُونَ فِي أَنْفُسِهِمْ مَا لَا يُبْدُونَ لَكَ﴾ أي: مِنَ الشَّكِّ والنِّفَاقِ، وتكذيب الوَعْدِ بالاستعلاء على أهل الشرك.وقوله تعالى: ﴿يَقُولُونَ لَوْ كَانَ لَنَا مِنَ الْأَمْرِ شَيْءٌ مَا قُتِلْنَا هَاهُنَا﴾رُوي {53} عن الزُّبَيْر بن العَوَام -رضي الله عنه -، أنَّه قال {54}: أَرْسَلَ اللهُ علينا النَّوْمَ، وإنِّي لأَسْمَعُ قولَ مُعَتِّب بن قُشَيْر -والنُّعَاس يغشاني-، ما أسمعه إلّا كالحُلم {55}، يقول: لو كان لنا من الأمر شىِءٌ، ما قُتلنا ههنا {56}. يَعْنُونَ أنهم أُخْرِجُوا كُرْهًا، ولو كان الأمر بيدهم لم يخرجوا.وقال المفسرون {57}: إنَّ المُنافِقِينَ قال بعضُهم لِبَعضٍ: لَوْ كانَ لنا عُقُولٌ، لم نخرجْ مع محمد لِقِتال أهل مكة، وَلَمَا قُتِلَ رُؤَساؤُنا. وهذا منهم تكذيبٌ بالقَدَرِ؛ حين ظَنُّوا أنهم لو لم يخرجوا لم يُقْتَلوا. فَرَدَّ اللهُ -تعالى- عليهم هذا الكلام بقوله: ﴿قُلْ لَوْ كُنْتُمْ فِي بُيُوتِكُمْ﴾ أيها المُنافِقُونَ، وَلم تَخْرُجوا إلى أُحُد.﴿لَبَرَزَ الَّذِينَ كُتِبَ عَلَيْهِمُ الْقَتْلُ إِلَى مَضَاجِعِهِمْ﴾ يعني: لو تَخلَّفتم عن القتال؛ لَخَرَج منكم الذين كُتِب عليهم القَتْل، ولم يكن لِيُنْجِيهم قُعُودهم.ومعنى (بَرَزَ): صار إلى (بَرَاز)؛ وهو المكان المنكشف {58}.والمضاجع: جمعُ (المَضْجَع)؛ وهو الموضع الذي يَضْجَعُ عليه الإنسانُ. ومنه قوله تعالى: ﴿تَتَجَافَى جُنُوبُهُمْ عَنِ الْمَضَاجِعِ﴾ [السجدة: 16].قال الهُذَلِيُّ {59}:أَم ما لجنْبِكَ لا يُلائِمُ مَضْجَعًا ... إلّا أَقَضَّ عليكَ ذاكَ المَضْجَعُ {60}وقال: (أضْجَعْتُ فُلانا): إذا وَضَعْت جَنْبَهُ بالأرض. و (ضَجَعَ)، فهو يَضْجَعُ بنَفْسِهِ. ويريد بـ ﴿المَضَاجِعِ﴾ ههنا: مَصارِعَهم للقتل؛ أي: حيث يَسْقُطُون {61} -هناك- قتلى.وقوله تعالى: ﴿وَلِيَبْتَلِيَ اللَّهُ مَا فِي صُدُورِكُمْ﴾ قال الكسائيُّ وغيرُهُ {62}: وليَبْتَلِيَ اللهُ ما في صدوركم، فَعَلَ ما فَعَلَ يومَ أُحُد. فَحُذِفَ واختُصِرَ؛ لِبَيَان المعنى.ومعنى ﴿لِيَبْتَلِيَكُمْ﴾: ليعاملكم معامَلَة المُبْتَلِي، المُخْتَبِرِ لكم.وقال أبو إسحاق {63}: أي: لِيَخْتَبِرَ ما في صدوركم، لِيَعلَمَهُ مُشَاهدَةً، كما يعلمه غَيْبًا؛ لأن المُجَازَاةَ تَقَعُ على ما عَلِمَهُ مُشَاهَدَةً.وقيل {64}: لِيَبتلي أولياءُ اللهِ ما في صدوركم. إلّا أنه أُضِيفَ الابتلاءُ إلىاللهِ -تعالى-، تفخيما لشأنهم؛ كقوله: ﴿فَلَمَّا آسَفُونَا﴾ {65}.وقوله تعالى: ﴿وَلِيُمَحِّصَ مَا فِي قُلُوبِكُمْ﴾ قد ذكرنا للتَّمْحِيصِ ثلاث مَعَانٍ، عند قوله -تعالى-: ﴿وَلِيُمَحِّصَ اللَّهُ الَّذِينَ آمَنُوا﴾ [آل عمران: 141]: التَّطْهِير، والكَشْف، والابْتِلاء. وهذ كلها مُحْتَمَلَةٌ في هذه الآية.قال قتادة {66} - في قوله: ﴿وَلِيُمَحِّصَ مَا فِي قُلُوبِكُمْ﴾، أي: يُظْهِرها {67} مِنَ الشَّكِّ والارْتِيَاب؛ بما يُرِيكم من عجائب صُنعه في إلقاء الأَمَنَةِ، وصَرْفِ العدُوِّ، وإعلانِ سَرَائِرِ المنافقين. وهذا {68} التمحيص خاصٌّ للمؤمنين؛ فابن عباس قال {22}: يريد: يُمَحِّص قلوب أوليائه من الخطأ.وقال الكَلْبِيُّ {22}: ﴿وَلِيُمَحِّصَ﴾: يُبَيِّن ما في قلوبكم. يعني: أن المؤمن يُظْهِر الرِّضَا بِقَدَرِ الله، والمنافق يُظْهر مثلَ ما أظهرَ مُعَتِّب بن قُشَيْر وأصحابُه. فَعَلَ اللهُ ما فَعَلَ يومَ أُحُد؛ لِيُبَيِّنَ ما في قلوب الفريقين.ويَحْتَمِلُ التَّمْحِيصُ -ههنا- معنى الابتلاء، غير أن القولين الأَوَّلَيْن أجودُ؛ لِزِيَادَةِ الفائدة؛ فإنَّ الابتلاءَ قد ذُكِرَ في قوله: ﴿وَلِيَبْتَلىَ اللَّهُ﴾.وقوله تعالى: ﴿وَاللَّهُ عَلِيمٌ بِذَاتِ الصُّدُورِ﴾ (ذاتُ الصدور)، تحتمل معنيين: أحدهما: أن (ذات الصدور) هي: الصدور؛ لأن ذاتَ الشيء نَفْسُهُ، وعَيْنهُ. يقال: (فَهَمتُ ذاتَ كلامك)، كما يقال: (نَفْسَ كلامك). قال الشاعر:نَطُوفُ بِذَاتِ البيتِ والخَيْرُ ظاهِرُ {71}أي: البيت نفسه. وفيه معنى التأكيد. فيكون المعنى: واللهُ عليمٌ بالصدور.والثاني: أنَّ (ذاتَ الصدور): الأشياء التي في الصدور، وهي الأسرار والضمائر، وهي (ذات الصدور)؛ لأنها فيها، تَحُلُّها {72} وتصاحبها وصاحب الشيء: (ذُوهُ)، وصاحبته: (ذاته) {73}."
  3,155,"قوله تعالى: ﴿إِنَّ الَّذِينَ تَوَلَّوْا مِنْكُمْ يَوْمَ الْتَقَى الْجَمْعَانِ﴾ هذا الخطاب للمؤمنين خاصَّةً، يعني: الذين انهزموا يوم أحد {1}.﴿إِنَّمَا اسْتَزَلَّهُمُ الشَّيْطَانُ﴾ أي: حَمَلَهُمْ على الزَّلَّةِ، وَكَسَبَهُمْ الزَّلَّةَ {2}.و (أَزَلَّ)، و (اسْتَزَلَّ)، بمعنى واحد. ذكرنا ذلك في قوله: ﴿فَأَزَلَّهُمَا الشَّيْطَانُ﴾ [البقرة: 36] {3}.وقال ابن قُتَيْبَة {4}: ﴿اسْتَزَلَّهُمُ﴾: طَلَبَ زَلَّتَهم؛ كما يقال: (استعجلته)؛ أي: طَلَبْتُ عَجَلَتَهُ، و (استعملته): طَلَبْتُ عَمَلَهُ.وقول تعالى: ﴿بِبَعْضِ مَا كَسَبُوا﴾ قال مقاتل {5}: يعني: معصيتهم النبيَّ ﷺ، وتركهم المَرْكَزَ.وقيل: استزَلَّهم الشيطانُ بِتَذْكِيرِ خَطَايَا سَلَفَتْ لهم، فكرهوا أن يُقْتَلُوا قبلَ إخلاصِ التَّوْبَةِ. وهذا اختيار الزَّجَّاج؛ لأنه قال {6}: لَمْ يَتَوَلَّوا على جهة المُعَانَدَةِ، ولا على الفِرَارِ مِنَ الزَّحْفِ؛ رَغْبَةً في الدنيا، وإنَّمَا ذَكَّرَهُم الشيطانُ خَطَايَا كانت لهم، فكرهوا لقاءَ اللهِ، إلا على حَالَةٍ يَرْضَوْنَهَا {7}.وقوله تعالى: ﴿وَلَقَدْ عَفَا اللَّهُ عَنْهُمْ﴾.قال الكلبيُّ {8}، ومقاتلُ {5}: عَفَا عنهم إذْ لَمْ يُقْتَلوا جميعًا، ولم يَسْتَأصِلْهم {10}.وقيل {11}: عَفا عنهم؛ أي: غفر لهم تلك الخطيئة."
  3,156,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا لَا تَكُونُوا كَالَّذِينَ كَفَرُوا﴾ الآيةقال ابن عباس -في رواية عطاء {1} -: يريد قومًا من المنافقين قالوا فيمن بعثه رسولُ الله ﷺ، مِنَ السَّرَايَا إلى بِئْرِ مَعُونَة {2}، وإلى الرَّجيع {3}، فأُصِيبوا: ﴿لَوْ كَانُوا عِنْدَنَا مَا مَاتُوا وَمَا قُتِلُوا﴾.وقال مجاهد {4}، ومحمد بن إسحاق {5}: يعني بـ ﴿الَّذِينَ كَفَرُوا﴾: جميعَ المنافقين.وقوله تعالى:﴿وَقَالُواْ لِإِخوَانِهِم﴾. أي: في النِّفَاق. وقيل: في النَّسَبِ {6}.﴿إِذَا ضَرَبُوا فِي الْأَرْضِ﴾ أي: ساروا وسافروا فيها. وكان {7} ينبغي في العَرَبِيَّةِ أنْ يُقَال: (وقالوا لإخوانهم إذْ {8} ضَرَبُوا في الأرض)؛ لأنه ماضٍ، كما تقول: (ضربتك إذْ قُمْتَ)، ولا تقول {9}: (ضربتك إذا قُمْتَ). والذي في كتاب الله عَرَبِيٌّ حَسَنٌ، لأن القَوْلَ -وإن كان ماضيًا في اللفظ- فهو في معنى {10} الاستقبال؛ لأن (الذين) يُذْهَبُ بها إلى معنى الجزاء، وكذلك: (مَنْ)، و (ما). فإذا وقع الماضي صِلَةً لِمُبْهَمٍ مِنْ (مَنْ) و (ما) و (الذين)، جازَ أنْ يكون بمعنى الاستقبال {11}.فقوله {12}: ﴿كَالَّذِينَ كَفَرُوا﴾، في معنى: يَكْفُرُونَ، فدخلت (إذا) لِمَعْنى الاستقبال؛ والتقدير: (لا تكونوا كالذين يكفرون {13}، ويقولون لإخوانهم إذا ضربوا في الأرض (ومثله: ﴿إِنَّ الَّذِينَ كَفَرُوا وَيَصُدُّونَ عَنْ سَبِيلِ اللَّهِ﴾ [الحج: 25]؛ معناه: إنَّ الذين يكفرون. وكذلك قوله: ﴿إِلَّا الَّذِينَ تَابُوا مِنْ قَبْلِ أَنْ تَقْدِرُوا﴾ [المائدة: 34]؛ معناه: يَتُوبُون. ومثله: ﴿إِلَّا مَنْ تَابَ وَآمَنَ وَعَمِلَ صَالِحًا﴾ [مريم: 60]؛ معناه: إلّا مَن يَتُوب.ومشهورٌ في كلامهم، أنْ يقول الرجلُ للرجلِ: (لا تضربْ إلّا الذي ضَرَبَكَ؛ إذا سَلَّمْتَ عليه). فيجيء بـ (إذا)؛ لأن (الذي) غير مُؤَقَّت، فلو وَقَّته، لَقَالَ: (اضربْ هذا الذي ضَرَبَكَ؛ إذْ {14} سَلَّمْتَ عليه). ولا يجوز: (إذا سَلَّمْتَ) -ههنا-؛ لأنَّ توقيت (الذي) أبْطَلَ أنْ يكونَ الماضي في معنى المستَقبَلِ. وتقول: (ما هَلَكَ امرُؤٌ عَرَفَ قَدْرَهُ)؛ لأن الفعل حديثٌ عن مَنْكُورٍ؛ يُراد به الجنس؛ كأنَّ المتكلمَ يريد: (ما يهلك كُلُّ امرئٍ إذا عرف قدره)، أو الرَّجُل وما أشبهها {15}.هذا مذهب الفراء {16}، وأنشد:وإنِّي لآتِيكمْ تَشَكُّرُ ما مَضَى ... مِنَ الأمرِ واستيجابَ ماكان في غَدِ {17} أي: ما يكون.وأجاز {18} قُطْرُب {19} أنْ تُوقَعَ (إذْ) على معنى (إذا)، و (إذا) على معنى (إذ)، واحتج بقول الشاعر:ثمَّ جَزَاهُ اللهُ عَنِّي إذ جَزَى ... جَنَّاتِ عَدْنٍ في العَلالِيِّ العُلى {20}معناه: إذا يجزي {21}.قال ابن الأنباري {22}: والاختيار: مذهب الفراء؛ لأنه لا يصلح في كلِّ موضعٍ وَضْعُ {23} (إذ) في موضع (إذا)، ولا وَضْعُ (إذا) في موضع (إذ).والذي احْتَجَّ به من قولِ الراجز، فإن معناه: (ثم جزاه الله عني، إذْ حَكَمَ بالجزاء وأوجبه). فـ (إذ) في بابها، غير منقولة إلى معنى غيرها {24}.وقوله تعالى: ﴿أَوْ كَانُوا غُزًّى﴾ (الغُزَّى) {25}: جمع (غازٍ)؛ مثل: (شاهِدٍ، وشُهَّد)، و (نائِم ونُوَّم)، و (صائِمٍ وصُوَّم)، و (قائلٍ وقُوَّل). ومثله من الناقص: (عَافٍ وعُفًّى {26}. ويجوز (غُزَاة)؛ مثل: (قُضَاة)، و (دُعَاة)، و (رُمَاة). ويجوز (غُزَّاء) مثل: (حُرَّاب) {27}، و (ضُرَّاب) {28}.ومعنى (الغَزْوِ) -في كلام العرب-: قَصْدُ العَدُوِّ. و (المَغْزَى): المَقْصد.روى عَمْرُو {29} عن أبيه: (الغَزْوُ): القَصْد. و-كذلك- (الغَوْزُ). و (قد غَزَاه، وغَازَه، غَزْوًا، وغَوْزًا): إذا قَصَدَه.قال الأزهري {30}: ويقال لِجَمْعٍ (الغَازِي): (غَزِيٌّ)؛ مثل: (نَاجٍ، ونَجِيٍّ)؛ للقوم يَتَناجَوْنَ، وأنشد لِزِياد {31} الأعجم:قُلْ لِلْقَوافِلِ والغَزِيِّ إذا غَزَوْا ... والباكِرِينَ ولِلْمُجِدِّ الرَائحِ {32} وفي الآية محذوفٌ، يَدُلُّ عليه الكلامُ؛ والتقدير: إذا ضَرَبُوا في الأرض، فَمَاتُوا أو كانوا غُزًّى فَقُتِلُوا، ﴿لَوْ كَانُوا عِنْدَنَا مَا مَاتُوا وَمَا قُتِلُوا﴾ {33}.فقوله: ﴿مَا مَاتُوا وَمَا قُتِلُوا﴾؛ يَدُلُّ على موتِهم وقَتْلِهم.وقوله تعالى: ﴿لِيَجْعَلَ اللَّهُ ذَلِكَ حَسْرَةً فِي قُلُوبِهِمْ﴾ أي: لِيَجْعَلَ ظَنَّهُمْ -أَنَهم لو [لم]، {34} يَحْضُروا {35} الحربَ؛ لاندفع عنهم القتلُ- حَسْرَةً في قلوبهم. وحَسْرَتُهُم -في مَقَالَتِهم، التي كانوا كاذبين فيها على القضاء والقدر-؛ أشَدُّ {36} عليهم مما {37} نالهم في قَتْلِ إخوانهم ومَوْتِهم.وتقدير الآية: لا تكونوا كهؤلاء الكفار في هذا القول منهم؛ لِيَجْعَلَ اللهُ ذلك حسرةً في قلوبهم دونكم. فـ (اللام) في ﴿لِيَجْعَلَ﴾ متعلقة بـ ﴿لاَ تَكُونُوا﴾.وقوله تعالى: ﴿وَاللَّهُ يُحْيِي وَيُمِيتُ﴾ أي {38}: ليس يمنع الإنسانَ تَحَرُّزُهُ مِن إتْيَان أجَلِهِ على ما سَبَقَ في عِلْمِ الله -عز وجل-. فهو إنكارٌ على مَن خالفَ أمْرَ اللهِ في الجهاد؛ طَلَبًا {39} للحياة، وهَرَبًا من الموت. هذا قول أكثر المفسرين في هذه الآية {40}.وقال ابن عباس -في رواية عطاء {1} - في قوله: ﴿لِيَجْعَلَ اللَّهُ ذَلِكَ حَسْرَةً فِي قُلُوبِهِمْ﴾ ، يريد: يومَ القِيَامَةِ؛ لِمَا هم فيه من الخِزْيِ والهَوَان، ولما فيه أولياء {42} الله مِنَ الكَرَامَةِ والنَّعِيم. ﴿حَسْرَةً فِي قُلُوبِهِمْ﴾؛ يريد: الندامة على ترك الإسلام.﴿وَاللَّهُ يُحْيِي وَيُمِيتُ﴾؛ يريد: يحيى قلوبَ أوليائه وأهلِ طاعته، وُيرْشِدُهم للعمل بطاعته، وُيميت قلوبَ أعدائِهِ من المنافقين والكُفَّار. واللَّام {43} -على هذا التفسير- في قوله ﴿لِيَجْعَلَ اَللَّهُ﴾ متعلق {44} بقوله ﴿كَفَرُوا﴾؛ على [أنها] {45} لام العاقبة {46}؛ مثل قوله: ﴿فَالْتَقَطَهُ آلُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّا وَحَزَنًا﴾ {47}.وقوله تعالى: ﴿وَاللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ﴾ بالياء والتاء {48}. فمن قرأ بالتاء؛ فلأن الآية خطاب، وهو قوله: ﴿وَلَا تَكُونُوا﴾. ومن قرأ [الياء] {49}، فلِلْغَيْبَةِ التي قبلها؛ وهو قوله: ﴿وَقَالُوا لِإخوَانِهِم﴾، فحمل الكلام على الغَيْبَةِ."
  3,157,"قوله تعالى: ﴿وَلَئِنْ قُتِلْتُمْ فِي سَبِيلِ اللَّهِ﴾.اللام في ﴿لَئِنْ﴾ لام القَسَم؛ بتقدير: والله لَئِنْ قُتِلتُمْ في سبيل الله -أيها المؤمنونَ- ﴿أَوْ مُتُّمْ﴾؛ يريد: في سبيل الله؛ كقوله: ﴿وَالْحَافِظِينَ فُرُوجَهُمْ وَالْحَافِظَاتِ﴾ [الأحزاب: 35]؛ يعني: فُرُوجَهم. وقال الكَلْبِيُّ {1}: أوْ مُتُّمْ في إقامتكم، وأنتم مؤمنون.وقرأ بعضهم: ﴿مِتُّمْ﴾ بكسر الميم {2}.قال أهل اللغة {3}: الأشهر الأقْيَس: (مُتَّ، تَمُوتُ)، مثل: (قُلْتَ، تقول). والكسر شادٌّ {4}. ونظيره في الصحيح {5}: (فَضِلَ يَفْضُلُ) {6}.هذا مذهب الخليل {7}.وحكى المُبرِّد {8}: أنَّ (مَاتَ يَمَاتُ)، لغة، مثل: (هَابَ يَهَابُ)، و (خافَ يَخَافُ)، وأنشد:عِيشِي ولا يَوْمِي بِأنْ تَمَاتِي {9}فإن ثَبَتَ هذا، فهو لُغَةٌ.قالَ ابنُ عباس {10}: هذه الآية رَدٌّ على المنافقين؛ حيث اختاروا الدنيا على الآخرة، وتركوا الجهاد؛ مَحَبَّةً للدنيا. فقيل للمؤمنين: ﴿وَلَئِنْ قُتِلْتُمْ﴾ في الجهاد ﴿أَوْ مُتُّمْ﴾ ليغفرن لكم، وهو ﴿خَيْرٌ مِمَّا يَجْمَعُونَ﴾.وقوله تعالى: ﴿لَمَغْفِرَةٌ مِنَ اللَّهِ وَرَحْمَةٌ﴾.﴿لَمَغْفِرَةٌ﴾ {11}: جواب القسم. وقد قام مقام جواب الجزاء.وقوله تعالى: ﴿خَيْرٌ مِمَّا يَجْمَعُونَ﴾ أي: من أعراض الدنيا، التي يتركون القتال {12} في سبيل الله؛ للاشتغال بجمعها.وروي عن ابن عباس، أنه قال {13}: ﴿تَجمَعون﴾ {14}: خطاب المنافقين؛ لأنه قال: ﴿خَيْرٌ مِمَّا تَجْمَعُون﴾ {15} يا معشرَ المنافقين. ومثله، قال الكَلْبِيُّ {10}.وقرأ حَفْص، عن عاصم: ﴿يَجمَعُونَ﴾ -بالياء-. ويكون المعنى: لَمَغْفِرةٌ مِن اللهِ ورَحْمَةٌ، خيرٌ مِمَّا يجمعُهُ غَيْرُكُم، مِمَّا تَرَكوا القِتَال لِجَمْعِهِ {17}."
  3,158,"قوله تعالى: ﴿وَلَئِنْ مُتُّمْ﴾ قال المفسرون: يريد: مقيمين عن الجهاد. ﴿أَوْ قُتِلْتُمْ﴾؛ يريد: مجاهدين {1}.﴿لَإِلَى اللَّهِ تُحْشَرُونَ﴾؛ يعني: في الحالين. وهذا تهديد بالحشر، وتحذير من القيامة.واللام في ﴿لَئِنْ﴾ خلف من القسم. والثانية {2}: جواب، على معنى: والله إن متم، أو قتلتم لتحشرون إلى الله.قال أبو عبيد: وتقول في الكلام: (لَئِن أحسنتَ إِليَّ؛ لأحْسِنَنَّ إليك) -بالنُّونِ-. فإذا حُلْت بينهما بالصفة {3}، قلت: (لَئِن أحسنتَ إليَّ، لإليكَ أُحْسِن) -بغير نُونِ-. كما في الآية-، لأن اللام قد تحولت إلى الصفة {4}."
  3,159,"قوله تعالى: ﴿فَبِمَا رَحْمَةٍ مِنَ اللَّهِ﴾.أكثر النحويِّينَ على أنَّ (ما) -ههنا- صِلَةٌ {1}، لا تمنع الباءَ مِن عَمَلِها فيما عملت فيه، وهي مع كونها صلةً، تُحْدِثُ معنى التأكيد {2} وحُسْن النَّظْم. وهي كثيرةٌ في القرآن؛ كقوله: ﴿عَمَّا قَلِيلٍ﴾ [المؤمنون: 40]، و ﴿جُندٌ مَّا﴾ [ص: 11]، ﴿فبَمَا نَقضِهِم﴾ [النساء: 155]، ﴿مِمَّا خَطَايَاهُمْ﴾ {3} [نوح: 25].[وتكثر] {4} -أيضًا- في الشعر؛ قال امرؤ القيس:وقاهم جَدُّهُمْ بِبَني أبِيهم ... وبالأشْقَيْنَ ما كانَ العِقَابُ {5}أراد: (وبالأشْقَيْنَ {6} كان العِقَابُ) {7}.وقال النابغة:المرءُ يَهْوَى أنْ يَعِيـ ... ـشَ وطُولُ عَيْشٍ ما يَضُرُّهْ {8} أراد: (وطول عيش يَضُرُّهْ). فأكد الكلام بـ (ما).والعرب قد تزيد في الكلام ما يُسْتغنى عنه؛ للتأكيد؛ كقوله: (أنت فعلت كذا وكذا؛ يا هذا!) فأدخلوا (يا هذا)؛ للتأكيد؛ إذ كانت (أنت) دالاًّ على الخطاب. وكذلك قولهم: (لَمَّا أنْ زارني عبد الله، زُرْتُه). معناه: لَمَّا زارني {9}.قال الله تعالى: ﴿فَلَمَّا أَنْ جَاءَ الْبَشِيرُ﴾ [يوسف: 96]، أراد: فلَمَّا جاء. فأكّد بـ (أنْ) {10}. وكذلك قولهم:يا تَيْمَ تَيْمَ عَدِيٍّ {11} أكد الكلام بـ (تَيْم) {12} الثاني. هذا قول أكثر أهل التأويل.وقال بعضهم {13}: يجوز أن تكون (ما) استفهامًا للتعجب {14}، تقديره: (فَبِأَيِّ رَحْمَةٍ مِنَ اللهِ لِنْتَ لهم؟!)؛ أي: سَهُلَتْ لهم أخلاقُكَ، وكثر احتمالك {15}.وقوله تعالى: ﴿لِنْتَ لَهُمْ﴾ (لانَ، يَلِينُ، لِينًا) {16}، و (لَيَانًا) -بالفتح: إذا رَقَّ، وحَسُنَ [خُلُقُهُ] {17}، وانْقادَ {18}.قال الشاعر:وإنْ هي أعطتك اللَّيانَ كأنها ... لِغَيرك مِن خُلّانِها سَتَلِينُ {19} وقوله تعالى: ﴿وَلَوْ كُنْتَ فَظًّا﴾ الفظُّ {20}: الغليظ الجانب، السَّيّءُ الخُلُق {21}. يقال: (فَظِظْتَ، تَفَظُّ، فَظَاظَةً، وَفِظَاظًا)، فأنت فَظٌّ {22}، وأصله. (فَظِظٌ)؛ كقولك: (حَذِرٌ) {23}؛ من: (حَذِرْتَ) {24}، و (فَرِقٌ) {25}؛ مِن: (فَرِقْتَ). إلّا أنَّ ما كان مِن المضاعف على هذا الوزن، يُدْغَم؛ نحو: (رَجُلٌ صَبٌّ) {26}. وأصله: صَبِبٌ) {27}.قال الكلبي {28}: ولو كنت فظًّا في القول، غليظ القَلْبِ في الفعل {29}. ﴿لَانْفَضُّوا مِنْ حَوْلِكَ﴾ أي: لَتَفَرَّقوا وَنَفَرُوا منك؛ كما تتطاير شظايا الشيء المتكَسِّر.والفَضُّ: الكسر والتفريق {30}. يقال: (فَضضْتَ القومَ، فانْفَضُّوا). ومنه يقال: (لا يَفْضُضِ اللهُ فاكَ) {31}.قال الزّجاج {32}: المعنى: إنَّ لِينَكَ لهم، يُوجِبُ {33} دخولهم في الإسلام {34}؛ لأنك تأتيهم بالحُجَجِ والبراهين، مع لِينٍ وخُلُقٍ عظيم.وقوله تعالى: ﴿فَاعْفُ عَنْهُمْ﴾. أي: ما فعلوا يومَ أُحُد حتى أشفعك فيهم. وقال الكلبي: فاعف عنهم أي الشيء يكون منهم و ﴿وَاسْتَغْفِرْ لَهُمْ﴾. مِنْ ذلك الذَنْب.وقوله تعالى: ﴿وَشَاوِرْهُمْ فِي الْأَمْرِ﴾ يقال: (شَاوَرَ مُشَاوَرَةً)، و (شِوارا) {35}، و (مَشُورَةً) {36}، و (مَشْوَرَةً) {37}. و (القوم شُورى). وهي مصدرٌ، سُمِّي القومُ بها، كقوله: ﴿وَإِذْ هُمْ نَجْوَى﴾ {38} [الإسراء: 47].وقد ذَكَرْنا أمْرَ هذه الكلمة وما فيها، عند قوله: ﴿عَنْ تَرَاضٍ مِنْهُمَا وَتَشَاوُرٍ﴾ [البقرة: 233].قال أصحاب المعاني {39}: هذه عامَّةٌ في اللفظ، خاصَّةٌ في المعنى؛ لأن المعنى: وشاورهم فيما ليس عندك فيه من الله {40} أَمْرٌ وَوَحْيٌ {41} وعَهْد. يدل عليه: قراءةُ ابن عباس: (وشاورهم في بعض الأمر) {42}.وقال الكلبي {43}: إنما أُمِرَ بالمُشَاوَرَةِ معهم في لِقَاءِ العدُوِّ، والحربِ ومكايِدِها {44}. فالأمر -عنده- بالمشاورة، خاصٌّ في الحرب.وروى عَمرو بن دينار، عن ابن عباس، أنه قال {45}: الذي أُمِرَ النبيُّ ﷺ، بمشاورته في هذه الآية: أبو بكر وعمر- رضي الله عنهما-.وقال قتادة {46}، والربيع {47}، ومقاتل {48}: إنما أُمِرَ بالمشاورة مع استغنائه بوحي الله وجَزَالَةِ رأيه؛ تَطْيِيبًا لِنُفُوسِ القوم، ورَفْعًا {49} مِن أقدارهم؛ إذْ كانت العربُ إذا لم يُشَاوروا في الأمر، شَقَّ عليهم.قال الشافعي ({50}: وهذا كقوله ﷺ: ""والبِكْرُ تُسْتَأمَر"" {51}، ولو أكرهها {52} الأبُ على النِّكاح، جَازَ، لكنَّها تُسْتَأمر؛ تطييبا لِنَفْسِها.وقال الحَسَنُ {53}، وسُفْيانُ بن عُيَيْنَة {54}: إنما ذلك؛ لِيَقْتَدِيَ به غيرُهُ في المُشَاوَرَةِ، ويَصِير سُنَّة.وقوله تعالى: ﴿فَإِذَا عَزَمْتَ﴾؛ أي: على ما تريد إمضاءَهُ {55}.﴿فَتَوَكَّلْ عَلَى اللَّهِ﴾، لا على المشاورة. ومعنى التَّوَكُّلِ: تفويضُ الأَمْرِ إلى الله؛ لِلثِّقَةِ بِحُسْنِ تدبيره."
  3,160,"قوله تعالى: ﴿إِنْ يَنْصُرْكُمُ اللَّهُ فَلَا غَالِبَ لَكُمْ وَإِنْ يَخْذُلْكُمْ﴾ الآية.معنى (الخِذْلان): القعود عن النُّصرَةِ وقت الحاجة إليها، والإسلامُ للهَلَكَةِ.يقال: (خَذَلَ، يَخْذُلُ، خِذْلانًا، وخَذْلًا). ويقال للبقرة والظَّبْيَة، إذا تخلفت مع ولدها في المرعى، وتركت صواحباتها: (خَذُول) {1}.قال {2} طَرَفَة:خَذُولٌ تُرَاعِي رَبْرَبًا بِخَمِيلَةٍ ... تَنَاوَلُ أطرافَ البَرِيرِ وترتدي {3} وقال ذو الرُّمَّةِ {4}:دَعَتْ مَيَّةَ الأعدادُ واستَبدَلت بها ... خَنَاطِيلَ آجَالٍ {5} مِنَ العِينِ {6} خُذَّلِ {7}أي: متخلفات من الأولاد.والخَنَاطِيل {8}: جماعاتٌ في تَفْرِقَةٍ، لا واحد لها مِنْ لَفْظِها. وقيل: واحدها (خُنْطُول) {9}.قال محمد بن إسحاق بن يَسَار -في هذه الآية- {10}: أي: إنْ يَنْصُرْكَ {11} اللهُ؛ فَلاَ غالبَ لك مِنَ النَّاس، ولن يَضُرَّكَ خِذْلانُ مَنْ خَذَلَكَ، وإنْ يَخْذلْكَ؛ فَلَنْ يَنْصُرَكَ الناسُ؛ أي: لا تترك أمري للناس، وارفض الناسَ {12} لأمري.وقوله تعالى: ﴿فَمَنْ ذَا الَّذِي يَنْصُرُكُمْ مِنْ بَعْدِهِ﴾.(مَنْ) -ههنا-: تقريرٌ لِلنَّفْي؛ أي: لا يَنْصُرُكُمْ أحدٌ {13} مِنْ بَعْدِهِ. وإنما تضمن حرفُ الاستفهام معنى النفي؛ لأن جوابَهُ يجب أن يكون بالنفي، فصار ذِكْرُهُ يغني عن ذِكْرِ جوابه، وكان أبلغ لتقرير المخاطَبِ فيه، بما لا يتهيأ له إنكاره."
  3,161,"قوله تعالى: ﴿وَمَا كَانَ لِنَبِيٍّ أَنْ يَغُلَّ﴾ الآية.اختلفوا في سبب نزول هذه الآية:فرَوَى عكرمةُ، ومِقْسَم {1}، وسعيد بن جبير، عن ابن عباس: أنَّ الآية نزلت في قَطِيفَةٍ {2} حمراءَ، فُقِدَت يوم بَدْر، قال بعض الناس: لَعَلَّ النبي ﷺ أخذها {3}.وقال -في رواية الضحّاك- {4}: إن رسول الله ﷺ، لَمَّا وَقَعَ في يده غنائمُ هَوَازِنَ يوم حُنَيْنٍ، غَلَّهُ رجلٌ بِمِخْيَط، فأنزل الله هذه الآية.وقال قتادة -في نزول هذه الآية- {5}: نزلت وقد غَلَّ طوائفُ مِن أصحابه. ورُوي عن ابن عباس -من طريقٍ آخرَ-: أنَّ أشراف الناس استدعوا رسول الله ﷺ، [وطلبوا] {6} تخصيصهم {7} بشيءٍ مِنَ المغانم؛ فنزلت هذه الآيةُ {8}وقال الكلبي {9}، ومقاتل {10}: نزلت حين ترك الرُّمَاةُ المَرْكَزَ يومَ أحُد؛ طلبا للغنيمة، وقالوا: نخشى أنْ يقول النبي ﷺ: مَن {11} أخَذَ شيئًا فهو له، وأنْ لا يقسِم الغنائمَ، كما لم يَقْسِمْ {12} يومَ بَدْر. فقال النبي ﷺ: ظننتم أنَّا نَغُلُّ، ولا نَقْسِم لكم. فأنزل الله هذه الآية.وفي قوله ﴿يَغُلَّ﴾ قراءتان: أحدهما: فتح الياء، وضم الغَيْن {13}؛ ومعناه: ما كان لِنَبِيٍّ أن يَخُونَ. مِنَ (الغُلُول)، وهو: الخِيَانَةِ. يُقال: (غَلَّ، يَغُلُّ، غُلُولًا): إذا خَانَ، وأصلُهُ: أخْذُ الشيء في خُفْيَةٍ {14}.قال الزّجاج {15}: وما {16} كان مِنْ هذا الباب، فهو راجعٌ إلى هذا، مِنْ ذلك: (الغَالُّ): وهو الوادي الذي {17} يُنْبِتُ الشجرَ، في مُطْمَئِن مِنَ الأرض {18}، وجمعه: (غُلّان)، ومن ذلك: (الغِلّ): الحقد في الصدر؛ لأنه كامن {19}، و (الغِلاَلَة): الثوب الذي يلبس تحت الثياب {20}. و (الغَلَلُ) {21}: الماء الذي يجري في أصول الشجر؛ لأنه مستَتِرٌ بالأشجار.فمعنى قوله تعالى: ﴿وَمَا كَانَ لِنَبِيٍّ أَنْ يَغُلَّ﴾، أي: أن يَخُونَ فيكم {22} الغنيمةَ مِن أصحابه. أو أنْ يَخُونَ بأن يعطيَ البعضَ دون البعضِ، على ما روي في سبب النزول.فإن قيل: ما معنى تخصيص النبي ﷺ ههنا-، وغيرُهُ يساويه في أنه ليس له ذلك؟.قلنا: (أَنْ) مع المستقبل، تكون بمعنى المصدر؛ كأنه قيل: (ما كان لِنَبي الغُلُول)؛ أراد: ما غَلَّ نَبِيٌّ. ينفي عن الأنبياء الغُلُولَ، لا أنه {23} ينهاهم بهذا اللفْظَ.وقال {24} بعض أهلِ المعاني: اللّام فيه منقولة؛ معناه: ما كان نَبِيٌّ {25} ليَغُل، كقوله -عز وجل-: ﴿مَا كَانَ لِلَّهِ أَنْ يَتَّخِذَ مِنْ وَلَدٍ﴾ [مريم: 35]، أي: ما كان الله لِيَتّخِذَ [ولدا] {26}، على نفي الاتخاذ، -كذلك- الآيةُ على نفي الغُلُول عن الأنبياء.وحجة هذه القراءة: ما روي عن ابن عباسٍ -في أكثر الروايات- في سبب نزول الآية، وعن الكلبي ومقاتل، وذلك يدل على نَسَبِ الغُلُول إلى النبي ﷺ، فَنَفى ذلك عنه. و-أيضًا- فإنَّ ما هو مِن هذا {27} القبيل في التنزيل، أُسنِدَ الفعلُ فيه إلى الفاعل، نحو: ﴿مَا كَانَ لَنَا أَنْ نُشْرِكَ بِاللَّهِ﴾ [يوسف: 38]، و ﴿مَا كَانَ لِيَأْخُذَ أَخَاهُ﴾ [يوسف: 76]، و ﴿وَمَا كَانَ لِنَفْسٍ أَنْ تَمُوتَ﴾ [آل عمران: 145]، و ﴿وَمَا كَانَ اللَّهُ لِيُضِلَّ قَوْمًا﴾ [التوبة: 115] ، و ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ﴾ [آل عمران: 179].ولا يكاد يجيء منه: (ما كان زيدٌ ليُضْرَبَ)، فيُسنَد الفعلُ فيه إلى المفعول به، فكذلك: ﴿وَمَا كَانَ لِنَبِيٍّ أَنْ يَغُلَّ﴾ يُسندُ {28} فيه الفعلُ إلى الفاعل. يُؤكِّدُ {29} هذا الفصل، ما حكى أبو عبيد {30} عن يونس {31} أنه اختار (يَغُلّ) -بفتح الياء-، وقال: لا يكون في الكلام: (ما كان لك أن تُضْرَب) بضم التاء.وهذه القراءة اختيار ابن عباس، كان {32} يقرأ (يَغُلّ) بفتح الياء، فقيل له: إنَّ ابن مسعود يقرأ: ﴿يُغَلّ﴾، فقال ابن عباس: قد كان النبي يُقتَل، فكيف {33} لا يُخَوَّنُ؟ {34}.والقراءة الثانية: ﴿يُغَلّ﴾ بضم الياء، وفتح الغين.وهذه القراءة تحتملُ وجهين {35}: أحدهما: أن يكون من (الغُلُول). والثاني: أن يكون من (الإغلال).فإن جعلتها من (الغُلُول) احتملت معنيين: أحدهما: أن معنى قوله: ﴿وَمَا كاَنَ لِنبيٍّ أَن يُغَلّ﴾ {36}؛ أي: ليس لأحدٍ أن يَغُلَّهُ، فيأخذ مِنَ الغنيمة التي حازها {37} على طريق الخيانة، وإن كان لا يجوز أن يُغَلّ غيرُ النبيِّ، مِن إمام المسلمين وأميرٍ لهم {38}.وفائدة تخصيص النبي ﷺ بالذِّكْر: أن الغُلُول يَعْظُمُ بحضرته، ويكبر كِبَرًا لا يكبر عند غيره؛ لأن المعاصي بحضرته أعظم.المعنى {39} الثاني: أن تكون (أَنْ) مع الفعل، بمنزلة المصدر؛ كما ذَكَرْنا في القراءة الأولى. ويكون المعنى: ما كان لِنَبيٍّ غُلولٌ من المُتَحقِّقِينَ بِنُبُوَّتِهِ؛ أي: لم يَخُنْهُ أصحابُهُ وأنصارُهُ، ويكون في هذا ذَمٌّ لِمَن خانَه.يُؤكِّد هذا المعنى ما روى عطاءٌ عن ابن عباس {40}، في قوله: ﴿وَمَا كاَنَ لِنبيٍّ أَن يَغُلَّ﴾؛ يريد: أن يكون ممن يَصْحَبُهُ، أحدٌ يَغُلُّ ويَسْتَحلُّ الغُلُولَ.وإن أخذت بهذه القراءةِ مِنَ (الإغْلال)، احتَمَلَتْ -أيضا- معنيين:أحدهما: أن يكون (الإغلال) بمعنى (الغُلول). يقال: (غَلّ الرجلُ مِنَ الغنيمة، يَغل غَلًّا، وغلولًا)، و (أَغَلّ إغلالًا): إذا سَرَق منها {41}. ذكره الزّجاج في باب الوفاق {42} ومِن هذا يقال: (أغَلّ الجازِر، والسَّالِخُ): إذا أبْقَى في الجِلْدِ شيئًا مِنَ اللَّحْمِ؛ على طريقِ السَّرِقَةِ والخيانة {43}.قال النَّمْر بن تَوْلَب {44}: جَزَى اللهُ عنَا جَمْرَةَ ابْنَةَ نَوْفَلٍ ... جَزاءَ مُغِلٍّ {45} بالأمانَةِ كاذبِ {46}وقال آخر:حَدَّثْتَ {47} نفْسَكَ بالوَفَاءِ ولم تَكُنْ ... للْغَدْر خائنَةً مُغلَّ الإصْبَع {48}قوله: (لِلْغَدْرِ) {49}؛ أي: لِكَراهَةِ الغَدرِ. و (الخائِنَة): يحتمل أن تكَون مصدرا؛ كـ (العافِيَةِ)، و (العَاقِبَةِ).و-حينئذٍ - يُقَدَّرُ حذفُ المضاف؛ أي: لم يكنَ صاحبَ خائِنَةٍ؛ أي: خيانَة. وإنْ شئتَ جعلته مثل: (راوِيَة).ونَسَبَ {50} الإغْلالَ إلى الإصْبَع، كَمَا نَسَبَ {51} الآخرُ الخيانةَ إلى اليَدِ، في قوله:أَحَذَّ {52} يَدِ القَمِيصِ {53} قال: جعلت (الإغلالَ) بمعنى (الغُلول). فقد ذكرنا للغُلُول معنيين في هذه القراءة.المعنى الثاني: أنْ يكون (الإغلالُ) بمعنى النسبة إلى الغُلُول. وقد يَردُ {54} (الإفْعَال) بمعنى النسمة، شاذًّا، وإن كان الأكثر فيه التَفْعيل؛ كقولهم: (أسْقاهُ)، أي: قال له: سَقَاكَ اللهُ {55}.ومنه قول ذي الرُّمَّة:وأُسْقِيهِ حتى كاد {56} ... البيت.ويقال (أَكْفَرَهُ): إذا نَسَبَهُ إلى الكفر.قال الكُمَيْت {57}:فَطَائِفَةٌ قَدْ أكفَرُوني بِحُبِّكُمْ {58}فيكون المعنى: وما كان لِنَبِيٍّ أن يُنْسَبَ إلى الغُلُول؛ أي: لا يُقَال له غَلَلْتَ.قال الفرّاءُ، في {59} هذه الآية {60}: وقرأ {61} أصحاب عبد الله {62}: ﴿يُغَلّ﴾؛ يريدون: أنْ يُسَرَّقَ ويُخَوَّنَ {63}، وذلك جائزٌ، وإنْ لم يَقُل: (يُغلَّل)، فيكون مثل قوله: ﴿فَإِنَّهُمْ لَا يُكَذِّبُونَكَ﴾، و ﴿ويُكَذِّبُونَكَ﴾ {64} [الأنعام: 33].ومِن حُجَّةِ هذه القراءة: ما رُوي عن ابن عبّاس، من طريق الضّحاك، وما روي عن قتادة، في سبب نزول هذه الآية {65}.وقوله تعالى: ﴿وَمَنْ يَغْلُلْ يَأْتِ بِمَا غَلَّ يَوْمَ الْقِيَامَةِ﴾.أي: يأتي به حاملًا له على ظهره، كما روي أن النبي ﷺ، خَطَبَ يومًا، فذَكَرَ الغُلُولَ، وعَظَّمَه، وعَظَّمَ أَمْرَهُ، فقال: ""لا أُلْفِيَنَّ {66} أحدَكمْ يجيء على رقبته يوم القيامة بَعِيرٌ له رُغَاء {67}، يقول: يا رسولَ الله! أعِنِّي {68}.فأقول: لا أملك لك مِنَ الله شيئًا، قد أَبْلَغْتُكَ"". وذَكَر في الحديث: الشاةَ والفرَسَ والصَّامِتَ {69}.وهذا قول: ابن عباس {70}، وأبي هريرة {71}، وأبي حُمَيْد الساعدي {72}، وابن عمر {73}، وقتادة {74}.وقوله تعالى: ﴿ثُمَّ تُوَفَّى كُلُّ نَفْسٍ مَا كَسَبَتْ﴾.قال ابن عباس {75}: يريد: تجازى ثوابَ عَمَلِها.﴿وَهُمْ لَا يُظْلَمُونَ﴾. قال {75}: وهم لا يُنقَصُونَ مِنْ ثوابِ أعمالهم شيئًا."
  3,162,"قوله تعالى: ﴿أَفَمَنِ اتَّبَعَ رِضْوَانَ اللَّهِ﴾.يعني: بترك الغُلُولِ -في قول: الكلبي {1}، والضحاك {2} -.﴿كَمَنْ بَاءَ بِسَخَطٍ مِنَ اللَّهِ﴾، في فِعْلِ الغُلول.وقيل: ﴿أَفَمَنِ اتَّبَعَ رِضْوَانَ اللَّهِ﴾ بالعمل بطاعته والإيمان، ﴿كَمَنْ بَاءَ بِسَخَطٍ مِنَ اللَّهِ﴾ في العملِ بمعصيته، والكفر به. وهذا القولُ يُحكَى عن محمد بن إسحاق {3}.وعلى هذا المعنى دلّ كلامُ ابن عباس -في رواية عطاء-؛ لأنه قال {4}: ﴿أَفَمَنِ اتَّبَعَ رِضْوَانَ اللَّهِ﴾؛ يريد: المهاجرين والأنصار، {كَمَنْ بَاءَ بِسَخَطٍ مِنَ اللَّهِ}؛ يريد: المنافقين.وقال الزجاج {5}: يروى أن النبي ﷺ، حين أمر المسلمين يوم أحد بالحرب، اتَّبَعَهُ المؤمنون، وتَخَلَّفَ عنه جماعةٌ مِنَ المنافقين {6}.فأعلم الله عز وجل: أنّ مَنْ اتَّبَعَ نَبِيَّهُ، اتَّبَعَ رِضوانَهُ، وأنَّ مَن تَخَلّف عنه فقد باء بِسَخَطٍ مِنَ الله.ومعنى (باءَ به)؛ أي: احتمله، ورَجَع به. وقد ذكرنا هذا في سورة البقرة {7}."
  3,163,"قوله تعالى: ﴿هُمْ دَرَجَاتٌ عِنْدَ اللَّهِ﴾ أي: ذَوُو {1} درجات. فحذف المضاف. وحَسُن ذلك ههنا؛ لأن اختلاف أعمالهم، قد صيَّرَهم بمنزلة المختلفي الذوات، كاختلاف مراتب الدرجات؛ لتبعيدهم من استواء الأحوال، فجاء على هذا المَجَاز.والمجاز في موضعه، أحسنُ مِنَ الحقيقة، لِمَا فيه [مِنَ] {2} الإيجاز مِن غيرِ إخلال، ومِنَ المُبالغة التي لا ينوبُ مَنَابها الحقيقة، إذْ {3} قولك: (هو الشمسُ ضياءً)، أبْلَغُ في النفس مِن: (هو كالشمس ضياءً). فكذلك: ﴿هُمْ دَرَجَاتٌ﴾ {4}، أبلغ مِنْ: (هم أهلُ درجاتٍ) {5}.وأصل الدَّرَجَةِ: الرُّتْبَةُ {6}، ومِنْهُ: (الدَّرْجُ)، لأنه يُطوَى رُتْبةً بعد رُتْبةٍ؛ قال: (أدْرَجَني إدْرَاجًا) {7} و (الدَّرَجَانُ) {8}: تَقارُبُ الخَطْوِ؛ كَمِشْيَة الشَّيْخ، والصَّبِيِّ؛ لتقارُبِ الرُّتَبِ {9}.فأما التفسير: فالآيةُ تحتملُ ثلاثةَ أوجه:أحدها: أن يكون المراد بقولهم: دَرَجاتُ المؤمنين والكافرين جميعًا. والمعنى: أن المؤمنين ذَوُو {10} دَرَجةٍ رفيعةٍ، والكافرين ذَوُو درجةٍ {11} خَسِيسَةٍ.وهذا الوجه مروي عن ابن عباسٍ، قال {12}: يعني أنَّ مَن اتَّبَعَ رِضْوانَ الله، ومَنْ بَاءَ بِسَخَطٍ مِنَ الله، مختلِفُو {13} المَنَازِلِ عند الله فَلِمَن اتبع رِضْوانه الكرامةُ والثواب، ولِمَن باء بسخطٍ منه المَهَانةُ والعذاب.وهذا قول الكلبي -أيضًا-، فإنه قال {14}: هم درجاتُ، بعضهم أشدُّ عذابًا مِنْ بعضٍ، وكلٌّ في عذابٍ وهَوَانٍ، وأهل الجَنَّةِ بعضهم أفضلَ من بعض، وكلٌّ {15} في فَضْلٍ وكَرَامَةٍ {16}.الوجه الثاني: أن تكون الآيةُ خاصَّةً في المؤمنين؛ يريد: أنَّ بعضهم أرفع درجة عند الله مِنْ بعض.وهذا قول ابن عباس -في رواية عطاء-، قال {17}: يريد: أصحاب النبي ﷺ، بعضهم أفضل من بعض، وهذا أيضًا اختيارُ الفرّاء، قال {18}: يقول: هم في الفضل مختلفون، بعضهم أرفع من بعض.الوجه الثالث: أن تكون الآية خاصة في الكافرين {19}. وهذا قول الحسن، يقول {20}: بعض أهل النار أشدُّ عذابًا مِنْ بعضٍ؛ ألا تَرَاهُ {21} يقول: ﴿وَلِكُلٍّ دَرَجَاتٌ مِمَّا عَمِلُوا﴾ [الأنعام: 132].قال: وبلغني أن النبي ﷺ قال: (إنَّ منها {22} ضحْضاحًا {23}، وإنَّ منها غَمْرًا {24}، وإني لأرجو أنْ يكون أبو طالب في ضحْضَاحِها) {25}.وقوله تعالى: ﴿وَاللَّهُ بَصِيرٌ بِمَا يَعْمَلُونَ﴾ {26}.فيه تحريضٌ على العمل بطاعته؛ لأن ثوابه لا يضيع؛ إذا عَمِلَه {27} مَنْ يعمل له، وتحذيرٌ مِنَ العملِ بمعصيته؛ لأن جزاءه لا يفوتُ إذا كان عالِمًا به. فهو تهديد ووعيدٌ للكافرين، وتبشيرٌ ووَعْدٌ للمؤمنين."
  3,164,"قوله تعالى: ﴿لَقَدْ مَنَّ اللَّهُ عَلَى الْمُؤْمِنِينَ إِذْ بَعَثَ فِيهِمْ رَسُولًا مِنْ أَنْفُسِهِمْ﴾ الآية.لـ (المَنِّ) {1} -في كلام العرب- مَعَانٍ:أحدها: الذي يسقط من السماء، وقد مرّ ذكره في قوله: ﴿وَأَنْزَلْنَا عَلَيْكُمُ الْمَنَّ وَالسَّلْوَى﴾ [البقرة: 57]. والمَنُّ: الاعتداد بالصنَّيعَةِ {2}، وهو: أنْ تَمُنَّ بما أعطيت، وذلك في قوله: ﴿لَا تُبْطِلُوا صَدَقَاتِكُمْ بِالْمَنِّ﴾ [البقرة: 264].والمَنُّ: القَطْعُ. ومنه قوله: ﴿أَجْرٌ غَيْرُ مَمْنُونٍ﴾ [فصلت: 8]؛ أي: غيرُ مَقْطُوع {3}.والمَنُّ: الإعطاء والإنعام، والإحسان إلى مَنْ لا تَسْتَثِيبه. منه قوله تعالى: ﴿هَذَا عَطَاؤُنَا فَامْنُنْ أَوْ أَمْسِكْ﴾ [ص: 39]، وقوله: ﴿وَلَا تَمْنُنْ تَسْتَكْثِرُ﴾ [المدثر: 6] {4}. و (المَنَّانُ) -في صفة الله- تعالى-؛ معناه: المُعْطِي ابتداءً {5}.فمعنى قوله: ﴿لَقَدْ مَنَّ اللَّهُ عَلَى الْمُؤْمِنِينَ﴾؛ أي: أنعَمَ عليهم، وأحسَنَ إليهم، إذ بَعَثَ فيهم رَسُولًا.واختلفوا في المراد بـ (المؤمنين) في قوله: ﴿عَلَى الْمُؤْمِنِينَ﴾.فقال بعضهم {6}: هذا خاصٌّ في العرب، لأن النبي ﷺ، كانَ مِنَ العَرَبِ، ولم يكُنْ حَيٌّ مِن أحياء العرب، إلّا [و] {7} قد وَلَدَهُ، وله فيهم نَسَبٌ، غير بني تَغْلِب؛ لأنهم كانوا نَصَارَى {8}، فطَهَّرَهُ {9} اللهُ منهم؛ لأنهم ثَبَتوا على النصرانية {10}. وعلى هذا دلّ كلام ابن عباس -في رواية عطاء- {11}، فإنه قال: يعنى المهاجرين والأنصار.وعلى هذا التفسير، معنى قوله: ﴿مِنْ أَنْفُسِهِمْ﴾؛ أي: مِنْ نَسَبِهم. قال ابن عباس {12}: يريد: نَسَبه نَسَبهم، هو مِن وَلَدِ إسماعيل. وبه قال الكلبيُّ {13}.ومعنى (المِنَّة) -على هذا التفسير-: أنه بُعِثَ واحدًا منهم؛ ليكونَ ذلك شَرَفًا لهم {14}. ففيه إنعامٌ مِنْ وجهين:أحدهما: أنه أنقذهم به من النار، وهداهم. والثاني: أنْ جعله منهم. ودليل هذا التأويل، قولُه: ﴿هُوَ الَّذِي بَعَثَ فِي الْأُمِّيِّينَ رَسُولًا مِنْهُمْ﴾ [الجمعة: 2].وقال آخرون {15}: أراد المؤمنين كلَّهم، وعلى هذا معنى قوله: ﴿مِنْ أَنْفُسِهِمْ﴾؛ أي: إنه واحدٌ منهم، يعرفونه، ويعرفون نَسَبَهُ، ليس بِمَلَكٍ، ولا أحد مِن غيرِ بني آدم.ومعنى (المِنّة) -على هذا القول-: أنّه {16} مَنَّ على المؤمنين، بإرساله واحدًا منهم، عُرِفَ أمرُهُ، وخُبِرَ صِدْقُهُ وأمانَتُهُ، فكانَ تَنَاوُلُ {17} الحُجّةِ والبرهانِ {18} سَهْلًا مِنْ قِبَلِهِ {19}.وهذا القول اختيار الزجّاج؛ لأنه قال {20}: لو كانت المنّةُ فيه [أنه] {21} مِنَ العرب، لكانَ {22} العَجَمُ لا مِنَّة عليهم فيهِ، ولكن المِنَّة {23} فيه: أنَّهُ قد خُبِرَ أمْرُه، وشأنُه، وعُلِمَ صدقُهُ، بعد أنْ عَلِمُوا أنه كان واحدًا منهم، وإذا كان واحدًا منهم، كانَ أيْسَرَ عليهم معرِفةُ أحوالِهِ مِنَ الصِّدقِ والأمانة.وعلى هذا التفسير: خُصّ المؤمنون بالذكر، وإنْ كانَ جميعُ المُكَلَّفِينَ في هذا سواء؛ لأن المِنّة على المُؤْمِنِ في هذا أعظمُ منها على الكافر؛ لانتفاع المؤمن ببعثته، فصار كقوله: ﴿إِنَّمَا أَنْتَ مُنْذِرُ مَنْ يَخْشَاهَا﴾ [النازعات: 45]، وهو كان منذرًا لجميع البَشَرِ، ولكنْ لَمَّا كان المؤمنُ يخشَى الساعةَ دون الكافرين، وكان للمؤمن الانتفاعُ بإنذاره، أُضِيفَ إليه.وباقي الآية مفسَّرَةٌ في سورة البقرة {24}.وقوله تعالى: ﴿وَإِنْ كَانُوا مِنْ قَبْلُ لَفِي ضَلَالٍ مُبِينٍ﴾ قيل: معناه: وقد كانوا {25}.وقيل: معناه: وما كانوا مِنْ قَبْلِهِ؛ أي {26}: مِنْ قبل محمد، إلَّا في ضلال مبين. ومثله قوله: ﴿وَإِنْ كُنْتُمْ مِنْ قَبْلِهِ لَمِنَ الضَّالِّينَ﴾ {27} [البقرة: 198]."
  3,165,"قوله تعالى: ﴿أَوَلَمَّا أَصَابَتْكُمْ مُصِيبَةٌ﴾ الآية.الواوُ في ﴿أَوَلَمَّا﴾، لِعَطْفِ جملةٍ على جملة. ودخل أَلِفُ الاستفهام على واو النَّسَقِ {1}؛ لأنَّ له صدر الكلام.قال الزجّاج {2}: ومثله من الكلام قولُ القائل: (تكَلّمَ فلانٌ بكذا وكذا) فيقول مجيبًا له: (أوَ هُوَ مِمَّن يقول ذلك؟).والمعنى: أَوَ حين أصابتكم مُصيبةٌ. ويعنى بالمصيبة: ما أصابتهم يوم أحد.وقوله تعالى: ﴿قَدْ أَصَبْتُمْ مِثْلَيْهَا﴾.هو مِنْ صفة النَّكِرَةِ {3}. ومعناه: قد أصبتم مثليها يوم بدر؛ وذلك [أنَّ] {4} المشركين قتلوا من المسلمين يوم أُحُد سبعين، [وقَتَلَ المسلمونَ منهم يوم بدر، سبعين] {4} وأسروا سبعين. هذا قول أكثرِ المفسرين: ابن عباس {6}، وقتادة {7}، وعكرمة {7}، والربيع {7}، والسُدِّي {10}.وقال بعضهم {11}: أي: أَصبتم في يوم أحد مثلها {12}، وفي يوم بدر مثلها {13}. فقد أصَبتم مِثْلَيْ ما أصابكم، وقتلوا منكم في يوم أُحُد، وقتلتم منهم في يومين. وهذا اختيار الزجّاج {14}.والأول أصح؛ لأن الكفار يوم بدر، نالوا مِنَ المسلمين -أيضًا- {15}؛ بقتل بعضهم {16}.وقوله تعالى: ﴿قُلْتُمْ أَنَّى هَذَا﴾.جواب الاستفهام. ومعناه: قلتم: مِنْ أينَ أصابَنَا هذا القتلُ والهزيمة، وقد تقدم الوَعْدُ بالنُّصْرَةِ، ونحن مسلمون، ورسول الله فينا، والوحي ينزل عليه [فينا] {17}؟.وقوله تعالى: ﴿قُلْ هُوَ مِنْ عِنْدِ أَنْفُسِكُمْ﴾.فيه ثلاثة أوْجُه:أحدهما -وهو قول أكثر أهل التأويل-: أن {18} معناه: أنّكم تركتم ما أمِرْتُم به، وطلبتم الغنيمةَ وتركتم مراكزكم، فَمِنْ قِبَلِكُمْ جاء الشَّرُّ. وهذا قول: الكلبي {19}، وعطاء {20}، واختيار: الفرّاء {21}، والزجّاج {22}.وعلى هذا القول: أضاف إليهم المعصيةَ والهزيمةَ، وإنْ كانت مخلوقة لله -تعالى- مُرَادةً، لأن المعصيةَ تضاف إلى العاصي من حيث المباشرة والكَسْب {23}.والثاني: أن معنى قوله: ﴿مِنْ عِنْدِ أَنْفُسِكُمْ﴾؛ أي: بخرُوجِكُم مِنَ المدينة، وخلافكم على رسولكم؛ وذلك أنه دعاهم إلى التَحَصُّنِ بالمدينة، وكان {24} قد رأى في المنام أنَّ عليه درْعًا حَصِينَةً، فأوَّلَها: المدينة. فقالوا: كنا نَمْتَنِع في الجاهلية، ونحن اليوم أحقُّ بالامتناع، فأكرهوا رسولَ الله على الخروج. وهذا قول: قتادة {25}، والربيع {26}، وابن عباس -في رواية عطاء- {19}؛ لأنه قال: يريد: حيث اختلفوا على النبي ﷺ {28}.الوجه الثالث {29}: ما روي عن علي - رضي الله عنه -، أنه قال: جاء جبريلُ إلى النبي ﷺ، يوم بَدْر، فقال {30}: يا محمدُ: إنَّ الله -تعالى- قد كَرِهَ ما صَنَعَ قومُكَ في أخذهم الفداءَ من الأُسارى، وقد أمرك أن تُخَيِّرَهم بين أن يُقَدِّمُوا الأُسارى فَيَضْرِبُوا أعناقَهم، وبين أن يأخذوا الفداء، على أن يُقْتَلَ منهم عِدَّتُهُم. فَذَكَرَ ذلك رسولُ الله ﷺ لقَومِهِ، فقالوا: يا رسول الله: عشائرُنا وإخواننا، لا؛ بل نأخذ فِدَاهم {31}، فنقوى {32} به على قتال العدوِّ، ويُستشهد منّا بعددهم {33}.فقُتِلَ منهم يوم أحد سبعون رجلًا، عدد {34} أُسارى أهلِ بَدْر. فهو معنى قوله: ﴿قُلْ هُوَ مِنْ عِنْدِ أَنْفُسِكُمْ﴾؛ أي: بأخْذِكُم الفداء، واختياركم القَتْلَ {35}.وقوله تعالى: ﴿إِنَّ اللَّهَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ﴾ يعنى: مِنَ النَّصْرِ؛ مع طاعتكم النبي ﷺ، وترك النصر؛ مع مخالفتكم ما أُمرتم به. وقال ابن عباس {19}: يريد: على نَصرِكُم، وعلى اتِّخاذِ الشهداءِ منكم، وتعجيلِ أوليائهِ إلى الجَنَّةِ، قديرٌ."
  3,166,"قوله تعالى: ﴿وَمَا أَصَابَكُمْ يَوْمَ الْتَقَى الْجَمْعَانِ فَبِإِذْنِ اللَّهِ﴾ دَخَلَتْ الفاءُ في ﴿فَبِإِذْنِ اللَّهِ﴾ {1}؛ لأن خبر (ما) التي بمعنى (الذي)، يشبه جواب الجزاء؛ مِنْ جهة أنه مُعَلَّقٌ {2} بالفعل الذي في الصِّلَةِ، كتعلُّقِهِ بالفعل الذي في الشَّرْط. وقد شرحنا هذه المسألة عند قوله: ﴿وَمَنْ تَطَوَّعَ خَيْرًا فَإِنَّ اللَّهَ شَاكِرٌ عَلِيمٌ﴾ [البقرة: 158].ومعنى قوله: ﴿فَبِإِذْنِ اللَّهِ﴾: قيل: بِعِلْمِ الله {3}. وقال ابن عباس {4}: يريد: فبقضاء الله. وهذا أوْلَى؛ لأن الآية تَسْلِيَةٌ للمؤمنينَ مما أصابهم {5}، ولا تَقَعُ التسليةُ إذا كان واقعًا بِعِلْمِهِ، وإنما تقع؛ إذا كان واقعًا بقضاء الله وقدره، فحينئذٍ يرضون بما قضى عليهم. وفي هذا دليلٌ على أن الكائنات كلَّها تقع على ما قضاه الله في الأزَلِ.وقوله تعالى: ﴿وَلِيَعْلَمَ الْمُؤْمِنِينَ﴾."
  3,167,"﴿وَلِيَعْلَمَ الَّذِينَ نَافَقُوا﴾ أي: لِيظْهرَ إيمان [المؤمنين] {1}، بِثُبُوتِهِمْ {2} على ما نالَهم، ويظْهرَ نفاق المنافقين، بِفَشَلِهم، وقِلَّةِ صبرِهِمْ على ما ينزلُ بهم.وقد مضت نظائرُ لهذه الآية، وذكرنا معنى عِلْمِهِ فيما لا يزال، مع سبقِ عِلْمِهِ بالكائنات فيما لم يزل {3}.وقوله تعالى: ﴿نَافَقُواْ﴾.يقال: (نافق الرجلُ)، فـ (هو منافقٌ): إذا أظهر كلمةَ الإيمانِ، وأضْمَرَ {4} خِلاَفَهَا. و (النِّفَاق): اسمٌ إسْلامِيٌّ {5}.واختلفوا في اشتقاقه: قال أبو عبيد {6}: يقال (نافق اليَرْبُوعُ) {7}، و (نَفَقَ) {8}. وَ (نَافِقاءُ اليربوع): أحَدُ جُحْرَيْهِ. وله جُحْرٌ آخر يقال له: (القاصِعَاء)، فإذا طُلِبَ مِنَ النافقاء، خرج {9} من القاصعاء، وإذا طُلِبَ مِنَ القاصعاء، خَرَجَ {10} مِنَ النافقاء، فقيل للمنافق: (مُنافِقٌ)، لأن يخرجُ مِنَ الإسلامِ مِنْ غير الوجه الذي دَخَلَ فيه؛ وذلك أنه دَخَلَ عَلاَنِيَةً وخرج سِرًّا.وَحَكَى ابنُ الأنباري {11} عن بعضهم: أن المنافقَ مِنَ (النَّفَق)، وهو: السَّرَبُ. ومعناه: أنَّه يَتَستَّرُ بالإسلام، كما يتستر {12} الرجلُ في السَّرَبِ.وقال قوم {13}: هو مأخوذ من (النافقاء)، على غير الوجه الذي ذكره أبو عبيد، وهو: أن [النافقاء] {14} جُحْرٌ يَحْفِرُه اليَّرْبُوعُ مِن داخلِ الأرض، فإذا بَلَغَ إلى جِلْدَةِ {15} الأرض، رَقَّقَ التُّرَابَ، ولم يُتِم الحَفْرَ، حتى إذا رَابَهُ رَيْبٌ، دفَعَ الترابَ بِرَأسِهِ، فَخَرَجَ.فقيل للمنافق: منافقٌ؛ لأنه يُضمر غير ما يُظهر؛ بمنزلة النافقاء، ظاهِرُهُ {16} غير بَيِّن، وباطِنُه محفور في الأرض.قال ابن عباس {17}: ويريد {18} بـ ﴿الَّذِينَ نَافَقُوا﴾: عبد الله بن أُبَي وأصحابه.وقوله تعالى: ﴿وَقِيلَ لَهُمْ تَعَالَوْا قَاتِلُوا فِي سَبِيلِ اللَّهِ﴾.قال السدّيُّ {19}، ومحمدُ بن إسحاق {20}: هذا حين انصرف عبد الله بن أُبَي، قبل أن يبلغ أُحُد، بثلاثمائة مِنْ جُمْلَةِ الأَلْفِ الذين خرج بهم رسولُ الله ﷺ، فقال لهم عبد الله بن عَمْرِو بن حرام -أبو جابر بن عبد الله- {21}: أذَكِّرُكُم اللهَ أنْ تَخْذلوا نبيَّكم وقومَكم، عندما حضر {22} عَدُوُّهُم {23}! ودعاهم إلى القتال في سبيل الله، فذلك قوله: ﴿وَقِيلَ لَهُمْ﴾، يعنى: قولَ عبد الله بن عمرو: تَعَالوا قاتلوا في سبيل الله.وقوله تعالى: ﴿أَوِ ادْفَعُوا﴾.قال السدّي {24}، وابنُ جُرَيْج {25}: ادفعوا عنّا العدُوَّ {26}، بِتَكثير {27} سَوَادِنَا، إنْ لمْ تُقَاتِلُوا معنا. وهذا اختيار الفرّاء، لأنه قال {28}: لأنهم إذا كثروا دفعوا القومَ عنهم بكثرتهم.وقال جماعةٌ من المفسرين {29}: معناه: أو ادفعوا عن أهلكم وبلدكم وحرِيمكم. يعنى: إنْ لم تقاتلوا في سبيل الله، لأجلِ ديِنِهِ {30}، فقاتِلُوا للدَّفْع عن الأهل والمال. يقول: فافعلوا هذا، أو ذلك.وقوله تعالى: ﴿قَالُوا لَوْ نَعْلَمُ قِتَالًا لَاتَّبَعْنَاكُمْ﴾.هذا جواب المنافقيِن لعبد الله بن عَمرو بن حَرَام.قال محمد بن إسحاق {31}: لَمَّا قال لهم عبد الله ما قال، قالوا: لو ونعلم أنكم تقاتلون ما أسلمناكم، ولكِنَّا لا نَرَى أنْ يكون قتال؛ يعنون: لا يكون اليوم قتالٌ؛ ولو نعلم أنه يكون لاتَّبعناكم؛ وأرادوا: أن انصرافنا؛ لِعِلْمِنَا بِأَنَّ {32} الفريقين لا يقْتَتِلان. ونافقوا بهذا القول؛ لأنه كان في قلوبهم خلاف ما تكلموا به.قالَ الله تعالى: ﴿هُمْ لِلْكُفْرِ يَوْمَئِذٍ أَقْرَبُ مِنْهُمْ لِلْإِيمَانِ﴾ يريد: أنَّهم [بما] {33} أظهروا من خذلان المؤمنين عند الحرب، صاروا أقرب إلى الكفر منهم إلى الإيمان؛ وذلك {34} أنهم قبل هذا، كانوا -بظاهر حالهم- أقرب إلى الإيمان، حتى هتكوا أنفسَهم عند مَنْ تخفى عليه حالُهم مِنَ المؤمنين، الذين كانوا يحسنون الظنَّ بهم. وفي هذا دليلٌ على أنَّ مَنْ أتَى بكلمة التوحيد لم يكفر، ولم يُطْلَق القولُ بتكفيره؛ لأن الله تعالى لم يُطْلق القول بتكفيرهم، مع أنهم كانوا كافرين؛ لإظهارهم القولَ بـ (لا إله إلا الله، محمد رسول الله).وقوله تعالى {35}: ﴿يَقُولُونَ بِأَفْوَاهِهِمْ مَا لَيْسَ فِي قُلُوبِهِمْ﴾ قال المفسِّرون {36}: يعنى: بإظهار الإيمانِ وإضمار الكفر.وقال بعضهم {37}: يعنى {38} قولَهم: ﴿لَوْ نَعْلَمُ قِتَالًا لَاتَّبَعْنَاكُمْ﴾، ولو عَلِمُوا ما اتَّبعوهم.وذِكْرُ الأفواه -ههنا- زيادة للتوْكيد {39}، لأن القولَ قد يضاف إلى الإنسان، إذا كَتَبَ أو أشار به.فأعْلَمَ اللهُ أنهم يقولون بألسنتهم؛ لِيُفَرِّقَ بين قول {40} اللسان وقول الكتابة {41}."
  3,168,"قوله تعالى: ﴿الَّذِينَ قَالُوا لِإِخْوَانِهِمْ﴾.في محل ﴿الَّذِينَ﴾ ثلاثةُ أوْجُهٍ:أحدها: النصب على البدل من ﴿الَّذِينَ نَافَقُوا﴾ {1}.و {2} الثاني: الرفع على البدلِ من الضمير في ﴿يَكْتُمُونَ﴾ {3}.الثالث: الرفع على خبر الابتداء، بتقدير: (هم الذين) {4}.والمراد بـ ﴿الَّذِينَ قَالُوا﴾: عبد الله بن أُبَيّ، وأصحابه {5}.وقوله: ﴿لِإِخْوَانِهِمْ﴾، أكثر المفَسِّرينَ {6} على أنَّ المرادَ بِهِ شهداءُ أُحُد، قالوا فيهم: لو أطاعونا في القعود بالمدينة، والانصراف عن رسول الله ﷺ، بعد الخروج، ما قُتِلوا. وعلى هذا؛ المراد بـ (الأخُوَّةِ) -ههُنا-: أخُوَّةُ النَّسَبِ، لا أخوَّةُ الدِّين {7}.أو نقول: يجوز هذا في إطلاق اللفظ، من حيث إنهم كانوا يظهرون المَوَدّةَ والمؤاخَاةَ للمؤمنين.فالمراد {8} بقوله: ﴿قَالُوا لِإِخْوَانِهِمْ﴾ {9}: قالوا في إخوانهم الذين قُتِلوا، لَوْ أطاعونا؛ لأنهم بعد أن قُتِلوا لا يخاطَبُون. ومثل هذا، قولُه: ﴿لَا {10} تَكُونُوا كَالَّذِينَ كَفَرُوا وَقَالُوا لِإِخْوَانِهِمْ إِذَا ضَرَبُوا فِي الْأَرْضِ﴾ [آل عمران: 156] الآية. وقال الكلبي {11}: ﴿الَّذِينَ قَالُوا لِإِخْوَانِهِمْ﴾، {12}؛ يعني: من {13} المنافقين {14}.وعلى هذا التفسير: لا إشكال؛ فإن أصحابَ عبد الله بن أُبَي قالوا لقرنائهم مَنَ المنافقين: لو أطاعنا {15} هؤلاء -الذين خرجوا مع محمد- في القعود؛ ما قُتِلوا.وقوله تعالى: ﴿وَقَعَدُوا﴾ يعني: المنافقين، قعدوا عن الجهاد. والواو للحال {16}.﴿لَوْ أَطَاعُونَا﴾؛ يعنون: شهداء أُحُد. ﴿مَا قتلُوا﴾.فَرَدَّ الله عليهم، وقال: قل لهم يا محمد: ﴿فَادْرَءُوا عَنْ أَنْفُسِكُمُ الْمَوْتَ﴾ إنْ صَدَقْتُم أنَّ الحَذَرَ ينفع مِنَ القَدَرِ.وفي هذا دليل على أن المقتول يُقْتَلُ بِأَجَلِهِ، وأنَّ {17} المُنَافِقِينَ كَذَبُوا في أنَّهم لو قعدوا ما قُتِلُوا.ومعنى (الدَرْء) -في اللغة-: الدَفْعُ. ومنه قوله: ﴿وَيَدْرَأُ عَنْهَا الْعَذَابَ﴾ [النور: 8] أي: يدفع {18} وقوله ﷺ: ""ادرَءُوا الحُدُودَ بالشُّبُهاتِ"" {19}."
  3,169,"قوله تعالى: ﴿وَلَا تَحْسَبَنَّ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللَّهِ أَمْوَاتًا﴾.أكثر أهل التفسير على أن هذه الآية نزلت في شهداء أحد {1}.روى ابن عباس عن النبي ﷺ، قال: ""لَمَّا أُصِيبَ إخْوانكم يومَ أُحُد، جَعَلَ اللهُ أرواحَهم في أجواف طَيْر خُضرٍ، تَرِدُ أنهارَ الجَنَّة، وتأكل مِنْ ثمارِها، وتَسْرَحُ مِنَ الجنة حيث شاءت، وتأوي إلى قناديل من ذهب تحت العرش، فَلَمَّا رأوا طِيبَ مَقِيلِهم {2} ومطعمهم ومشربهم، قالوا: يا ليت قومنا يعلمون مما نحن فيه من النعيم، وما صنع الله عز وجل بنا؛ كي يرغبوا في الجهاد، وقال الله عز وجل: أنا مخْبِرٌ عنكم، ومُبَلغ إخوانكم، فَفَرحوا بذلك واستبشروا؛ فأنزل الله هذه الآية"" {3}.وقوله تعالى: ﴿بَلْ أَحْيَاءٌ﴾، أي: (بل هم أحياءٌ)، فهو رَفعٌ بالابتداء. وخبره: قوله {4}: ﴿عِنْدَ رَبِّهِمْ﴾ {5}. قال أبو إسحاق {6}: ولو قُرِئ: (أحياءً) {7} -بالنصب-، لجاز {8}، على معنى: بل احسبهم أحياءً {9}.قال أبو علي الفارسي {10}: لا يجوز ذلك؛ لأنه أَمْرٌ بالشَّكِّ، ولا يجوز أنْ يَأْمُرَ {11} الله {12} بالشك، ولا يجوز أن نتأول {13} في (الحِسْبَانِ) معنى العِلْم، على أن يكون معنى (احسبهم أحياء): اعلمهم؛ لأن ذلك لم يذهب إليه [أحدٌ من أهل] {14} اللغة {15}واختلفوا في كيفية حياة الشهداء: فالأصح ما ذكرنا عن النبي ﷺ، أن أرواحهم في أجواف طير خضر، وأنهم يُرزقون ويأكلون ويتنعمون.وقال جماعة من أهل العلم {16}: معنى قوله: ﴿أَحْيَاءٌ﴾: أن أرواحهم أُحْضِرَتْ دارَ السَّلام، وأرواح غيرهم لا تشهدها {17} إلى يوم البعث.وقال آخرون {18}: لا تحبسهم أمواتًا في الدين والإيمان؛ بل هم {19} أحياء، كما قال الله تعالى: ﴿أَوَمَنْ كَانَ مَيْتًا فَأَحْيَيْنَاهُ﴾ [الأنعام: 122]. [وهذا الوجه] {20} اختيار أبي إسحاق {21}.وقيل {22}: لأن أرواحهم تركع وتسجد كل ليلة تحت العرش، إلى يوم القيامة، كأرواح الأحياء من المؤمنين الذين باتوا على الوضوء {23}.وقوله تعالى: ﴿عِنْدَ رَبِّهِمْ يُرْزَقُونَ﴾ فيه وجهان: أحدهما: بحيث لا يملك لهم أحدٌ نفعًا ولا ضرًّا، إلّا {24} الله عز وجل.والثاني: هم أحياء عند ربهم؛ أي: في عِلْمِهِ بِعَمَلِهِم، -كذلك- كما تقول: (هذا عند الشافعي كذا)؛ أي: في عِلْمِهِ وقولِه.وقل {25}: معنى ﴿عِنْدَ رَبِّهِمْ﴾: أنهم أحياء في دار كرامته، فمعنى (عند): معنى القرب والإكرام، بحضور دار السلام."
  3,170,"وقوله تعالى: ﴿وَيَسْتَبْشِرُونَ بِالَّذِينَ لَمْ يَلْحَقُوا بِهِمْ مِنْ خَلْفِهِمْ﴾ الاستبشار: السرور بالبِشَارَةِ {1} يُبَشَّرُ بها. وأصل الاستفعال: طَلَبُ الفعل.فالمستَبْشِر بمنزلة الذي طَلَبَ السُّرُورَ فوجده بالبِشَارَةِ {2}.وفي هذا ثلاثة أقوال:أحدها: أنهم يفرحون بإخوانهم الذين فارقوهم وهم أحياء، يقولون: إخواننا يُقْتَلُونَ كما قُتِلْنَا، فَيُصِيبونَ مِنْ كَرَامَةِ الله ما أَصبْنَا. وهذا قول: الحَسَن {3}، وابن جريج {4}، وقتادة {5}، واختيار الفرّاء {6}، فإنَّهُ قال: وَيَسْتَبْشَرُونَ بإخوانهم الذين يرجون لهم الشهادة، للذي {7} رَأَوا مِنْ ثواب الله، فهم يستبشرون بهم.والثاني: يستبشرون بإخوانهم الذين لم يلحقوا بهم في الفضل؛ لأنهم لم يُقْتَلُوا في سبيل الله، إلا أنّ لهم فضلًا عظيمًا بتصديقهم النبي [ﷺ] {8}، وإيمانهم بالله، عَلِمُوا ذلك بإعلام الله إيَّاهم، [أن] {8} أولئك الإخوان الذين خَلَّفُوهم في الدنيا، هم مرحومون عند الله، لا خوف عليهم ولا هم يحزنون. فالشهداء يفرحون بذلك ويستبشرون. وهذا القول، اختيار أبي إسحاق {10}.القول الثالث: ما قاله السُّدِّي {11}: وهو أن الشهيد يؤتى بكتاب فيه ذِكْرُ {12} مَنْ يَقْدَمُ {13} عليه من إخوانه، فَيُقَال: يَقدَمُ {13} عليك فلانٌ يومَ كذا، وفلانٌ يوم كذا، فَيَسْتَبْشِرُ {15} بهم حين يقدمون عليه، كما يستبشر أهلُ الغائب بقدومه في الدنيا.وقوله تعالى: ﴿أَلَّا خَوْفٌ عَلَيْهِمْ﴾ {16} موضع (أنْ): خفض، لأن المعنى: بأنْ لا خوف عليهم. هذا قول الخليل {17}، والكسائي {18}، والزجاج {19}.ويجوز أن يكون نصبًا، على أنه لَمَّا حُذف الجارُّ، نُصبَ بالفعل، كما قال:أمرتك الخيرَ ......... {20}.أي: بالخير. وهذا هو القياس {21}. وقد مضت هذه المسألة فيما تقدم."
  3,171,"قوله تعالى: ﴿يَسْتَبْشِرُونَ بِنِعْمَةٍ مِنَ اللَّهِ وَفَضْلٍ﴾ الآية.يُقرأ: ﴿وَأَنَّ اللَّهَ﴾ بالفتح والكسر {1}. فمن فتحها {2}: جعلها خفضًا، على معنى: (وَبِأَنَّ الله)، فـ (أَنَّ) معطوفة على الباء في ﴿بِنِعْمَةٍ﴾؛ والمعنى: يستبشرون بتوفير نِعْمَةِ الله عليهم، ووصول أجرهم إليهم؛ لأنه إذا لم يُضِعْهُ {3}، وَصَلَ إليهم.ومَنْ {4} كَسَرَها: استأنف، وهو يَؤُولُ إلى معنى القراءةِ الأولى؛ لأنه إذا لم يُضِعْهُ وَصَلَ إليهم. والأول أشد إبانة لهذا المعنى."
  3,172,"قوله تعالى: ﴿الَّذِينَ اسْتَجَابُوا لِلَّهِ وَالرَّسُولِ﴾ الآية.[قال المفسرون {1}: لما انصرف أبو سفيان] {2} وأصحابه من أحد، ندموا على انصرافهم، وتلاوموا فيما بينهم، وقالوا: قتلتموهم حتى إذا [لم يَبْقَ إلا الشَّرِيدَ تركتموهم؟] {2} ارجعوا فاستأصِلُوهم. فَبَلَغَ ذلك رسول الله ﷺ، فأراد أن يرهب العَدُوَّ، ويريهم من نفسه وأصحابه [قُوَّةً؛ فَنَدَبَ] {2} أصحابَهُ للخروج في طلب أبي سفيان، فانتدب عِصَابَةٌ منهم، مع ما {5} بهم من الجرح الذي أصابهم يوم أحد، فخرج رسول الله ﷺ في أصحابه، حتى بلغوا حَمرَاءَ الأسد -وهي مِنَ المدينة على ثمانية أميال {6} -، وألقى {7} الله عز وجل الرعبَ في قلوب المشركين، فانهزموا من غير حَرْبٍ، فذلك قولُه: ﴿الَّذِينَ اسْتَجَابُوا لِلَّهِ وَالرَّسُولِ﴾ {8}.ومحل ﴿الَّذِينَ﴾: خَفْضٌ، على النعت للمؤمنين {9}. قال الزجّاج {10}: والأحسن أن يكون في موضع رَفْعٍ، على الابتداء، و {11} يكون خبر الابتداء {12} ﴿لِلَّذِينَ أَحْسَنُوا﴾ على آخر الآية {13}.و ﴿اسْتَجَابُوا﴾، بمعنى: أجابوا {14}. وقد مَرَّ {15}.وقوله: ﴿لِلَّذِينَ أَحْسَنُوا مِنْهُمْ﴾ أي: بطاعة رسول الله، وإجابته إلى ما دعاهم إليه، واتَّقَوا معصيتَهُ ومخالفته."
  3,173,"قوله تعالى: ﴿الَّذِينَ قَالَ لَهُمُ النَّاسُ﴾ الآية.قال المفسِّرُون: إنَّ أبا سفيان يوم أحد، حين أراد أن ينصرف، قال: يا محمد! موعِدُ ما بيننا وبينك موسمُ بَدْرٍ الصُّغْرَى {1}، لِقابِل، إنْ شِئْتَ.فقال {2} رسول الله ﷺ {3}، (ذلك بيننا [وبينك] {4}، إن شاءَ الله). فَلَمَّا كان العام المقبل، خرج أبو سُفيان في أهل مَكَّةَ، حتى نزل [مَجَنَّة] {5}، ثم ألقى اللهُ الرُّعْبَ في قَلْبِهِ. فَبَدَا له الرجوع، فلقي نُعَيْمَ بنَ مَسْعُود الأشجَعِي {6}، فبعثه أبو سفيان، وقال: ثَبِّطْ {7} عنّا مُحَمَدًا، وخَوِّفْهُ حتى لا {8} يلقانا ببدر الصغرى. ولأن يكونَ الخُلْفُ مِنْ قِبَلِهِم، أحبّ إليّ مِنْ أنْ يكون مِنْ قِبَلي. فأتاهم نعَيْم [وخَوَّفَهم] {4}، فوجدهم يتجهزون لميعاد أبي سفيان، فقال: قد أَتَوْكُم في بلدكم، وصنعوا بكم ما صنعوا، فكيف بكم إذا وَرَدْتُم عليهم في بَلْدَتِهِم، وهم أكثر، وأنتم أقل؟وهذا قول: مجاهد {10}، ومقاتل {11}، وعكرمة {12}، والواقدي {13}، والكلبي {14}.فـ ﴿النَّاسُ﴾ على قول هؤلاء، في قوله: ﴿قَالَ لَهُمُ النَّاسُ﴾: هو نُعَيم ابن مسعود. وهو من العَامِّ الذي أريد به الخاصُّ. وهذا {15} اختيار الفرّاء {16} والزجّاج {17} أن ﴿النَّاسُ﴾ -في هذا الموضع {18} -: واحدٌ. وجاز ذلك؛ لأن هذا القول {19} جاء من قِبَل الناس، فوُضِعَ كلامٌ موْضِعَ كلامٍ؛ للإيجاز {20}؛ وذلك أن نُعَيْمًا {21} ابتدأ بقوله: ﴿إِنَّ النَّاسَ قَدْ جَمَعُوا لَكُمْ﴾، ثم انتشر هذا القولُ؛ وخاضَ فيه الناسُ، وتكلم به كلُّ {22} أَحَدٍ، و-أيضًا- فقد يُطْلَقُ لفظُ (الناس) على الواحد، كما تقول -إذا انتظرت قومًا، فجاء واحدٌ منهم-: (قد جاءَ الناسُ)؛ إمَّا لتفخيمِ الشَأْنِ، وإمَّا لابتداء الإتيان.وقال ابن عباس {23}، ومحمد بن إسحاق {24} -في قوله: ﴿قَالَ لَهُمُ اَلنَّاسُ﴾ -: هم {25} رَكْبٌ مِنْ عَبْد القيس، مَرُّوا بِأبِي سفيان، فَدَسَّهم {26} على المسلمين لِيُجَبِّنُوهم {27} عنه، وَضَمن على ذلك لهم جُعْلًا {28}.وقال السُّدِّي {29}: ﴿النَّاسُ﴾ ههنا هم: المنافقون، قالوا للمسلمين حين تجهزوا للمسير إلى بدر، لميعاد أبي سفيان: قد أتوكم في دياركم، فقاتلوكم {30} وظَفَرِوا {31} فإنْ أتيتموهم في ديارهم لا يَرْجِعُ منكم أَحَدٌ.ومحل ﴿الَّذِينَ﴾: رَفْعٌ أو خفْضٌ، على ما ذكرنا في قوله: ﴿الَّذِينَ اسْتَجَابُوا﴾ [آل عمران: 172] لأن هذا بدل منه.وقوله تعالى: ﴿إِنَّ النَّاسَ قَدْ جَمَعُوا لَكُمْ﴾ يعني: أبا سفيان وأصحابَه.وقوله {32}: ﴿فَزَادَهُمْ إِيمَانًا﴾ أي: زادهم قولُ الناس لهم إيمانًا. أضمر المصدر، وأسند الفعل إليه. ومثله: قوله: ﴿فَلَمَّا جَاءَهُمْ نَذِيرٌ مَا زَادَهُمْ إِلَّا نُفُورًا﴾ [فاطر: 42]؛ أي: ما زادهم {33} مجيءُ النذيرِ. ومثله: قوله: ﴿وَلَمَّا رَأَى الْمُؤْمِنُونَ﴾ إلى قوله: ﴿وَمَا زَادَهُمْ إِلَّا إِيمَانًا﴾ [الأحزاب: 22]؛ أي: ما زادهم رؤيتُهم لهم.ومثله مِنْ إضمار المصدر لِدِلالَةِ الفعلِ عليه كثيرٌ.ومعنى قوله: ﴿إِيمَانًا﴾: قال ابن عباس {34}: أي: تصديقًا ويقينًا.وقال أبو إسحاق {35}: أي: فزادهم ذلك التخويف ثبوتًا في دينهم، وإقامة على نُصْرة نبيهم.﴿وَقَالُوا حَسْبُنَا اللَّهُ﴾ [أي: الذي {36} يكفينا أمرَهم: اللهُ.قال ابن الأنباري {37}: معنى قوله: ﴿حَسْبُنَا اللَّهُ﴾] {4}: كافينا الله، وأنشد:إذا كانت الهيجاءُ وانْشَقَّتِ العَصَا ... فَحَسْبُكَ والضَّحَّاكَ سَيْفٌ مُهَنَّدُ {39}قال: معناه: يكفيك ويكفي الضحاكَ {40}.ومثله {41} قول امرىء القَيْسِ:وحَسْبُكَ مِنْ غِنًى شِبَعٌ ورِيُّ {42}أي: يكفيك الشِبَعُ والرِيُّ.ويقال: (أَحْسَبَني الشيءُ، إحْسابًا): إذا كفاني {43}. فـ (حَسْبُ) مأخوذٌ من (الإحْساب)، وهو: الكِفَايَة. وهو اسمٌ فيه معنى الفعل؛ ألا ترى أنه يُعْطَفُ على المَكْني المتصل به بالنصب، كقوله: (فَحَسْبُكَ والضَّحَّاكَ)، على معنى: يكفيك. ومثله: ﴿إِنَّا مُنَجُّوكَ وَأَهْلَكَ﴾ [العنكبوت: 33].وقوله تعالى: ﴿وَنِعْمَ الْوَكِيلُ﴾ أي: الموكول إليه الأمور. (فَعِيل) بمعنى: (مَفْعُول) {44}.قال ابن الأنباري {45}: والعرب تتكلم بالوكيل، بمعنى: الكَفِيل. فتقول: (هو وكيلٌ بكذا وكذا)؛ يريدون: كفالته به. قال الشاعر:ذَكَرْتُ أبا أرْوَى فَبِتُّ كَأنَنِي ... بِرَدِّ {46} الأُمورِ الماضيات وَكِيلُ {47}أراد: كأنني برد الأمور كفيلُ.وقال الفرّاء {48}: الوكيل: الكافي. قال الله -عز وجل-: ﴿أَلَّا تَتَّخِذُوا مِنْ دُونِي وَكِيلًا﴾ [الإسراء: 2]، أي: كافيا.قال أبو بكر {49}: والذي أختاره: مذهب الفرّاء؛ لأن (نِعْمَ) سبيلها أن يكون الذي بعدها موافقًا للذي قبلها؛ كما تقول: (رازقُنا اللهُ، ونِعْمَ الرّازق). و (خالقُنا الله؛ ونعم الخالق). فيكون أحسنَ مِنْ قولك: (رازقنا الله؛ ونعْمَ الخالق)، وكذلك الآية: يكفينا {50} الله، ونِعْمَ الكافي.وأصلُه في اللغة: ما ذكرنا؛ أنه الموكول إليه، ثم الكافي {51}.والكفيل؛ يجوز أنْ يُسَمَّى: وكَيلاً؛ لأن الوكيل يكفي الأمور والكفيلُ -أيضًا- موكولٌ إليها الأمر."
  3,174,"قوله تعالى: ﴿فَانْقَلَبُوا بِنِعْمَةٍ مِنَ اللَّهِ وَفَضْلٍ﴾ وذلك أنَّ رسولَ الله ﷺ، خرج في أصحابه حتى وافوْا بدرَ الصُّغْرَى، وهي ماءٌ لِبَني كِنَانَة {1}، وكانت موضع سُوقٍ لهم، يجتمعون إليها في كل عام ثمانية أيام. فلم يلْقَ رسولُ الله ﷺ، وأصحابُه، أحدًا من المشركين، ووافقوا السُّوقَ، وكانت معهم نفقاتٌ وتجارات، فباعُوا واشتَرَوْا أُدمًا {2} وزَبِيبًا، وربحوا وأصابوا للدرهم درهمَيْنِ، وانصرفوا إلى المدينة سالمين غانمين {3}؛ فذلك قوله: ﴿فَانْقَلَبُوا﴾، أي: وخرجوا فانقلبوا. فحذف الخروجَ؛ لأن الانقلابَ يَدُلُّ عليه؛ كقوله: ﴿أَنِ اضْرِبْ بِعَصَاكَ الْبَحْرَ فَانْفَلَقَ﴾ [الشعراء: 63]؛ أي: فَضَرَبَه {4} فانْفَلَقَ.وقوله تعالى: ﴿بِنِعْمَةٍ مِنَ اللَّهِ وَفَضْلٍ﴾ قال السُّدِّي {5}، ومجاهد: النِّعمةُ -ههنا-: العافية. والفَضْلُ: التجارة {6}.وقوله تعالى: ﴿لَمْ يَمْسَسْهُمْ سُوءٌ﴾. لم يُصِبْهُم قَتْلٌ وَلاَ جِراحٌ. في قول الجميع.﴿وَاَتَّبَعُواْ رِضْوَانَ اَللَّهِ﴾ في طاعةِ رَسُولِه."
  3,175,"قوله تعالى: ﴿إِنَّمَا ذَلِكُمُ الشَّيْطَانُ﴾ (ذلك) إشارةٌ إلى التخويف؛أي {1}: ذلك التخويفُ الذي كان، فِعْلُ الشيطان؛ لأنه سَوَّلَهُ للمُخَوَّفِين. قاله {2} الزجاج {3}.وعلى هذا {4}؛ الآيةُ مِنْ باب حذف المضاف، على تقدير: إنما ذلكم فِعْلُ الشيطان {5}، أو كَيْدُ الشيطان، أو تخويفُ الشيطان؛ لأنَّه سبب ذلك؛ بالدعاء {6} إليه والإغواء فيه.وقوله تعالى: ﴿يُخَوِّفُ أَوْلِيَاءَهُ﴾ مذهب النحويين في هذا {7}: أنَّ ﴿يُخَوِّفُ﴾ قد حُذِف معه مفعولٌ {8} يقتضيه؛ تقديره: يخوفكم {9}، أو: يخوفُ المؤمنينَ.وقوله تعالى ﴿أَوْلِيَاءَهُ﴾ حُذِف منه الجارُّ، أي: بأوليائهِ، أو: مِن أوليائه، فَلَمَّا حُذِفَ الجار، وَصَلَ الفعلُ إلى المفعول الثاني فَنَصَبَهُ.ومثله -مِن حذفِ المفعول منه-، قولُه: ﴿فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِي الْيَمِّ﴾ [القصص: 7] المعنى: إذا خِفْتِ عليه فِرْعَونَ أو الهلاكَ.والجارُّ المُظْهَرُ في قوله: ﴿فَإِذَا خِفْتِ عَلَيْهِ﴾، بمنزلة المحذوف مِن قوله: ﴿أَوْلِيَاءَهُ﴾.والتقديرُ عندهم: يُخَوِّفُكم بأوليائِهِ.قال الفَرّاءُ {10}: ومِثْلُهُ، قولُهُ: ﴿لِيُنْذِرَ يَوْمَ التَّلَاقِ﴾ [غافر: 15]؛ معناه: لِيُنْذِرَكُمْ بِيَومِ التَّلاقِ. وقوله: ﴿لِيُنْذِرَ بَأْسًا﴾ [الكهف: 2]؛ معناه: لِيُنْذِرَكُمْ بِبِأسٍ.هذا الذي ذَكَرْنَا: مذهب الفرّاء، والزّجاج {11}، وأبي علي {12}.والذي يدلّ عل هذا: قراءةُ أُبَيِّ بن كعب: (يُخوِّفُكُمْ بِأَوْلِيَائِهِ) {13}. وللمفسِّرِينَ في هذه الآية مذهبان، سِوَى ما ذكرنا:أحدهما: أنَّ هذا، على قول القائل: (خَوَّفْتُ زَيْدًا عَمْرًا). ومعنى الآية: يُخَوِّفكم أولياءَهُ. فحذف المفعول الأول؛ كما تقول: (أعطيتُ الأموالَ)؛ أي: أعطيتُ القومَ، أو الناسَ الأموالَ.قال ابن الأنباري {14}: وهذا أشْبَه مِن ادِّعاءِ جارٍّ {15} ما عليه دليلٌ.قال: وقوله: ﴿لِيُنْذِرَ بَأْسًا﴾ [الكهف 20]، معناه: لِيُنْذِرَكمْ بأسًا. وكذلك قوله: ﴿لِيُنْذِرَ يَوْمَ التَّلَاقِ﴾ [غافر: 15] [معناه: لِيُنْذِرَكُم يومَ التَّلاقِ] {16}.والتخويفُ يتعدَّى إلى مفعولين، من غير حرف جَرٍّ؛ تقول {17}: (خافَ زَيْدٌ القِتَالَ)، و (خَوّفْتُهُ القتالَ)؛ كما تقول: (عَرَفَ زيدٌ أخاكَ)، و (عَرَّفْتُهُ أخاكَ).وهذا مذهب ابن عباس {18}، ومجاهد {19}، وقتادة {20}. ويَدلُّ على هذا قراءةُ ابن مسعود: (يخوِّفُكُم أولياءَهُ) {21}.المذهب الثاني: أنَّ معنى الآية: يُخَوَفُ أولياءَهُ [المنافقين {22}؛ ليقعدوا عن قتال المشركين. كأنَّ المعنى: يُخَوِّف أولياءَه] {16} الذين يُطيعونَهُ، وُيؤْثِرُونَ أمرَهُ، وَيعْصون رَبَّهم، ويُقِيمونَ على خِلافِهِ. فأمَّا أولياءُ اللهِ، فَإنَّهُمْ لا يَخَافُونَهُ إذا خَوَّفَهم، ولا يَنْقادُون لِمُرَادهِ منهم. وهذا قولُ: الحَسَن {24}، والسدِّي {25}، وابنِ عباس في رواية عطاء {26}.فالمذهب الأول: فيه محذوفان، والثاني: فيه محذوفٌ واحد، والثالث: لا حَذْفَ فيه.ومعنى (الأوْلِيَاء) -في القولين الأوَّلَيْنِ-: المشركون والكفار.وقوله تعالى: ﴿فَلَا تَخَافُوهُمْ﴾ الكناية {27} تعود إلى الأولياء في القولين الأوَّلَيْنِ. وفي الثالث: تعود إلى المشركين؛ وهم قد ذُكِروا في قوله: ﴿إِنَّ النَّاسَ قَدْ جَمَعُوا لَكُمْ﴾ [آل عمران: 173].وقوله تعالى: ﴿وَخَافُونِ إِنْ كُنْتُمْ مُؤْمِنِينَ﴾ أي: خافونِ {28} في تركِ أمري؛ إنْ كنتم مصدِّقِينَ بوعدي، وقد أعلمتكم أنِّي أنصركم عليهم {29}، فقد سقط عنكم {30} الخوف."
  3,176,"قوله تعالى: ﴿وَلَا يَحْزُنْكَ الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ﴾.أكثر القُرّاءِ على ﴿يَحْزُنْكَ﴾ -مِنَ الثلاثي-. وقرأ نافع: ﴿يَحْزُنْكَ﴾ -بضمِّ الياء- {1}.واختلف أهل اللغة في هذا: فقال قومٌ: (حَزَنَ، وأحْزَنَ)، بمعنى واحد {2}.قال الزّجاج -في باب الوفاق- {3}: (حزَنَني الأمْرُ، وأَحْزَنَنِي).و (أمرٌ حازِنٌ ومُحزِنٌ).وقال ابن المُظَفَّر {4}: تقول {5}: (حَزَنَنِي)، و (هو يَحزُنُني حُزْنًا)، (فأَنَا مَحْزُونٌ)، و (هو حازِنٌ) {6} و (أحْزَنَنِي، فأنا مَحْزون) {7}، و (هو مُحزِنٌ).وحكى -أيضًا- سيبويه {8} -عن بعض العرب-: أنهم يقولون: (أحْزَنْت الرجلَ): إذا جعلته حزينًا.وحكى أبو زيد -في كتاب (خُبَأة) {9}: (أحْزَنَنِي الأمرُ إحزانًا)، و (هو يُحْزِنُنِي) بضم الياء.وقال الخليل {10}: إذا أردت تغيير {11} (حَزِنَ)، قلت: (أحزنته). فهذا قولُ مَن سَوَّى بينهما، وجعلهما لُغَتَيْن. وهو حُجَّةٌ لِقِرَاءةِ نافع.وروى أبو عُبَيد، عن أبي زيد، قال {12}: لا يقولون: (حَزَنه الأمرُ). ويقولون: (يَحْزُنُه). فإذا صاروا {13} على (8) الماضي، قالوا: [أحْزَنَهُ] {14}.يستعمل الماضي مِنَ الرُّبَاعي، والمضارع مِنَ الثلاثي. وهذا شاذٌّ؛ لأنه استعمل (أحزَنَ)، وأهمل (يُحْزِن)، واستعمل (يَحْزُنُ)، وأهمل (حَزَنَ). فمن قرأ بقراءة العامَّة، فَحُجَّته: أنه أشهر اللغَتَيْنِ، وأكثرهما استعمالًا.قال الأزهري {15}: اللغة الجَيِّدة: (حَزَنَهُ، يَحْزُنُه)، على ما قرأ به أكثر القرّاء.وحجّة نافع: قولُ مَن زَعم أنهما لُغَتَان، وما حكاه سيبويه {16} عن الخليل، أنَّك حيث قلت: (حَزَنْتُه)، لم تُرِدْ أن تقول: [جعلتُه حزينًا، كما أنك حيث قلت: (أدْخَلته)، أردت: (جعلته داخلًا). ولكنك أردت أن تقول:] {17} جعلت فيه حُزْنًا.كما تقول: (كحَلْتُهُ)؛ أي: جعلت فيه كُحْلًا، و (دَهَنْته)؛ جعلت {18} في دُهنًا، و (فَتَنْتُه): جعلت فيه فِتْنة. فجئت بـ (فَعَلْتُهُ) على حَدِّهِ {19}، ولم {20} تُرِد بـ (فَعَلْتُهُ) -ههنا- تغيير قوله: (حَزِنَ)، و (فَتِنَ) {21}. ولو أردت ذلك، لقلت: (أحزنته)، و (أفتنته).وهذا الذي حكاهُ، حُجَّةُ نافع؛ لأنه أرادَ تغيير (حَزِنَ)، فنقله بالهمز.قال الخليل {22}: ومثله: (شَتِرَ {23} الرجلُ)، و (شَتَرْتُ عَيْنَه). فإذا أردت تغيير (شَتِرَ الرجلُ)، قلت: (أشْتَرْتُ، كما تقول: (فَزعَ) {24} [و] {25} (أفزَعْتُهُ).وأراد بـ ﴿الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ﴾: المنافقين، وقُرَيْظَة والنّضير -في قول ابن عباس- {26}.ومعنى مسارعتهم في الكفر: مُظَاهَرَتُهُم {27} الكفَّارَ على محمد ﷺ. وتأويله: يُسارِعُون في نُصْرةِ الكفر. وقال الضَّحَّاكُ {28}: يعني: كفّار قريش.فإذا قيل: معنى قوله: ﴿وَلَا يَحْزُنْكَ الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ﴾: لا تحزن لِكفرِهم. والحزن على كفر الكافر، ومعصيةِ العاصي، طاعةٌ، فكيف نهى عنهُ؟.قيل: إنما نهى عنه النبيَّ ﷺ، لأنه كان يُفرطُ وُيسْرِفُ في الحُزْنِ على كُفْر قومِهِ، حتى كان يؤدّي ذلك إلى أن يَضُرّ {29} به، فنُهِي {30} [عن] {31} الإسراف فيه؛ ألا ترى إلى قوله -عز وجل-: ﴿فَلَا تَذْهَبْ نَفْسُكَ عَلَيْهِمْ حَسَرَاتٍ﴾ [فاطر: 8].وقوله تعالى: ﴿إِنَّهُمْ لَنْ يَضُرُّوا اللَّهَ شَيْئًا﴾ يعنى: أنَّ عائِدَ الوَبَالِ في ذلك عليهم، لا على غيرهم. وقال عطاء {32}: يريد: لن يضروا أولياءَ اللهِ شيئا.وقوله تعالى: ﴿يُرِيدُ اللَّهُ أَلَّا يَجْعَلَ لَهُمْ حَظًّا فِي الْآخِرَةِ﴾ يعنى: نصيبًا في المجنة. وفي هذا رَدٌّ على القَدَرِيّة، وبيان أنَ الخيرَ والشرَّ بإرادة الله -جلَّ وعزَّ- {33}."
  3,177,""
  3,178,"وقوله تعالى: ﴿وَلَا يَحْسَبَنَّ الَّذِينَ كَفَرُوا أَنَّمَا نُمْلِي لَهُمْ﴾ الآية.﴿الَّذِينَ﴾ {1} -في قراءة من قرأ: ﴿يَحْسَبَنَّ﴾ بالياء {2} -، رَفْعٌ؛ بأنه فاعل (يَحْسَبُ) {3}.وإذا كان ﴿الَّذِينَ﴾ فاعلًا؛ اقتضى (يَحْسَبُ) مفعولين؛ لأنّه يتعدى إلى مفعولين، أو إلى مفعولٍ يَسُدُّ مَسَدَّ مفعولين، وذلك إذا جَرَى - في صلة ما يتعدى إليه الحِسْبانُ-، ذِكْرُ الحديثِ والمُحَدَّث عنه، نحو: (حَسِبْتُ أن زيدًا منطلقٌ)، و (حَسِبتُ أنْ يقومَ عمرٌو) {4}.فجرى {5} فيما تَعَدَّى إليه (حَسِبْتُ) الحديثُ، وهو: الانطلاقُ والقيامُ. والمُحَدَّثُ عنه، وهو: زيدٌ أو عَمْرُو. فقام المفعولُ الواحدُ مقامَ المفعولين. وفقوله: ﴿أَنَّمَا نُمْلِي لَهُمْ خَيْرٌ لِأَنْفُسِهِمْ﴾ قد سَدَّ مسَدَّ المفعولين اللَّذَيْن يقتضيهما ﴿يَحْسَبَنَّ﴾.وقرأ حمزة: ﴿ولا تَحْسَبَنَّ الذين كفروا﴾ بالتاء. و ﴿الَّذِينَ كَفَرُوا﴾ -في هذه القراءة- في موضع نَصْبٍ، بأنّه المفعول الأول.واختلفوا في وجه هذه القراءة:فقال الفرّاء {6}: هو على التكرير. المعنى: ولا تَحْسَبَنَّ يا محمدُ الذين كفروا، ولا تَحْسَبَنَّ أنَمَا نمْلِي لهم خيرٌ {7} لأنفسهم. قال: وهذا كقوله -تعالى-: ﴿فَهَلْ يَنْظُرُونَ إِلَّا السَّاعَةَ أَنْ تَأْتِيَهُمْ بَغْتَةً﴾ {8} [محمد: 18]؛ يعنى: فهل ينظرون إلا الساعة، هل يَنْظُرُونَ {9} إلا أنْ تأتيهم بَغْتةً؟.وقال الزّجاج {10}: هذه القراءة عندي، يجوز على البدل من ﴿الَّذِينَ﴾؛ المعنى: ولا تَحسَبَنَّ ﴿أَنَّمَا نُمْلِي لَهُمْ خَيْرٌ لِأَنْفُسِهِمْ﴾ {11}. وأنشد:فَمَا كانَ قَيْسٌ هُلْكُهُ هُلْكَ واحدٍ {12}جعل (هُلكُهُ) بدلًا من (قَيس)؛ المعنى: فما كان هُلْكَ قيسٍ هُلكَ واحدٍ.ومثلُه -مما جُعِلَ (أنَّ) مع الفعل بدلًا من المفعول-، قولُه: ﴿وَمَا أَنْسَانِيهُ إِلَّا الشَّيْطَانُ أَنْ أَذْكُرَهُ﴾ {13} [الكهف: 63]، وقوله -تعالى-: ﴿وَإِذْ يَعِدُكُمُ اللَّهُ إِحْدَى الطَّائِفَتَيْنِ أَنَّهَا لَكُمْ﴾ {14} [الأنفال: 7]، بَدَلًا مِنْ إحْدَى الطائفتين.قال أبو علي الفارسي {15}: هذه القراءة على تقدير البدل، لا يصح إلا بنصب (خيْر) {16}؛ لأن (أنّ) تصير بدلًا من ﴿الَّذِينَ كَفَرُوا﴾ وإذا صار بدلًا منه، فكأنه قال: لا تَحْسَبَنَّ إملاءَ الذين كفروا خيرًا. فيلزم انتصاب (خير) {16} من حيثُ كان المفعول الثاني لـ (حَسِبْتُ).ألا ترى أنه أبدل {18} ﴿أَنَّمَا﴾ كما {19} أبدل الشاعرُ (هلكُهُ) من (قيس)، فصار التقدير: وما كان هُلْك قَيْسٍ هُلْكَ واحدٍ، انتصب (هلكَ واحدٍ) {20} على أنه خبرُ (كان)، ولو {21} لم يبدل (هلكُه) من (قيس)؛ لارتفع بالابتداء، وصار (هُلْكُ واحدٍ) خَبَرَه. والجملة في موضع نصب على خبر (كان). كما أَنه لو لم يُبْدِلْ (أنّ) من ﴿الَّذِينَ كَفَرُوا﴾ لكسرها ولم يَفْتَحْها، ولو كسرها لصارت (أنّ) واسمها وخبرها، في موضع نصب؛ لأنه مفعول ثانٍ لـ ﴿تَحْسَبَنَّ﴾.وكما انتصب (هُلْكَ واحد) في البيت، لَمّا أبدل الأول مِنْ (قيس) بأنه خَبَرُ (كان)؛ كذلك ينتصبُ ﴿خيرٌ لهم﴾ في الآية، إذا أبدل الإملاء من ﴿الَّذِينَ كَفَرُوا﴾ بأنه مفعول ثانٍ لـ ﴿تَحْسَبَنَّ﴾.فإذًا، قد جاء أنه لا يجوز أن يُقرأ ﴿تَحْسَبَنَّ﴾ بالتاء، إلّا أن يُكسر (إنَّ) في ﴿أَنَّمَا نُمْلِي﴾، أو يُنصب ﴿خَيْرٌ﴾ {22}، مع فتح ﴿أَنَّمَا﴾، فيقرأ: (أنَّمَا نُمْلي لهم خيرًا لأنفسهم).ولم يُرْوَ عن حمزةَ كسْرُ (أنّ)، ولا نَصْبُ (خَيْرٌ)، فلا تصح القراءة بالتاء، على ما قرأ به حمزةُ، عند أبي عليّ {23}.قال ابن عباس {24}: أراد بـ ﴿الَّذِينَ كَفَرُوا﴾: المنافقين، وقُرَيْظَةَ والنَّضِير. وقال مقاتل {25}: يعنى: مشركي مكة.وقوله: ﴿أَنَّمَا﴾، (ما) تحتمل وجهين:أحدهما: أن يَكون بمعنى (الذي) {26}، فيكون التقدير: لا يحسبن الذين كفروا أن الذي نمليه خيرٌ لأنفسهم، وحَذَفَ (الهاء) مِنْ ﴿نُمْلِي﴾؛ لأنه يجوز حذفُ الهاء مِنْ صِلَةِ (الذي)؛ كقولك: (الذي رأيتُ زيدٌ).والآخر: أن يَكون (ما) بمنزلة الإملاء، فيكون مصدرًا، وإذا كان مصدرًا {27}، لم تقتض راجعًا إليها {28}.وقوله تعالى: ﴿نُمْلِي لَهُمْ﴾.معنى ﴿نُمْلِي﴾ -في اللغة-: نُطِيل، ونُؤَخِّر. والإملاء: الإمهال والتأخير. واشتقاقه {29} من (المِلْوَة)، وهي: المُدَّة من الزمان. يقال: (مِلْوَةٌ مِنَ الدَّهْرِ)، و (مُلْوَةٌ، ومَلْوَةٌ، ومِلاَوَةٌ {30}، ومَلاَوَةٌ {31}، ومُلاَوَةٌ)، بمعنًى {32}.قال العَجَّاج:وقد أُرَانِي لِلغَوَانِي {33} مِصْيَدا ... مُلاوَةً كأنَّ فَوْقِي جَلَدا {34} ومنه قولُ العَرَبِ: (الْبَسْ جَدِيدا، وتَمَلَّ حبيبًا) {35}؛ أي: لِتطل أيَّامك معه. وقال مُتَمِّم {36}:بِودَّيَ أَنّي لو تَمَلَّيْتُ عُمْرَهُ ... بِمَالِيَ مِنْ مالٍ طَريفٍ وتَالدِ {37} وقال الأصمعي {38}: (أمْلَى عليه الزمانُ) {39}؛ أي: طال عليه. و (أملَى له)؛ أي: طَوَّل له، وأمهله.قال أبو عبيدة: ومنه: (المَلاَ) {40}: الأرض الواسعة الطويلة {41}.قال ابن عباس {42} -في قوله: ﴿أَنَّمَا نُمْلِي لَهُمْ﴾ -: يريد {43}: تماديهم في معاصي الله.وقوله تعالى: ﴿إِنَّمَا نُمْلِي لَهُمْ لِيَزْدَادُوا إِثْمًا﴾ قال ابن الأنباري {42}: قال جماعة من أهل العلم {45}: أنزل الله عز وجل هذه الآية في قوم يعاندون الحق، سَبَقَ في علمه أنهم لا يؤمنون، فقال: ﴿إِنَّمَا نُمْلِي لَهُمْ لِيَزْدَادُوا إِثْمًا﴾ بمعاندتهم الحقَّ، وخِلاَفِهِم الرسولَ.وقد قال رسول الله ﷺ: (إذا رأيتَ اللهَ يُعْطِي على المعاصي، فإنَّ ذلك استدراجٌ مِنَ اللهِ لِخَلْقِهِ)، ثم تلا هذه الآية {46}.ونحو هذا، قال الزّجاج {47}: إن هؤلاء قومٌ، أعلَمَ اللهُ نبيَّه أنهم لا يؤمنون أبدًا، وأن بقاءهم يزيدهم كفرًا وإثما.والآية حجّة ظاهرة على القَدَريّة {48}؛ حيث أخبر الله -تعالى-، أنه يطيل أعمارَ قومٍ وُيمْهِلُهُم؛ لِيَزدادوا غَيًّا وكُفْرا.والقَدَرِيّة، تأولوا الآية على وجهين:أحدهما: على التقديم والتأخير؛ فقالوا: التقدير: (ولا يحْسَبَنَّ الذين كفروا إنما نُملي لهم لِيَزدادوا إثما؛ إنَّما نُملي لهم خيرٌ لأنفسهم). وهذا {49} إنما كان يُحتمل لو قُرِئ بِكَسْرِ ﴿أَنَّمَا نُمْلِي لَهُمْ خَيْرٌ لِأَنْفُسِهِمْ﴾، ﴿إِنَّمَا نُمْلِي لَهُمْ لِيَزْدَادُوا﴾. ولم يقرأ به أحدٌ يُعرَف. ولا يجوز حملُ الآية على وجهٍ لا يجوز أن يُقرأ به {50}.والوجه الثاني: قالوا {51}: معنى قوله: ﴿إِنَّمَا نُمْلِي لَهُمْ لِيَزْدَادُوا إِثْمًا﴾: إنما نُمْلي لهم، على أنَّ عاقبةَ أمْرِهم ازديادُ الإثم. وهذه لام العاقبة؛ كقوله: ﴿فَالْتَقَطَهُ آلُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّا وَحَزَنًا﴾ [القصص: 8]. وهذا {52} الذي قالوه، خِلافُ ما ذَكَرَهُ المفسرون وأهل العلم، وعُدُولٌ عن ظاهرِ الخِطَاب، فلا يُقْبَلُ.على أن لام العاقبة يشَاكِل ما قبله؛ كقوله: ﴿فَالْتَقَطَهُ آلُ فِرْعَوْنَ﴾، الآية، وهم ما التقطُوهُ لِهذا؛ ولكنْ كان الالتقاطُ سبَبَ كونِهِ عَدُوًّا لهم، كذلك في الآية، يجب أنْ يكونَ إمْلاءُ اللهِ إيَّاهم، سَبَبَ ازديادهم الإثم {53}، وهو ما نقول: إن الله -تعالى- يُملِي لهم، لِيَزدادوا إثمًا."
  3,179,"قوله تعالى: ﴿مَا كَانَ اللَّهُ لِيَذَرَ الْمُؤْمِنِينَ عَلَى مَا أَنْتُمْ عَلَيْهِ﴾ الآية.اختلفوا في سبب نزول هذه الآية:فقال الكَلْبيُّ {1}: قال المشركون للنبي ﷺ: ما بَالُكَ تَزْعُمُ أن الرَّجلَ مِنْ أهلِ النار، حتى يَدْخُلَ في دِينِكَ، فإذا انتقل إلى دينك، ادَّعَيْتَ أنه من أهل الجَنَّةِ، فينبغي أنْ تُعَرِّفَنَا الذي يَنتَقِلُ، قبل أن ينتَقِلَ.فأنزل الله -تعالى- مجيبًا لهم-: ﴿مَا كَانَ اللَّهُ لِيَذَرَ الْمُؤْمِنِينَ عَلَى مَا أَنْتُمْ عَلَيْهِ﴾ أي: ما كانَ اللهُ لِيَدَعَ المؤمِنَ {2}، على ما عليه الكافرُ {3}. وأَعْلَمَ أنَّ حُكْمَ مَنْ كَفَر، أن يقال: أنه مِن أهل النار، ومَنْ آمَنَ: فهو من أهل الجَنَّة.ومعنى: ﴿حَتَّى يَمِيزَ الْخَبِيثَ مِنَ الطَّيِّبِ﴾ -على هذا التفسير-: حتى يُفَرِّقَ بين المؤمن والكافر؛ بالحُكْمِ لِلْمُؤْمِنِ بالجَنَّةِ، ولِلكافر بالنار.والخِطاب في قوله: ﴿أَنتُمْ﴾ -على هذا الوجْهِ-، للمشركين.وقوله تعالى: ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ عَلَى الْغَيْبِ﴾ أي {4}: وما كان اللهُ لِيُخْبِركم بإسلامِ مَنْ يُسْلِم قبل أن يُسْلِم؛ فَيَدُلكم على غَيْبِهِ؛ وذلك أنهم سألوا أن يُعرَّفوا ذلك.وقوله تعالى: ﴿وَلَكِنَّ اللَّهَ يَجْتَبِي مِنْ رُسُلِهِ مَنْ يَشَاءُ﴾: أي: يختارُ مِنَ الرُّسُل مَن يشاء بالغيب، فيُطْلِعُه على بعض عِلْمِ الغيب؛ كقوله: ﴿عَالِمُ الْغَيْبِ فَلَا يُظْهِرُ عَلَى غَيْبِهِ أَحَدًا (26) إِلَّا مَنِ ارْتَضَى مِنْ رَسُولٍ﴾ [الجن:26 - 27]، الآية.قال الزّجاج {5}: وإنما يُطْلِعُ الرسلَ على الغيب؛ لإقامة البرهان في أنهم رُسُلٌ، وأنَ ما أتَوا به مِن عند الله.ومعنى قوله: ﴿وَلَكِنَّ اللَّهَ يَجْتَبِي مِنْ رُسُلِهِ مَنْ يَشَاءُ﴾؛ أي: بالغيب. فَحذف ذلك للعلم به؛ وذلك لاستثناء الرسولِ مِمَّن لا يُطلَعُ على الغيب.وهذا {6} قول جماعةٍ مِنَ المفسرين {7}، واختيار الفرّاء {8} والزّجاج {9}. والآية مطَّرِدَة على هذا التفسير.وقال مجاهد {10}، ومحمد بن إسحاق {11}: نزلت الآية في المنافقين، وتمييزهم عن المؤمنين، و-على هذا التفسير- الخطابُ للمؤمنين في قوله: ﴿أَنْتُمْ﴾، رَجَعَ من الخَبَر عن المؤمنين إلى مخاطبتهم.ومعنى الآية: ما كان الله ليذركم يا معشر المؤمنين، على ما أنتم عليه مِن التباسِ المنافقِ بالمؤمنِ، والمؤمن بالمنافق، حتى يُمَيِّزَ الخبيثَ من الطَّيِّب، أي: المنافقَ مِنَ المُؤمِنِ.قال مجاهد {10}: فَمَيّزَ الله المؤمنين يومَ أحد مِنَ المنافقين؛ حيث أظهروا النفاقَ، وتَخَلَّوا عن رسول الله ﷺ.﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ عَلَى الْغَيْبِ﴾ فتعرفوا المنافقَ من المؤمنِ قبل التمييز، ولكنَّ اللهَ يختار بمعرفة {13} ذلك مَنْ يَشَاء مِنَ الرُّسُلِ.قال ابن عباس {14}: يريد: أنت يا محمد ممن اصطفيتُهُ وأطلعته على هذا الغيب.وهذا معنى قول السُّدِّي في هذه الآية، فإنه قال في سبب نزولهما ما يُشاكِل هذا التفسير، وهو أنه قال: قال رسول الله ﷺ: ""أُعْلِمْتُ مَنْ يُؤْمِنُ بي وَمَنْ لا يُؤمِنُ"" فَبَلَغَ ذلك المنافقينَ، فاستهزؤوا، وقالوا: كيف، ونحن معه لا يعرفنا؟! فأنزل الله هذه الآية {15}.. . . . . . . . . . . . . . . . . . . . . . . .وهذا {16} وجهان من التفسير لهذه الآية.وقيل فيه وجه ثالث من التفسير، وهو: إن الخطاب للمشركين والمنافقين واليهود {17} في قوله: ﴿أَنْتُمْ﴾ {18}؛ والمراد بـ (المؤمنين) {19} في قوله: ﴿لِيَذَرَ الْمُؤْمِنِينَ﴾: الذين هم {20} في أصلاب الرجال من المشركين، وأرحام النساء من المشركات، ممن يؤمنون.ومعنى الآية: ما كان الله لِيَدَعَ أولادَكُمْ الذين جرى لهم الحكمُ بالإيمان، على ما أنتم عليه من الشِّرْك، حتى يُفَرِّق بينكم وبين مَن في أصلابكم، وأرحام نسائِكم من المؤمنين.وهذا قول الضّحاك {21}، وابن عباس في رواية عطاء {22}.وقوله: ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ عَلَى الْغَيْبِ﴾، لا يتعلق بأوَّلِ الآية في المعنى -على هذا التفسير-، ولكن معناه: إنه أَخْبَرَ ابتداءً، أنه لا يُطلِعُ أحدًا على عِلْمِ الغيب؛ لأنه لا يعلمه أحدٌ غيرُه، ولكن يجتبي مِن رُسُلِهِ مَنْ يَشاء، فَيُطْلَعَ على بعض عِلْمِ الغَيْب.وقيل في سبب نزول قوله: ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ عَلَى الْغَيْبِ﴾: إنّ المشركين أنكروا نُبُوَّةَ محمد ﷺ، وقالوا: ما بالنا نحن لا نكون أنبياء، فإنَّا أكثرُ أموالًا وأولادًا؟ فأنزل الله: ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ عَلَى الْغَيْبِ﴾؛ أي: لم يكن ليوحي إليكم فيجعلكم بمنزلة الرُّسُل، بظنِّكُم عند أنفسكم أنكم مستحقون ذاك {23}، بل يُنَبِّئ {24} مَنْ يَراهُ أهلًا للخصوصية والتشريف.وهذا معنى قولِ أبي إسحاق {25}، وابن الأنباري {14}. قال ابن الأنباري: وأوَّلُ الآية يدل على هذا، ويمكن حمله على هذا التفسير؛ وهو: أنهم أنكروا نُبُوَّةَ محمد، وما يدعوا إليه مِنْ تَرْكِ دينِ الآباءِ والأجداد. فأعلم الله -تعالى- أنه لم يكن لِيَدَعَ المؤمنين على ما عليه الكفارُ مِنَ العَمَى والحَيْرة، حتى يَنْتاشَهم {27} ويستنقذهم من المهالك، بإرساله محمدًا ﷺ، وإعطائه {28} إيَّاه مِنَ الدَّلائِلِ ما يكَون عَلَما لِصِدْقِهِ، وسببًا لانقياد {29}، [الناس] {30} إلى متابعته.فهذه أربعة أوجُهٍ مِنَ التفسير، في هذه الآية.فقوله: ﴿مَا كَانَ اللَّهُ لِيَذَرَ﴾، هذه اللام يُسمِّيها بعضُ أهل النحو، لامَ الجَحْد؛ كما تقول: (ما كنت لأفعل ذلك) {31}. وهي في تأويل (كي)؛ ولذلك نَصَبَتْ ما بعدها.وذكرنا الكلام في (يَذَر) عند قوله: ﴿وَيَذَرُونَ أَزْوَاجًا﴾ {32}.قوله تعالى: ﴿حَتَّى يَمِيزَ﴾.فيه {33} قراءتان: التشديد والتخفيف {34}. وهما لغتان. يقال: (مِزْتُ الشيءَ بَعْضَهُ عن بَعْض)، فأنا (أمِيزُهُ مَيْزًا)، و (مَيّزْتُهُ تمييزًا) {35}. ومنه الحديث: ""مَن مَازَ أذًى عن طريق، فهو له صدقة"" {36}.وقال الشاعر:تنفِي رُضَاضَ الحَصَا مَنَاسِمُها ... كَمَا يَمِيزَ الزُّيُوفَ مُنْتَقِدُ {37}و (التمييز) {38} ليس بمنقول بالتشديد عن (المَيْز)؛ كـ (التَّغْرِيم) مِنَ (الغرْم)؛ لأنه لو كان منقولًا لَتَعدَّى إلى مفعولين؛ كـ (التغريم)؛ فإنه [يقال] {39}: غَرَّمْتُ زيدًا مالًا. و (التمييز) لا يتعدّى إلى مفعولين إلّا بحرف جرٍّ؛ نحو قولك: (مَيَّزت مَتَاعَكَ بعضَه من بعض).ومثل {40} (مَيَّز) -في أنّ التضعيف فيه ليس للنقل والتعدّي- قولُهم: (عَوَّض)، فهو بمعنى (عاض). ولو كان التضعيف فيه للنقل؛ لَتَعدّى إلى ثلاثة مَفْعولِينَ {41}؛ لأن (عاض) يَتَعدَّى إلى مَفْعولَيْنِ، فـ (عَوّضَ) و (عاض) لُغَتَان.وحجّة مَن قَرَأ بالتخفيف: أنَّه يَصْلُح للقليل والكثير؛ لأن (المَيْز) كـ (التميِيز)، سَوَاء، وهو -مع ذلك- خفيف في اللفظ. وإذا اجتمعت خِفَّةُ اللفظ مع استيعاب المعنى، كان المصير إليه أَوْلى.وحكى أبو زيد، عن أبي عمرٍو، أنه كان يقول {42}:التشديد للكثرة، فأما واحدٌ مِن واحدٍ فـ (يَمِيز) -بالتخفيف-. والله -تعالى- يقول: ﴿حَتَّى يَمِيزَ الْخَبِيثَ مِنَ الطَّيِّبِ﴾، فَذَكَر شيئين. و-هذا- كما قال بعضهم {43} في (الفَرْق) و (التَّفرِيق) {44}.وحجّة من قرأ بالتشديد: أن التشديد للتكثير والمبالغة، ويِكثر المؤمنون والمنافقون. فالتمييز -ههنا- أَوْلى، والله -تعالى- ذَكَرَ الجِنْسَيْنِ بلفظ ﴿الْخَبِيثَ﴾ و ﴿الطَّيِّبِ﴾ وهما للجِنْس؛ فالمراد بهما: جميع المؤمنين والمنافقين، لا اثنان منهما. وقد قال الله -تعالى-: ﴿تَكَادُ تَمَيَّزُ مِنَ الْغَيْظِ﴾ [الملك: 8]. وهذا مُطَاوع [(التَّميِيِز). والذي يدل على {45} أن التخفيف أولى، قولُه: ﴿وَامْتَازُوا الْيَوْمَ﴾ [يس: 59]، وهو مُطاوع] {46} (المَيْز).وقوله تعالى: ﴿لِيُطْلِعَكُمْ﴾.الإطْلاعُ: أن تُطلِعَ إنسانًا على أمرٍ، لم يكن عَلِمَ {47} به. فيقال {48}: (أطلعته على كذا)؛ أي: أعلمته. ويقال: (أطْلِعْنِى طِلْعَ أمْرِكَ)؛ أي: أعلمني بما خَفِيَ منه عَلَيَّ {49}.ويقال: (طَلَعْتُ على كذا)، و (اطَّلَعتُ)، و (أطْلَعْتُ عليه) {50}، و (أطْلَعْتُ غيري) {51}. فـ (الاطلاع)، واقعٌ ومُطاوع {52}."
  3,180,"قوله تعالى: ﴿وَلَا يَحْسَبَنَّ الَّذِينَ يَبْخَلُونَ﴾ الآية.قُرِئ: ﴿يَحْسَبَنَّ﴾ بالياء والتاء {1}.فمن قَرَأ بالياء؛ فـ ﴿الَّذِينَ يَبْخَلُونَ﴾: فاعل ﴿يَحْسَبَنَّ﴾]، {2}، والمفعول الأول محذوفٌ؛ لدلالة اللفظ عليه؛ معناه: لا يَحسَبَنَّ الذين يبخلون بما آتاهم الله مِنْ فَضْلِهِ، البُخْلَ خيرًا لهم. فدلّ ﴿يَبْخَلُونَ﴾ على البخل، فَحُذِفَ؛ كقولهم: (مَنْ كَذَبَ كان شَرًّا له)؛ أي: الكذب {3}. ومثلُه:إذا نهِيَ السَّفِيهُ جَرَى إليه {4} أي: إلى السَّفَةِ. وأنشد الفَرّاء {5}:هُمُ المُلوكُ وأبناءُ المُلوكِ هُمُ ... والآخِذُونَ بِهِ والسَّاسَةُ الأُوَل {6}قوله: (به)؛ يريد: بالمُلْكِ. فاكتَفَى منه بِذِكْرِ (المُلُوك).وقوله تعالى: ﴿هُوَ خَيْرًا لَهُمْ﴾.﴿هُوَ﴾ -ههنا- فَصْلٌ {7}، وهو الذي يُسَمِّيه الكوفيون: عماداً {8}؛ وذلك أنّ تَقَدمَ ﴿يَبْخَلُونَ﴾ بمنزلة تقدم (البُخْل)؛ فَكَأنَّه قيل: ولا يَحْسَبَنَّ الذين يَبخَلُونَ البُخْلَ -هو- خَيْرًا لهم.ومَن قَرَأ بالتَّاء فَقَال الزّجَّاجُ {9}. معناه: ولا تَحْسَبَنَّ بُخْلَ الذين يبخلون، فَحذف المُضَاف؛ كأنه قيل: ولا تَحسَبَنَّ بُخْلَ الباخلين [هو] {10} خيرًا.وأمَّا التفسير فقال ابنُ عباس -في رواية عطاء- {11}، وأكثر أهل التفسير -ابن مسعود {12}، والشعبي {13}، والسُّدِّي {14}، وغيرهم {15} -: نزلت الآية في الباخلين بالزكاة الواجبة {16} عليهم.وقوله تعالى: ﴿بِمَا آتَاهُمُ اللَّهُ مِنْ فَضْلِهِ﴾ قال ابن عباس {17}: يريدون: الذهبَ والفِضَّةَ والحيوان والثِّمَارَ. فَفَسَّرَهُ {18} بالأشياء التي تَجِبُ فيها الزكاةوقوله تعالى: ﴿بَلْ هُوَ شَرٌّ لَهُمْ﴾ قال الحَسَن {17}: لأنهم نالوا بهِ عذَابَ الله.وقوله تعالى: ﴿سَيُطَوَّقُونَ مَا بَخِلُوا بِهِ يَوْمَ الْقِيَامَةِ﴾ أكثرُ المفسِّرينَ على أنَّ معناه: يُجْعَلُ ما بَخِلَ به مِنَ المَالِ حَيَّةً، يُطَوَّقها يومَ القيامة {20} في عُنُقِهِ، تَنْهَسُهُ {21} مِنْ قَرْنِهِ {22} إلى قَدَمِهِ {23}.يَدُلُّ على هذا ما روى ابن مسعود عن النبي ﷺ، [قال] {24}: ""ما مِن رَجُلِ لا يُؤدِّي زكاةَ مالِهِ إلاّ جُعِلَ {25} له شُجاعٌ {26} في عنقِه يومَ القيامة""، ثُمَّ قَرَأ علينا رسول الله ﷺ، مِصْدَاقَهُ مِنْ كتاب الله ﴿سَيُطَوَّقُونَ مَا بَخِلُوا بِهِ يَوْمَ الْقِيَامَةِ﴾ {27} وقال إبراهيم النَّخَعِي: معناه: يُجعَل يوم القيامة في أعناقهم، طَوْقٌ مِن نارٍ.أخبرنا إسماعِيل بن أبي القَاسِم الصوفي {28}، أَبَنَا {29} أبو عبد الرحمن، عبد الله بن عمر بن علَّك الجَوْهري {30}، بِمَرْو {31}، ثنا عبد الله بن محمود السَّعْدِي {32}، ثنا موسى بن بحر {33}، ثنا عَبِيدة بن {34} حُمَيْد {35} ، حدّثَنِي منصور {28}، عن إبراهيم {37} -في قوله: ﴿سَيُطَوَّقُونَ مَا بَخِلُوا بِهِ يَوْمَ الْقِيَامَةِ﴾ -، قال: (يُطَوَّقون بِطَوْقٍ {38} منْ نار) {39}.وعلى هذا التَّفْسِير، يجعَل ما بَخِلُوا به مِنْ المال، طَوْقًا مِنْ نارٍ، كما جُعِلَ في التفسير الأوَّلِ حَيَّة.وقال المُؤَرج {17}: معناه {41}: يُلزَمُون أعمالَهم، مِثْل ما يَلْزم الطوقُ العنقَ. والعربُ تكني بالتطويق {42} عن الإلْزام؛ ومنه قراءة مَن قرأ: ﴿وَعَلَى الَّذِينَ يُطِيقُونَهُ﴾ [البقرة: 184]، {43}؛ أي: يَتَكَلَّفُونَه، وُيلْزَمُونَه. يُقال: (طُوِّقَ فلانٌ عَمَلَهُ، مثلَ طَوْقِ الحَمَامَةِ).قال ابنُ الأنباري {17}: معناه -على هذا التفسير-: سَيُطَوّقُونَ جَزَاءَ ما بخلُوا به. وذِكْرُ التَّطْوِيق -ههنا- على جهة المَثَلِ، كِنَايَةً عن الإلزام، لا على أنَّ ثَمَّ أطواقًا.وقال ابن عباس -في رواية العَوْفي- {45}: نزلت هذه الآية في اليهود الذين كتموا صِفَةَ محمد ﷺ، وأراد بـ (البخل): كِتْمان العِلْم الذي آتاهم الله.يَدُلُّ على هذا التفسير: قولُه -تعالى-: ﴿الَّذِينَ يَبْخَلُونَ وَيَأْمُرُونَ النَّاسَ بِالْبُخْلِ وَيَكْتُمُونَ مَا آتَاهُمُ اللَّهُ مِنْ فَضْلِهِ﴾ [النساء: 37].وعلى هذا، معنى قوله: ﴿سَيُطَوَّقُونَ مَا بَخِلُوا بِهِ﴾ أي: يُحَمَّلُون وِزْرَهُ وإثْمَهُ. وهذا القول اختيار: ابنِ كَيْسان {17}، وأبي إسحاق {47}.وقوله تعالى: ﴿وَلِلَّهِ مِيرَاثُ السَّمَاوَاتِ وَالْأَرْضِ﴾.قال المفسرون كلُّهم {48}: يعني أنه يَفْنى أهلُها، وتبقى الأملاكُ والأموالُ، ولا مالكَ لها إلا اللهُ. فجرى هذا مجْرى الوِراثَةِ؛ إذْ كانَ الخلْقُ قبل ذلك يَدّعُونَ المُلْكَ، فَلَمَّا ماتُوا عنها، ولم يُخَلِّفُوا أحدًا، كانَ هو الوارث لها -جل وعَزَّ-.قال أبو إسحاق {49}: خُوطِبَ القومُ بِمَا يَعْقِلُون؛ لأنهم يَجْعَلُون ما رَجَعَ إلى الإنسانِ ميراثًا، [إذا كان ملكًا له.وتأويله: بُطلانُ مُلْكِ جميع المَالِكين، إلّا مُلْك الله -جَلَّ وعَزَّ-] {10}، فيصير كالميراث.قال ابن الأنباري {51}: والعرب تقول: (وَرِثَ فلانٌ عِلْمَ فلانٍ): إذا تَفَرَّد به {52} بعد أن كان مشاركًا فيه {53}.وقد قال الله -تعالى- {54}: ﴿وَوَرِثَ سُلَيْمَانُ دَاوُودَ﴾ [النمل: 16]، [فَذَهَبَ إلى وِراثَتِهِ عِلْمَهُ، بعد أنْ كانَ داودُ] {55} مشاركًا فيه {53}، أو {57} غالبًا عليه.وقوله تعالى: ﴿وَاللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌ﴾.مَنْ قَرَأَ بالياءِ {58}، فلأنَّ ما قَبْلَهُ على الغَيْبَةِ، وذلك قوله: ﴿سَيطَوَّقُونَهُ﴾ {59}، ﴿والله بِمَا يَعملون {60} خبير﴾ مِنْ مَنْعِهِم الحقوقَ، فَيُجَازِيهم عليه.ومَن قرأ بالتاء؛ فَلأنَّ قبل هذه الآية خِطابًا، وهو قوله: ﴿وَإِنْ تُؤْمِنُوا وَتَتَّقُوا فَلَكُمْ أَجْرٌ عَظِيمٌ﴾ [آل عمران: 179]، ﴿وَاللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌ﴾، فَيُجازِيكم عليه.والغَيْبَةُ أقرب إليه مِنَ الخطاب."
  3,181,"وقوله تعالى: ﴿لَقَدْ سَمِعَ اللَّهُ قَوْلَ الَّذِينَ قَالُوا﴾ الآية.قال ابن عباس {1} والمفسرون {2}: نزلت هذه الآية في اليهود، حين قالوا -لَمَّا نَزَلَ قولُه: ﴿مَنْ ذَا الَّذِي يُقْرِضُ اللَّهَ﴾ {3} -: إنَّ اللهَ فقيرٌ يَسْتَقرِضُنا، ونحن أغنياء.وُيروى أن قائل هذا رجلٌ من اليهود، يقال له فِنْحاص، قال: لو كان الله غنيَّا ما استَقْرَضَنَا أموالَنَا {4}، وأنه {5} يَنهَى عن الرِّبَا، ويعطينا، ولو كان غنيًا ما أعطانا الرِّبا. وقيل: إن قائِلَه: حُييُّ بن أخْطَب {6}.وقوله تعالى: ﴿سَنَكْتُبُ مَا قَالُوا﴾ أي: نأمر {7} الحَفَظَةَ بإثبات قولهم في صحائف أعمالهم؛ وذلك أظهر في الحجَّة عليهم. وهذا كقوله: ﴿وَإِنَّا لَهُ كَاتِبُونَ﴾ [آل عمران:181]وقرأ {8} حمزة {9}: ﴿سيُكتَبُ ما قالوا﴾ اعتبارًا بقراءة عبد الله {10}: (وَيُقالُ ذُوقوا عذابَ الحَرِيق) {11}؛ ولأنَّه مِنَ التَّصَرُّف في وجوه الكلام.وقراءة العامَّة أحسنُ؛ لِجَرْيِ الكلامِ فيها على تَشَاكل {12}.و ﴿الْحَرِيقِ﴾: اسمٌ للنار الملتهبة، وهو بمعنى المُحْرِق {13}."
  3,182,"قوله تعالى: ﴿ذَلِكَ بِمَا قَدَّمَتْ أَيْدِيكُمْ﴾.أي: ذلك {1} العذاب بما سلف من الإجرام، وأضيف التقديم إلى أيديهم -وهو لهم في الحقيقة-؛ لِيَكون أدَلّ على تَوَلِّي الفِعْلِ؛ لأنه قد يُضافُ الفِعْلُ إلى الإنسان على أنه أَمَرَ به، وَدَعَا إليه؛ نحو قوله: {يُذَبِّحُ أَبْنَاءَهُمْ} [القصص: 4]، فإذا ذُكِرَت اليد، دَلَّ على تَوَلِّي الفعل؛ نحو قوله -تعالى-: ﴿مِمَّا عَمِلَتْ أَيْدِينَا﴾ [يس: 71].وقوله تعالى: ﴿ذَلِكَ﴾ ابتداءٌ. وخَبَرُهُ: ﴿بِمَا قَدَّمَتْ﴾.وقوله تعالى: ﴿وَأَنَّ اَللهَ﴾. أي: وبأن الله ﴿لَيْسَ بِظَلَّامٍ لِلْعَبِيدِ﴾ وموضع (أنَّ) {2}: جَرٌّ {3}."
  3,183,"قوله تعالى: ﴿الَّذِينَ قَالُوا إِنَّ اللَّهَ عَهِدَ إِلَيْنَا﴾ الآية.قال أبو إسحاق {1}: هذا مِن نَعْتِ (العبيد) {2}.ويجوز أن يكون رفعًا بالابتداء؛ على معنى: هم الذين قالوا. ويجوز أن يكون بدلًا مِنَ ﴿الَّذِينَ﴾ الأوَّل {3}.قال السدِّي {4}: إن الله أمَرَ بني إسرائيلَ في التوراة: مَن جاءَكم {5} يَزْعُمُ أنه رسول الله، فلا تُصَدِّقوه حتى يأتيكم بِقُرْبانٍ تأكله النار، حتى يأتيكم المسيحُ ومحمد، فإذا أتَيَاكم، فآمنوا بهما، فإنهما يأتيان بغير قُرْبان.وقوله تعالى: ﴿بِقُرْبَانٍ تَأْكُلُهُ النَّارُ﴾.القُرْبان: البِرُّ الذي تتقرب به إلى الله {6}. وأصلُهُ المَصْدَر، من قولك: قَرُبَ قُرْبانًا {7}. كالكُفْران والرُّجْحان، والخُسْران، ثم يُسَمَّى {8} به نفْسُ المُتَقَرَّب به. ومنه قوله ﷺ، لكَعْبِ بن عُجْرَة {9}: ""يا كعبُ: الصوم جُنَّة، والصلاة قُرْبان"" {10}؛ أي: بها يُتَقَرَّبُ إلى الله، ويُسْتشفَعُ في الحاجة لَديْهِ"" {11}قال عَطَاءَ {12}: كانت بنو إسرائيل يَذْبَحون لله، فيأخذون الثُّرُوبَ {13} وأطايِبَ اللَّحْم، يضعونها في وسْطِ بَيْتٍ، والسَّقْفُ مكشوفٌ، فيقومَ النبيُّ في البيت، ويُناجي رَبَّهُ، وبنو إسرائيل خارجون حول البيت، فتنزل نارٌ {14} بيضاء لها دَويٌّ وحَفِيفٌ، ولا دُخانَ لها، فتأكل ذلك القربان، فقال الله -تعالى- إقامةً للحُجَّةِ عليهم:﴿قُلْ قَدْ جَاءَكُمْ رُسُلٌ مِنْ قَبْلِي بِالْبَيِّنَاتِ﴾، إلى آخرها.وخُوطِب [بهذا] {15} اليهودُ الذين كانوا في عهد النبي ﷺ لأنهم يجرون مجرَى أسلافهم؛ لِرِضاهم بمذاهبهم، وكونهم على طريقتهم.وقد مضى مثل هذا في أوائل سورة البقرة {16}."
  3,184,"قوله تعالى: ﴿فَإِنْ كَذَّبُوكَ فَقَدْ كُذِّبَ رُسُلٌ مِنْ قَبْلِكَ﴾ الآية.قال ابن عباس {1}، والحسن {1}، والضحّاك {3}، وابن جريج {4}: هذهالآية تعزِيَةٌ للنبي ﷺ، في تكذيب اليهود إيَّاه، وجوابٌ لقائلٍ يقول: لو كانما جاء به حقًّا لَصَدّق به مَن أتاه من العقلاء، وبيان أنهم إن كَذَّبوهُ،فالتكذيب عادة للأمم، وسائر الرُّسُل قد كُذّبوا كما كُذِّب.وقوله تعالى: ﴿وَالزُّبُرِ﴾.معناه: الكُتُب. وهو جَمْعُ (زَبُور). والزَّبُور: الكتاب؛ بمعنى: المَزْبُور؛ أي: المكتوب. يقال: (زَبَرْتُ الكِتَابَ)؛ أي: كتبته. وكُلُّ كِتَابٍ زَبُورٌ {5}.قال امرؤ القيس:لِمَنْ طَلَلٌ أبْصَرْتُهُ فَشَجانِي ... كَخَطِّ زَبُورٍ في عَسِيبِ يَمَانِ {6} وقال الزّجاج {7}: الزَّبُور: كلُّ كِتَابٍ ذي {8} حِكْمَةٍ. وعلى هذا، يُشْبِهُ أنْ يكونَ معنى الزَّبُورِ، مِنَ: (الزَّبْرِ)، الذي هو: الزَّجْر. يقال: (زَبَرْتُ الرجلَ، أزْبُرُهُ زَبْرًا): إذا زَجَرْتُه مِنَ {9} الباطل {10}. وسمّي الكتاب: (زَبُورًا)؛ لما فيه من الزَّبْر عن خلاف الحق. وبه سُمِّي زَبُورُ داود؛ لِكثرة ما فيه من المَزَاجِرِ، والمواعظ.وقرأ {11} ابنُ عامر {12}:﴿وَبِاَلزُّبُرِ﴾ {13}، ووجهه أنه أعاد الباءَ، وإنْ كانَ مُسْتَغْنًى عنه؛ لِضَرْبٍ من التأكيد. ومما جاء على قياس هذه القراءة، قولُ رُؤبَة:يا دارَ عَفْراءَ وَدارَ البَخْدَنِ {14}فَكَرَّرَ الدارَ، والدار واحدةٌ لهما {15}. يدلك {16} على ذلك: قوله:فيكِ المَهَا مِنْ مُطْفِلٍ ومُشْدِنِ {17} ولم يقل: فيكما. فكذلك كرَّرَ ابنُ عامر الباءَ، وكلا {18} الوجهين -مِن تكرير الباءِ وحَذْفِهِ- حَسَنٌ عربيٌّ.ومعنى {19} قوله: ﴿جَاءُوا بِالْبَيِّنَاتِ﴾ إلى آخرها؛ أي: بالمعجزات، وكتب المَزَاجِرِ، و ﴿الْكِتَابِ﴾ الهادي إلى الحق.و ﴿الْمُنِيرِ﴾؛ مِنْ قولك: (أَنَرْتُ الشيءَ، أُنِيرُه، إنَارَةً)؛ أي: بَيَّنتُه، وأوضحته، وفي الحديث: (فَرَض عمرُ بن الخطاب لِلجَدِّ، ثم أنارهما زيدُ ابن ثابت) {20}؛ أي: أوضحها. ويقال {21}: (نارَ الشيءُ وأنَارَ، ونَوَّرَ، واستنار) بمعنى واحد. كما {22} يقال: (أبَانَ الشيءُ {23}، وبَيَّنَ، وتَبَيَّنَ، واستَبَان) بمعنى واحدٍ. وعلى ما ذكرنا؛ (أنَارَ) يكون واقعًا ومُطاوعًا {24}."
  3,185,"قوله تعالى: ﴿كُلُّ نَفْسٍ ذَائِقَةُ الْمَوْتِ﴾ الآية.﴿ذَائِقَةُ﴾: فاعِلَة، مِنَ: (الذَّوْقِ). واسم الفاعِلِ إذا أضيف إلى اسمٍ، وأُريِدَ {1} بِهِ المُضِيّ، لم يَجُزْ إلّا الجَرُّ، نحو:(زيْدٌ ضارِبُ عمروٍ أمسِ)، فإنْ أردت به الحالَ والاستقبالَ، جازَ الجَرُّ والنَصْبُ؛ تقول: (هو ضاربُ زيدٍ غدًا)، و (ضاربٌ زيدًا {2} غدًا). قال الله -تعالى-: ﴿هَلْ هُنَّ كَاشِفَاتُ ضُرِّهِ﴾ [الزمر: 38]. و ﴿كاشفات ضُرَّه﴾ {3}، قُرِئ بالوجهين {4}، لأنه الاستقبال.وروي عن الحسن أنه قرأ: (ذائقةٌ الموتَ) {5} -بالتنوين، ونصب الموت-، واستقصاء الكلام في هذه المسألة يأتي عند قوله: ﴿ظَالِمِي أِنْفُسِهِمْ﴾ في سورة النساء.وقوله تعالى: ﴿فَقَدْ فَازَ﴾. الفَوْزُ؛ معناه: الظَّفَرُ بالخير، والنجاةُ من الشَّرِّ {6}. ألا ترى أن الله -تعالى- حَكَمَ بالفوز لِمَن أُبْعِدَ مِنَ النار، فَنَجَا مِنْ شَرِّها، وأدْخِلَ الجَنَّةَ، فَظَفِرَ بنعيمها؟.قال الزّجاج {7}: يقال لِكُلِّ مَنْ نَجَا من هَلَكَةٍ، ولَقِيَ ما يَغْتَبِطُ به {8}: (فازَ). فتأويل {9} ﴿فَازَ﴾: تَبَاعَدَ مِنَ المكروه، ولَقِيَ ما يُحِب.وقوله تعالى: ﴿وَمَا الْحَيَاةُ الدُّنْيَا إِلَّا مَتَاعُ الْغُرُورِ﴾ يريد: العيش في هذه الدار الفانية، تَغُرُّ الإنسان بما تُمَنِّيهِ مِنْ طولِ البقاء، وسينقطع عن قريب. فَوُصِفت بأنها متاعُ الغرُوُر؛ لأنها بمنزلة مَنْ يَغُرّ ببذل المحبوب، والتخييل [إليك] {10} أنه يَدُوم.و ﴿المَتَاع﴾ قد ذكرنا أنه كل ما يُنْتَفَع به، وُيسْتَمتَعُ {11}. وأضافَهُ إلى ﴿الْغُرُورِ﴾ لأنه يَغُرّ."
  3,186,"قوله تعالى: ﴿لَتُبْلَوُنَّ فِي أَمْوَالِكُمْ وَأَنْفُسِكُمْ﴾ الآية.اللَّام، لام القَسَمِ. والنونُ دخلت مُؤَّكِدَةً. وضُمَّت الواوُ لِسُكُونها وسكون النون. ولم تكسر لالتقاء الساكنين؛ لأنها واو جمع، فحركت بما كان يَجِبُ لِمَا قبلها مِنَ الضَمِّ. ومثله: ﴿اشْتَرَوُا الضَّلَالَةَ﴾ [البقرة: 16]. وقد مَرّ مستقصًى فيه.ومعنى ﴿لَتُبْلَوُنَّ﴾: لَتُخْتَبَرُنَّ. ولا يجوز في وصف الله تعالى الاختبار؛ لأنه طلب المعرفة، لِيُعْرَفَ الجَيِّدُ مِنَ الرَّديء، ولكنَّ معناه -في وصف الله-: أنه يُعامِلُ العبدَ مُعامَلَةَ المُخْتَبِرِ.واختلفوا في معنى هذا الابتلاء:فقال ابن عباس -في رواية عطاء- {1}: الخطاب للمهاجرين؛ أَخَذَ المشركون أموالَهم، وباعوا رِبَاعَهم، وعَذَّبوهم.وقال الحَسَنُ {2}: يعنى: بالفرائض التي أوْجَبَها في الأموال، وعلى الأنفس؛ كالصوم والصلاةِ والزكاةِ والحجِّ والجهاد {3}.وقال مقاتل {4}:يعنى: بالحوائِجِ {5}، والخسران في الأموال، والأمراض في الأنفس.قال {6}: ونزلت الآية في النبي ﷺ، وأبي بكر رضي الله عنه.وقوله تعالى: ﴿وَلَتَسْمَعُنَّ مِنَ الَّذِينَ أُوتُوا الْكِتَابَ مِنْ قَبْلِكُمْ وَمِنَ الَّذِينَ أَشْرَكُوا أَذًى كَثِيرًا﴾.قال عكرمة {7}، ومقاتل {8}، والكلبي {9}، وابن جريجِ {10}: بعث رسولُ اللهِ أبا بكرٍ الصدِّيقَ إلى فِنْحاص، يَسْتَمِدُّه. فقالَ فِنْحاصُ: قد احتاجَ رَبُّكُم إلى أن نُمِدَّه؟ فَهَمَّ أبو بكر أنْ يضرِبَهُ بالسيف، وقد كان رسول الله قال له -حين بَعَثَهُ-: لا تَفْتَاتَنَّ {11} عليّ بشيء حتى ترجع. فتذكر أبو بكرٍ ذلك، فَكَفَّ عن الضرب، ونزلت هذه الآية {12}.. . . . . . . . . . . . . . . . . . . . . . .وقوله تعالى: ﴿وَإِنْ تَصْبِرُوا﴾ أي: على الأذى الذي ينالكم {13} منهم ، كترك المفارضة. وكان هذا قبل نزول آية السَّيْفِ {14}.قوله تعالى: ﴿فَإِنَّ ذَلِكَ مِنْ عَزْمِ الْأُمُورِ﴾.قال ابن عباس {15}: مِنْ حقيقة الإيمان. ومعنى العَزم: تَوْطِينُ النفس على الأمر. ومعنى ﴿مِنْ عَزْمِ الْأُمُورِ﴾؛ أي: ذلك مِمَّا يُعْزَم عليه مِنَ الأمْرِ {16}؛ لظُهُورِ رُشدِهِ، وموضع الحظِّ {17} فيه، فيجب التَّمَسُّكُ به {18}.ومعنى قول ابن عباس: (مِنْ حقيقة الإيمان)؛ أي: مِمَّا عَزَمْتم عليه مِنَ الأمر، وهو الإيمانُ والتصديق لِوَعْدِ الله بالنُّصْرِةِ."
  3,187,"قوله تعالى: ﴿وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ الَّذِينَ أُوتُوا الْكِتَابَ﴾ الآية.قال ابن عباس {1}، والسدّي {2}، والكلبي {3}، والمفسِّرون {4}: نَزَلت في يهود المدينة، أخَذَ اللهُ ميثاقهم في التوراة، لَيُبَيِّنُنَّ شأن محمد ﷺ، ونَعْتِهِ، وَمَبْعَثِهِ، ولا يُخْفُونَه، فَنَبَذوا الميثاقَ، ولم يَعْمَلُوا به {5}.قوله تعالى: ﴿لَتُبَيِّنُنَّهُ لِلنَّاسِ وَلَا تَكْتُمُونَهُ﴾ {6} يُقرأ بالياء والتاء {7}. فَمَن قرأ بالياء؛ فلأنهم غَيْبٌ. ومن قرأ بالتاء؛ حَكَى المخاطبةَ التي كانت في وقت أخذ الميثاق.ومثل {8} هذه الآية: قوله: ﴿وَإِذْ أَخَذْنَا مِيثَاقَ بَنِي إِسْرَائِيلَ لَا تَعْبُدُونَ﴾ [البقرة: 83]، بالياء والتاء {9}. وقد تقدم القول في ذلك.وقوله تعالى: ﴿وَلَا تَكْتُمُونَهُ﴾ {10} ولم {11} يقل: ولا تكتُمُنَّهُ {12}؛ كما قال: ﴿لَتُبَيِّنُنَّهُ﴾ {13}؛ لأنه في معنى الحال {14}، لا في معنى الاستقبال المعطوفِ على ما قبله.كأن المعنى: لَتُبَيِّنُنَّه للناس غيرَ كاتِمِينَ {15}. و (الهاء) في ﴿لَتُبَيِّنُنَّهُ﴾، يعود {16} على محمد ﷺ، في قول أكثر المفسرين {17}. فهو عائدٌ على معلوم، ليس بمذكور.وفي قول الحسن، وقَتَادة {18}: يعود على الكتاب، في قوله: ﴿الَّذِينَ أُوتُوا الْكِتَابَ﴾، [ويدخُلُ فيه بَيانُ أمرِ النبي ﷺ؛ لأنه في الكتاب] {19}.قال الحسن {3}: هذا ميثاق الله على علماء أهل الكتاب، أن يُبَيِّنوا للناس ما في كتابهم، وفيه ذكر رسول الله ﷺ، والإسلام، فَنَبَذُوه وَرَاءَ ظُهورهم.وقال قتادة {21}، والقُرَظِيُّ {22}: كلّ مَنْ أوتي عِلْمَ شيءٍ مِنْ كُتُبِ {23} الله -جل وعز- {24}، فقد أخذَ ميثاقُهُ: أنْ يُبَيِّنَه للناس ولا يكتُمَه.وقوله تعالى: ﴿فَنَبَذُوهُ وَرَاءَ ظُهُورِهِمْ﴾.قال {25} ابن عباس {3}: يريد: ألقوا ذلك الميثاقَ خَلْفَ ظهورهم.وقال أهل المعاني {27}: تركوا العَمَلَ {28} به {29}، وقد كانوا يقرأونَهُ {30}، فصاروا بترك العمل به، كأنهم قد ألقوه وراء ظهورهم.قال الزجّاج {31}: يقال للذي يطرح الشيء، لا {32} يَعْبَأ به: قد جعلت هذا الأمر بِظَهْرٍ {33}.وأنشد للفرزدق {34}: تميم بن قيس:لا يكونن حاجتي بظهر ... فلا يعبأ على جوابهاأي لا يتركنها تعبأ بها.وقوله تعالى ﴿وَاشْتَرَوْا بِهِ ثَمَنًا قَلِيلًا﴾ يعني ما كان يأخذونه من سفلتهم من المآكل التي كانوا يصيبونها منهم برياستهم في العلم.وقوله تعالى: ﴿فَبِئْسَ مَا يَشْتَرُونَ﴾ قال ابنُ عبَّاس {3}: يريد: قَبُحَ شراؤُهم وخَسِروا."
  3,188,"قوله تعالى: ﴿لَا تَحْسَبَنَّ الَّذِينَ يَفْرَحُونَ﴾ الآية.قال أبو سعيد الخُدْرِي {1}: نزلت في رجالٍ من المنافقين، كانوا يتخلفون عن رسول الله في الغَزْوِ، ويفرحون بقعودهم عنه. فإذا قدم اعتذروا إليه، فيقبل عذْرَهم {2}، وأحَبُّوا أنْ يُحْمَدوا بما ليسوا عليه مِنَ الإيمان.وقال عكرمة {3}: هم اليهود، فرحوا بإضلال الناس، وبنسبة الناس إيَّاهم إلى العِلْمِ؛ وليسوا كذلك.وقال بعضُهم: نزلت في الذين ذَمَّهم الله -تعالى-: بِكِتْمان الحَقِّ، كتموه وفَرِحوا بذلك، وأحَبُّوا أنْ يُحْمدوا بالتمسك بالحق، وقالوا: نحن أصحاب التوراة، وأولوا العِلْمِ القديم، وكلُّ ما {4} قلناه واجبٌ على الناس قَبُولُهُ، واتِّباعنا فيه. وهذا يُروَى عن ابن عباس {5}.واختلف القرّاء في هذه الآية:فقرأ ابن كثير، وأبو عمرو -كلاهما-: بالياء وضمِّ الباء، مِنْ ﴿يَحْسِبُنَّهم﴾ {6}.ووجه {7} هذه القراءة: أنهما لم يُعَدِّيا (حَسِبْتُ) إلى مفعوليه اللذين {8} يقتضيهما؛ لأنهما جعلا قولَهُ -تعالى- {9}: ﴿فَلا يَحْسِبُنَّهُم﴾ {10} بدلًا مِنَ الأوَّلِ. ولَمَّا جعلاه بَدَلًا، وعُدِّي إلى مفعوليه، استُغنِيَ عن تَعْدِيَة الأولى إليهما، كما استغنى في قوله:بِأيِّ كتابٍ أم بِأيِّة سُنَّةٍ ... تَرىَ حُبَّهُمْ عارًا عليَّ وتَحْسَبُ {11}بتعدية أحد الفعلين إلى مفعوليه، عن تعدية الآخر إليهما.فإن قيل: لا {12} يستقيم تقدير البَدَلِ في قوله: ﴿لا يَحْسِبَن {13} الذيِن يَفْرَحُون بِمَا أتَوْا فَلا يَحْسِبُنَّهم {14} بِمَفَازَةٍ﴾، وقد دخلت الفاءُ بينهما، ولا يدخل بين البدل والمُبْدَلِ منه، الفاءُ {15}.قيل: إن الفاء زائدة {16}؛ يَدُلُّك {17} على ذلك: أنها لا يجوز أن تكون عاطفة؛ لأن المعنى: لا يَحْسِبَنَّ الذين يفرحون بما أتوا، أَنْفُسَهم بمفازةٍ مِنَ العَذَابِ.وإذا كان كذلك، لَمْ يَجُزْ تقديرُ العطف؛ لأن الكلام لم يستقل بعدُ، فيستقيم فيه تقديرُ العَطْفِ. ولا يجوز {18} -أيضًا- أن تكون للجزاء، كالتي في قوله: ﴿وَمَا بِكُمْ مِنْ نِعْمَةٍ فَمِنَ اللَّهِ﴾ {19}، ونحوها؛ لأن هذا ليس من مواضع الجزاء. وإذا لم يجز أن تكون للعطف [و] {20} لا لِلْجَزَاء، ثَبَتَ أنها زائدة؛ كقوله:وإذا هَلَكْتُ {21} فَعِنْدَ ذلك فاجْزَعِي {22} وكما أنشد {23} قُطْرُب {24}:وحِينَ تَركتُ العائداتِ يَعدْنَهُ ... يَقُلْن فلا تَبْعَدْ وقلتُ لَه ابْعَدِ {25}وذكرنا وجْهَ زيادة الفاء في الكلام، فيما تقدم.وقوله تعالى: ﴿فَلَا تَحْسَبَنَّهُمْ﴾ قد {26} تَعَدّى فيه فعلُ الفاعل إلى ضميرِهِ. وفِعْلُ الفاعل في هذا الباب، يَتَعدَّى إلى ضمير نفسه؛ نحوَ (ظَنَنْتُنىِ أخاه)، و (حَسِبْتُني ذاهبًا).يدل على ذلك: قُبْحُ دخولِ النَفْسِ عليها. ولو قلت: (حَسِبتُ نفسي تفعل كذا). لم يَحْسُنْ، كما يَحْسنُ: (حَسِبْتُنِي)، و (أَحْسِبُنِي) {27}.وحُذِفَتْ واوُ الضميرِ في ﴿يَحْسِبُنَّهم﴾ {28}؛ لِدُخول النون الثقيلة، واجتماع الساكنين {29}. و-كذلك- يُحذف عند دخول النونِ الخفيفة؛ كما تقول: (لا يَحْسِبُنْ زيدًا ذاهبًا).وقوله تعالى: ﴿بِمَفَازَةٍ مِنَ الْعَذَابِ﴾.في موضع المفعول الثاني. وقرأ حمزة، وعاصم والكسائي -كلاهما- {30}: بالتَّاء، وفتحوا الباءَ من ﴿تَحْسَبَنَّهُمْ﴾ {31}.ووجه هذه القراءة: أنه حذف {32} المفعولَ الثاني الذي يقتضيه ﴿تَحْسَبَنَّ﴾ الأول؛ لأن ما يجيء بَعدُ من قوله: ﴿فَلَا تَحْسَبَنَّهُمْ﴾ ، يدل عليه.ويجوز أن تجعل {33} ﴿تَحْسَبَنَّهُمْ﴾ بدلًا من ﴿تَحْسَبَنَّ﴾، كما جاز أن تجعل (يَحسِبُنَّهم {34}) بدلًا من (يَحْسِبَنَّ {35}) في قراءة ابن كثير وأبي عمرو، لاتِّفاق {36} الفعلين.قال أبو إسحاق {37}: ووقعت (فَلا {38} تَحسَبَنَّهم) مُكَرَّرةً؛ لِطُول القصَّة.والعربُ تُعيد إذا طالت القصّة (حَسبت) وما أشبهها؛ إعلامًا أن الذي جرى متصل بالأوَّل، وتوكيد {39} له، فتقول: (لا تظنَنَّ زيدًا إذا جاءك وَكلَّمَكَ في كذا وكذا، فَلاَ تظُننَّه صادقًا)، فتكرره إيضاحًا للقصة.وهذا -الذي ذكره أبو إسحاق- سائغٌ في القراءتين: قراءةِ أبي عمرو، وقراءةِ حمزة.وقرأ نافعٌ وابنُ عامر: الأوَّل بالياء، والثاني بالتاء وفتح الباء {40}.ووجه هذه القراءة: أن المفعولَيْن {41} اللَّذَيْن يقتضيهما الحِسْبانُ في قوله: ﴿لَا يَحْسَبَنَّ الذين يفرحون﴾ محذوفان {42}؛ لِدَلالَةِ ما ذكِرَ من بَعْدُ عليهما {43}. فَلمَّا كان قوله: ﴿فَلَا تَحْسَبَنَّهُمْ بِمَفَازَةٍ مِنَ الْعَذَابِ﴾ متَّصلًا بمفعولَيْن ظاهِرَيْنِ، جُعِلا مفعولَي قولِهِ {44}: ﴿لا يَحْسَبَنَّ {45} الذين يَفْرَحُون﴾ ، بتقدير: لا يَحْسَبَنَّ {46} الذين يفرحون أنْفُسَهُمْ، بمفازةٍ من العذاب، ولا تَحْسَبَنَّهم أنت -أيضًا- كذلك.وقوله تعالى: ﴿بِمَا أَتَوْا﴾ قال الفرّاء {47}: يريد: [ما] {48} فعلوه؛ كما قال ﴿لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾ [مريم: 27] أي: فَعَلْتِ. وكقوله: ﴿وَاللَّذَانِ يَأْتِيَانِهَا مِنْكُمْ﴾ [النساء: 16].وقوله تعالى: ﴿بِمَفَازَةٍ﴾ أي {49}: بِمَنْجَاةٍ؛ مِنْ قولهم: (فَازَ فلانٌ): إذا {50} نَجَا. وقال الفرّاء {51}: أي: بِبُعْدٍ {52} من العذاب؛ لأن الفَوْزَ معناه: التباعد من المكروه {53}.وذكرنا ذلك في قوله: (﴿فَقَدْ فَازَ﴾ [آل عمران: 185]."
  3,189,"قوله تعالى: ﴿وَلِلَّهِ مُلْكُ السَّمَاوَاتِ وَالْأَرْضِ﴾ أي: بِمُلْكِ تدْبيرِهما {1}، وتصريفهما {2} على ما يشاء. وهذا تكذيبٌ لِلَّذِين قالوا: ﴿إِنَّ اللَّهَ فَقِيرٌ وَنَحْنُ أَغْنِيَاءُ﴾ {3}."
  3,190,""
  3,191,"قوله تعالى: ﴿الَّذِينَ يَذْكُرُونَ اللَّهَ قِيَامًا وَقُعُودًا﴾ الآية.رُوي عن علي، وابن عباس، وقتادة {1}: أنهم قالوا: يعني {2} [أنهم] {3} يُصَلُّون على هذه الأحوال: قِيَامًا، فإن لم يستطيعوا فقُعُودا، فإن لم يستطيعوا فَعَلَى جُنُوبِهم.وهذا اختيار الزجاج، قال {4}: يصلون في {5} جميع هذه الأحوال، على قَدْرِ إمْكانِهِم، في صحتهم وسَقَمِهم.وقال آخرون {6}: يريد: أنهم يذكرون الله على كل حال.وجاز {7} أن يعطف بـ (على) على ﴿قِيَامًا﴾ و ﴿وَقُعُودًا﴾ ، لأن معناه يُنْبِئ عن حالٍ مِنْ أحوال تَصَرُّفِ الإنسان؛ كما تقول: (أنا أصِيرُ إلى زيدٍ ماشِيًا، وعلى الخيل). المعنى: ماشِيًا ورَاكِبًا {8}.وقوله تعالى: ﴿وَيَتَفَكَّرُونَ فِي خَلْقِ السَّمَاوَاتِ وَالْأَرْضِ﴾.ليَكُون {9} ذلك أزيد في بَصِيرتهم؛ لأن فكرهم يُرِيهم عِظَمَ شأنهما، فيكون تعظيمُهم للهِ عز وجل على حسب ما يقفون عليه من آثار حكمته.وقوله تعالى: ﴿رَبَّنَا مَا خَلَقْتَ هَذَا بَاطِلًا﴾.أي: و {10} يقولون: رَبَّنا ما خلقت هذا {11}. الإشارة بـ ﴿هَذَا﴾ راجعةٌ إلى الخَلْقِ. و ﴿خَلَقْتَ﴾ يدل على الخَلْقِ {12}.وقوله تعالى: ﴿بَاطِلًا﴾.أي: خلقته دليلًا على حكمتك، وكَمَالِ قُدرتِك.ومعنى الباطل: الزائِل الذاهب، الذي لا يَثْبُتُ {13}. ولَمَّا كان خَلْقُ السَّموات والأرض خَلْقًا مُتْقَنًا، وصُنْعًا مُحْكمًا دالًا على قدرة الصانع، لم يكن باطلًا.وكثير من المفسرين يذهبون إلى أن المعنى: (ما خلقتهما لغَيرِ شيءٍ) {14}؛ لأنه خلقهما لِيَبْلُوَ العِبَادَ بينهما بالأمر والنهي، فيثيب المطيع، ويعاقب العاصي {15}، وانتصب قولُه ﴿بَاطِلًا﴾ على أنه نَعْتُ مصدرٍ محذوفٍ؛ أي: خَلْقًا باطلًا {16}.وقوله تعالى: ﴿سُبْحَانَكَ﴾.أي: تنزيهًا لك، ببراءتك عما لا يجوز في وصفك {17}.﴿فَقِنَا عَذَابَ النَّارِ﴾.أي: قد اعترفنا بوحدانيَّتِك، وصدَّقنا أنَّ لك جَنّةً ونارًا، فقِنا عذابَ النار."
  3,192,"قوله تعالى: ﴿رَبَّنَا إِنَّكَ مَنْ تُدْخِلِ النَّارَ فَقَدْ أَخْزَيْتَهُ﴾.الإخزاء -في اللغة- يَرِدُ على معانٍ، يَقْرُبُ بعضُها مِنْ بَعْضٍ.قال الزجاج {1}: (أخزى اللهُ العَدُوَّ)؛ أي: أبْعَدَهُ. وقال غيرُه {2}: الخِزْي: الهَوَانُ، و (أخزاهُ الله)؛ أي: أهانه.وقال شَمِر {3}: أخزيته: فضحته. وفي القرآن: ﴿وَلَا تُخْزُونِ فِي ضَيْفِي﴾ [هود: 78].وقال {4} المُفَضَّلُ {5} -في قوله: ﴿أَخْزَيْتَهُ﴾ -: أي: أهْلَكته.وقال ابن الأنباري {6}: معنى الخِزْي -في اللغة-: الهلاك بتَلفٍ أو انقطاع حُجّةٍ، أو بوقوعٍ في بلاء {7}. قال جرير:تَمَّتْ تَمِيمٌ يا أُخَيْطِلُ فانْجَحِرْ ... خَزِيَ الأُخَيْطِلُ حين قُلتُ وقالا {8}أي: هَلَكَ بانقطاع حُجّتِهِ. ويحتمل: استحيا بانقطاعه. يقال {9}: (خَزِيَ، يَخْزَى، خِزْيًا): إذا هلك. و (خَزِي، يَخْزى {10}، خَزَايةً): إذا استحيا {11}.وتعلقت الوَعِيدِيَّةُ بهذه الآية، وقالوا: قد أخبر الله -تعالى-: أنه لا يُخزي النبيَّ والذين آمنوا معه، فوجب أن كلّ مَنْ يدخل النارَ لا يكون مؤمنًا؛ لِقَولِه: ﴿أَخْزَيْتَهُ﴾. والجواب عن هذا، من وجوه: أحدها: ما رَوَى قتادة، عن أنسٍ {12} -في قوله: ﴿إِنَّكَ مَنْ تُدْخِلِ النَّارَ فَقَدْ أَخْزَيْتَهُ﴾ -، قال: إنك مَنْ تُخَلِّدْ في النار.وقال الثَوْريُّ: بَلَغَنِي عن سعيد بن المسيب {13}، أنه قال في هذه الآية: هي خاصَّةٌ في قومٍ لا يخرُجونَ مِنَ النَّارِ بعد دُخُولِهم إيَّاها.ورُوي هذا المعنى -أيضًا- عن قتادة {14} نفسِهِ. فمذهب هؤلاء الثلاثة: أنَّ الآية خاصَّةٌ فيمن يدخلها للخلود فيها. يدل عليه آخرُ الآية، وهو قوله تعالى: ﴿وَمَا لِلظَّالِمِينَ مِنْ أَنْصَارٍ﴾ يريد: الكفار.والثاني: أن المُدخَل في النار مَخْزِيٌّ في حال دُخُولِهِ، وإن كانت عاقبتُهُ أن يخرج منها، فإن الدخول لا يقع إلّا بخزيٍ في ذلك الوقت. وهذا مذهب جابر بن عبد الله، واختيار ابن الأنباري.يَدُلُّ عليه ما روي عن عَمْرُو بن دينار، أنه قال: قَدِم علينا جابر -في عُمْرةٍ -، فسألته عن هذه الآية، فقال: وما أخزاهُ {15} حين أحرقه بالنار! إنّ دون ذا {16} لَخِزْيًا {17}.قال ابن الأنباري {6}: وحَمْل الآية على العموم أولى من نقلها إلى خصوصٍ لا دليل عليه.والجواب الثالث: ما قال أهلُ المعاني، وهو: أنّ الإخزاءَ يحتمل معنيين: أحدهما: الإهانة والإهلاك والإبعاد، كما ذكرنا. وهذا للكفّار والثاني: الإخجال؛ يقال: (خَزِيَ خَزَايَةً): إذا استحيا، و (أخزاه غَيْرُهْ): إذا عَمِلَ بِهِ عَمَلًا يُخْجِلُه، ويستحيي منه.ومنه حديث يزيد بن شَجَرَة {19}: (ولا تُخزُوا الحورَ العِين) {20}؛ كأنهن يَتَطلَّعنَ مَن يَصيرُ إليهن بالشهادة؛ يقول: فلا تُخْجِلُوهُنَّ بِفِرَارِكُم.فعلى هذا، خِزْيُ المؤمنين: الحياءُ مِنْ سائِرِ أهلِ الإيمان، بدخول النار إلى أن يخرجوا منها، وخِزْيُ الكافرين: الهلاكُ بالخلود {21} فيها."
  3,193,"قوله تعالى: ﴿رَبَّنَا إِنَّنَا سَمِعْنَا مُنَادِيًا﴾ الآية.المنادي: محمد ﷺ، في قول ابن عباس {1}، وابن مسعود {2}، وابن جريج {3}، وابن زيد {4}، والأكثرين {5}.وقيل: عين {6} المُنادِي: القرآنُ؛ حِكايَةً عن مؤمني الإنس، كما حكى عن مؤمني الجنَّ: ﴿إِنَّا سَمِعْنَا قُرْآنًا عَجَبًا﴾ [الجن: 1] الآية.وهذا قول القُرَظِيِّ {7}، قال: لأنه ليس كلُّ أحدٍ لَقِيَ النبي ﷺ. والذين قالوا: إنه النبي؛ قالوا: إن من سَمِع القرآنَ، فكأنه رأى النبي وأدركه وسمع منه؛ لأن القرآن معجزته، لم يأت به غيره، فهو دليل عليه، وكل مَن بَلَغه القرآنُ، فقد أنذره رسول {8} الله ﷺ.وقال تعالى: ﴿يُنَادِي لِلْإِيمَانِ﴾ قال أبو عبيدة {9}: هذا على التقديم والتأخير، أي: سمعنا مناديًا للإيمان ينادي. وقيل {10}: اللام؛ بمعنى: (إلى)؛ كقوله: ﴿ثُمَّ يَعُودُونَ لِمَا نُهُوا عَنْهُ﴾ [المجادلة: 8]، ﴿ثُمَّ يَعُودُونَ لِمَا قَالُوا﴾ [المجادلة: 3] ﴿بِأَنَّ رَبَّكَ أَوْحَى لَهَا﴾ [الزلزلة: 5]، و ﴿الْحَمْدُ لِلَّهِ الَّذِي هَدَانَا لِهَذَا﴾ [الأعراف: 43]، ومثله كثير. وهذا قول أكثر النحويين {11}.وقيل: هي {12} لام (أَجْل) {13}.وقوله تعالى: ﴿وَكَفِّرْ عَنَّا سَيِّئَاتِنَا﴾ معنى (التكفير) في اللغة: التغطية. و (رجلٌ مُكَفَّرٌ بالسلاح)؛ أي: مُغَطَّى {14}.والكُفْر، منه {15} -أيضًا-، وقد {16} ذكرناه.ومعنى ﴿كَفِّرْ عَنَّا سَيِّئَاتِنَا﴾، أي: غَطِّها عَنّا {17}، حتَّى لا نراها {18}؛ كما تقول: (اغفر لي خطيئتي).و (الغَفْرُ) -في اللغة-: السَّتْر {19}. وجَمَعَ بين غُفْران الذنوب، وتكفير السَّيئات؛ لأن غفرانَ الذنوبِ، تَفَضُّلُه ورحمتُه؛ وتكفيرَ السيئات بالطاعات؛ كما تقول في الأشياء الموجبة للكفَّارة، فإنها إذا كُفِّرت، صارت مُكفَّرةً بتلك الطاعةِ التي هي كفَّارةٌ لها، كالصوم في الظِّهار، وإعتاق الرَّقبة في القتل الخطأ، والإطعام في الحِنْث {20}. فالمغفرة بفضله من غير سبب، والتكفير، بسبب {21} طاعة.والسَّيَئات جَمْعُ: سَيِّئَة. قال الليث {22}: يقال: (ساءَ الشَيءُ، يَسُوءُ)، فهو (سَيِّئٌ): إذا قَبُحَ.وقال أبو زيد: (السَّيِّىُء)، و (السَّيِّئة)، عملان قبيحان. يصير (السيِّىءُ) {23} نعتًا للذَّكَرِ مِنَ الأفعال {24}، و (السَّيِّئَةُ) للأنثى؛ ومِنْ هذا يقال: (سَوَّأتُ على فلان فعلَه) ، أي: قَبَّحْتُهُ عليه، وعِبْتُهُ بما صَنَع.وقوله تعالى: ﴿وَتَوَفَّنَا مَعَ الْأَبْرَارِ﴾.قال ابن عباس {25}: يريد: مع {26} الأنبياء؛ والمعنى: تَوَفَّنا في جُمْلَتِهم. وكلُّ مَنْ أُخِذَ في جُمْلَةِ قومٍ صار معهم؛ فلذلك قال: ﴿مَعَ الْأَبْرَارِ﴾."
  3,194,"قوله تعالى: ﴿رَبَّنَا وَآتِنَا مَا وَعَدْتَنَا عَلَى رُسُلِكَ﴾ الآية.قالوا: معناه: على ألسُنِ رُسُلِك. فهو من باب حذف المضاف {1}.وقال الكَلْبيُّ -عن ابن عباس- {2}: يقولون: على لِسان رُسُلِك.ومعنى الدعاء -ههنا- مع العِلْم أنه مُنْجِزٌ وَعْدَهُ لا محالة-: التَّعَبُدُ؛ لمَا في ذلك من الخُضُوع لله، وإظهار الحاجة إليه؛ وذلك أن (الدعاء مُخُّ العِبَادةِ) {3}.ومثلُهُ -مِمَّا لا يجوز غيرُه، وقد تعبدنا بالدعاء به-: قولُهُ {4} -تعالى- {5}: ﴿قَالَ رَبِّ احْكُمْ بِالْحَقِّ﴾ [الأنبياء: 112]، وقوله: ﴿فَاغْفِرْ لِلَّذِينَ تَابُوا وَاتَّبَعُوا سَبِيلَكَ﴾ [غافر: 7] {6} الآيةوقيل {7}: معناه: اجعلنا مِمَّن وَعَدته بالثواب، دون الخِزْي والعِقَاب.فمعنى (آتِنَا ذلك): اجعلنا مِنْ أهلِهِ. وقيل {8}: معناه: و {9} آتِنا ما وعدتنا مِنَ النصْرِ لنا، والخِذْلان لِعَدُونَّا، عاجِلًا. فهم سألوا تعجيل ما وُعِدوا.وقوله تعالى: ﴿وَلَا تُخْزِنَا﴾ قد ذكرنا معاني (الإخزاء)، عند قوله: ﴿مَنْ تُدْخِلِ النَّارَ فَقَدْ أَخْزَيْتَهُ﴾ [آل عمران: 192]."
  3,195,"قوله تعالى: ﴿فَاسْتَجَابَ لَهُمْ رَبُّهُمْ أَنِّي﴾ أي: بِأنِّي.وقوله تعالى: ﴿بَعْضُكُمْ مِنْ بَعْضٍ﴾ أي: في الدِّينِ والنُصْرَةِ، والمُوَالاة. معناه: بعضكم يوالي بعضًا؛ كما ذكرنا في قوله: ﴿ذُرِّيَّةً بَعْضُهَا مِنْ بَعْضٍ﴾ [آل عمران: 34]. هذا قولُ الكَلبِيِّ {1} وغيرِه {2}.وقيل {3}: معناه: حُكْمُ جَمِيعِكم حُكْمُ واحِدٍ منكم؛ فيما أفْعَلُ بكم؛ مِنْ مُجازاتِكم على أعمالكم، وتَرْكِ تضييعها لكم. يستوي في ذلك ذُكْرانُكم وإناثكم.وقوله تعالى: ﴿وَقَاتَلُوا وَقُتِلُوا﴾. أحسنُ {4} وجوهِ القِراءَةِ: تقديمُ ﴿قَاتَلُوا﴾ على ﴿قُتِلُوا﴾ {5}، لأن القتال قبل القتل. وقرأ ابنُ عامر، وابنُ كَثير: ﴿وَقُتِّلُواْ﴾ -مُشَدَّدَة- {6}؛ لِتَكَرُّرِ القتلِ فيهم، فهو مثل: ﴿مُفَتَّحَةً لَهُمُ الْأَبْوَابُ﴾ [ص: 50]، ومَنْ خَفَّفَ؛ فإن التخفيف يقع على القليل والكثير.وقرأ حمزة، والكسائيُّ {7}: ﴿وَقَاتَلُوا وَقُتِلُوا﴾، ولها وجهان:أحدهما: أن المعطوف بالواو، هو الأوَّلُ في المعنى، وإنْ كان مُؤَخَّرًا في اللفظ؛ لأن {8} الواوَ لا يُوجِبُ {9} ترتيبًا.والثاني: أن المُرادَ بقوله: ﴿وَقتُلُواْ﴾ ، أي: قُتِلَ بعضُهم، ثم قاتل مَنْ بَقِيَ منهم، ولم يَهِنُوا، ولم يَضْعُفوا، لِلْقَتْلِ الذي وَقَعَ بهم {10}.وقوله تعالى: ﴿ثَوَابًا مِّن عِندِ اَللَّهِ﴾ قال الزجاجُ {11}: هو مصدرٌ مؤكِّدٌ لِمَا قبله {12} ، لأن معنى ﴿وَلَأُدْخِلَنَّهُمْ جَنَّاتٍ﴾: لأُثِيبَنَّهُمْ.قال: ومثله: ﴿كِتَابَ اللهِ﴾ {13}، و ﴿صُنْعَ اللهِ﴾ {14}؛ لأن ما قبله بمنزلة: (كَتَبَ اللهُ)، و (صَنَعَ اللهُ) {15}."
  3,196,"قوله تعالى: ﴿لَا يَغُرَّنَّكَ تَقَلُّبُ الَّذِينَ كَفَرُوا فِي الْبِلَادِ﴾قال المفسرون: نزلت {1} في مشركي مَكَّة، وذلك أنهم كانوا يَتَجَبَّرُون {2} وَيتَنَعَّمُون. فقال بعض المؤمنين: إن {3} أعداء الله فيما نرى من الخير، وقد هَلَكْنَا من الجُوعِ والجَهْدِ، فنزلت هذه الآية.وقال الفراء {4}: كانت اليهود تضرب في الأرض فَتُصِيبُ الأموالَ، فأنزل {5} الله: ﴿لَا يَغُرَّنَكَ﴾ {6}.قال الزجاج {7}: خطاب النبي ﷺ، خطاب الخَلْقِ في هذا الموضع؛ المعنى: لا يَغُرَّنَّكم أيها المؤمنون. وهذا قول قتادة {8}. قال: والله ما غَرُّوا نَبِيَّ اللهِ، حتى قبضه الله. والخطاب له، والمراد غيره {9}.وقال بعض النَحْوِيِّين {10}: هذا خطابٌ لكل من سمعه من المكلفين؛ كأنه قيل: لا يَغُرَّنك أيُّها السامِعُ.وُيبْنى المضارعُ مع النون الشديدة؛ لأن النون لحقت حرفَ الإعراب، على جهة التأكيد، فصار بمنزلة ضمِّ الاسم إلى الاسم في (خَمْسَةَ عَشَرَ)، ونحوه.وقوله تعالى: ﴿تَقَلُّبُ الَّذِينَ كَفَرُوا فِي الْبِلَادِ﴾.يعني: تَصَرُّفهم للتجارات {11}.أعلَمَ {12} اللهُ أن ذلك مما لا ينبغي أن يُغْبَطوا به؛ لأن مصيرهم -بكفرهم- إلى النار، ولا خير {13} في نَعِيمٍ {14} بعده النار."
  3,197,"فقال: ﴿مَتَاعٌ قَلِيلٌ﴾ أي: تَقَلُّبُهُم مَتَاعٌ قَلِيلٌ. وقال الفراء {1}: ذلك متاعٌ قليل.وقال الزجاج {2}: ذلك الكَسْبُ والرِّبْحُ الذي يربحونه، مَتَاعٌ قليل. وإنما وصفه {3} بالقِلَّةِ؛ لأنه فانٍ مُنْقَطِعٌ؛ ولأنَّهُ {4} -بالإضافة إلى نعيم الآخرة- قليلٌ."
  3,198,"قوله تعالى: ﴿لَكِنِ الَّذِينَ اتَّقَوْا رَبَّهُمْ﴾ الآية. قد ذكرنا التخفيفَ والتشديد في ﴿لَكِنِ﴾ {1} عند قوله: ﴿وَلَكِنَّ الشَّيَاطِينَ كَفَرُوا﴾ {2}، ومعناه {3} -ههنا-: الاستدراك بها، خلاف المعنى المتقدم؛ وذلك أن {4} قوله: ﴿مَتَاعٌ قَلِيلٌ﴾ تَضَمَّنَ: ما لَهُم كثيرُ انتفاع؛ فجاء على ذلك: ﴿لَكِنِ الَّذِينَ اتَّقَوْا رَبَّهُمْ﴾ لَهُمْ {5} الخلود في النعيم المقيم.وقوله تعالى: ﴿مِنْ تَحْتِهَا الْأَنْهَارُ﴾. المعنى: مِنْ تحتِ أشجارِهَا وقصورها وأبْنِيَتِها.وقوله تعالى: ﴿نُزُلًا مِنْ عِنْدِ اللَّهِ﴾ النُّزُلُ {6}: ما يُهيّأ لضيف أو لقوم إذا نزلوا موضعًا.ويقال: (أقمت لهم نُزُلَهم) ، أي: أقمت لهم غذاءَهم {7}، وما يصلح معه أن ينزلوا {8} عليه. هذا معناه في اللغة {9}.وقال الكَلْبيُّ في تفسيره {10}: جزاءً وثوابًا {11}. وانتصابه على المصدر {12}، في قول الزجاج، قال {13}: هو مصدرٌ مُؤَكِّدٌ {14}؛ لأن خلودهم فيها: إنزالهم فيها أو نزولهم {15}.وقال الفرّاء {16}: هو نصبٌ على التفسير {17}، كما تقول: (هو لك: هِبَةً وبَيْعًا وَصَدَقَة).وقوله تعالى: ﴿وَمَا عِنْدَ اللَّهِ خَيْرٌ لِلْأَبْرَارِ﴾ أي: مما يَتَقَلَّبُ {18} فيه الكفّار في دار الدنيا. و (الأبرار) {19} يجوز أن يكون واحده (بارٌّ)، مثل: صاحِبٌ وأصحاب. ويجوز أن يكون واحده (بَرٌّ)، وأصلُهُ: (بَرَرٌ) {20}، فأدْغِمَ {21} للتضعيف {22}."
  3,199,"وقوله تعالى: ﴿وَإِنَّ مِنْ أَهْلِ الْكِتَابِ لَمَنْ يُؤْمِنُ بِاللَّهِ﴾ الآية.اختلفوا في نزولها؛ فقال ابن عباس {1}، وجابر {2}، وقتادة {3}: نزلت في النَّجَاشيِّ {4} حينَ مات، وصلّى عليه النبيُّ ﷺ بالمدينة. فقال المنافقون: إنه يُصَلِّي على نصرانِيٍّ لم يَرَهُ قَطُّ {5}.وقال ابن جُرَيْج {6}، وابن زيد {7}: نزلت في عبد الله بن سَلامٍ وأصحابه.وقال مجاهد {8}: نزلت في مؤمِنِي أهلِ الكتابِ، كلِّهم.و {9} قال الزجاج {10}: لَمَّا ذكر الذين كفروا من أهل الكتاب في قوله: ﴿فَنَبَذُوهُ وَرَاءَ ظُهُورِهِمْ وَاشْتَرَوْا بِهِ ثَمَنًا قَلِيلًا﴾ [آل عمران: 187] ذكر حال مَنْ آمَنَ مِنْ أهلِ الكتاب، وأخبر أنهم صَدَقُوا في حال خُشُوعٍ.وقوله تعالى: ﴿لَا يَشْتَرُونَ بِآيَاتِ اللَّهِ ثَمَنًا قَلِيلًا﴾ أي: عَرَضًا مِنَ الدُّنياَ، كفعل اليهود الذين غَيَّروا التوراة بِثَمَن.ومعنى: ﴿سَرِيعُ الْحِسَابِ﴾ -ههنا-: أنه لا يُؤخِّرُ الجزاءَ عَمَّن استحقه؛ لِطُول الحِسَابِ والاشتغال به؛ كما يتأخر {11} لذلك الحقوقُ في الدنيا. ومضى الكلام في معنى سرعة حساب الله {12}."
  3,200,"وقوله {1} تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا اصْبِرُوا﴾قال الحسن {2}: اصبروا على دينكم فلا تَدَعُوه لِشِدّةٍ. وهذا اختيار الزجّاج {3}.وقال زيد بن أسلم {4}: أي: على الجهاد. وهو اختيار ابن الأنباري {5}.وقال الفرّاء {6}: ﴿اصْبِرُوا﴾ مع نَبِيِّكم {7}، ﴿وَصَابِرُوا﴾ عدُوَّكم، فلا يكونن {8} أصْبَرَ منكم.﴿وَرَابِطُوا﴾، أي: أقيموا على جهاد عدوكم بالحرب والحُجَّةِ. قاله الزجّاج {9}. وأصلُهُ -عند أهل اللغة-: مِن (مُرابَطَةِ الخَيْل)، وهو ارتباطها بإيزاء العَدُوِّ في بعض الثُّغُور {10}.قال ابن قتيبة {11}: أصل (المُرَابَطَةِ) و (الرِّباط): أن يَرْبِطَ هؤلاء خيولَهم في الثَّغْرِ، وَيربط الكفارُ خيولَهم، كلٌّ يُعِدُّ لِصَاحبه، ثم سُمِّيَ المُقامُ بالثغور (رِباطًا)؛ لوجود هذا المعنى {12}.وكلام ابن عباس -في رواية عطاء- يَدُلُّ على هذه الجملة، فإنه قال في قوله: ﴿وَرَابِطُوا﴾ يريد: عَدُوِّي وعدوَّكم. حتى يرجع عن دينه إلى دينكم {13}.وهذا اللفظ يتضمن معنى {14} ملازمة الجهاد. وهذا قول أكثر أهل التفسير {15}.وقال أبو سَلَمَة بن عبد الرحمن {16}: معنى ﴿وَرَابِطُوا﴾: انتظروا الصلاة بعد الصلاة. واحتج {17} بقوله ﷺ في حديث أبي هريرة، حيث ذكر انتظار الصلاة بعد الصلاة- قال: (فَذلِكُمُ الرِّبَاط)، ثلاث مرّات {18}.وأصل هذا من الرَّبْط، وهو: الشَّدُّ {19}. ويقال لِكُلِّ مَنْ صَبَرَ على أمْرٍ: (رَبَطَ قَلْبَه عليه)، و (ربط نفسه) {20}.قال لَبِيد: رابطُ الجَأْشِ على كُلِّ وَجَلْ {21}أي: صابرٌ ثابت. فقيل للصبر على الصلاة وربط النفس عليها: (رِبَاط).وقال أبو عبيدة {22}، وابنُ الأنباري {5}: معنى ﴿وَرَابِطُوا﴾؛ أي: اثْبُتُوا، وداوموا {24}.وأنشد ابنُ الأنباري قولَ الأخْطَل {25}: ما زال فينا رِباطُ الخيْل معْلِمَةً ... وفي كُلَيْبٍ رِباطُ اللُّؤْمِ والعَارِ {26}قال: إنما {27} أراد بـ (الرِّبَاط): اللزوم والثبات. وهذا المعنى راجع إلى ما ذكرنا من الصبر ورَبْطِ النفس.ثم هذا الثبات والدوام يجوز أن يكون على جهاد العدو، ويجوز أن يكون على الصلاة {28}."
