tafsir[29]{c,v,t}:
  81,1,"﴿إِذَا الشَّمْسُ كُوِّرَتْ﴾ قال أبو عبيدة: كورت مثل تكوير العمامة، تلَفُّ فَتُمْحَى {1}، وقال {2} الزجاج: جمع ضوؤها، ولُفَّت {3} كما تلف العمامة، يقال: كورت العمامة على رأسي أكورها كورًا، وكوَّرْتُها تكويرًا إذا لففتها {4}.هذا معنى التكوير في اللغة، وهو الكف والجمع، (ومن هذا سميت الكارة التي للقصَّار؛ لأنه يجمع ثيابه في ثوب واحد، ويكون بعضها على بعض، وللتكوير معنى آخر، يقال: كورت الحائط ودهورته: إذا طرحته حتى يسقط. أبو عبيد {5} عن الأصمعي: طعنه فكوره إذا صرعه {6}.قال أبو كبير {7}:مُتَكَورينَ على المعَارى بينهم ... ضَرْبٌ كتعطاط الْمَزادِ الأثجلِ) {8} {9}وعبارات المفسرين مختلفة، ومعناها ترجع إلى أحد الأصلين {10}:قال قتادة {11}، ومقاتل {12}، (والكلبي) {13} {14} ذهب ضوؤها.وقال مجاهد {15}: اضمحلت وذهبت. وقال أبو صالح: طمست، وعنه أيضًا: انكسفت {16}.وقال أهل المعاني: التكوير: تلفيف على جهة الاستدارة، كتكوير العمامة، والشمس تكور: بأن يجمع نورها حتى يصير كالكارة الملقاة، فيذهب ضوؤه {17}. هذا كله على قول من يقول إنه من اللف {18}.وقال إبراهيم {19}: كورت رُمي بها {20}، وهو قول الربيع {21} بن خثيم {22}. {23} وروي عن مجاهد: دهورت {24}. وعن أبي صالح: أُلقيت {25}.قال المفسرون {26}: تجمع الشمس بعضها {10} إلى بعض ثم تلف فيرمى بها.وأما ما روي عن ابن عباس في تفسير كورت، [ما رواه مُجَالِد] {28} عن رجل من بجيلة {29} {30}، قال: يكور الله الشمس، والقمر، والنجوم يوم القيامة في البحر، ثم يبعث عليها ريحًا دبورًا {31} فتضرمها {32} فتصير نارًا {33}.فقوله: ""يكور الله الشمس"" يحتمل اللف، ويحتمل الرمي."
  81,2,"قوله (تعالى) {1}: ﴿وَإِذَا النُّجُومُ انْكَدَرَتْ﴾قال [أبو عبيدة] {2}: يقال: انكدر فلان أي: انصبَ، وأنشد قول العجّاج {3}: أبْصَر خِرْبان فَضاء فانْكَدَرْ ... حتى {4} انقضّ من الهواء كالمنصب {5}(ويقال: انكدر يّعْدو {6} إذا أسرع) {7}. والمفسرون يقولون: تهافتت وتناثرت وتساقطت {8}.قال الكلبي: وتمطر السماء يومئذ نجومًا، فلا يبقى نجم في السماء إلا وقع على وجه الأرض {9}.وقال عطاء: إنها في قناديل معلقة بين السماء والأرض من النور، وتلك السلاسل بأيدي ملائكة، فإذا مات من في السموات، ومن في الأرض تساقطت تلك السلاسل من أيدي الملائكة؛ لأنه مات من كان يمسكها {10}."
  81,3,"قوله (تعالى) {1}: ﴿وَإِذَا الْجِبَالُ سُيِّرَتْ﴾ قال ابن عباس: تقلعت {2} من أصولها، فسارت وصارت كالهباء {3} المنبث {4}، كقوله: ﴿وَهِيَ تَمُرُّ مَرَّ السَّحَابِ﴾ [النمل: 88]، وقوله: ﴿وَسُيِّرَتِ الْجِبَالُ فَكَانَتْ سَرَابًا﴾ [النبأ: 20]، وقوله: ﴿نُسَيِّرُ الْجِبَالَ﴾ [الكهف: 47]."
  81,4,"قوله (تعالى) {1}: ﴿وَإِذَا الْعِشَارُ عُطِّلَتْ﴾ العشار: جمع العشراء، قال الليث: يقال: عَشَّرَتْ فهي عُشرَاء، والعدد عُشَرَاوات {2}، والجميع {3}: عِشَار -قال-: ويقع اسمُ العشار على النُّوق التي نُتج بعضها، وبعضها مقاريب {4} {5} -قال- (الأزهري) {6}: العرب يسمونها عِشارًا بعد وضعها أولادها للزوم الاسم لها بعد الوضع، كما يسمونها لقاحًا {7}.وقال الزجاج: العشار: النوق الحوامل التي في بطونها {8} أولادها إذا أتت عليها عشرة أشهر، وأحسن ما تكون الإبل، وأنفسها عند أهلها: العشار {9}.وقال المبرد: وإنما سميت عشارًا؛ لأنها قد كملت {10} عشرة أشهر، الواحدة منها عُشراء كقولك {11}: نفساء ونفاس {12}.وقوله: ﴿عُطِّلَتْ﴾ أي تركت هملًا بلا راع، وكل شيء ترك ضياعًا {13} فهو معطل {14}.قال ابن عباس {15}، والمفسرون {16}: أهملها أهلها لما جاءهم من أهوال يوم القيامة وأفزاعها، وليس أحب إلى العرب من النوق الحوامل.وقال الربيع بن خثيم: تخلى منها أربابها فلم تحلب ولم تَصر {17} {18}.وقال أبو إسحاق: وليس يعطلها أهلها إلا في حال القيامة، وخوطب العرب بأمر العشار؛ لأن أكثر مالها وعيشها من الإبل {19}."
  81,5,"قوله (تعالى) {1}: ﴿وَإِذَا الْوُحُوشُ حُشِرَتْ﴾ (كل شيء من دواب الأرض {2} مما لا يستأنس فهو وَحْشٌ، والجمع وحوش) {3} {4}.قال ابن عباس في رواية عطاء {5}، (والكلبي) {6} {7}: يعني جمعت {8} حتى يقتص بعضها من بعض، (وهو قول أكثر المفسرين) {9} {7}.وروى (عكرمة) {7} عن ابن عباس {12} قال: حشر البهائم: موتها، وحَشْر كل شيء الموت غير الجن والإنس."
  81,6,"﴿وَإِذَا الْبِحَارُ سُجِّرَتْ﴾ قال ابن عباس {1} (في رواية عطاء) {2}: أوقدت فصارت نارًا تضطرم {3}، وهو قول مجاهد {4}.وقال الكلبي: تفتح بعضها إلى بعض، فصارت بحرًا واحدا فملئت، وكثر ماؤها {5}.وهذا قول مقاتل {6}، ومعناه: ملئت بأن أفضى بعضها إلى بعض. قاله الفراء {7}.وقال قتادة: غار ماؤها إلى الأرض فذهب {8}، (وهو قول الحسن: يبست {9}. والضحاك: رد ماؤها إلى الأرض {10} {2}.وهذه الأقوال كلها مذكورة في قوله: ﴿وَالْبَحْرِ الْمَسْجُورِ﴾ [الطور: 6]."
  81,7,"(قوله تعالى) {1}: ﴿وَإِذَا النُّفُوسُ زُوِّجَتْ﴾ قال عطاء عن ابن عباس: يريد زوجت نفوس المؤمنين بالحور العين، وقرنت نفوس الكافرين، والمنافقين بالشياطين {2} {3}، وذلك قوله: ﴿احْشُرُوا الَّذِينَ ظَلَمُوا وَأَزْوَاجَهُمْ﴾ {4} (وهذا قول مقاتل {5}، والكلبي) {6} {7}.وروى (النعمان بن بشير) {8} {7} عن عمر -رضي الله عنه- قال: يقترن الرجل الصالح مع الرجل الصالح في الجنة، ويقرن الرجل السوء مع الرجل السوء في النار، فذلك قوله: تزويج {10}.وهذا المعنى روي عنه بألفاظ مختلفة أحدها: ما ذكرنا، والآخر: هما الرجلان يعملان العمل يدخلان (به) {7} الجنة أو النار {12}. ومنها أنه قال: (الفاجر) {7} مع الفاجر، والصالح مع الصالح {14}.ونحو هذا روى الفراء (بإسناده) {15} {7}، عن عكرمة، قال: يقرن الرجل بقرينه الصالح في الدنيا في الجنة، ويقرن الرجل الذي كان يعمل السيئ بصاحبه الذي كان يعينه على ذلك في النار، فذلك تزويج الأنفس {17}.قال {18}: وسمعت بعض العرب يقول: زوجت إبلي، وذلك أن يقرن البعير بالبعير، فيعتلفان معًا، ويرتحلان معًا {19}. وهذا معنى قول الربيع بن خثيم: يحشر المرء مع صاحب عمله {2} {21}.(وهذا معنى قول) {7} مجاهد: أُلحق كل امرئ [بشيعته] {23}: اليهود باليهود، والنصارى بالنصارى {24}.(وروى) {25} عكرمة (قولًا آخر) {7} قال: زوجت الأرواح بالأجساد، يعني: ردت إليها {27}.وقال أبو إسحاق: قرنت كل [شيعة] {28} بمن شايعت {29}.وروي هذا مرفوعًا من طريق النعمان بن بشير عن النبي -ﷺ- أنه قال في هذه الآية: ""الضُّرَباء كل رجل مع كل قوم كانوا يعملون عمله"" {30}. (وهذا معنى قول مجاهد) {7}: {32} الأمثال من الناس جمع بينهم {33}.(وحكى أبو إسحاق قولًا فقال) {34}: وقرنت النفوس بأعمالها {35}. قوله (تعالى) {7}: ﴿وَإِذَا الْمَوْءُودَةُ﴾ هي مفعولة من الوأد، (وكانت العرب إذا ولدت لأحدهم بنت، دفنها حية مخافة العار، أو الحاجة، يقال وأد يئد وأدًا فهو وائد، والمفعول به موءود. قال الفرذدق {37}:ومنا الذي مَنَع الوائدات ... فأحيا الوئيدَ فلم تُؤْد) {38} {39} هذا قول جميع أهل اللغة {40}."
  81,8,""
  81,9,"وقوله: ﴿سُئِلَتْ (8) بِأَيِّ ذَنْبٍ قُتِلَتْ﴾ قال (عطاء) {1} عن ابن عباس {2}، (ومقاتل {3} {1}: تسأل {5} قاتلها يوم القيامة بأي ذنب قتلها، وهي لم تذنب.قال الفراء: معنى ""سئلت"": سئل عنها الذين وأدوها، كأنك قلت: طلبت منهم، فقيل: أين أولادكم، فبأي ذنب قتلتموهم، وذكر وجهًا آخر، وهو: أن يكون المسؤول: ""هي"" على معنى: سئلت الموؤدة فقيل لها: ""بأي ذنب قتلت؟ ""، ثم يجوز قتلت، كما تقول: سألته بأي ذنب قتل، وبأي ذنب قتلت {6}.قال أبو إسحاق: ومعنى سؤالها تبكيت قاتلها في القيامة، لأنها تقول: قُتلت بغير ذنب، قال: ومثل هذا {7} التبكيت قوله عَزَّ وَجَلَّ: ﴿أَأَنْتَ قُلْتَ لِلنَّاسِ اتَّخِذُونِي﴾ .. الآية [المائدة: 116] وسؤاله وجوابه تبكيت لمن ادعى له، ولأمه الإلهية {8}."
  81,10,"﴿وَإِذَا الصُّحُفُ﴾ {1} يعني صحائف بني آدم نشرت.قال مقاتل: إن المرء إذا مات طويت صحيفة {2} أعماله، فإذا كان يوم القيامة نشرت، فتعطيهم الحفظة منشورة {3}، ونحو هذا قال المفسرون {4}: نشرت للحساب."
  81,11,"قوله (تعالى) {1}: ﴿وَإِذَا السَّمَاءُ كُشِطَتْ﴾ (معنى الكَشْطِ في اللغة: رَفْعُك شيئًا عن شيء قد غطاه وغَشِيَه، كما يُكْشَطُ {2} الجلد عن السَّنام، وذلك الجلد يسمى كِشاطًا بعدما يُكْشَط) {3}.قال ابن عباس: يريد: يكشط عمن {4} فيها كما يكشط الجلد كن الكبش {5}.وقال مقاتل: تكشف عمن فيها {6}.وقال الفراء: نزعت فطويت {7}. وقال الزجاج: قُلِعَت كما يُقلع السقف {8}.وقال أهل المعاني: الكشط قلع عن شدة التزاق {9}، وتقلع السماء عن مكانها على شدة وثاقتها {10}."
  81,12,"﴿وَإِذَا الْجَحِيمُ سُعِّرَتْ﴾ أوقدت لأعداء الله من الكفار {1}."
  81,13,"﴿وَإِذَا الْجَنَّةُ أُزْلِفَتْ﴾ قربت {1} لأولياء الله من المتقين، (قاله ابن عباس {2}، ومقاتل) {3} {4}وجواب هذه الأشياء: قوله (تعالى) {5}: ﴿عَلِمَتْ نَفْسٌ مَا أَحْضَرَتْ (14)﴾ أي إذا كانت هذه الأشياء التي هي للقيامة علمت في ذلك الوقت كل نفس ما أحضرت من خير أو شر، فيجزى به {4}."
  81,14,""
  81,15,"(ثم) {1} أقسم فقال: ﴿فَلَا أُقْسِمُ﴾ {2} والمعنى: فأقسم، وقد تقدم القول في ""لا"" و""أقسم"" في مواضع {3}."
  81,16,"قوله (تعالى) {1}: ﴿بِالْخُنَّسِ (15) الْجَوَارِ الْكُنَّسِ﴾ أكثر المفسرين على أن المراد بها النجوم، وهو قول علي {2} (رضي الله عنه) {3}، وابن عباس (¬12) في رواية عكرمة، ومقاتل {4}، وقتادة {5}، (وابن زيد {6}، ومجاهد {7}، والحسن) {8} {9}.وعلى هذا: الخنس: جمع خانس، (والخنوس: إلانقباض، والاستخفاء، تقول: خَنَس من بين القوم، وانْخَنَسَ من الحديث: ""الشيطان يوسوس {10} إلى العبد، فإذا ذكر الله خنس"" {11}، أي انقبض منه، ولذلك سمي الخناس) {12}.(والكُنَّس: جمع كانس، وكانسة، يقال: كنس إذا دخل الكِناس، وهو مولج الوحش، يقال: كَنَسَتِ الظباءُ في كنسها، وتكنست، ويقال: تكنست المرأة إذا دخلت هودجها، تشبه بالظبي إذا دخل الكناس، ومنه قول لبيد:شاقَتْكَ ظُعْنُ الحيِّ يومَ تَحمَّلوا ... فَتَكنَّسوا قُطُنًا تَصِرُّ خِيامُها) {13} {14}واختلفوا في خنوس النجم وكنوسها، فقال علي-رضي الله عنه-: النجوم {15} تخنس بالنهار فتخفى، ولا ترى، وتكنس في وقت غروبها {16}.ومعنى تخنس، على {17} هذا القول، تتأخر عن البصر، فلا ترى.وقال الفراء: خنوسها أنها تخنس في مجراها وترجع {18}.قال الليث: الخنس: الكواكب الخمسة، تخنس الأحيان راجعة حتى تخفى تحت ضوء الشمس، فلا ترى {19}.وجعل الزجاج خنوسها، وكنوسها: أن تغيب في مواضعها التي تغيب فيها إذا غابت {20}.وقال عبد الله: هي بقر الوحش {21}. (وهو قول إبراهيم) {22} {9}. وقال سعيد بن جبير: هي الظباء {24}.وعلى هذا: الخنس من (الْخَنَسِ في الأنف، وهو تأخُّر الأرنبة، وقصر القصبة، والبقرة، والظباء أنوفهن خنس، والبقر خنساء {25}، والظبي أخنس) {26}، ومنه قول لبيد يذكر بقرة:خَنْساءُ ضَيَّعَتِ الفَريرَ فَلَمْ يَرِم ... عُرْضَ الشَّقائقِ طَوْفُها وبُغامُها {27} {28}والكنس: جمع كانس، وهي التي تدخل الكِناس، والقول هو الأول {29}.وهو اختيار الفراء {30}، والكسائي {19}، (وأبي عبيدة {32}، والمبرد {33}، وابن قتيبة) {34} {35}، وذلك أن الخُنَّسَ جمع خانس من الخنوس، وجمع خنساء، وأخنس من الخنس، خنْس بالسكون، والتخفيف، ولا يقال فيه الخنس بالتشديد، إلا أن يجعل الخنس في الوحشية أيضًا من الخنوس، وهو اختفاؤها في الكناس إذا غابت عن الأعين {36}.واحتج أبو إسحاق على أن المراد به النجوم، فقال: ﴿وَاللَّيْلِ إِذَا عَسْعَسَ﴾ وهذا أليق بذكر النجوم منه بذكر الوحش {37}.وأكثر المفسرين قالوا في: ""عسعس"" أنه: ولى، وذهب، وأدبر، وهو قول عطاء {38}، (والكلبي) {39} {9} عن ابن عباس، (ومقاتل {19}، ومجاهد {42}، والضحال {43}، وابن زيد {44}، وهو قول قتادة {45}، وعلي {46} (رضي الله عنه) {9}.وقال الحسن: عسعس (الليل إذا) {9} أقبل بظلامه {49}.(وروي ذلك عن مجاهد) {50} {9}.وأهل اللغة ذكروا القولين أيضًا في عسعس، وذهبوا إلى أن الحرف من الأضداد، وهو قول أبي عبيدة {52}، وأبي حاتم {53}، (وقطرب) {54} {9}، والفراء {30}، (والزجاج) {20} {9}، (قالو: عسعس الليل: إذا أقبل {59}، وعسعس إذا أدبر، وأنشد أبو عبيدة:مُدَّرِعاتِ الليلِ لَمِّا عَسْعَسا {60}أي أقبل.وقال الزِّبْرِقان {61}:وَرَدْتُ بِأفْراسٍ عِتاقٍ وَفِتْيَةٍ ... [فوارِطَ] {62} في أعْجازِ ليلٍ مُعِسْعسِ {63} أي مدبر مولي) {64}.(وروى أبو العباس {65}، عن) {9} ابن الأعرابي: العَسْعسة: ظلمة الليل كله، ويقال: إقباله وإدباره، (قال أبو العباس: هذا هو الاختيار {67} {9}، ويدل على أن المراد: أدبر."
  81,17,""
  81,18,"قوله: ﴿وَالصُّبْحِ إِذَا تَنَفَّسَ﴾أي امتد ضوؤه.ويقال: تنفس النهار؛ إذا امتد بطوله، ومعنى التنفس: (خروج النسيم من الجوف {1}.قال ابن عباس {1}، والمفسرون {3}: يريد طلوع الفجر إذا أضاء ثم زاد واستعرض في السماء.قال الفراء: إذا ارتفع النهار فهو تنفس الصبح) {4} {5}.(وقال الزجاج: تنفس) {5}:إذا امتد حتى يصير نهارًا بينًا {7}. وأنشد (أبو عبيدة) {5} لعلقمة بن قرط:حتى إذا الصبحُ لها تَنَفَّسا ... وانجاب عنها ليلُها فَعَسْعَسا {9} {10}وحكى الأزهري: إذا تنفس: إذا انشق وانفلق حتى يتبين، ومنه يقال: تنفَّست القوس: إذا تصدَّعَت {11}، والنَّفْس {12}: الشَّقُّ في القِدح، والقَوْس، وما أشبهها. ذكره اللحياني {13} {14}."
  81,19,"ثم ذكر جواب القسم، وهو قوله: ﴿إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾ يعني جبريل عليه السلام في قول الجميع {1}.والمعنى: إن القرآن نزل به جبريل، وأخبر محمدًا به عن الله.وهذه الآية مفسرة في سورة الحاقة {2}."
  81,20,"ثم وصف جبريل فقال: ﴿ذِي قُوَّةٍ﴾ {1} أي فيما كلف وأمر به.وذكر ابن عباس من قوته: رفعه مدائن لوط بجناحيه من الأرض إلى السماء {2}.وذكر مقاتل من قوته: أن شيطانًا يقال له: الأبيض، صاحب الأنبياء، قصد أن يفتن النبي -ﷺ- فدفعه جبريل دفعة (هينة) {3} [فوقع] {4} بها من مكة إلى أقصى الهند {5}. وقوله {6} (عَزَّ وَجَلَّ) {7}: ﴿عِنْدَ ذِي الْعَرْشِ مَكِينٍ﴾قال الكلبي {8}، ومقاتل {8}: يعني في المنزلة، يعني: هو وجيه عند الله.وقال الكسائي: يقال: قد مَكُن فلان عند فلان -بضم الكاف- مكنًا ومكانة {10}."
  81,21,"﴿مُطَاعٍ﴾ {1} تطيعه الملائكة. ﴿ثَمَّ﴾ أي في السماء. وذكر ابن عباس {2}، والمفسرون {3}:من طاعة {4} الملائكة لجبريل أنه أمر خازن الجنة ليلة المعراج حتى فتح لمحمد -ﷺ- أبوابها فدخلها، [ورأى] {5} ما فيها، وأمر خازن جهنم فقال له: افتح لمحمد -ﷺ- عن جهنم حتى ينظر إليها، فأطاعه مالك فذلك قوله: ""مطاع"".(ثم أمين) على وحي الله (عَزَّ وَجَلَّ) {6} ورسالته وأنبيائه."
  81,22,"﴿وَمَا صَاحِبُكُمْ (بِمَجْنُونٍ) {1}﴾ يعني محمدًا -ﷺ-، والخطاب لأهل مكة، وهذا أيضًا من جواب القسم، أقسم الله: أن القرآن نزل به جبريل، وأن محمدًا ليس كما تقوله أهل مكة، وذلك أنهم قالوا: إن محمدًا مجنون، وهذا الذي يأتي به تقوله من تلقاء نفسه، وقد ذكر الله ذلك عنهم في قوله: ﴿وَقَالُوا يَا أَيُّهَا الَّذِي نُزِّلَ عَلَيْهِ الذِّكْرُ﴾ [لحجر: 6] الآية. وكذبهم الله فيما قالوا بقوله: ﴿ن وَالْقَلَمِ﴾ إلى قوله: ﴿بِمَجْنُونٍ﴾ [القلم: 1 - 2]، وبقوله: ﴿وَمَا صَاحِبُكُمْ بِمَجْنُونٍ﴾."
  81,23,"قوله تعالي {1}: ﴿وَلَقَدْ رَآهُ﴾ {2} يعني رأى محمد {3} جبريل (عليهما السلام) {4} بالأفق المبين، يعني حيث تطلع الشمس في قول الجميع {5}، وهذا مفسر في سورة ""والنجم"" {6}.ثم (أخبر) {4} أن القرآن الذي يأتي به ليس من {8} تلقاء نفسه، ولا هو بمتهم في ذلك، وهو قوله:"
  81,24,"﴿وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ﴾ {1} معنى الغيب -هاهنا- القرآن، وما أنزل الله عليه، في قول الجميع، قالوا: هو الوحي وخبر السماء، وما اطلع عليه بعلم الغيب الذي (كان) {2} غائبًا عن أهل مكة من الأنبياء والقصص {3}والعرب لم تكن تعرف ذلك؛ لأنهم لم يكونوا أهل الكتاب.(والظنين {4}: المتهم، يقال: ظننت زيدًا في معنى: اتهمت {5}، ليس من الظن الذي يتعدى إلى مفعولين) {6}، وأنشد (أبو عبيدة) {7} {2}:أمَا وكتاب الله لا عن شناءة ... هجرت ولكنَّ الظنين ظنين {9} قال جماعة من المفسرين {10}:ما محمد على القرآن (بمتهم) {2}، أي هو ثقة فيما يؤدي عن الله تعالي.(ومن قرأ: ""بضنين {12} "" -بالضاد {13} - فهو من البخل، يقال: ضننت به أضَنُّ، أي بخلت) {14}، وأنشد (أبو عبيدة {15} قول) جميل:أجودُ بمضنون التلاد وإنني ... بِسِرِّكِ عَمَّنْ سالني لَضَنينُ {16} قال ابن عباس: ليس ببخيل بما أنزل الله {17}.وقال مجاهد: لا يضن عليهم بما يعلم {18}.وقال الفراء: يقول: يأتيه غيب السماء، وهو منفوس فيه {19}، فلا يضن به عليكم {20}.وقال أبو إسحاق: أي هو يؤدي عن الله، ويُعَلِّم كتاب الله {21}.قال أبو علي الفارسي: المعنى أنه يخبر عن الغيب {22} فيبينه، ولا يكتمه كما يكتم الكاهن (ذلك) {2}، ويمتنع من إعلامه حتى يأخذ عليه حُلوانًا {24}. واختار أبو عبيد {25} القراءة الأولى لمعنيين {26}:أحدهما: أن الكفار لم يُبخّلوه، وإنما اتهموه، فنفي التهمة أولى من نفي البخل.والآخر: قوله: ""على الغيب"" ولو كان المراد بالبخل لقال: بالغيب؛ لأنه يقال: فلان ضنين بكذا، وقلّ ما يقال: على كذا {27} {28}."
  81,25,"ثم ذكر أنه ليس من تعليم الشيطان فقال: ﴿وَمَا هُوَ بِقَوْلِ شَيْطَانٍ رَجِيمٍ﴾. قال الكلبي: يقول: إن القرآن ليس بشعر، ولا كهانة، ولا قول شيطان كما قالت {1} قريش {2}.وقال عطاء: يريد الشيطان {3} الأبيض الذي كان يأتي النبي -ﷺ- في صورة جبريل يريد أن يفتنه {4}.وقال مقاتل: إن كفار مكة قالوا: إنما يجيء به ""الري"" وهو شيطان، فيلقيه على لسان محمد -ﷺ-. {5}"
  81,26,"ثم بكتهم فقال: ﴿فَأَيْنَ تَذْهَبُونَ﴾. قال الفراء: العرب تقول: إلى أين تذهب؟ وأين تذهب؟ ويقول: ذهبت الشام، وانطلقت السوق، وخرجت الشام، استجازوا في هذه الأحرف الثلاثة إلفاء (إلى) {1} لكثرة {2} استعمالهم إياها، وأنشد {3}: تَصيحُ بِنا حَنيفةُ إذْ رأتْنا ... وأيَّ الأرضِ تذهبُ بالصِّياحِ {4}أراد إلى أي الأرض {5}.قال المفسرون: أين تعدلون؟ وأين تذهبون عن كتابي يا أهل مكة {6}؟ قال أبو إسحاق: معناه وأي طريق تسلكون أبين من هذه الطريقة التي قد بينت لكم {7}.ثم بين أن القرآن ما هو، فقال:"
  81,27,"﴿إِنْ هُوَ إِلَّا ذِكْرٌ لِلْعَالَمِينَ﴾ يقول: ما القرآن إلا موعظة للخلق كلهم أجمعين {1}."
  81,28,"وقوله {1} (تعالى): ﴿لِمَنْ شَاءَ﴾ {2} بدل من قوله: ""للعالمين""وقوله {1} (تعالى) {4}: ﴿أَنْ يَسْتَقِيمَ﴾ أي على الحق، والإيمان، والإسلام {5}.والمعنى: إن القرآن إنما يتعظ به من استقام على الحق.قال المفسرون {6}: ثم رد {7} المشيئة إلى نفسه فقال:"
  81,29,"قوله تعالى: ﴿وَمَا تَشَاءُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ رَبُّ الْعَالَمِينَ﴾ قال أبو هريرة: لما أنزل الله: ﴿لِمَنْ شَاءَ مِنْكُمْ أَنْ يَسْتَقِيمَ﴾ قالوا: الأمر إلينا إن شئنا استقمنا {1}، وإن شئنا لم نستقم، فأنزل الله: ﴿وَمَا تَشَاءُونَ﴾ الآية {2}.قال {3} أبو إسحاق: أعلمهم أن المشيئة في التوفيق إليه، وأنهم لا يقدرون على ذلك إلا بمشيئة الله وتوفيقه {4}.وقوله: ﴿وَمَا تَشَاءُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ﴾ (وهذا إعلام أن (الإنسان) {5} لا يعمل خيرًا إلا بتوفيق من الله، ولا شرًا إلا بخذلانه، وأن الخير والشر بقضائه وقدره، يضل من يشاء، ويهدي من يشاء) {6}.. . . . . . . . . . . . . . . . . . . . . . . ."
