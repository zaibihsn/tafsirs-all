tafsir[42]{c,v,t}:
  80,1,"﴿عَبَسَ﴾ يعني النبي -ﷺ- {1} ﴿وَتَوَلَّى﴾ أعرض {2} ﴿أَنْ جَاءَهُ﴾ قال أبو إسحاق: ""أن"" في موضع نصب {3} مفعول له، المعنى: لأن جاءه الأعمى، وهو ابن مكتوم، أتى النبي -ﷺ- وعنده رهط {4} من أشراف قريش، وهو مقبل عليهم يدعوهم إلى الله و (إلى) {5} الإسلام، وفرح أن يجيبوه إلى ذلك، إذا أتى ابن أم مكتوم الأعمى {6}، فجعل يناديه ويقول: يا رسول الله، علمني مما علمك الله، يعني القرآن والإسلام، ويكرر {7} ذلك، ولا يدري أنه مشتغل عنه بغيره، فكلح {8} النبي -ﷺ- وأعرض عنه، وظهرت في وجهه الكراهة، فأنزل الله عَزَّ وَجَلَّ هذه الآيات {9}.(وهذا قول جماعة المفسرين) {10} {5}."
  80,2,"80:1"
  80,3,"قوله (تعالى) {1}: ﴿وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّى﴾ قال الكلبي: يصلح فيعمل خيرًا {2}، قال الفراء: أي بما أراد أن يتعلمه من علمك {3}.والمعنى: يتطهر من الذنوب بالعمل الصالح، والانتفاع بما يتعلم منك.وذهب بعض المفسرين إلى أن المعنى: يتطهر من الشرك بالإسلام.وهو قول: ابن زيد {4}، (ومعنى قول عطاء) {5} {6}. والصحيح هو الأول؛ لأنه كان قد آمن (من) {2} قبل هذه القصة قاله الكلبي {8}."
  80,4,"قوله تعالى: ﴿أَوْ يَذَّكَّرُ﴾ أي يتذكر فيتعظ بما يعلمه من مواعظ القرآن. ﴿فَتَنْفَعَهُ الذِّكْرَى﴾ الموعظة.(وقراءة العامة الرفع في: (فتنفعُه {1}) بالعطف على ما تقدم من المرفوع، ومن نصب {2} فعلى جواب لعل {3} كقوله: ﴿لَعَلِّي أَبْلُغُ الْأَسْبَابَ * فَأَطَّلِعَ﴾ [غافر: 36 - 37] و""أطلع"" {4} {5} -وقد مر {6}."
  80,5,"(قوله تعالى) {1}: ﴿أَمَّا مَنِ اسْتَغْنَى﴾ قال عطاء: يريد عن الإيمان {2}.وقال الكلبي {3}، ومقاتل {4}: استغنى عن الله في نفسه، -وذكر أيضًا- ""استغنى"": أثرى {5}.وهو فاسد- هاهنا- لأن إقبال النبي -ﷺ- لم يكن لثروتهم ومالهم، حتى يقال له: أما من أثرى فأنت تقبل عليه؛ ولأنه قال: ﴿وَأَمَّا مَنْ جَاءَكَ يَسْعَى (8) وَهُوَ يَخْشَى﴾، ولم يقل وهو فقير عديم.وأما من قال استغنى بماله {6}، فهو صحيح؛ لأن المعنى أنه استغنى عن الإيمان والقرآن بماله من المال."
  80,6,"وقوله {1} تعالى: ﴿فَأَنْتَ لَهُ تَصَدَّى﴾ قال مقاتل {2}، والكلبي {3}: تقبل عليه بوجهك. (ونحو هذا قال الزجاج: أنت تقبل عليه {4} {5}.وقال أبو عبيدة: ""تصدى"" تعرض {6}.وقال أبو الهيثم: ""فأنت له تصدى"" معناه تتعرض له، وتميل إليه، وتقبل عليه، يقال: تصدى فلان لفلان يتصدّى، إذا تعرض له، وهو ما استقبلك فصار {7} قُبَالَتَك {8}.وقد ذكرنا مثل هذا في قوله: ﴿إِلَّا مُكَاءً وَتَصْدِيَةً﴾ {9}.وفيه قراءتان: التشديد على الإدغام {10}، ............والتخفيف على الحذف {11}."
  80,7,"وقوله: ﴿وَمَا عَلَيْكَ أَلَّا يَزَّكَّى﴾ قال ابن عباس: يريد ألا يهتدي، ولا يؤمن {1}.والمعنى: أي شيء عليك في أن لا يسلم من تدعوه إلى الإسلام، فإنه ليس عليك إلا البلاغ، أي لا يبلغن بك الحرص على إسلامهم إلى أن تعرض عمن أسلم للاشتغال بدعوتهم."
  80,8,"قوله (تعالى) {1}: ﴿وَأَمَّا مَنْ جَاءَكَ يَسْعَى (وَهُوَ يَخْشَى) {1}﴾ قال ابن عباس، والكلبي، ومقاتل {3}: يسعى في الطلب لرضاء الله، والعمل في الخير وما يرضي الله."
  80,9,"﴿وَهُوَ يَخْشَى﴾ الله عَزَّ وَجَلَّ يعني ابن أم مكتوم."
  80,10,"(قوله تعالى) {1}: ﴿فَأَنْتَ عَنْهُ تَلَهَّى﴾ قال مقاتل {2}، والكلبي {3}: تعرض عنه بوجهك.قل أبو إسحاق معناه: تتشاغل، يقال: لهيت عن الشيء، وألهى عنه إذا تشاغلت عنه {4}."
  80,11,"ثم وعظ نبيه -ﷺ- فقال: ﴿كَلَّا﴾ هو، وهو ردع وزجر {1}.قال مقاتل: لا تقبل على من استغنى، وتعرض عمن يخشى {2}. ثم استأنف فقال:(قوله تعالى) {3}: ﴿إِنَّهَا تَذْكِرَةٌ﴾ (لمن يخشى) {3} قال مقاتل: يعني أنها آيات القرآن {5}.وقال الكلبي: يعني هذه السورة {6}. (وهو قول الأخفش {7}، والفراء {8}) {9}."
  80,12,"قوله: ﴿فَمَنْ شَاءَ ذَكَرَهُ﴾ يعني الوحي، والقرآن {1}.وقال صاحب النظم: ""إنها تذكرة"" يعني به القرآن، والقرآن مُذَّكرٌ؛ إلا أنه لما جعل القرآن تذكرة، أخرجه على لفظ التَّذكِرة، ولو ذَكَّرَهُ لجاز، كما قال في موضع آخر: ﴿كَلَّا إِنَّهُ تَذْكِرَةٌ﴾ [المدثر:54] ويدل على (أن قوله) {2}: ""إنها تذكرة"" يراد به: القرآن، قوله: ﴿فَمَنْ شَاءَ ذَكَرَهُ﴾ {3}.والمعنى: القرآن موعظة وتذكير، فمن شاء ذكره.قال ابن عباس {4}، ومقاتل {5}: فمن شاء ألهمه، وفهمه القرآن حتى يذكر ويتعظ به.ثم أخبر عَزَّ وَجَلَّ بجلالة الكتاب في اللوح المحفوظ عنده فقال:"
  80,13,"﴿فِي صُحُفٍ مُكَرَّمَةٍ﴾ قال المفسرون {1}: يعني اللوح المحفوظ."
  80,14,"﴿مَرْفُوعَةٍ﴾ قالوا {1}: في السماء السابعة.﴿مُطَهَّرَةٍ﴾ لا يمسها إلا المطهرون، وهم الملائكة {2}، ويجوز أن يكون المعنى القرآن، أُثبت في صحف الملائكة يقرؤونها {3}، فتلك الصحف هي: المكرمة، المرفوعة: الرفيعة القدر. يدل على هذا المعنى،"
  80,15,"فقال: ﴿بِأَيْدِي سَفَرَةٍ﴾قال المفسرون: هم الكتبة من الملائكة، وهو قول ابن عباس {1}، (ومقاتل) {2} {3}، ومجاهد {4}، وقتادة {5}قال أبو إسحاق: السفرة الكتبة، يعني بهم الملائكة، واحدهم: سافر، مثل كاتب، وكتبة، وإنما قيل [للكتاب] {6} سِفر؛ لأن معناه أنه يبين الشيء ويوضحه، يقال: سفرت المرأة، إذا كشفت عن وجهها {7}.وجعل الفراء: السفرة -هاهنا- الملائكة الذين يَسفِرون بالوحي بين الله وبين رسله، فقال: واحد السفرة: سافر، والعرب تقول: سفرت بين القوم، إذا أصلحت بينهم، فجعلت الملائكة إذا نزلت بالوحي وتأديبه كالسفير الذي يصلح بين القوم، وأنشد {8}:وما أدعُ السِّفارةَ بينَ قومي ... وما أمْشي بِغِشٍّ إنْ مَشَيْتُ {9} وأصل السفارة من الكشف {10}، -أيضًا- قال الزجاج: سفرت بين القوم، أي كشفت ما في قلب هذا، وقلب هذا، لأصلح بينهم {11}."
  80,16,"ثم أثنى على السفرة: قوله تعالى: ﴿كِرَامٍ﴾ قال مقاتل: يعني مسلمين {1}. وقال الكلبي: كرام على ربهم {2}.وقال عطاء: يريد أنهم يتكرمون أن يكونوا مع بني آدم، إذا خلا مع زوجته للجماع، وعند الغائط {3}.﴿بَرَرَةٍ﴾ قال مقاتل: مطيعين {4}.(وبررة: جمع بار {5}، -قال الفراء-: لأن العرب لا يقولون: فَعَلة يريدون به الجمع إلا والواحد منه فاعل، مثل: كافر، وكفرة، وفاجر، وفجرة) {6}.قال مقاتل: كان ينزل بالقرآن {7} من اللوح المحفوظ إلى السماء الدنيا ليلة القدر إلى الكتبة من الملائكة، ثم ينزل جبريل إلى محمد -ﷺ- {8}."
  80,17,"(قوله تعالى) {1}: ﴿قُتِلَ الْإِنْسَانُ (مَا أَكْفَرَهُ) {2}﴾ هو قال ابن عباس: لعن عتبة {3}.قال المفسرون: نزلت في (عتبة بن) {1} أبي لهب {5}.﴿مَا أَكْفَرَهُ﴾ قال مقاتل {6}، الكلبي {7}: ما الذي أكفره.وقال {8} الفراء: بهذا الوجه جاء التفسير {9}، ويجوز أن يكون تعجبًا {10}.وشرح الزجاج القولين، فقال: يكون على جهة لفظ التَّعّجُّبِ، ومعنى التعجب [مما] {11} يؤمر به الآدميون كقوله: ﴿فَمَا أَصْبَرَهُمْ عَلَى النَّارِ﴾ [البقرة: 175] أي اعْجَبوا أنتم من كفر الإنسان.(قال) {1}: ويجوز أن يكون على معنى التوبيخ {13}، ولفظه لفظ الاستفهام، أي: أيُّ شيء أكفره؟ {14}."
  80,18,"(ثم بين من أمْره ما كان ينبغي أن يعلم معه أن الله خالقه، وأنه واحد، فقال: ﴿مِنْ أَيِّ شَيْءٍ خَلَقَهُ﴾ لفظه استفهام، ومعناه التقرير) {1}."
  80,19,"ثم فسر فقال: ﴿مِنْ نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾ قال ابن عباس {1}، ومقاتل {2}: يقدره في بطن أمه.وهذا يحتمل معنيين: أحدهما: ما ذكره الفراء: وقدره أطوارًا: نطفة، علقة إلى آخر خلقه، ذكرًا، أو أنثى، شقيًا، أو سعيدًا {3}.والثاني: ما ذكره الزجاج قال: المعنى: فقدره على الاستواء، كما قال: ﴿أَكَفَرْتَ بِالَّذِي خَلَقَكَ مِنْ تُرَابٍ ثُمَّ مِنْ نُطْفَةٍ ثُمَّ سَوَّاكَ رَجُلًا﴾ [الكهف: 37]. {4}وهذا معنى قول الكلبي: (قدر خلقه، ورأسه، وعينيه، ويديه، ورجليه {5} {6}."
  80,20,"قوله: ﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾ (قال الحسن {1}، ومجاهد {2}، وعطاء {3} {4}، والكلبي {5} {1}: بين له سبيل الخير، والشر كقوله: ﴿إِنَّا هَدَيْنَاهُ السَّبِيلَ﴾ [الإنسان: 30] أي أعلمناه طريق الخير والشر.قال السدي {7}، ومقاتل {8}: أي أخرجه من الرحم، وهداه للخروج من بطن أمه."
  80,21,"﴿ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ﴾ هو قال مقاتل {1}، (والكلبي) {2} {3} أمر به فقبر.قال أبو عبيدة: [أمره] {4} بأن يُقبر، [أي: جعل، له قبرًا -قال- وقالت بنو تميم: لعمر بن هبيرة {5} لما قتل صالح بن عبد الرحمن {6}: أقبرنا صالحًا، قال: دونكموه. والذي يدفن هو القابر {7}.وقال ابن السكيت: أقبرت فلانًا، أي صيرت له قبرًا يدفن فيه {8}.([أقبره] {9} جعله مقبورًا، ولم يجعله ممن يُلقى للطير، والسباع، ولا ممن يلقى في النواويس {10}، كأن القبر مما أكرم به المسلم.قال: ولم يقل: فقبره، لأن القابر هو الدافن بيده، والمقبر هو الله؛ لأنه صيره ذا قبر، وليس فعله كفعل الآدمي، والعرب تقول: بترت ذنب البعير، والله أبتره، وعضبت {11} قرن الثور، والله أعضبه، وطردت فلانًا عني، والله أطرده: صيره طريدًا) {12}."
  80,22,"قوله: ﴿ثُمَّ إِذَا شَاءَ أَنْشَرَهُ﴾ (أي بعثه بعد موته، يقال: أنشر الله الميت فنشر) {1}."
  80,23,"﴿كَلَّا﴾ {1} قال (عطاء عن) {2} ابن عباس: يريد لا يؤمن الكافر أن الله يبعثه {3}. وقال الحسن: حقًا {4}.﴿لَمَّا يَقْضِ مَا أَمَرَهُ﴾ أي: ما عهد إليه من الميثاق الأول في التوحيد، وهو قول عطاء، عن ابن عباس {5}، ومقاتل {6}.وقال الكلبي: ليس أحد قضى ما أمره الله به {3}.وعلى هذا هو على العموم؛ لأنه لم يقض أحد من الخلق كل ما أمر به {8}.ولما ذكر خلق ابن آدم ذكر رزقه ليعتبر فقال:"
  80,24,"(قوله تعالى) {1}: ﴿فَلْيَنْظُرِ الْإِنْسَانُ إِلَى طَعَامِهِ﴾ (أي فلينظر كيف خلق الله طعامه الذي جعله سببًا لحياته) {2}.(والمعنى: إلى كونه وحدوثه وهو موضع الاعتبار) {3}."
  80,25,"ثم بين فقال: ﴿أَنَّا صَبَبْنَا الْمَاءَ صَبًّا﴾ قال الفراء: يخبر عن صفة الطعام بالاستئناف {1}، ومن فتح ""أنَّا"" فهو في موضع خفض {2}. أي: فلينظر إلى أنا صببنا الماء، وفعلنا، وفعلنا.قال: وكذلك قوله: ﴿فَانْظُرْ كَيْفَ كَانَ عَاقِبَةُ مَكْرِهِمْ أَنَّا دَمَّرْنَاهُمْ﴾ {3} و""إنا دمرناهم"" {4}.قال: قد يكون موقع ""أنا"" إذا فتحت في هذه السورة، رفعًا كأنه استئناف، فقال: طعامه صببنا الماء، وإنباتُنا كذا وكذا {5}.قال أبو إسحاق: من قرأ ""إنَا"" فعلى الابتداء والاستئناف، ومن فتح فعلى معنى البدل من الطعام، ويكون ""إنا"" في موضع خفض. المعنى: فلينظر الإنسان إلى {6} إنا صببنا الماء {7}.وقال أبو علي: من قال ""إنا صببنا"" بكسر ""إن"" كان ذلك تفسيرًا للنظر إلى طعامه، كما أن قوله ""مغفرة"" {8} تفسيرًا للوعد، ومن فتح فعلى معنى البدل بدل الاشتمال؛ لأن هذه الأشياء تشتمل على كون الطعام وحدوثه، فهو من نحو ﴿يَسْأَلُونَكَ عَنِ الشَّهْرِ الْحَرَامِ قِتَالٍ فِيهِ﴾ [البقرة: 217]، و ﴿قُتِلَ أَصْحَابُ الْأُخْدُودِ (4) النَّارِ﴾ [البروج: 4 - 5] {9}، قال ابن عباس {10}، والمفسرون {11}: أراد بصب الماء: المطر."
  80,26,"﴿ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا﴾ بالنبات {1}."
  80,27,"﴿فَأَنْبَتْنَا فِيهَا حَبًّا (27) وَعِنَبًا﴾ يعني الحبوب كلها مما يتغذى به {1}.﴿وَقَضْبًا﴾ أكثر أهل اللغة، والتفسير قالوا: القضب: الرَّطْبة، وهي الفِسْفِسة ما دامت خضراء، فإذا يبست فهو القت {2}، وأهل مكة يسمونه القضب أيضًا، وأصله من القطع {3}؛ (وذلك أنه يقطع ويُقضَب مرة بعد أخرى، وكذلك الفصيل {4}؛ لأنه يفصل أي يقطع) {5}، وهذا قول أبي عبيدة {6}، والفراء {7}، (والأصمعي {8}، وابن عباس {9}، والضحاك {10}، ومقاتل) {11} {12}.قال المبرد: القضب هو العلف بعينه، وأصله من أنه يقضب، أي يقطع {13}.وهو قول الحسن {14} {15}."
  80,28,"80:27"
  80,29,""
  80,30,"قوله (تعالى) {1}: ﴿غُلْبًا﴾ {2} قال عطاء عن ابن عباس: يريد الشجر العظام {3}.وقال الكلبي: غلاظًا طوالًا في السماء {4}.وقال عكرمة: غلاظ الرقاب، ألا ترى أن الرجل إذا كان غليظ الرقبة، قالوا: إنه لأغلب {5}.قال أبو عبيدة يقال: شجرة، ونخلة غلباء، إذا كانت غليظة {6}.قال الفراء: الغُلْب: ما غلُظ من النخل {7}.وقال ابن قتيبة: الغُلب: الغلاظ الأعناق؛ الواحد أغلب، يعني النخل {8}.وعلى هذا القول هو (من الغَلِب، وهو [غليظ] {9} القَصَرة، يقال: أسدٌ أغلب.وفيه قول آخر: وهو قول مجاهد {10}، ومقاتل {11}، قالا: الغلب: الملتفة الشجر بعضه في بعض، يقال: اغْلَوْلَبَ العُشْبُ، واغْلَوْلبت الأرض، إذا التفّ عُشبها) {12}.وذكر أبو إسحاق القولين، فقال: معناه متكاثفة {13} عظامًا {14}.قوله: (وفاكهة (وأبا) {15}). (قال الكلبي يعني: ألوان الفاكهة) {16} {15}.(وأبا) {15} قال ابن عباس: يريد ما أنبتت الأرض مما لم يزرعه الناس {19}.وقال الكلبي: يعني الكلأ {20} كله {21}. وقال مقاتل: يعني المرعى {22}وقال عطاء: الفاكهة ما يأكلون، والأب: ما تأكل أنعامكم {23}.وقال أبو زيد: الأب: النبات {24}. وقال الضحاك: الأب: التبن {25}.وقال الحسن: ما طاب واحلولى فلكم، والأب لأنعامكم {26}.وروى عاصم بن كُلَيب {27} عن أبيه {28} عن ابن عباس: فـ""أبا""، قال: ما أنبتت الأرض مما لا يأكل الناس {29}.وروى عنه سعيد بن جبير: ما أنبتت الأرض مما يأكل الأنعام {30}. وقال مجاهد: هو ما أكلت الأنعام {31}.هذا ما ذكره المفسرون في تفسير الأب {32}، وأما أهل اللغة فقال أبو عبيدة: الأب: كل مرعى للهوام {33}. أي البهائم. وأنشد لذي الرمة:أنبت أبًا ناضرًا وأمرعا {34}وقال الفراء: الأب: ما تأكله الأنعام {35}.قال أبو إسحاق: الأب [جميع] {36} الكلأ الذي تأكله الماشية {14}.وأنشد {38}: جِذْمُنا قيْسٌ {39} ونجدٌ أرضنا ... ولنا الأبُّ بها والمكرَعُ {40}(وذكر الله تعالى (ما يدل) {15} على وحدانيته (من إنشاء) {15} ما يغذو {43} به جميع الحيوان، وهو:قوله (تعالى) {1}: ﴿مَتَاعًا لَكُمْ وَلِأَنْعَامِكُمْ﴾ {45} قال المفسرون {46}: يريد منافع لكم، ولأنعامكم.وقال الفراء: خلقناه منفعة لكم، ومتعة لكم ولأنعامكم {47}.قال الزجاج: هو منصوب؛ لأنه مصدر مؤكد لقوله: ""فأنبتنا"" {48} لأن إنباته الأشياء إمتاع لجميع الحيوان {49} {14}.ثم ذكر القيامة فقال:"
  80,31,""
  80,32,"80:31"
  80,33,"﴿فَإِذَا جَاءَتِ الصَّاخَّةُ﴾ قال المفسرون: يعني صيحة القيامة {1}، وهي النفخة الأخيرة.قال اللبث: الصاخة: صيحة تصُخُّ الآذان فَتُصِمُّها {2}. وذكر نحو هذا الزجاج في تفسير الصاخة {3}. وأصل الصخ في اللغة: الطعن والصك {4}.قال المبرد: يقال: صخ رأسه بحجر، أي: شدخه {5}، والغراب يصخ بمنقاره في دبر البعير أي يطعن {6}.فمعنى الصاخة: الصاكة لشدة صوتها للآذان {7}. ثم ذكر في أي وقت تجيء فقال:"
  80,34,"﴿يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ (34) وَأُمِّهِ وَأَبِيهِ (35) وَصَاحِبَتِهِ وَبَنِيهِ﴾، أي لا يلتفت إلى واحد من أدانيه {1}؛ لعظم ما هو فيه.وقال أبو علي: ليس يراد بالفرار -هاهنا- الشراد، ولا النفار {2}، ولكن المعنى: يوم يفر المرء من موالاة أخيه، أو من مساءلة {3} أخيه؛ لاهتمامه بشأنه، وأنت تقول لمن تكلم {4}: فررت مما ألزمك {5}، لا تريد بذلك نفارًا في المحل {6}، فأما الفرار من موالاته يدل عليه قوله: ﴿إِذْ تَبَرَّأَ الَّذِينَ اتُّبِعُوا مِنَ الَّذِينَ اتَّبَعُوا﴾. [البقرة: 166]وأما الفرار من نصرته، [فيدل] {7} عليه: ﴿يَوْمَ لَا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا وَلَا هُمْ يُنْصَرُونَ﴾ [الدخان: 41].وأما المساءلة يدل عليه قوله: ﴿وَلَا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾ [المعارج: 10] {8}قوله (تعالى) {9}: ﴿لِكُلِّ امْرِئٍ مِنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ﴾ قال المفسرون {10}: لكل إنسان منهم شأن (يغنيه) {11}، يشغله عن الأقرباء.قال ابن قتيبة: يغنيه: أي {12} يصرفه، ويصده عن قرابته، وأنشد {13}:ستغنيك حرب بني مالك ... عن الفحش والجهل في المحفل {14}قال: أي: سيشغلك، ويقال: اغنِ عني وجهك، أي [اصرفه {15}]. {16}وقال أهل المعاني: معنى يغنيه: يكفيك {17} عن زيادة عليه من الاهتمام لغيره.أي: ليس فيه فضل لغير ما هو فيه من الأمر الذي قد اكتنفه، وما أصدره، فصار حاله كحال الغني عن الشيء في أن نفسه لا تنازع إليه {18}."
  80,35,"80:34"
  80,36,"80:34"
  80,37,""
  80,38,"ثم وصف أحوال المؤمنين والكفرين في ذلك اليوم، فقال: ﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ﴾ مشرقة مضيئة منكشفة الألوان، ناضرة {1}."
  80,39,"﴿ضَاحِكَةٌ﴾ {1} قال عطاء: مسرورة {2}.وقال الكلبي: يعني بالفراغ من الحساب مستبشرة فرحة بما نال من كرامة الله ورضاه {3}."
  80,40,"(قوله تعالى) {1}: ﴿وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ﴾ قال الليث: الغَبَرَة: لَطْخُ غبار، والغُبْرَة: اغبِرار اللَّوْن يَغْبَرُّ لِلْهَمِّ {2} {3}.وقال المبرد: الغبرة ما يصيب الإنسان من الغبار المعفر على الألوان {4}.والمفسرون يقولون: سواد {5}،"
  80,41,"وهو قوله: ﴿تَرْهَقُهَا﴾ {1} أي يغشاها ويعلوها. ﴿قَتَرَةٌ﴾ قال الكلبي {2}، ومقاتل {3} يعني: سواد وكسوف عند معاينة النار.وقال المبرد {4}، والزجاج {5}: هي سواد كالدخان {6}، وأصلها من القتار، وهو دخان الشواء، {7} وهو قول عطاء (عن ابن عباس) {8}، قال: يريد قتار جهنم {4}."
  80,42,"(ثم بين من أهل هذه الحال فقال: (قوله تعالى) {1}: ﴿أُولَئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ﴾ {2}."
