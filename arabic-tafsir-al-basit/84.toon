tafsir[25]{c,v,t}:
  84,1,"﴿إِذَا السَّمَاءُ انْشَقَّتْ﴾، قال المفسرون: انشقاقها من علامات القيامة {1}، وذكر ذلك في مواضع من القرآن {2}."
  84,2,"﴿وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ﴾ قالوا: سمعت لربها وأطاعت في الانشقاق {1}. من الأذن، وهو الاستماع للشيء، والإصغاء إليه، وأنشد أبو عبيدة {2} {3}، و (المبرد {4}، والزجاج {5} {6} قول قعنب:صُمُّ إذا سَمِعوا خيراً ذُكِرْتُ به ... وإذا ذُكِرْتُ بُسوءٍ أَذِنوا {7}وقوله: ﴿حَقَّت﴾ أي وحُقَّ لها أن تطيع ربها {8} الذي خلقها {9}."
  84,3,"(قوله) {1}: ﴿وَإِذَا الْأَرْضُ مُدَّتْ﴾ قال ابن عباس: تمد مد الأديم {2} ويزاد في سعتها كذا وكذا {3}. قال {4} مقاتل: سويت كمد الأديم، فلا يبقى {5} عليها بناء، ولا جبل، إلا دخل فيها {6}."
  84,4,"﴿وَأَلْقَتْ مَا فِيهَا﴾ من الموتى، والكنوز {1}. ﴿وَتَخَلَّتْ﴾ منها.قال الفراء: وجواب ﴿إِذَا السَّمَاءُ انْشَقَّتْ﴾ وما بعده كالمتروك؛ لأن المعنى معروف قد تردد في في القرآن معناه فعرف، وقد فسر جوابه فيما يقى الإنسان من ثواب أو عقاب، وكأن المعنى: إذا السماء انشقت يرى الإنسان الثواب والعقاب. وهو قوله تعالى: ﴿يَا أَيُّهَا الْإِنْسَانُ﴾ {2} الآية.ونحو هذا قال الزجاج: وجواب ﴿إذا﴾ يدل عليه قوله عز وجل: ﴿فَمُلَاقِيهِ﴾ {3}.المعنى: إذا كان يوم القيامة لقي الإنسان عمله {4}.وقوله: ﴿إِنَّكَ كَادِحٌ﴾ ([..] {5} معنى الكدح في اللغة: السعي والدؤوب في العمل في باب الدنيا والآخرة) {6}.وقال الليث: الكدح عمل الإنسان من الخير والشَّر {7}. وقال أبو عبيدة: فلان يَكدَح في عيشه {8} أي يجهد، وأنشد {9} لابن مقبل:ومَا الدهر إلا تارتان فمنهما أَمُوت ... وأخرى أبتغي العيش أكدح {10}أي: وتارة أبتغي في طلب العيش وأدأب {11}. قال الكلبي {12}، (والضحاك) {13} {14}: إنك عامل لربك عملًا. وقال مقاتل: سَاعٍ بعملك إلى ربك سعياً {15}.وقوله {16}: ﴿فَمُلَاقِيهِ﴾ قال أبو إسحاق: فملاق ربك. وقيل: فملاق عملك {17}.والمعنى: ثواب عملك."
  84,5,""
  84,6,"84:5"
  84,7,"(قوله تعالى) {1}: ﴿فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ (7) فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا (8)﴾ قال مقاتل: (لأنه) {2} يغفر ذنوبه، ولا يحاسب بها {3}. وروت عائشة -رضي الله عنها- أن النبي -ﷺ- قال: ""من نوقش الحساب فقد هلك""، قلت: يا رسول الله، ﴿فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ (7) فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا (8)﴾؟ قال: ""ذلك العرض، ولكن من نوقش الحسَاب عُذب"" {4}.فمعنى قوله: ﴿يُحَاسَبُ حِسَابًا يَسِيرًا﴾ أي تعرض عليه سيئاته، ثم يغفرها الله له، فهو الحساب اليسير {5}. ﴿وَيَنْقَلِبُ إِلَى أَهْلِهِ﴾ في الجنة، يعني أزواجه من الحور العين، والآدميات، مغتبطاً قرير العين بما أوتي من الخير والكرامة. قاله ابن عباس {6}، ومقاتل {7}."
  84,8,"84:7"
  84,9,""
  84,10,"﴿وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ وَرَاءَ ظَهْرِهِ﴾ قال الكلبي: لأن يمينه مغلولة إلى عنقه، وتكون يده اليسرى خلف ظهره {1}. وقال مجاهد: تجعل يده وراء ظهره {2}. وقال مقاتل: تخلع يده اليسرى فتكون وراء ظهره {3} {4}.﴿فَسَوْفَ يَدْعُو﴾ إذا قرأ كتابه قال: (يا ويلاه {5}، يا ثبوراه.) {6} كقوله ﴿دَعَوْا هُنَالِكَ ثُبُورًا﴾ [الفرقان: 13].﴿وَيَصْلَى سَعِيرًا﴾ (يقال صلى {7} الكافر النار. قال الله تعالى: ﴿وَسَيَصْلَوْنَ سَعِيرًا﴾ [النساء: 10]) {8} وقرئ {9}: ""يُصلّى"" بضم الياء وتشديد اللام {10}.وقوله: ﴿وَتَصْلِيَةُ جَحِيمٍ﴾ [الواقعة: 94] {11}."
  84,11,""
  84,12,"84:11"
  84,13,"(وقوله تعالى) {1}: ﴿إِنَّهُ كَانَ فِي أَهْلِهِ﴾ {2} يعني في الدنيا {3} ﴿مَسْرُورًا﴾ مستبشرًا باتباع هواه، وركوب ما منته نفسه من شهواته."
  84,14,"قوله تعالى: ﴿إِنَّهُ ظَنَّ أَنْ لَنْ يَحُورَ﴾ لن {1} يرجع إلى الآخرة {2} أي: لن يبعث.قال ابن عباس {3}، ومقاتل {4}: حسب لا {5} يرجع إلى الله.والحور: الرجوع، والمحار: المرجع والمصير {6}. أنشد أبو عبيدة {7} للبيد:ومَا المرءُ إلا كالشهاب وضوءه ... يحورُ رمَاداً بعد إذ هو سَاطِعُ {8}وأنشد أيضًا للمُنَحّل اليَشكُريّ:إذا كنت عاذلتي {9} فسيري ... نحو العراق ولا تَحُوري {10}قال الله تعالى: ﴿بَلَى﴾ {11} ليحورن، وليبعثن. قاله مقاتل {12}، (والفراء) {13} {14}."
  84,15,"ثم أستأنف (قوله تعالى): ﴿إِنَّ رَبَّهُ كَانَ بِهِ بَصِيرًا﴾قال الكلبي: بصيراً به من خلقه إلى أن بعثه {1} {2}.وقال عطاء: بصيراً بما سبق عليه في أم الكتاب من الشقاء والخزي {3}.قال {4} مقاتل: بصيراً متى يبعثه {3}.وقال أبو إسحاق: كان به بصيرًا قبل أن يخلقه، عالماً بأن مرجعه إليه {6}."
  84,16,"قوله تعالى: ﴿فَلَا أُقْسِمُ بِالشَّفَقِ﴾ قال الكلبي: هي العمرة التي تكون في المغرب {1}.وقال مقاتل: الشفق الذي يكون بعد غروب الشمس في الأفق قبل الظلمة {2}.وقال عكرمة: مَا بقي من النهار {3}.وقال مجاهد: هو النهار كُلَه {4}.هذا ما ذكر المفسرون في تفسير الشفق، وأهل اللغة على أن الحمرة من بعد غروب الشمس إلى وقت صلاة العشاء الآخرة {5}.وهو قول الليث {6}، والفراء {7}، والزجاج {8}، (وعمرو عن أبيه) {9} {10} قالوا: الشفق الحمرة في السماء {11}.وأصل موضوع هذه الحرف: لرقة الشيء، ومنه يقَال: شيء شفق لا تماسك له، لرقته؛ ولذلك يقال للرديء من الأشياء {12}: شفق، وأشفق عليه إذا رق قلبه عليه، والشفقة رقة القلب {13}.وأهل اللغة إذا فسروا ""الشفق"" قالوا: بقية ضوء الشمس وحمرتها، فيذكرون الحمرة كأنهم حققوا أن تلك الرقة من ضوء الشمس، وأن الغالب عليها الحمرة، (وإنما جعل غيبوبة الشفق وقتًا للعشاء الآخرة {5}، واعتبرت الحمرة فيه دون البياض؛ لأن البياض {15} يمتد وقته، ويطول لبثه، والحمرة لما كانت بِقية ضوء الشمس، ثم بعدت {16} الشمس عن الأفق ذهبت الحمرة).قال {17}: سمعت بعض العرب يقول: عليه ثوب مصبوغ، كأنه الشفق، وكان أحمر، فهذا شاهد للحمرة) {18} هذا كلامه.قوله تعالى: ﴿وَاللَّيْلِ وَمَا وَسَقَ﴾ أي: وما جمع، وضم، وحوى، ولفَّ. قاله مجاهد {19}، ومسروق {20}، والحسن {21}، (وأبو صالح {20} {23})، وأبو العالية {24}، (ورواية ابن أبي مليكة عن) {10} ابن عباس قال: ما جمع {26}.واختيار {27} الفراء {28}، والزجاج {29}، (والمبرد {30}) {23}، وأنشدوا {32}:مُسْتَوْسِقات لَوْ يَجِدْنَ سائقاً {33}أي مجتمعات.ومنه الوَسْق في الطعام؛ لأنه مكيلة معلومة {34} تجمع قدرًا معلومًا {35}، والمعنى: جمع، وضم ما كان منتشرًا بالنهار في تصرفه، وذلك أن الليل إذا أقبل أوى كل شيء إلى مأواه {36}.قال الليث: الوسق: ضمك الشيء بعضه إلى بعض، واستوسقت الإبل إذا اجتمعت، وانضمت، والراعي يسقها: أي يجمعها {37}.وقال {38} الكلبي: ﴿وَمَا وَسَقَ﴾ يقول: ما ساق من شيء إلى حيث يأوي {24}.والوسق على هذا القول معناه: الطرد، (ومنه يقال للطريدة {40} من الإبل والغنم والحمر: وسقة) {41}.روى عطاء عن ابن عبَّاس: ﴿وَمَا وَسَقَ﴾ يريد وما حمل {42}.والوسق: يكون بمعنى الحمل، وكل شيء حملته فقد وسقته، ومعنى حمل في الليل: يعني ضم وجمع، أي ما أتى عليه الليل، وحمله في ظلمته، وذلك أنه يجلل الأشجار والجبال، والبحار، والأرض كلها، فإذا جللها فقد وسقها {43}."
  84,17,""
  84,18,"قوله تعالى: ﴿وَالْقَمَرِ إِذَا اتَّسَقَ﴾ قال أبو عبيدة: إذا تم {1}. وقال الزجاج: اجتمع واستوى {2}، وقال الفراء: اتساقه: امتلاؤه واجتماعه، واستواؤه ليلة ثلاثة عشر، وأربعة عشر إلى ستة عشر، وهو افتعل من الوسق الذي هو الجمع {3}.قال (ابن عباس {4} و) {5} المفسرون {6}: إذا استوى، واجتمع ، وتكامل، وتم، واستدار. كل هذا من ألفاظهم."
  84,19,"قوله تعالى: ﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾ فيه قراءتان {1}: فتح ""الباء""، وضمها، فمن فتح ""الباء"" قال: الخطاب لمحمد -ﷺ-.والمراد بالطبق: السماء. وهو قول مسروق {2}، (والشعبي) {3} {4}، وابن عباس {5} في رواية مجاهد. والمعنى: لتركبن يا محمد سماء بعد سماء. قال الكلبي: يصعد فيها {6}.ويجوز أن يريد درجة بعد درجة، ورتبة بعد رتبة في القربة من الله تعالى، ورفعة المنزلة {7}.ويجوز أن يكون المعنى: لتركبن السماء حالاً بعد حَال من تغير حَالاتها التي وصفها الله من الانشقاق، والطي، وكونها مرة كالدهَان، ومرة كالمهل، وهو قول عبد الله {8}.وروى الفراء بإسناده عن عمرو بن دينار، عن ابن عباس: لتركبن، بفتح {9} ""الباء""، وفسر: لتصيرن الأمور حَالاً بعد حَال {10}.ويجوز أيضًا أن يكون الخطاب للإنسان المتقدم في قوله: ﴿يَا أَيُّهَا الْإِنْسَانُ إِنَّكَ كَادِحٌ﴾والمعنى: لتركبن أيها الإنسان حَالاً بعد حَال من كونه نطفة، وعلقة، وَمُضغة، وحياً، وميتاً، وحياً بعد الموت، وغنياً، وفقيراً، وجميع الأحوال المختلفة على الإنسان في دنياهُ وآخرته. وهو قول مقاتل {11}، وعلى أيضًا قراءة من قرأ بضم ""الباء"" إلا أن الخطاب للجماعة، وهو اختيار أبي عبيد قال: لأن المعنى: بالناس أشبه منه بالنبي -ﷺ- لما ذُكر قبل الآية (من يؤتى كتابه بيمينه، ثم فسر هذه الآية) {12}: قوله تعالى: ﴿فَمَا لَهُمْ لَا يُؤْمِنُونَ﴾، وذكر ركوبهم طبقاً بعد طبق {13}، وهذا قول أكثر المفسرين؛ قالوا: لتركبن حَالاً بعد حَال، ومنزلاً بعد منزل، وأمرًا بعد أمر. وهذا قول الحسن {14}، وقتادة {15}، ومجاهد {16}، (وعكرمة {17}، وابن زيد {18}، وسعيد بن جبير {19}) {20} [قالوا] {21}: لتكونن في الآخرة بعد الأولى، ولتصيرن أغنياء بعد الفقر، وفقراء بعد الغنى، يعني في الآخرة.قال {22} عطاء: يريد شدة بعد شدة، يعني شدائد القيامة {23}.وقال أبو عبيدة: لَتَركَبُنَّ سنة الأولين، وسنة من كان قبلكم {24}. يعني في التكذيب والاختلاق على النبي -ﷺ-.والطبق في اللغة: يكون بهذه المعاني التي ذكرهَا المفسرون.قال الليث: السموات طباق، وكل واحد من الطباق طبقة، وقد يُذَكر طبق -قال- والطبقة: [الحال] {25}، يقال: كان فلان من الدنيا على طبقات شتى؛ أي حالات {26}.وقال ابن الأعرابي: الطبق [الحال] {27} على اختلافها {28}.وقد يكون الطبق بمعنى الشدة، قال الفراء: العرب تقول: وقع في بنات طبق {29} إذا وقع في الأمر الشديد {30}.وقال الأصمعي: يقال: جَاء بإحدى بنات طبق، وهي الداهية، وأصلها من الحيّات {31}. (يقال للحية: أم طبق لحسها {32} لتَرحَيها {33} وتحوَّيها {34}) {35}.وقوله: ﴿عَنْ طَبَقٍ﴾ ""عن"" بمعنى: بعد {36}.قال أبو علي: ومثل ما فسروا من ""أن"" بمعنى ""عن"" بمعنى ""بعد"" قول الأعشى:سادوا {37} وألقَى رهَطه سَادةً ... وكَابرًا سادوك عن كَابِرِ {38} قال: والمعنى: كابرا بعد كابر.فـ""عن"" متعلق بسادوك، ولا يكون متعلقاً بكابر، وقد تبين ذلك في قول النابغة:بَقِيَّةُ قِدْرٍ من قُدورٍ تُوُرِّثت ... لاَلِ الجلاحِ كَابِرًا بَعْدَ كابرِ {39}وقالوا عن الحمى أي عَرِقَ بعدها {40}.وتم الكلام عندها لتمام جواب القسم {41}.ثم قال: ﴿فَمَا لَهُمْ﴾ يعني كفار مكة ﴿لَا يُؤْمِنُونَ﴾ بمحمد، والقرآن.والمعنى: أي شيء لهم غير مؤمنين، وهو استفهام {42} إنكاري، أي: أي شيء لهم من النعيم والكرامة؛ إذ ألم يؤمنوا.ويجوز أن يكون استفهامًا معناه التعجب، أي: اعجبوا منهم لم يؤمنوا بعد البيان ووضوح البرهان.(قوله (عَزَّ وَجَلَّ) {43}: ﴿وَإِذَا قُرِئَ عَلَيْهِمُ الْقُرْآنُ لَا يَسْجُدُونَ﴾ قال عطاء {44}، والكلبي {45}: لا يصلون لله عَزَّ وَجَلَّ.وقال غيرهم {46}: لا يخضعون، ولا يستكينون."
  84,20,""
  84,21,"84:20"
  84,22,"(وقوله) {1}: ﴿بَلِ الَّذِينَ كَفَرُوا يُكَذِّبُونَ﴾ بالبعث، والقرآن ، والثواب، والعقاب."
  84,23,"(قوله) {1}: ﴿وَاللَّهُ أَعْلَمُ بِمَا يُوعُونَ﴾في صدورهم من التكذيب، ويضمرون في قلوبهم، ويكتمون. قاله ابن عباس {2}، وقتادة {3}، (ومقاتل {4}) {5}.وتفسير الإيعاء قد تقدم {6}."
  84,24,"قوله تعالى: ﴿فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ﴾(أي اجعل ذلك لهم بدل البشارة {1} للمؤمنين بالرحمة) {2}، وقد قدم مثل هذا {3}."
  84,25,"وقوله تعالى: ﴿إِلَّا الَّذِينَ آمَنُوا﴾ {1}قال مقاتل: استثنى مَن آمن مِن الكفار بقوله: ﴿إِلَّا الَّذِينَ آمَنُوا﴾ {2}.وقوله تعالى: ﴿غَيْرُ مَمْنُونٍ﴾ أي: غير منقوص ولا مقطوع؛ لأن نعيم الآخرة يزيد وينمو {3}، ولا ينقطع. (قاله عطاء عن ابن عباس {4}) {5}.وفسرنا ﴿غَيْرُ مَمْنُونٍ﴾ وفي أول سورة القلم {6}. (والله تعالى أعلم) {7} (تمت) {8}."
