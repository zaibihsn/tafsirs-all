  69,40,"69:39"
  69,41,"69:39"
  69,42,"69:39"
  69,43,"69:39"
  69,44,"69:39"
  69,45,"69:39"
  69,46,"قوله تعالى: ﴿ثُمَّ لَقَطَعْنَا مِنْهُ الْوَتِينَ (46)﴾ الوتين: نياط القلب، وهو عرق يجري في الظهر حتى يتصل بالقلب، فإذا انقطع بطلت القوى، ومات صاحبه. وهذا قول جميع أهل اللغة {1}، وأنشدوا (للشماخ) {2}: إذا بَلَّغْتِنِي وحَمَلْتِ رَحْلي ... عَرَابَةَ فاشْرَقي بِدَمِ الوَتِينِ {3}قال أبو زيد: وجمعه: الوُتُن، وثلاثة {4} أوتنة، الموتون: الذي قطع وتينه {5}، (وابن عباس) {6}، وأكثر المفسرين {7} قالوا: إنه نياط القلب، وحبل القلب.قال ابن قتيبة {8}: (ولم يُرد أنا نقطعه بعينه فيما يرى أهل النظر {8}، ولكنه أراد: لو كذب لأمَتْنَاه، أو قتلناه، فكان كمن قُطِع وتينُه، قال: ومثله قوله -ﷺ-: ""ما زالت أكلة {10} خيبر {11} تعاودني، فهذا أوانَ قطعَتْ أبْهَري"" {12}.والأبْهَرُ: عِرق يتصل بالقلب، فإذا انقطع مات صاحبه، فكأنه قال: هذا أوان قتلني السم، فكنت كمن {13} انقطع أبْهَرُهُ {14}."
  69,47,"قوله تعالى: ﴿فَمَا مِنْكُمْ مِنْ أَحَدٍ عَنْهُ حَاجِزِينَ (47)﴾. قال مقاتل {1}، (والكلبي {2} {3}: ليس منكم أحد يحجزنا عنه، وعن ذلك.وقال عطاء: يقول: لا يحجزه مني أحد {4}.وقال أبو عبيدة {5}، والفراء {6}، والزجاج {7}: إنما قال: (حاجزين) في صفة (أحد)؛ لأنه يقع على الجمع، المعنى: فما منكم قوم يحجزون {8} عنه. وقد ذكرنا هذا عند قوله: ﴿بَيْنَ أَحَدٍ مِنْ رُسُلِهِ﴾ {9}."
  69,48,"ثم ذكر أن القرآن ما هُوَ فقال تعالى: ﴿وَإِنَّهُ لَتَذْكِرَةٌ لِلْمُتَّقِينَ (48)﴾ قال الكلبي: (وإنه) لعظة للمتقين الشرك والفواحش، والمتقين عقاب الله بطاعته {1}.قوله: ﴿وَإِنَّهُ لَحَسْرَةٌ عَلَى الْكَافِرِينَ (50)﴾ قال ابن عباس: القرآن حسرة على الكافرين يوم القيامة {2}، يعني ندامة إذ لم يؤمنوا به. والكناية {3} في: (وإنه) على هذا القول للتكذيب {4}. ودل عليه قوله: ﴿أَنَّ مِنْكُمْ مُكَذِّبِينَ﴾ [الحاقة: 49]قوله: ﴿وَإِنَّهُ لَحَقُّ الْيَقِينِ (51)﴾. قال عطاء: يعني القرآن مني بدأ، وأنا أرسلته إليكم {5}. وقال مقاتل: ﴿لَحَقُّ الْيَقِينِ﴾ إنه من الله {6}.قال الزجاج: المعنى أنَّ القرآن لليقين {7} حق اليقين. هذا الذي ذكرنا قول المفسرين.وقال الكلبي: حقاً يقيناً ليكون ذلك عليهم حسرة {8}.وعلى هذا الكناية في قوله: ﴿وَإِنَّهُ لَحَسْرَةٌ﴾ وهي مصدر بمعنى التحسر، فيجوز تذكيره. ثم أمر بتنزيهه عن السوء، فقال: ﴿فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ (52)﴾.وقال عطاء: فصل لربك الذي عصمك من كل ما رَمَوْك به {9} {5}."
