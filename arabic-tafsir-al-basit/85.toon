tafsir[22]{c,v,t}:
  85,1,"﴿وَالسَّمَاءِ ذَاتِ الْبُرُوجِ﴾، ذكرنا تفسير البروج كاملاً {1} عند قوله: ﴿جَعَلَ فِي السَّمَاءِ بُرُوجًا﴾ {2} وهي النجوم {3}، أو منازلها."
  85,2,"﴿وَالْيَوْمِ الْمَوْعُودِ﴾ قالوا جميعاً: يعني يوم القيامة {1}."
  85,3,"﴿وَشَاهِدٍ وَمَشْهُودٍ﴾ واختلفوا فيه، (و) {1} الأكثرون على أن الشاهد يوم الجمعة، والمشهود يوم عرفة، وهو قول أبي هريرة {2}، والحسن {3} ، وعلي بن أبي طالب {4}، (وابن الزبير {5}، وقتادة {6}، ورواية يوسف المكي {7} عن ابن عباس {8}) {9}، وروي ذلك مرفوعاً إلى النبي -ﷺ- {10} (رواه أبو هريرة) {11} {9}، وعلى هذا سمي يوم الجمعة شاهداً؛ لأنه يشهد على كل عامل بما عمل فيه، وكذلك كل يوم، ويوم عرفة يوم مشهود؛ لأنه يشهد الناس فيه موسم الحج، وتشهده الملائكة.وعلى الضد من هذا روى أبو هريرة أن النبي -ﷺ- قال: ""شاهد"" يوم عرفة، ""ومشهود"" يوم الجمعة) {13}، فإنه يوم مشهود تشهده الملائكة.وقال آخرون: الشاهد محمد -ﷺ-، والمشهود يوم القيامة، وهو {14} قول الحسن بن علي {15} -رضي الله عنه-، ومحمد بن علي {16}، وتلا الحسن بن علي -رضي الله عنه- قوله عَزَّ وَجَلَّ: ﴿إِنَّا أَرْسَلْنَاكَ شَاهِدًا﴾ [الأحزاب: 45]، وقوله: ﴿وَذَلِكَ يَوْمٌ مَشْهُودٌ﴾ [هود: 103]، وتلا محمد -رضي الله عنه- قوله: ﴿وَجِئْنَا بِكَ عَلَى هَؤُلَاءِ شَهِيدًا﴾ [النحل: 89].وقال جماعة: الشاهد: ابن آدم، والمشهود يوم القيامة، (وهوقول مجاهد {17} ، وعكرمة {18}، وابن عباس {19}، في رواية مجاهد) {9}، وقال (في رواية الوالبي {21}) {22}، (قال ابن عباس) {23}: الشاهد الله، والمشهود: يوم القيامة."
  85,4,"قوله تعالى: ﴿قُتِلَ أَصْحَابُ الْأُخْدُودِ﴾، قال الأخفش: هو جواب القسم، وأضمر اللام {1} كما قال ﴿وَالشَّمْسِ وَضُحَاهَا﴾ [الشمس: 1]، ﴿قَدْ أَفْلَحَ مَنْ زَكَّاهَا﴾ [الشمس: 9] يريد: لقد أفلح، قال: ولئن شئت على [التقديم] {2}، كأنه قيل: ﴿قُتِلَ أَصْحَابُ الْأُخْدُودِ﴾، ﴿وَالسَّمَاءِ ذَاتِ الْبُرُوجِ﴾ {3}.وقال أبو إسحاق: جواب القسم: ﴿إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ﴾ {4}، وهو قول ابن مسعود {5} -رضي الله عنه-، وقتادة {6}.وقال صاحب النظم: جواب القسم قوله ﴿إِنَّ الَّذِينَ فَتَنُوا﴾ {7}.(وقال غيره {8}) {9}: كما تقول: والله إن زيداً لقائم، وقد اعترض بين القسم وجوابه قوله: ﴿قُتِلَ أَصْحَابُ الْأُخْدُودِ﴾ وما يتصل به إلى قوله ﴿إِنَّ الَّذِينَ فَتَنُوا﴾، وقال غيره من أهل المعاني: جواب القسم محذوف بتقدير: الأمر حق في الجزاء على الأعمال {10}.و""قتل {11} "" معناه: لعن في قول جميع المفسرين {12} كقوله تعالى: {قُتِلَ الْخَرَّاصُونَ} {13}، وقد مر.واختلفوا في أصحاب الأخدود من هم؟ فروي عن صهيب بطرق مختلفة أن النبي -ﷺ- ذكر مَلِكًا فيمن كان قبلنا أسلم في عهده قوم، فأمر بالأخدود في أفواه السكك فخدوها، وأضرم فيها النار، وقال: من لم يرجع عن دينه {14} فأقحموه فيها ففعلوا.وهو حديث طويل {15} نذكره في مسند {16} التفسير إن شاء الله.وقال مقاتل: إن قوماً باليمن عمدوا إلى أولياء الله فخدوا لهم أخدوداً، وأوقدوا فيها النار، ثم عرضوا على الشرك، فمن تابعهم خلوا عنه، ومن لم يتابعهم قذفوه في النار {17}، وهو قول الحسن {18}.وقال الكلبي {19}، ومجاهد {20}: هم قوم من نصارى ""نجران"" {21} {22} عذبوا بالنار قوماً من المؤمنين على التوحيد.وروى علي -رضي الله عنه- أنهم كانوا قوماً من المجوس، وذلك أن ملكاً منهم واقع أخته على السكر، ثم أراد أن يجعل ذلك شرعاً في رعيته، فلم يقبلوه، فأوقد لهم النيران في الأخدود، وعرضهم عليها، فمن أبى {23} قبول ذلك قذفه في النار، ومن أجاب خلى {24} سبيله {25}.وقال الضحاك: (أصحاب) {26} كانوا من بني إسرائيل {27}.(والأخدود: الشق في الأرض يحفر مستطيلاً) {28}، وجمعه: الأخاديد، ومصدره {29}: الخد، وهو الشق، يقال: خد في الأرض خداً، وتخدد لحمه: إذا صار فيه طرائق كالشقوق {30}، وانشد (المبرد {31}) {26} فقال:يا مَن لِشيخٍ قَدْ تَخَدَّدَ لَحْمُهُ ... أفْنَى ثلاث عَمَائمٍ ألْوَاناًسَوْداءَ حالِكةً وسَحْقَ مُفْوفٍ ... وأجَدَّ لوْناً بَعْدَ ذَاكَ هِجْاناً {33}"
  85,5,"قوله: ﴿النَّارِ ذَاتِ الْوَقُودِ﴾ قال أبو علي: هذا من بدل الاشتمال، كقوله: سلب زيد ثوبه، ومنه ""أصحاب الأخدود النار""، فالأخدود يشتمل على النار {1}.و ﴿ذَاتِ الْوَقُودِ﴾ يعني ذات الحطب الذي جعل لها وقوداً."
  85,6,"﴿إِذْ هُمْ﴾ العامل في ""إذ"" ""قتل""، والمعنى: لعنوا في ذلك الوقت؛ إذ هم قعود عند الأخدود يعذبون المؤمنين.﴿وَهُمْ﴾ يعني أولئك: الملك وأصحابه الذين خدوا الأخدود.قوله تعالى: ﴿عَلَيْهَا قُعُودٌ﴾. قال ابن عباس: عندهَا جلوس {1}قال مقاتل: يعني عند النار قعود يعرضونهم على الكفر {2}.قال مجاهد: كانوا قعودًا على الكراسي عند الأخدود {3}، وهو قوله:"
  85,7,"﴿وَهُمْ عَلَى مَا يَفْعَلُونَ بِالْمُؤْمِنِينَ﴾ {1} أي من عرض منهم على النار، وإرادتهم أن يرجعوا إلى دينهم.﴿شُهُودٌ﴾. حضور، قاله ابن عباس {2}.ويكون ""على"" بمعنى ""مع"" كأنه قيل: وهم مع مَا يفعلون بالمؤمنين شهود حضروا ذلك التعذيب {3}.قال أبو إسحاق: أعلم الله قصة قوم بلغت بصيرتهم وحقيقة إيمانهم إلى أن صبروا على أن أحرقوا بالنار في الله {4}.قال الحسن: كان رسول الله -ﷺ- إذا ذكر أصحاب الأخدود تعوذ بالله من جهد البلاء {5}"
  85,8,"قوله تعالى: ﴿وَمَا نَقَمُوا مِنْهُمْ إِلَّا أَنْ يُؤْمِنُوا بِاللَّهِ الْعَزِيزِ الْحَمِيدِ﴾.قال ابن عباس: ما كرهوا منهم إلا أنهم آمنوا {1}.وقال مقاتل: مَا عَابوا منهم {2}.وقال أبو إسحاق: أي ما أنكروا عليهم ذنباً إلا إيمانهم {3}، وهذا كقوله: ﴿هَلْ تَنْقِمُونَ مِنَّا إِلَّا أَنْ آمَنَّا بِاللَّهِ﴾ [المائدة: 59]، ﴿وَمَا نَقَمُوا إِلَّا أَنْ أَغْنَاهُمُ اللَّهُ﴾ [التوبة: 74] وقد مر.قوله (عز وجل) {4}: ﴿وَاللَّهَ عَلَى كُلِّ شَيْءٍ﴾ {5}أي من فعلهم بالمؤمنين شهود، لم يخف عليه ما صنعوا.ثم أعلم مَا أعد لأولئك فقال:"
  85,9,""
  85,10,"(وقوله تعالى) {1}: ﴿إِنَّ الَّذِينَ فَتَنُوا الْمُؤْمِنِينَ وَالْمُؤْمِنَاتِ﴾ {2}، قال ابن عباس {3}، (ومقاتل {4}) {5}: حرقوهم بالنار. وهو قول قتادة {6}.(قال الزجاج) {5}،: يقال: [فتنت] {8} الشيء: أحرقته، والفتين: حجارة سود كأنها محرقة {9}. ومنه قوله: ﴿يَوْمَ هُمْ عَلَى النَّارِ يُفْتَنُونَ﴾ [الذاريات: 13].قولى تعالى: ﴿ثُمَّ لَمْ يَتُوبُوا﴾ قال ابن عباس: يريد من فعلهم ذلك، ومن الشرك الذي كانوا عليه {10}.﴿فَلَهُمْ عَذَابُ جَهَنَّمَ﴾. (بكفرهم. ﴿وَلَهُمْ عَذَابُ الْحَرِيقِ﴾ بما أحرقوا المؤمنين. قاله الزجاج) {11}: والحريق النار، ويكون عذاب جهنم نوعاً من التعذيب غير الإحراق للتفصيل في الذكر {12}.وقال الربيع بن أنس: ﴿وَلَهُمْ عَذَابُ الْحَرِيقِ﴾ يعني في الدنيا، وذلك أن النار ارتفعت من الأخدود إلى الملك وأصحابه فأحرقتهم {13}. وهو قول الكلبي {14}، وذكره {15} الفراء {16}.قال مقاتل: ثم ذكر مَا أعد للمؤمنين الذين أُحرقوا بالنار فقال:"
  85,11,"قوله تعالى: ﴿إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ﴾ {1} الآية {2}"
  85,12,"﴿إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ﴾ قال ابن عباس: إن أخذه بالعذاب إذا أخذ الظلمة، والجبابرة لشديد {1}، كقوله: ﴿إِنَّ أَخْذَهُ أَلِيمٌ شَدِيدٌ﴾ {2}."
  85,13,"﴿إِنَّهُ هُوَ يُبْدِئُ وَيُعِيدُ﴾ الخلق يخلقهم أولاً في الدنيا، ويعيدهم أحياء بعد الموت. وهذا قول المفسرين جميعاً {1}.وذكر ابن عباس في رواية عطاء: هو أن أهل جهنم تأكلهم النار حتى يصيروا فحماً، ثم يعيدهم خلقاً جيداً {2}."
  85,14,"﴿وَهُوَ الْغَفُورُ﴾ {1} قال ابن عباس {2}، ومقاتل {3}: لذنوب المؤمنين من أوليائه وأهل طاعته.﴿الْوَدُودُ﴾ المحب لهم (وهذا قول أكثر المفسرين {4}) {5}.وقال الكلبي: الودود: المتودد إلى أوليائه بالمغفرة والجزاء {6}.والقول هو الأول.قال ابن الأنباري: الودود في السماء، الله المحبّ لعباده {7}.وذكرنا اللغات في الود عند قوله: ﴿يَوَدُّ أَحَدُهُمْ﴾ {8}وقال {9} الأزهري في تفسير أسماء الله {10}: قال بعض أهل اللغة: يجوز أن يكون ""ودود"" فعول بمعنى المفعول، كركوب، وحلوب، ومعناه أن عباده الصالحين {11} يودونه ويحبونه لما عرفوا من فضله، ولما أسبغ عليهم من نعمائه، قال: وكلتا الصفتين مدح؛ لأنه جل ذكره إن أحب عباده (المؤمنين) {12} المطيعين، فهو فضل منه، وإن أحبه عباده العارفون فلِما تقرر عندهم من كريم إحسانه {13}."
  85,15,"قوله تعالى: ﴿ذُو الْعَرْشِ الْمَجِيدُ﴾ ﴿الْمَجِيدُ﴾ بالرفع مُتبعاً لقوله: ﴿ذُو﴾، وهو أكثر القراءة {1}، والتفسير {2}، والاختيار؛ لأن الله تعالى هو المجيد الموصوف بالمجد؛ لأن لفظ المجيد لم يسمع في غير صفة الله خالى كما {3} سمع الماجد.قال أبو علي: لم أعلم في صفة الأناسي ""مجيد"" كما جاء في وصفهم ""عليم"" ""وحفيظ"" نحو قوله: ﴿اجْعَلْنِي عَلَى خَزَائِنِ الْأَرْضِ إِنِّي حَفِيظٌ عَلِيمٌ﴾ {4} [يوسف: 55]، وقد ذكرنا تفسير المجيد فيما تقدم {5}.ومن كسر ""المجيد"" {6} جعله صفة العرش، ووصفه بالمجادة كما قال: ﴿بَلْ هُوَ قُرْآنٌ مَجِيدٌ﴾ [البروج: 21] فوصف القرآن بالمجادة، هذا قول الفراء {7}، (والزجاج {8}) {9}، وأكثر النحويين {10}.(ومنهم من قال: أجعله صفة للرب في قوله: ﴿إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ﴾ ولا أجعله وصفاً للعرش، حكى ذلك أبو علي؛ قال: والفصل والاعتراض بين الصفة والموصوف في هذا النحو لا يمتنع؛ لأن ذلك يجري مجرى الصفات) {11}قال عطاء عن ابن عباس: قال: من قرأ بالخفض فإنما يريد العرش وحسنه {12}، ويدل على صحة هذا أن العرش وصف بالكرم في قوله ﴿رَبُّ الْعَرْشِ الْكَرِيمِ﴾ [المؤمنون: 23]، فجاز أن يوصف بالمجد، لأن معناه الكمال، والعرش على ما ذكر أحسن شيء وأكمله، وأجمعه بصفات الحسن {13}."
  85,16,"قوله تعالى: ﴿فَعَّالٌ لِمَا يُرِيدُ﴾ أي من الإبداء والإعادة، (قاله مقاتل {1}) {2}.وقال عطاء عن ابن عباس: يريد أنه لا يعجزه شيء يريده، ولا يمتنع منه شيء طلبه {3} {4}. ثم ذكر خبر الجموع الكَافرة فقال:"
  85,17,"قوله تعالى: ﴿هَلْ أَتَاكَ حَدِيثُ الْجُنُودِ﴾ قال مقاتل: يريد قد أتاك {1}؛ كقوله: ﴿هَلْ أَتَى عَلَى الْإِنْسَانِ﴾ [الإنسان: 1] وقد مر {2}.قال عطاء: يعني الذين تجندوا على أنبياء الله وأصفيائه، يعزي نبيه بذلك {3}."
  85,18,"ثم بين من هم فقال: ﴿فِرْعَوْنَ وَثَمُودَ﴾.والمعنى: أتاك حديث الجنود، وما كان منهم إلى أنبيائهم، أو اصبر كما صبر الرسل من قبلك، وهذا معنى قول ابن عباس: يريد تعزية النبي -ﷺ- {1} وقيل معناه: تذكير الكفار من أهل مكة حديث الجنود قبلهم ليعتبروا ويتذكروا ما كان منهم إلى أنبيائهم، وما فعل الله بهم {2}، ويدل على هذا المعنى:"
  85,19,"قوله: ﴿بَلِ الَّذِينَ كَفَرُوا فِي تَكْذِيبٍ﴾ بل أعرضوا عما يُوجبه الاعتبار بفرعون وثمود، وأقبلوا على ما يوجبه الكفر والتكذيب، فكذبوك، وكذبوا ما جئت به من القرآن."
  85,20,"﴿وَاللَّهُ مِنْ وَرَائِهِمْ مُحِيطٌ﴾ يقدر أن ينزل بهم مَا أنزل بفرعون وثمود.قال أبو إسحاق: أي لا يعجزه منهم أحد، قدرته مشتملة عليهم {1}."
  85,21,"قوله تعالى: ﴿بَلْ هُوَ قُرْآنٌ مَجِيدٌ﴾ قال ابن عباس {1}، (ومقاتل {2}) {3}: كريم لأنه كلام الرب ليس هو كما يقولون: شعر، وكهانة، وسحر {4}.وقال أهل المعاني: لما كان القرآن يعطي المعَاني الجليلة، والدلائل النفيسة، كان كريماً، مجيد: كريم، كثير الخير بما يعطي من الحكم والمواعظ والحجج {5}."
  85,22,"قوله تعالى: ﴿فِي لَوْحٍ مَحْفُوظٍ﴾ عند الله، وهو أم الكتاب، منه نسخ الكتاب القرآن، والكتب، وهو الذي يعرف باللوح المحفوظ من الشياطين، ومن الزيادة فيه والنقصان {1}.وهذا قول [ابن عباس {2}، ومقاتل {3}، ومجاهد {4}، والحسن {2}] {6}.(وقرأ نافع (محفوظٌ) رفعاً {7} على نعت القرآن، كأنه قيل: بل هو قرآن مجيد محفوظ في لوح، وذلك أن القرآن وصف بالحفظ في قوله ﴿إِنَّا نَحْنُ نَزَّلْنَا الذِّكْرَ وَإِنَّا لَهُ لَحَافِظُونَ﴾ [الحجر: 9]، فكما وصف بالحفظ في تلك {8} الآية، كذلك وصف في هذه الآية بأنه محفوظ ، ومعنى حفظ القرآن أنه يؤمن من تحريفه، وتبديله، وتغيره، فلا يلحقه من ذلك شيء، قال أبو الحسن: والأولى: هو الذي نعرف). {9}وقال أبو عبيد: الوجه الخفض، لأن الآثار الواردة في اللوح المحفوظ تصدق ذلك {10}."
