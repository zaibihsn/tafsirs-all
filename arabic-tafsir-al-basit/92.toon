tafsir[21]{c,v,t}:
  92,1,"﴿وَاللَّيْلِ إِذَا يَغْشَى﴾ قال ابن عباس {1}، ومقاتل {2}: أقسم الله بالليل إذا يغشى بظلمته {3} والنهار، ولم يذكر مفعول يغشى للعلم به.وقال أبو إسحاق: ""يغشى الليل"" الأفق، وجميع ما بين السماء والأرض، فيذهب ضوء النهار {4}."
  92,2,"قوله تعالى {1}: ﴿وَالنَّهَارِ إِذَا تَجَلَّى﴾ (أي بَان وظهر) {2} من بين الظلمة.قال قتادة: هما آيتان عظيمتان يكررهما الله على الخلائق {3}."
  92,3,"(قوله) {1}: ﴿وَمَا خَلَقَ الذَّكَرَ وَالْأُنْثَى﴾ قال الكلبي: والذي خلق {2}، وهو قول الحسن {3}. و""ما"" على هذا بمعنى ""مَنْ"".وقال مقاتل: يعني: وخلْق الذكر والأنثى {2}.وعلى هذا ""مَا"" للمصدر، -وقد فسرنا هذا في مواضع {5} - والذكر والأنثى يجوز أن يعني بهما الجنس من الذكر والأنثى {6}، وهو الظاهر {7}.وقال مقاتل {8}، (والكلبي {9}) {10}: يعني آدم وحواء.وجواب القسم قوله تعالى:"
  92,4,"﴿إِنَّ سَعْيَكُمْ لَشَتَّى﴾.قال ابن عباس: إن أعمالكم لمختلفة، عمل للجنة، وعمل للنار {1}.وقال مقاتل: يعني أن أهل مكة تقول إن أعمالكم لمختلفة في الخير والشر {2}.وتفسير ""شتى"" قد سبق في قوله: ﴿مِنْ نَبَاتٍ شَتَّى﴾ {3}.قال المفسرون: نزلت في أبي بكر الصديق -رضي الله عنه- وفي أبي سفيان {4}. ثم فصل عملهما فبين {5} فقال:"
  92,5,"(قوله) {1}: ﴿فَأَمَّا مَنْ أَعْطَى وَاتَّقَى﴾.قال الكلبي: تصدق من ماله، واتقى معصية ربه {2}.وقال مقاتل: أعطى المال في حق الله، واتقى الله (ومعصيته {2}) {4}، يعني الصديق -رضي الله عنه-."
  92,6,"﴿وَصَدَّقَ بِالْحُسْنَى﴾.قال عكرمة عن ابن عباس: بالخَلَف {1}، وهو قول الكلبي {2}، ومقاتل {3}، وقتادة {4}، (قالوا: يعيده) {5} الله، وهو أن يخلفه في الآخرة الجنة.فـ""الحسنى"" على هذا القول: الجنة، يجعلها الله خلفًا لأبي بكر مما أعطى.وقال مجاهد {6}، وأبو عبد الرحمن (السلمي {7}) {8}، والضحاك {9}، قال: لا إله إلا الله.وقال عطاء عن ابن عباس: يريد الخلف من الله والثواب والجنة، وصدق بأن لا إله إلا الله وأن محمد رسول الله {6}."
  92,7,"(قوله تعالى) {1}: ﴿فَسَنُيَسِّرُهُ لِلْيُسْرَى﴾ فسنهيئه لعمل الخير، وهو معنى قول ابن عباس: نيسر له أعمال الخير {2}.وقال الكلبي، و (مقاتل {3}) {1}، والفراء {5}: نيسره للعودة للعمل الصالح.ومعنى اليسرى: الخلة اليسرى {6}، (وهي الأمر السهل الذي لا يقدر عليه أحد إلا المؤمنون) {7}، يسر الله لهم العمل بمرضاته، فتيسر عليه الإنفاق في سبيل الخير، والعمل بالطاعة بتيسير الله ذلك لهم {8}.قال المفسرون: نزلت هذه الآيات في أبي بكر الصديق -رضي الله عنه- {9}، اشترى منه ستة نفر من المؤمنين كانوا في أيدي أهل مكة يعذبونهم في الله {10}."
  92,8,"﴿وَأَمَّا مَنْ بَخِلَ﴾ أي بالنفقة في الخير والصدقة {1}﴿وَاسْتَغْنَى﴾ عن ثواب الله فلم يرغب فيه {2}.قال مقاتل {3}، والكلبي {4}: يعني أبا سفيان، ثم عمت الكفار بعده.وقال عطاء: يريد أمية بن خلف {5}."
  92,9,"﴿وَكَذَّبَ بِالْحُسْنَى﴾ يعني بما صدق (به) {1} أبو بكر وقد فسرنا {2}."
  92,10,"﴿فَسَنُيَسِّرُهُ لِلْعُسْرَى﴾ قال عطاء: يريد سوف أحول بينه وبين أن يؤمن بالله ويصدقق رسوله {1}. وهذا على (قول) {2} من يقول: إنه أمية بن خلف.وقال مقاتل: يعسر عليه أن يعطي خيرًا {3}.وقال عكرمة عن ابن عباس: للعسرى {4}: للشر {5}، وهذا {6} هو القول، وذلك أن الشر يؤدي إلى العذاب، فهو الخلة العسرى، والخير يؤدي إلى اليسرى والراحة في الجنة، فهو الخلة اليسرى، يقول: سنهيئه للشر بأن يجريه على يديه.قال الفراء: والعرب تقول: قد يسرت غنم فلان؛ إذا تهيأت للولادة {7}.وكذلك إذا ولدت وكثر ألبانها، كأنها يسرت الأمر على أصحابها.ثم ذكر أن ما أمسك من {8} ماله عن الإنفاق لا ينفعه فقال:"
  92,11,"(قوله): ﴿وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تَرَدَّى﴾ {1} أي الذي بخل به عن الخير. ﴿إِذَا تَرَدَّى﴾ إذا مات.قال مجاهد {2}، ومقاتل، (وأبو صالح {3}) {4}: قال أبو عبيدة {5}: ""تردى"" وردى إذا مات. قال المبرد: هو تَفَعَّل من الرَّدى، وهو الهلاك {6}.وقال ابن عباس {7}، وقتادة {8}: إذا تردى في جهنم، أي سقط وهوى، وذكرنا هذا الحرف عند قوله: ﴿وَالْمُتَرَدِّيَةُ﴾ {9}."
  92,12,"قال الله تعالى: ﴿إِنَّ عَلَيْنَا لَلْهُدَى﴾.وفي تفسيره ثلاثة أقوال {1}:قال مقاتل: يعني البيان {2}.قال أبو إسحاق: أي إن علينا أن نبين طريق الهدى من طريق الضلال {3}.وهو قول قتادة: أي على الله البيان: بيان حلاله، وحرامه، وطاعته، ومعصيته {4}.القول الثاني: إن المعنى يقول: من سلك الهدى فعلى الله سبيله، كقوله عز وجل: ﴿وَعَلَى {5} اللَّهِ قَصْدُ السَّبِيلِ﴾ [النحل: 5]، يقول علينا {6} الهدى: أي أن الهدى يوصل صاحبه إلى الله، وإلى ثواب الله وجنته.ذكر {7} ذلك الفراء {8}، وذكر قولًا آخر، فقال: ويقال: إن علينا للهدى والإضلال. فترك الإضلال كما قال: ﴿سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾ [النحل: 81]، وهي تقي {9} الحر والبرد {10}.وهذا معنى قول ابن عباس في رواية عطاء، قال: يريد أرشد أوليائي إلى العمل بطاعتي، وأحول بين أعدائي أن يعملوا بطاعتي {11}. فذكر معنى الإضلال {12}."
  92,13,"قوله ﴿وَإِنَّ لَنَا لَلْآخِرَةَ وَالْأُولَى﴾ يعني الدارين: الدنيا، والآخرة {1}.قال الكلبي: أي ثواب الدنيا والآخرة {2}، (كقوله: ﴿فَعِنْدَ اللَّهِ ثَوَابُ الدُّنْيَا وَالْآخِرَةِ﴾ [النساء: 134]) {3}.وهو قول الفراء {4}.والمعنى: لنا ملك الدارين، نعطي منهما من نشاء، فليطلبا منا.ويجوز أن يكون معنى الإخبار عن كونهما إيجاب التسليم {5} لأمره، فإنهما {6} له، يفعل فيهما مَا يشاء، فمن شاء أعطى من الدنيا، ومن شاء (حرمه، ومن شاء) {3} أُدخل الجنة، ومن شاء أُدخل النار، لا راد لمشيئته، ولا ناقض لحكمه.ولما ذكر هذا أخبر عن إبانته طريق الهدى بالإنذار على الكفر بالنار، فقال:"
  92,14,"﴿فَأَنْذَرْتُكُمْ﴾ قال مُقاتل: يريد أهل مكة {1}.﴿فَأَنْذَرْتُكُمْ نَارًا تَلَظَّى﴾ تتوقد وتتوهج وتتلهب، يقال: تلظت النار تتلظى تلظيًا. ومنه سميت جهنم لظى {2}، وقد مر {3} ثم بين أنها لمن هي بقوله:"
  92,15,"﴿لَا يَصْلَاهَا إِلَّا الْأَشْقَى﴾ يعني إلا من كان شقيًا في علم الله. قاله الفراء {1}.وقال ابن عباس: يريد أمية بن خلف، ونظراءه الذين كذبوا محمدًا -ﷺ- والأنبياء قبله {2}.وقال الحسن: يعني المشرك {3}، ويدل عليه قوله:"
  92,16,"﴿الَّذِي كَذَّبَ﴾ أي كذب الرسول، والقرآن {1}. ﴿وَتَوَلَّى﴾ أعرض عن الإيمان {2}.فإن قيل: أليس غير المشرك يدخل النار، وهذه الآية تدل على أنه لا يدخلها إلا (المكذب الكافر؟ والجواب عنه من وجوه:أحدهما: أن هذا ورد في درك مخصوص من أدراك جهنم؛ لا يحله إلا) {3} من كان بهذه الصفة، وهي: دركات، ولأهل النار منها منازل، (وهذا قول أبي إسحاق {4}) {3}.والثاني: أن هذا على الاختصار بحذف ذكر العصاة من غير المشركين، بدليل الآي الآخر، على أن معنى قوله: ﴿لَا يَصْلَاهَا﴾ لا يلزمها في حقيقة اللغة، يقال: صلى الكَافر النار إذا لزمها مقاسيًا شدتها وحرهَا {6}، لعل هذا الأصل مما سبق بيانه {7}، ولا يلزم النار خالدًا فيها إلا المشرك المكذب."
  92,17,"وقوله: ﴿وَسَيُجَنَّبُهَا﴾ أي سنبعدها، ويجعل منها على جانب، يقال: جنبته الشيء أي بعدته وتجنبه عنه {1}.﴿الْأَتْقَى﴾ يعني أبا بكر -رضي الله عنه- في قول الجميع {2}، قالوا: يزحزح عن النار.قال مقاتل: الأتقى المخلص بالتوحيد.ثم وصفه فقال:"
  92,18,"(قوله): ﴿الَّذِي يُؤْتِي مَالَهُ يَتَزَكَّى﴾ قال أبو إسحاق: يطلب أن يكون عند الله زاكيًا لا يطلب بذلك رياء ولا سمعه {1} يدل عليه قوله:"
  92,19,"﴿وَمَا لِأَحَدٍ عِنْدَهُ مِنْ نِعْمَةٍ تُجْزَى﴾ قال المفسرون {1}: لما اشترى أبو بكر رضي الله عنه بلالًا من صاحبه عبد الله بن جدعَان، وكان قد سلح {2} على الأصنام، فأسلمه مولاه إلى المشركين ليعذبوه بما فعل، فكانوا يعذبونه في الرمضاء {3}، وقد وضعوا على صدره صخرة، فاشتراه أبو بكر وأعتقه، فقال المشركون: مَا فعل ذلك أبو بكر إلا ليد كانت عند بلال، أراد أن يجزيه بها، فقال الله تعالى: ﴿وَمَا لِأَحَدٍ عِنْدَهُ مِنْ نِعْمَةٍ تُجْزَى﴾.قال ابن عباس: يريد مَا لبلال عند أبي بكر نعمة يجزيه بها {4}.والمعنى: (لم يفعل ذلك مجازاة ليد أسديت إليه) {5}، ولكنه ابتغى بذلك وجه الله، وهو قوله:"
  92,20,"﴿إِلَّا ابْتِغَاءَ وَجْهِ رَبِّهِ الْأَعْلَى﴾ (أي إلا طلب ثواب الله) {1}قال أبو عبيدة: ""إلا ابتغاء"" {2} استثناء من النعمة، كما يُستثنى الشيء وليس منه {3}.قال الفراء: وهذا على اختلاف ما قبل ""إلا"" ومَا بعدها، والعرب تقول: مَا في الدار أحد إلا أكلبًا وأحمرةً، وهذا كقوله: ﴿إِلَّا اتِّبَاعَ الظَّنِّ﴾ [النساء: 157]كقول {4} النابغة:.. .. وما بالرَّبعِ من أحدِ إلا الأواريَّ {5}وهي لغة أهل الحجاز {6}.وذكر الفراء وجهًا آخر، وهو: أن يضمر الإنفاق على تقدير: ما ينفق إلا ابتغاء وجه ربه الأعلى، وهذا كقوله: ﴿وَمَا تُنْفِقُونَ إِلَّا ابْتِغَاءَ وَجْهِ اللَّهِ﴾ [البقرة: 272] {6}. وقد مر.ومعنى ﴿الْأَعْلَى﴾: الأجل بصفاته التي لا يوارى فيها، فهو الأقدر، الأغلب الأظهر بالحجة والقوة {8}.ثم وعد أبا بكر أن يرضيه في الآخرة بثوابه، فقال: قوله تعالى: ﴿وَلَسَوْفَ يَرْضَى﴾ قال ابن عباس: يعطيه الله في الجنة حتى يرضى {9}. وقال مقاتل: يرضى بثواب الله في الآخرة {10}. وقال أبو إسحاق أي: سيدخل الجنة كما قال: ﴿ارْجِعِي إِلَى رَبِّكِ رَاضِيَةً مَرْضِيَّةً﴾ [الفجر: 29 - 30] {11}."
  92,21,""
