tafsir[110]{c,v,t}:
  18,1,"﴿الْحَمْدُ لِلَّهِ الَّذِي أَنْزَلَ عَلَى عَبْدِهِ الْكِتَابَ وَلَمْ يَجْعَلْ لَهُ عِوَجًا (1) قَيِّمًا﴾.ذكرنا معنى العَوج والفرق بينه وبين العِوج في قوله: ﴿تَبْغُونَهَا عِوَجًا﴾ [آل عمران: 99] {1}. روى الوالبي عن ابن عباس في قوله: ﴿وَلَمْ يَجْعَلْ لَهُ عِوَجًا﴾ قال: (ملتبسًا) {2}. ومعناه: التباس، أي: لم يجعل ملتبسًا لا يُفهم، ومعوجًا لا يستقيم.وقال أبو إسحاق: (لم يجعل فيه اختلافًا) {3}. كما قال: ﴿وَلَوْ كَانَ مِنْ عِنْدِ غَيْرِ اللَّهِ لَوَجَدُوا فِيهِ اخْتِلَافًا كَثِيرًا﴾ [النساء: 82]. يدل على هذا قوله: ﴿قَيِّمًا﴾ قال ابن عباس: (يريد مستقيمًا عدلاً) {4}. وذكرنا الكلام في القيِّم عند قوله: ﴿دِينًا قِيَمًا﴾ [الأنعام: 161] ، وجميع أهل اللغة والتفسير قالوا: (هذا من التقديم والتأخير، وتقديره: أنزل على عبده الكتاب قيمًا ولم يجعل له عوجًا) {5}."
  18,2,"وقوله تعالى: ﴿لِيُنْذِرَ بَأْسًا شَدِيدًا﴾ قال ابن عباس: (يريد: لينذر عذابًا شديدًا) {1} [قال الفراء: (مع البأس أسماء مضمرة يقع عليها الفعل قبل أن يقع على البأس) {2}.يعني أن] {3} المفعول الأول للإنذار محذوف على تقدير: لينذر الكافرين بأسًا، كما قال في ضده: ﴿وَيُبَشِّرَ الْمُؤْمِنِينَ﴾، فأظهر {4}. وفسر الزجاج فقال: (أي لينذرهم بالعذاب البئيس) {5}.وقوله تعالى: ﴿مِنْ لَدُنْهُ﴾ قال ابن عباس: (يريد من عنده) {6}.وقال الزجاج:- (من قِبَلِهِ) {7}. قال: (وفي لدن لغات يقال: لدُ، ولَدُنْ، ولَدَى، والمعنى {8} واحد. قال: وهي لا تتمكَّن تمكُّن عند؛ لأنك تقول: هذا القول عندي صواب، ولا تقول: هو لدني صواب {9}، وتقول {10}: عندي مال عظيم، والمال غائب عنك، ولدن لما يليك لا غير) {11}.وقرأ عاصم في رواية أبي بكر: (من لَدُنِهِ)، بشم الدال الضمة وبكسر النون والهاء {12}. وهي لغة الكلابيين {13}.روى أبو زيد عنهم أجمعين: (هذا من لدُنِه، فتحوا اللام وضموا الدال وكسروا النون) {14}.قال أبو علي الفارسي: (في لدُنْ لغات: لدن مثل سبعٍ، وتخفف الدال، فإذا خففت على ضربين أحدهما: أن تحذف {15} الضمَّة من الدال فيقال: لدن. والآخر: أن تحذف الضمة من الدال وتنقل إلى اللام، فيقال: لدن، مثل: عضد، وفي كلا الوجهين يجتمع في الكلمة ساكنان: الدال المنقول عنها الحركة، والمحذوفة منها مع النون. فأما قراءة عاصم: (من لَدْنِهِ) {16} فالكسرة في النون ليست بجر، إنما هي كسرة للتقاء الساكنين، وذلك أن الدال أسكنت كما أسكنت في سبُعٍ، والنون ساكنة، فلما التقى ساكنان كسر الثاني منهما وأشمت {17} الدال الضمة، لتدل على أنها كانت متحركة بها، كما قالوا: أنت تَغْزُين. وقولهم: قُيل، أشمت الكسرةُ فيهما الضمة، لتدل على أن الأصل فيهما التحريك بالضم، وإن كان إشمام عاصم ليس بحركة خرجت إلى اللفظ، وإنما هو تهيئة العضو لإخراج الضمة، ولو كانت حركة لم يلتق ساكنان ولم تكسر النون لاجتماعهما) {18}. وليس يحتمل هذا الموضع من الكلام في لدن أكثر مما ذكرنا، وما بقي نذكره عند قوله: ﴿قَدْ بَلَغْتَ مِنْ لَدُنِّي عُذْرًا﴾ [الكهف: 76]، إن شاء الله.والجار في قوله: ""من لدنه"" يحتمل وجهين: أحدهما: أن يكون صفة النكرة التي هي قوله: ""بأسًا""، وفيها ذكر الموصوف. والآخر: يكون متعلقًا بشديد {19}.وقوله تعالى: ﴿أَنَّ لَهُمْ أَجْرًا حَسَنًا﴾ قال الزجاج: (المعنى بأن لهم أجرًا حسنًا) {20}.قال ابن عباس: (يريد ثوابًا عظيمًا) {21}.وقال السدي: (هو الجنة) {22}."
  18,3,"قوله تعالى: ﴿مَاكِثِينَ فِيهِ أَبَدًا﴾ بمعنى: خالدين {1}. وهو حال للمؤمنين من قوله: (أن لهم أجرًا) {2}."
  18,4,"وقوله تعالى: ﴿وَيُنْذِرَ الَّذِينَ قَالُوا اتَّخَذَ اللَّهُ وَلَدًا﴾ قال ابن عباس: (يريد بعذاب الله ونقمته) {1}.قال الكلبي، والسدي: (يعني اليهود والنصارى) {2}."
  18,5,"قوله تعالى: ﴿مَا لَهُمْ بِهِ﴾ أي: بذلك القول ﴿مِنْ عِلْمٍ﴾ يعني: قالوه جهلاً، وافتراء على الله تعالى ﴿وَلَا لِآبَائِهِمْ﴾ اختار الفراء ﴿كَلِمَةً﴾ بالنصب.قال الفراء: (من نصب أضمر الفاعل؛ كأنه قيل: كبرت تلك الكلمة كلمة، ومن رفع لم يضمر شيئًا، كما تقول: عظم قولك) {1}.وقال الزجاج: (المعنى: كبرت مقالتهم كلمة، و ﴿كلِمَةً﴾ منصوب على التمييز)؛ هذا كلامه {2}.ومعنى التمييز في هذا: أنك إذا قلت: كبرت المقالة، أو الكلمة، جاز أن يتوهم أنها كبرت كذبًا، أو جهلاً، أو افتراء، فلما قلت: كلمة، ميزتها من محتمل فانتصب، كما تقول في باب التمييز.قال أبو عبيد: (والنصب وجه القراءة؛ لأن الكلمة قد ذكرت قبل، وهي قوله: ﴿قَالُوا اتَّخَذَ اللَّهُ وَلَدًا﴾، فصارت مضمرة في (كبرت) {3}.قال الأخفش: (هذه في النصب كقول الشاعر:ولقد علمت إذا العشار ترَوَّحت .... هدج الرئال تكبهن شمالاً {4} أي: تكبُّهنَّ الرياح شمالاً، وهاهنا كأنه قيل: كبرت تلك الكلمة) {5}.﴿فَلَعَلَّكَ بَاخِعٌ نَفْسَكَ عَلَى آثَارِهِمْ إِنْ لَمْ يُؤْمِنُوا بِهَذَا الْحَدِيثِ أَسَفًا﴾ [الكهف: 6]."
  18,6,"قوله تعالى: ﴿فَلَعَلَّكَ بَاخِعٌ نَفْسَكَ﴾ قال ابن عباس، ومجاهد: (قاتل نفسك) {1}. وهو قول المفسرين، وأهل المعاني {2}. قال الفراء في المصادر: (بَخَعَها، يبخَعُهَا، بخعًا، وبخوعًا) {3}. وقال الليث: (بَخَعَ الرجل نفسه إذا قتلها غيظًا من شدة وجده بالشيء) {4}.وأنشد قول ذي الرمة {5}:ألا أيُّهذا الباخعُ الوجد نفسه ... لشيءٍ نحته عن يديه المقادرقال أبو عبيدة: (كان ذو الرمة ينشد الوجد رفعًا) {6}.وقال الأصمعي: (يقول: إنما هو الوجد بالفتح) {7}.وأصل معنى البَخْع: الجهد، يقال: بَخَعْت لك نفسي، أي جهدتها، ذكره الفراء، والأخفش {8}. وفي حديث عائشة: (أنها ذكرت عمر فقالت: بَخَعَ الأرض) {9}. أي: جهدها حتى أخرج ما فيها من أموال الملوك.وقال الكسائي: (بَخَعْتُ الأرض بالزراعة، إذا أنهكتها وتابعت {10} حراثتها، ولم تجمَّها عامًا، وبَخَعَ الوجدُ نفسه إذا أنهكها، وأنشد بيت ذي الرمة) {11}. وعلى هذا معنى: ﴿بَاخِعٌ نَفْسَكَ﴾ أي: ناهكها، وجاهدها حتى تهلكها، ولكن أهل التأويل كلهم قالوا: قاتل نفسك ومهلكها؛ والأصل هو ما ذكرنا {12}.وقوله تعالى: ﴿عَلَى آثَارِهِمْ﴾ قال الزجاج: (أي من بعدهم) {13}. وهذا كلام العرب يقولون: مات فلان واحدًا على أثر فلان، أي: بعده، وأصل هذا من التأثير، والأثر الذي هو العلامة، وذلك أنهم يقولون: خرجت في أثر فلان، وجئت على أثره، يعنون بعده، كأنهم يريدون أثر سلوكه الطريق، ثم كثر هذا حتى استعمل بمعنى بعد حيث لا يتحقق الأثر، كقول: مات فلان على أثر فلان أي: بعده، وأثر كذا بكذا أتبعه إياه {14}، ومنه قول متمم {15}:فأثر سيل الواديين بديمةٍأي: أتبعه بمطر.ومعنى ﴿عَلَى آثَارِهِمْ﴾ هاهنا: من بعدهم، وتحقيقه ما بينَّا، وليس يريد من بعد موتهم، وإنما التأويل: من بعد توليهم وإعراضهم عنك {16}.قوله تعالى: ﴿إِنْ لَمْ يُؤْمِنُوا بِهَذَا الْحَدِيثِ﴾ قال ابن عباس وغيره: (يعني القرآن) {17}.﴿أَسَفًا﴾ قال مجاهد: (جزعاً) {18}.وقال السدي: (حزنًا) {19}. وقال سفيان: (غضبًا) {20}.وجمع ابن عباس بينهما فقال: (يريد: غضبًا وحزنًا) {21}. وقال الزجاج: (والأسف: المبالغة في الحزن والغصب) {22}. وذكرنا الكلام في هذا عند قوله: (غضبان أسفًا) في سورة الأعراف. وانتصابه يجوز أن يكون على المصدر، ودل ما قبله من الكلام على أنه تأسف، ويجوز أن يكون مفعولاً له أي: للأسف، كقولهم: جئتك ابتغاء الخير {23}.وقال الزجاج: (﴿أَسَفًا﴾ منصوب؛ لأنه مصدر في موضع الحال) {13}. وفي هذه الآية إشارة إلى نهي النبي -ﷺ- عن كثرة الحرص على إيمان قومه حتى يؤدي ذلك إلى هلاك نفسه بالأسف، والفاء في قوله: ﴿فَلَعَلَّكَ﴾ جواب الشرط، وهو قوله: ﴿إِنْ لَمْ يُؤْمِنُوا﴾ قدّم عليه، ومعناه التأخير."
  18,7,"قوله تعالى: ﴿إِنَّا جَعَلْنَا مَا عَلَى الْأَرْضِ زِينَةً لَهَا﴾ قال مجاهد: (ما عليها من شيء من البحار، والجبال، والأشجار، والنبات) {1}. والمعنى: إنا زينّا الأرض بما خلقنا فيها من الماء، والمعادن، وأنواع المخلوقات، ويدخل في هذا كل ما على الأرض من ذي الروح والجماد.وقوله تعالى: ﴿لِنَبْلُوَهُمْ﴾ قال ابن عباس: (يريد الاختبار في خلقه بما يفهمون) {2}. ومضى الكلام في مثل هذا في مواضع {3}.وقوله تعالى: ﴿أَيُّهُمْ أَحْسَنُ عَمَلًا﴾ قال الحسن: (أيّهم أزهد في الدنيا زهدًا، وأترك لها تركًا) {4}. وهذا قول أبي إسحاق قال: (فالحسن العمل من زهد فيما زيِّن له من الدنيا) {5}.وقال مقاتل: (أيهم أصلح فيما أوتي من المال) {6}.وذكر قتادة في تفسير هذه الآية قول النبي -ﷺ-: ""إن الدنيا خضرة حلوة، وإن الله مستخلفكم فيها فناظر كيف تعملون، فاتقوا فتنة الدنيا"" {7}. قال الزجاج: (و ﴿أَيُّهُمْ﴾ رفع بالابتداء؛ لأن لفظه لفظ الاستفهام) {5}. والمعنى: ليختبر أهذا أحسن أم هذا، والاستفهام لا يعمل فيه ما قبله إلا ما يخبر، وإنما يعمل فيه ما بعده. ثم أعلم جل وعز أنه [مبيد] {9} ومُفْن ذلك كله."
  18,8,"بقوله: ﴿وَإِنَّا لَجَاعِلُونَ مَا عَلَيْهَا صَعِيدًا جُرُزًا﴾ [الكهف: 8].قال أبو عبيد: (الصعيد: المستوي من الأرض) {1}. وقال الزجاج: (الصعيد: الطريق الذي لا نبات فيه) {2}. ومثله قال المفضل. وقد ذكرنا تفسير الصعيد في آية التيمم {3}.وأما الجرز فقال الفراء: (الجُرُز: الأرض لا نبات فيها، يقال: جُرِزَت الأرض فهي مجروزة، وجَرَزَها الجرادُ أو النساء أو الإبل أكلت ما عليها) {4}.وقال الزجاج: (الجرز: الأرض التي لا تنبت، كأنها تأكل النَّبْت أكلاً، يقال: أرض جُرُز، وأرَضُون أَجْرازٌ) {2}.وامرأة جَرُوز إذا كانت أكولا، وسيف جرَّاز إذا كان مستأصلاً {6}، ونذكر شيئًا من هذا عند قوله: ﴿نَسُوقُ الْمَاءَ إِلَى الْأَرْضِ الْجُرُزِ﴾ [السجدة: 27] إن شاء الله.قال مجاهد في هذه الآية: (بلاقع ليس فيه نبات) {7}. وقال عطاء عن ابن عباس في هذه الآية: (يريد يوم القيامة يجعل الله الأرض جرزًا ليس فيها ماء ولا نبات) {8}."
  18,9,"قوله تعالى: ﴿أَمْ حَسِبْتَ أَنَّ أَصْحَابَ الْكَهْفِ﴾ الآية. ذكرنا سبب نزول قصة أصحاب الكهف عند قوله: ﴿وَيَسْأَلُونَكَ عَنِ الرُّوحِ﴾ [الإسراء: 85]. وذكر محمد بن إسحاق سبب نزول هذه القصة مشروحًا، فقال: (كان النضر ابن الحارث من شياطين قريش، كان يؤذي رسول الله ﷺ، وينصب له العداوة، وكان قدم الحيرة {1} وتعلم بها أحاديث رستم {2}، واسفنديار {3}، وكان رسول الله -ﷺ- إذا جلس مجلسًا ذكر فيه الله تعالى، وحذر قومه ما أصاب من كان قبلهم من الأمم، خلفه في مجلسه إذا قام، ثم قال: وإنا والله يا معشر قريش أحسن حديثًا منه فهلمّوا أحدثكم بأحسن من حديثه، ثم يحدثهم عن ملوك فارس، فبعثته قريش، وبعثوا معه عقبة بن أبي معيط {4} إلى أحبار يهود [بالمدينة، وقالوا لهما: سلوا عن محمد، وعن صفته، وأخبروهم بقوله، فإنهم أهل الكتاب الأول، وعندهم من العلم مما ليس عندنا من علم الأنبياء، فخرجا حتى قدما المدينة فسألوا أحبار يهود] {5} عن رسول الله -ﷺ- ووصفوا لهم صفته، وأخبروهم بأمره وببعض قوله، فقالت لهم أحبار يهود: سلوه عن ثلاث: عن فتية ذهبوا في الدهر الأول، ما كان من أمرهم؟ فإنه كان لهم حديث عجيب، وعن رجل طوّاف قد بلغ مشارق الأرض ومغاربها ما كان نبأه؟ وسلوه عن الروح ما هو؟ فإن أخبركم فهو نبي فاتبعوه، وإن لم يخبركم فهو متقوّل. فأقبل النضر بن الحارث وصاحبه حتى قدما مكة وقالا: قد جئناكم بفصل ما بيننا وبين محمد، وأخبراهم بما قالت اليهود. فجاؤوا رسول الله -ﷺ- وسألوه عن هذه الأشياء، فقال رسول الله -ﷺ-: ""أخبركم بما سألتم عنه غدًا"". ولم يستثن، فانصرفوا عنه، فمكث رسول الله -ﷺ- فيما يذكرون خمس عشرة ليلة لا يحدث الله إليه في ذلك وحيا، ولا يأتيه خبر، حتى أرجف أهل مكة به، وقالوا: وعدنا محمد غدًا واليوم خمس عشرة ليلة، وشقّ عليه ذلك، ثم جاءه جبريل من الله -عز وجل- بسورة أصحاب الكهف فيها معاتبة الله إياه على حزنه عليهم، وخبر ما سألوا عنه من أمر الفتية، والرجل الطوّاف) {6}.وافتتح السورة تبارك وتعالى بحمده وذكر نبوة رسوله لما أنكروه عليه من ذلك وهو قول: ﴿أَنْزَلَ عَلَى عَبْدِهِ الْكِتَابَ﴾ [الكهف: 1]، فذكر أنه أنزل عليه القرآن للإنذار والتبشير إلى قوله: ﴿وَيُنْذِرَ الَّذِينَ قَالُوا اتَّخَذَ اللَّهُ وَلَدًا﴾، يعني قريشًا في قولهم: الملائكة بنات الله {7}.ثم عاتبه على حزنه عليهم حين فاته ما كان يرجو منهم من الإسلام بقوله: ﴿فَلَعَلَّكَ بَاخِعٌ نَفْسَكَ﴾ الآية. ثم قال: ﴿إِنَّا جَعَلْنَا مَا عَلَى الْأَرْضِ زِينَةً لَهَا لِنَبْلُوَهُمْ أَيُّهُمْ أَحْسَنُ عَمَلًا﴾ أيهم أتبعُ لأمري وأعمل بطاعتي، ﴿وَإِنَّا لَجَاعِلُونَ مَا عَلَيْهَا صَعِيدًا جُرُزًا﴾، يعني أنَّ ما على الأرض فانٍ زائل، وأن المرجع إلى فأجزي كلا بعمله، فلا يحزنك ما ترى وتسمع.ثم أخبر عن ما سألوه عنه من شأن الفتية فقال: ﴿أَمْ حَسِبْتَ﴾ فقال أبو إسحاق: (معناه: بل حسبت) {8}. والكلام في ﴿أَمْ﴾ في مثل هذا الموضع قد ذكرناه في قوله: ﴿أَمْ حَسِبْتُمْ أَنْ تَدْخُلُوا الْجَنَّةَ﴾ [البقرة: 214] وفي غيره من مواضع {9}.وقوله: ﴿أَنَّ أَصْحَابَ الْكَهْفِ﴾ يعني أولئك الفتية الذين سئل عن قصتهم {10}.و ﴿الْكَهْفِ﴾ قال الليث: (كالمغارة في الجبل) {11}. روى عكرمة عن ابن عباس أنه قال: (كل القرآن أعلمه إلا أربعة: غسلين {12}، وحنان {13}، والأواه {14}، والرقيم) {15}.وروى عكرمة أيضًا عن ابن عباس أنه سئل عن الرقيم فقال: (زعم كعب أنها القرية التي خرجوا منها) {16}؛ ونحو هذا قال السدي {17}.وروي كن ابن أبي طلحة عنه قال: (""الرَّقِيم"": الكتاب) {18}.وهو قول مجاهد {19}. وسعيد بن جبير قال: (""الرَّقِيم"": لوح من حجارة) {20}.وقيل: (من رصاص كتب فيه أسماؤهم وقصتهم، وجعل في البناء على باب الكهف) {21}، ونحو هذا قال عطاء عن ابن عباس {22}، وهو قول جميع أهل المعاني والعربية قالوا: (الرقيم: الكتاب) {23}.والأصل فيه المرقوم ثم حُول إلى فعيل، والرَّقْم: الكتابة، ومنه قوله -عز وجل-: ﴿كِتَابٌ مَرْقُومٌ﴾ [المطففين: 9] أي: مكتوب، وأنشدوا {24}: سأرقم في الماء القراح إليكم ... على بعدكم إن كان في الماء راقمُوقال الفراء: (الرقيم: لوح كان فيه أسماؤهم) {25}، ونرى أنه إنما سُمى رقيما؛ لأن أسماءهم كانت مرقومة {26} فيه {27}.وقوله تعالى: ﴿كَانُوا مِنْ آيَاتِنَا عَجَبًا﴾ قال مجاهد، وسفيان: (لم يكونوا بأعجب آياتنا) {28}. قال المفضل: (أم حسبت أنهم كانوا عجبًا من آياتنا فقط، فلا يحسن ذلك، فإن آياتنا كلها عجيب) {29}. وقال أبو إسحاق: (أعلم الله أن قصة أصحاب الكهف ليست بعجيبة من آيات الله؛ لأن خلق السموات والأرض وما بينهما مما يشاهد أعجب من قصة أصحاب الكهف) {30}. والعجب هاهنا مصدر سمي المفعول به.والتقدير: كانوا معجوبًا منهم، فسموا بالمصدر، والمفعول من هذا يستعمل باسم المصدر {31}."
  18,10,"قوله تعالى: ﴿إِذْ أَوَى الْفِتْيَةُ﴾ الآية، ""إِذْ"" هنا لا يجوز أن يكون متعلقًا بما قبله على تقدير: أم حسبت إذ أوى الفتية؛ لأنه كان بين النبي -ﷺ- وبينهم مدة طويلة، فلم يتعلق الحسبان بذلك الوقت الذي أووا فيه إلى الكهف، وإذ يتعلق بمحذوف كأنه قيل: اذكر إذا أوى {1}. كما قلنا في مواضع كثيرة. ومعنى ﴿أَوَى الْفِتْيَةُ إِلَى الْكَهْفِ﴾: صاروا إليه وجعلوه مأواهم {2}.قال ابن عباس: (يريد هربوا إلى الكهف) {3}. وذكرنا الكلام في الفتية عند قوله: ﴿وَقَالَ لِفِتْيَانِهِ﴾ [يوسف: 62] في سورة يوسف.وقوله تعالى: ﴿فَقَالُوا رَبَّنَا آتِنَا مِنْ لَدُنْكَ رَحْمَةً﴾ أخبر الله تعالى أنهم لما هربوا عمن يطلبهم اشتغلوا بالدعاء والتضرع إلى الله تعالى: ﴿فَقَالُوا رَبَّنَا آتِنَا مِنْ لَدُنْكَ رَحْمَةً﴾ أي: أعطنا من عندك مغفرة ورزقًا {4}.قال ابن عباس: (يريدون تغنينا بها عن جميع من سواك) {5}، يعني أن قولهم: ﴿مِنْ لَدُنْكَ﴾ تتضمن هذا المعنى.وقوله تعالى: ﴿وَهَيِّئْ لَنَا﴾ أي: أصلح، من قولك: هيأت الأمر فتهيأ ﴿مِنْ أَمْرِنَا رَشَدًا﴾ الرَّشَد، والرُّشْد، والرَّشاد، والرّشَاد: نقيض الضلال {6}.قال أبو إسحاق: (أي أرشدنا إلى ما يقرب منك ويزلف عندك) {7} وهذا معنى قول ابن عباس: (أرشد أفعالنا إلى محبتك) {8}. وقال أهل المعاني: (تقدير الآية: هيئ لنا من أمرنا ذا رشد) {9}. أي: أمر ذا رشد. فحذف الموصوف، ثم حذف المضاف أيضًا، كأنهم قالوا: هيئ لنا من أمرنا ما نصيب به الرشد."
  18,11,"قوله تعالى: ﴿فَضَرَبْنَا عَلَى آذَانِهِمْ﴾ قال المفسرون: (معناه: أنمناهم) {1}.قال أبو إسحاق: (أي منعناهم أن يسمعوا؛ لأن النائم إذا سمع انتبه) {2}. فالمعنى: أنمناهم ومنعناهم السمع. وهذا معنى قول ابن عباس: (فضربنا على آذانهم بالنوم) {3}. والمعنى: سددنا آذانهم بالنوم الغالب عن نفوذ الأصوات إليها، ومن هذا النظم قال الأسود بن يَعْفُر {4}:ومن الحَوادِثِ لا أَبالَكِ أَنَّثِي ... ضربَتْ عليَّ الأرضُ بالأسْدَادِوذلك أنه كان ضريرًا لا يتمكن من المشي في الأرض، فكأن الأرض قد ضربت بالأسداد عليه، حيث منع من التصرف.وقوله تعالى: ﴿فِي الْكَهْفِ﴾ بيان أن محل الضرب على آذانهم بالنوم كان في الكهف، فهو ظرف له بمنزلة المكان. ثم ذكر ظرف الزمان فقال: ﴿سِنِينَ عَدَدًا﴾، وذكر العدد هاهنا يفيد كثرة السنين {5}، وكذلك كل شيء مما يعد إذا كثر فيه العدد ووصف به أريد كثرته؛ لأنه إذا قلَّ فُهِم مقداره فلم يحتج أن يعد، وإذا كثر احتيج إلى أن يُعد، فإذا قلت: أقمت أيامًا عددًا. أردت به الكثرة {6}. وفي انتصابه وجهان أحدهما: أنه نعت للسنين. المعنى: سنين ذات عدد، أي معدودة، هذا قول الفراء، والزجاج {7}.وعلى هذا يجوز في الآية ضربان من التقدير أحدهما: حذف المضاف. والثاني: تسمية المفعول باسم المصدر. قال الزجاج: (ويجوز أن ينتصب على المصدر، المعنى: نعد عددًا) {2}."
  18,12,"قوله تعالى: ﴿ثُمَّ بَعَثْنَاهُمْ﴾ قال ابن عباس: (يريد من بعد نومهم) {1}، يعني: أيقظناهم بعد نومهم، وقوله تعالى: ﴿لِنَعْلَمَ﴾ المفسرون يقولون في هذا: (لنرى) {2}.وقد تكلمنا في مثل هذا عند قوله: ﴿إِلَّا لِنَعْلَمَ﴾ [البقرة: 143] في سورة البقرة، وقوله: ﴿وَلَمَّا يَعْلَمِ اللَّهُ الَّذِينَ جَاهَدُوا مِنْكُمْ﴾ [آل عمران: 142] في سورة آل عمران.وقوله تعالى: ﴿أَيُّ الْحِزْبَيْنِ﴾ الآية، ﴿أَيُّ﴾ رفع بأحصى على الابتداء والخبر، ولم يوقع العلم على شيء منهما في الظاهر، وهو في الباطن واقع على ما يتضمنان من القصة، كما تقول: اذهب فاعلم أيهم قام {3}. قال الله تعالى: ﴿سَلْهُمْ أَيُّهُمْ بِذَلِكَ زَعِيمٌ﴾ [القلم: 40]. و ﴿أَيُّ﴾ من حروف الاستفهام فلا يعمل فيه ما قبله، سوى ما يجر، وذكرنا هذا.وسنذكر استقصاء المسألة عند قوله: ﴿ثُمَّ لَنَنْزِعَنَّ مِنْ كُلِّ شِيعَةٍ أَيُّهُمْ أَشَدُّ﴾ [مريم: 69] إن شاء الله.واختلفوا في الحزبين، فقال عطاء عن ابن عباس: (الحزبين الملوك الذين تداولوا المدينة مَلِكًا بعد مَلِك، وأصحاب الكهف حزب والملوك حزب) {4}. وقال مجاهد: (الحزبين من قوم الفتية) {5}. وقال الكلبي: (يعني المؤمنين والكافرين) {6}.وحكى الفراء: (أن طائفتين من المسلمين في دهر أصحاب الكهف اختلفوا في مدة لبثهم) {7}. قال من اختار هذا القول: (تنازع المسلمون الأولون أصحاب الملك الذي أطلقه الله تعالى على أصحاب الكهف، والمسلمون الذين أسلموا حين رأوا أصحاب الكهف في قدر مدة لبثهم في الكهف) {8}. فهذا ما وجدته للمفسرين في هذه الآية، وهو غير مقنع، ولا كاف، إذ لم يفتح غلقا.وقال صاحب النظم: [(هذا ما قصه ربنا] {9} فيما بعد هذا الفصل في قوله: ﴿بَعَثْنَاهُمْ لِيَتَسَاءَلُوا بَيْنَهُمْ﴾ إلى قوله: ﴿قَالُوا رَبُّكُمْ أَعْلَمُ بِمَا لَبِثْتُمْ﴾ [الكهف: 19]، وهذا يدل على تنازع كان فيما بينهم فيما لبثوا، وكان ذلك سبب بعث الله إياهم، كما أعلمنا -عز وجل- وهو عالم بما كان منهم، وبما يكون قبل أن يكون، ويتعالى عن أن يكون شيء سببًا لعلمه، والتأويل -إن شاء الله-: ثم بعثناهم ليكون ذلك منهم، أي: تساؤل وتنازع واختلاف في مدة لبثهم) {10}. فجعل صاحب النظم ﴿لِنَعْلَمَ﴾ هاهنا بمعنى ليكون ذلك لنعلم كائنًا قال الله تعالى: ﴿أَمْ تُنَبِّئُونَهُ بِمَا لَا يَعْلَمُ فِي الْأَرْضِ﴾ [الرعد: 33]، أي: بما ليس ولا يعلمه كائنا.قال: (والحزبان جميعًا من أصحاب الكهف، أنهم قالوا هذا القول منكرين على من قال: ﴿لَبِثْنَا يَوْمًا أَوْ بَعْضَ يَوْمٍ﴾ [الكهف: 19]، فدل هذا على أن أصحاب الكهف كانوا حزبين) {11}؛ هذا كلامه، وهو بعيد؛ لأنه يجعل معنى قوله: ﴿لِنَعْلَمَ أَيُّ الْحِزْبَيْنِ أَحْصَى لِمَا لَبِثُوا أَمَدًا﴾ [الكهف: 12] بمعنى: ليكون بينهم تساؤل وتنازع، وهذه العبارة التي في نظم الآية لا ينسى عن هذا المعنى الذي {12} ذكره، وقد ارتكب في كتابه أشياء بعيدة لم أحكها لبعدها. ومعنى الآية على ما ذكره المفسرون: قتادة، ومجاهد، وغيرهما: (ليعلم أي الحزبين من المؤمنين والكافرين من قوم أصحاب الكهف عدّ أمد لبثهم وعلم ذلك، وكأنه وقع بينهم تنازع في مدة لبثهم في الكهف، وخروجهم من بيتهم، فبعثهم الله ليبين ذلك ويظهر) {13}.وأما وجه نصب قوله: ﴿أَمَدًا﴾ فقال الفراء: (ويكون نصبه على وجهين: إن شئت جعلته خرج من أحصى مفسرًا، كما تقول: أي الحزبين أصوب قولاً، وإن شئت أوقعت عليه اللُّباث للباثهم أمدا) {7}.وقال أبو إسحاق نحو هذا سواء فقال: (﴿أَمَدًا﴾ منصوب على نوعين: وهو على التمييز إن شئت كان على أحصى أمدا، فيكون العامل فيه أحصى، كأنه قيل: لنعلم أهؤلاء أحصى للأمد أم هؤلاء؟. والوجه الثاني: أن يكون منصوبًا بلبثوا، ويكون أحصى متعلقًا بلما، فيكون المعنى: أيّ الحزبين أحصى للبثهم في الأمد) {15}.قال أبو علي الفارسي: (إن انتصاب الأمد بالتمييز عندي ممتنع غير مستقيم؛ وذلك أنه لا يخلو من أن يحمل أحصى على أن يكون فعلاً ماضيًا، أو أفعل نحو: أحسن وأعلم، فلا يجوز أن يكون أحصى أفعل، وغير مثال الماضي لأمرين أحدهما: أنه يقال: أحصى يحصى في التنزيل: ﴿أَحْصَاهُ اللَّهُ وَنَسُوهُ﴾ [المجادلة: 6] وأفعل يفعل لا يقال منه: هو أفعل من كذا، فأما قولهم: ما أولاه للخير، وما أعطاه للدرهم، فمن الشاذ النادر الذي حكمه أن يحفظ لقلته، وسبيل ما كان كذلك أن لا يقاس عليه، ولا جوز أن يكون أحصى أفعل من كذا لهذا. والأمر الآخر: هو أن ما ينتصب على التمييز في نحو: هو أكثر منك مالاً، وأحسن وجهًا، وأغزر علمًا، هو في المعنى فاعل، وإن كان في اللفظ منتصبًا، ألا ترى أن الأمد ليس هو الذي أحصى، فهو خارج عن ما عليه {16} الأسماء المنتصبة على التمييز، وإذا كان كذلك لم يجز أن يكون منها كان أحصى مثالاً ماضيًا، ويكون المعنى: لنعلم أي الحزبين أحصى أمدًا للبثهم، فيكون الأملى على هذا منتصبًا بأنه مفعول به، والعامل فيه أحصى الذي هو فعل، ومن قدّر أن أحصى أفعل من كذا فمخطئ لما ذكرنا) {17}.وهذا الذي ذكره أبو علي قول ثالث؛ لأن ﴿أَمَدًا﴾ عند الفراء وأبي إسحاق: ينتصب إما على التمييز، أو على الظرف، وعند أبي علي أنه مفعول به {18}. قال {19}: (ويجوز مع تأويل أحصى أفعل من كذا أن ينتصب الأمد بلبثوا، ويكون المعنى: للبثهم أمدا أي في الأمد، يتصل أحصى باللام، قال: وهذا القول مستكره؛ لأنك جعلت أحصى أفعل من كذا. قال: ومن قدّر أحصى فعلا وقدّر انتصاب الأمد بلبثوا دون أحصى فقد أساء، وعدل بالكلام عن وجهه، ألا ترى أن الكلام: أحصيت كذا، وفي التنزيل ﴿أَحْصَاهُ اللَّهُ﴾ [المجادلة: 6]، و ﴿وَأَحْصَى كُلَّ شَيْءٍ عَدَدًا﴾ [الجن: 28]، فأوصل الفعل بلا حرف، وإذا كان تأويله انتصاب الأمد بلبثوا يؤدي إلى أن الفعل الذي هو أحصى المتعدي بلا حرف يتعدى بحرف استقبحنا هذا التأويل، وكرهناه، واستبعدناه) {20}."
  18,13,""
  18,14,"قوله تعالى: ﴿وَرَبَطْنَا عَلَى قُلُوبِهِمْ﴾ قال المفسرون: (ألهمناها الصبر وثبتناها) {1}وذكرنا معنى الربط على القلب في سورة الأنفال {2}.وقوله تعالى: ﴿إِذْ قَامُوا﴾ قال عطاء ومقاتل: (يعني من النوم) {3}. وهذا يتعدّى من وجوه، أحدها: أن الله تعالى استأنف قصتهم بقوله: ﴿نَحْنُ نَقُصُّ عَلَيْكَ﴾ [الكهف: 13] الآية، فلأنه قال: ﴿إِذْ قَامُوا فَقَالُوا رَبُّنَا رَبُّ السَّمَاوَاتِ وَالْأَرْضِ﴾ وكانوا قد قالوا هذا قبل نومهم في الكهف، ولكن الوجه تفسير ﴿قَامُوا﴾: (أنهم قاموا بين يدي ملكهم دقيانوس الجبار الذي كان يفتن أهل الإيمان عن دينهم، فربط الله على قلوبهم بالصبر واليقين حتى قالوا بين يديه: ﴿رَبُّنَا رَبُّ السَّمَاوَاتِ وَالْأَرْضِ﴾ الآية، وذلك أنه كان يدعو الناس إلى عبادة الأصنام، والذبح للطواغيت، فثبت الله هؤلاء الفتية وعصمهم، حتى عصوا ذلك الجبار وأقروا بربوبية الله -سبحانه وتعالى- ووحدانيته، وأنهم إن دعوا غيره وعبدوه كان ذلك شططا) {4}.وفي تفسير شبل عن مجاهد قال: (إنهم أبناء عظماء مدينتهم، فخرجوا فاجتمعوا وراء المدينة من غير ميعاد، فقال رجل منهم هو أسن القوم: إني لأجد في نفسي شيئًا ما أظن أن أحدًا يجده. قالوا: ما تجد؟ قال: أجد في نفسي أن ربي رب السموات والأرض. فقالوا: نحن كذلك نجده في أنفسنا، فقاموا جميعًا فقالوا: ربنا رب السموات والأرض) {5}.وقوله تعالى: ﴿لَقَدْ قُلْنَا إِذًا شَطَطًا﴾ أي: كذبًا وجورًا، قاله المفسرون {6}.ومعنى الشطط في اللغة: مجاوزة القدر {7}. قال الفراء: (يقال: قد أشطّ في السَّوم، إذا جاوز القدر، ولم أسمع إلا أَشطَّ، يُشِطُّ، إِشطَاطًا، شَطَطًا) {8}. وحكى الزجاج وغيره: (شَطَّ الرجل وأَشَطَّ إذا جار) {9}. ومنه قوله: ﴿وَلَا تُشْطِطْ﴾ [ص: 22]، ومثله أَشَطَّ، وأصل هذا من قولهم: بما شَطَّت الدار، إذا بعدت، فالشَّطَطُ في القول بعد عن الحق؛ وهو هاهنا منصوب على المصدر، والمعنى: لقد قلنا إذا قول شَطَط، قاله الزجاج {10}."
  18,15,"وقوله تعالى: ﴿هَؤُلَاءِ قَوْمُنَا اتَّخَذُوا مِنْ دُونِهِ آلِهَةً﴾ هذا من قول أصحاب الكهف، ويعنون الذين كانوا في زمان دقيانوس عبدوا الأصنام ﴿لَوْلَا يَأْتُونَ عَلَيْهِمْ بِسُلْطَانٍ بَيِّنٍ﴾ بحجة بينة.قال الزجاج: (ومعنى ﴿عَلَيْهِمْ﴾ أي على عبادة الآلهة) {1}. وهذا قول يوجب تقدير حذف المضاف، أي: هلا يأتون على عبادتهم، أو على اتخاذهم بسلطان بين، ثم حذف المضاف {2}.وقال صاحب النظم: (ظاهر قوله: ﴿لَوْلَا يَأْتُونَ﴾، حث وسؤال، وتأويله نفي وإبطال، على معنى: اتخذوا من دونه آلهة لا يأتون عليهم يسلطان؛ لأن في قولك: لولا فعلت كذا، دليل على أنه لم يفعله، وكان من حقه أن يفعل، وهذا من باب الإيماء إلى الشيء بالشيء)؛ انتهى كلامه {3}. وعلى قوله أيضًا يرجع حقيقة التأويل إلى تقدير حذف المضاف؛ لأن معنى ﴿لَوْلَا يَأْتُونَ عَلَيْهِمْ﴾ لا يأتون على عبادتهم، أي: على عبادة الآلهة، على هذا يحسن الكلام؛ لأن الحجة على الآلهة ضد الحجة لهم، فلابد من تقدير حذف المضاف، وإذا كان كذلك فالقول الأول أولى؛ لأنه لا يحتاج فيه إلى العدول عن ظاهر قوله: ﴿لَوْلَا يَأْتُونَ﴾، والكناية في قوله: ﴿عَلَيْهِمْ﴾ يجوز أن تكون عن القوم في قوله: ﴿هَؤُلَاءِ قَوْمُنَا﴾ وهو الظاهر، ويجوز أن تكون عن الآلهة."
  18,16,"وقوله تعالى: ﴿وَإِذِ اعْتَزَلْتُمُوهُمْ﴾ قال ابن عباس: (هذا من قول تمليخا، وهو رئيس أصحاب الكهف، قال لهم: وإذا اعتزلتموهم، أي: فارقتموهم وتنحيتم عنهم جانبًا، يعني عبدة الأصنام) {1}.﴿وَمَا يَعْبُدُونَ﴾ قال أبو إسحاق: (﴿مَا﴾ نصب، المعنى: واعتزلتم ما يعبدون إلا الله، فإنكم لن تتركوا عبادته) {2}، وذلك أنهم كانوا يشركون بالله فقال: اعتزلتم الأصنام ولم تعتزلوا الله ولا عبادته، وهذا قول الفراء وهو: (أن ﴿مَا﴾ اسم وليس بنفي) {3}.وروى عطاء عن ابن عباس في قوله: ﴿وَمَا يَعْبُدُونَ إِلَّا اللَّهَ﴾ قال: (يريد لم يعبد أصحاب الكهف إلا الله) {4}. وهذا يحمل على أن الله أخبر عنهم أنهم لم يعبدوا غيره، وعلى هذا لا يكون هذا حكايته قولهم؛ والقول ما قاله الفراء، والزجاج، وأهل التفسير {5}، يدل على صحته ما روي أنه في مصحف عبد الله: (وما يعبدون من دون الله) {6}. وهذا يقطع يكون ""ما"" اسماً.وقوله تعالى: ﴿فَأْوُوا إِلَى الْكَهْفِ﴾ قال الفراء: (هذا جواب ""إذ"" كما تقول: إذ فعلت كذا فافعل كذا) {3}، ومعناه: صيروا إليه واجعلوه مأواكم.﴿يَنْشُرْ لَكُمْ رَبُّكُمْ مِنْ رَحْمَتِهِ﴾ أي: يبسطها عليكم، ﴿وَيُهَيِّئْ لَكُمْ مِنْ أَمْرِكُمْ مِرْفَقًا﴾ قال ابن عباس: (يسهل عليكم ما خوفكم من الملك وظلمه، ويأتيكم من الله اليسر والرفق واللطف) {8}.وقال الكلبي: (يعني غداء يأكلونه) {9}. ويقال: (مخرجا) {10}. وكل ما ارتفقت به فهو مِرْفَق، ويقال فيه أيضًا: مَرْفَق، ويقال فيه أيضًا: مَرْفِق بفتح الميم وكسر الفاء، كقراءة أهل المدينة {11}، وهما لغتان في مِرْفَق اليد، والأمر، والمتكأ، قال أبو عبيدة: (المَرْفَق: ما ارتفقت به، وبعضهم يقول: المَرْفِق، فأما ما في اليدين فهو مِرْفَق) {12}.وقال الأخفش: (﴿مِرْفَقًا﴾ أي: شيئًا يَرْتَفقُون به، مثل المِقْطَعِ) {13}.ومن قرأ: مَرْفِقًا، جعله اسما مثل المسجد، ويكون لغة. قال أبو علي: (قوله: جعله اسما، أي: جعل المِرْفَقَ اسمًا ولم يجعله اسم المكان ولا المصدر من رَفَقَ يَرْفُقُ، كما أن المسجد ليس باسم الموضع من سَجَدَ يَسْجُدُ، وقوله: أو يكون لغة أي: لغة في اسم المصدر، كما جاء المَطْلِعُ ونحوه، ولو كان على القياس لفتحت اللام) {14}.قال الفراء: (وأكثر العرب على كسر الميم، من الأصل ومن مِرْفَق الإنسان، والعرب أيضًا تفتح الميم فيهما، فهما لغتان في هزا وفي هذا) {3}. وكأن الذين فتحوا الميم أرادوا أن يفرقوا بين المَرْفَق من الإنسان، وقال يونس: (الذي أختار المَرْفَق في الأمر، والمِرْفَق في اليد) {16}.وقال الأصمعي: (لا أعرف إلا الكسر فيهما) {17}؛ يعني كسر الميم في الأمر واليد، وذكر قطرب اللغتين جميعًا فيهما {18}."
  18,17,"قوله تعالى: ﴿وَتَرَى الشَّمْسَ إِذَا طَلَعَتْ تَزَاوَرُ عَنْ كَهْفِهِمْ ذَاتَ الْيَمِينِ﴾ الآية، التاء في قوله: ﴿وَتَرَى﴾ لمخاطب، أي: ترى أنت أيها المخاطب الشمس عند طلوعها تميل عن كهفهم، وليس أن من خوطب بهذا يرى ذلك، ولكن العادة في المخاطبة تكون على هذا النحو، ومعناه: أنك لو رأيته على هذه الصورة {1}.ومعنى ﴿تَزَاوَرُ﴾ قال ابن عباس: تتنحى {2}. وقال في رواية الوالبي: (تميل عنهم) {3}. ومعنى التَّزَاور: التمايل من الزَّوْر والأزور، فإن قيل: التَّزاور إنما يستعمل في زيارة بعض الناس بعضا، فكيف يحسن استعمال بمعنى الميل، كما قالوا: تمايل، أجروا تَزَاور مجرى تمايل، قال الشاعر {4}:كَلَون الحِصَان الأنبطِ البطن قائمًا ... تمايل عنه الجلُّ واللونُ أشقرُوكذلك قالوا: تجانف، بهذا المعنى {5}، وقراءة أهل الكوفة: بحذف تاء التفاعل، وقرأ ابن عامر: تَزْوَرُّ {6}. قال أبو الحسن: (لا يوضع في هذا المعنى إنما يقال: هو مزْوزٌّ عني، أي: منقبض) {7}. ويدل على أن معنى ازوزَّ انقبض قول عنترة {8}: ازورَّ من وقع القنا بلبانهِأي: انقبض. والذي حسَّن القراءة به قول جرير {9}:وفي الأظعان عن طلح ازورارفظاهر استعمال هذا في الأظعان مثل استعماله في الشمس {10}.وقوله تعالى: ﴿ذَاتَ الْيَمِينِ﴾، أي: ناحية اليمين، فذات هاهنا صفة قامت مقام الموصوف، كأنه قيل: ناحية ذات اليمين. قال الأخفش: (وهو نصب على الظرف) {11}.وقوله تعالى: ﴿تَقْرِضُهُمْ﴾ قال الوالبي عن ابن عباس: (تذرهم) {12}.وقال قتادة: (تدعهم) {13}. وقال مقاتل: (تجاوزهم) {14}.وقال الأخفش، والزجاج، وأبو عبيدة: (تعدل عنهم وتتركهم) {15}. وقال الكسائي: (قرضت المكان، أي: عدلت عنه) {16}.وأنشد قول ذي الرمة {17}:إلى ظُعُنٍ يَقْرضْن أقواز مشرفٍ ... شمالا عن أيمانهن الفوارسُوقال أبو عبيد: (القرض في أشياء) فمنها: القطع، وكذلك السير في البلاد إذا قطعتها، وأنشد البيت {18}.قال أبو عبيدة: (تقول لصاحبك: هل وردت مكان كذا؟ فيقول المجيب: إنما قرضته ذات الشمال، إذا مرَّ به وتجاوز عنه وهو على شماله) {19}.قال الكلبي: (يقول إذا طلعت الشمس مالت عن كهفهم ذات اليمين، يعني: يمين الكهف، وإذا غربت تمر بهم ذات الشمال، يعني: شمال الكهف لا تصيبه، وكان كهفهم نحو بنات نعش {20} في أرض الروم) {21}.وقال المفسرون: (أعلم الله تعالى أنه ثواهم في مَقنَاة {22} من الكهف مستقبلاً بنات نعش، تميل عنهم الشمس طالعة وغاربة، لا تدخل عليهم فتؤذيهم بحرها، وتغير أوانهم، وتبلي ثيابهم) {23}.وقال أبو علي الفارسي: (إذا مالت الشمس عنهم إذا طلعت، وتجاوزتهم إذا غربت، دلَّ أن الشمس لا تصيبهم ألبتة، أو في أكثر الأمر، فتكون صورهم محفوظة) {24}.هذا الذي ذكرنا قول المفسرين قالوا في سبب ميل الشمس عنهم: (إنهم كانوا في مَقْنَاة) {25}. وقال أبو إسحاق: (هذا التفسير ليس ببين، إنما جعل الله فيهم هذه الآية أن الشمس لا تقربهم في مطلعها ولا عند غروبها) {26}، ودل عليه قوله: ﴿ذَلِكَ مِنْ آيَاتِ اللَّهِ﴾ يعني: أن الله تعالى بقدرته {27} حبس عنهم ضوء الشمس وحرها عند طلوعها وغروبها، فلا تنالهم طالعة ولا غاربة، لا بكونهم في مكان لا تصيبه الشمس، ولكن بقدرة الله تعالى جعل ذلك آية من آياته، كما قال: ﴿ذَلِكَ مِنْ آيَاتِ اللَّهِ﴾ {28}.ثم أخبر أنهم كانوا في متسع من الكهف، ينالهم فيه برد الريح، ونسيم الهوى فقال: ""وهم في فجوة منه"" أي: من الكهف، والفجوة: متسع في مكان {29}.قال أبو عبيدة: (وجمعها فَجَوات) {30} وفِجَا، نحو: زَكوات وزِكَاء. ومنه الحديث: (فإذا وجد فجوة نصّ) {31} {32}.وقال مجاهد: (الفجوة: المكان الذاهب) {33}. يعني: الذاهب في السعة والعرض. قال ابن عباس في قوله: ""وهم في فجوة"" (يريد في سعة) {34}، ﴿ذَلِكَ مِنْ آيَاتِ اللَّهِ﴾، أي: ذلك التزاور والقرض من دلائل قدرة الله ولطفه بأصحاب الكهف. ﴿مَنْ يَهْدِ اللَّهُ فَهُوَ الْمُهْتَد﴾ أشار إلى أن الله تعالى هو الذي تولى هداية أصحاب الكهف] {35}، ولولا ذلك لم يهتدوا، فالمهتدي من هداه الله كهؤلاء، ﴿وَمَنْ يُضْلِلْ فَلَنْ تَجِدَ لَهُ وَلِيًّا مُرْشِدًا﴾، كدقيانوس الكافر وأصحابه."
  18,18,"قوله تعالى: ﴿وَتَحْسَبُهُمْ﴾ معنى هذا الخطاب على ما ذكرنا في قوله: ﴿وَتَرَى الشَّمْسَ﴾، أي: لو رأيتهم لحسبتهم أيقاظًا، هو جمع: أيقاظ، ويقظ، ويقظان، قا له الأخفمش، وأبو عبيدة، والزجاج {1}. وأنشدوا لرؤبة {2}: ووجدوا إخوانهم أيقاظاومثله: نَجْدٌ، نُجد، وأَنْجاد.وقوله تعالى: ﴿وَهُمْ رُقُودٌ﴾ أي: نائمون، وهو مصدر سمِّي به، كما يقال: قوم ركوع، وقعود، وسجود، يوصف الجميع بالمصدر {3}، ومن قال: إنه جمع راقد، فقد أبعد؛ لأنه لم يجمع فاعل على فعول {4}.(وإنما يحسبون أيقاظًا؛ لأن أعينهم مفتحة وهم نيام) {5}؛ قاله الكلبي. وحكى أبو إسحاق: (لكثرة تقلبهم، يظن أنهم غير نيام. قال: ويدل على هذا قوله: ﴿وَنُقَلِّبُهُمْ ذَاتَ الْيَمِينِ وَذَاتَ الشِّمَالِ﴾) {6}، وعلى هذا يجب أن يكثر تقلبهم.قال قتادة: (ذكر لنا أن أبا عياض {7} قال: كان لهم في كل عام تقليبتان) {8}.وهو قول أبي هريرة {9}. قال ابن عباس في رواية عطاء: (لئلا تأكل الأرض لحومهم، ولا تبليهم) {10}.وروى ابن أبي نجيح عن مجاهد قال: (يمكثون رقودًا على أيمانهم تسع سنين، ثم يقلبون على شمائلهم فيمكثون رقودًا تسع سنين) {11}. و ﴿ذَاتَ﴾ منصوبة على الظرف؛ لأن المعنى: نقلبهم في ناحية اليمين، كما قلنا في قوله: ﴿تَزَاوَرُ عَنْ كَهْفِهِمْ ذَاتَ الْيَمِينِ﴾.وقوله تعالى: ﴿وَكَلْبُهُمْ بَاسِطٌ ذِرَاعَيْهِ﴾ قال ابن عباس وأكثر المفسرين: (هربوا ليلاً من ملكهم، فمروا براع معه كلب، فتبعهم على دينهم ومعه كلبه) {12}. وقال كعب: (مروا بكلب فنبح عليهم فطردوه، فعاد ففعلوا ذلك مرارًا، فقال لهم الكلب: ما تريدون مني؟ لا تخشوا جانبي، أنا أحب أحباء الله، فناموا حتى أحرسكم) {13}.وقال عبيد بن عمير: (كان ذلك كلب صيدهم) {14}.ومعنى: ﴿بَاسِطٌ ذِرَاعَيْهِ﴾ أي: يلقيهما على الأرض مبسوطتين غير مقبوضتين، ومنه الحديث في الصلاة: أنه نهى عن افتراش السبع، وقال: ""لا تفترش ذراعيك افتراش السبع"" {15}، هو أن يضعهما على الأرض، والذراع: اسم جامع في كل ما يسمى يدًا من ذوي الأيدان.قال الليث: (الذراع: من طرف المرفق إلى أطراف الأصبع الوسطى) {16}. قال ابن السكيت: (الذراع مؤنثة، تقول: هذه ذراع) {17}.قال أبو علي: (لولا حكاية الحال لم يعمل اسم الفاعل في ذراعيه؛ لأنه إذا مضى اختص وصار معهودًا، فخرج بذلك من شبه الفعل، ألا ترى أن الفعل لا يكون معهودًا، فكما أن اسم الفاعل إذا وصف وحقر لم يعمل عمل الفعل لزوال شبهه عنه، كذلك إذا كان ماضيًا، ولكن المعنى على حكايته الحال الماضية) {18}. وهذا الفضل نذكره بأشرح من هذا عند قوله: ﴿رَابِعُهُمْ كَلْبُهُمْ﴾ [الكهف: 22].وقوله تعالى: ﴿بِالْوَصِيدِ﴾ قال ابن عباس في رواية على وعطاء: (بالفناء) {19}، وهو قول أكثر المفسرين، قال مجاهد والضحاك: (يعني فناء الكهف) {20}، وبه قال أكثر أهل اللغة.روى أبو عبيد عن الأحمر {21}: (الوصيد: الفناء) {22}.وقال الزجاج: (الوصيد: فناء البيت، وفناء الدار) {6}.وقال أبو عبيدة: (الوصيد: الفناء، والجميع وصائد ووصدٌ) {24}.وقال يونس والأخفش والفراء: (الوَصِيد والأصَيد لغتان، مثل: الوِكَاف {25} والإكاف) {26}.وقال الكسائي: (أهل تهامة {27} يقولون: الوصيد، وهو الفناء، وأهل نجد {28} يقولون: الأصيد، والقرآن بلغة تهامة نزل) {29}.وقال السدي: (الوصيد: الباب، وهو رواية عكرمة عن ابن عباس) {30}. واختيار المبرد قال: (﴿بِالْوَصِيدِ﴾ عند أهل اللغة: بالباب، أي: بحضرة الباب، يقال: فلان بالباب، وإنما يراد بحضرة الباب).وقال عطاء: (الوصيد: عتبة الباب) {31}. وهو اختيار ابن قتيبة قال: (لأنهم يقولون: أوصد بابك، أي: أغلقه، قال: وأصله أن تلصق الباب بالعتبة [إذا أغلقته، والكهف لم يكن له باب ولا عتبة، وإنما أراد أن الكلب منه بموضع العتبة من البيت] {32}، قال: وقد يكون الوصيد الباب نفسه) {33}، وأنشد {34}:بأرض فضاءٍ لا يسدُّ وصيدها ... عليَّ ومعروفي بها غير منكرِويقال: أصدت الباب، وأوصدته إذا أطبقته، وباللغتين قرئ: ﴿إِنَّهَا عَلَيْهِمْ مُؤْصَدَةٌ﴾ [الهمزة: 8] {35}. فمن قال: أَصَدت بالهمزة، قال: الأصيد، ومن قال: أوصدت، قال: الوصيد، ويقال للمطبق: الأصاد والوصاد، وهذا الاشتقاق يوجب أن يكون معنى الوصيد: الباب المطبق المجافى، فالذين قالوا: إنه الباب، وافق قولهم أصل اللفظ في اللغة، ويكون معنى الوصيد في الكهف: بأنه المسدود، كما روي في القصة: أن باب الكهف سدَّ عليهم، والذين قالوا: إنه الفناء؛ فلأن الكلب إذا كان داخل الكهف وراء بابه المسدود كان بالفناء؛ لأن ما جاوز فم الكهف كان من جملة الفناء، والكلب كان في آخر الفناء عند الباب. والقولان صحيحان على ما بينا {36}؛ وأما ما روي عن سعيد بن جبير أنه فسر الوصيد: (الصعيد، والتراب) {37}؛ فإنه أراد الفناء، ولكنه عبر بالصعيد.وقوله تعالى: ﴿لَوِ اطَّلَعْتَ عَلَيْهِمْ﴾، أي: أشرفت عليهم، يقال: أطلعت فلانًا على الشيء فاطلع هو، قال الله تعالى: ﴿فَاطَّلَعَ فَرَآهُ﴾ [الصافات: 55].﴿لوَلَّيْتَ مِنْهُمْ فِرَارًا﴾، أي: لأدبرت وانقلبت منهم فرارًا. قال الزجاج: (منصوب على المصدر؛ لأن معنى وليت منهم: فررت منهم) {38}. ﴿وَلَمُلِئْتَ مِنْهُمْ رُعْبًا﴾ أي: فزعًا وخوفًا، قال المفسرون: (هو أن الله تعالى منعهم بالرعب لئلا يراهم أحد) {39}.وقال أبو إسحاق: (قيل في التفسير: إنهم طالت شعورهم جدًا، وأظفارهم، فلذلك كان الرائي لو رآهم لهرب مرعوبًا) {40}.وفي قوله: ﴿وَلَمُلِئْتَ﴾ قراءتان: التخفيف، والتشديد {41}، والاختيار التخفيف. قال أبو الحسن: (الخفيفة أجود في كلام العرب، يقولون: ملأتني رعبًا، ولا يكادون يعرفون {42} ملأتني) {43}. ويدل على هذا كثرة استعمالهم الملء كقوله {44}:فيملأ بيتنا أقطًا وسمنًاوقول الآخر {45}:ومن مالئ من شيء غيره إذا ... راح نحو الحمرة البيض بالدُّمىوقول الآخر {46}: لا تملأ الدَّلو وعرِّق فيهاوقول الآخر {47}:امتلأ الحوض وقال قطنيوامتلأ يدل على ملأ؛ لأنه مطاوعه، وقد جاء الثقيل أيضًا، أنشدوا للمُخبَّل السعدي {48}:وإذا فتك النعمان بالنَّاس محرمًا ... فملئ من كعب بن عوفٍ سلاسلهقوله تعالى: ﴿وَكَذَلِكَ﴾ أشار إلى ما تقدم من قوله: ﴿فَضَرَبْنَا عَلَى آذَانِهِمْ﴾ [الكهف: 11]، وقوله: ﴿وَزِدْنَاهُمْ هُدًى﴾ [الكهف: 13]، وقوله: ﴿وَنُقَلِّبُهُمْ﴾ أي: كما فعلنا بهم هذه الأشياء بعثناهم، قال ابن قتيبة: (أجسامهم من تلك النومة التي تشبه الموت) {49}."
  18,19,"وقوله تعالى: ﴿لِيَتَسَاءَلُوا بَيْنَهُمْ﴾ قال أبو علي الجرجاني: (ليكون بينهم تساؤل وتنازع واختلاف في مدة لبثهم) {1}.﴿قَالَ قَائِلٌ مِنْهُمْ كَمْ لَبِثْتُمْ﴾ قال ابن عباس: (يريد كم لنا منذ دخلنا الكهف) {2}.﴿قَالُوا لَبِثْنَا يَوْمًا أَوْ بَعْضَ يَوْمٍ﴾ قال المفسرون: (إنهم دخلوا الكهف غدوة، وبعثهم الله في آخر النهار، لذلك قالوا: ﴿يَوْمًا﴾ فلما رأوا الشمس قالوا: ﴿أَوْ بَعْضَ يَوْمٍ﴾، وكان قد بقيت من النهار بقية) {3}.﴿قَالُوا رَبُّكُمْ أَعْلَمُ بِمَا لَبِثْتُمْ﴾ قال ابن عباس: (يرد تمليخا رئيسهم رد علم ذلك إلى الله) {4}، ﴿فَابْعَثُوا أَحَدَكُمْ بِوَرِقِكُمْ هَذِهِ إِلَى الْمَدِينَةِ﴾، الورق: اسم للدراهم.وقال أبو عبيدة: (الفضة كانت مضروبة دراهم أو لا) {5}؛ يدل على هذا ما روي: (أن عرفجة {6} اتخذ أنفًا من ورق) {7}. وفيه لغات: وَرِق، وَوَرْق، وَوِرْق، مثل كَبِد، وكَبْد، وكِبْد، ذكر ذلك الفراء والزجاج {8}. وكسر الواو أردؤها.ويقال أيضًا: للورق: الرِّقَة، قال الأزهري: (أصله: وِرْقَة، مثل: صِلَة وعِدَة) {9}. وإنما قال هذه؛ لأنه عني بالورق الدراهم أو الفضة.قال ابن عباس: (وكانت معهم دراهم عليها صورة الملك الذي كان في زمانهم، فهربوا منه) {10}. ويعني بالمدينة: دقسوس، وهي مدينتهم، ويقال: هي اليوم طرسوس {11}.وقوله تعالى: ﴿فَلْيَنْظُرْ أَيُّهَا أَزْكَى طَعَامًا﴾ قال عطاء عن ابن عباس: (يريد: أحل الذبائح) {12}.وهو قول سعيد بن جبير {13}، واختيار الفراء {14}. قالوا: لأن عامة بلدهم كانوا مجوسًا، وفيهم قوم يخفون إيمانهم.وقال مجاهد: (أيها أحل، وكان لهم ملك غشوم يظلم الناس في طعامهم وأسواقهم، فقالوا لصاحبهم: لا تبتع طعامًا فيه ظلم ولا غصبًا) {15}.وذكر أبو إسحاق القولين جميعًا وقال: (الآية من باب حذف المضاف؛ لأن المعنى: أي أهلها أزكى طعامًا، أي: أحل، إما من جهة أنه ذبيحة مؤمن، وإما من جهة أنه لا غصب فيه، هذا معنى قوله. قال: و ﴿أَيُّهَا﴾ رفع بالابتداء، و ﴿أَزْكَى﴾ خبره، و ﴿طَعَامًا﴾ منصوب على التمييز) {16}.وقوله تعالى: ﴿وَلْيَتَلَطَّفْ﴾ قال ابن عباس: (يريد يكون ذلك في ستر وكتمان) {17}، يعني دخول المدينة وشراؤه الطعام، ومعنى ﴿وَلْيَتَلَطَّفْ﴾: وليدقق النظر وليحتل حتى لا يطلع عليه.وقوله تعالى: ﴿وَلَا يُشْعِرَنَّ بِكُمْ أَحَدًا﴾ قال ابن عباس: (يريد لا يخبرن بكم، ولا بمكانكم أحدًا من أهل المدينة) {18}.وقال أبو إسحاق: (أي إن ظهر عليه فلا يوقعن إخوانه فيما يقع فيه) {16}. وهذا خلاف ما ورد في التفسير، فقد ذكر السدي وغيره: (أن الرسول خرج من عندهم وقد أخذ عليه المواثيق، لئن أخذت لتدلن علينا ولا تستأثر بالشهادة) {20}؛ وهذا أليق بحالهم مما ذكره أبو إسحاق. والمعنى ما قاله ابن عباس، أنه لا يتولى إعلام أحد، ثم إن عرف واحد دل على أصحابه ليشاركوه في الشهادة."
  18,20,"قوله تعالى: ﴿إِنَّهُمْ إِنْ يَظْهَرُوا عَلَيْكُمْ﴾، أي: يطلعوا ويشرفوا على مكانكم أو على أنفسكم، من قولهم: ظهرت على فلان إذا علوته، وظهرت على السطح إذا صرت فوقه، ومنه قوله: ﴿فَأَصْبَحُوا ظَاهِرِينَ﴾ [الصف: 14]، أي: عالين {1} غالبين، وكذلك قوله: ﴿لِيُظْهِرَهُ عَلَى الدِّينِ كُلِّهِ﴾ [التوبة: 33]، أي: ليعليه، وقد مر.وقوله تعالى: ﴿يَرْجُمُوكُمْ﴾ قال ابن عباس: (يقتلوكم) {2}. والرجم بمعنى القتل قد ورد كثيرًا في التنزيل كقوله: ﴿وَلَوْلَا رَهْطُكَ لَرَجَمْنَاكَ﴾ [هود: 91] وقوله: ﴿لَأَرْجُمَنَّكَ﴾ [مريم: 46] وقوله: ﴿أَنْ تَرْجُمُونِ﴾ [الدخان: 20]، وأصله: الرمي.قال أبو إسحاق: (أي يقتلوكم بالرجم، والرجم من أخبث القتل) {3}.ولما كانوا بالرجم سمي القتل: رجما، وقد يسمى السب والشتم: رجما، وهو قول ابن جريج في هذه الآية {4}، وذلك لأنه رمي بالقبيح من القول.وقوله تعالى: ﴿يُعِيدُوكُمْ فِي مِلَّتِهِمْ﴾ قال ابن عباس: (يردوكم إلى دينهم) {5}، ﴿وَلَنْ تُفْلِحُوا إِذًا أَبَدًا﴾ أي: إن رجعتم إلى دينهم لن تسعدوا في الدنيا ولا في الآخرة.قال الزجاج: (""إذ"" يدل على الشرط، أي: ولن تفلحوا إن رجعتم إلى ملتهم أبدًا) {3}."
  18,21,"وقوله تعالى: ﴿وَكَذَلِكَ أَعْثَرْنَا عَلَيْهِمْ﴾ الآية. قال العلماء بأخبار القدماء: (إن الفتية لما هربوا من ملكهم دقيانوس ودخلوا الكهف، أمر دقيانوس بالكهف أن يسد عليهم، ويدعوهم كما هم في الكهف يموتوا عطشًا وجوعًا، وليكن كهفهم الذي اختاروا قبرًا لهم، وهو يظن أنهم أيقاظ، وقد توفي الله تعالى أرواحهم وفاة النوم، ثم إن رجلين مؤمنين كتبا شأن الفتية وأنسابهم وأسماءهم وخبرهم في لوح من رصاص، وجعلاه في تابوت من نحاس، وجعلا التابوت في البنيان الذي بنوا على باب الكهف، وقالا: لعل الله يظهر على هؤلاء قومًا مؤمنين قبل يوم القيامة، فيعلم خبرهم حين يقرأ هذا الكتاب. ثم انقرض أهل ذلك الزمان وخلفت بعدهم قرون وملوك كثيرة، وملك أهل تلك البلاد رجل صالح يقال له: تندوسيس، وتحزب الناس في ملكه أحزابًا منهم من يؤمن بالله ويعلم أن الساعة حق، ومنهم من يكذب، فكبر ذلك على الملك الصالح وبكى إلى الله وتضرع إليه، وقال: أي رب، قد ترى اختلاف هؤلاء فأبعث لهم آية تبين لهم أن البعث حق وأن الساعة آتية لا ريب فيها. فألقى الله تعالى في نفس رجل {1} من أهل ذلك البلد الذي هو به الكهف أن يهدم البنيان الذي على فم الكهف فيبني {2} به حظيرة لغنمه ففعل ذلك، وحجب الله الفتية عن الناس بالرعب، فلم يتجاسر أن يدخل عليهم أحد، وبعث الله الفتية من نومهم فجلسوا فرحين، وأرسلوا أحدهم ليطلب لهم طعامًا، فاطلع الناس على أمرهم كما ذكر في القصة، وبعثوا إلى الملك الصالح تندوسيس ليعلمونه الخبر، ليعجل القدوم عليهم وينظر إلى آية من آيات الله جعلها الله في ملكه آية للعالمين، فتية بعثهم الله وقد كان توفاهم منذ أكثر من ثلاثمائة سنة، فلما بلغه الخبر حمد الله تعالى، وركب معه أهل مدينته حتى أتوا مدينة أصحاب الكهف، ثم صعدوا نحو الكهف حتى أتوه. فذلك قوله: ﴿وَكَذَلِكَ أَعْثَرْنَا عَلَيْهِمْ﴾، أي: أطلعنا وأظهرنا عليهم)، كذا قال المفسرون {3}. وذكرنا هذا عند قوله: ﴿فَإِنْ عُثِرَ﴾ [المائدة: 107].وقوله تعالى: ﴿لِيَعْلَمُوا أَنَّ وَعْدَ اللَّهِ حَقٌّ﴾ قال ابن عباس: (يريد الملك ورعيته) {4}، أن البعث والثواب والعقاب حق، والقيامة لا شك فيها.وقوله تعالى: ﴿إِذْ يَتَنَازَعُونَ بَيْنَهُمْ أَمْرَهُمْ﴾ اختلفوا في هذا التنازع، فالأشبه ما قال عكرمة: (أن أهل ذلك الزمان تنازعوا بالبعث) {5}. كما ذكرنا في القصة.والمراد بقوله: ﴿أَمْرَهُمْ﴾ ما تنازعوا فيه من أمر البعث. و ﴿إِذْ﴾ منصوب بقوله: ﴿أَعْثَرْنَا﴾، والمعنى: أطلعنا عليهم إذ وقعت المنازعة في أمرهم {6}. قال أبو إسحاق: (ويجوز أن يكون منصوبًا بقوله: ﴿لِيَعْلَمُوا﴾ أي: ليعلموا في وقت منازعتهم) {7}.وقال ابن عباس في رواية عطاء في قوله: ﴿إِذْ يَتَنَازَعُونَ بَيْنَهُمْ أَمْرَهُمْ﴾ (وذلك أن الرجل إذ خرج ليشتري لهم الطعام لما وقف يتنازع، نظروا إلى درهمه، فإذا عليه صورة دقيانوس)، وذكر القصة {8}. فعلى هذا التنازع: هو تنازع القوم مع هذا الواحد الذي كان يطلب لهم الطعام وتكذيبهم إياه فيما كان يخبر به.وقال قوم: (يعني تنازعوا في قدر مكثهم ولبثهم) {9}. وقيل: (تنازعوا في عددهم) {10}، وهذا لا يتجه؛ لأن قوله: ﴿إِذْ يَتَنَازَعُونَ﴾ إما أن يتعلق بقوله: ﴿أَعْثَرْنَا﴾، أو بقوله: ﴿لِيَعْلَمُوا﴾ على ما بينا. وإذا جعلنا التنازع في قدر المكث أو في العدد لم يصح المعنى، إلا أن يجعل تمام الكلام عند قوله: ﴿لَا رَيْبَ فِيهَا﴾، ثم يقول: ﴿إِذْ يَتَنَازَعُونَ﴾، أي: اذكر يا محمد ﴿إِذْ يَتَنَازَعُونَ بَيْنَهُمْ أَمْرَهُمْ﴾: مدة مكثهم، أو في عددهم فلا يتعلق بما قبله. ومنهم من قال: (هذا التنازع يعود إلى التنازع في البنيان، والمسجد)، يروى هذا عن ابن عباس {11}. يدل على هذا سياق الآية، وهو قوله: ﴿فَقَالُوا ابْنُوا عَلَيْهِمْ بُنْيَانًا﴾، يعني استروهم من الناس، قال ذلك المفسرون {12}.وقوله تعالى: ﴿رَبُّهُمْ أَعْلَمُ بِهِمْ﴾ يدل على أنه وقع تنازع في عدتهم، فمعنى: ﴿رَبُّهُمْ أَعْلَمُ بِهِمْ﴾، أي: بعددهم كما قال: ﴿قُلْ رَبِّي أَعْلَمُ بِعِدَّتِهِمْ﴾ [الكهف: 22]، ويحتمل أن هذا من قول الله ابتداء، ويحتمل أنه من قول بعض الناس الذين تكلموا في عددهم {13}.وقوله تعالى: ﴿قَالَ الَّذِينَ غَلَبُوا عَلَى أَمْرِهِمْ﴾ قال ابن عباس: (يريد المؤمنين الذين لم يشكوا في البعث). قال المفسرون: (هم تندوسيس الملك وأصحابه) {14}.﴿لَنَتَّخِذَنَّ عَلَيْهِمْ مَسْجِدًا﴾ قال أبو إسحاق: (هذا يدل على أنه لما ظهر أمرهم غلب المؤمنون بالبعث والنشور؛ لأن المساجد للمؤمنين) {15}. ومعنى: ﴿عَلَيْهِمْ﴾ هاهنا وفي قوله: ﴿ابْنُوا عَلَيْهِمْ بُنْيَانًا﴾ أنهم يجعلون وراء ذلك، كما يقال: بني عليه جدارًا، إذا حوطه وجعله وراء الجدار، وقد ذكر في قصتهم: (أن الملك جعل على باب الكهف مسجدًا يصلى فيه، وجعل عنده عيدًا عظيمًا، وأمر أن يؤتى كل سنة) {16}. وقد نسقت شرح هذه الآية على ما أمكن، والآية مشكلة الظاهر والنظم، والله أعلم بما أراد."
  18,22,"قوله تعالى: ﴿سَيَقُولُونَ ثَلَاثَةٌ رَابِعُهُمْ كَلْبُهُمْ﴾ الآية. قال المفسرون: (إن نصارى نجران {1} كانوا عند النبي -ﷺ-، فجرى ذكر أصحاب الكهف، فقالت اليعقوبية {2} منهم: كانوا ثلاثة رابعهم كلبهم. وقالت النسطورية {3}: كانوا خمسة سادسهم كلبهم. وقال المسلمون: كانوا سبعة وثامنهم كلبهم)، هذا حكاية ما ذكره المفسرون {4}.ونظم الآية يوجب أن يكون هذا التنازع بعد نزول الآية؛ لأن الله تعالى قال: ﴿سَيَقُولُونَ﴾، وهذه السين للتأخير، فالآية تكون نازلة قبل هذا التنازع، أخبر الله فيها أنه سيقع نزاع في عددهم، ثم وقع ذلك على ما في الآية، يدل على هذا أن السورة مكية ووفد نجران إنما أتوا النبي -ﷺ- بعد الهجرة.واختلف النحويون في نظم هذه الآية وسقوط الواو من قولهم: رابعهم وسادسهم، ودخولها في ثامنهم، بعد اجتماعهم على أن قوله: ﴿ثَلَاثَةٌ﴾ مرفوع بالابتداء محذوف على تقدير: هم ثلاثة {5}.فقال صاحب النظم: (﴿رَابِعُهُمْ﴾ ابتداء و ﴿كَلْبُهُمْ﴾ خبره، وهو جملة في موضع الحال لقوله: ﴿ثلاثةٌ﴾ {6}. وتأويله: سيقولون ثلاثة بهذه الحال فيكون قوله: ﴿رَابِعُهُمْ كَلْبُهُمْ﴾ توقيتًا للآية وحالاً لهم، وكذلك قوله: ﴿خَمْسَةٌ سَادِسُهُمْ﴾، قال أبو الفتح الموصلي: (لا يجوز أن تكون الجملة حالاً لثلاثة؛ لأنك لو فعلت ذلك لم يجد الحال ما ينصبها، ألا ترى أن التقدير: سيقولون: هم ثلاثة، وليس في قولك: هم ثلاثة ما يجوز أن ينصب الحال) {7}.وقال آخرون: (﴿رَابِعُهُمْ﴾ وصف لثلاثة، على أن يكون ﴿كَلْبُهُمْ﴾ رفع برابع، كما تقول: عندي غُلامٌ ضاربه زيد، فيرفع ضاربه؛ لأنه وهف لغلام، وترفع زيد بفعله، وهو الضرب) (¬2).قال أبو الفتح: (وهذا الوجه أيضًا غير جائز، من قبل أن رابعهم في هذا الموضع، وإن كان اسم فاعل، فإنه أراد به الماضي، وإذا كان اسم الفاعل ماضيًا في المعنى لم يجز أن يعمل عمل الأفعال، لا رفعًا ولا نصبًا؛ ألا ترى أنك لا تقول: هذا رجل غلام أخوه، فترفع الأخ بفعل، وتجعل الغلام فعلا له؛ لأن اسم الفاعل إذا أريد به الماضي جرى مجرى غلام ورجل وفرس وما لا معنى فعل فيه، فقد بطل إذن أن يرتفع ﴿كَلْبُهُمْ﴾ بما في ﴿رَابِعُهُمْ﴾ من معنى الفعل) (¬3). وقد ذكرنا هذا الفصل عند قوله: ﴿وَكَلْبُهُمْ بَاسِطٌ ذِرَاعَيْهِ﴾ [الكهف: 18]، من كلام أبي علي.وقال بعضهم: (﴿رَابِعُهُمْ كَلْبُهُمْ﴾ مبتدأ وخبر، والجملة وصف لثلاثة، كما تقول: هؤلاء ثلاثة غُلامهم رابعهم) (¬4).قال أبو الفتح: (وهذا الوجه غير سائغ ولا مختار، وإن كان في غير هذا الموضع جائزًا. والذي منع من إجازته هاهنا وضعفها أن الجملة التي في آخر الكلام [فيها واو العطف، وهو قوله: ﴿وَيَقُولُونَ سَبْعَةٌ وَثَامِنُهُمْ كَلْبُهُمْ﴾، فكما ظهرت الواو في آخر الكلام] {8} فكذلك هي -والله أعلم- مرادة في أوله؛ لتتجنَّس الجمل في أحوالها والمراد بها، فكأنه قيل: سيقولون: ثلاثة ورابعهم كلبهم، ويقولون: خمسة وسادسهم كلبهم رجمًا بالغيب، ويقولون: سبعة وثامنهم كلبهم، إلا أن الواو حذفت من الجملتين المتقدمتين؛ لأن الذي فيهما من الضمير يعقدهما بما قبلهما لا عقد الحال ولا عقد الوصف لما ذكرنا، ولكن عقد الإتباع، لا سيما وقد ظهرت الواو في الجملة الثالثة، فدل ذلك على أنها مرادة في الجملتين المتقدمتين)، انتهى كلامه {9}.ونحو هذا قال أبو علي في هذه الآية فقال: (قوله: ﴿رَابِعُهُمْ كَلْبُهُمْ﴾ و ﴿سَادِسُهُمْ كَلْبُهُمْ﴾، جملتان استغني عن حرف العطف فيهما بما تضمنتا من ذكر الجملة الأولى، وهي قوله: ﴿ثلاثةٌ﴾، والتقدير: هم ثلاثة) {10}. وهذا الذي ذكره أبو علي وأبو الفتح في وجه نظم هذه الآية معنى قول أبي إسحاق: (دخول الواو في ﴿وَثَامِنُهُمْ﴾ وإخراجها من الأول واحد) {11}. وعلى ما قالوا قوله: ﴿رَابِعُهُمْ﴾ عطف على خبر الابتداء الذي هو ثلاثة، كما تقول: هو حلو وحامض. و ﴿كَلْبُهُمْ﴾ مرفوع على أنه نعت لقوله: ﴿رَابِعُهُمْ﴾.وقوله تعالى: ﴿رَجْمًا بِالْغَيْبِ﴾ الرجم: القول بالظن والحَدْس {12}.ومنه قول زهير {13}:وما هو عنها بالحديث المرجَّموذلك أنه رمى الظن إلى ذلك الشيء. قال أبو إسحاق: (أي تقولون ذلك رجما، أي ظنًّا وتخرصًا) {14}. ومعنى قول المفسرين: ظنًّا من غير يقين.وقوله تعالى: ﴿بِالْغَيْبِ﴾ الباء هاهنا ظرف للرجم، والتأويل: يرجمون القول فيهم بالغيبة عنهم، وتلخيصه: بالمكان الغائب عنهم، كما تقول: هو يحسن القول فيك بالغيب، ويظهر الغيب، والمعنى: أنهم يقولون هذا القول من غير مشاهدة.وقوله تعالى: ﴿وَيَقُولُونَ سَبْعَةٌ وَثَامِنُهُمْ كَلْبُهُمْ﴾ قال ابن عباس: (حين وقعت الواو وانقطعت العدة) {15}؛ يريد أنهم سبعة وثامنهم كلبهم، وإلى هذا المعنى أشار أبو إسحاق فقال: (وقد يجوز أن يكون الواو يدخل ليدل على انقطاع القصة وأن الشيء قد تمَّ) {14}. إلى هاهنا إخبار عما يقوله المختلفون في عدد {17} أصحاب الكهف، ثم قال: ﴿قُلْ رَبِّي أَعْلَمُ بِعِدَّتِهِمْ مَا يَعْلَمُهُمْ إِلَّا قَلِيلٌ﴾، أي: ما يعلم عددهم إلا قليل من الناس. قال ابن عباس: (أنا من ذلك القليل) {18}. فقال في رواية الضحاك: (أنا من أولئك القليل، ثم ذكرهم بأسمائهم، فذكر سبعة) {19}. وقال في رواية عكرمة: (كانوا سبعة) {20}. وقال في رواية سعيد بن جبير: (كانوا سبعة أو ثمانية) {21}. وقال في رواية عطاء الخراساني: ﴿مَا يَعْلَمُهُمْ إِلَّا قَلِيلٌ﴾، يعني أهل الكتاب) {22}.وروى السدي عن ابن عباس قال: (أرجو أن أكون من القليل، أظن القوم كانوا ثلاثة، يقول واحد منهم: كم لبثتم؟ فقال الثاني: لبثنا يومًا أو بعض يوم، قال الثالث: ربكم أعلم بما لبثتم) {23}.وقوله تعالى: ﴿فَلَا تُمَارِ فِيهِمْ إِلَّا مِرَاءً ظَاهِرًا﴾ قال السدي: (يقول بما أوحى إليك من القرآن) {24}.وقال سفيان: (إلا بما قصصنا عليك في القرآن) {25}.وروي عن ابن عباس، وقتادة، والضحاك في قوله: ﴿إِلَّا مِرَاءً ظَاهِرًا﴾ (حسبك ما قصصنا عليك من شأنهم) {26}. وقال ابن زيد: (المراء الظاهر: أن تقول لهم: ليس كما تقولون، ليس كما تعلمون عدتهم) {27}؛ يعني إنما يعلمهم القليل. ومعنى المراء في اللغة: الجدال، يقال: مَارَى يُماري، مُمارَاة ومِراء، أي: جادل {28}.قال أبو إسحاق: (أي لا تأت في أمرهم بغير ما أوحي إليك، أي: أفت في قصتهم بالظاهر الذي أنزل عليك) {29}. فعلى ما قالوا المراء الظاهر هو: أن يجادلهم بما أنزل إليه من أنه لا يعلم عددهم إلا القليل، كما قال ابن زيد.وقوله تعالى: ﴿وَلَا تَسْتَفْتِ فِيهِمْ﴾، أي: في أصحاب الكهف ﴿مِنْهُمْ﴾، أي: من اليهود وأهل الكتاب. قال الفراء: (هم فريقان أتوه من أهل نجران: يعقوبي ونسطوري، فسألهم النبي -ﷺ- عن عددهم فَنُهي) {30}. قال أصحابنا: (وهذا دليل على منع المسلمين من استفتاء اليهود والنصارى) {31}."
  18,23,"قوله تعالى: ﴿وَلَا تَقُولَنَّ لِشَيْءٍ إِنِّي فَاعِلٌ ذَلِكَ غَدًا﴾ ذكرنا قبل هذا سبب نزول هذه الآية {1}. قال المفسرون: (هذا تأديب من الله تعالى لنبيه -عليه السلام-، وأمر له بالاستثناء فيما يعزم بمشيئة الله، إذا قلت لشيء: إني فاعله غدًا، فقل: إن شاء الله) {2}. قال الفراء في قوله: (إِلَّا أَن يَشَاء اللهُ}: إلا أن يريد الله) {3}.قال أبو إسحاق: (موضع ﴿أَن﴾ نصب، المعنى: لا تقولن إني أفعل إلا بمشيئة الله) {4}. جعل أبو إسحاق ﴿أَن﴾ مع الفعل مصدرًا وأضمر الباء.وقال الأخفش: (أي: إلا أن يقول: إن شاء الله. فأجزأ من ذلك هذا، وكذلك إذا طال الكلام أجزأ فيه، شبيه بالإيماء؛ لأن بعضه يدل على بعض) {5}. ونحو هذا روي عن المبرد عن الكسائي والفراء قالا: (المعنى إني فاعل ذلك غدًا إلا أن يقول: إن شاء الله) {6}؛ فأضمر القول، ومثله كثير في القرآن، وهذا على ما ذكروا، ولما حذف يقول نقل شاء إلى لفظ الاستقبال."
  18,24,"وقوله تعالى: ﴿وَاذْكُرْ رَبَّكَ إِذَا نَسِيتَ﴾ أكثر الناس على أن معناه: إذا نسيت الاستثناء بمشيئة الله تعالى فاذكره، وقله إذا ذكرت.قال ابن عباس رواية عطاء: (يريد الاستثناء ولو بعد شهر) {1}. يعني أن من قال: أفعل غدًا كذا وكذا، ونسي أن يقول: إن شاء الله، فقد واقع ما نهى الله عنه، فإذا ذكر أنه كان قد نسي الاستثناء فقاله وضع عنه الحرج.وقال سعيد بن جبير: (إذا قلت لشيء إنك فاعله غدًا، فنسيت أن تقول: إن شاء الله، ثم ذكرت، فقل: إن شاء الله، وإن كان بعد يوم أو شهر أو سنة) {2}.وقال أبو العالية: (إذا ذكرت فاستثن) {3}.وقال عمرو بن دينار: (له الاستثناء متى ما ذكر) {4}. هذا كله فيما يعد من نفسه أن يفعله من غير يمين، فإن حلف ثم استثنى بمشيئة الله متصلاً بيمينه فلا حنث عليه، كذلك روى أبو هريرة عن النبي ﷺ: ""مَنْ حلف فقال: إن شاء الله، لم يحنث"" {5}.وروى ابن عمر عن النبي -ﷺ- قال: ""مَنْ حلف على يمين فقال: إن شاء الله، فهو بالخيار"" {6}.ولا خلاف في هذا بين الناس، وإنما الخلاف فيه إذا انقطع الاستثناء عن اليمين، روى قتادة عن الحسن في الرجل يحلف فيستثني في يمينه قال: (له ثنياه إذا اتصل كلامه، ولم يكن بين ذلك كلام) {7}.وقال طاووس: (له ثنياه ما كان في مجلسه) {8}. وعن حماد {9} قال: (إن استثنى في نفسه فليس بشيء حتى يسمع نفسه) {10}.وقال الحسن: (إذا حرك لسانه أجزأ عنه) {11}. ومذهب الشافعي -رحمه الله-: أن الحالف إذا نسي الاستثناء موصولاً بكلامه، فات وقته في الطلاق والعتاق وسائر الأيمان {12}. حتى قال بعض أصحابنا: (إنما ينفعه الاستثناء إذا أنشأ أول يمينه مع نية الاستثناء ثم وصله باليمين، فإن أنشأ اليمين ثم بدا له أن يستثني فوصل الاستثناء لم ينفعه) {13}.والصحيح: أنه إذا اتصل نفع، ووقع موقعه {14}.وروي عن ابن عباس أنه قال: (يستثني الرجل في يمينه متى ما ذكر، وإن تطاول الزمان، وقرأ هذه الآية) {15}. وهذا لا يصح؛ لأن سبيل الاستثناء أن لا يكون منفردًا بنفسه، هو مضمر كلام غيره، والآية وردت في غير اليمين، وليس في الآية: ولا تحلفن على شيء إني فاعل ذلك غدًا، يدل على هذا سبب نزول الآية، والنبي -ﷺ- لما سألوه عن قصة أصحاب الكهف قال: غدًا أخبركم، ولم يحلف على ذلك، ويؤكد هذا ما روي أن النبي -ﷺ- قال: ""مَنْ حلف على يمين ورأى غيرها خيرًا منه، فليأتِ الذي هو خير ويُكَفّر عن يمينه"" {16}.ولو كان يخرج بقوله: إن شاء الله عن الحنث، لقال: وليقل: إن شاء الله، وأيضًا فإن الإنسان إذا حلف من غير نية [فقد تمت يمينه واستقرت، فلم يجز أن ينقض حكمها شيء يحدثه بعد ذلك، بخلاف ما يقارنه الاستثناء] {17}؛ لأنه لا يستقر، على أن كثيرًا من المفسرين حملوا قوله: ﴿اللَّهُ وَاذْكُرْ رَبَّكَ إِذَا نَسِيتَ﴾ على غير الاستثناء؛ لأن قوله: ﴿وَاذْكُرْ رَبَّكَ﴾ ابتداء كلام آخر وقصة أخرى، والاستثناء الذي ذكر وقع في موضعه متصلاً.قال عكرمة: (﴿وَاذْكُرْ رَبَّكَ إِذَا نَسِيتَ﴾ قال: إذا غضبت) {18}ومعناه أنه إنما يغضب لما يطرأ عليه من نسيان ذكر الله، فأمر بذكر الله ليزول غضبه. وروي عن السدي والضحاك أنهما قالا: (هذا فيمن نسي صلاة فعليه أن يصليها إذا ذكرها) {19}.وقال المبرد: (إن ابن عباس أعلم من أن يسقط حكم الحنث بالاستثناء الذي لا يصله الحالف بيمينه، ولعله قال هذا في الاستثناء من غير يمين كما قال المفسرون، قال: إذا نسي أن يقول: إن شاء الله، ثم ذكر فليقله. فظن بعض الناس أنه يقول ذلك في اليمين، فروي عنه ذلك في اليمين) {20}.قوله تعالى: ﴿وَقُلْ عَسَى أَنْ يَهْدِيَنِ﴾ إلى آخرها، قال أبو إسحاق: (أي قل عسى أن يعطيني ربي من الآيات والدلالات على النبوة ما يكون أقرب في الرشد، وأدل من قصة أصحاب الكهف) {21}.قال المفسرون: (إن الله -عز وجل- فعل به ذلك حيث آتاه من علم غيوب المرسلين، وخبرهم ما كان أوضح في الحجة وأقرب إلى الرشد من خبر أصحاب الكهف) {22}.وقال بعضهم: (هذا نبأ أمر أن يقوله مع الاستثناء إذا ذكر، وهو كفارة نسيان الاستثناء أن يقول: ﴿عَسَى أَنْ يَهْدِيَنِ﴾ إلى آخرها) {23}. والمعنى: عسى أن يهدين حتى لا أنسى الاستثناء بمشيئته، وهو أقرب رشدًا من أن ينسى ذلك.وقال بعضهم: (هذا فيما ينساه النبي -ﷺ- أمر أن يذكر الله تعالى فسأله أو يذكره ما نسي، أو يهديه لما هو خير له من ذكر ما نسيه) {24}."
  18,25,"قوله تعالى: ﴿وَلَبِثُوا فِي كَهْفِهِمْ﴾ الآية، اختلفوا في معنى هذه الآية على قولين أحدهما: أن هذا إخبار عن أهل الكتاب أنهم قالوا ذلك {1}. وهذا قول ابن عباس في رواية الضحاك قال: (إن الرجل ليفسر الآية يرى أنها كذلك فيهوي أبعد مما بين السماء والأرض ثم تلا: {وَلَبِثُوا فِي كَهْفِهِمْ} الآية، ثم قال: كم لبث القوم؟ قالوا: ثلاثمائة سنة وتسع سنين، قال: فلو كانوا لبثوا ذلك لم يقل الله: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾، ولكنه حكى مقالة القوم، فقال: سيقولون: ﴿وَلَبِثُوا فِي كَهْفِهِمْ﴾ الآية {2}.وقال قتادة: (هذا قول أهل الكتاب، فرد الله عليهم بقوله: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ قال: ويدل على صحة هذا قراءة ابن مسعود: قالوا لبثوا في كهفهم) {3}. ونحو هذا قال مطر الورّاق {4} {5}.القول الثاني: أن هذه الآية إخبار عن الله تعالى، أخبر عن قدر لبثهم في الكهف من يوم دخلوا إلى أن بعثهم الله وأطلع عليهم الخلق {6}؛ وهذا قول مجاهد قال في هذه الآية: (هو عدد ما لبثوا) {7}، ونحوه قال عبد الله بن عبيد بن عمير {8}، والضحاك {9}.واختاره الزجاج وقال: (هو الأجود عندي) {10}، وهو اختيار ابن قتيبة {11}. وعلى هذا القول معنى قوله: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ ما قاله القتبي: (وهو أنهم اختلفوا في لبثهم فقال الله: ﴿وَلَبِثُوا فِي كَهْفِهِمْ﴾ الآية، ثم قال: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ أي. وأنا أعلم بما لبثوا من المختلفين) {12}. وهذا معنى قول الزجاج، والكلبي: (قالت نصارى نجران: أما الثلاثمائة فقد عرفناها، وأما التسع فلا علم لنا بها، فنزلت: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ {13}.وقال كثير من أهل التفسير: (معنى قوله: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ أن أهل الكتاب قالوا على رسول الله -ﷺ-: أن الفتية من لدن دخلوا الكهف إلى يومنا هذا ثلاثمائة وتسع سنين، فرد الله -عز وجل- عليهم وقال: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ بعد أن قبض أرواحهم المرة الثانية إلى يومنا هذا لا يعلم ذلك غير الله تعالى) {14}.هذا الذي ذكرنا تفسير الآية {15}، فأما إعرابها فقال ابن عباس في رواية عطاء: (نزل قوله: ﴿وَلَبِثُوا فِي كَهْفِهِمْ ثَلَاثَ مِائَةٍ﴾ فلم يدرِ رسول الله -ﷺ- أسنين، أم أشهر، أم أيام، أم ساعات، حتى نزل جبريل فقال: ﴿سِنِينَ وَازْدَادُوا تِسْعًا﴾ {16}؛ ونحو هذا قال الضحاك، ومقاتل {17}. وعلى هذا أجاز ابن مجاهد الوقف على ثلاثمائة، لفصل ما بينهما في النزول {18}. والاختيار ترك الوقف؛ لأن سنين وإن نزل بعد ثلاثمائة فقد التحق به في قول جميع النحويين، وصار التقدير: سنين ثلاثمائة. قاله الفراء، والزجاج، وأبو عبيدة، والكسائي. وعلى هذا ﴿سِنِينَ﴾ في موضع نصب بالفعل {19}. قال أبو إسحاق: (ويجوز في تقدير العربية أن يكون سنين معطوفًا على ثلاث، عطف البيان والتوكيد) {10}. وقال أبو علي: ﴿سِنِينَ﴾ بدل من قوله: {ثَلَاثَ مِائَةٍ} وموضعه نصب، كما أن موضع المبدل منه كذلك وهذا كما تقول: أعطيته ألفا درهما ومائة أثوابا) {21}. قال الفراء: (ويجوز أن يكون ﴿سِنِينَ﴾ نصبا بالتفسير للعدد، كما قال عنترة {22}:فيها اثنتان وأربعون حلوبةً ... سودًا كخافية الغراب الأسحم[وهي جمع مفسرة كما يفسر الواحد) {23}.وقال أبو إسحاق: (وجائز أن يكون ﴿سِنِينَ﴾ من نعت المائة، وهو راجع في المعنى إلى ثلاث، كما قال الشاعر، وأنشد البيت)] {10} {25}. فجعل سودا نعتا للحلوبة، وهي في المعنى نعت لجملة العدد. وهذا القول أحسن من قول الفراء؛ لأنه جعل سودًا تفسيرًا للعدد، وليس كذلك تفسير العدد حلوبة، وسودًا نعت للحلوبة راجع إلى جملة العدد، كذلك قوله: ﴿سِنِينَ﴾ نعت المائة راجع إلى جملة العدد، وعلى هذا يكون ﴿سِنِينَ﴾ في محل الجر، غير أنه يفتح النعت بالسنين؛ لأنها اسم جامد فلا يحسن النعت بها.وقد حصل في قوله: ﴿سِنِينَ﴾ خمسة أوجه من الإعراب: الظرف، وعطف البيان، والبدل، والتفسير، والنصت. هذا الذي ذكرنا وجه قراءة العامة وهو تنوين (مِائَةٍ)، وقراءة حمزة، والكسائي: ""ثلاثمائةِ سنين"" مضافة غير منونة {26}، وهذه قراءة غير جيدة {27}.قال أبو الحسن: (لا يحسن إضافة المائة إلى السنين، لا تكاد العرب تقول: مائة سنين) {28}.وقال صاحب النظم: (من أضاف وأظهر العدد اعتسف) {29}. إلا أن أبا الحسن قال: (هو جائز، وقد يقوله بعض العرب) {30}.قال الفراء: (مِنَ العرب من يضع السنين في موضع سنة، وهي حينئذٍ {31} في موضع خفض لمن أضاف) {23}.وقوله تعالى: ﴿وَازْدَادُوا تِسْعًا﴾ قال أبو إسحاق: (لا يكون على معنى تسع ليال، ولا تسع ساعات؛ لأن العدد يعرف تفسيره، فإذا تقدم تفسيره استغنى بما تقدم عن إعادة ذكر التفسير، تقول: عندي مائة درهم وخمسة، فتكون الخمسة قد دل عليها ذكر الدراهم) {33}.وقال أبو علي: (﴿وَازْدَادُوا تِسْعًا﴾ أي: ازدادوا لُبث تسع، فحذف المصدر وأقيم المضاف إليه مقامه، وانتصاب تسع انتصاب المفعول به لا انتصاب الظرف، كما أن المضاف لو ظهر وأضيف إلى التسع كان كذلك) {34}."
  18,26,"قوله تعالى: ﴿قُلِ اللَّهُ أَعْلَمُ بِمَا لَبِثُوا﴾ ذكرنا تفسيره في الآية المتقدمة.وقوله تعالى: ﴿لَهُ غَيْبُ السَّمَاوَاتِ وَالْأَرْضِ﴾ ذكرنا تفسيره في آخر سورة هود {1}.﴿أَبْصِرْ بِهِ وَأَسْمِعْ﴾ قال الأخفش: (أي ما أبصره وأسمعه! كما تقول: أكرم به! أي ما أكرمه! قال: ويدلك على ذلك أن العرب تقول: يا أمة الله أكرم يزيد! فهذا معناه ما أكرمه! ولو كان يأمرها أن تفعل شيئًا لقال: أكرمي زيدًا) {2}.وقال الفراء: (﴿أَبْصِرْ بِهِ وَأَسْمِعْ﴾ يريد الله، كقولك: أكرم بعبد الله! ومعناه: ما أكرم عبد الله! وكذلك قوله: ﴿أَسْمِعْ بِهِمْ وَأَبْصِرْ﴾ [مريم: 38] ما أسمعهم وما أبصرهم!) {3}.وقال أبو إسحاق: قوله: (﴿أَبْصِرْ بِهِ وَأَسْمِعْ﴾ أجمع العلماء أن معناه: ما أسمعه وأبصره! أي: هو عالم بقصة أصحاب الكهف وغيرهم) {4}.وقال أبو علي: (العرب تتسع فتقيم المثال الذي يختص بالأمر مقام الخبر، والمثل المختص بالخبر موقع الدعاء والأمر مما أقيم من أمثلة الأمر موقع الخبر قولهم: أكرم يزيد! وقوله تعالى: ﴿أَسْمِعْ بِهِمْ وَأَبْصِرْ﴾ [مريم: 38]، ومعنى هذا ما أكرم زيدًا، واسمعوا وأبصروا، أي: صار زيد ذا كرم، وصار هؤلاء ذوي أسماع وأبصار. قال: وموضع الباء مع ما بعده من المنجر رفع، كما أن الباء في: ﴿كَفَى بِاللَّهِ﴾ [العنكبوت: 52] كذلك فوقع مثال الأمر هاهنا موقع الخبر، كما وقع مثال الخبر موقع الأمر في الدعاء في مثل: غفر الله لزيد، وقطع الله يد فلان، وجاء في التنزيل: ﴿قُلْ مَنْ كَانَ فِي الضَّلَالَةِ فَلْيَمْدُدْ لَهُ الرَّحْمَنُ مَدًّا﴾ [مريم: 75] فهذا لفظه كلفظ أمثلة الأمر، ومعناه الخبر، ألا ترى أنه لا وجه للأمر هاهنا وأن المعنى مده الرحمن مدا، ويدلك على أن المراد بقوله: أكرم يزيد! أن معناه أنه قد كرم، وأن الكرم وما أشبهه من الأحداث لا يخاطب ولا يؤمر ولا ينهى، وأنه ليس للأمر هاهنا معنى ولا متوجه، وأيضًا فإنك إذا قلت: يا زيد أكرم بعمرو، فليس يخلو هذا الفعل من أن يكون له فاعل، وفاعله لا يخلو من أن يكون المخاطب أو المتعجب منه، فلو كان المخاطب لوجب أن يجمع الضمير في الفعل ويلحق علامة التأنيث، فلما لم يفعل من ذلك شيء، بل أجروا هذا الفعل بعد المذكر والمؤنث والجمع والتثنية مجرى واحد أعلم أن فاعله المتعجب منه دون المخاطب، وثبت أن الجار مع المجرور في موضع رفع) {5}.هذا الذي ذكره أبو علي أصل هذا الكلام، وشرح وضعه، ثم صار من ألفاظ التعجب حتى لا فصل بين قولك: ما أحسن زيدًا! وقولك: أحسن بزيد، وإذا كان كذلك فقدله تعالى: ﴿أَبْصِرْ بِهِ وَأَسْمِعْ﴾ قال المفسرون: (ما أبصر الله بكل موجود، وأسمعه بكل مسموع) {6}.وقال ابن زيد: (معناه أنه يرى أعمال أهل السموات والأرض، ويسمع منهم) {7}. هذا الذي ذكرنا إجماع من أهل العلم أن قوله: ﴿أَبْصِرْ بِهِ وَأَسْمِعْ﴾ معناه ما أبصره وأسمعه!.وروى عطاء عن ابن عباس أنه قال: (معناه أبصر أوليائي بعجائب القرآن، وأسمع به أوليائي) {8}. وعلى هذا ﴿أَبْصِرْ بِهِ وَأَسْمِعْ﴾ المراد به الأمر، والمفعول محذوف على تقدير: أبصرهم وأسمعهم، وقوله: ﴿بِهِ﴾ أي: بالقرآن، كأنه قيل: اجعلهم يبصرون بالقرآن غيري، وولايتي ويسمعون ذلك {9}. والقول الذي عليه الناس هو الأول.وقوله تعالى: ﴿مَا لَهُمْ مِنْ دُونِهِ مِنْ وَلِيٍّ﴾ قال المفسرون: (أي ليس لأهل السموات والأرض من دون الله) {10}. والكناية تعود إلى أهل السموات والأرض، وقد سبق ذكرهم في قوله: ﴿غَيْبُ السَّمَاوَاتِ وَالْأَرْضِ﴾، وهم من غيبها، أي: مما غابوا فيها. وقال عطاء عن ابن عباس: (﴿مَا لَهُمْ مِنْ دُونِهِ مِنْ وَلِيٍّ﴾ يريد قد عرفوا عظمتي وربوبيتي فلم يتخذوا من دوني وليًّا) {11}. وعلى هذا الكناية في قوله تعود إلى المؤمنين خاصة من أهل السموات والأرض {12}.وقوله تعالى: ﴿وَلَا يُشْرِكُ فِي حُكْمِهِ أَحَدًا﴾ قال أبو إسحاق: (هذا على معنيين أحدهما: أنه جرى ذكر علمه وقدرته، فأعلم أنه لا يشرك في حكمه بما يخبر به من الغيب أحدًا كما قال: ﴿عَالِمُ الْغَيْبِ فَلَا يُظْهِرُ عَلَى غَيْبِهِ أَحَدًا﴾ [الجن: 26]. ويكون على معنى: أنه لا يجوز أن يحكم حاكم إلا بما حكم الله، وبما دل عليه حكم الله، وليس لأحد أن يحكم من ذات نفسه فيكون شريكًا في حكمه يأمر بحكم كما أمر الله) {4}. وقرأ ابن عامر: ولا تشرك {14}، على معنى: ولا تشرك أنت أيها الإنسان في حكمه أحدًا، على النهي عن الإشراك في حكمه، أي: لا يكن كمن قيل فيه: ﴿أَيُشْرِكُونَ مَا لَا يَخْلُقُ شَيْئًا وَهُمْ يُخْلَقُونَ)﴾ [الأعراف: 191]. وعلى هذه القراءة في الآية رجوع من الغيبة إلى الخطاب، والقراءة الأولى التي عليها العامة أشبه لتقدم اسم الغيبة، وهو قوله: ﴿مَا لَهُمْ مِنْ دُونِهِ مِنْ وَلِيٍّ﴾، والهاء للغيبة فكذلك قوله: ﴿وَلَا يُشْرِكُ﴾ أي: ولا يشرك الله في حكمه أحدًا {15}."
  18,27,"قوله تعالى: ﴿وَاتْلُ مَا أُوحِيَ إِلَيْكَ مِنْ كِتَابِ رَبِّكَ﴾ قال المفسرون: (معناه: أَتبع القرآن) {1}.وقوله تعالى: ﴿لَا مُبَدِّلَ لِكَلِمَاتِهِ﴾ قال ابن عباس: (يريد لمواعيده) {2}.وإلي هذا أشار الزجاج فقال: (أي ما أخبر الله به، وما أخبر به فلا مبدل له) {3}. وعلى هذا المعنى: لا مبدل لحكم كلماته مما وعد به وأمر، وقال الكلبي: (لا مغير للقرآن) {4}.وقوله تعالى: ﴿وَلَنْ تَجِدَ مِنْ دُونِهِ مُلْتَحَدًا﴾ قال مجاهد: (ملجأ) {5} وقال الفراء: (الملتحد: الملجأ) {6}. وقال أبو عبيدة: (معدلا) {7}.وقال الزجاج: (أي لن تجد معدلا عن أمره ونهيه) {8}. وأصل هذا الحرف: من الميل، ومن قال: ملجأ، فهو يؤول إلى هذا المعنى أيضًا؛ لأنك إذا لجأت إلى شيء فليس يكون إلا بالميل منك إليه، وذكرنا هذا الحرف عند قوله: ﴿لِسَانُ الَّذِي يُلْحِدُونَ إِلَيْهِ أَعْجَمِيٌّ﴾ [النحل: 103].وقال ابن زيد في هذه الآية: (لا تجدون من دونه ملجأ ولا أحدا يمنعكم) {9}."
  18,28,"قوله تعالى: ﴿وَاصْبِرْ نَفْسَكَ مَعَ الَّذِينَ يَدْعُونَ رَبَّهُمْ بِالْغَدَاةِ وَالْعَشِيِّ يُرِيدُونَ وَجْهَهُ﴾ مفسرا بما فيه من النزول، واختلاف القراءة في سورة الأنعام {1}.وقوله تعالى: ﴿وَلَا تَعْدُ عَيْنَاكَ عَنْهُمْ﴾ قال علي عن ابن عباس: (يقول لا تتعداهم إلى غيرهم) {2}. وقال عطاء عنه: (يريد يصدهم بالنظر والمحبة لهم) {3}.وقال الفراء: (لا تصرف عيناك عنهم) {4}.وقال الزجاج: (لا تصرف بصرك إلى غيرهم من ذوي الهيئات والزينة) {5}. والنهي في الظاهر واقع على العينين، والمراد منه صاحب العينين، وهو النبي -ﷺ-.قوله تعالى: ﴿تُرِيدُ زِينَةَ الْحَيَاةِ الدُّنْيَا﴾ قال المفسرون: (يعني مجالسة أهل الشرف والغنى) {6}.وقال أهل المعاني: (قوله: ﴿تُرِيدُ﴾ هاهنا في موضع الحال) {7}، أي: مريدًا، نهي أن يرفع بصره عن ضعفاء المؤمنين مريدًا مجالسة الأشراف. وكان -ﷺ- حريصًا على إيمان الرؤساء طمعًا في إيمان أتباعهم، ولم ينسب إلى إرادة زينة الحياة الدنيا؛ لأنه لم يمل إلى الدنيا قط ولا إلى أهلها، وإنما كان يلين في بعض الأحيان للرؤساء طمعًا في إيمانهم، فعوتب بهذه الآية، وأمر بأن يجعل إقباله على المؤمنين، وأن لا يلتفت إلى غيرهم، ونهي أن يكون له حال يميل فيها إلى الأشراف دون الضعفاء، ومثل هذه الآية قوله: ﴿أَمَّا مَنِ اسْتَغْنَى (5) فَأَنْتَ لَهُ تَصَدَّى﴾ [عبس: 5، 6].وقوله تعالى: ﴿لَا تُطِعْ مَنْ أَغْفَلْنَا قَلْبَهُ عَنْ ذِكْرِنَا﴾ قال ابن عباس: (يريد عيينة وأباهه) {8}، أي: لا تطعهم في تنحية الفقراء عنك ليجلسوا إليك.وسئل أبو العباس عن قوله: ﴿لَا تُطِعْ مَنْ أَغْفَلْنَا قَلْبَهُ عَنْ ذِكْرِنَا﴾ فقال: (من جعلناه غافلاً. قال: ويكون في الكلام أغفلته سميته غافلاً، ووجدته غافلاً) {9}، وتأويل ﴿أَغْفَلْنَا قَلْبَهُ عَنْ ذِكْرِنَا﴾ تركناه غُفْلا عن الذكر، كالأرض الغُفْل التي لا علامة بها، والكتاب الغُفْل الذي لا شكل عليه.وقوله تعالى: ﴿وَكَانَ أَمْرُهُ فُرُطًا﴾ قال مجاهد: (ضياعا) {10}. وقال قتادة: (ضاع أكبر الضيعة) {11}. وقال السدي: (هلاكا) {12}.وقال أبو الهيثم: (أمر فرط، أي: متهاون به) {13}. وشبه أن يكون أصل هذا من التفريط، وهو تقديم العجز، وهذا بمعنى قول أبي إسحاق {5}. ومن قدم العجز في أمره أضاعه وأهلكه، ومعنى هذا أنه ترك الإيمان والاستدلال بآيات الله واتبع هواه.الليث: (الفَرَطُ: الأمر الذي يُفَرَّط فيه، تقول: كل أمر فلان فَرَط) {15}، ونحو هذا قال الفراء: (فُرُطا: متروكًا قد ترك فيه الطاعة) {4}.وقال ابن عباس في رواية عطاء: (يريد أنه أفرط في مسألته، وأحب أن يرتفع عند الله بغير تقوى) {17}، يعني حين أراد مجالسة النبي -ﷺ- والقرب منه، والتقدم على أهل الإيمان من غير طاعة وتقى. وعلى هذا الفَرَط اسم من الإفراط وهو مجاوزة الحد، ونحو هذا روي عن مقاتل أنه قال في قوله: ﴿فُرُطًا﴾ قال: (سرفا) {18}. فيحتمل أنه يريد بالمسرف ما ذكرنا عن ابن عباس، ويحتمل أن يريد ما ذكره الكلبي والفراء.قال الكلبي: (قال عيينة: إنا رؤوس مضر {19} وأشرافها، فإن نسلم يسلم الناس بعدنا) {20}.وقال الفراء: (إنه أفرط في القول فقال: نحن رؤوس مضر وأشرافها، وليس كذلك) {4}. وعلى هذا كان أمره فُرُطا لإفراطه في القول والبذخ حين قال: إنه رأس العرب وهم أتباعه على دينه. ويقال: أمر فُرُط، أي مجاوز فيه الحدود. روي عن أبي زيد البلخي أنه قال: (معناه: قدما في الشر) {22}. وعلى هذا أصله من قوله: فَرَطَ منه أمر، أي: سبق وبدر {23}.ومنه قوله تعالى: ﴿إِنَّنَا نَخَافُ أَنْ يَفْرُطَ عَلَيْنَا﴾ [طه: 45]، ومنه يقال: فرس فُرُط، أي: سريعة، قال لبيد {24}:فُرُط وشاحي إذ غدوتُ لجامها"
  18,29,"قوله تعالى: ﴿وقُلِ﴾ قال عطاء عن ابن عباس: (وقيل يا محمد لمن جاءك من أهل الدنيا شريفًا أو وضيعًا) {1}. قال المفسرون: قل لهؤلاء الذين أمروك بتنحية الفقراء عنك، وإدناء مجلسهم ليؤمنوا بك.وقوله تعالى: ﴿الْحَقُّ مِنْ رَبِّكُمْ﴾ قال الكسائي: (يعني هو الحق من ربكم، وهو الإسلام) {2}.وقال الأخفش: (أي قل: هو الحق) {3}.قال أبو إسحاق: (أي الذي أتيتكم به الحق من ربكم) {4}. وهذا معنى قول قتادة: (﴿الْحَقُّ﴾ هذا القرآن) {5}.وقوله تعالى: ﴿فَمَنْ شَاءَ فَلْيُؤْمِنْ وَمَنْ شَاءَ فَلْيَكْفُرْ﴾ قال السدي: (هذا على وجه الوعيد) {6}. وقال قتادة: (إن ربكم بين ثم خير) {7}؛ يعني التخيير الذي هو للتهديد، كما قال الزجاج: (هذا الكلام ليس بأمر لهم ما فعلوا منه فهم فيه مطيعون، ولكنه كلام وعيد وإنذار، قد بين بعده ما لكل فريق من مؤمن وكافر) {4}. هذا الذي ذكرنا قول أكثر أهل التفسير {9}.وروى الوالبي عن ابن عباس والضحاك في هذه الآية يقول: (من يشاء الله له الإيمان آمن، ومن شاء الله له الكفر كفر) {10}. وهو كقوله: ﴿وَمَا تَشَاءُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ رَبُّ الْعَالَمِينَ﴾ [التكوير: 29]، فعلى هذا القول قوله: ﴿فَمَن شَآءَ﴾، أي: من شاء الله، فالمشيئة مسندة إلى الله.وقوله تعالى: ﴿إِنَّا أَعْتَدْنَا﴾ أي: هيأنا وأعددنا. ومضى الكلام في معنى الإعتاد {11}. ﴿لِلظَّالِمِينَ﴾ الذين عبدوا غير الله تعالى {12}.﴿نَارًا أَحَاطَ بِهِمْ سُرَادِقُهَا﴾ معنى السرادق في اللغة: كل ما أحاط بشيء واشتمل عليه من ثوب أو حائط. وأكثر ما يستعمل في الفسطاط.قال الليث: (السرادق: كالحجرة المحوطة من غزل غليظ منسوج مضرب الأسفار للملوك، والجمع: سرادقات) {13}.قال رؤبة {14}:سرادق المجد عليك ممدودقال الأزهري: (ويقال للغبار الساطع، والدخان الشاخص المحيط بالشيء: سرادق) {13}.قال لبيد يذكر الإبل {16}:رفعن سرادقًا في يوم ريح ... يصفق بين ميل واعتدالهذا معنى السرادق في اللغة {17}. فأما التفسير فروى أبو سعيد الخدري عن النبي -ﷺ- قال: ""سرادق النار أربع جدر، كثف كل جدار منها مسيرة أربعين سنة"" {18}وقال الكلبي: (هو دخان يحيط بالكفار يوم القيامة) {19}. وبهذا فسِّر قوله تعالى: ﴿وَظِلٍّ مِنْ يَحْمُومٍ﴾ [الواقعة: 43]، وقوله: ﴿انْطَلِقُوا إِلَى ظِلٍّ ذِي ثَلَاثِ شُعَبٍ﴾ [المرسلات: 30] الآية؛ وهذا اختيار أبي عبيدة، وابن قتيبة {20}.وقوله تعالى: ﴿وَإِنْ يَسْتَغِيثُوا﴾ قال المفسرون: أي مما هم فيه من العذاب وشدة العطش.﴿يُغَاثُوا بِمَاءٍ كَالْمُهْلِ﴾ قال أبو عبيد: (المهل: كل فِلِزٍّ {21} أذيب) {22}.وروي في حديث أبي بكر -رضي الله عنه- أنه أوصى في موضعه فقال ""ادفنوني في ثوبي هذين، فإنما هما للمهل والتراب"" {23}.قال أبو عبيدة: (المهل في هذا الحديث: الصديد والقيح) {24}.وقال أبو عمرو: (المهل في شيئين: هو في حديث أبي بكر: القيح والصديد، وفي غيره: دردي الزيت) {25}.وقال اليث: (المهل: ضرب من القطران، يقال: مَهَلْتُ البعير فهو مَمْهُول) {26}.وروى شمر عن ابن شميل: (المهل عندهم الملَّة إذا حميت جدًّا رأيتها تموج) {26}.وقالت العامرية: (المهل عندنا السُّمّ) {28}. هذا معنى المهل في اللغة، وهو على ستة معان. روى أبو سعيد الخدري عن النبي -ﷺ- في قوله: ""بماء كالمهل"" قال: ""كعكر الزيت"" {29}.وهو قول ابن عباس في رواية سعيد بن جبير قال: (كدردي الزيت) {30}. ونحو هذا روى عنه الوالبي والعوفي {31}. وقال مجاهد: ""كالمهل"" (القيح والدم) {32}.وقال عطاء عن ابن عباس: (هو عكر القطران) {33}.وروى قتادة والحسن عن ابن مسعود: (أنه سئل عن المهل، فدعا بذهب وفضة فخلطهما، فأذيبا حتى إذا أزبدا وانماعا قال: هذا أشبه شيء في الدنيا بالمهل الذي هو شراب أهل النار) {34}. وإلى هذا القول ذهب من قال في تفسير المهل: هو الذي قد انتهى حره؛ لأنه لا شيء أشد حرارة من هذه الجواهر إذا أذيبت. وهذا القول هو اختيار الزجاج فقال: (يعني أنهم يغاثون بماء كالرصاص المذاب والصُّفْر أو الفضة) {35}.وقوله تعالى: ﴿يَشْوِي الْوُجُوهَ﴾ يقال: شويتُ اللحم أشويه شيًّا، فإذا شويته لنفسك خاصة قلت: أشويت. قال لبيد {36}:فاشتوى ليلة ريحٍ واجتملوانشوى اللحم انشواء، ويقال: اشتوى أيضًا بهذا المعنى {37}.روى الخدري عن النبي -ﷺ- في هذه الآية قال: ""فإذا قربه إليه سقط فروة وجهه فيه"" {38}.وقال ابن عباس: (يشويه حتى يسقط لحم وجهه) {39}. ثم ذمه فقال: ﴿بِئْسَ الشَّرَابُ﴾ هذا الماء الذي وصفنا. ﴿وَسَاءَتْ مُرْتَفَقًا﴾ أي: ساءت النار مرتفقا، وهو نصب على التمييز {35}. ومعنى المرتفق في اللغة: ما يرتفق به {41}.قال ابن عباس: (يريد وبئس ما ارتفقوا به) {42}. واختلفت العبارات عن المفسرين في هذا، فقال مجاهد: (مجتمعا) {43}.وقال عطاء: (مقرًّا) {44}. وقال الزجاج: (منزلا) {35}.وقال ابن قتيبة: (مجلسا) {46}. ومعنى هذه الألفاظ واحد، وهي كلها ترجع إلى أصل واحد، فيجوز أن ترجع إلى ما ذكرنا، وذلك أن المنزل والدار مما يرتفق به، ويجوز أن يكون أصلها من الارتفاق وهو الاتكاء على المرفق، ومنه قول الهذلي {47}: نام الخلي وبتُّ مرتفقاوهذا قول ابن السكيت في قوله: ﴿مُرْتَفَقًا﴾ قال: (متكأ) {48}. وكل موضع نزلته وقعدت فيه فهو مرتفق لك ومتكأ."
  18,30,"ثم ذكر ما وعد المؤمنين فقال: ﴿إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ﴾ الآية. واختلف النحويون في جواب ﴿إِنَّ﴾ الأولى، فذكر أبو إسحاق وأبو علي فيه ثلاثة أوجه:أحدها: أن خبره قوله: ﴿إِنَّا لَا نُضِيعُ أَجْرَ مَنْ أَحْسَنَ عَمَلًا﴾ على إضمار منهم، فحذف الراجع من الخبر؛ لأنه معلوم أن الله إنما لا يضيع أجر من أحسن عملاً من المؤمنين، فأما من أحسن عملاً من غير المؤمنين فإن الله يحبط عمله.الوجه الثاني: أن المعنى إنا لا نضيع أجرهم، إلا أنه وقع المظهر موقع المضمر؛ لأن من أحسن عملاً في المعنى الذين آمنوا وعملوا الصالحات.الوجه الثالث: أن الخبر قوله: ﴿أُولَئِكَ لَهُمْ جَنَّاتُ عَدْنٍ﴾ ويكون قوله: ﴿إِنَّا لَا نُضِيعُ﴾ اعتراضًا بين الاسم والخبر، وجاز ذلك؛ لأن من أحسن عملاً بمنزلة الذين آمنوا {1}. وذكر الفراء وجهين آخرين أحدهما: (أن قوله: ﴿إِنَّا لَا نُضِيعُ أَجْرَ﴾ من عمل صالحًا، فترك الكلام الأول واعتمد على الثاني كقول الشاعر {2}:إنَّ الخليفة إنَّ الله سربله ... سربال ملك به تزجى الخواتيمالثاني: أن يجعل ﴿إِنَّ الَّذِينَ آمَنُوا﴾ في مذهب جزاء ويضمر، فيصير كأنك قلت: إن من عمل صالحًا فإنا لا نضيع أجره) {3}. والقول ما ذكره أبو إسحاق وأبو علي {4}."
  18,31,"قوله تعالى: ﴿يُحَلَّوْنَ فِيهَا مِنْ أَسَاوِرَ مِنْ ذَهَبٍ﴾ قال أبو إسحاق: (أساور جمع أسورة، وأسورة جمع سوار، يقال: سوار في اليد بالكسر، وقد حُكي: سوار، وحكى قطرب: إسوار، وذكر أن أساور جمع إسوار)؛ انتهى كلامه {1}. وقال أبو زيد: (هو سوار المرأة، وسوار المرأة، وأسورة لجماعتها، وهما قلبان يكونان في يدها) {2}.قال أبو علي: (قول من قال: سوار صحيح، يدل عليه قوله {3}: وفي الأكفِّ اللامعات سورففعل يجمع به هذا النحو، فأما من حكى أسوار فهذا الضرب من الأسماء قليل جدًّا، إلا أن الثقة إذا حكى شيئًا لزم قبوله، ونظيره قولهم: الإعصار، والإسكان، ولا يجوز عندي أن يكون الجمع الذي جاء في التنزيل مكسرا على هذا الواحد، ألا ترى أنه لو كان كذلك لوجب ثبات الياء في التكسير ليكون على زنة: دنانير؛ لأن حرف اللين إذا كان رابعًا في الواحد، ثبت أنه الآخر الذي هو سوار جمع على أسورة، ثم جمع أسورة على أساور، كما حكى سيبويه من جمعهم أسقية على: أساق {4}. ولو كان أساور التي في التنزيل جمع: أسوار، لكان يجب أن يكون أساوير، فلما كانت بغير الياء كانت جمع: سِوَار، كما أن أسقية جمع: سقاء، ثم جمع على: (أساق) {5}.قال سعيد بن جبير: (على كل واحد منهم ثلاثة من الأساور، واحد من فضة، وواحد من ذهب، وواحد من لؤلؤ ويواقيت) {6}. وقال أهل المعاني: (السوار: زينة تلبس في الزند من اليد، وهو من زينة الملوك تسور في اليد وتتوج على الرأس) {7}.ويروى: (أن كسرى كان له تاج وسواران، فأتي بها عمر -رضي الله عنه-) {8}.وقوله تعالى: ﴿مِنْ سُنْدُسٍ وَإِسْتَبْرَقٍ﴾ قال الزجاج: (هما نوعان من الحرير) {9}.وقال المفسرون: (السندس: ما رقَّ من الديباج، والإستبرق: مما غلظ منه) {10} قال المرقش {11} {12}:تراهنَّ يلبسن المشاعر مرَّةً ... وإستبرق الديباج طورًا لباسهاوهو اسم أعجمي أصله بالفارسية: [استبر، ونقل من العجمية إلى العربية، كما سمي الديباج، وهو منقول من الفارسية] {13}.قال أبو علي: (الإستبرق لا تخلو حروفه من أن تكون أصولًا كلها أو بعضها أصولًا وبعضها زائدًا، ولا يجوز أن تكون أصولا؛ لأنه ليس من كلامهم في الأسماء والأفعال ما هو على ستة أحرف أصول، ولا يجوز أن تكون الهمزة وحدها زائدة؛ لأنها لم تلحق زائدة أول بنات الأربعة، فإن لا تلحق أوائل بنات الخمسة أجدر، فإذا لم يجز هذا فلابد من أن ينضم إليها في الزيادة غيرها، فلا يجوز أن تكون السين؛ لأنها لم تزد مع الهمزة أولاً، ولا يجوز أيضًا أن تكون التاء مع الهمزة، كما لم يجز أن تكون السين، فإذا لم يجز هذا علمت أن الزيادة، وهي التاء والسين مع الهمزة، وأن الكلمة من الثلث، ولما نقلت فأعربت وافق التعريب وزن استفعل الذي هو مثال من أمثلة الماضي، إلا أن الهمزة منه قطعت لينقل من مثال الفعل إلى الاسم، وكان قطع الهمزة أحد ما نقل به الفعل إلى أحكام الاسم، وجعل النحويون هذا الحرف ومجيء الهمزة مقطوعة فيه أصلاً لجميع ما أوله همزة موصولة إذا نُقل سمي به، فقطعوا الهمزة في جميع ذلك، يقال: لو سميت رجلاً بأضرب وأشرب أو أقتل قطعت الهمزة في جميع ذلك؛ لأنه ليس من حكم الاسم أن يلحق همزة الوصل أولها، والحروف التي لحقت همزة الوصل أولها كما لابن والاسم أشبهت الأفعال عند النحويين لما لحق أواخرها الحذف الذي يلحق الأفع الذي الجزم، فلحق أولها همزة الوصل أيضًا لهذه المشابهة التي بينها) {14}.وروي عن ابن محيصن {15} أنه كان يقرأ: واستبرق، موصولة الألف مفتوحة الآخر على مثال الماضي {16}، نحو: استفعل، وذلك لا يجوز؛ لأنه ليس هذا الحرف استفعل من برق، وإنما وافق اللفظ، واللفظ في التقريب [كما أن سراويل في التقريب] {17} وافق هذا اللفظ وإن لم يكن في كلامهم، وإذا كان كذلك لم يتبع أن يجعل مثال الماضي، ولكنه اسم جنس، يدلك على ذلك دخول لام المعرفة عليه، والجار في نحو قوله: ﴿بَطَائِنُهَا مِنْ إِسْتَبْرَقٍ﴾ [الرحمن: 54]. وإذا كان كذلك ففتحه لا يجوز إذ ليس بفعل، وإذا لم يكن فعلاً كان اسمًا أعجميًّا [معربًا واقعًا على الجنس، كما أن السندس والخَزّ {18} كذلك] {17} كان بمنزلة الديباج والفِرنْد {20}، والبَرِيم {21}، ونحو ذلك من الأسماء المنقولة نكرة، وليس من باب إبراهيم وإسماعيل، وإذا كان من هذا الضرب لم يكن فيه إلا الصرف إلا أن يُسمَّى به شيء فينضم إلى مثال الفعل التعريف، فإذا لم يكن كذلك فترك الصرف فيه لا يستقيم.وقوله تعالى: ﴿مُتَّكِئِينَ فِيهَا﴾ يقال: اتكأ الرجل، وأصله: اوتكا، مثل: اتزن من الوزن، والتُكأة أصلها: وُكأة، ومنه التَّوكؤ، وهو: التحامل على الشيء، قال الله تعالى: ﴿قَالَ هِيَ عَصَايَ أَتَوَكَّأُ عَلَيْهَا﴾ [طه: 18]؛ ورجل تُكأة إذا كان كثير الاتِّكاءِ، وهو في الأصل وكأة، فقلبت الواو تاء كما قالوا: تكلة في موضع وكلة ويقال: تكأ الرجل يتكئ مثل اتكأ، وأوكأت فلانًا إذا نصبت له متكأ {22}.وقوله: ﴿عَلَى الْأَرَائِكِ﴾ جمع أريكة. قال الليث: (وهي سرير حجلة، فالحجلة والسرير أريكة، وجمعها: أرائك) {23}. وهو قول المفسرين؛ قال ابن عباس ومجاهد: ﴿الْأَرَائِكِ﴾ هو: السُّرر في الحجال) {24}. ولا يكون أريكة حتى يكون السرير في الحجلة.وقال أبو إسحاق: (﴿الْأَرَائِكِ﴾: الفرش في الحجال) {9}.قال ابن عباس {26}: (يريد الأَسِرَّة من ذهب مكللة بالدر والياقوت عليها الحجال، الأريكة ما بين صنعاء {27} إلى أيلة {28}، وما بين عدن {29} إلى الجابية {30}). وما نزلت من الصفة أعظم.وقوله تعالى: ﴿نِعْمَ الثَّوَابُ﴾ قال: يريد طاب ثوابهم وعظم، ﴿وَحَسُنَتْ مُرْتَفَقًا﴾ يعني حسنت الأرائك مرتفقا، أي: موضع ارتفاق، بمعنى اتكأ؛ قاله الفراء في المصادر {31}. ومر معنا تفسير المرتفق آنفًا."
  18,32,"قوله تعالى: ﴿وَاضْرِبْ لَهُمْ مَثَلًا رَجُلَيْنِ﴾ الآية، قال ابن عباس في رواية عطاء: (يريد ابني ملك كان في بني إسرائيل توفي وترك ابنين، فاتخذ أحدهما القصور والأجنة، والآخر كان زاهدًا في الدنيا، راغبًا في الآخرة، فكان إذا عمل أخوه شيئًا من زينة الدنيا أخذ مثل ذلك فقدم لآخرته، واتخذ به عند الله الأجنة والقصور، حتى نفذ ماله. فضربهما مثلاً للمؤمن والكافر الذي أبطرته النعمة) {1}.وقال الكلبي: (هما أخوان من بني مخزوم {2}: أحدهما مؤمن وهو: أبو سلمة عبد الله بن عبد الأسد {3} زوج أم سلمة. والآخر: كافر وهو: الأسود {4}.قال أبو إسحاق: (كان المشركون سألوا النبي -ﷺ- بمشورة اليهود عن قصة أصحاب الكهف، وعن الروح، وعن هذين الرجلين فأعلمه الله الجواب؛ لأنه مثل له -ﷺ- وللكفار، ومثل لجميع من آمن بالله، وجميع من عَنَدَ عنه وكفر به) {5}. فقال: ﴿وَاضْرِبْ لَهُمْ مَثَلًا رَجُلَيْنِ﴾ منصوب {6} على معنى المفعول.وقوله تعالي: ﴿وَحَفَفْنَاهُمَا بِنَخْلٍ﴾ الحفُّ: الإطافة بالشيء، يقال: حفَّ القوم بسيدهم يَحُفُّون بضم الحاء إذا أطافوا به وعكفوا {7}، ومنه قوله: ﴿حَافِّينَ مِنْ حَوْلِ الْعَرْشِ﴾ [الزمر: 75]. والمعنى: جعلنا النخل مطبقًا بها ﴿وَجَعَلْنَا بَيْنَهُمَا﴾ أي: بين الجنتين ﴿زَرْعًا﴾ ثم أخبر أنهما كاملتان في مادة حملهما وأعنابهما، والزرع الذي بينهما."
  18,33,"فقال: ﴿كِلْتَا الْجَنَّتَيْنِ آتَتْ أُكُلَهَا﴾ ذكرنا الكلام في (كلا) عند قوله: ﴿أَحَدُهُمَا أَوْ كِلَاهُمَا﴾ [الإسراء: 23]، وأما ﴿كِلْتَا﴾ فذهب سيبويه إلى أنها فعلى بمنزلة الذكرى، وأصلها كلوى، فأبدلت الواو تاء كما أبدلت في أنحت وبنت {1}. والذي يدل على أن لام ""كلتا"" معتلة قولهم في مذكرها: كِلَى، وكِلَى فِعَل، ولامه معتلة بمنزلة لام حِجَى وَرِضَى، وهما من الواو لقولهم: حَجَى يَحْجُو، والرضوان، ولذلك مثلها سيبويه بما اغتسلت لامه فقال: (هي بمنزلة شروى) {1}.وأما أبو عمرو الجرمي فذهب إلى أنها معتلة وأن التاء فيها علامة تأنيثها {3}. وخالف سيبويه، وشهد بفساد هذا القول أن التاء لا تكون علم تأنيث الواحد إلا وقبلها فتحة، مثل: حَمْزَة وطلحة وقاعدة، أو تكون قبلها ألف نحو: سعلاة وعزهاة، والسلام في كلتا ساكنة كما ترى. ووجه آخر: أن علامة التأنيث لا تكون أبدًا وسطا، إنما تكون آخرا لا محالة، وكلتا اسم مفرد يفيد معنى التثنية فلا يجوز أن يكون علامة تأنيثه التاء، وما قبلها ساكن، وأيضًا فإن فعلى مثال لا يوجد في الكلام أصلاً، فيحمل هذا عليه، فإن سميت بـ (كلتا) رجلاً لم تصرفه في قول سيبويه معرفة ولا نكرة؛ لأن ألفها للتأنيث بمنزلة ألف ذكرى، وتصرفه نكرة في قول أبي عمرو، لأن أقصى أحواله عنده أن يكون كتائهة وقاعدة وعزة وحمزة {4}.وقوله تعالى: ﴿آتَتْ أُكُلَهَا﴾ قال الأخفش: (جعل الفعل واحدًا ولم يقل: آتتا، لأنه جعل ذلك لقوله: ﴿كِلْتَا﴾ هو في اللفظ، ولو جعله على معنى قولك: كلتا، لقال: آتتا) {5}. ونحو هذا قال الزجاج {6}. ومعنى ﴿آتَتْ أُكُلَهَا﴾ صاحبها أكلها أي: أدت إليه ريعها تامًا من غير نقصان، وهو قوله: ﴿وَلَمْ تَظْلِمْ مِنْهُ شَيْئًا﴾ قال ابن عباس والمفسرون: (لم تنقص منه شيئًا) {7}.يقال: ظلمهُ حقه إذا نقصه، وقد مر. ﴿وَفَجَّرْنَا﴾ أي: أنبطنا {8} وأخرجنا ﴿خِلَالَهُمَا﴾ وسط الجنتين ﴿نَهَرًا﴾ أخبر أن شربهما كان من ماء نهر، وهو من أعذب الشرب، والكلام في التفجير والخلال قد مر في سورة بني إسرائيل {9}.قوله تعالى: ﴿وَكَانَ لَهُ ثَمَرٌ﴾ أي: كان للأخ الكافر أموال كثيرة، قال ابن عباس في رواية علي بن أبي طلحة في قوله: ﴿ثَمَرٌ﴾ يقول: (مال) {10}. وقال مجاهد: (ذهب وفضة) {11}. وقال قتادة: (يقول ومن كل المال) {12}.واختلف القراء في قوله: ﴿ثَمَرٌ﴾ علي ثلاثة أوجه: ثُمُر بضم الثاء والميم وهو قراءة أكثر القراء، وقرأ أبو عمرو: بضم الثاء وسكون الميم، وقرأ عاصم: بفتحهما {13}.قال الليث: (الثَمَر: حمل الشجر) {14}. والثُمُر أنواع المال، يقال: أثمر الرجل إذا كثر ماله، وثَمَّر الله مال فلان ، أي: كثره. وروى الفراء بإسناده عن مجاهد قال: (ما كان في القرآن من ثُمُر فهو مال، وما كان من ثَمَر فهو من الثمار) {15}.وقال ابن زيد: (الثُّمُر الأصل، والثَّمَرة ما يجتنى من ذي الثمر) {16}. ويجمع ثَمَرَات مثل: رَقَبَة ورَقَبات، قال الله تعالى: ﴿وَمِنْ ثَمَرَاتِ النَّخِيلِ﴾ [النحل: 67]، وثِمَار أيضًا مثل: رِقَاب في جمع رَقَبَة، ويجوز أن يُكسَّر ثَمَار على ثُمُر ككِتَاب وكُتُب، ويجوز في جمع ثَمَرَة وجهان آخران: ثَمَر مثل: بَقَرة وبَقَر، وثُمْر أيضًا كبَدَنة وبُدْن وخَشَبَة وخُشْب.فقراءة أبي عمرو بالتخفيف تحتمل ثلاثة أوجه أحدها: أن يكون جمع ثِمَار، فخفِّف نحو كتُب في جمع {17} كِتَاب. الثاني: أن يكون جمع ثمرة مخفف نحو خُشْب جمع في {18} خَشَبَة. الثالث: أن يكون ثُمُر واحد مثل ثَمَر فخفف نحو {19} عَنُق وطُنُب. فعلى أي: هذه الوجوه كان، جاز إسكان العين {20} وساغ {21}.وأما قراءة العامة بضمتين ، فلأن أهل اللغة فرقوا بين الثُمر والثمَر فقالوا: الثَمَر المال، والثُمُر المأكول. وأكثر المفسرين على أن الثَمَر هاهنا: الأموال، وعلى قول ابن زيد الثُمُر: الأصول التي تحمل الثمرة لا نفس الثمرة. وهذه القراءة أقوى الوجوه لقوله: ﴿فأصبحَ يُقلِّب كفَّيه عَلَى ما أَنْفَقَ فيها﴾ أي: في الجهة، والنفقة إنما تكون على ذوات الثمر في أغلب العرف {22}. وقال أبو إسحاق: (الثُمُر هاهنا أحسن؛ لأن قوله: ﴿كِلْتَا الْجَنَّتَيْنِ آتَتْ أُكُلَهَا﴾ قد دل على الثَمَر) {6}.وحكي عن أبي عمرو أنه قال: (الثَمَر والثُمُر أنواع المال) {24}. وهو المراد في هذه الآية، لا الثمرة التي تُجنى، دل على هذا قوله: ""وأحيط بثَمَره"" أي: أهلك جنته وماله وأصول نخله وشجره، وإذا كان كذلك فمن قرأ: بثُمْره وثُمُره كان قوله أبين، وأما قراءة عاصم في قوله: ""وكان له ثَمَر"" يعني ثَمَر {25} نخله وكرمه، فليس بالجيد {26} ، لأن هذا قد فُهم من قوله: ﴿آتَتْ أُكُلَهَا﴾ وفي قوله: ""وأحيط بثمره"" كأنه أخبر عن بعض ما أصيب وأمسك عن بعض، وقراءة الباقين في قوله: ""وأحيط بثمرة"" جيدة عامة في الثَمَرة والأصول ، لأنه لا يكون أن يصاب الأصل ولا يصاب الثمرة.وقال محمد بن سلام: (قال سلام أبو المنذر القارئ {27}: من قرأ: ""ثَمَر"" قال: من كل المال، ومن قرأ: ""ثُمُر"" فهو جمع ثَمَره. فأخبرت بذلك يونس فقال: هما سواء) {14}.وهذا على أنه جعل الثُمْر جمع ثَمَرة، كما ذكرنا في خَشَبَة وخُشب، والصحيح الفرق بين القراءتين على ما ذكرنا.والثمّر في جمع الثَّمَرة صحيح، غير أن الثُّمُر هاهنا الأولى أن يحمل على الأموال كما بينا {29}."
  18,34,"وقوله تعالى: ﴿فَقَالَ لِصَاحِبِهِ﴾ قال ابن عباس: (يريد لأخيه) {1}. ﴿وَهُوَ يُحَاوِرُهُ﴾ أي: يراجعه في الكلام ويجاوبه.قال ابن عباس: (وذلك أنه سأله عن ماله فيما أنفقه؟ فقال: قدمته بين يدي لأقدم عليه) {2}. فقال: ﴿أَنَا أَكْثَرُ مِنْكَ مَالًا وَأَعَزُّ نَفَرًا﴾ روى أبو عبيد عن أبي زيد: (النفر والرهط ما دون العشرة من الرجال) {3}.وقال أبو العباس: (النفر، والقوم، والرهط هاهنا معناهم الجمع لا واحد لهم من لفظهم للرجال دون النساء) {3}.وقال الليث: (يقال: هؤلاء عشرة نفر أي: عشرة رجال، ولا يقال: عشرون نفرًا، ولا ما فوق العشرة) {5}.قال ابن عباس: (يريد كثرة العبيد وعزة فيهم) {6}.وقال الزجاج: (أخبر أن ناصره كثير) {7}. وقال قتادة في هذه الآية: تلك والله أمنية الفاجر كثرة المال وعزة النفر، وهم الخدم والحشم) {8}. مقاتل: (يعني ولدًا) {9}. دليله قوله: ﴿إِنْ تَرَنِ أَنَا أَقَلَّ مِنْكَ مَالًا وَوَلَدًا﴾ وقال المفسرون: (يعني عشيرة ورهطًا) {10}. ومنه قول امرئ القيس {11}:ماله لا عدَّ من نفرهأي: من رهطه وعشيرته."
  18,35,"قوله تعالى: ﴿وَدَخَلَ جَنَّتَهُ﴾ [قال المفسرون: (أخذ بيد أخيه المسلم فأدخله جنته] {1} يطوف به فيها، ويريه إياها ويعجبه منها) {2}. وقوله تعالى: ﴿وَهُوَ ظَالِمٌ لِنَفْسِهِ﴾ قال ابن عباس: (يعني خارجًا عن الإيمان إلى الكفر بالله) {3}.قال الزجاج: (وكل من كفر بالله فنفسه ظلم ، لأنه يولجها النار، وأي ظلم للنفس فوق هذا) {4}.وقوله تعالى: ﴿قَالَ مَا أَظُنُّ أَنْ تَبِيدَ هَذِهِ أَبَدًا﴾ أنكر أن الله تعالى يفني الدنيا، لما رأى ما راقه وكبر في نفسه، وتوهم بجهله أنه يدوم، وأن مثله لا يبيد ولا يفنى."
  18,36,"قوله تعالى: ﴿وَمَا أَظُنُّ السَّاعَةَ قَائِمَةً﴾ قال ابن عباس: (أنكر البعث والثواب والعقاب) {1}.وقال أبو إسحاق: (أخبر أخاه بكفره بالساعة، وبكفره بفناء الدنيا) {2}.وقوله تعالى: ﴿وَلَئِنْ رُدِدْتُ إِلَى رَبِّي﴾ الآية، قال ابن عباس: (يريد إن كان البعث حقًا) {3} ﴿لَأَجِدَنَّ خَيْرًا مِنْهَا مُنْقَلَبًا﴾ يريد: كما أعطاني هذا في الدنيا سيعطيني في الآخرة أفضل منه لكرامتي عليه {4}.وقال أهل المعاني: (هذا يدل على أن صاحبه المؤمن قد أعلمه أن الساعة تقوم، وأنه يبعث، فأجابه بأن قاله له: إن كان الأمر على ما أعلمتني أني أبعث، ليعطيني في الآخرة خيرًا مما أعطاني في الدنيا؛ لأنه لم يعطني هذا في الدنيا إلا وهو يريدني) {5}.وقال ابن زيد: (شك، ثم قال على شكه في الرجوع إلى ربه: ما أعطاني هذا إلا ولي عنده خير منه) {6}. تهكما سولته له نفسه.واختلفوا في قوله: ﴿مِنْهَا﴾ فقرؤا بالإفراد والتثنية {7}. والإفراد أولى من حيث كان أقرب إلى الجنة المفردة في قوله: ﴿وَدَخَلَ جَنَّتَهُ﴾، والتثنية لا تمتنع لتقدم ذكر الجنتين."
  18,37,"فأجابه صاحبه مكفرًا له بهذا القول فقال: {أَكَفَرْتَ بِالَّذِي خَلَقَكَ مِنْ تُرَابٍ} قال ابن عباس: (يريد أن آدم خلق من تراب) {1}. ثم ولده من نطفة، وإذا كان أبوه من تراب فهو من تراب، ومعنى النطفة في اللغة: الماء، يقال: في القربة نطفة من ماء {2}. ولا فعل للنطفة.قال الأزهري: (والعرب تقول للماء القليل والكثير: نطفة) {3}. وسمى الله عز وجل المني نطفة قال: ﴿أَلَمْ يَكُ نُطْفَةً مِنْ مَنِيٍّ يُمْنَى﴾ [القيامة: 37].وقوله تعالى: ﴿ثُمَّ سَوَّاكَ رَجُلًا﴾ قال الكلبي: (جعلك معتد الخلق والقامة، صحيح اليدين، والرجلين، والعينين) {4}. والتسوية: جعل الشيء على المقدار.وقال الزجاج: (أي: ثم أكملك) {5}. وهذا الجيد في تفسير سواك هاهنا، لأن العرب تقول للغلام إذا تم شبابه: قد استوى، ومنه قوله: ﴿وَلَمَّا بَلَغَ أَشُدَّهُ وَاسْتَوَى﴾ [القصص: 14] أي: تم شبابه واجتمع، فالتسوية هاهنا: واقع الاستواء بالمعنى الذي ذكرنا، يقال: سواه الله رجلاً فاستوى."
  18,38,"ثم أعلمه صاحبه أنه موحد لله فقال: ﴿لَكِنَّا هُوَ اللَّهُ رَبِّي﴾ وأصله: لكن أنا، كما هو في قراءة أُبي {1}، فخفف الهمزة التخفيف القياسي، وألقى حركتها على النون فصار لكننا، فاجتمع المثلان، فأدغموا المثل الأول في الثاني بعد أن أسكنوها، فصار في الدرج: لكنا هو الله، فلم تثبت ألف أنا في الوصل، كما لم تثبت الهاء في الوصل في نحو: إِرْمه، وأُغزه، و (كِتَابِيهْ) [الحاقة: 19]، و (حِسَابِيهْ) [الحاقة: 20]؛ لأنها إنما تلحق في الوقف لتبين {2} الحرف الموقوف عليه، فإذا وقف على ﴿لَكِنَّا﴾ أثبت الألف في الوقف، كما تثبت الهاء في الوصل، وإذا لم يقف حذفها، هذا وجه قراءة العامة {3}.ومثل هذه القراءة في الإدغام ما حكاه أبو زيد في قول من سمعه يقرأ: ﴿وَيُمْسِكُ السَّمَاءَ أَنْ تَقَعَ عَلَى الْأَرْضِ إِلَّا بِإِذْنِهِ﴾ [الحج: 65] (يريد: على الأرض، لكنه خفف الهمزة، وألقى حركتها على لام المعرفة فصار: (على الرض)، فاجتمع لامان مثلان فأدغم الأول في الثاني) {4}. وهذا كله في إجراء المنفصل مجرى المتصل في نحو: شدَّ، وحلَّ.وقرأ ابن عامر، ونافع في رواية المسيبي {5}: ﴿لَكِنَّا﴾ بإثبات الألف في الوصل والوقف {6}. وهذا على إجراء الوصل مجرى الوقف. وهو غير مختار في القراءة. فتكون كقراءة حمزة: (ومكر السيئ) بالجزم في الوصل {7}. غير أن أبا علي الفارسي ذكر وجهًا جيدًا لهذه القراءة، فجعل النون والألف في ﴿لَكِنَّا﴾ الضمير المتصل في نحو: فعلنا، ولم يجعله الضمير المنفصل وهو: أنا، كما ذكرنا في القراءة الأولى فقال: (أدغم النون من لكن لسكونها في النون من علامة الضمير، فيكون على هذا في الوصل والوقف ﴿لَكِنَّا﴾ بإثبات الألف لا غير، ألا ترى أن أحدًا لا يحذف الألف في: نحن فعلنا. وعاد الضمير الذي دخلت عليه لكن على المعنى، ولو عاد على اللفظ لكان: لكنا هو الله ربنا) {8}.وقال أبو إسحاق في توجيه هذه القراءة: (أثبت الألف في الوصل، كما كان يثبتها في الوقف، وهذا على لغة {9} من قال: أنا قمت، فأثبت الألف، قال الشاعر {10}: أنَا سيف العشيرة فاعرفوني ... حميد قد تذريت السناماثم قال: فأما: ﴿لَكِنَّا هُوَ اللَّهُ رَبِّي﴾ فهو الجيد بإثبات الألف؛ لأن الهمزة قد حذفت من أنا فصار إثبات الألف عوضًا من الهمزة) {11}. فاختار قراءة ابن عامر على قراءة عامة القراء {12}.ورد ذلك عليه أبو علي فيما استدرك عليه فقال: (لا أرى ما قاله كما قال ، وذلك أن هذه الألف تلحق للوقوف، ولا يسوغ أن تلحق في الوصل، ألا ترى أن الهمزة في: ذيل أمه قد حذفت حذفًا على غير الحذف الذي توجه قياس التخفيف، ولم يعوض منها، فأن لا يعوض منها في التخفيف القياسي أجدر؛ لأنها في هذا الوجه في تقدير الثبات، ولولا ذلك لم يحرك حرف اللين، كقولهم: جيل في تخفيف جيال، فلما كانت في تقدير الثبات لم يلزم منها بدل. ومما يؤكد أن العوض لا يجب أن (أنا) علامة ضمير، وعلامات الضمير لا ينكر كونها على حرف أو حرفين، بل ذلك الأغلب من أحوالها والأكثر، وأيضًا فلو جاز أن تثبت الألف التي حكمها أن تلحق في الوقف دون الوصل للحذف اللاحق للحرف، للزم أن تثبت الهاء التي تلحق في الوقف [أيضًا إذا لحق كلمة محذوفة منها نحو: عه، وشه، وارمه، واغزه، فتثبت] {13} في هذا الضرب ليكون عوضًا من المحذوف من الكلمة، فإذا لم يجز هذا أحدًا فالأول كذلك لا فصل) {14}.وقوله تعالى: ﴿هُوَ﴾ من ﴿هُوَ اللَّهُ رَبِّي﴾ ضمير علامة الحديث والقصة، كما أنه قوله: ﴿فَإِذَا هِيَ شَاخِصَةٌ أَبْصَارُ الَّذِينَ كَفَرُوا﴾ [الأنبياء: 97] وقوله: ﴿قُلْ هُوَ اللَّهُ أَحَدٌ﴾ [الإخلاص: 1] كذلك، ويسمى هذا الضمير على شريطة التفسير، وقد مضت هذه المسألة مشروحة عند قوله: ﴿فَأَسَرَّهَا يُوسُفُ﴾ [يوسف: 77]. وهذا الضمير يدخل على المبتدأ والخبر، فيصير المبتدأ والخبر في موضع خبره.وقوله تعالى: ﴿وَلَا أُشْرِكُ بِرَبِّي أَحَدًا﴾ قال أبو إسحاق: (دل خطابه على أن صاحب الجنتين مشرك عابد مع الله غيره) {11}. وهذا من أبي إسحاق قول بمفهوم الخطاب."
  18,39,"ثم أقبل على أخيه يلومه فقال: ﴿وَلَوْلَا إِذْ دَخَلْتَ جَنَّتَكَ﴾ بمعنى: هلا، وتأويله التوبيخ. ﴿قُلْتَ مَا شَاءَ اللَّهُ﴾ ذكر الفراء والزجاج في ﴿مَا﴾ وجهين:أحدهما: أنه في موضع رفع على معنى: الأمر ما شاء الله، أو: هو ما شاء الله. والمعنى: أن الأمر بمشيئة الله، وفي هذا رد على الأخ الكافر، حيث قال حين دخل جنته: ﴿مَا أَظُنُّ أَنْ تَبِيدَ هَذِهِ أَبَدًا﴾ فرد عليه الأخ المؤمن وقال: هلا قلت حين دخلتها: الأمر بمشيئة الله وما شاء الله كان.الوجه الثاني: أن ﴿مَا﴾ في موضع نصب بـ (شاء) على معنى الشرط والجزاء، ويكون الجواب مضمرًا على تقدير: ما شاء الله كان. ويكون التأويل: أي شيء شاء الله كان، فطرحت كان وأضمرته، وجاز طرح الجواب كما قال: ﴿فَإِنِ اسْتَطَعْتَ أَنْ تَبْتَغِيَ نَفَقًا﴾ [الأنعام: 35] الآية. ليس له جواب ، لأن معناه معروف {1}.وقوله تعالى: ﴿لَا قُوَّةَ إِلَّا بِاللَّهِ﴾ قال أبو إسحاق: (أي لا يقوى أحد على ما في يديه من ملك ونعمة إلا بالله، ولا يكون له إلا ما شاء الله) {2}. قال ابن عباس: (ثم رجع إلى نفسه) {3}. فقال: ﴿إِنْ تَرَنِ أَنَا أَقَلَّ مِنْكَ مَالًا وَوَلَدًا﴾. قال الفراء: (﴿أَنَا﴾ إذا نصبت ﴿أَقَلَّ﴾ عماد، وإذا رفعت ﴿أَقَلَّ﴾ فهي اسم، والقراءة بهما جائزة) {4}، هذا كلامه {5}.وقال أبو إسحاق بيانًا فقال: (﴿أَنَا﴾ يصلح لشيئين: إن شئت كانت توكيدًا للنون والياء، وإن شئت كانت فصلاً، كما تقول: كنت أنت القائم) {6}. و ﴿أَقَلَّ﴾ هو منصوب مفعول ثان لترن، ويجوز رفعه على أن يكون ﴿أَنَا﴾ ابتداء، و ﴿أَقَلَّ﴾ خبره، والجملة في موضع المفعول الثاني لترن) {7}."
  18,40,"قوله تعالى: ﴿فَعَسَى رَبِّي أَنْ يُؤْتِيَنِ﴾ قال ابن عباس: (يريد في الآخرة) {1}.قال الزجاج: (وجائز أن يكون أراد في الدنيا) {2}.﴿وَيُرْسِلَ عَلَيْهَا حُسْبَانًا مِنَ السَّمَاءِ﴾ قال ابن عباس في رواية عطاء: (نارًا من السماء) {3}. وهو قول الكلبي {4}.وقال قتادة والضحاك: (عذابًا) {5}. وقال ابن زيد: (قضاء من أمر الله يقضيه) {6}. هذا كلام المفسرين في تفسير الحسبان، [وذلك كله معنى، وليس بتفسير. وتفسيره ما ذكره أهل اللغة، قال الأخفش: (الحُسْبَان)] {7} المرامي، واحدتها حُسْبَانة) {8}.وقال ابن الأعرابي مما روى عنه ثعلب من رواية أبي عمرو: (أراد بالحسبان المرامي، قال: والحُسْبَانة: السحابة، والحُسْبَانة: الصاعقة) {9}.وقال النضر: (الحُسْبَانُ: سهام يرمي بها الرجل في جوف قصبة ينزع القوس ثم يرمي بعشرين منها دفعة، فلا تمر بشيء إلا عقرته من صاحب سلاح وغيره، فإذا نزع في القصبة خرجت الحُسْبَان كأنها غيثة مطر، فتفرقت في الناس، واحدها حُسْبَانَة، قال: والمرامي مثل المسالِّ دقيقة فيها شيء من طُول لا حُروف لها) {10}. ونحو هذا قال أبو عبيدة، وابن قتيبة، وكل أهل اللغة {11}. والمعنى في هذه الآية: أن يرسل عليها عذاب حسبان، وذلك الحسبان حساب ما كسبت يداك {12}. فجعل الآية من باب حذف المضاف، وجعل الحسبان بمعنى حساب ذنوبه، قال الأزهري: (الذي قاله الزجاج بعيد، والقول ما قاله الأخفش وابن الأعرابي والنضر. والمعنى والله أعلم: أن الله يرسل عليها مرامي من عذابه، إما بَرَدا، وإما حِجَارة أو غيرهما مما يشاء) {13}. وقول المفسرين يوافق قول أهل اللغة، لأن ما قالوه لا يخرج عن أن يكون مرامي.وقال أهل المعاني: (إنما سُمِّي المرامي حُسبَانا، لأنها تكثر كثرة الحسبان) {10}.وذكرنا الحسبان بمعنى الحساب في تفسير قوله تعالى: ﴿وَالشَّمْسَ وَالْقَمَرَ حُسْبَانًا﴾ [الأنعام: 96].وقوله تعالى: ﴿فَتُصْبِحَ صَعِيدًا زَلَقًا﴾ قال ابن عباس: (أرضا لا نبات فيها). وهو قول الكلبي وغيره {15}. والزَّلق في اللغة: المكان المزلقة، ومنه قول الشاعر {16}:فمن علا زلقا عن غرة زلقاوالذي في الآية ليس من هذا؛ لأنه ليس أنها تفسير مزلقة، ولكن معناه: أنها تفسير جرداء لا نبات بها، من قولهم: زَلَقَ رأسه، وأَزْلَقه، وزَلَقه إذا حلقه، والزَّلْق: الحَلْق، والزَّلق: المحلوق، كالنَّقْض والنَّقَض فشبه الصعيد الذي لا نبات فيه بالرأس المحلوق {17}. قال الفراء: (الزَّلَق التراب الذي لا نبات فيه) {18}. وقال قتادة: وفي قوله: ﴿صَعِيدًا زَلَقًا﴾ يقول: (قد حصد ما فيها فلم يُتْرَك فيها شيءٌ) {19}. وذهب ابن قتيبة إلى الإملاس فقال: (الزَّلق: الإملاس الذي تزل عليه الأقدام) {20}. وهذا الذي ذكره هو الأصل، من أن المراد: ذهاب النبات لا الإملاس. والمعنى: أن هذا العذاب يهلكها ويبطل غلتها."
  18,41,"قوله تعالى: ﴿أَوْ يُصْبِحَ مَاؤُهَا غَوْرًا﴾ قال ابن عباس: (يعني النهر الذي من خلالها) {1} {2}. ﴿غَوْرًا﴾ يقال: غَارَ الماء في الأرض، يَغُور غَورًا، أو غوورًا إذا ذهب، وغَارَت العين في الرأس فهي غائرة {3}.وفي قوله: ﴿أَوْ يُصْبِحَ مَاؤُهَا غَوْرًا﴾ وجهان أحدهما: ذا غور فحذف المضاف {4}. والثاني: وهو قول جميع أهل المعاني: أن الغور هاهنا بمعنى: الغائر أقيم المصدر مقام الصفة للمبالغة، كما يقال: وجه فلان نور ساطع، وعلى هذا يقال: ماء غَوْرٌ، ومياه غُورٌ، كما يقال: رجل عدل {5}. قال الشاعر {6}: وجاؤوني نوحًا قيامًايريد {7}: نساء نائحات قائمات، فوصفهن بالمصدر. وقال قتادة في قوله: ﴿غَوْرًا﴾ يقول: (ذاهبا قد غار في الأرض) {8}.وقوله تعالى: ﴿فَلَنْ تَسْتَطِيعَ لَهُ طَلَبًا﴾ أي: لا يبقى له أثر يطلبه به. وقال الكلبي: (لن تستطيع له حيلة) {9}."
  18,42,"قوله تعالى ﴿وَأُحِيطَ بِثَمَرِهِ﴾ معنى ""أحيط"" هاهنا: أهلك، أى أحاط العذاب بثمره، كما يحيط القوم بعدوهم فيهلكونهم عن آخرهم {1}. وذكرنا الكلام في هذا عند قوله: ﴿وَأَحَاطَتْ بِهِ خَطِيئَتُهُ﴾ [البقرة:81].وقوله تعالى: ﴿بِثَمَرِهِ﴾ قال ابن عباس: (بأشجار الثمر والنخل) {2}. وذكرنا الكلام واختلاف القراء في هذا عند قوله: ﴿وَكَانَ لَهُ ثَمَرٌ﴾ [الكهف: 34].وقوله تعالى: ﴿فَأَصْبَحَ يُقَلِّبُ كَفَّيْهِ﴾ قال ابن عباس: (يضرب يديه واحدة على الأخرى ندامة) {3}. وقال الكلبي: (يصفق بالواحدة على الأخرى ندما) {4}.وقال أبو عبيدة، والزجاج، والمفضل، وابن قتيبة: (يقال: فلان يقلب كفيه على ما فاته، وتقليب الكفين يفعله النادم كثيرًا، والعرب تقول للرجل إذا ندم على الشيء وجعل يفكر فيه: يقلب يديه وكفيه؛ لأن ذلك يكثر من فعله. فصار تقليب الكف عبارة عن الندم كعض اليد) {5}. قال الشاعر {6}:كمغبون يعض على يديه ... يُقلب كفَّه بعد السباعوقوله تعالى: ﴿عَلَى مَا أَنْفَقَ فِيهَا﴾ يقال: أنفقت في هذه الدار، وفي هذا الثوب كذا وكذا، وأنفقت عليها أيضًا، فيجوز أن يكون هاهنا بمعنى: على، كقوله: ﴿وَلَأُصَلِّبَنَّكُمْ فِي جُذُوعِ النَّخْلِ﴾ [طه: 71].وقوله تعالى: ﴿وَهِيَ خَاوِيَةٌ عَلَى عُرُوشِهَا﴾ ومضى الكلام في هذا مستقصى في سورة البقرة {7}. والعروش في هذه الآية تعم سقوف الأبنية، وما عُرِش للكروم. يريد: أنها ساقطة على سقوفها خالية من عريشها {8}. وقوله تعالى: ﴿وَيَقُولُ يَا لَيْتَنِي لَمْ أُشْرِكْ بِرَبِّي أَحَدًا﴾ تمنى منه حين لا ينفعه التمني. أخبر الله تعالى أنه سلبه ما أنعم عليه في الدنيا، فندم حين لم ينفعه الندامة، وتمنى أنه كان موحدًا غير مشرك."
  18,43,"قوله تعالى: ﴿وَلَمْ تَكُنْ لَهُ فِئَةٌ يَنْصُرُونَهُ مِنْ دُونِ اللَّهِ﴾ قال ابن عباس: (لم ينصره النفر الذين افتخر بهم في قوله: ﴿وَأَعَزُّ نَفَرًا﴾) {1}.قال الفراء والزجاج: (﴿يَنْصُرُونَهُ﴾ محمول على معنى الفئة، ولو حمل على لفظها لقيل: تنصره، كما قال: ﴿فِئَةٌ تُقَاتِلُ﴾ [آل عمران: 13]) {2}. ﴿وَمَا كَانَ مُنْتَصِرًا﴾ بأن يسترد بدل ما ذهب منه. قال الزجاج: (وما كان هو أيضًا قادر على نصرة نفسه) {3}.وقال قتادة: (وما كان ممتنعًا) {4}. وقد تمت هاهنا قصة الأخوين، وضربت مثلاً للمؤمن مع الكافر، فالكافر تغره دنياه ويتبجح بها ويظن أنها تبقى له، والمؤمن يصبر على نوائبها احتسابًا من الله تعالى جميل الأجر وجزيل الذخر، ولا يركن إليها لما يعلم من فنائها. وقبل ذكر قصة الأخوين ذكر الله تعالى ما أعد للكافرين في قوله: ﴿إِنَّا أَعْتَدْنَا لِلظَّالِمِينَ نَارًا﴾ [الكهف: 29] إلى آخر الآية، وما أعد للمؤمنين في قوله: ﴿إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ﴾ [الكهف: 30 - 31] الآيتان."
  18,44,"ثم عاد الكلام إلى ما قبل القصة فقال: ﴿هُنَالِكَ﴾ قال الكلبي: (يقول عند ذلك، وهو يوم القيامة) {1}.وذكرنا عند {2} قوله: ﴿هُنَالِكَ دَعَا زَكَرِيَّا رَبَّهُ﴾ [آل عمران: 38] أنه يجوز أن يشار بهنالك إلى المكان، وإلى ما مضى من الزمان.وقوله تعالى: ﴿الْوَلَايَةُ﴾ أكثر القراء على فتح الواو {3}، والولاية: نقيض العداوة، ومعناها التولي، وهو مصدر الوَلِيِّ {4}. وروي عن أبي عمرو، والأصمعي أنهما قالا: (الولاية بالكسر هاهنا لحن {5}، والكسر في فعالة يجيء فيما كان صنعة نحو: الخياطة والصناعة {6}، أو معنى متقلدًا كالكتابة والإمارة والخلافة، وليس هنا معنى تولي أمر، إنما {7} الولاية من الدين) {8}. وكذلك التي في الأنفال: ﴿مَا لَكُمْ مِنْ وَلَايَتِهِمْ مِنْ شَيْءٍ﴾ [الأنفال: 72]. وأما ولاية الأمور فهو بالكسر، كولاية السلطان، ومن أهل اللغة من يقول: يجوز الفتح في هذه، والكسر في تلك. كما قالوا: الوِكالة والوَكالة، والوصاية والوصاية بمعنى واحد {9}.وقوله تعالى: ﴿لِلَّهِ الْحَقِّ﴾ من كسر القاف جعله من وصف الله سبحانه، ووصفه بالحق وهو مصدر كوصفه بالعدل وبالسلام {10}. والمعنى: أنه ذو الحق وذو السلام. وكذلك الإله معناه ذو العبادة، ويدل على صحة هذه القراءة: ﴿وَيَعْلَمُونَ أَنَّ اللَّهَ هُوَ الْحَقُّ الْمُبِينُ﴾ [النور: 25]، وقوله: ﴿ثُمَّ رُدُّوا إِلَى اللَّهِ مَوْلَاهُمُ الْحَقِّ﴾ [الأنعام: 62]، ويصدقه قراءة عبد الله: (هنالك الولاية لله وهو الحق) {11}. وقرأ أبو عمرو والكسائي: ﴿للهِ الحقُّ﴾ بضم القاف {12}. جعلا الحق من صفة الولاية، وحجتهما قراءة أبي: (هنالك الولاية الحقّ لله) {13}. ومعنى وصف الولاية بالحق: أنه لا يشوبها غيره، ولا يخاف فيها ما يخاف في سائر الولايات من غير الحق.وأما معنى الآية فقال أبو إسحاق: (في تلك الحال بيانُ الولاية لله أي: عند ذلك يتبين وليُّ الله بتولي الله إياه) {14}. قوله: (في تلك الحال) يعني: في حال مجازاة الله الكافر والمؤمن الولاية لله، على معنى: هنالك يتبين ذلك على ما ذكر. وقال ابن قتيبة: (يريد يومئذ يتولون الله ويؤمنون به، ويتبرؤون مما كانوا يعبدون) {15}. وهذا أظهر من قول الزجاج. وذهب غيرهما في معنى الولاية في هذه الآية: إلى تولي الأمر، لا إلى معنى الموالاة، فقال: (معنى الآية: في ذلك الموطن الذي هو موطن الجزاء لا يتمكن أحد من نصرة أحد، بل الله تعالى يتولى ذلك، فينصر المؤمنين ويخذل الكافرين، لا يملك ذلك أحد من العباد، فالولاية يومئذ تخلص له كما قال: ﴿مَالِكِ يَوْمِ الدِّينِ﴾ [الفاتحة: 4] {16}.وقوله تعالى: ﴿هُوَ خَيْرٌ ثَوَابًا﴾ يقول: هو أفضل ثوابًا يقول: هو أفضل ثوابًا ممن يرجى ثوابه. قال أهل المعاني: (قوله: ﴿هُوَ خَيْرٌ ثَوَابًا﴾ مع أنه لا يثبت إلا هو، على تقدير: لو كان يثبت غيره لكان هو خير ثوابًا) {17}.وقيل: (هذا على ادعاء الجهال والكفار أنه قد يثبت غير الله) {18}. ﴿وَخَيْرٌ عُقْبًا﴾ وعُقُبَا {19}. وهما لغتان في العاقبة يقال: عُقْب، وعُقُب، وعَاقِبَة وعُقْبى، والعقب لا يكون لله تعالى كما يكون الثواب له. ولا يجوز أن يضاف العاقبة إلى الله تعالى أو يوصف بالعاقبة، وإنما المعنى عاقبة طاعته خير من عاقبة طاعة غيره، فهو خير عقب طاعة وإثابة ونصرة وما يكون من هذا المعنى، ثم حذف المضاف إليه {20}.﴿وَاضْرِبْ لَهُمْ مَثَلَ الْحَيَاةِ الدُّنْيَا كَمَاءٍ أَنْزَلْنَاهُ مِنَ السَّمَاءِ فَاخْتَلَطَ بِهِ نَبَاتُ الْأَرْضِ فَأَصْبَحَ هَشِيمًا تَذْرُوهُ الرِّيَاحُ وَكَانَ اللَّهُ عَلَى كُلِّ شَيْءٍ مُقْتَدِرًا﴾ [الكهف: 45]."
  18,45,"قوله تعالى: ﴿وَاضْرِبْ لَهُمْ مَثَلَ الْحَيَاةِ الدُّنْيَا﴾ قال ابن عباس: (يريد لقومك) {1}. وقوله تعالى: ﴿كَمَاءٍ﴾ الكاف في محل الرفع لخبر ابتداء محذوف، أي: هو كماء يعني: مثل الحياة الدنيا {2}.﴿كَمَاءٍ أَنْزَلْنَاهُ مِنَ السَّمَاءِ﴾ يعني: المطر {3}. ﴿فَاخْتَلَطَ﴾ فالتف واجتمع به، بذلك الماء أي: بسببه؛ لأن النبات إنما يختلط ويكثر بالماء {4}.وقال أبو إسحاق: (تأويله أنه نجع في النبات حتى خالطه، فأخذ النبات زخرفه) {5}. يريد: أن النبات شرب من ذلك الماء فبدأ فيه الري والنضارة، فعلى هذا الوجه قد اختلط النبات بالماء حيث يروى به.وقوله تعالى: ﴿فَأَصْبَحَ﴾ أي: النبات ﴿هَشِيمًا﴾ معنى الهَشْم في اللغة: الكسر، والهَاشِم: الذي يَهْشِم الخبز ويكسره في الثريد، وبه سمي هَاشِم، والهَشِيم: ما تَكَسَّر وتَهَشَّم وتَحَطَّم من يَبَسِ النبات {6}.وقال المفسرون في الهشيم: (أنه الكسير المتفتت) {7}.وقوله تعالى: ﴿تَذْرُوهُ الرِّيَاحُ﴾ الذَّرُّ حمل الريح الشيء ثم تثيره، يقال: ذَرَتْه الريح، تَذْرُوه، وتَذْرِيه، وبه قرأ عبد الله: (تَذْرِيه الرياح) {8}. وتَذْرُوة، وتَذْرِية وتُذْرِية لغات أربع {9}.قال المفسرون: (تَرْفعه وتُفْرقه وتنسفه) {10}. وهذه الآية مختصرة من قوله في سورة يونس: ﴿إِنَّمَا مَثَلُ الْحَيَاةِ الدُّنْيَا كَمَاءٍ أَنْزَلْنَاهُ مِنَ السَّمَاءِ﴾ [يونس: 24] الآية. وقد شرحناها هناك.قال أبو إسحاق: (أعلم الله أن الحياة الدنيا زائلة، وأن مثلها هذا المثل) {5}.وقوله تعالى: ﴿وَكَانَ اللَّهُ عَلَى كُلِّ شَيْءٍ مُقْتَدِرً﴾ أي: على كل شيء من الإنشاء والإفناء قادرًا، أنشأ النبات ولم يكن، ثم أفناه. قال الحسن: (كان الله على كل شيء مقتدرًا أن يكونه قبل كونه) {5}. قال الزجاج وهو مذهب النحويين في هذا: (أن معناه كان مقتدرًا لم يزل) {5}. أي: ما شاهدتم من قدرته ليس بحادث عنده. وهذا مما سبق بيانه قديمًا.﴿الْمَالُ وَالْبَنُونَ زِينَةُ الْحَيَاةِ الدُّنْيَا وَالْبَاقِيَاتُ الصَّالِحَاتُ خَيْرٌ عِنْدَ رَبِّكَ ثَوَابًا وَخَيْرٌ أَمَلًا﴾ [الكهف: 46]."
  18,46,"قوله تعالى: ﴿الْمَالُ وَالْبَنُونَ زِينَةُ الْحَيَاةِ الدُّنْيَا﴾ قال المفسرون: (هذا رد على عيينة بن حصين، والأقرع والرؤساء الذين كانوا يفتخرون بالمال والغنى والأبناء. أخبر الله تعالى أن ذلك مما يُتَزيَّن به في الحياة الدنيا ويُتَجمل به، لا مما ينفع في الآخرة) {1}. ﴿وَالْبَاقِيَاتُ الصَّالِحَاتُ﴾ يعني: ما يأتي به سلمان، وصهيب، وفقراء المسلمين {2}.واختلفوا في المراد بالباقيات الصالحات، فقال ابن عباس في رواية سعيد بن جبير: (هي الصلوات الخمس) {3}. وهو قول مسروق، وإبراهيم، ومحمد بن كعب {4}. وقال في رواية عطاء: (يريد سبحان الله، والحمد لله، ولا إله إلا الله، والله أكبر) {5}. وهذا قول مجاهد، وعكرمة، والضحاك {6}. وروي ذلك مرفوعًا: (أن النبي -ﷺ- سمَّي هذه الأذكار الباقيات الصالحات فقال: ""وهي الباقيات الصالحات"") {7}. روى ذلك أنس، وأبو هريرة، والخدري -رضي الله عنهم-. وزاد عثمان، وابن عمر، وسعيد بن المسيب: (لا حول ولا قوة إلا بالله، مع هذه الأذكار في تفسير الباقيات الصالحات) {8}.وقال فى رواية العوفي: (هي الكلام الطيب) {9}. وهذا أيضًا راجع إلى ذكر الله؛ لأنه الكلام الطيب.وقال في رواية الوالبي: (هي الأعمال الصالحات وجميع الحسنات) {10}.وهو قول قتادة قال: (هي كل ما أريد به وجه الله) {11}. واختاره الزجاج فقال: (هي كل عمل صالح يبقى ثوابه) {12} {13}.قوله تعالى: ﴿خَيْرٌ عِنْدَ رَبِّكَ ثَوَابًا وَخَيْرٌ أَمَلًا﴾ قال ابن عباس: (يريد أفضل ثوابًا وأفضل أملاً من المال والبنين) {14}. وهذا على عادة خطاب العرب تقول في الشيئين: هذا خير، وإن لم يكن في الثاني شيء يُخيَّر به. كقوله تعالى: ﴿أَصْحَابُ الْجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًّا﴾ [الفرقان: 24]، ومعلوم أنه، لا خير في مستقر أهل النار، وإلى هذا المعنى أشار الفراء فقال في قوله: ﴿وَخَيْرٌ أَمَلًا﴾ الأمل للعمل الصالح خير من الأمل للعمل السيئ) {15}.وقال ابن قتيبة: (﴿وَخَيْرٌ أَمَلًا﴾ مما يؤملون) {16}. أي: هو خير أن يؤمل."
  18,47,"قوله تعالى: ﴿وَيَوْمَ﴾ قال الزجاج: (هو منصوب على معنى واذكر، ثم قال: ويجوز أن يكون نصبه على معنى: خير يوم تسير الجبال، أي: خير في القيامة) {1}. وهذا الوجه يحسن لو لم يكن في ﴿وَيَوْمَ﴾ الواو {2}.وقوله تعالى: ﴿نُسَيِّرُ الْجِبَالَ﴾ معنى التسيير: جعل الشيء يسير، وقال الكلبي: (تُسير الجبال عن وجه الأرض، كما تُسير السحاب في الدنيا، ثم تكسر فتعود في الأرض) {3}. وهذا معنى قوله: ﴿وَبُسَّتِ الْجِبَالُ بَسًّا (5) فَكَانَتْ هَبَاءً مُنْبَثًّا (6)﴾ [الواقعة: 5، 6] وقرئ: ﴿نُسَيِّرُ الْجِبَالَ﴾ علي بناء الفعل للفاعل {4}. وهذه القراءة أشبه بما بعده من قوله: ﴿وَحَشَرْنَاهُمْ فَلَمْ نُغَادِرْ مِنْهُمْ﴾، وحجة القراءة الأولى قوله: ﴿وَسُيِّرَتِ الْجِبَالُ﴾ [النبأ: 20]، وقوله: ﴿وَإِذَا الْجِبَالُ سُيِّرَتْ﴾ [التكوير: 3]، فبني الفعل للمفعول به.وقوله تعالى: ﴿وَتَرَى الْأَرْضَ بَارِزَةً﴾ قال ابن عباس: (يريد لا جبل ولا بناء ولا شجر ولا ماء) {5}. وقال مجاهد: (لا خَمَر {6} فيها) {7}. وقال الكلبي: (ظاهرة ليس عليها شيء) {8}.وقال أهل المعاني: (لا شيء يسترها، يحشر الناس فيكونون كلهم في صعيد واحد، يرى بعضهم بعضًا) {9}. وهذا قول قتادة في البارزة: (أنها الظاهرة التي لا بناء عليها ،ولا شجر) {10}. وقال عطاء: (قد برز الذين كانوا في بطنها فصاروا على ظهرها) {11}. وحكى الكلبي هذا القول أيضًا فقال: (ويقال برز كل شيء فيكون على ظهرها) {12}. وذكره الفراء فقال: (﴿وَتَرَى الْأَرْضَ بَارِزَةً﴾ يقول: أبرزنا أهلها من بطنها) {13}.والقول الأول هو الأولى {14}. وهذا لا يصح إلا على بعد.واستكره بأن يجعل برز بمعنى: أبرز، فقد قال ابن هانئ {15} في قول لبيد {16}: النَّاطق المبروز والمختومقال: (يقال: بَرَزْته بَرَز، بمعنى: أبرزته) {17}.ويكون معنى الآية على هذا: وترى الأرض مبرزة ما فيها، كما قال: ﴿وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ﴾ [الانشقاق: 4]. وهذه لغة شاذة لا يفسر بها كتاب الله.وقوله تعالى: ﴿وَحَشَرْنَاهُمْ﴾ أي: المؤمنين والكافرين، وقد تقدم ذكرهم في هذه السورة. ﴿فَلَمْ نُغَادِرْ﴾ أي: لم نترك ولم نخلف، يقال: غَادَرَه وأغدره إذا تركه، ومنه الغدر، لأنه ترك الوفاء، والغدير: الماء الذي غادره السيل والمطر {18}."
  18,48,"وقوله تعالى: ﴿وَعُرِضُوا عَلَى رَبِّكَ﴾ يعني المحشورين. ﴿صَفًّا﴾ الصف مصدر وصف به، ووضع موضع الحال، فهو بمعنى مصفوفين: كل زمرة وأمة صف {1}.وقوله تعالى: ﴿لَقَدْ جِئْتُمُونَا﴾ القول هاهنا مضمر، أي: يقال لهم: لقد جئتمونا. أو فيقول لهم الله: ﴿لَقَدْ جِئْتُمُونَا كَمَا خَلَقْنَاكُمْ أَوَّلَ مَرَّةٍ﴾ قال ابن عباس: (يريد حفاة عراة غرلاً) {2}وقيل: (يعني فرادى) {3}. كما قال في سورة الأنعام: ﴿وَلَقَدْ جِئْتُمُونَا فُرَادَى كَمَا خَلَقْنَاكُمْ أَوَّلَ مَرَّةٍ﴾ الآية. وقال أبو إسحاق: (أي بعثناكم كما خلقناكم) {4}. لأن قوله: ﴿لَقَدْ جِئْتُمُونَا﴾ يعني: بعثناكم.وقوله تعالى: ﴿بَلْ زَعَمْتُمْ﴾ خطاب لمنكري البعث خاص، ومعناه: بل زعمتم في الدنيا أن لن تُبعثوا، لأن الله وعدهم البعث فلم يصدقوا، والمعنى: ﴿أَلَّنْ نَجْعَلَ لَكُمْ مَوْعِدًا﴾ للبعث والجزاء، و ﴿بَلْ﴾ هاهنا إيذان بأن القصة الأولى قد تمت وبدأ في كلام آخر، وذلك أن الآية عامة في المؤمن والكافر إلى قوله: ﴿بَلْ زَعَمْتُمْ﴾ فلما أخذ في كلام خاص لأحد الفريقين أدخل ﴿بَلْ﴾ ليؤذن بتحقيق ما سبق، وتوكيد ما يأتي بعده، كقوله تعالى: ﴿بَلِ ادَّارَكَ عِلْمُهُمْ فِي الْآخِرَةِ بَلْ هُمْ فِي شَكٍّ مِنْهَا بَلْ هُمْ مِنْهَا عَمُونَ﴾ [النمل: 66]، وقد يجيء ﴿بَلْ﴾ في الكلام لترك ما سبق من غير إبطال له {5}، كقول لبيد {6}: بل ما تذكر من نوار وقد نأت ... وتقطعت أسبابها ورمامهالم يرد ببل هاهنا إبطال ما سبق، وإنما أراد الإذان بترك الكلام الأول، كما تقول: دع ذا، واترك ذا، عند تمام ما يتكلم به والانتقال إلى غيره، كما قال امرئ القيس {7}:فدع ذا وسلِّ الهمَّ عنك بجسرةٍ"
  18,49,"قوله تعالى: ﴿وَوُضِعَ الْكِتَابُ﴾ قال المفسرون: (يعني كتب أعمال الخلق) {1}. و ﴿الْكِتَابُ﴾ اسم الجنس، فيعمُّ عند الإطلاق. قال أبو إسحاق: (معناه ووضع كتاب كل امرئ بيمينه أو شماله) {2}.وقوله تعالى: ﴿فَتَرَى الْمُجْرِمِينَ﴾ قال ابن عباس: (يريد المشركين. ﴿مُشْفِقِينَ﴾ قال: خائفين) {3}. ومعنى الإشفاق في اللغة: الخوف والحذر من وقوع المكروه، ويقال: شَفَقَ بمعنى أَشْفَقَ شفقةً، وإشْفاقًا فهو مشفق وشَفِق، وأصل الحرف من الرقة {4}. وسنذكر ذلك مستقصى عند قوله: {فَلَا أُقْسِمُ بِالشَّفَقِ} [الانشقاق: 16] إن شاء الله.وقوله تعالى: ﴿مِمَّا فِيهِ﴾ أي: من الأعمال السيئة.﴿وَيَقُولُونَ يَا وَيْلَتَنَا﴾ لوقوعهم في الهلكة يدعون بالويل على أنفسم: ﴿مَالِ هَذَا الْكِتَابِ لَا يُغَادِرُ صَغِيرَةً﴾ أي: لا تاركًا صغيرة، فقوله: ﴿لَا يُغَادِرُ﴾ في موضع الحال، قال ابن عباس في رواية عكرمة: (الصغيرة التبسم، والكبيرة الضحك) {5}.ونحو هذا روى عنه الذبال بن عمرو الأوزاعي فيما كان يعظ به المنصور {6} {7}. ونحو هذا روي عن الحسن عن ابن عباس، وهو قول ابن أبي ليلى {8}، والكلبي {9}. وقال في رواية عطاء: ﴿لَا يُغَادِرُ صَغِيرَةً﴾ يريد: من أعمالنا ﴿وَلَا كَبِيرَةً﴾ يريد: الشرك) {10}. وقال سعيد بن جبير: (الصغيرة: اللمم، والكبيرة: الزنا) {11}.وقوله تعالى: ﴿إِلَّا أَحْصَاهَا﴾ أي: عدَّها، وأثبتها، وكتبها، وحفظها، كل هذه ألفاظ المفسرين {12}. والمعنى: إني أحصيت وأثبت في الكتاب. فأضيف الإحصاء إلى الكتاب توسعًا.قال قتادة في هذا: (اشتكى القوم -كما تسمعون- الإحصاء، فإياكم والمحقرات من الذنوب، فإنها تجتمع على صاحبها حتى تهلكه) {13}.وقوله تعالى: ﴿وَوَجَدُوا مَا عَمِلُوا حَاضِرًا﴾ أي: في الكتاب مكتوبًا مثبتًا ذكره. ﴿وَلَا يَظْلِمُ رَبُّكَ أَحَدًا﴾ قال الزجاج: (أي: يعاقبهم، فيضع العقوبة موضعها في مجازاة الذنوب، قال: وأجمع أهل اللغة: أن الظلم وضع الشيء في غير موضعه) {2}.وتأويل هذا: أنه لا يعاقب أحدًا بغير جرم، وهو معنى قول الضحاك: (لا نأخذ أحدًا بجرم لم يعمله) {15}."
  18,50,"قوله تعالى: ﴿وَإِذْ قُلْنَا لِلْمَلَائِكَةِ اسْجُدُوا لِآدَمَ﴾ قال المفسرون: أمر الله تعالى نبيه -ﷺ- أن يذكر هؤلاء المتكبرين عن مجالسة الفقراء قصة إبليس، وما أورثه الكبر، فقال: ﴿وَإِذْ قُلْنَا لِلْمَلَائِكَةِ﴾ أي: واذكر يا محمد ﴿وَإِذْ قُلْنَا لِلْمَلَائِكَةِ اسْجُدُوا لِآدَمَ فَسَجَدُوا إِلَّا إِبْلِيسَ كَانَ مِنَ الْجِنِّ﴾ قال ابن عباس في رواية عطاء: (يريد أن ملائكة السماء الدنيا يقال لهم: الجن) {1}. مقل قوله: ﴿وَجَعَلُوا بَيْنَهُ وَبَيْنَ الْجِنَّةِ نَسَبًا﴾ [الصافات: 158] يعني حين قالوا: الملائكة بنات الله. وكان ابن عباس يقول: (لو لم يكن من الملائكة لم يؤمر بالسجود) {2}.وروى سعيد عن قتادة قال: (كان من قبيل من الملائكة يقال لهم: الجن) {3}. وقال شهر بن حوشب: (كان إبليس من الجن الذين ظفر بهم الملائكة) {4}.وقال الحسن: (ما كان إبليس من الملائكة طرفة عين، وإنه لأصل الجن، كما أن آدم أصل الإنس) {5}.وقد ذكرنا الخلاف في هذا في سورة البقرة عند ذكر قصة آدم بالشرح {6} {7}.وقوله تعالى: ﴿فَفَسَقَ عَنْ أَمْرِ رَبِّهِ﴾ ذكر أهل التأويل في هذا ثلاثة أوجه: أحدها وهو الأكثر: أن معناه خرج عن أمر ربه إلى معصيته في ترك السجود. وهو قول الفراء، وأبي عبيدة.قال الفراء: (أي خرج عن طاعة ربه، والعرب تقول: فسقت الرطبةمن قشرها لخروجها منه، وكأن الفأرة إنما سميت فويسقة لخروجها {8} من جحرها على الناس) {9}.وقال أبو عبيدة: (﴿فَفَسَقَ عَنْ أَمْرِ رَبِّهِ﴾ أي: جار ومال عن طاعته) {10}، وأنشد لرؤية {11}: فواسقًا عن قصده جوائراالوجه الثاني: ما ذكره الأخفش قال: (معنى ﴿فَفَسَقَ عَنْ أَمْرِ رَبِّهِ﴾ نحو قول العرب: اتخم عن الطعام، أي: عن أكله، ولما رد هذا الأمر فسق) {12}. ونحو هذا حكى الزجاج عن قطرب {13}. قال أبو العباس: (ولا حاجة به إلى هذا، الفسوق معناه: الخروج، ﴿فَفَسَقَ عَنْ أَمْرِ رَبِّهِ﴾ أي: خرج) {14}.الوجه الثالث: ما ذهب إليه سيبويه والخليل: (أن معنى ﴿فَفَسَقَ عَنْ أَمْرِ رَبِّهِ﴾ أتاه الفسق لما أُمِرَ فعصى، وكان سبب فسقه أمر ربه، كما تقول: أطعمه عن جوع وكساه عن عُرِي، المعنى: كان سبب فسقه الأمر بالسجود، كما كان سبب الإطعام الجوع، وسبب الكسوة العري) {15}.قال أبو عبيد: (وهذه الكلمة -يعني الفسوق- لم أسمعها في شيء من أشعار الجاهلية ولا أحاديثها، وإنما تكلمت بها العرب بعد نزول {16} القرآن) {17}. قال أهل المعاني المبرد وغيره: (هي كلمة فصيحة على ألسنة العرب) {14}. وأوكد الأمور ما جاء في القرآن، ومعناه: الخروج، كما قال: فواسقا ... البيت {19}.وقوله تعالى: ﴿أَفَتَتَّخِذُونَهُ وَذُرِّيَّتَهُ أَوْلِيَاءَ مِنْ دُونِي﴾ قال قتادة: (وهم أولاده، وهم يتوالدون كما يتوالد بنوا آدم) {20}. ﴿أَوْلِيَاءَ مِنْ دُونِي﴾ قال الكلبي: (ليس تصلون له ولا تصومون، ولكن من أطاع شيئًا فقد عبده) {21}. واختلف في كيفية ولادة إبليس وحصول ذريته، فقال مجاهد فيما روى عنه ابن جريج: (أن إبليس أدخل ذكره في دبره، فباض خمس بيضات فهم ذريته) {22}.وقال الشعبي في هذه الآية: (لا تكون ذريته إلا من زوجة) {23}.وروى عبد الله بن المغيرة {24}: (أن أبا هريرة قال: اسم امرأة إبليس ردة) {25}. وروى ليث عن مجاهد قال: (ذريته الشياطين) {26} {27}.وقوله تعالى: ﴿وَهُمْ لَكُمْ عَدُوٌّ﴾ أعلم الله تعالى أنه من العداوة والحسد لبني آدم على مثل الذي كان لأبيهم. قال ابن عباس: (يريد كما أخرج أبويكم من الجنة) {28}.وقوله تعالى: ﴿بِئْسَ لِلظَّالِمِينَ بَدَلًا﴾ قال ابن عباس: (يريد حيث استبدلوا بالرحمن عبادة الشيطان) {29}.وقال الحسن: (بئس ما استبدلوا بعبادة ربهم أن أطاعوا إبليس، فبئس ذلك لهم بدلاً) {30}.وقال الزجاج: (بئس ما استبدل به الظالمون من رب العزة إبليس) {13}. والمعنى: بئس هو بدلاً أي: إبليس.﴿مَا أَشْهَدْتُهُمْ خَلْقَ السَّمَاوَاتِ وَالْأَرْضِ وَلَا خَلْقَ أَنْفُسِهِمْ وَمَا كُنْتُ مُتَّخِذَ الْمُضِلِّينَ عَضُدًا﴾. [الكهف: 51]"
  18,51,"وقوله تعالى: ﴿مَا أَشْهَدْتُهُمْ خَلْقَ السَّمَاوَاتِ وَالْأَرْضِ﴾ أي: ما أحضرتهم يعني إبليس وذريته {1}.قال صاحب النظم: (أومأ بقوله: ﴿مَا أَشْهَدْتُهُمْ﴾ إلى أنه لم يشاورهم في خلق السموات والأرض ولا في خلق أنفسهم) {2}. أي: أنه خلقها وخلقهم على ما أراد وقدر من غير مشاورة لهم، وإنما ضمن الإشهاد الإيماء إلى المشاورة؛ لأن الرجل إذا أراد مشاورة إنسان أشهده نفسه، أو شهده بنفسه، يدل على صحة هذا المعنى قوله: ﴿وَمَا كُنْتُ مُتَّخِذَ الْمُضِلِّينَ عَضُدًا﴾ أي: الشياطين الذين يضلون الناس.وقال أهل المعاني: هذه الآية تأكيد في زجرهم عن اتخاذ إبليس وذريته أولياء. يقول: ليس عندهم علم ما تحتاجون إليه فتقبلوا أنتم على إتباعهم، فإني لم أشهدهم خلق السموات والأرض. وقيل: (إن هذه الآية إخبار عن كمال قدرة الله تعالى، واستغنائه عن الأنصار والأعوان) {3}.قوله تعالى: ﴿وَمَا كُنْتُ مُتَّخِذَ الْمُضِلِّينَ عَضُدًا﴾ قال قتادة: (أعوانا) {4}. ولفظ العَضُد يستعمل كثيرًا في معنى العون، وذلك أن العضْد قوام اليد، منه الاعتضاد وهو التَّقوِّى، واعتضدت بفلان معناه: استعنت به، ومن هذا قوله تعالى: ﴿سَنَشُدُّ عَضُدَكَ بِأَخِيكَ﴾ [القصص: 53] أي: سنعينك ونقويك، وكل معين فهو عضد، وعاضدني فلان أي: عاونني، وفي العضد لغات: عَضُد، وعَضْد، وعُضُد، وعُضْد {5}. والناس على أن معنى هذا: استغنى الله تعالى بقدرته عن الأنصار.وقال ابن عباس في رواية عطاء: (يريد: لم يعضدوا لي وليًا، ولم ينصروا لي عبدًا، ولم يقوموا لأحد من أوليائي بحق) {6}. ومعنى هذا: أنهم لو نصروا أولياء الله لكان كأنهم نصروا الله، ولما لم يفعلوا ذلك أخبر الله تعالى أنه لم يتخذهم أعوانًا. والقول هو الأول، وإنما قال: عَضُد على واحد لوفاق الفواصل."
  18,52,"قوله تعالى: ﴿وَيَوْمَ يَقُولُ﴾ أي: الله تعالى، وقراءة العامة: بالياء لقوله: ﴿شُرَكَائِيَ﴾ وقرأ حمزة: بالنون {1}، حملاً على ما تقدم في المعنى من قوله: ﴿وَمَا كُنْتُ﴾ [الكهف: 51] فكما أن كنت للمتكلم كذلك: نقول، والجمع والإفراد في ذلك بمعنى.قال ابن عباس: (يريد يوم القيامة) {2}. قال المفسرون: (يقول الله تعالى يوم القيامة: ادعوا الذين أشركتم بي ليمنعوكم من عذابي) {3}. وهو قوله: ﴿نَادُوا شُرَكَائِيَ الَّذِينَ زَعَمْتُمْ﴾ قال ابن عباس: (يريد في الدنيا) {4} ﴿فَدَعَوْهُمْ فَلَمْ يَسْتَجِيبُوا لَهُمْ وَجَعَلْنَا بَيْنَهُمْ مَوْبِقًا﴾ قال أنس: (هو واد في جهنم من قيح ودم) {5}. وهو قول مجاهد، وعبد الله بن عمر {6}.وقال نوف البكالي: (هو واد بين أهل الضلال وبين أهل الإيمان) {7}. وقال البكالي: (هو واد يفرق به {8} بين أهل لا إله إلا الله ومن سواهم) {9}. وهذا القول يوافق قول ابن عباس في رواية عطاء فإنه قال: (يريد حِجازًا وحاجزْا) {10}. ونحو هذا قال ابن الأعرابي في الموبق قال: (وكل حاجِز بين شيئين فهو مُوبِق) {11}. وعلى هذا القول الكناية في قوله: ﴿بَيْنَهُمْ﴾ يعود إلى الفريقين من المؤمنين والكافرين، وليس يعرف للموبق بمعنى الحاجز اشتقاق. وقال ابن عباس في رواية الوالبي: (مهلكا) {12}. وهو قول قتادة، والضحاك، وابن زيد، والسدي {13}. وجميع أهل المعاني {14}.قال الفراء: (يقول: جعلنا تواصلهم في الدنيا موبقا، أي: مهلكا لهم في الآخرة) {15}. وعلى هذا ﴿بَيْنَهُمْ﴾ ينتصب انتصاب المفعول به؛ لأنه جعل البين بمعنى التواصل، فلا ينتصب انتصاب، والكناية تعود على المشركين فقط {16}.وقال أبو إسحاق: (أي جعلنا بينهم من العذاب ما يوبقهم أي: يهلكهم) {17}. والبين على هذا ظرف، والموبق على القولين في مصدر، كأنه قيل: جعلنا تواصلهم في الدنيا هلاكًا لهم في الآخرة. والتأويل: سبب هلاك. هذا تقدير قول الفراء. وعلى قول أبي إسحاق كأنه قيل: جعلنا بينهم هلاكًا. يعني: عذابًا يهلكهم. ونص الضحاك على لفظ الهلاك فقال في قوله: ﴿مَوْبِقًا﴾: (هلاكًا) {18}.قال الفراء في ""المصادر"": (يقال: وَبِقَ، يَوبقُ، وَبَقاً، فهو وَبِق، قال: وبنو عامر {19} يقولون: يابِق، وتميم {20} تقول: يَبِق والمصدر واحد) {21}. وحكى الكسائي: (وَبَقَ، يَبِقُ، وُبُوقًا، فهو وابِق، قال: ولم أسمعها {22}.وذكر الزجاج هذه اللغات كلها {17}.وذُكِرَ في تفسير الموبق قولان آخران لا يدرى لهما أصل.أحدهما: ما روي عن الحسن أنه قال: (جعلنا بينهم عداوة يوم القيامة) {24}. فقال بعض أهل المعاني في هذا: يعني عداوة مهلكة. وهذا بعيد.والقول الآخر: ما قاله أبو عبيدة قال في تفسير الموبق: (أنه الموعد، واحتج بقول الشاعر {25}: وجاد شرورى والستار فلم يدع ... تعارًا له والواديين بموبققال: معناه بموعد) {26}. ولم يذكر أحد من أهل اللغة وَبَقَ بمعنى: وعد، ثم وإن صح، فأي معنى لقوله: وجعلنا بينهم موعدًا. وهذا القول فاسد لفظًا ومعنى. وقد قال الأخفش: (موبق مثل: موعد) {27}. ولعله رأى هذا فظن أنه يقول: هو مثله في التفسير. وذهب عليه أن يريد ذلك في اللفظ؛ لأنه قال: هو مثل: موعد، من وَبَقَ يَبِقُ. فظن أن وَبَقَ بمعنى: وعد، لما رأى مثل موعد. والله أعلم {28}."
  18,53,"قوله تعالى: ﴿وَرَأَى الْمُجْرِمُونَ النَّارَ﴾ قال ابن عباس: (يريد المشركين) {1}. وهي تتلظى حنقا عليهم ﴿فَظَنُّوا﴾، قال ابن عباس، ومجاهد: (تيقنوا) {2}.وقال السدي: (استيقنوا) {3}.وهو قول جميع المفسرين {4}. والظن هاهنا بمعنى: العلم.وقوله تعالى: ﴿أَنَّهُمْ مُوَاقِعُوهَا﴾ قال ابن عباس: (أنهم واردوها) {5}. وقال الحسن: (أنهم داخلوها) {6}. وقال مجاهد: (مقتحموها) {7}.ومعنى المواقعة في اللغة: ملابسة الشيء بشدة، يقال: واقَعَهُ مُوَاقَعَةً، وأَوْقَعَ به إِيْقاعاً، ومنه: وقائع الحروب، وتَوَقَعَ أي: ترقب وقعة شيء، ومن هذا يقال للجماع: الوِقَاع؛ لأنه يلابسه بدفع وشدة {8}. والمعنى: ملابسون إياها ملابسة تقع بهم وتشتد عليهم. ﴿وَلَمْ يَجِدُوا عَنْهَا مَصْرِفًا﴾ قال ابن عباس: (يريد قد أحاطت بهم من كل جانب، فلم يقدروا على الهرب ولا على الرجوع عنها) {9}. وقال أهل اللغة: (معنى المصرف: المعدل. وهو الموضع الذي يصرف إليه) {10}.قال أبو كبير الهذلي {11}:أزهير هل عن شيبةٍ من مَصْرِفِوالمصرف في هذه الآية: موضع، وليس بمعنى المصدر، ولو كان مصدرًا كان مفتوح الراء."
  18,54,"قوله تعالى: ﴿وَلَقَدْ صَرَّفْنَا فِي هَذَا الْقُرْآنِ لِلنَّاسِ مِنْ كُلِّ مَثَلٍ﴾ مفسرًا في سورة بني إسرائيل في موضعين {1}].وقوله تعالى: ﴿وَكَانَ الْإِنْسَانُ أَكْثَرَ شَيْءٍ جَدَلًا﴾ قال ابن عباس: (يريد النضر بن الحارث، وجداله في القرآن) {2}. وقال الكلبي: (يعني أبي بن خلف) {3} {4}.وقال أبو إسحاق: (معناه كان الكافر، ويدل عليه قوله: ﴿وَيُجَادِلُ الَّذِينَ كَفَرُوا بِالْبَاطِلِ﴾ [الكهف: 56] الآية. وإن قيل: هل يجادل غير الإنسان؟ قيل: إن إبليس قد جادل، وإن كل ما يعقل من الملائكة، والجن يجادل، ولكن الإنسان أكثر هذه الأشياء جدلاً) {5} {6}."
  18,55,"قوله تعالى: ﴿وَمَا مَنَعَ النَّاسَ﴾ قال ابن عباس: (يريد أهل مكة) {1}. ﴿أَنْ يُؤْمِنُوا﴾ أي: الإيمان ﴿إِذْ جَاءَهُمُ الْهُدَى﴾ محمد -ﷺ- جاءهم من الله بالرشاد والبيان {2}. وهذا مفسر في سورة بني إسرائيل {3}.وقوله تعالى: ﴿وَيَسْتَغْفِرُوا رَبَّهُمْ﴾ عطف على أن يؤمنوا.وقوله تعالى: ﴿إِلَّا أَنْ تَأْتِيَهُمْ سُنَّةُ الْأَوَّلِينَ﴾ قال صاحب النظم: (﴿سُنَّةُ اَلأَوَّلِينَ﴾ أنهم إذا تمردوا ولم يؤمنوا أن يعذبوا ويهلكوا) {4}.يقول: فقدرت على هؤلاء العذاب أي: لم أقدر عليهم الإيمان، فذلك الذي يمنعهم من الإيمان؛ لأني قد قدرت عليهم الإهلاك وهو سنة الأولين {5} -وهذه الآية على هذا التفسير دليل إثبات القدر.وقال أبو إسحاق: (المعنى إلاَّ طلب أن تأتيهم سنة الأولين، وسنة الأولين أنهم عاينوا العذاب فطلب المشركون ذلك ﴿وَإِذْ قَالُوا اللَّهُمَّ إِنْ كَانَ هَذَا هُوَ الْحَقَّ﴾ [الأنفال: 32] {6}.وقوله تعالى: ﴿أَوْ يَأْتِيَهُمُ الْعَذَابُ قُبُلًا﴾ قال ابن عباس والكلبي: (يريد قتل المؤمنين إياهم ببدر) {7}. معنى ﴿قبُلًا﴾: عيانًا أي: مقابلة. قرأ أهل الكوفة: قُبُلاً {8}، وهو يحتمل تأويلين أحدهما: أنه بمعنى قِبَلاً، فقد قال أبو زيد: (لقيت فلانًا قِبَلاً ومُقابَلَةً وقَبَلاً وقُبُلاً وقَبَلِيّاً وقبيلاً) {9}. أي: صنفاً صنفاً، كل قبيل منه غير صاحبه، ويجوز أن يكون ضربًا واحدًا، ويجيئهم منه شيء بعد شيء. وهذا الحرف قد مضى تفسيره في سورة بني إسرائيل {10}، والأنعام {11}."
  18,56,"وقوله تعالى: ﴿وَيُجَادِلُ الَّذِينَ كَفَرُوا بِالْبَاطِلِ﴾ قال ابن عباس: (يريد المستهزئين، والمقتسمين وأتباعهم) {1}. وجدالهم بالباطل: أنهم ألزموه أن يأتي بالآيات على أهوائهم على ما كانوا يقترحون.وقوله تعالى: ﴿لِيُدْحِضُوا بِهِ الْحَقَّ﴾ قال ابن عباس: (ليبطلوا به ما جاء به محمد -ﷺ-) {2}. ومعنى الإدحاض: الإذهاب والإهلاك. يقال: دَحَضَتْ رجله تَدْحَضُ دَحْضًا أي: زلت. ودَحَضْتَ حجته: إذا أبطلتها {3}.ومن هذا ما روي في الحديث: (أنه كان يصلي الأولى حين تَدْحَض الشمس) {4}. أي: تزول وتزلق عن بطن السماء.وقوله تعالى: ﴿وَاتَّخَذُوا آيَاتِي﴾ يعني القرآن ﴿وَمَا أُنْذِرُوا﴾ وإن جعلت ﴿مَا﴾ موصولاً بمعنى: الذي، كان الراجع من الصلة محذوفًا على تقدير: وما أنذروا به أي: خوفوا به من النار والقيامة. وإن جعلت بمعنى المصدر لم يحتج إلى الراجع، ويكون المعنى: واتخذوا آياتي هزوا {5}. والهزؤ: مصدر وصف به، كقوله تعالى: ﴿أَتَتَّخِذُنَا هُزُوًا﴾ [البقرة: 67]، وقد مر."
  18,57,"قوله تعالى: ﴿وَمَنْ أَظلَمُ﴾ استفهام بمعنى التقرير أي: لا أحد أظلم: ﴿مِمَّن ذُكِرَ﴾. قال ابن عباس: (وعظ) {1}. ولهذا دخلت الباء في ﴿بِآيَاتِ رَبِّهِ﴾ يريد: العقاب والعذاب. ﴿فَأَعْرَضَ عَنْهَا﴾ قال: (يريد فتهاون بها) {2}. قال قتادة في هذه الآية: (إياكم والإعراض عن ذكر الله، فإن من أعرض عن ذكر الله فقد اغتر أكبر الغرة) {3}.وقوله تعالى: ﴿وَنَسِيَ مَا قَدَّمَتْ يَدَاهُ﴾ قال قتادة: (نسي ما سلف من الذنوب الكبيرة) {4}.وقوله تعالى: ﴿إِنَّا جَعَلْنَا عَلَى قُلُوبِهِمْ أَكِنَّةً أَنْ يَفْقَهُوهُ وَفِي آذَانِهِمْ وَقْرًا﴾ مفسر في سورة بني إسرائيل {5}، والأنعام {6}. ﴿وَإِنْ تَدْعُهُمْ إِلَى الْهُدَى﴾ قال ابن عباس: (يريد إلى الإيمان) {7}. ﴿فَلَنْ يَهْتَدُوا إِذًا أَبَدًا﴾ قال أبو إسحاق: (أخبر الله أن هؤلاء بأعيانهم أهل الطبع) {8}."
  18,58,"قوله تعالى: ﴿بَلْ لَهُمْ مَوْعِدٌ﴾ قال المفسرون: (يعني البعث والحساب) {1}. ﴿لَنْ يَجِدُوا مِنْ دُونِهِ مَوْئِلًا﴾ قال الأخفش، وأبو عبيد: (منجا، من وأل يئل وألاً على فعول) {2}. وأنشد أبو عبيدة للأعشى {3}:وقد أخالس ربَّ البيت غفلته ... وقد يحاذر مني ثم ما يئلوقال الفراء: (﴿مَوْئِلًا﴾: منجا وهو: الملجأ) {4}. ومعناهما واحد، والعرب تقول: إنه ليوائل إلى موضعه. يريدون يذهب إلى حرزه، والمنجا والملجأ في هذا لفظ المفسرين. قال ابن عباس في رواية الوالبي: (ملجأ) {5}. وهو قول الكلبي ومجاهد في رواية إسرائيل {6}. وروى ورقاء عنه: (محرزًا) {7}. وقال قتادة وابن زبد: (منجا) {8}."
  18,59,"وقوله تعالى: ﴿وَتِلْكَ الْقُرَى أَهْلَكْنَاهُمْ﴾ قال الزجاج: (﴿وَتِلْك﴾ رفع بالابتداء، و ﴿الْقُرَى﴾ صفة لها، و ﴿أَهْلَكنَاهُمْ﴾ خبر الابتداء. قال: وجائز أن يكون موضع ﴿وَتِلْكَ الْقُرَى﴾ نصبا، ويكون ﴿أَهْلَكْنَاهُمْ﴾ مفسرًا للناصب، ويكون المعنى: وأهلكنا تلك القرى أهلكناهم) {1}. قال الأخفش: (أراد أهلها لذلك قال: ﴿أهلَكْنَاهُمْ﴾ حملة على القوم والأهل) {2}.قال ابن عباس: (يريد ما أهلك بالشام واليمن لما ظلموا وأشركوا وكذبوا بالأنبياء) {3}.﴿وَجَعَلْنَا لِمَهلِكِهِم﴾ والمهلك هاهنا يجوز أن يكون: مصدرًا، وأن يكون: وقتًا، والمعنى: جعلنا لإهلاكهم أو لوقت إهلاكهم، وكل فعل على أفعل.فالمصدر واسم الزمان والمكان فيه سواء، تقول: أدخلتُه مُدْخلاً وهذا مُدْخله، أي: المكان الذي يدخل منه وقت إدخاله {4}. وقرأ عاصم في رواية أبي بكر: ﴿لِمَهْلَكِهم﴾ بفتح الميم واللام {5}، وهو مصدر هلك يهلك، والمعنى لوقت هلاكهم يكون المهلك مصدرًا مضافًا إلى الفاعل {6}.قال أبو علي: (ويجوز على لغة تميم أن يكون مصدرًا مضافًا إلى المفعول؛ لأنهم يقولون: هلكني زيد، كأنهم جعلوه من باب رجع، ورجعته، وغاض الماء وغضته، وعلى هذا حمل بعضهم {7}:ومهمهٍ هالك من تعرَّجاقال: هو بمنزلة: مُهْلِكِ مَنْ تَعَرَّجا. فقدل: ﴿لِمَهْلَكِهم﴾، على قول من عَدَّى: هلكت مصدر مضاف إلى المفعول به، نحو ﴿مِنْ دُعَاءِ الْخَيْرِ﴾ [فصلت: 49]. وقرئ في رواية حفص {8}: ﴿لِمَهْلِكِهِم﴾ بفتح الميم وكسر اللام {9}.قال أبو إسحاق: (هذا على أن يكون مهلك اسما للزَّمان، يقال: هلك يهلك، هذا زمن مهلكه) {10}.قال أبو علي: (ويجوز أن يكون مصدرًا، وقد جاء المصدر من باب فعل يفعل بكسر العين قال: ﴿إِلىَّ مَرْجِعُكُمْ﴾ [آل عمران: 55]، وقال: ﴿وَيَسْأَلُونَكَ عَنِ الْمَحِيضِ﴾ [البقرة: 222]، والفتح في المصدر أكثر وأوسع) {11}.وقوله تعالى: ﴿مَوْعِدًا﴾ قال ابن عباس: (يريد وقتًا) {12}. وقال مجاهد: (أجلا) {13}."
  18,60,"قوله تعالى: ﴿وَإِذْ قَالَ مُوسَى لِفَتَاهُ﴾ الآية. روي عن أبي بن كعب من طرق كثيرة أنه قال: (سمعت رسول الله -ﷺ- يقول: ""بينما موسى في ملأ من بني إسرائيل إذ جاءه رجل فقال: هل تعلم أحدًا أعلم منك؟ فقال موسى: لا. فأوحى الله إلى موسى: بلى عبدنا خضر {1}، فسأل موسى السبيل إلى لقياه فجعل الله له الحوت آية. [وقيل؛ إذا فقدت الحوت] {2} فأرجع فإنك ستلقاه"" {3}.وروى سعيد بن جبير عن ابن عباس قال: (قام موسى خطيبًا في بني إسرائيل فأبلغ في الخطبة، وحدث في نفسه أن أحدًا لم يؤت من العلم ما أوتي، فعلم الله الذي حدث نفسه من ذلك فقال له: يا موسى إن من عبادي من قد آتيته من العلم ما لم أوتك، قال: إي ربي من عبادك؟ قال: نعم، قال: فدلني على هذا الرجل الذي آتيته من العلم ما لم تؤتني حتى أتعلم منه قال: يدلك عليه بعض زادك. فقال لفتاه يوشع: ﴿لَا أَبْرَحُ حَتَّى أَبْلُغَ مَجْمَعَ الْبَحْرَيْنِ﴾ الآية، فكان فيما تزود حوتًا مالحاً في زبيل {4}، ثم كان من أمرهما ما قص الله في كتابه) {5}.فقوله: ﴿وَإِذْ قَالَ مُوسَى﴾ معناه: واذكر إذ قال موسى، لما في قصته من العبرة وقوله تعالى: ﴿لِفَتَاهُ﴾ أجمعوا أنه: يوشع بن نون. قال عطاء عن ابن عباس: (يريد غلامه) {6}.قال الفراء، والزجاج: (وإنما سمي فتى موسى؛ لأنه كان ملازمًا له يأخذ عنه العلم ويخدمه) {7}.وقوله تعالى: ﴿لَا أَبْرَحُ﴾ قال جميع أهل التأويل: (معناه لا أزال) {8}. يقال: برحت أفعل كذا أي: ما زلت، ومنه قوله تعالى: ﴿لَنْ نَبْرَحَ عَلَيْهِ عَاكِفِينَ﴾ [طه: 91]، أي: لن نزال. وأصله من قوله: برح الرجل براحا، إذا راح من موضعه، ومنه قوله: ﴿فَلَنْ أَبْرَحَ الْأَرْضَ﴾ [يوسف: 80] وقد مرَّ بنا، فإذا قلت: ما برح يفعل كذا، فكأنك قلت: أقام يفعل ذلك، ودام على حاله تلك من غير مفارقة. قال أبو إسحاق: (معنى ﴿لَا أَبْرَحُ﴾: لا أزال، ولو كان معناه لا أزول كان محالاً؛ لأنه إذا لم يزل من مكانه لا يقطع أرضًا، وأنشد {9}:وأبرح ما أدام الله قومي ... بحمد الله مُنْتَطِقًا مُجِيدًاأي: لا زال) {10}. وقال صاحب النظم: (قوله: ﴿لَا أَبْرَحُ حَتَّى أَبْلُغَ مَجْمَعَ الْبَحْرَيْنِ﴾ مكفوف عن إتمام نظمه؛ لأن فيه إضمارًا وهو: لا أبرح أمضى ماضيًا، أي: سائرًا حتى أبلع مجمع البحرين) {11}.قال ابن عباس في رواية عطاء: (يريد ملتقى البحرين العذب والمالح) {12}.وقال قتادة: (يعني بحر فارس وبحر الروم) {13}. وكان مجمع البحرين الموضع الذي وعد موسى للقاء الخضر -عليه السلام-.وقوله تعالى: ﴿أَوْ أَمْضِيَ﴾ أو أسير. ﴿حُقُباً﴾ قال ابن عباس فيما روى عنه الوالبي يقول: (دهرًا) {14}. وقال في رواية عطاء: (الحقب الواحد بضع وثمانين سنة، السنة ثلاثمائة وستون يومًا، اليوم الواحد ألف سنة) {15}. وقال مجاهد: (الحقب سبعون خريفاً) {16}.وأمما أهل اللغة فإنهم كلهم قالوا: (الحقب ثمانون سنة) {17}.قال صاحب النظم: (﴿أَوْ﴾ بمعنى حتى، مثل قولك: لا آتيك أو تكرمني، فيرجع تأويل الآية: لا أبرح ماضيًا إلى أن أمضي حقبًا حتى أبلغ مجمع البحرين. قال: ونظير هذا في الكلام أن تقول: لا أزال إلى أن أسير سنة حتى أقضى حاجتي. ومعنى إلى أن أسير سنة: وإن احتجت إلى أن أسير سنة) {18}. وعلى ما ذكر يكون في الآية تقديم وتأخير، ولا يجوز أن يجعل ﴿أَوْ﴾ للعطف؛ لأنه ليس المراد حتى أبلغ مجمع البحرين وحتى أمضي حقبا، و ﴿أَوْ﴾ هاهنا الناصبة للفعل بإضمار أن كما تقول: لألزمنك أو تعطيني حقي، التقدير: إلى أن تعطيني حقى {19}، ومنه قول امرئ القيس {20}:فقلت له لا تبك عينك إنَّما ... نحاول ملكًا أو نموت فنعذراالمعنى: إلى أن نموت."
  18,61,"قوله تعالى: ﴿فَلَمَّا بَلَغَا﴾ يعني: موسى وصاحبه. ﴿مَجْمَعَ بَيْنِهِمَا﴾ قال ابن عباس: (يريد ملتقى العذب والمالح) {1}. وعلي قول قتادة: (ملتقى بحر الروم وبحر فارس) {2}. وهو حيث وعد لقاء الخضر.وقوله تعالى: ﴿نَسِيَا حُوتَهُمَا﴾ إلى آخر الآية. قال سعيد بن جبير عن ابن عباس: (كان فيما تزودا حوتًا مالحًا في زبيل، وكان يصيبان منه عند العشاء والغداء، فلما انتهيا إلى الصخرة على ساحل البحر، وضع فتاه المكتل {3} فأصاب الحوت [ندى البحر فتحرك في] {4} المكتل فقلب المكتل، وانسرب في البحر) {5}.وروى أبي بن كعب عن رسول الله -ﷺ- قال: ""لما أراد موسى أن يطلبه قيل له: تزود معك حوتًا مالحًا فحيث {6} يفقد الحوت ثم تجد الرجل، فانطلق هو وفتاه حتى أتيا الصخرة، فقال لفتاه: امكث حتى آتيك، وانطلق موسى لحاجته، فجرى الحوت حتى وقع في البحر، فقال فتاه: إذا جاء نبي الله حدثته، فأنساه الشيطان"" {7}.قال ابن عباس في رواية عطاء: (نسي الفتى أن يذكر قصة الحوت لموسى) {8}.﴿فَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ سَرَبًا﴾ قال: (يريد مسيرًا) {9}. وفي حديث أبي: ""جعل لا يصيب الحوت شيئًا من الماء إلا جمد، حتى اتخذ سبيله في البحر سربًا شبه النقب"" {7}.وقال قتادة: (جعل لا يسلك طريقًا إلا صار الماء جامدًا) {11}.وقال الربيع بن أنس: (انجاب الماء على مسلك الحوت فصارت كوة لم تلتئم) {12}.وروي أيضًا عن النبي -ﷺ- في حديث أبي بن كعب قال: ""ما انجاب الماء مذ كان الناس غير مكان الحوت الذي دخل منه كالكوة، حتى رجع إليه موسى فرأى مسلكه"" {13}. هذا معنى قوله: ﴿فَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ سَرَبًا﴾.وقال الكلبي: (كان عند تلك الصخرة التي نزلا عندها عين ماء فتوضأ يوشع من ذلك الماء، فانتضح على الحوت في المكتل ثم طفر في البحر) {14}.والسَّرب معناه في اللغة: المحفور في الأرض لا نفاذ له، شبه مسلك الحوت في الماء {15}، والماء منجاب عنه بالسَّرب. كما قال الفراء: (حيي الحوت بالماء الذي أصابه من العين، فلما وقع في الماء جمد مذهبه في البحر فكان كالسرب) {16}.هذا قول المفسرين في هذه الآية. وعلى ما قالوا في نظم الآية تقديم وتأخير على تقدير: فلما بلغا مجمع بينهما اتخذ الحوت [سبيله في البحر سربا، ونسي يوشع أن يذكر ذلك لموسى؛ لأن النسيان لم يتقدم على ذهاب الحوت] {17}، ذهب الحوت فنسي الفتى أن يذكر ذلك لموسى حتى جازوا ذلك المكان على ما في القرآن من الآيات بعد هذه الآية.وقوله تعالى: ﴿نَسِيَا حُوتَهُمَا﴾ إجماع المفسرين أن النسيان هاهنا معناه: نسيان الفتى ذكر قصة الحوت لموسى، والناسي كان أحدهما، وأضيف إليهما جميعًا.واختلفوا في وجه هذا فقال الفراء: (إنما نسيه يوشع فأضافة إليهما كما قال: ﴿يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَالْمَرْجَانُ﴾ [الرحمن: 22] وإنما يخرج من الملح دون العذب) {16}. وعلى هذا أضيف إليهما توسعا، وذكر غيره العلة في جواز هذا التوسع فقال: (إنهما كانا جميعًا تزوداه لسفرهما، فجاز إضافته إليهما كما يقال: نسي القوم زادهم، وإنما نسيه أحدهم) {19}.وقال أبو علي الفارسي: (هذا من باب حذف المضاف. المعنى: نسي أحدهما حوتهما، فلما حذف المضاف عادت الكناية إلى الفعل فقيل: نسيا. قال: وكذلك قوله: ﴿يَخْرُجُ مِنْهُمَا﴾ [الرحمن: 22] المعنى: من أحدهما، وفيه حذف أيضًا من وجه آخر وهو أن التقدير: نسيا أمر حوتهما وقصته؛ لأن يوشع نسي أن يذكر أمره لموسى على ما بينا) {20}.هذا الذي ذكره مذهب المفسرين، وجميع أهل المعاني، وقد أغنى الزجاج عن الحذف والتقديم والتأخير الذي يلزم على مذهب هؤلاء فقال في قوله: ﴿نَسِيَا حُوتَهُمَا﴾ (كان النسيان من يوشع أن يقدمه، وكان النسيان من موسى أن يأمره فيه بشيء) {21}.وعلى هذا المعنى لما بلغا مجمع بينهما نسي يوشع أن يقدم الحوت للأكل، ونسي موسى أيضًا أن يأمره بذلك، فلما نسياه حيا بإذن الله، وذهب في البحر، فصح المعنى واستغنى عن تقدير الحذف والتقديم والتأخير، غير أن مذهب المفسرين في النسيان ما ذكرنا أولى.وذكر في انتصاب قوله: ﴿سَرَبَاً﴾ وجهين أحدهما: أنه مفعول ثان، كما تقول: اتخذت زيدًا وكيلاً.والثاني: أن ""سَرَبا"" هاهنا مصدر سرب ينسرب إذا ذهب على وجهه {22}. منه قول الشاعر {23}:ونحن خلعنا قيده فهو ساربوذكرنا هذا عند قوله: ﴿وَسَارِبٌ بِالنَّهَارِ﴾ [الرعد: 10]، وكأنه قيل: سَرب الحوت سربًا، ودل عليه قوله: ﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ﴾ [الكهف: 63]؛ لأنه بمعنى سرب، ولهذا نظائر كثيرة في التنزيل. وعلى هذا قد حصل في معنى السرب قول آخر. وبنحو هذا القول أخبرني العروضي عن الأزهري قال: (أخبرني المنذري عن ابن اليزيدي عن أبي حاتم. في قوله: ﴿سَرَبًا﴾ قال: أظنه يريد ذهابًا يسرب سربًا، كقولك: يذهب ذهابًا) {24}."
  18,62,"قوله تعالى: ﴿فَلَمَّا جَاوَزَا﴾ أي: ذلك المكان الذي كانت عنده الصخرة وذهب الحوت.قال رسول الله -ﷺ-: ""انطلقا وأصابهما ما يصيب المسافر من النصب والكلال"" {1}. ولم يجد النَّصَب حتى جاوز حيث أمره الله تعالى ﴿قَالَ لِفَتَاهُ آتِنَا غَدَاءَنَا﴾ الآية. ونحو هذا قال ابن عباس وجميع المفسرين: (إنه لم ينْصَب حتى جاوز الموضع الذي يريده، فلما خرج من حد الموضع نصب فدعا بالطعام ليأكل) {2}. والغداء: الطعام الذي يؤكل بالغداة. كالعشاء: الطعام الذي يؤكل بالعشي. والنَّصب: التعب والوهن الذي يكون عن الكلال {3}.قال الليث: (النَّصب الإعياء من العناء، والفعل نَصِبَ يَنْصَب، وأنْصَبَنِي هذا الأمر) {4}."
  18,63,"قال المفسرون: فلما قال له موسى ذلك تذكر قصة الحوت؛ لأنه كان من عنده عذابهما، فقال: ﴿أَرَأَيْتَ إِذْ أَوَيْنَا إِلَى الصَّخْرَةِ﴾ [الكهف: 63] الآية.قال صاحب النظم: (الأمر عند الناس قوله: أرأيت من رؤية البصر، وليس كذلك، إنما هي كلمة وضعت لتنبيه المسؤول {1} عنه وبعثه على التفهم والإجابة كما قال -عز وجل -: ﴿أَرَأَيْتَ إِنْ كَانَ عَلَى الْهُدَى﴾ [العلق: 11]، والدليل على ذلك أن الفاء في قوله: ﴿فَإِنِّي نَسِيتُ الْحُوتَ﴾ يدل على أنه جواب لمعنى يقتضي الفاء، والتأويل: إن شاء الله أرأيت. أي: اسمع وتفهم فإني نسيت الحوت) {2}. ونحو هذا قال أبو علي الفارسي: (وأما ما جاء أرأيت فيه بمعنى انتبه فقوله: ﴿أَرَأَيْتَ إِذْ أَوَيْنَا إِلَى الصَّخْرَةِ﴾ كأن المعنى: انتبه فإني نسيت الحوت، ولذلك دخلت الفاء كما تدخل في جواب الجزاء. ومثله: ﴿أَرَأَيْتُمْ إِنْ أَصْبَحَ مَاؤُكُمْ غَوْرًا فَمَنْ يَأْتِيكُمْ﴾ [الملك: 30]، كأنه انتبهوا فمن يأتيكم) {3}.وقوله تعالى: ﴿إِذْ أَوَيْنَا إِلَى الصَّخْرَةِ﴾ يعني: حين نزلا هناك ووضع يوشع المكتل الذي فيه الحوت عند الصخرة.وقوله تعالى: ﴿فَإِنِّي نَسِيتُ الْحُوتَ﴾ قال ابن عباس في حديث أبي بن كعب مرفوعًا: (فإني نسيت الحوت أن أحدثكه) {4}. وعلى هذا المعنى نسيت قصة الحوت وأمره على ما ذكرنا. ثم اعتذر فقال: ﴿وَمَا أَنْسَانِيهُ إِلَّا الشَّيْطَانُ﴾ وذلك؛ لأنه لو ذكر لموسى قصة الحوت عند الصخرة ما جاوزها موسى، وما ناله النصب الذي شكاه في قوله: ﴿لَقَدْ لَقِينَا مِنْ سَفَرِنَا هَذَا نَصَبًا﴾ فاعتذر فتاه من ذلك بأن أنساه الشيطان إياه. قال أهل المعاني: (معناه شغل قلبي بوسوسته حتى نسيته؛ لأن الشيطان لا يقدر على فعل النسيان وإنما عرضه له) {5}.وقوله تعالى: ﴿أَنْ أَذْكُرَهُ﴾ قال أبو إسحاق: (﴿أَنْ أَذْكُرَهُ﴾ بدل من الهاء لاشتمال الذكر على الهاء في المعنى، وما أنساني أن أذكره إلا الشيطان) {6}. قال ابن عباس: (يريد أن أحدث بقصة الحوت) {7}. وهذه الآية تدل على صحة قول المفسرين في قوله: ﴿نَسِيَا حُوتَهُمَا﴾.وقوله تعالى: ﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ عَجَبًا﴾ قال ابن عباس في رواية سعيد بن جبير: (اتخذ موسى سبيل الحوت في البحر عجبا) {8}. ونحو هذا قال قتادة، ومجاهد، وابن زيد {9}. وقد ذكرنا: أن مسلك الحوت لم يلتئم فدخل موسى ذلك المسلك. وينتصب ﴿عَجَبًا﴾ على هذا بوقوعه موقع الحال، كأنه قيل: واتخذ موسى سبيل الحوت عاجبًا من ذلك الأمر {10}.قال مجاهد: (تعجب موسى من أثر الحوت في البحر ودورانه التي غاب فيها) {11}.وقال ابن زيد: (أي شيء أعجب من حوت كان دهرًا من الدهور يؤكل منه، ثم صار حيًا حتى مشى في البحر) {12}. وهذا القول اختيار الفراء فقد قال: (واتخذ موسى سبيل الحوت في البحر عجبًا) {13}. ويجوز أن ينتصب عجبا بأنه نعتُ محذوفٍ؛ كأنه قيل: سبيلاً عجبًا. ذكره ابن قتيبة {14}. وهذا القول الذي ذكرنا عن هؤلاء بعيدة لأن اتخاذ موسى سبيل الحوت مسلكًا كان بعد أن ارتدا على آثارهما قصصًا، إلا أن تحمل النظم على التقديم والتأخير، ولكن التقريب أن يجعل قوله: ﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ عَجَبًا﴾ من قول يوشع [إخبارًا عن الحوت أنه فعل ذلك. ذهب إلى هذا طائفة من المفسرين فقالوا: (هذا من قول يوشع] {15} يقول: اتخذ الحوت سبيله في البحر سبيلاً عجبًا) {16}. وذكر الزجاج هذا القول {6}.وذكر كثير من أهل العلم: (أن الكلام قد تمَّ عند قوله: ﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ﴾ ويحسن الوقف هاهنا ثم تقول {18}: ﴿عَجَبًا﴾) {19}. ووجه هذا ما قاله أبو إسحاق: (وهو أن يكون قال يوشع: ﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ﴾ فأجابه موسى فقال: ﴿عَجَبًا﴾ كأنه قال: أعْجَبُ عَجَبًا) {20}.ونحو هذا حكى أبو حاتم {21} عن أهل التفسير فقال: (إنهم قالوا: ﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ﴾ تمام، ثم قال: ﴿عَجَبًا﴾ أي: أعْجَبُ عَجَبًا، وعلى هذا يجوز أن يكون العجب راجعًا إلى يوشع أخبر عن اتخاذ الحوت سبيله في البحر، ثم أخبر عن تعجبه من ذلك) {22}. والوقف على قوله: ﴿فِي الْبَحْرِ﴾ مذهب الحسن، وعيسى بن عمر {23}، ويعقوب {24}.قال سعيد بن جبير عن ابن عباس: (لما قال هذا يوشع ذكر موسى ما كان عهد إليه أنه يدلك عليه بعض زادك) {25}."
  18,64,"فقال: ﴿ذَلِكَ مَا كُنَّا نَبْغِ﴾ قال ابن عباس في رواية سعيد بن جبير: (أي هذه حاجتنا) {1}. وهذا اللفظ يحتمل معنيين أحدهما: أن المراد بحاجته التي كان يطلبها الخضر -عليه السلام-، وعلى هذا الإشارة بقوله: ﴿ذَلِكَ﴾ إلى الخضر. هذا قول ذكره المتأخرون من أهل التفسير. والصحيح: أنه أراد بقوله: ﴿ذَلِكَ مَا كُنَّا نَبْغِ﴾ انسراب الحوت {2}؛ لأن هذا جواب لقول يوشع حين أخبره بذلك الحوت، وعنده الخضر في ذلك المكان الذي تنسرب فيه السمكة، فقال موسى: ﴿ذَلِكَ مَا كُنَّا نَبْغِ﴾ أي: نطلب ونريد من العلامة، ولو أراد الخضر بقوله: ﴿مَا كُنَّا نَبْغِ﴾ لقال: ذلك من كنا نبغي. ولكن يوشع لم يخبره عن الخضر بشيء حتى يكون معنى قوله: ﴿ذَلِكَ مَا كُنَّا نَبْغِ﴾ الخضر. ودل كلام أبي إسحاق، والفراء على هذا القول {3}.وقوله تعالى: ﴿فَارْتَدَّا عَلَى آثَارِهِمَا﴾ قال المفسرون: (رجعا وعادا عودهما على بدئهما في الطريق الذي جاءا منه) {4}. ﴿قَصَصًا﴾ أي: يقصان آثارهما قَصَصا. والقَصَص: إتباع الأثر {5}، وقد مر ذكره. وانتصابه على المصدر {6}.ودل قوله: ﴿فَارْتَدَّا عَلَى آثَارِهِمَا﴾ حتى انتهيا إلى الصخرة التي فعل عندها الحوت ما فعل، وأبصر موسى أثر الحوت فأخذا أثر الحوت يمشيان على الماء حتى انتهيا إلى جزيرة من جزائر البحر فوجدا الخضر {7}."
  18,65,"فذلك قوله تعالى: ﴿فَوَجَدَا عَبْدًا مِنْ عِبَادِنَا﴾ أي: صادفا وأدركا الخفر. قال المفسرون: (اسمه بليا بن ملكان) {1}.وقال مقاتل بن سليمان: (اسم المذكور في القرآن اليسع) {2}.قال مجاهد: (سمي الخضر؛ لأنه إذا صلى اخضر ما حوله) {3}.وقوله تعالى: ﴿آتَيْنَاهُ رَحْمَةً مِنْ عِنْدِنَا﴾ قال ابن عباس: (يريد نبوة) {4}.﴿وَعَلَّمْنَاهُ مِنْ لَدُنَّا عِلْمًا﴾ قال: (أعطاه علمًا من علم الغيب) {5}."
  18,66,"﴿قَالَ لَهُ مُوسَى هَلْ أَتَّبِعُكَ عَلَى أَنْ تُعَلِّمَنِ مِمَّا عُلِّمْتَ رُشْدًا﴾ وقرئت: رَشَدا {1}، ومثله كثير في العربية نحو: البُخْل والبَخَل، والعُجْم والعَجَم، والعُرْب والعَرَب.قال أبو علي الفارسي: (فُعْل وفَعَل قد أجرى العرب كل واحد منهما مجرى الآخر {2}، ألا ترى أنهم جمعوهما جمعًا واحدًا فقالوا: تاجٌ وتِيْجان، وقاعٌ وقِيْعان، وحُوت وحِيْتان، ونُوْنٌ ونيْنان، وكما جمعوا فعلاً على فعلٍ نحو: أَسَد وأُسْد، ووَثَن ووُثْن، جمعوا فُعْلا على فُعْلٍ أيضًا، كما جمعوا فَعَلاً وذلك قولهم: الفلك، قال الله تعالى: ﴿فِي الْفُلْكِ الْمَشْحُونِ﴾ [الشعراء: 119] أراد الواحد. وقال: ﴿وَالْفُلْكِ الَّتِي تَجْرِي فِي الْبَحْرِ﴾ [البقرة: 164]، أراد الجمع. وقيل: أرجح الوجهين قراءة من قرأ: رَشَدا، لاتفاقهم على الفتح في قوله: ﴿فَأُولَئِكَ تَحَرَّوْا رَشَدًا﴾ [الجن: 14]. وقد اجتمعا في أن كل واحد منهما فاصلة. فأما وجه انتصابه فقوله: ﴿عَلَى أَنْ تُعَلِّمَنِ﴾ حال من قوله: ﴿أَتَّبِعُكَ﴾، والراجع إلى الموصول في قوله: ﴿مِمَّا عُلِّمْتَ﴾ محذوف تقديره: مما علمته. و ﴿رُشْدًا﴾ منصوب على أنه مفعول له، كأنه قيل: أتبعك للرشد. ويجوز أن يكون مفعولاً به تقديره: هل أتبعك على أن تعلمني رشدًا مما علمته {3}.ومعنى: ﴿رُشدًا﴾ أمرا ذا رشد، وعلما ذا رشد) {4}، وذكرنا معنى الرشد عند قوله: ﴿وَإِن يَرَوْاْ سَبِيلَ الرُّشَدِ﴾ [الأعراف: 146] وفي موضع آخر.وهذه الآية بيان عما يوجبه العلم من تعظيم صاحبه، ألا ترى كيف دعت موسى مع جلالة شأنه وما أتاه الله من التوراة والعلم، في إتباع من يتعلم منه فيزداد إلى علمه.قال أبو إسحاق: (وفيما فعل موسى وهو من جلة الأنبياء عليهم السلام من طلب العلم والرحلة في ذلك، ما يدل على أنه لا ينبغي لأحد أن يترك طلب العلم، وإن كان قد بلغ نهايته، وأحاط بأكثر ما يدركه أهل زمانه، وأن يتواضع لمن هو أعلم منه) {5}.وقال قتادة: (لو كان أحد مكتفيًا من العلم لاكتفى موسى نبي {6} الله حيث قال: ﴿هَلْ أَتَّبِعُكَ عَلَى أَنْ تُعَلِّمَنِ﴾ الآية) {7}."
  18,67,"وقوله تعالى: ﴿قَالَ إِنَّكَ لَنْ تَسْتَطِيعَ مَعِيَ صَبْرًا﴾ هذا قول الخضر لموسى عليهما السلام. قال ابن عباس: (يريد لن تصبر على صنيعي؛ لأني علمت علم غيب، علم ربي) {1}."
  18,68,"وقال أبو إسحاق: (ثم أعلمه العلة في ترك الصبر، فقال: ﴿وَكَيْفَ تَصْبِرُ عَلَى مَا لَمْ تُحِطْ بِهِ خُبْرًا﴾ أي: كيف تصبر على ما ظاهره منكر، والأنبياء والصالحون لا يصبرون على ما يرونه منكرًا) {1}.وقال الكلبي: (يقول لا ينبغي لرجل صالح أن يصحبني يرى مني ما ينكر لا يغيره) {2}. وقال ابن عباس: (يريد لم تحط بعلم الغيب) {3}.وقال الزجاج: (نصب ﴿خُبْرًا﴾ على المصدر؛ لأن معنى ﴿لَمْ تُحِطْ بِهِ خُبْرًا﴾ أي: لم يخبره خبرا) {4}. ومعنى لم يخبره خبرا: لم يعلمه. والخبر: علمك بالشيء، يقال: من أين خبرت هذا؟ أي: علمت. وليس هذا من الخبر بمعنى التجربة. وقد روي ذلك عن عطاء في هذه الآية قال: (يريد لم يخبر من علم الغيب شيئًا) {5}. وهو بعيد مع قوله: ﴿لَمْ تُحِطْ بِهِ﴾ ولفظ الإحاطة يستعمل في معنى العلم لا في معنى التجربة، فقوله: ﴿لَمْ تُحِطْ بِهِ خُبْرًا﴾ كقولك: لم تحط به علمًا."
  18,69,"﴿قَالَ﴾ موسى ﴿سَتَجِدُنِي إِنْ شَاءَ اللَّهُ صَابِرًا﴾ قال الكلبي: (يقول لا أسألك عن شيء حتى تكون أنت تحدثني) {1} {وَلَا أَعْصِي لَكَ أَمْرًا} قال ابن عباس: (يريد ولا أخالفك في شيء) {2}."
  18,70,"قال له الخضر: ﴿فَإِنِ اتَّبَعْتَنِي﴾ قال ابن عباس: (وذلك أنه كان رجلاً يعمل على الغيب) {1}.وقوله تعالى: ﴿حَتَّى أُحْدِثَ لَكَ مِنْهُ ذِكْرًا﴾ قال: (يريد حتى أكون أنا الذي أفسره لك؛ لأنه قد غاب علمه عنك) {2}. هذا كلامه، وتفسير ﴿أُحْدِثَ لكَ مِنْهُ ذِكْراً﴾ أبتدئ بذكره لك وبيانه."
  18,71,"وقوله تعالى: ﴿فَاَنطَلَقَا﴾ روي عن أبي بن كعب مرفوعًا أنه قال: (فانطلقا يمشيان على ساحل البحر، فمرت بهم سفينة وكلموهم أن يحملوهما، فحملوهما بغير أجر، فلما ولجوا البحر أخذ الخضر فأسًا فخرق لوحًا من السفينة، فحشاها موسى بثوبه، وقال له: ﴿أَخَرَقنَهَا﴾ الآية) {1}. فذلك قوله تعالى: ﴿حَتَّى إِذَا رَكبَا في اَلسَّفِينَهِ﴾ أراد ركبا البحر في السفينة، فحذف المفعول للعلم به. والسفينة معروفة أصلها: من السَّفن وهو القشر، سميت لِسَفْنِهَا وجه الماء كأنها تَقْشرة، وهي فَعِيلَة بمعنى فَاعِلة. وروى ثعلب عن ابن الأعرابي قال: (قيل لها سَفِينَة؛ لأنها تَسْفِنُ الرَّمْل إذا قلَّ الماء. قال: ويكون مأخوذًا من السَّفن، وهو الفأس التي ينجر به النجار) {2}. ومنه قوله {3}:كما تخوَّف عود النبعة السَّفنفهي على هذا فعيلة بمعنى مَفْعولة؛ لأنه نُحِتَت من الخشب بالسَّفَن فهي مَسْفونة، أي: منجورة منحوتة {4}.وقوله تعالى: ﴿خَرَقَهَا﴾ أي: شقها. جاء في التفسير: (أنه قلع لوحين مما يلي الماء) {5}، فقال موسى منكرًا عليه: ﴿أَخَرَقْتَهَا لِتُغْرِقَ أَهْلَهَا لَقَدْ جِئْتَ شَيْئًا إِمْرًا﴾ قال مجاهد: (منكرا) {6}. وهو قول قتادة، والمفسرين {7}.وقال أبو عبيدة: (داهية نكرا) {8}، وأنشد {9}:قد لقي الأقران منِّي نكرا ... داهيةً دهياء إدًّا إمراوقال الكسائي: (شديدًا عظيمًا) {10}. من أَمِر الأمر إذا كبر أمرا بفتح الميم، والإمر الاسم {11}."
  18,72,"فقال له الخضر محققًا ما كان قال له أولاً: ﴿قَالَ أَلَمْ أَقُلْ إِنَّكَ لَنْ تَسْتَطِيعَ مَعِيَ صَبْرًا (72) قَالَ لَا تُؤَاخِذْنِي بِمَا نَسِيتُ﴾ روى ابن عباس، وأبي بن كعب عن النبي -ﷺ- قال: ""كانت الأوُلى من أمر موسى في النسيان، والثانية العذر، ولو صبر موسى لقص الله علينا أكثر مما قص"" {1}. فعلى هذا معنى قوله: ﴿نَسِيتُ﴾ غفلت عن التسليم لك، وترك الإنكار عليك ونسيت ذلك.وروي عن ابن عباس نفسه أنه قال: (بما تركت من عهدك) {2}. وهو قول الكلبي يقول: (ما تركت من وصيتك) {3}. وعلى هذا القول النسيان بمعنى: الترك، لا بمعني الغفلة. وروي عن أبي بن كعب نفسه أنه قال: (لم ينسها ولكنها من معاريض الكلام) {4}. وهذا القول مروي عن أبي عمرو بن العلاء قال: (ما كان نسي {5}، ولكن هذا من معاريض الكلام) {6}. ومعني هذا: أنه اعتذر بالنسيان كالعادة في الكلام، وأن لفظ النسيان كثيرًا ما يذكر معترضًا به من غير حقيقة. وقال بعضهم: (أراد أنه لم يقل له: نسيت فيكون كاذبًا، ولكنه قال: ﴿لَا تُؤَاخِذْنِي بِمَا نَسِيتُ﴾ فأوهمه النسيان تعريضًا) {7}. وقد حصل في قوله: ﴿بِمَا نَسِيتُ﴾ ثلاثة أوجه {8}.قوله تعالى: ﴿وَلَا تُرْهِقْنِي﴾ قال ابن عباس في رواية عطاء: (تلحقني) {9}. روى سلمة عن الفراء: (رهِقَني الرجل، يَرْهَقني، رهقًا، أي: لَحِقَني وغَشِيَني، وأَرْهَقته إذا أَرْهَقَته غيرك) {10}.وقال أبو إسحاق: (معنى ﴿تُرْهقِنى﴾ تغشيني) {11}. ونحو ذلك قال ابن قتيبة {12}، وهو قول العامة. ويغشني ويلحقني بمعنى واحد، ومن لحق شيئًا فقد غشيه.وقال الكلبي في قوله: (﴿وَلَا تُرْهِقْنى﴾ لا تكلفني) {13} قال أبو زيد: (أرهقتُه عُسْرًا إذا كلَّفته ذاك) {14}. وهذا قريب من الأول، والكلام في هذا الحرف قد سبق عند قوله: ﴿وَلَا يَرْهَقُ وُجُوهَهُمْ قَتَرٌ وَلَا ذِلَّةٌ﴾ [يونس: 26].ومعنى الآية؛ عاملني باليسر لا بالعسر، ولا تضيق عليَّ الأمر في صحبتي إياك {15}.وقال الفراء في قوله: ﴿وَلَا تُرْهِقْنىِ﴾: (لا تعجلني) {16}.قال ابن شميل: (أرهَقَني القوم أن أصلِّي، أي: أعْجَلُوني) {17}.وقال ابن الأعرابي: (إنه لرَهِقٌ أي: سريع إلى الشر سريع الحِدَّة) {18}.وقال الكسائي: (فيه رَهَق، أي: خفِّة وحدِّة) {19}. والأحسن في تفسير ﴿ترهقني﴾ مع قوله: ﴿مِنْ أَمْرِي عُسْرًا﴾ قول ابن عباس، والكلبي. وقول الفراء بعيد في تفسير الآية، لا يحسن أن نقول: لا تعجلني من أمري عسرا، والله أعلم."
  18,73,"18:72"
  18,74,"وقوله تعالى: ﴿فَانْطَلَقَا حَتَّى إِذَا لَقِيَا غُلَامًا فَقَتَلَهُ﴾ في حديث أبي بن كعب: (أنهما خرجا مع الصبيان فقال به هكذا، كأنه اجتذب رأسه فقلعه. وأشار عبد الرزاق {1} حين روى هذا الحديث بأصابعه الثلاثة: السبابة، والوسطى، والإبهام وفتحها) {2}.وروى سعيد بن جبير عن ابن عباس: (أن ذلك الغلام كان من أحسن أولئك الغلمان وأصبحهم) {3}.وقال أبو العالية: (كان الخضر عبدًا لا تراه الأعين، ورآه موسى، ولو رآه الناس يقتله ما تركوه) {4}.قال موسى حين رأى ذلك: ﴿أَقَتَلْتَ نَفْسًا زَكِيَّةً﴾ قال ابن عباس ومجاهد: (لم يبلغ الحلم) {5}. ومعنى الزاكية: الطاهرة من الذنوب، وذلك؛ لأنه كان صغيرًا لم يبلغ حد التكليف. وقرئ: زاكيه {6}. وهي البرئية من الذنوب. كذا قال الأعمش وغيره، وهو قول أبي إسحاق {7}. وقال الفراء: (الزَاكِية والزَكِية مثل: القَاسِية والقَسِية) {8}.قال الليث: (الزكاة: الصلاح) {9}. ورجل زاكٍ وزَكِي أي: تَقِي، ومنه قوله تعالى: ﴿خَيْرًا مِنْهُ زَكَاةً﴾ [الكهف: 81] أي: صلاحًا.قال الكسائي: (والفعل منه زَكَوْتُ، يزْكُو، زُكُوًا، وزكاءً ممدود) {10}. هذا الذي ذكرنا أنه كان صبيًا لم يبلغ الحنث، قول أكثر المفسرين {11}.وقال الضحاك: (كان غلامًا يعمل بالفساد ويتأذى منه أبواه) {12}.وقال الكلبي: (كان يقطع الطريق) {13}. وعلى هذا معنى قوله: ""زاكية"" ما قال قتادة: (الزاكية التائبة) {14}. يعني النامية، وكل شيء يزداد ويسمن فهو يزكو، زكاء والمعنى: أنه كان غلامًا مقتبل الشباب {15}. أو تقول معنى زاكية على تفسير الضحاك والكلبي: (أنها كانت زاكية في رأي العين؛ لأنه لم يجن جناية توجب قتله بحضرة موسى) {16}.وقوله تعالى: ﴿بِغَيْرِ نَفْسٍ﴾ قال ابن عباس: (يريد من غير قود) {17}. والمعنى: بغير قتل نفس: ﴿لَّقَدْ جِئْتَ شَيْئا نُكْراً﴾ أي: فظيعًا منكرًا لا يعرف. قال قتادة: (والنكر أشد من الإمر) {18}. وهو اختيار ابن كيسان {19}. والمعنى على هذا: لقد جئت شيئًا أنكر من الأول.وقال أبو إسحاق: (و ﴿نُّكْرًا﴾ أقل من قوله: ﴿إِمْرًا﴾؛ لأن تغريق من في السفينة كان عنده أنكر من قتل نفس واحدة) {20}. وانتصاب قوله: {شَيْئًا نُّكْراً} على المفعول به؛ لأن المعنى: أتيت شيئًا نكرا. قال الزجاج: (ويجوز أن يكون معناه جئت بشيء نكر، فلما حذف الباء أمضى الفعل فنصب) {21}."
  18,75,""
  18,76,"قوله تعالى: ﴿قَالَ إِنْ سَأَلْتُكَ عَنْ شَيْءٍ بَعْدَهَا﴾ قال أهل المعاني: أراد إن سألتك سؤال توبيخ وإنكار، كما قال في السفينة: ﴿أَخَرَقْتَهَا﴾ وفي الغلام: ﴿أَقَتَلْتَ نَفْسًا﴾ وذاك أن السؤال على وجوه: منه ما هو: طلب الأخبار عن المعنى للفائدة، ومنه ما هو: للتقرير، ومنه ما هو: للتوبيخ. والكناية في قوله: ﴿بَعْدِهَا﴾ تعود إلى النفس المقتولة.وقوله تعالى: ﴿قَدْ بَلَغْتَ مِن لَّدُنِى عُذرًا﴾ قال ابن عباس: (يريد أنك قد أعذرت فيما بيني وبينك، وقد أخبرتني أني لا أستطيع معك صبرا) {1}. وقال أهل المعاني: (هذا إقرار من موسى بأن الخضر قد قدم إليه ما يوجب العذر عنده، فلا يلزمه ما أنكر) {2}.وروي: أن النبي -ﷺ- تلا هذه الآية فقال: ""استحيا نبي الله موسى عندها، ولو صبر لرأى ألفا من العجائب"" {3}.واختلف القراء في قوله: (مِن لَّدُنِّي) فقراءة العامة: بتشديد النون، وقرأ أهل المدينة: بتخفيفها {4}.قال أبو إسحاق: (الأجود تشديد النون؛ لأن أصل نون لَدُنْ الإسكان، فإذا أضفتها إلى نفسك زدت نونًا ليِعْلَمَ سكون النون الأولى، تقول: من لدنْ زيدٍ، فتسكن النون ثم تضيف إلى نفسك فتقول: من لَدُنِي، كما تقول: عن زيدٍ، ثم تقول: عَنِي) {5}.وقال أبو علي: (من قال من لَدُنِّي زاد النون التي تزاد مع علامة المضمر المجرور والمنصوب، في نحو مِنِّي، وعَنِّي، وقَطْنِي، وضَرَبَني، فأدغم الأولى الساكنة في التي تزاد مع الضمير، فصار من لدنِّي، وهذا هو القياس والذي عليه الاستعمال. ومن خفف فإنه لم يلحق النون التي تلحق علامة الضمير في نحو: ضَرَبني، وقدني كما قال {6}: قَدْنِي من نصر الخُبَيْبَيْن قديلم يلحق النون، كذلك قرأ نافع: لدني. ولا تكون النون المحذوفة نون لدن لثبوته في قولك: لدنه، ولدنك، ولدنَّا) {7}.وقال أبو إسحاق: (ومن قال: لدني، لم يجز له أن يقول: عَنِي، ومِنِي؛ لأن لَدُن اسم غير متمكن، ومن، وعن حرفان جاءا لمعنى، ولدن مع ذلك أثقل من: مِنْ، وعَنْ، والدليل على أن الأسماء يجوز فيها حذف النون قولهم: قدنى، في معنى: حسبي) {5}، هذا كلامه. وذكر الفرق بين لدني مخفف، ومتى خفف لا يجوز من وجهين أحدهما: أن لَدُنْ اسم والاسم يجوز الحذف فيه كقولهم: قَدِي. والآخر: أن لدن أثقل من (من).وقال أبو علي فيما استدرك عليه: (النون مع الياء التي للمتكلم إنما اجتلبت ليسلم سكون الحرف، كما اجتلبت في (قد)، كذلك ثم استجيز الحذف في لدن، كما استجيز في (قد): (قدي)، فيجب أن ينظر في أي: موضع يجوز الحذف في (قدي)، فيجوز في لدن على ذلك الحد. فوجدنا الحذف في (قد) إنما وقع في الضرورة في الشعر دون الكلام، ولم يجيء الحذف في غير الشعر فإذا كان كذلك فلا يستحسن على هذا الحذف في القراءة من لدني؛ لأنه ليس بموضع ضرورة، ولم يفصل أبو إسحاق ما يجوز في الشعر، مما يجوز في الكلام والقرآن، حتى صار الجائز في الضرورة يتوهم من كلامه جوازه في الكلام. فإن قيل: إن الحذف للنون في (لدني) أدنى مزية في الحسن على (قدي)، لاجتماع المثلين فيه وهم يكرهون اجتماعهما، فيكون الحذف فيه أمثل منه في (قدي)، فيجوز في الكلام. قلنا: ليس بأمثل؛ لأن المثلين ليسا بلازمين، فلا يستحسن فيهما ما يستحسن في اللازمين من الحذف للتخفيف، على أنه قد يجرى غير اللازم مجرى اللازم في الإدغام نحو: علماء بنو فلان، وكثير من الأحكام. وإجازة (لدني) في الكلام قياسًا على هذا وجيه، والأول أعجب إلينا. وأما فصله بين (لدني)، و (مني)، بأن أحدهما اسم والآخر حرف، فغير صحيح؛ لأنه لو امتنع الحذف في [منِّي وعنِّي؛ لأنهما حرفا معنى لامتنع في إنِّي وأَنني، ولَعَلِي ولَعَلَنِي، وكأني وكأنَنِي، وليتني وليتي فلما لم يمتنع الحذف في] {9} النون من هذه الكلم وهي حروف، دل أن الحذف في النون من منِّي لم يمتنع من حيث كان حرفا ، ولذلك لم يجر الحذف في لدني من حيث كان اسمًا ، وليس في كون الكلمة اسمًا ما يوجب الحذف منه أو يجوزه فيه، بل ظاهر الأمر يوجب أن تبقية الزيادة في الاسم أولى، إذ الاسم للزيادة أحمل، وإنما امتنع الحذف في مني وعني؛ لأن هذه النون [اجتلبت ليسلم به سكون الحرف كما] {10} اجتلبت لتسلم به الحركة في ضرني ويضربني، فحذفه هو خلاف ما قصدوا له وإبطاله، والحذف في قدي إنما جاز في الشعر للضرورة، والشاعر إذا اضطر حذف ورد الكلمة إلى الأصل، ولو اضطر فحذف في مني وعني لجاز ذلك أيضًا وكان أمثل من قدي؛ لأنه مثلان في قد، وما لم تجتمع المتماثلة أو المتقاربة لم يحسن الحذف في الكلام، وإنما يجيء في الضرورة، ألا ترى أن ليت لما لم يجتمع المماثلة فيه لم يحذف في الكلام، وإنما جاء الحذف في بيت الكتاب. وأما قوله: (ولدن أثقل من مني، فلذلك حذف) فليس بشيء أيضًا، ألا ترى أنه قد حذف من قد وهو مثل: من في أنه على حرفين، فليس الحذف في هذه الحروف معتبرًا به لثقلها ولخفتها، وإنما الإثبات في هذه الحروف لما ذكرت من أنه ليسلم السكون أو الحركة، والحذف للضرورة إلا عند اجتماع الأمثال نحو: كأن، وأن، أو المتقاربة: كلعل، فإن هذا يجوز في الكلام، والأحسن فى لدن ألا يحذف في الكلام ويلحق بباب قد) {11}.وروى أبو عبيدة عن الكسائي عن أبي بكر عن عاصم: (من لدن بضم اللام وتسكين الدال) {12}. قال ابن مجاهد: (وهو غلط) {13}.قال أبو علي: (يشبه أن يكون التغليط منه في وجه الرواية، فأما من جهة اللغة ومقاييسها فهو صحيح، ألا ترى أن عَضُد إذا خفف فتخفيفه على ضربين أحدهما: أن تحذف الضمة وتبقى فتحة الفاء على حالها، فيقال: عَضْدٌ. والآخر: أن تلقى الحركة التي هي الضمة على الفاء، وتحذف الفتحة فيقال: عُضْدٌ {14}. وكذلك {15}: أرني، ولدني، إلا أن التخفيف في لدني مستقبح من حيث أنه امتناع بعد الحذف والنون، وإن كسرت من أجل مجاورة الياء في نية سكون، فكما أنه إذا سكنت النون لم يجز الإسكان في الدال، كذلك إذا حركت وكانت في نية سكون، ألا تراهم قالوا: لم يردد الرجل، فلم يدغموا لما كان الآخر في نية سكون، كما لم يدغموا إذا كان على لفظ السكون، ووجه الجواز فيه ما مر من: أنه قد يجري المنفصل مجرى المتصل في نحو: وَهُوَ، ولَهُو، هذا الذي ذكرنا الكلام في وجوه القراءة {16}. فأما حكم هذه الكلمة: فاعلم أن لدن اسم غير متمكن، حذفت اللام منها في حال الإضافة إلى المظهر في نحو قولهم: مِنْ لدُ الحائط. وقول الشاعر {17}:من لد شولا فإلى إتلائهاو {18}:من لد لحييه إلى منحورهوكان القياس ألا يحذف منه شيء لمشابهة الاسم للحرف في البناء، والحرووف لا تحذف إذا لم تكن مضاعفة، وليس هنا تضعيف، إلا أنه لما كان اسمًا وإن كان مشابهًا لحروف اللين استجيز الحذف فيه في حال الإضافة إلى المظهر، فألزم الرد في حال الإضافة إلى المضمر، ليكون ذلك دلالة علي أن الحذف لم يكن بقياس فيه، فكأنه جرى مجرى الأشياء التي تحذف في اللفظ للتخفيف، والمراد إثباتها، فإذا اتصل بالمضمر رد إلى أصله كقولهم: أعْطَيْتُكُمُوه ونحوه، كذلك قيل في هذا: من لدنه ولدنا). هذا كلام أبي علي {19}.وقال ابن كيسان: (لَدُن حرف يَخْفِض، وربما نُصِب بها، وقال: وحكى البصريون: أنها تنصب غدوة خاصة من بين الكلام) {20}. وأنشدوا {21}:مازال مهري مزجر الكلب منهم ... لدن غدوةً حتى دنت لغروبوأجاز الفراء في: غُدْوَة: الرفع، والنصب، والخفض {22}. قال ابن كيسان: (من خفض بها أجراها مجرى: مِنْ، وعَنْ، ومن رفع أجراها مجرة مذْ، ومن نصب جعلها وقتا، وجعل ما بعدها ترجمة عنها) {20}. وإن شئت أضمرت كان، كما قال {24}:من لد شولا فإلى إتلائهاأراد: من لد كانت شولا. وحكى أبو عمرو عن أحمد بن يحيى، والمبرد أنهما قالا: (العرب تقول لَدُن غُدْوَةٌ، وغُدْوَةً، وغُدوةٍ، فمن رفع أراد: لدن كانت غدوةٌ، ومن نصب أراد: لَدُنْ كان الوقت غدوةً، ومن خفض أراد: من عند غدوةٍ) {25}.وقال أبو الفتح الموصلي: (إنهم شبهوا النون في لدن بالتنوين في ضارب فنصبوا غدوة، نحو: هذا ضارب زيدًا، ووجهه الشبه بينهما اختلاف حركة الدال قبل النون، وذلك لأنه يقال: لدن، ولدن بفتح الدال وضمها، فلما اختلفت الحركات قبل النون شابهت النون التنوين، وشابهت الحركتان قبلها باختلافهما حركات الإعراب في نحو: ضَارِبٌ، وضاربًا، فلما أشبهت النون التنوين من حيث ذكرنا انتصب غدوةً تشبيهًا بالمفعول، وكذلك شبه بعضهم غدوةً بالفاعل، فرفعها فقال: لدن غدوةٌ، كما تقول: أقائم زيد؟ ومنهم من يلزم القياس فيها، فيجر بها فيقول: لدن غدوةٍ) {26}.قال سيبويه: (ولا تنصب مع لدن غير غُدوة، فلا تقول: لدن بكرةً؛ لأنها لم تكثر في كلامهم كثرة غدوة) {27}.قال أبو الفتح: (ويزيد عندك في شبه نون لدن بتنوين اسم الفاعل، أن العرب قد حذفتها في بعض المواضع تخفيفًا، فقالت: من لَدُ الحائط، ولَدُ الصلاةِ، وقد حذفوها أيضًا ولا ساكن بعدها. أنشد سيبويه {24}:من لد شولا فإلى إتلائهافلما حذفت النون تارة، وثبتت أخرى، قوي شبه النون بالتنوين الذي حذف تارة وثبت أخرى) {29}.وقال القاضي أبو سعيد السيرافي في {30} حكم لدن: (أن يخفض بها على الإضافة؛ لأن النون من أصل الكلمة بمنزلة الدال من عند، كما قال الله تعالى: ﴿مِنْ لَدُنْ حَكِيمٍ عَلِيمٍ﴾ [النمل: 6] ﴿مِن لَّدُنْ حَكِيمٍ خَبِيرٍ﴾ [هود: 1] غير أن من العرب من ينصب بها، وإنما يفعل ذلك؛ لأنه ينزع النون عنها فيقال: لَدُ، فشبهت الأصلية بالزائدة حين ثبتت في حال وسقطت في حال، كما ثبتت الزائدة في حال وسقطت في حال) {31}.وكنت قد وعدت في أول هذه السورة، عند قوله: ﴿مِن لَّدُنْهُ﴾ [الكهف: 2] بسط الكلام في هذا الحرف، وقد ذكرت ذلك على حد الإيجاز والله المستعان."
  18,77,"قوله تعالى: ﴿فَانْطَلَقَا حَتَّى إِذَا أَتَيَا أَهْلَ قَرْيَةٍ﴾ هي: أنطاكية {1} في قول ابن عباس {2}. والأيلة، في قول ابن سيرين {3}.وقوله تعالى: ﴿فَأَبَوْا أَنْ يُضَيِّفُوهُمَا﴾ روى أبي بن كعب أن النبي -ﷺ- قال: ""كانوا أهل القرية لئام"" {4}. والتضييف والإضافة فيه بمعنى واحد، يقال: ضافَه وتَضَيَّفه إذا نزل به وصار له ضيفًا، وأضافه وضيَّفه إذا أنزله وقراه، وأصل هذا في اللغة: من الميل والإمالة، يقال: ضاف يضِيف إذا مال، وأضافه إذا أماله، يقال: هذا مُضاف إلى كذا، أي: ممال إليه، ومنه قيل للدَّعي: مُضاف؛ لأنه مستند إلى قوم ليس منهم {5}.ومنه: (قوله -ﷺ- في النهي عن الصلاة: ""إذا أضفت الشمس للغروب"") {6}. أي: مالت.قال أبو عبيد: (ومنه سمي الضَّيف ضيفًا، يقال: ضِفْت فلانًا إذا ملت إليه، وأضفته: إذا أَمَلْتَه إليك) {7}. ومن الناس من فرق بين التضييف والإضافة، قال شمر: (سمعت رجاء بن سلمة {8} يقول: التَّضيف الإطعام، تقول: ضيَّفته إذا أطعمتَه، وأضافه إذا لم يُطْعِمْهُ. وقال في هذه الآية معناه: فأبوا أن يطعموهما) {9}.وقال أبو الهيثم: (هما عندنا بمعنى واحد) {10}. وقال الفراء في هذه الآية: (لو قرئت يُضيِفُوهُما كان صوابًا) {11}.وقوله تعالى: ﴿فَوَجَدَا فِيهَا جِدَارً﴾ هو الجَدْرُ، والجِدَارُ، ومنه الحديث: ""حتى يبلغ الماء الجَدْرُ"" {12}. ومكان جَدِير ومجدور: قد بني حواليه جدار؛ وأصله من الرفع، ومنه: أجدرت الشجرة إذا أخرجت في الربيع وأطلعت، ومنه: الجدري {13}.وقوله تعالى: ﴿يُرِيدُ أَنْ يَنْقَضَّ﴾ الإرادة في صفة الجِدَار مجاز على جميع أهل المعاني، ومعناه: قرب أن ينقض، وذلك على التشبيه بحال من يريد أن يفعل {14}.قال الفراء: (وذلك من كلام العرب أن يقولوا: الجدار يريد أن يسقط) {15}. ومثله قوله تعالى: ﴿ولَمَّا سَكَتَ عَن مُّوسَى الْغَضَبُ﴾ [الأعراف: 154]، وقوله: ﴿فَإِذَا عَزَمَ اَلأَمْرُ﴾ [محمد: 21]، يريد: أن إضافة السكوت إلى الغضب، والعزم إلى الأمر، كإضافة الإرادة إلى الجدار.وقال الكسائي: (قوله للجدار: ﴿يُرِيدُ﴾ من أفصح كلام العرب، وإنما إرادة الجدار ميله) {16}.قال أبو عبيد: (وهذا كقوله -ﷺ-: ""لا تتراءى ناراهما"") {17}. وإنما هو أن تكون ناران كل واحدة من صاحبتها بالموضع الذي لو قام فيه إنسان رأى الأخرى في القرب {18}.وقال ابن قتيبة: (الجدار إذا أشرف على الانهيار يقال فيه: جدار يهم أن ينقض، أو يكاد، أو يقارب، وأياما يقال فقد جعل فاعلا، ولا يوصل إلى هذا المعنى إلا بمثل هذه الألفاظ. قال: والعرب تقول بأرض بني فلان شجر قد صاح، إذا طال وتبين للناظر بطوله جعلوه كأنه صائح؛ لأن الصائح يدل على نفسه بصوته) {19}. ويقال: شجر واعد إذا نور؛ كأنه ما نور وعد أن يثمر، وكل هذا مجاز كلام العرب واستعارتهم، وأنشد أبو عبيدة في مثل هذه الآية {20}: يريد الرمح صدر أبي براء ... ويرغب عن دماء بني عقيلوأنشد الفراء {21}:إنَّ دهرًا يلف شملي بجملٍ ... لزمان يهم بالإحسانوأنشد أبو عبيد لذي الرمة، يذكر حوضًا دارسًا قد كان {22}:... قد هم بالبيودومثل هذا كثير مستفيض في كلامهم. وقال أبو إسحاق: (الجدار لا يريد إرادة حقيقية، إلا أن هيئته في التهيؤ للسقوط قد ظهرت، كما تظهر أفعال المريدين القاصدين، فوصف بالإرادة إذا كانت الصورتان واحدة) {23}. وأنشد الراعي يصف إبلا {24}:في مهمة فلقت به هاماتها ... فلق الفؤوس إذا أردن نصولاوقوله تعالى: ﴿أَنْ يَنْقَضَّ﴾ معنى الانقضاض: السقوط بسرعة يقال: انقض الحائط إذا وقع، وانقض الطائر إذا هوى من طيرانه ليسقط علي شيء. وقال الليث؛ (يقال: قضضنا عليهم الخيل فانقضت عليهم أي: أوقعنا عليهم فوقعت، وأنشد {25}:قضوا غضابًا عليك الخيل من كثبٍوهذا قول مجاهد في هذه الآية: (يريد أن يسقط) {26}.وقال آخرون: (معنى ﴿يَنْقَضَّ﴾ ينكسر، يقال: قضضت الشيء إذا كسرته ودققته، ومنه قيل للحَصَى الصغار: قضض {27}. وكلا اللفظين ذكرهما المفسرون في تفسير ﴿يَنْقَضَّ﴾ فقالوا (ينكسر ويسقط)، وذكرهما ابن قتيبة {28}.وقوله تعالى: ﴿فَأَقَامَهُ﴾ روى ابن عباس عن أبي بن كعب عن النبي -ﷺ- قال: (انتهى إلى جدار مائل فدفعه بيده فقام) {4}.وقال مجاهد: (مسحه بكفه حتى استوى) {30}.ومعنى أقامه: سواه، وذلك أن قوله: ﴿يُرِيدُ أَنْ يَنْقَضَّ﴾ معناه: مال، كأنه قال: فوجدا جدارًا قد مال فأقامه. فقال موسى: ﴿لَوْ شِئْتَ لَتَّخَذتَ عَلَيْهِ﴾ أي: على إقامته وإصلاحه ﴿أَجرًا﴾ قال الفراء: (لو شئت لم تقمه حتى يقرونا فهو الأجر) {15}.وقال أبو إسحاق: (وذلك أنهما لما نزلا القرية لم يضيفهما أهلها، فقال موسى: لو شئت لأخذت أجرة إقامتك هذا الحائط) {32}.وروى هارون. بن عنترة {33} عن أبيه عن ابن عباس في هذه الآية قال: (كان قول موسى في الجدار لنفسه لطلب شيء من الدنيا، وكان قوله في السفينة وفي الغلام لله) {34}.وقراءة العامة: ﴿لَتَّخَذْتَ﴾، افتعلت من الأخذ. وقرأ ابن كثير، وأبو عمرو: لَتَخِذْتَ {35}. وهي قراءة مجاهد، واختيار أبي زيد الأنصاري قال: (وكذلك هو مكتوب في الإمام، ومن قرأ: لاتخذت، فإنه يخالف الكتابة) {36}.قال الليث: (يقال: اتَّخذ فلان يتَّخِذ اتِّخاذًا، ويقال: تَخِذَ يتخذ تخذًا، وتَخِذْتُ مالاً كسبتُه، ألزمت التاء الحرف كأنها أصلية) {37}. قال الفراء: (وأصلها اتَّخَذَ افْتَعَل) {15}.وحكى {39} النضر: (اسْتَخَذْتُ عليهم يدًا أي: اتَّخَذْتُ) {40}. ومثل هذا حكى سيبويه: (استخذ فلان أرضًا) {41}.قال أبو علي الفارسي: (وتأويله على أمرين أحدهما: أنه اتخذ فأبدل السين من التاء الأولى. والآخر: أنه استفعل من تخذ فحذف التاء التي هي فاء من تخذت) {42}. وكلهم أنشدوا {43}:وقد تخذت رجلي إلى جنب غرزها ... نسيفًا كأفحوص القطاة المطرَّقفحصل من هذا أن تَخِذ لغة بمعنى اتخذ، وأصله: اتخذ، على ما قال الفراء، كأنهم لما رأوا التاء في اتخذ ظنوها أصلية فقالوا في الثلاثي: تخذ، كما قالوا: اتقى من يتقي {44}.قال أبو إسحاق: (وأصل تَخِذْتُ: أخَذْتُ) {45}. وأنكر عليه أبو علي وقال: (تَخِذْتُ فعلت وأَخَذْتُ فعلت، وإبدال الحرف من الكلمة ليس يوجب تغيير بنائها عما كان عليه قبل البدل، لكن ينبغي أن يحافظ على البناء الأول، ليكون أدل على أنه قد أبدل منه شيء، ولا يظن أنه بناء آخر وصياغة أخرى) {46}.وقال ابن الأنباري: (العرب تجعل تَخَذَ وتَخِذَ مستغنيا عما سقط منه، قائمًا بنفسه، جاريًا مجرى طعم أطعم، وعلمت أعلم، وبنوا يقنت على أيقنت، واتقى على يتقى، فلم يغيروا شيئًا من ماضيه ولا مستقبله ليجرى مجرى ما الساقط مظهر معه، وهو بالأفعال، وهذا لافتنانهم وإسباغ مبانيهم في لغاتهم) {47}.وقال أبو العباس: (الاختيار لاتخذت؛ لأنه هو أصل الحرف يعرى من الحذف واللبس، قال: والقراءة الأخرى من لغة معروفة) {48}."
  18,78,"قوله تعالى: ﴿قَالَ هَذَا فِرَاقُ بَيْنِي وَبَيْنِكَ﴾ معناه: هذا الذي عليه فراق بيني وبينك، هذا الكلام، والإنكار على ترك الأجر هو المفرق بيننا {1}. وذلك أن موسى قد كان قال له: ﴿إِن سَأَلْتُكَ عَن شَئٍ بَعْدَهَا﴾ الآية. وقيل معناه: (هذا وقت فراق بيني وبينك) {2}.وقال الزجاج: (المعنى هذا فراق بيننا، أي: هذا فراق اتصالنا، وكرر ""بين"" تأكيدًا، ومثل هذا من الكلام: أخزى الله الكاذب مني ومنك) {3}. قال ابن الأنباري: (ويجوز أن يكون ""بين"" هاهنا ظرف وموضعًا) {4}. فلما قال الخضر هذا أخذ موسى بطرف ثوبه فقال: حدثني. فقال الخضر: ﴿سَأُنَبِّئُكَ﴾ الآية {5}."
  18,79,"ثم فسر له فقال: ﴿أَمَّا السَّفِينَةُ فَكَانَتْ لِمَسَاكِينَ يَعْمَلُونَ فِي الْبَحْرِ﴾ هذه الآية دلالة على أن الفقير أسوأ حالاً من المسكين؛ لأن الله تعالى أخبر أنهم كانوا مساكين مع أنهم كانوا يملكون سفينة وهي تساوى جملة من الدنانير {1}، وذكرنا هذا عند قوله: ﴿إِنَّمَا الصَّدَقَاتُ لِلْفُقَرَاءِ وَالْمَسَاكِينِ﴾ [التوبة: 60] الآية، ويجوز أن تكون المسكنة هاهنا لم يعن بها الفقر وقلة ذات اليد، لكن أريد بها عدم الناظر وانقطاع الحيلة، كما يقال للذي يظلمه عدوه: مسكين فلان. يراد بالمسكين المستضعف المهتضم، وإن كان كثير المال واسع الملك.ومن هذا الباب ما روي في الحديث: ""مسكين لا زوجة له"" {2}. يعني في العجز عن الصبر في بعض الأحوال وضعف الحيلة، وإن كان له مال كثير {3}.وقوله تعالى: ﴿فَأَرَدتُّ أَنْ أَعِيبَهَا﴾ قال مجاهد: (أخرقها) {4}. وعَابَ في اللغة يكون على معان ثلاثة يقال: عَابَ فلان فلانًا يعيبه عَيبًا، ورجل عَيَّاب، وعاب الحائط، والشئ إذا صار ذا عيب {5} {6}.وقوله تعالى: ﴿وَكَانَ وَرَاءَهُمْ مَلِكٌ﴾ أكثر أهل العلم من المفسرين وأصحاب المعاني قالوا: ﴿وَرَاءَهُمْ﴾ هاهنا معناها أمامهم) {7}. وكذا كان ابن عباس يقرأ: (وكان أمامهم ملك) {8}. ووراء بمعنى: أمام، ورد كثيرًا في التنزيل والشعر، فمن ذلك قوله تعالى: ﴿وَمِنْ وَرَائِهِ عَذَابٌ غَلِيظٌ﴾ [إبراهيم: 17]، ﴿وَمِنْ وَرَائِهِمْ بَرْزَخٌ﴾ [المؤمنون: 100] ، وقول لبيد {9}:أليس ورائي إن تراخت منيتيوهذا قول أبي حاتم، وأبي عبيد، وابن السكيت، وأبي عبيدة، والفراء، والزجاج {10}، وذكرنا هذا في سورة إبراهيم {11}.وأنشد أبو عبيدة: لسوار بن المضرب السعدي {12}:أيرجو بنو مروان سمعي وطاعتي ... وقومي تميم والفلاة ورائياأي: أمامي {13}. قال: ووراء الرجل خلفه، ووراءه قدامه، وأنشد أيضًا {14}: أليس ورائي أن أدبَّ على العصا ... فيأمن أعدائي ويسأمني أهليولا خلاف بين أهل اللغة أن وراء يجوز أن تكون بمعنى قدام، واختلفوا في معنى ذلك، فقال الفراء: (لا يجوز أن يقال لرجل بين يديك: هو وراءك، إنما يجوز ذلك في المواقيت من الأيام والليالي والدهر، تقول: وراءك برد شديد، وبين يديك برد شديد، جاز الوجهان؛ لأن البرد إذا لحقك صار من ورائك، وكأنك إذا بلغته كان بين يديك) {15}.وقال غيره: (يجوز استعمال وراء بمعنى أمام على الاتساع؛ لأنها جهة مقابلة لجهة، فكأن كل واحد من الجهتين وراء الآخر، إذا لم يرد معنى المواجهة، ويجوز ذلك في الأجسام التي لا وجه لها مثل: حجرين متقابلين كل واحد منها وراء الآخر) {16}.وأكثر أهل اللغة على أن وراء من الأضداد.قال أبو علي: (وقد حكى متقدمو أهل اللغة وقوع الاسم على الشيء وعلى ضده، وصنفوا فيه الكتب؛ كقطرب، والتوَّزي {17}، ويعقوب وغيرهم، وربما أنكر ذلك بتعسف وتأويلات غير سهلة، وليس ينكر ان اللفظ الواحد يقع على الشيء وعلى خلافه، فلذلك لا ينبغي أن ينكر وقوعه على الشيء وضده؛ لأن الضد ضرب من الخلاف، فإن زعموا أن ذلك يلبس [فهو في الخلاف أيضًا يلبس)] {18} {19}.وروى الأزهري بإسناده عن ابن السكيت قال: (وراء، وأمام، وقدام يؤنَّثن ويُذَكَّرن، ويصغر أمام فيقال: أُمَيِّم ذلك وأُمَيِّمة، وقُدَيْدِيم ذلك وقديديمه، وهو وريئ ذلك {20} الحائط، ووريئة الحائط) {21}.قال أبو علي: (اللام من هذه الكلمة همزة، والقول في تحقيرها: وُرَئِّيةٌ مثل: وديعة، حكى ذلك أبو عثمان وغيره، ولو كان من باب الوري والتواري لكان تحقيره: وريَّةً، قال: ومن نادر ما جاء في هذه الكلمة دخول الهاء في تحقيرها مع أنها على أربعة أحرف، وكذلك دخلت في قُدَيْديمة تحقير قُدَام، وأنشد {22}:قديديمة التجريب والحلم إنني ... أرى غفلات العيش قبل التجاربوما كان على أربعة أحرف لا تدخله هاء التأنيث {23}، كما تدخل عامة ما كان على ثلاثة أحرف، وذلك أن الحرف الأصلي قام مقام الزائد، كما قام مقامه في قولهم: لم يَغْزُ، ولم يَرْمِ، ولم يَخْشَ، ألا ترى أن هذه اللامات حذفت كما تحذف الحركات للجزم، فأما دخولها على قُدَيْديمةٍ، ووُرَيِّئةٍ فمن الأشياء التي شذت فترد إلى الأصل المرفوض نحو: استحوذ، والقصوى، والقود) {24}. وهذا الذي ذكره أبو علي خلاف ما ذكره ابن السكيت؛ لأنه لم يجعل الهمز أصلاً {21}.قال أبو علي: (ووراء معرفة لا يصرف للتأنيث والتعريف) {26}. والآية تدل على أن معنى وراء أمام؛ لأنه لو كان بمعنى خلف كانوا قد جاوزوه فلا يأخذ سفينتهم. واختار الزجاج أن يكون وراء بمعنى: خلفهم قال: (هذا أجود الوجهين- وعلى هذا قال: يجوز أن يكون: كان رجوعهم في طريقهم عليه، ولم يكونوا عالمين بخبره، فأعلم الله الخضر خبره حتى عاب السفينة لتسلم من الغصب) {27}.وقوله تعالى: ﴿يَأْخُذُ كُلَّ سَفِينَةٍ غَصْبًا﴾ قال أهل المعاني: (أراد كل سفينة صالحة) {28}. وكذا كان يقرأ ابن عباس، وأبي، وحذفت في قراءة الناس للعلم بها {29}.وروي في حديث أبي عن النبي -ﷺ- في هذه القصة: ""أن الخضر قال {30}: وكان وراءهم ملك يأخذ كل سفينة غصبا، فإذا مرت عليه فرآها منخرقة تركها، ورقعها أهلها بقطعة خشب فانتفعوا بها"" {31}."
  18,80,"قوله تعالى: ﴿وَأَمَّا الْغُلَامُ فَكَانَ أَبَوَاهُ مُؤْمِنَيْنِ﴾ الآية. روى ابن عباس عن أبي بن كعب قال: (سمعت رسول الله -ﷺ- يقول: في قوله: ﴿وَأَمَّا الْغُلَامُ فَكَانَ أَبَوَاهُ مُؤْمِنَيْنِ﴾ قال: كان طبع يوم طبع كافرًا، وكان قد ألقى عليه محبة من أبويه) {1} (لأرهقهما طُغْيَانًا وَكُفْرًا) وكذا كان يقرأ ابن عباس، وأبي: (وأما الغلام كان كافرًا وكان أبواه مؤمنين) {2}.وقوله تعالى: ﴿فَخَشِينَا﴾ قال الفراء (فعلمنا) {3}. وهو قول ابن عباس في رواية عطاء {4}. وهي قراءة أبي: (فخاف ربك) {5}. على معنى: علم ربك، وذكرنا الخوف بمعنى: العلم عند قوله: ﴿فَمَنْ خَافَ مِن مُوصٍ﴾ [البقرة: 182] الآية. وقال قطرب والأخفش: (معناه فكرهنا) {6}.قال أبو إسحاق: (الخشية من الله معناه الكراهة، ومعناها من الآدميين الخوف) {7}. قال ابن الأنباري: (الخشية صلحت خبرا عن الله بمعنى الكراهية، فإذا وصف المخلوق بها أفادت هلعًا وفزعًا، وإذا أخبر بها عن الخالق دلت على تأويل الكراهة، كما كان الاستهزاء من المخلوق سفها، ومن الخالق استدراجا) {8}.﴿فَأَرَدْنَا أَنْ يُبْدِلَهُمَا رَبُّهُمَا خَيْرًا مِنْهُ زَكَاةً وَأَقْرَبَ رُحْمًا﴾ [الكهف: 81].وقال قوم: (هذا من كلام الخضر، ولا يجوز أن يكون فخشينا عن الله بل الخضر -عليه السلام- خشي أن يرهق الغلام أبويه طغيانًا وكفرا فلذلك قتله، قالوا: والدليل على أن هذا من كلام الخضر قوله تعالى: ﴿فَأَرَدْنَا أَنْ يُبْدِلَهُمَا رَبُّهُمَا﴾ ولو كان من كلام الله لقال: فأردنا أن نبدلهما خيرًا منه ولم يعد ذكر الرب) {9}. والظاهر يعضد هذا، غير أن أبا إسحاق قال: (هذا جائز أن يكون عن الله بمعنى فكرهنا، وقوله: ﴿فَأَرَدْنَا﴾ بمعنى فأراد الله، ولفظ الإخبار عن الله كذا أكثر من أن يحصى) {7}. هذا كلامه. وقول من قال: إنه من كلام الخضر ظاهر جلي.وقوله تعالى: ﴿أَنْ يُرْهِقَهُمَا طُغْيَانًا وَكُفْرًا﴾ أي: يغشيهما ويكلفهما، وذكرنا الكلام في هذا الحرف عند قوله: ﴿وَلَا تُرْهِقْنِي مِنْ أَمْرِي عُسْرًا﴾ [الكهف: 73].قال المفسرون: (خشينا أن يحملهما حبه على أن يتبعاه ويدينا بدينه) {11}. وقال ابن عباس في رواية عطاء: (كان الغلام يؤذي الجيران، ويفعل القبيح، وكان أبواه يحلفان عنه بالكذب طغيانًا وكفرًا) {12}."
  18,81,"وقوله تعالى: ﴿فَأَرَدْنَا أَنْ يُبْدِلَهُمَا﴾ وقرئ: بالتخفيف {1}. وبدل وأبدل متقاربان في المعنى، كما أن نزل وأنزل كذلك. وفرق قوم بينهما، وذكرنا ذلك عند قوله: ﴿بَدَّلْنَاهُمْ جُلُودًا غَيْرَهَا﴾ [النساء: 56] الآية.قوله: ﴿خَيْرًا مِنْهُ زَكَاةً﴾ قال ابن عباس في رواية سعيد بن جبير: (خيرًا منه دينًا) {2}. وهو قول قتادة {3}. ومعنى هذا ما قاله الكلبي، والفراء: (خيرًا منه صلاحًا) {4}. والزكاة: الصلاح، والزاكي: الصالح، ذكرنا ذلك عند قوله: ﴿نَفْسًا زَكِيَّةً﴾ [الكهف: 74] وفسر الصلاح: بالدين؛ لأن الصلاح يكون من الدين. وكذلك تفسير ابن جريج الزكاة في هذه الآية: (بالإسلام) {5}. فيكون كتفسير ابن عباس بالدين.وقوله تعالى: ﴿وَأَقْرَبَ رُحْمًا﴾ والرُّحْمُ، والرُّحُمُ، والرَّحْم: العطف والرحمة {6}. قاله أبو عبيدة، والزجاج {7}. وأنشد أبو عبيدة للعجاج {8}:ولم تعوَّج رحم من تعوَّجاوأنشد غيره لرؤبة {9}:يا منزل الرَّحم على إدريس ... ومنزل اللعن علي إبليسويستعمل الرحم بمعنى القرابة لا بمعنى الشفقة. ويقال: فلان أشفق منك رحما، وفلان أمس رحما من فلان أي: قرابة. وأما الذي في الآية فقال قتادة: (أبر بوالديه) {10}. وهو قول ابن عباس قال: (أوصل للرحم، وأبر بوالديه) {11}. وروى عنه سعيد بن جبير: (وأقرب مودة) {12}. وهذا قول أكثر المفسرين جعلوا البدل: أبر بالوالدين.ومنهم من جعل الوالدين أبر بالبدل، وهو قول ابن جريج، والفراء. قال ابن جريج: (أرحم به منهما بالذي قتل الخضر) {13}. يعني رحمة الوالدين عليه أكثر.وقال الفراء: (أقرب أن يرحماه) {14}. فعلى هذا، الرحم من جهة الوالدين، وعلى القول الأول الرحم من جهة الولد، وكلهم على أن معنى الرحم هاهنا: الرحمة والشفقة والعطف، غير أن الزجاج قال في هذه الآية: (أقرب عطفا، وأمس بالقرابة) {15}. وَهِمَ؛ لأن الأولاد لصلب الوالدين سواء في القرابة، ولا يكون بعضهم أمس بالقرابة من بعض.قال النبي -ﷺ- في حديث أبي بن كعب: ""فوقع أبوه على أمه فنقلت: فولدت خيرًا منه زكاة وأقرب رحما"" {16}.وقال سعيد بن جبير عن ابن عباس: (ولدت جارية فولدت نبيا) {17}. وروى عكرمة عنه في قوله: ﴿خَيْرًا مِنْهُ زَكَاةً وَأَقْرَبَ رُحْمًا﴾ قال: (ولدا كان في بطن أمه) {18}. وقال مجاهد: (كان ذلك الولد جارية) {19}. وهو قول جميع المفسرين إلا ابن جريج، فإنه قال: (أبدلهما الله غلامًا مسلمًا، وكان المقتول كافرًا) {20}. وقال ابن عباس في رواية عطاء: (أبدلهما الله به جارية ولدت سبعين نبيا) {21}. وهذا قول الباقر {22}.والجمع بين هذا وبين قوله في رواية سعيد: (ولدت نبيا)، أن السبعين كانوا من نسلها ولم تلد لبطنها إلا نبيًا. قال مطرف {23} في هذه الآية: (أيم الله لقد كان أبوه فرحا بمولده، وحزينًا بمقتله، ولو عاش كان في بقائه هلكتهما، فقضاء الله خير من قضائك لنفسك، وما يقضيه الله لك بما تكرهه خير من قضائك لنفسك بما تحب يا بني، فاستخر الله وارض) {24}."
  18,82,"قوله تعالى: ﴿وَأَمَّا الْجِدَارُ فَكَانَ لِغُلَامَيْنِ يَتِيمَيْنِ فِي الْمَدِينَةِ﴾ يعني: القرية التي ذكرها في قوله: ﴿حَتَّى إِذَا أَتَيَا أَهْلَ قَرْيَةٍ﴾ [الكهف: 77]، وقوله تعالى: ﴿وَكَانَ تَحْتَهُ كَنْزٌ لَهُمَا﴾ روى أبو الدرداء أن رسول الله -ﷺ- قال: (كان ذهبًا وفضة) {1}. وهذا قول عكرمة وقتادة {2}.وقال ابن عباس في رواية عطاء: (كان لوحًا من ذهب فيه مكتوب: عجبا لمن أيقن بالقدر ثم هو ينصب، عجبا لمن أيقن بالنار ثم يضحك، عجبا للمؤمن كيف يفرح، عجبا لمن يوقن بالرزق كيف يتعب، عجبا لمن يؤمن بالحساب كيف يغفل، عجبا لمن رأى الدنيا وتقلبها بأهلها كيف يطمئن إليها، أنا الله لا إله إلا أنا محمد عبدي ورسولي. وفي الشق الآخر: أنا الله لا إله إلا أنا وحدي لا شريك لي، خلقت الخير والشر، فطوبي لمن خلقته للخير وأجريته على يديه، والويل لمن خلقته للشر وأجريته على يديه) {3}.وهذا قول الحسن {4}، وأكثر أهل التفسير {5}.وقال في رواية سعيد بن جبير، وكريب: (كان صحفا وعلما) {6}. وهو قول مجاهد: (كان صحفا للغلامين فيها علم) {7}.قال أبو إسحاق: (المعروف في اللغة أن الكنز إذا أفرد فمعناه: المال المدفون والمدَّخر، فإذا لم يكن المال قيل: عنده كنز علمٍ، وله كنز فهمٍ، والكنز هاهنا بالمال أشبه. قال: وجائز أن يكون الكنز كان مالاً مكتوب فيه علم على ما روي، فهو مال وعلم عظيم من توحيد الله وإعلام أن محمد -ﷺ- مبعوث) {8}. وعلى ما ذكره أبو إسحاق قول من قال: (إنه كان صحفا فيها علم)، بعيد.قال ابن الأنباري: (من قال: إن الكنز كان علمًا سمى العلم كنزًا؛ لأنه يتعجل من نفعه أفضل بما ينال من ناحية الأموال) {9}. فمعنى قوله: ﴿كَنْزٌ لَهُمَا﴾ مثل الكنز، كما يقال: هو الأسد شدة، والقمر حسنا معناه: مثل الأسد، ومثل القمر. وعلى قول من قال: إنه مال، لم يكن الكنز حرامًا على أهل ذلك الزمان.قال قتادة: (كانت الكنوز حلالاً لمن كان قبلنا، وكانت الغنائم محرمة عليهم، فأحل الله لنا الغنائم، وحرم علينا الكنوز) {10}.وقوله تعالى: ﴿وَكَانَ أَبُوهُمَا صَالِحًا﴾ قال سعيد بن جبير عن ابن عباس: (حفظا بصلاح أبيهما، ولم يذكر منهما صلاحا) {11}.قال جعفر بن محمد: (كان بينهما وبين ذلك الأب الصالح سبعة أباء) {12} {13}.﴿فَأَرَادَ رَبُّكَ﴾ يا موسى ﴿أَنْ يَبْلُغَا أَشُدَّهُمَا﴾ قال ابن عباس: (أن يكبرا ويعقلا) {14}. ﴿وَيَسْتَخْرِجَا كَنْزَهُمَا﴾ ومضى الكلام في بلوغ الغلامين الأشد. ولما أراد الله تعالى أن يبقي ذلك إلى بلوغ الغلامين حتى يستخرجاه أمر الخضر حتى أقام الجدار لأن لا ينهدم.وقولى تعالى: ﴿رَحْمَةً مِنْ رَبِّكَ﴾ منصوب على ضربين: أحدهما: على معنى أراد ذلك للرحمة، كما تقول: أنقذتك من الهلكة رحمة لك، والثاني: أن يكون منصوبًا على المصدر؛ لأن ما تقدم من الكلام معناه: رحمهما الله بذلك. وهذا معنى قول أبي إسحاق {8}.وقوله تعالى: (﴿وَمَا فَعَلْتُهُ عَنْ أَمْرِي﴾ قال ابن عباس: (يريد انكشف لي من الله علم فعملت به ﴿ذَلِكَ تَأْوِيلُ﴾ قال: يريد هذا تفسير ﴿مَا لَمْ تَسْطِعْ عَلَيْهِ صَبْرًا﴾) {16}. وتسطع بمعنى تستطيع، ويذكر الكلام فيه عند قوله: ﴿فَمَا اسْطَاعُوا أَنْ يَظْهَرُوهُ﴾ إن شاء الله."
  18,83,"قوله تعالى: ﴿وَيَسْأَلُونَكَ عَنْ ذِي الْقَرْنَيْنِ﴾ الآية. قد ذكرنا أن اليهود سألت النبي -ﷺ- عن الروح، وقصة أصحاب الكهف، وعن رجل طواف بلغ شرق الأرض وغربها؟ فكان من جوابه في الروح وقصة أصحاب الكهف ما تقدم {1}.واختلفوا في ذي القرنين فقال مجاهد: (كان نبيا) {2}. وهو قول عبد الله بن عمرو {3}. وقال علي -رضي الله عنه-: (كان عبدًا صالحًا أحب الله فأحبه الله، وناصح الله فنصحه الله) {4}.وروى عقبة بن عامر {5} أن النبي -ﷺ- قال: ""إن أول أمره أنه كان غلامًا من الروم أعطي ملكًا"" {6}. فهو ملك على هذا القول.وروى خالد بن معدان {7}: (أن عمر بن الخطاب -رضي الله عنه- سمع رجلاً يقول: يا ذا القرنين. فقال: اللهم غفرا، أما رضيتم أن تتسموا بالأنبياء حتى تسميتم بالملائكة) {8}. والله أعلم أي: ذلك كان.واختلفوا أيضًا في تسميته بذي القرنين فقال علي -رضي الله عنه-: (دعا قومه إلى الله فضربوا على قرنه {9} الأيمن فمات، فأحياه الله، ثم دعا قومه إلى الله فضربوا على قرنه الأيسر فمات، فأحياه الله فسمي ذو القرنين) {10}.قال أبو إسحاق: (ويجوز على مذهب أهل اللغة أن يكون سمي ذا القرنين؛ لأنه بلغ قطري الأرض، مشرق الأرض ومغربها) {11}. وهذا قول الزهري قال: (إنما سمي ذا القرنين؛ لأنه بلغ قرن الشمس من مغربها وقرنها من مطلعها) {12}.وقال محمد بن إسحاق عن وهب: (إنما سمي [ذا القرنين؛ لأن صفحتي رأسه كانتا من نحاس) {13}. ويقال: (إنما سمي] {14}؛ لأنه كانت له ضفيرتان) {15}.وقوله تعالى: ﴿قُلْ سَأَتْلُو عَلَيْكُمْ مِنْهُ ذِكْرًا﴾ أي: خبرا يتضمن في ذكره."
  18,84,"قوله تعالى: ﴿إِنَّا مَكَّنَّا لَهُ فِي الْأَرْضِ﴾ قال على -رضي الله عنه-: (سخر الله له السحاب فحمله عليها، ومد له في الأسباب، وبسط له النور وكان الليل والنهار {1} عليه سواء) {2}. وهذا معنى تمكينه في الأرض، وهو: أنه سهل عليه المسير فيها، وذلل له طرقها، وحزومها حتى تمكن منها أنى شاء {3}.وقوله تعالى: ﴿وَآتَيْنَاهُ مِنْ كُلِّ شَيْءٍ سَبَبًا﴾ قال علي عن أبي طلحة عن ابن عباس: (علما) {4}. وهو قول قتادة، وابن زيد، والضحاك، وابن جريج قالوا: (علما يتسبب به إلى ما يريد) {5}.وقال أبو إسحاق: (أي آتيناه من كل شيء يبلغ به في التمكن أقطار الأرض) {6}. ﴿سَبَبًا﴾ أي: علما يوصله إلى حيث يريد. قال المبرد: (وكل ما وصل شيئًا بشيء فهو سبب) {7}. وهذا بما يقدم فيه القول، وقال بعض المتأولين: (المعنى: وآتيناه من كل شيء بالخلق إليه ﴿سَبَبًا﴾ أي: علما ومعونة) {8}."
  18,85,"وقوله تعالى: ﴿فَأَتْبَعَ سَبَبًا﴾ قال مجاهد: (طريقًا بين المشرق والمغرب) {1}. وهو قول قتادة، والضحاك، وابن زيد، والكلبي وجميعهم {2}. قال أبو عبيدة: (اتبع طريقًا وأثرا) {3}. والمعنى على هذا: أنه، اتبع طريقًا يؤديه إلى مغرب الشمس. وعلى هذا السبب الثاني غير الأول؛ لأن معناه: الطريق، والأول بمعنى: العلم.وقال أبو إسحاق: (فأتبع سببا من الأسباب التي أوتي) {4}. وذلك أنه أوتي من كل شيء سببا فأتبع من تلك الأسباب التي أوتي سببا في المسير إلى المغرب. وعلى هذا القول هما سواء. والقراءة الجيدة: فاتبع، وقرئ: فأتبع بقطع الألف {5}. قال الأصمعي: (ومعناه: لحق، يقال: أتبعْتُ القوم لحقتهم، واتَّبع إنما هو أن يتتبع آثارهم وإن لم يلحقهم) {6}. وذكرنا هذا عند قوله: ﴿فَأَتْبَعَهُ الشَّيْطَانُ﴾ [الأعراف: 175]"
  18,86,"وقوله تعالى ﴿حَتَّى إِذَا بَلَغَ مَغْرِبَ الشَّمْسِ وَجَدَهَا تَغْرُبُ فِي عَيْنٍ حَمِئَةٍ﴾ أي: ذات حمأة وهي: الطين الأسود المنتن {1}. قال ابن السكيت: (أحمأتُ الركيَّة القيت فيها الحمأة، وحمأتُها إذا نزعت حَمْأتَها) {2}. ونحو هذا روى أبو عبيد عن أبي زيد [[و {2} ""تهذيب اللغة"" (حما) 1/ 909، ""لسان العرب"" (حمم) 2/ 1006.]].وقال الأصمعي في الأجناس: (على القلب من هذا) (¬4). قال الأزهري: (وليس ذلك بمحفوظ، والصواب ما قاله ابن السكيت) {4}.ويقال: حمئت البئر تحمأ حمأ إذا صارت ذات حمأة فهي حمئة، وهذه قراءة ابن عباس، ومجاهد، وفسراها: (حَمَأة سوداء، وطينة سوداء) {5}. ولما اختلف ابن عباس ومعاوية في حَمِئة وحامية، أرسلا إلى أبي بن كعب: (أين تجد الشمس تغرب؟ فقال: في طينة سوداء. فوافق ابن عباس) {6}.وقرأ ابن الزبير، وابن مسعود: حامِية، من غير همز (¬8). وهي فاعلة من حَمِيَت تَحْمَى فهي حامية أي: حارة، ويدل على صحة هذه القراءة ما روي: (أن النبي -ﷺ- نظر إلى الشمس حين غابت فقال: ""في نار الله الحامية، في نار الله الحامية"") {7}. وقال ابن عباس في رواية الوالبي والحسن في قوله: ""في عين حامية"" (عين حارة) {8}. وتترجح هذه القراءة؛ لأنها تجمع المعنيين {9}. وهو ما ذكره أبو إسحاق فقال: (وقد تكون حارة ذات حمأةٍ) {10}.وقال أبو علي: (يجوز أن تكون حامية فاعِلةً من الحَمَأة، فخفف الهمزة بأن قلبت ياء محضة، على قياس قول أبي الحسن، وعلى قول الخليل كانت بَين بَين) {11}.وقوله تعالى: ﴿وَوَجَدَ عِنْدَهَا قَوْمًا﴾ أي: عند العين: ﴿قُلْنَا يَا ذَا الْقَرْنَيْنِ﴾ قال ابن الأنباري: (من قال: إن ذا القرنين كان نبيا، فإن الله قال له كما يقول للأنبياء إما بتكلم، أو بوحي، ومن قال: لم يكن نبيا قال: معنى ﴿قُلْنَا﴾ هاهنا: ألهمنا) {12} ﴿إِمَّا أَنْ تُعَذِّبَ﴾ قال ابن عباس: (يريد إما أن [تقتل ﴿وَإِمَّا أَنْ تَتَّخِذَ فِيهِمْ حُسْنًا﴾ قال: وإما أن تسبيهم) {13}.قال المفسرون: (يريد إما أن] {14} تقتلهم إن أبوا ما تدعوهم إليه، وإما أن تأسرهم فتعلمهم وتبصرهم الرشاد) {15}. وعلى هذا المراد بالتعذيب: القتل، وباتخاذ الحسن فيهم: أن لا يقتلهم بل يأسرهم فيسلموا عنده.وقال الكلبي في قوله: ﴿وَإِمَّا أَنْ تَتَّخِذَ فِيهِمْ حُسْنًا﴾ (يريد تعفو أو تنعم) {16}. وعلى هذا المراد باتخاذ الحسن فيهم: عفوهم وتركهم. والأول القول؛ لأنه {17} لو أمر بتركهم والعفو عنهم لم يكن في الدعوة فائدة. قال أبو إسحاق: (أباح له الله عز وجل هذين الحكمين يعني: القتل، والأسر، كما أباح لمحمد الحكم بين أهل الكتاب أو الإعراض) {18}. يعني قوله: ﴿فَاحْكُمْ بَيْنَهُمْ أَوْ أَعْرِضْ عَنْهُمْ﴾ [المائدة: 42].قال ابن الأنباري: (موضع ﴿أَن﴾ نصب؛ لأن المعنى: اختر التعذيب أو اتخذا الحسن عندهم، فأفادت ﴿إِمَّا﴾ التخيير، قال: ويجوز أن يكون رفعا بتأويل: إما هو التعذيب، وإما هو الاتخاذ) {19}. قال قتادة: (فقضى فيهم بقضاء الله، وكان عالمًا بالسياسة) {20}."
  18,87,"فقال: ﴿أَمَّا مَنْ ظَلَمَ﴾ قال ابن عباس: (يريد أشرك) {1} ﴿فَسَوْفَ نُعَذِّبُهُ﴾: نقتله إذا لم يرجع عن الشرك. ﴿ثُمَّ يُرَدُّ إِلَى رَبِّهِ﴾ بعد قتلي إياه ﴿فَيُعَذِّبُهُ عَذَابًا نُكْرًا﴾ يعني في النار، وعذاب الله إياه بالنار أنكر من عذاب القتل. قاله الزجاج {2}."
  18,88,"﴿وَأَمَّا مَنْ آمَنَ وَعَمِلَ صَالِحًا فَلَهُ جَزَاءً الْحُسْنَى﴾ يكون هذا الجزاء من الله تعالى، والحسنى هاهنا على معنيين أحدهما: الجنة، وأضيف الجزاء إليها وهي الجزاء، كما قال: ﴿حَقُّ الْيَقِينِ﴾، ﴿وَلَدَارُ الْآخِرَةِ﴾، و ﴿دِينُ الْقَيِّمَةِ﴾ [البينة: 5]، وهذا قول الفراء {1}. والثاني: أن تكون الحسنى حسناته، ويكون المعنى: له جزاء الخلال الحسنة التي آتاها وعملها. وهذا القول ذكره الفراء أيضًا، واختاره أبو علي وحرره {2}. ويجوز أن يكون هذا الجزاء المذكور من ذي القرنين، وهو قول ابن عباس؛ كأنه قال: أتفضل عليه وأعطيه. وعلى هذا لا يكون معنى الحسنى: الجنة؛ لأن الجزاء بها لا يجزيه إلا الله عز ذكره، ومضى الكلام في الحسنى عند قوله: ﴿لِلَّذِينَ أَحْسَنُوا الْحُسْنَى﴾ [يونس: 26] الآية.وقرأ أهل الكوفة: فله جزاءً نصبا منونًا {3}. قال الفراء: (أي فله الحسنى جزاء، نصبت ﴿جَزَاءً﴾ هو على التفسير) {4}.وقال الزجاج: (﴿جَزَاءً﴾ مصدر منصوب في موضع الحال، المعنى: فله الحسنى مجزيًا بها جزاء) {5}. ونحو هذا قال أبو علي: (هو مصدر واقع موقع الحال، المعنى: فله الحسنى مجزية) {6}.قال الأخفش: (وهذا لا يكاد العرب تكلم به مقدما إلا في شعر) {7}. وذكر ابن الأنباري في انتصاب ﴿جَزَاءً﴾ وجهين أحدهما: (المصدر على معنى: فيجزى الحسنى جزاء، كما يقال: هو لك هبة. والآخر: أن ينتصب على التفسير بمعنى: فله الحسنى من جزاء، كما قالوا: لك أسمنها كبشا، أي: من كبش) {8}.وقوله تعالى: ﴿وَسَنَقُولُ لَهُ مِنْ أَمْرِنَا يُسْرًا﴾ قال الكلبي: (أي خيرًا) {9}. وقال مجاهد: (معروفًا) {10}. وقال أبو إسحاق: (أو نقول له قولا جميلاً) {5}.وقال عباس: (يريد كما يحيي المؤمنون بعضهم بعضًا، مثل قول النبي -ﷺ-: يكن لك ما لنا، وعليك ما علينا) {12}. فجعل القول باليسر هاهنا السلم والمشاركة معه في الخير والشر."
  18,89,"وقوله تعالى: ﴿ثُمَّ أَتْبَعَ سَبَبًا﴾ إخبار عن ذي القرنين أنه سلك طريقًا آخر مما يوصله إلى المشرق."
  18,90,"قوله تعالى: ﴿حَتَّى إِذَا بَلَغَ مَطْلِعَ الشَّمْسِ وَجَدَهَا تَطْلُعُ عَلَى قَوْمٍ لَمْ نَجْعَلْ لَهُمْ مِنْ دُونِهَا سِتْرًا﴾ قال قتادة: (لم يكن بينهم وبين الشمس ستر، وذلك أنهم كانوا في مكان لا يستقر عليه بناء) {1}.ونحو هذا قال الحسن {2}. وقال الكلبي بإسناده عمن لقيهم: (كان أحدهم يفرش أذنه ويلبس الأخرى، وقال: كانوا عراة حفاة) {3}. وعلى هذا القول لا ستر بينهم وبين الشمس مما يلبسون. وعلى القول الأول من البناء. وجمع بينهما أبو إسحاق فقال: (لم يكن لهم شيء يظلهم من سقف ولا لباس) {4}."
  18,91,"قوله تعالى: ﴿كَذَلِكَ﴾ اختلفوا في المشبه به، والمشار إليه فقال الزجاج: (يجوز أن يكون التقدير: وجدها تطلع على قوم، كذلك القبيل الذي كانوا عند مغرب الشمس وأن حكمهم حكم أولئك) {1}. وقال غيره: (المعنى كما بلغ مغرب الشمس فكذلك بلغ مطلعها) {2}. وقيل: (أتبع سببًا، كما أتبع سببا) {3}. والقول ما قاله أبو إسحاق؛ لأن التشبيه بالكاف يجب أن يرجع إلى أقرب المذكور إليه، والأقرب وجود القوم لا البلوغ والإتباع.وقوله تعالى: ﴿وَقَدْ أَحَطْنَا بِمَا لَدَيْهِ خُبْرًا﴾ قال مقاتل: (وقد أحطنا بما قبله علما) {4}. أي: علمنا ما كان عنده من الجيوش والعدة. وهذا معنى قول ابن عباس؛ لأنه يقول: (يقول الله سبحانه: مكنته {5} وملكته) {6}. يعني أنا أعطيته ما كان عنده، وإذا كان عطاؤه كان معلومه."
  18,92,"﴿ثُمَّ أَتْبَعَ سَبَبًا﴾ ثالثًا، مما يبلغه قطرا من أقطار الأرض."
  18,93,"قوله تعالى: ﴿حَتَّى إِذَا بَلَغَ بَيْنَ السَّدَّيْنِ﴾ قرئ: بالفتح، والضم {1}. قال أبو عبيدة: السُّد مضموم إذا كان مخلوقًا من فعل الله تعالى، فإن كان من فعل الآدميين فهو سَدّ مفتوح) {2}. وهذا قول عكرمة {3}، والأخفش {4}.وقال الكسائي: (ضم السين وفتحها سواء) {5}.وقال ابن الأعرابي: (كل ما قابلك فَسَدَّ ما وراءه فهو سَدّ وسُدّ، وهذا نحو: الضَعف والضُعف، والفَقر والفُقر) {6}. وقال أبو علي الفارسي: (يجوز أن يكون السَّد مصدرًا، والسُّد المسدود كالأشياء التي يفصل فيها من المصادر والأسماء، نحو: السِّقي والسُّقي، والطِّحن والطُّحن، والشِّرب والشُّرب، والقَبْض والقُبْض، وإذا كان كذلك فالأشبه بين السدين؛ لأنه المسدود، وأما من فتح السين جعله اسما للمسدود نحو: نَسجُ اليمن، وضَربُ الأمير) {7}.وقال الأخفش: (المفتوحة أكثر اللغتين) {8}.قال ابن عباس: (هما جبلان سَد ذو القرنين ما بينهما جاجزًا بين يأجوج ومأجوج ومن سواهم) {9}.وقوله تعالى: ﴿لَا يَكَادُونَ يَفْقَهُونَ قَوْلًا﴾ أي: يعلمونه فلا يستنبطون من فحواه شيئًا، وقرئ: يُفقهون بضم الياء {10}. والمعنى: لا يكادون يفقهون أحدًا قولاً، فحذف أحد المفعولين كما حذف من قوله: ﴿لِيُنْذِرَ بَأْسًا﴾ [الكهف: 2] وهذا الحذف غير ضيق. قال ابن عباس: (يريد لا يفهمون كلام أحد ولا يفهم الناس كلامهم) {11}."
  18,94,"قوله تعالى: ﴿قَالُوا يَا ذَا الْقَرْنَيْنِ﴾ إن قيل: كيف خاطبوا ذا القرنين وقد وصفهم الله تعالى بأنهم لا يَفهمون ولا يُفهمون؟والجواب عن هذا أن يقال: كلم عنهم قوم آخرون مترجمة عن لغتهم، فنسب القول إليهم، لما كان بأمرهم وإرادتهم، وهذا على قول من يجعل يكادون صلة كقوله: ﴿لَمْ يَكَدْ يَرَاهَا﴾ [النور: 40] {1}.ومن لم يجعل صلة قال: هم يفقهون وُيفقهون وإذا قلت: لا يكاد فلان يفعل كذا، كان المعنى أنه يقارب أن لا يفعل ولكن يفعل {2}. وذكرنا هذا عند قوله: ﴿وَمَا كَادُوا يَفْعَلُونَ﴾ [البقرة: 71].وقوله تعالى: ﴿إِنَّ يَأْجُوجَ وَمَأْجُوجَ﴾ أكثر أهل العلم على أن هذين اسمان أعجميان مثل: طالوت وجالوت، وهاروت وماروت، لا ينصرفان للتعريف والعجمة {3}. والقراءة فيها: بترك الهمز، وقرأ عاصم بالهمز {4}.قال الليث: (والهمز لغة رديئة) {5}.وذكر الأخفش، والزجاج، وأبو علي وجه جواز كون الاسمين عربيين فقالوا: (من همز يأجوج يجوز أن يكون عربيًا، ويكون على وزن يفعول مثل: يربوع من أَجَّةِ النار والحر، ومن لم يهمز أمكن أن يكون خفف الهمزة فقلبها ألفا مثل رأس وأما يأجوج فيمن همز: فمفعول {6} من أجَّ، والكلمتان من أصل واحد في الاشتقاق ومن لم يهمز فيجوز أن يكون خفف الهمزة كما ذكرنا، ويجوز أن يكون فاعول من مجَّ، والكلمتان على هذا من أصلين، وليستا من أجل واحد، ويكون ترك الصرف فيهما للتأنيث والتعريف، كأنه اسم للقبيلة كمجوس. وهذه التمثيلات لا يصح فيها إن جعلتها من العجمي؛ لأن العجمي لا يشتق {7} من العربية) {8}.قال ابن الأنباري: (وجه همزه على هذا القول أنه لا يعرف له أصل، كما أن العرب همزت حروفًا لا تعرف للهمزة فيها أصل، كقولهم: لبأت {9}، ورثأت {10}، واستنشأت الريح {11}، وإذا كان هذا معروفًا في أبنية العرب كان معروفًا في الألفاظ التي أصلها للعجم) {12}. هذا هو الكلام في أصل الكلمتين من العربية.وأما المسمون بهذين الاسمين فقال وهب: (هم من ولد يافث بن نوح، أب الترك) {13}. وهذا قول مقاتل بن سليمان {14}.وقال الضحاك: (هم جيل من الترك) {15}. وقال السدي: (الترك سرية من يأجوج ومأجوج خرجت تعبر، فجاء ذو القرنين فبنى السد على إحدى وعشرين قبيلة، وبقيت منهم قبيلة واحدة دون السد فهم الترك) {16}.وقال كعب: (هم نادرة في ولد آدم، وذلك أن آدم احتلم ذات يوم، وامتزجت نطفته بالتراب، فخلق الله من ذلك الماء يأجوج ومأجوج، فهم متصلون بنا من جهة الأب دون الأم) {17}.وقال ابن عباس في رواية عطاء: (هم عشرة أجزاء، وولد آدم كلهم جزء) {18}.وقوله تعالى: ﴿مُفْسِدُونَ فِي الْأَرْضِ﴾ قال قتادة: (هما: حيَّان حيَّا سوء، كانا أهل بغي وظلم على من جاورهما) {19}.وقال الكلبي: (كانوا يخرجون إلى أرض هؤلاء الذين شكوهم إلى ذي القرنين أيام الربيع، فلا يدعون فيها شيئًا أخضر إلا أكلوه) {20}.وقوله تعالى: ﴿فَهَلْ نَجْعَلُ لَكَ خَرْجًا﴾ وقرئ: خَرَاجًا {21}.قال ابن عباس: (يريد: جعلاً) {22}.قال الليث: (الخَرْجُ والخَرَاجُ شيء واحد، وهو شيء يُخرجه القوم من مالهم بقدر معلوم) {23}. والمعنى على هذا: هل نخرج إليك من أموالنا [شيئًا كالجُعل لك عطية نخرجه إليك من أموالنا] {24}، وكل ما استخرج من ضَرِيبة وجزية وغلة فهو خَراج وخَرْج، ومنه الحديث: ""الخَرَاخ بالضمان"" {25}. يعني الغَلَّة، سمي خراجا وخَرْجا؛ لأن المؤدي يُخرجه، والآخذ يستخرجه.وفصل قوم بين الخَرْج والخراج فقالوا: (الخرج المصدر لما يخرج من المال كالضرب والقطع، والخراج الاسم لما يخرج من الأرض ونحوه كالنبات والحصاد فالخرج والخراج بمنزلة الحصد والحصاد). وهذا معنى قول الفراء والزجاج {26}.وقال ابن الأعرابي -ونحو هذا قال ثعلب-: الخرج أخص، والخراج أعم. يقال: أدَّى خرج رأسه، وأخذ الإمام خراج البلد) {27}.وقد حكى أبو عبيدة: (العبد يؤدي إليك خرجه أي: غلته، والرعية تؤدي إلى الأمير الخرج) {28}. فحكى الخرجة في الضريبة التي على الأرضين فدل أن كلامهما بمعنى. وقال العجاج {29}: يوم خراجٍ يُخْرِج السمرَّجاوهذا ليس على الضرائب التي ألزمت الأرضين؛ لأن ذلك لا يكاد يضاف إلى وقت من يوم وغيره، وإنما هو شيء مؤبد لا يتغير عما عليه {30} وقال أبو الحسن: (لا أدري أيهما أكثر في بلاد العرب) {31}."
  18,95,"ويدل على أن المراد بالخَرْج والخَرَاج هاهنا: العطية منهم له، قوله تعالى في جوابه لهم: ﴿قَالَ مَا مَكَّنِّي فِيهِ رَبِّي خَيْرٌ﴾ والمعنى: ما مكني فيه من الاتساع في الدنيا، خير من خرجكم الذي تبذلونه لي، ومكَّن منقول من مكن يقال: مكُنَ مَكَانَةً، وهو مَكِين عند السلطان من قوم مُكناء، ومكَّن غيره إذا جعله ذا تمكن. وقراءة العامة: ما مَكَّنِّي بنون واحدة مشددة {1}. أدغموا النون في النون لاجتماع النونين كقوله: ﴿لَا تَأْمَنَّا عَلَى يُوسُفَ﴾ [يوسف: 11] وقرأ ابن كثير: بنونين؛ لأنهما من كلمتين والثانية غير لازمة؛ لأنك تقول: مكنتك ومكنته فلم تدغم {2}.قال ابن عباس: (يريد ما أعطاني وملكني أفضل من عطيتكم) {3}.وقولى تعالى: ﴿فَأَعِينُونِي بِقُوَّةٍ﴾ قال: (يريد بقوة الأبدان) {4}.وقال الزجاج: (بعمل يعملونه) {5}.معنى: ﴿أَجْعَلْ بَيْنَكُمْ وَبَيْنَهُمْ رَدْمًا﴾ سدًّا وحاجزًا.قال ابن عباس: (وهو أشد الحجاب) {6}.ومعنى الرَّدم في اللغة: سدُّك بابًا كله أو ثلمةً أر مدخلاً، يقال: رَدَمَه يردمه ردمًا {7}.قال أبو إسحاق: (والرَّدْمُ في اللغة أكثر من السدِّ؛ لأن الردم ما جعل بعضه على بعض، يقال: ثوب مردم إذا كان قد رُقِع رقعة فوق رُقعة) {5}."
  18,96,"قوله تعالى: ﴿آتُونِي زُبَرَ الْحَدِيدِ﴾ لم يرد فأتوني استدعاء تمليك عين، ولكن تمليك المناولة بالأنفس؛ لأنه كلفهم المعونة على عمل السد بقوله: ﴿فَأَعِينُونِي بِقُوَّةٍ﴾ ولم يقل: الخرج الذي بذلوه، فلا يسألهم الحديد أيضًا {1}. وهذا معنى قول ابن عباس: (يريدا احملوا إلى زبر الحديد) {2} ألا ترى أنه فسره بالحمل إليه لا بمعنى التمليك.قال الفراء: (معناه: آتوني) {3}. يريد: فلما ألقيت الباء زيدت ألف، كما تقول: قد أتيتك زيدًا، تريد: أتيتك يزيد، ويقوي هذا المعنى الذي ذكرناه قراءة من قرأ: ائتوني {4}. موصولاً من الإتيان على معنى جيؤني، وهو هاهنا حسن لاختصاصه بالمعونة فقط دون أن يكون سؤال عينه. وعلى هذه القراءة انتصب زبر الحديد بحذف الحرف اتساعًا، فيصل الفعل إلى المفعول الثاني على حد: أمرتك الخير، والتقدير: ايتوني بزبر الحديد {5}.وزبر الحديد: قطعه في قول الجميع. قال الليث: (زبرة الحديد: قطعة ضخمة منه) {6}. وأصلها الاجتماع ومنه: زبرى الأسد، وهي: ما اجتمع من الشعر على كاهله، وزَبَرْت الكتاب: إذا كتبته؛ لأنك جمعت حروفه، وزبرة الحديد: جملة مجتمعة منه {7}.قال ابن عباس في تفسير ﴿زُبَرَ الْحَدِيدِ﴾: (هي على قدر الحجارة التي يبنى بها قدر ما يحمل الرجل) {8}. ومعنى الآية: أنه يأمرهم أن ينقلوا إليه زبر الحديد ليعمل بها الردم في وجوه يأجوج ومأجوج، فأتوه بها فبناه ﴿حَتَّى إِذَا سَاوَى بَيْنَ الصَّدَفَيْنِ﴾ قال الفراء: (ساوى وسوَّى بينهما: واحد) {3}. والمعنى: أنه جمع زبر الحديد ووضع بعضها على بعض بين الصدفين حتى سوى بينهما بالحديد. والصدفان: (الجبلان) في قول جميع المفسرين {10}. قال أبو عبيدة: (الصدفان جانبا الجبل) {11}. ونحوه قال الزجاج {12}.وقال الأزهري: (الصَّدف والصُّدْفة الجانب والناحية، يقال: لجانبي الجبل إذا تحاذا صدفان لتصادفهما أي: تلاقيهما، ومن هذا يقال: صادفت فلانا أي: لاقيته) {13}. ويقال للبناء العظيم المرتفع: صَدَف. شبه بجانب الجبل، ومنه الحديث: (إذا مر بصدف مائل أسرع المشي) {14}. وفيه ثلاثة أوجه من القراءة: الصدفين بضم الصاد والدال، والصدفين بفتحهما، والصدفين بضم الصاد وتسكين الدال {15}. وكلها لغات في هذه الكلمة فاشية.وقوله تعالى: ﴿قَالَ انْفُخُوا﴾ قال ابن عباس: (يريد انفخوا على زبر الحديد بالكير) {16}. قال الزجاج: (جعل بينهما الحطب والفحم، ووضع عليها المنافيخ حتى إذا صارت كالنار، وهو قوله تعالى: ﴿حَتَّى إِذَا جَعَلَهُ نَارًا﴾ والحديد إذا أُحمي بالفحم والمنفاخ صار كالنار) {12}.وقوله تعالى: ﴿قَالَ آتُونِي أُفْرِغْ عَلَيْهِ قِطْرًا﴾ قال ابن عباس: (أذاب النحاس، ثم أفرغه على زبر الحديد فاختلط ولصق بعضه ببعض، حتى صار جبلاً صلدًا من حديد ونحاس) {18}. قال قتادة: (وهو كالبُرْد المحبَّر طريقة سوداء، وطريقة حمراء) {19}.والقطر: النحاس الذائب، وأصله من القطر وذلك أنه إذا أذيب قطر كما يقطر الماء {20}.ومضى الكلام في الإفراغ. وقرئ: ايتوني {21}، موصولاً من الإتيان على معني: جيؤوني به. واللفظ على اتصال الفعل إلى المفعول الثاني بالحرف، إلا أنه أعمل الفعل الثاني وهو الإفراغ، ولو أعمل الأول لكان أفرغه عليه، وقد وصل الفعل الأول هاهنا إلى المفعول الثاني بلا حرف، كما ذكرنا في قراءة من قرأ إيتوني بزبر الحديد، ومن قرأ آتوني أفرغ عليه فمعناه: ناولوني. كما ذكرنا في أول الآية {22}قال ابن الأنباري: (يجوز أن يكون (قِطْرًا) معمول ﴿آتُونِي﴾ وأضمر لأفرغ مفعول على تقدير: أفرغه، وحذف لدلالة (قِطْرًا) عليه. ويجوز أن يكون معمول أفرغ وأضمر لآتوني مفعول على تقدير: آتوني قطرا أفرغ عليه قطرا، فحذف الأول لدلالة الثاني عليه) {23}."
  18,97,"قوله تعالى: ﴿فَمَا اسْطَاعُوا﴾ أصله: (استطاعوا) فلما اجتمعت متقاربتان، وهما التاء والطاء، أحبوا التخفيف بالإدغام، كما أحبوا ذلك في المثلين، فلما لم يسمع التخفيف بالإدغام لتحريك ما لم يتحرك في موضع، وذلك أنه كان يلزم تحريك السين لئلا يجتمع ساكنان، ولم تْحرك سين استفعل في موضع، فلما لم يسمع هذا عدل عن الإدغام إلى الحذف، كما أنه لما اجتمع المثلان في قولهم: على الماء بنو فلان، حذفوا أحد المثلين، فقالوا: عَلْمَاءِ، ولم يسمع الإدغام، وإن كانت تتحرك لام المعرفة في الماء، فحذفوا الأول من المثلين حيث لم يتجه الإدغام. والحذف في اسطاع أولى، لأن هذه السين لم تتحرك في موضع شيء من الحركات، وقد تحرك لام المعرفة نحو قولهم: أَلَحْمَرُ في الأحمر، فلما حذفوا في: عَلْماء أحد المثلين، ولم يدغموا مع جواز تحريك لام المعرفة فلا يؤدي إلى الجمع بين ساكنين كان الحذف في اسطاع أولى. وقد أجروا المتقاربين في مجرى المثلين فقالوا: بلغني لما كانت النون متقاربة للام وكانت تدغم فيها نحو: مَنْ لَكَ، أريد إدغام في هذا الموضع أيضًا، فلما لم يسمع ذلك عندهم خففوا بالحذف كما خففوا به في المثلين.وفي (استطاع) لغة ثالثة وهو قولهم: يستيع في يستطيع، وهذا يحتمل أمرين أحدهما: [أنه أبدل من الطاء التي هي فاء التاء لقربها من الحرف الذي قبلها، فأبدل التاء لتوافق السين في الهمس، كما أبدل الدال] {1} من التاء في نحو: ازدان ليوافق ما قبله في الجهر. والآخر: أن يكون حذف الطاء لما يستقيم إدغام ما قبلها من المتقارب فيها، كما حذف المثل والمقارب من: عَلْماء بنو فلان، وبَلْعَنْبَر، ويكون هذا في أنه حذف من الكلمة الأصل للتخفيف، بمنزلة قولهم: تقيت، ألا ترى أنه في الأصل اتَّقى فحذف الفاء التي هي في الأصل واو، فلما حذفها سقطت همزة الوصل المجتلبة لسكون الفاء فبقي: تَقَيْتُ على فعلت {2}.فأما قولهم: أسطاع بقطع الألف، يُستطيع بضم الياء، فقال أبو علي الفارسي: (قولهم: أسطاع أَفْعَلَ، وإنما ألحقت السين لنقل الحركة إلى الفاء وتهيئة الكلمة بنقل الحركة فيها للحذف، ألا ترى أنها هيأت الكلمة للحذف منها في نحو: لم يَسْطِعْ، ومثل السين في ذلك الهاء، ففي قول من قال: أهَرَاق يُهَريق، فالهاء في: أنها عوض مثل السين في اسْطاع، وليس هذا العوض بلازم، ألا ترى أن ما كان نحوه لم يلزم هذا العوض) {3}. هذا كلامه.؟وشرحه أبو الفتح الموصلي فقال: (قولهم: أسطاع يستطيع، ذهب سيبويه فيه إلى أن أصله: أطاع يُطِيع، وأن السين زيدت عوضًا من حركة عين الفعل، وذلك أن أطاع أصله: أطْوَع، فنقلت فتحة الواو إلى الطاء، فانقلبت الواو ألفًا لتحركها في الأصل وانفتاح ما قبلها الآن) {4}.وتعقب أبو العباس هذا القول فقال: (إنما يعوض من الشيء إذا فقد وذهب، فأما إذا كان موجودًا في اللفظ فلا وجه للتعويض منه، وحركة العين التي كانت في الواو قد نقلت إلى الطاء التي هي الفاء، ولم تعدم، وإنما نقلت {5} فلا وجه للتعويض من شيء موجود غير مفقود {6}.(والذي يدل على صحة قول سيبويه في هذا وأن السين عوض من حركة عين الفعل، هو أن الحركة التي هي الفتحة، وإن كانت كما قال أبو العباس موجودة منقولة إلى الفاء لما فقدتها العين، فسكنت توهنت بالسكون، وبالتهيؤ للحذف عند سكون اللام وذلك قولك: لا تُطِع، وأطِع، ولم يُطِع، ففي كل هذا قد حذفت العين لالتقاء الساكنين، ولو كانت العين بحالها متحركة لما حذفت؛ لأنه لم يكن هناك التقاء ساكنين، ألا ترى أنك لو قلت: أطْوَع، يُطْوِع {7}، ولم يُطْوِع، وأَطْوَعْ زيدا، لصحت العين ولم تحذف، فلما نقلت عنها الحركة وسكنت، سقطت لاجتماع الساكنين، فكان هذا توهينًا وضعفًا للعين، فجعلت السين عوضًا عن سكون العين الموهِّن لها المسبب لقلبها، وحركة الفاء بعد سكونها لا تدفع عن العين ما لحقها من الضعف في السكون والتهيؤ للحذف عند سكون اللام.ويؤكد ما قال سيبويه من أن السين عوض من ذهاب العين، أنهم قد عوضوا من ذهاب حركة هذه العين حرفًا آخر غير السين، وهو الهاء في قول من قال: أهْرَقت فسكن الهاء، وجمع بينها وبين الهمزة، فالهاء هاهنا عوض من ذهاب فتحة العين؛ لأن الأصل: أرْوَقت، فجعلوا الهاء عوضًا من نقل فتحة العين عنها إلى الفاء، وأنشد {8}:فأصبحت كالمهريق فضلة مائه ... لضاحي سرابٍ بالملا يترقرق انتهى كلامه {9}.أخبرني العروضي عن الأزهري عن المنذري عن الحراني {10} عن ابن السكيت قال: (يقال ما أستطيع، وما أسطيع، وما أستيع، وما أسطيع أربع لغات) {11}. وقد ذكرنا وجوهها.وقرأ حمزة: ﴿فما اسْطَّاعوا﴾ مشددا الطاء، كأنه أدغم بالافتعال في الطاء {12}.قال أبو إسحاق: (من قرأ بهذه القراءة فهو لاحن مخطئ، زعم ذلك الخليل، ويونس، وسيبويه وجميع من يقول بقولهم، وحجتهم في ذلك: أن السين ساكنة وإذا أدغمت التاء في الطاء صارت طاء ساكنة، ولا يجمع بين ساكنين) {13}.قال أبو علي: (وقد قرأت القراء غير حرف من هذا كقوله: ﴿لَا تَعْدُوا فِي السَّبْتِ﴾ [النساء: 154] في قراءة من شدد الدال فأدغم فيها تاء افتعل {14}، وكذلك قراءة من قرأ: ﴿لَا يَهِدِّي إِلَّا أَنْ يُهْدَى﴾ [يونس: 35] {15}، ﴿يَخِصِّمُونَ﴾ [يس: 49] {16}.وقدمنا وجه ذكر هذا النحو) {17}.وقال ابن الأنباري: (عظم تشنيع البصريين على حمزة في هذا الحرف، وتلحينهم إياه، وقولهم: جمع بين ساكنين لا ينبسط اللسان عليهما، وفي هذا تعد منهم عليه إذ جرى إلى مثله جماعة هن القراء، فلم ينسبوا إلى الذي نسب إليه، فقد قرأ الحسن: ﴿شَهْرُ رَمَضَانَ﴾ [البقرة: 185] بالإدغام {18}، فإنه يقرؤه، ويقرأ ﴿نَحْنُ نَقُصُّ﴾ [يوسف: 3]، ﴿وَالْحَرْثِ ذَلِكَ﴾ [آل عمران: 14]، ومعلوم أن الإدغام إذا وقع هاهنا اجتمع ساكنان، وقرأ: ﴿فَتَخْطَفُهُ الطَّيْرُ﴾ [الحج: 31] {19} بالإدغام، ﴿يَخْطَفُ أَبْصَارَهُمْ﴾ [البقرة: 20] {20} في نظائر يطول ذكرها، ولا وجه للتشنيع على الأئمة والرؤساء في الخير بما يعرف له مساغ وطريق إلى الصواب) {21}.وقوله تعالى: ﴿أَنْ يَظْهَرُوهُ﴾ قال ابن عباس وغيره: (أن يصعدوه ويعلوه) {22}. يقال: ظهرت السطح إذا صرت فوقه، ومنه قوله تعالى ﴿لِيُظْهِرَهُ عَلَى الدِّينِ كُلِّهِ﴾ [التوبة: 33] معناه: ليعلنه.وقوله تعالى: ﴿وَمَا اسْتَطَاعُوا لَهُ نَقْبًا﴾ يقال: نقبت الحائط: إذا خرقت فيه خرقا يخلص إلى ما وراءه {23}. قال أبو إسحاق: (أي ما قدروا أن يعلوا عليه لارتفاعه وإملاسه، وما استطاعوا أن ينقبوه من أسفله لشدته وصلابته) {24}."
  18,98,"قوله تعالى: ﴿قَالَ هَذَا﴾ قال ذو القرنين لما فرغ من بنائه هذا. قال أبو إسحاق: (أي التمكين الذي أدركت به السد ﴿رَحْمَةٌ مِنْ رَبِّي﴾ {1}. وهذا معنى قول ابن عباس: (يريد معونة من ربي حيث ألهمني وقواني) {2}.وقال ابن الأنباري: (يجوز أن تكون الإشارة بهذا إلى السد، أي: هذا السد رحمة من ربي) {3}. ﴿فَإِذَا جَاءَ وَعْدُ رَبِّي﴾ يعني: القيامة، في قول ابن عباس {4}.وقال الكلبي: (يقول: أجل ربي أن يخرجوا منه) {5}.﴿جَعَلَهُ دَكَّاءَ﴾ أي: دَكَه دَكًا، ويجوز أن يكون المعنى: جعله ذا دك. ومن قرأ: في دكاء ممدودة {6}، كان التقدير: جعله مثل دكَّاء، وهي: الناقة التي لا سنام لها {7}، فحذف المضاف ولابد من تقدير الحذف؛ لأن السد مذكر ولا يوصف بدكاء؛ لأنه من وصف المؤنث. ومضى الكلام في هذا في سورة الأعراف {8}. ﴿وَكَانَ وَعْدُ رَبِّي حَقًّا﴾ يعني: بالثواب والعقاب في القيامة، في قول ابن عباس {9}.وقال الكلبي: (وكان أجل ربي بخروجهم حقًّا كائنًا) {10}."
  18,99,"قوله تعالى: ﴿وَتَرَكْنَا بَعْضَهُمْ يَوْمَئِذٍ يَمُوجُ فِي بَعْضٍ﴾ يقال: ماجَ الماء يَمُوج إذا اضطرب، وماجَ الناس إذا في دخل بعضهم في بعض حيارى كموج الماء {1}. قال كثير من المفسرين: (تركنا الجن والإنس يدخل بعضهم في بعض يوم القيامة) {2}. والصحيح أن قوله: ﴿بَعْضَهُمْ﴾ الكناية فيه عن يأجوج ومأجوج. يقول: تركناهم يوم انقضاء السد يموجون في الدنيا مختلطين لكثرتهم {3}. ثم ذكر نفخ الصور بعد هذا فقال: ﴿وَنُفِخَ فِي الصُّورِ﴾ لأن: خروج يأجوج ومأجوج من علامات قرب الساعة ﴿فَجَمَعْنَاهُمْ جَمْعًا﴾ حشرنا الخلق كلهم."
  18,100,"قوله تعالى: ﴿وَعَرَضْنَا جَهَنَّمَ﴾ الآية. قال الفراء: (أبرزناها حتى نظر إليها الكفار) {1}.وقال أبو إسحاق: (تأويل ﴿عَرَضْنَا﴾ أظهرنا لهم جهنم حتى شاهدوها ورأوها) {2}. ومضى الكلام في العرض {3}."
  18,101,"قوله تعالى: ﴿كَانَتْ أَعْيُنُهُمْ فِي غِطَاءٍ عَنْ ذِكْرِي﴾ الغطاء ما تغطيت به أو غطيت به، والجمع الأغطية، يقال: غطا الشيء، وغطا عليه إذا ستره {1}. ومعنى قوله: في ﴿أَعْيُنُهُمْ فِي غِطَاءٍ عَنْ ذِكْرِي﴾ كقوله تعالى: ﴿وَعَلَى أَبْصَارِهِمْ غِشَاوَةٌ﴾ [البقرة: 7].قال ابن عباس في قوله: ﴿عَنْ ذِكْرِي﴾ (يريد عما جاء به محمد -ﷺ- من البينات والهدى) {2}. وصف الله تعالى هؤلاء الكفار بأنهم عمي عن آيات الله، وأدلة توحيده لما سبق لهم من الشقاء، وإذا لم يبصروا أدلة توحيده، وعجائب قدرته لم يتذكروا بقلوبهم؛ لأن العين رائد القلب، ألا ترى أن الشاعر يقول {3}:ألا إنما العينان للقلب رائد ... فما تألف العينان فالقلب يألفوهذا أبلغ في وصف غفلتهم من أن لو قيل {4}: في غطاء عن الذكر؛ لأن وصفهم بالعمى عن الأدلة يوجب غفلة قلوبهم، ووصفهم بعمى القلوب لا يوجب عمى أبصارهم {5}.وقوله تعالى: ﴿وَكَانُوا لَا يَسْتَطِيعُونَ سَمْعًا﴾ قال ابن عباس {6}: (يريد لا يسمعون القرآن ولا يحبونه) {7}. وقال أبو إسحاق: (كانوا لعدواتهم النبي -ﷺ- لا يقدرون أن يسمعوا ما يتلو عليهم، كما تقول للكاره لقولك: ما يقدر أن يسمع كلامي) {8}. قال ابن الأنباري: (كان يثقل عليهم السمع وهم له مستطيعون، كما تقول: ما أستطيع البصر إليك. معناه: لما ثقل علي كنت كأني غير مستطيعه. قال: ويجوز أن يكون الله منعه الاستطاعة؛ لأن يسمع الهدى، وجعل على بصره غطاء عقابًا من الله له على عناده الحق) {9}."
  18,102,"قوله تعالى: ﴿أَفَحَسِبَ الَّذِينَ كَفَرُوا أَنْ يَتَّخِذُوا عِبَادِي مِنْ دُونِي أَوْلِيَاءَ﴾ يقول: أفظنوا أنهم يتخذونهم أربابًا من دوني، وعنى بالعباد هاهنا: المسيح، والملائكة {1}.وقال ابن عباس: (يعني الشياطين، تولوهم وأطاعوهم من دون الله) {2}. وقال مقاتل: (يعني الأصنام سماها عبادًا) {3}، كما قال: ﴿إِنَّ الَّذِينَ تَدْعُونَ مِنْ دُونِ اللَّهِ عِبَادٌ أَمْثَالُكُمْ﴾ [الأعراف: 194]. وجواب هذا الاستفهام محذوف.قال ابن عباس: (يريد أني لا أغضب لنفسي، ولا أعاقبهم) {4}. ويدل علي هذا المحذوف قوله: ﴿إِنَّا أَعْتَدْنَا جَهَنَّمَ لِلْكَافِرِينَ نُزُلًا﴾، لأن هذا يدل على أنه يريد عقوبتهم.وقال قوم: (هذا لا يقتضي جوابًا؛ لأنه أراد بالأولياء هاهنا الأنصار، والمعنى: أفحسبوا أنهم اتخذوهم أنصارا يمنعونهم من عذابي ويدفعون عنهم) {5}. وهذا معنى قول الزجاج في هذه الآية قال: (تأويله: أفحسبوا أن ينفعهم اتخاذهم عبادي أولياء) {6}.وقوله تعالى: ﴿نُزُلًا﴾ قال أبو إسحاق: (هو بمعنى: منزلا) {6}. وهو معني قول ابن عباس: (يريد هي مثواهم ومصيرهم) {8}. والنُّزُل على هذا التفسير المنزل.وقال آخرون: النُّزُل ما يقال للضيف إذا نَزَل، والنزالة الضيافة، ومنه قوله {9}:فجاءت بيتن للنزالة أرشما.والمعنى: أن جهنم معدة لهم عندنا، كما يهيؤ النُّزل للضيَّف النازل {10}."
  18,103,"وقوله تعالى: ﴿قُلْ هَلْ نُنَبِّئُكُمْ بِالْأَخْسَرِينَ أَعْمَالًا﴾ أي: بالقوم الذين هم أخسر الخلق فيما عملوا. قال ابن عباس في رواية عطاء: (يرد كفار أهل الكتاب) {1}.وهو قول الكلبي: (اليهود والنصارى) {2}. وروي عن علي -رضي الله عنه- أنه قال: (هم الرهبان أصحاب الصوامع) {3}.وعنه أيضًا أنه قال: (هم أهل حَرَوْرَاء) {4} {5}"
  18,104,"وقوله تعالى: ﴿الَّذِينَ ضَلَّ سَعْيُهُمْ﴾ يجوز في ﴿الَّذِينَ﴾ الخفض بالنعت للأخسرين. ويجوز الرفع على الاستيئناف على معنى: هم الذين ضل سعيهم، بطل عملهم واجتهادهم في الدنيا: ﴿وَهُمْ يَحْسَبُونَ أَنَّهُمْ يُحْسِنُونَ صُنْعًا﴾ يظنون أنهم بفعلهم محسنون، والصنع: مصدر صَنَع إليه معروفًا يصنع صنعًا، وأكثر ما يستعمل الصنع في الأعمال الحسنة {1}."
  18,105,"قوله تعالى: ﴿أُولَئِكَ الَّذِينَ﴾ أي: الأخسرين أعمالاهم: ﴿الَّذِينَ كَفَرُوا بِآيَاتِ رَبِّهِمْ﴾ جحدوا دلائل توحيده وقدرته ﴿وَلِقَائِهِ﴾ وكفروا بالبعث، والثواب، والعقاب.﴿فَحَبِطَتْ أَعْمَالُهُمْ﴾ قال ابن عباس: (بطل اجتهادهم) {1}.﴿فَلَا نُقِيمُ لَهُمْ يَوْمَ الْقِيَامَةِ وَزْنًا﴾ روى المفسرون في تفسير هذا: حديث أبي هريرة أن النبي -ﷺ- قال: ""ليؤتين يوم القيامة بالعظيم، الطويل، الشروب، الأكلول فلا يزن عند الله جناح بعوضه""، ثم يقول: ""اقرؤا ﴿أُولَئِكَ الَّذِينَ كَفَرُوا﴾ الآية"" {2}.وقال كعب بن عجرة {3}: (يؤتى برجل يوم القيامة فيوزن بحبة فلا يزنها، فيوزن بجناح بعوضة فلا يزنها، ثم قرأ هذه الآية) {4}. ونحو هذا قال عبيد بن عمير {5}.وروى عطاء عن ابن عباس في هذه الآية قال: (يريد أن ليس لهم وزن يوم القيامة، إنما يوزن من له عمل صالح، وكان على التوحيد) {6}. وهذه الأقوال في الظاهر تدل على أن أعيان الرجال يوزنون، وليس كذلك؛ لأن الأعمال توزن يوم القيامة. والصحيح في هذا ما قاله أهل المعاني، روى أبو العباس عن ابن الأعرابي في هذه الآية قال: (العرب تقول: ما لفلان عندنا وزن، أي: قدر، لخسته، ويوصف الجاهل بأنه لا وزن له، لخفته بسرعة طيشه، وقلة تثبته فيما ينبغي أن يتثبت فيه) {7}.فالمعنى على هذا: أنهم لا يعتد بهم، ولا يكون لهم عند الله قدر ومنزلة {8}. وحديث أبي هريرة محمول أيضًا على هذا، وهو: أن العظيم، الأكول، الشروب لا قدر له ولا وزن عند الله، إذا لم يكن من أهل التوحيد.وقال بعضهم: (معنى هذا خفة موازينهم من الحسنات، وذلك أن الموازين إنما ترجح بالطاعات، وتنقص بالمعاصي، فيوضع الكافر في الميزان يوم القيامة فلا يزن شيئًا لخلوه مما يثقل الميزان به من توحيد الله) {9}.وذكر ابن الأنباري وجه ما ذكره المفسرون فقال: (إن الله عز وجل يأمر بوزن أهل الكفر تحقيرًا لهم، وتصغيرًا لأمرهم، حتى يتبين الخلق أنهم لا يزنون في ذلك المشهد وزن ذرة ولا جناح بعوضة) {10}.يدل على صحة هذا ما روى عمرو بن شعيب عن أبيه عن جده قال: قال رسول الله -ﷺ-: ""يحشر المتكبرون يوم القيامة أمثال الذر في صور الناس، يعلوهم كل شيء من الصغار، حتى يدخلون إلى سجن في جهنم يقال له: بولس، يعلوهم فيه نار الأنيار، يسقون من طينة الخبال من عصارة أهل النار"" {11}.قال أبو بكر: (وإنما يجعلون أمثال الذر تصغيرًا لهم عند أنفسهم، ومن يحضر القيامة) {12}. وذكر من عنده في الآية وجهان: الكافر يقدم علي بسيئات لا حسنة معها، والموازين القسط يوزن فيها حسنات العبد وسيئاته، فإذا خلا الكافر من الحسنات، وحصل على السيئات استحق النار بغير وزن، ولا إقامة ميزان، وما فعل الكافر في الدنيا من نصرة مظلوم، وإطعام جائع، وعمل بر يكافؤ عليه في الدنيا بتوسعة له في الرزق، ويقدم على الله صفرا من كل خير. الثاني: لا يقيم لهم يوم القيامة وزنا؛ لأن الوزن عليهم لا لهم؛ لأنه لا عمل لهم من أعمال الخير يوزن. الوجه الثالث: هو ما ذكره أبو العباس عن ابن الأعرابي، وقد حكيناه {13}."
  18,106,"قوله تعالى: ﴿ذَلِكَ﴾ الذي ذكرت من حبوط أعمالهم، وخسة قدرهم. ثم ابتدأ فقال: ﴿جَزَاؤُهُمْ جَهَنَّمُ﴾ قال ابن الأنباري: (ويجوز أن يكون ﴿ذَلِكَ﴾ في موضع نصب، بمعنى: فعل الله ذلك الاحتقار بكفرهم، وجزاؤهم جهنم، فأضمرت واو الحال مع الجملة) {1}.وقوله تعالى ﴿بِمَا كَفَرُوا﴾ أي: بكفرهم واتخاذهم آياتي، يعني: القرآن. ﴿وَرُسُلِي هُزُوًا﴾ قال ابن عباس: (يريد الذين كانوا يستهزئون بالنبي -ﷺ-) {2}. وإنما قال: ﴿وَرُسُلِي﴾ والمراد محمد -ﷺ-؛ لأن من استهزأ به فقد استهزأ بجميع الرسل؛ لأن الإيمان واجب بهم، فالكفر بواحد كفر بالجميع. ونحو هذا قال الكلبي: (ورسلي محمد -ﷺ-) {3}.وقوله تعالى: ﴿هُزُوًا﴾ مصدر، والمراد المفعول به."
  18,107,"قوله تعالى: ﴿إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ كَانَتْ لَهُمْ جَنَّاتُ الْفِرْدَوْسِ﴾ قال رسول الله -ﷺ-: ""الفردوس ربوة الجنة، وأوسطها، وأفضلها، وأحسنها، وفوقه عرش الرحمن، ومنه تفجر أنهار الجنة، فإذا سألتم الله الجنة فاسألوه الفردوس"" {1}.وقال كعب: (هو البستان الذي فيه الأعناب) {2}. وهو قول الليث قال: (الفردوس جنة ذات كرم، يقال: كَرْم مُفَردس أي: مُعَرَّش) {3}.وقال الضحاك: (هي الجنة الملتفة الأشجار) {4}. وهو اختيار المبرد قال: (الفردوس -فيما سمعت من كلام العرب-: الشجر الملتف، والأغلب عليه العنب، وجمعه الفراديس. قال: ولهذا سمي باب الفراديس بالشام) {5}. وأنشد لجرير {6}:فقلت للركب إذ جد الرحيل بنا ... ما بعد يبرين من باب الفراديس.وقال مجاهد: (هو البستان بالرومية) {7}. واختاره الزجاج فقال: (هو بالرومية منقول إلى لفظ العربية، وأنشد لحسان {8}:وإن ثواب الله كل موحد ... جنان من الفردوس فيها يخلد قال: وحقيقته: أنه البستان الذي يجمع كل ما يكون في البساتين) {9}.ومعنى ﴿كَانَتْ لَهُمْ﴾ قال ابن الأنباري: (في علم الله قبل أن يخلقوا) {10}.وقوله: ﴿نُزُلًا﴾ أي: منزلا. قال أبو علي: (ويجوز أن يكون ﴿نُزُلًا﴾ يراد به القوت الذي يقام للنازل أو الضيف، فيكون النزل القوت، وهذا الوجه يحتاج فيه إلى تقدير المضاف على معنى: كانت له ثمار جنات الفردوس، أو نعيمها. قال: ويجوز أن يكون النُزُل جمع نَازِل، ويكون حالاً والعامل فيه معنى الفعل في لهم) {11}."
  18,108,"ويدل على هذا الوجه قوله تعالى: ﴿خَالِدِينَ فِيهَا لَا يَبْغُونَ عَنْهَا حِوَلًا﴾ قال الليث: (الحِوَلُ يجرى مجرى التَّحويل، تقول: حُوِّلوا عنها تحويلا وحِولا) {1}.قال الأزهري: (فالتحويل مصدر حقيقي من حوَّلت، والحول اسم يقوم مقام المصدر) {2}. ونحو هذا قال ابن قتيبة في تفسير (حِوَلًا): (تَحْوِيلا) {3}. ورواه أيضًا أبو العباس عن ابن الأعرابي {1}.وقال أبو عبيدة (حِوَلًا): (تحويلا) {5}.[قال الفراء: (وهو مصدر تحولت، ذكر على أصله)] {6} {7}. يعني بحذف الزوائد، كالصغر والعوج. ونحو هذا قال الزجاج: (أي لا يريدون عنها تحويلا) {8}.قال ابن عباس: (لا يريدون أن يتحولوا عنها، كما ينتقل الرجل من دار إذا لم توافقه إلى دار أخرى، والجنة ليست هكذا) {9}.وقال مجاهد في قوله: (حِوَلًا) (متحولا) {10}. يعني بالتحول المصدر، وذكر الزجاج وجهين آخرين في الحول، أحدهما: قال: (يقال: قد حال من مكانه حِوَلاً، كما قالوا في المصادر: صَغُرَ صِغَرًا، وعَظُم عِظَمًا وعادني حبها عِوَدًا، فعلى هذا الحِوَل الحِيلَةُ، فيكون المعنى على هذا: لا يحتالون منزلا غيرها) {8}."
  18,109,"قوله تعالى: ﴿قُلْ لَوْ كَانَ الْبَحْرُ﴾ الآية. روى عكرمة عن ابن عباس، قال: (قالت قريش لليهود: أعطونا شيئًا نسأل عنه هذا الرجل. فقالوا: سلوه عن الروح، فنزلت: ﴿وَيَسْأَلُونَكَ عَنِ الرُّوحِ﴾ إلى قوله: ﴿وَمَا أُوتِيتُمْ مِنَ الْعِلْمِ إِلَّا قَلِيلًا﴾ [الإسراء: 85]، فقالوا: أوتينا علمًا كثيرًا، أوتينا التوراة، فأنزل الله: ﴿قُلْ لَوْ كَانَ الْبَحْرُ مِدَادًا لِكَلِمَاتِ رَبِّي لَنَفِدَ الْبَحْرُ﴾ الآية) {1}.ومعنى المداد في اللغة: المجيء شيئًا بعد شيء على اتصال، ومنه يقال للزيت الذي يوقد به السراج: مداد {2}.قال الأخطل {3}:رأوا بارقات بالأكف كأنها ... مصابيح سرج أوقدت بمدادأي: بزيت يمدها. قال ابن الأنباري: (سمي المداد مدادا لإمداده الكاتب) {4}. وأصل هذا من الزيادة والكثرة، من قوله: مد النهر إذا كثر ماؤه ومده نهر آخر، ومنه قوله: ﴿وَالْبَحْرُ يَمُدُّهُ مِنْ بَعْدِهِ سَبْعَةُ أَبْحُرٍ﴾ [لقمان: 27]، قال مجاهد: (لو كان البحر مدادًا للقلم، والقلم يكتب، لنفد البحر قبل أن تنفد كلمات ربي) {5}.قال ابن عباس: (يريد أن كلماته أعظم من أن يكون لها أمد) {6}. والكلام القديم صفة من صفات ذاته {7}، فلا يجوز أن يكون لكلامه غاية ومنتهى، كما ليس له غاية وحد، فأوصاف ذاته غير محدودة أيضًا. وهذا رد على اليهود حين ادعوا أنهم أوتوا العلم الكثير، وكأنه قيل لهم: أي: شيء الذي أوتيتم في علم الله، فكلماته التي لا تنفذ ولا تتناهى، كما لو كتبت بماء البحار وأضعاف ذلك. وقال ابن عباس في تفسير ﴿كَلِمَاتُ رَبِّي﴾: (يريد مواعظ الشكر {8} مني، أو مواعيد ربي وعلمه في خلقه) {9}.وقوله تعالى: ﴿وَلَوْ جِئْنَا بِمِثْلِهِ مَدَدًا﴾ أي: بمثل البحر في كثرة مائه مدادا زيادة له.وأراد لو جئنا بمثله مدادًا له، والمدد: كل شيء زاد في شيء. يقال أمددناهم بمدد أي: بقوم يزيدون في عددهم. قال الزجاج: (﴿مَدَدًا﴾ منصوب على التمييز، يقول: ملؤ هذا، ومثل هذا ذهبًا، أي: من الذهب) {10}. كقوله: ﴿أَوْ عَدْلُ ذَلِكَ صِيَامًا﴾ [المائدة: 95] قال ابن الأنباري: (ويجوز أن يكون ﴿مَدَدًا﴾ منصوب على المصدر لجئنا بتقدير: لمدد البحر بمثله مددا، كما تقول: جاء فلان ركضا. قال: ويجوز أن يكون نائبا عن الحال بتقدير: لو جئنا بمثله مادين) {11}."
  18,110,"قوله تعالى: ﴿قُلْ إِنَّمَا أَنَا بَشَرٌ مِثْلُكُمْ﴾ قال ابن عباس: (علم الله رسوله التواضع لئلا يزهو على خلقه) {1}. وهذا أمر من الله لرسوله بأن يقر على نفسه بأنه آدمي كغيره، إلا أنه أكرم بالوحي وهو قوله: ﴿يُوحَى إِلَيَّ أَنَّمَا إِلَهُكُمْ إِلَهٌ وَاحِدٌ﴾ لا شريك له. ذكر المفسرون في سبب نزول هذه الآية: (أن رجلاً أتى النبي -ﷺ- فقال: إني لأصلي، وأتصدق، وأحب مع ذلك أن يطلع عليه الناس، فأنزل الله هذه الآية) {2}. والإشارة في ذكر توحيده هاهنا إلى من راءى بعمله {3}، فكأنه أشرك فيه غير الله، والمعبود واحد لا يقبل الشركة.قوله تعالى: ﴿فَمَنْ كَانَ يَرْجُو لِقَاءَ رَبِّهِ﴾ لقاء البعث والمصير إلى الله، والرجاء يذكر بمعنى الخوف؛ لأنه يتضمن الخوف، ومنه قول الهذلي {4}:إذا لسمعته النَّحل لم يرج لسعها أي: لم يخف. وهذا قول الكلبي، ومقاتل {5}. وهو باطل عند الفراء؛ لأن الرجاء لا تذهب به العرب مذهب الخوف إلا مع الجحد {6}. كقوله: ﴿لَا يَرْجُونَ أَيَّامَ اللَّهِ﴾ [الجاثية: 14]، و ﴿لَا تَرْجُونَ لِلَّهِ وَقَارًا﴾ [نوح: 13].قال ابن الأنباري: (""من"" حرف شرط، والشرط يقع على ما لم يتحصل، فجرى الشرط في هذا مجرى الجحد) {7}. وقال سعيد بن جبير: (من كان يأمل ثواب الله) {8}.وقوله تعالى: ﴿فَلْيَعْمَلْ عَمَلًا صَالِحًا﴾ أي: خالصًا لا يرائي به. والمفسرون والصحابة على أن هذه الآية نزلت: في النهي عن الرياء، وذكروا في تفسير هذه الآية: ما روي عن النبي -ﷺ- أنه قال: ""قال الله: أنا خير الشركاء، من عمل لي عملاً وأشرك فيه غيري، فأنا منه بري، وهو للذي أشرك"" {9}.وهذا قول عبادة بن الصامت، وشداد بن أوس {10} {11}.وقال كثير بن زياد {12}: (قلت للحسن: قول الله: ﴿فَمَنْ كَانَ يَرْجُو لِقَاءَ رَبِّهِ﴾ الآية، قال: في المؤمن نزلت. قلت: مشركا بالله؟ قال: لا، ولكن أشرك في عمله، يريد الله به والناس، فذلك الذي يرد عليه) {13}.وقال سعيد بن جبير في قوله: ﴿وَلَا يُشْرِكْ بِعِبَادَةِ رَبِّهِ أَحَدًا﴾ (ولا يرائي) {14}.ونحو هذا قال مجاهد، وموسى بن عقبة {15} {16}.هذا الذي ذكرنا قول الجمهور، وروى الوالبي عن ابن عباس: (أن هذه الآية أنزلت في المشركين الذين عبدوا مع الله غيره، وليست في المؤمنين) {17}والصحيح الذي عليه الناس، وقد بين ذلك ابن عباس فيما روى عنه عطاء، وهو أنه قال: (قال الله: ﴿وَلَا يُشْرِكْ بِعِبَادَةِ رَبِّهِ﴾، ولم يقل: ولا يشرك بربه؛ لأنه أراد العمل الذي يعمل الله، ويحب أن يحمد عليه، قال: وكذلك يستحب للرجل أن يدفع صدقته إلى غيره ليقسمها، كيلا يعظمه ويوقره من يصله بها) {18}.قال الكلبي، ومقاتل: (نزلت هذه الآية في رجل يقال له: جندب بن زهير {19}، قال: يا رسول الله أعمل العمل ألتمس به ثواب الله وأحب أن يثني عليَّ به، فأنزل الله فيه هذه الآية) {20}. ونحو هذا قال مجاهد {21}، وطاووس {22}."
