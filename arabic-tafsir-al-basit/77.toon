  77,14,"77:10"
  77,15,"77:10"
  77,16,"77:10"
  77,17,"77:10"
  77,18,"77:10"
  77,19,"77:10"
  77,20,"قوله تعالى: ﴿أَلَمْ نَخْلُقْكُمْ مِنْ مَاءٍ مَهِينٍ (20)﴾ وهذا كقوله: ﴿ثُمَّ جَعَلَ نَسْلَهُ مِنْ سُلَالَةٍ مِنْ مَاءٍ مَهِينٍ (8)﴾ ﴿فَجَعَلْنَاهُ فِي قَرَارٍ مَكِينٍ (21)﴾ {1} [السجدة: 8] ، وهذا مذكور في سورة المؤمنين {2}.﴿إِلَى قَدَرٍ مَعْلُومٍ (22)﴾ يعني مدة الحامل، ومنتهى الحمل.﴿فَقَدَرْنَا﴾ قال الكلبي: يعني خلقه، كيف يكون قصيراً، وطويلاً، وذكراً، وأنثى {3}.وفيه قراءتان: التخفيف، والتشديد {4}.قال الفراء: والمعنى فيهما واحد؛ لأن العرب تقول: قُدِر عليه الموت، والرزق، وقدِّر بالتشديد، وجه من احتج للتخفيف بقوله: ﴿فَنِعْمَ الْقَادِرُونَ﴾ [المرسلات: 23] لا يلزم؛ لأن العرب تجمع بين اللغتين، قال الله تعالى: ﴿فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ﴾ [الطارق: 17]، وقال الأعشى: وأنْكَرَتنْي وما كانَ الذي نَكِرَتْ {5} {6}قال أبو علي: ويجوز أن يكون: ""نعم المقدرون"" فجاء على حذف الزوائد، نحو: دلو الدالي {7}، وأجواز ليل غاضْ {8} {9}. وذكرنا ذلك في قوله: ﴿الرِّيَاحَ لَوَاقِحَ﴾ {10} [الحجر:22].ثم بين لهم صنعه ليعتبروا فيوحدوه، فقال:"
  77,21,""
  77,22,"77:21"
  77,23,"77:21"
  77,24,"77:21"
  77,25,"قوله تعالى: ﴿أَلَمْ نَجْعَلِ الْأَرْضَ كِفَاتًا﴾ معنى الكفت في اللغة: الضم، والجمع، يقال: كَفَتُّ الشيء: أي ضممته فانكفت، أي انضم، ومنه قول أوس:كِرامٌ حين تَنْكَفِتُ الأفاعي ... إلى أجحارهنَّ من الصَّقيعِ {1}أي ينضم، قال أبو عبيدة: كفاتًا: أوعية، يقال للنِّحْي: كِفْتٌ، كِفت، وكفيت {2}؛ لأنه يحوي اللبن ويضمه، ويقال أيضًا: جِرابٌ كَفِيتٌ وكِفتٌ إذا كان لا يضيِّع شيئًا مما يجعل فيه، ويقال للقدر أيضًا: كِفْتٌ، ومنه المثل: كِفْتٌ إلى وئيَّةٍ {3}.وقال: كفت وكفت إذا ضم شيئاً إلى شيء، ومنه الحديث: "" [و] {4} اكفتوا صبيانكم"" {5}، وانْكَفَت الثوب إذا انضم وتقلص {6}.قال ابن عباس: يريد مساكن وقبورًا {7}.وقال مقاتل: تكفت الأحياء فيسكنون ظهرها، وتكفت الأموات في بطنها {8}.وقال مجاهد: تكفت الميت، فلا يرى منه شيء، والحي إذا أوى إلى بيته {9}.وقال قتادة: تكفتهم أحياء فوقها على ظهرها، و""أمواتاً"" إذا قبروا فيها {10}. وهذا قول جماعة المفسرين {11}.قال الفراء: تكفتهم أحياء على ظهرها في دورهم ومنازلهم، وتكفتهم أمواتاً إذا قبروا فيها، في بطنها، أي تحفظهم وتحوزهم {12}، -قال-: ونصبك {13} الأحياء والأموات بوقوع الكفات عليه، كأنك قلت: ألم نجعل الأرض كفاتَ أحياءٍ وأمواتٍ، فإذا نونت نصبت، كما يقرأ: ﴿أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ (14) يَتِيمًا﴾. [البلد: 14، 15] {14}.وقال أبو علي: (إن كان الكفات مصدر الكفت، كما أن الكتاب مصدر الكتب، فقد انتصب (أحياء) به، كما انتصب بقوله: (أو إطعام) (يتيمًا) -قال-: وقد قيل: إن الكفات جمع الكافتة، فأحياء على هذا منتصب بالجمع كقوله: غُفُرٌ ذَنْبُهُمُ غَيرُ فُجُرْ {15}) {16} وقال الكلبي: يريد على ظهرها منازلهم، وعيشهم، وفي بطنها قبورهم {7}.قوله تعالى ﴿شَامِخَاتٍ﴾ أي عاليات، وكل عال فهو شامخ، شمخ يشمخ شموخاً، ويقال للمتكبر: شمخ بأنفه، وجبل شامخ، وجبال شامخة، وشامخات، وشوامخ، أي طوال عالية في السماء مرتفعات، وكل هذا من ألفاظ المفسرين {18}، وأهل المعاني {19}.قوله تعالى: ﴿وَأَسْقَيْنَاكُمْ مَاءً فُرَاتًا﴾ تقدم تفسيره عند قوله: ﴿فَأَسْقَيْنَاكُمُوهُ﴾ {20}.وقوله: ﴿هَذَا عَذْبٌ فُرَاتٌ﴾ {21} [الفرقان: 53].قال مقاتل: وهذا كله أعجب من البعث {22}. قال الله تعالى: ﴿فَوَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾ أي بالبعث.ثم ذكر ما يقال لهم في الآخرة، فقال: ﴿انْطَلِقُوا إِلَى مَا كُنْتُمْ بِهِ تُكَذِّبُونَ﴾.قال الكلبي: يقول لهم الخزنة: انطلقوا إلى ما كنتم به تكذبون في الدنيا {7}.ثم ذكر ما أمروا بالانطلاق إليه، فقال: قوله تعالى: ﴿انْطَلِقُوا إِلَى ظِلٍّ ذِي ثَلَاثِ شُعَبٍ﴾قال المفسرون {24}: (إن الشمس تدنو {25} يوم القيامة من رؤوس {26} الخلائق، وليس عليهم يومئذ لباس، ولا لهم كنان {27}، فتلفحهم الشمس، وتسْفَعُهُم، وتأخذ بأنفاسهم، [ومد] {28} ذلك اليوم وكربه، ثم ينجي الله برحمته من يشاء إلى ظل من ظلِّه، وهناك يقولون: ﴿فَمَنَّ اللَّهُ عَلَيْنَا وَوَقَانَا عَذَابَ السَّمُومِ﴾ [الطور: 27]، ويقول للمكذبين: {انْطَلِقُوا إِلَى مَا كُنْتُمْ بِهِ تُكَذِّبُونَ} [المرسلات: 29] من عذاب الله وعقابه، انطلقوا من ذلك إلى ظل من دخان نار جهنم قد سطع، ثم افترق ثلاث فرق، وكذلك شأن الدخان العظيم إذا ارتفع أن يتشعب، فيكونون {29} فيه إلى أن يفرغ من الحساب، كما يكون أولياء الله في ظل عرشه) {30}.ثم وصف ذلك الظل فقال:﴿لَا ظَلِيلٍ﴾ {31} (أي لا يظلُّكم من حَرِّ هذا اليوم؛ بل يدنيكم من لهب النار إلى ما هو أشد عليكم من حر الشمس) {32}.""ولا يغني"" عنكم ""من اللهب"" أي لا يدفع عنكم من حره شيئاً {33}؛ كما يدفع الظل الحر.قال الكلبي: يريد: لا يرد لهب جهنم عنكم {34}.(والمعنى: أنهم إذا استظلوا بذلك الظل لم يدفع عنهم حر اللهب، وهذا مثل قوله: ﴿وَظِلٍّ مِنْ يَحْمُومٍ (43) لَا بَارِدٍ وَلَا كَرِيمٍ﴾) {35} [الواقعة: 43 - 44].ثم وصف النار فقال: ﴿إِنَّهَا تَرْمِي بِشَرَرٍ كَالْقَصْرِ﴾ (يقال: شررة، وشرر، وشرار، وهو: ما تطاير من النار متبدداً في كلِّ جهة، وأصله من: شررت الثوب إذا أظهرته، وبسطته للشمس، والشر ينبسط متبددًا، وأنشد {36}:تنزو إذا شجها المزاج ... كما طار شرار يطيره اللهب {37}أو كَشَرارِ العَلاةِ يضربها ... القَيْنُ على كلِّ وِجهَةٍ تَثِبُ) {38}يصف الشرر. في قوله: ﴿كَالْقَصْرِ﴾ قولان:أحدهما: أنه القصر من البناء.قال عطاء عن ابن عباس: يريد القصور العظام {39}.وقال الكلبي: شبه الشرار من النار بالقصر من قصور الأعراب التي تكون على المياه {7}.قال ابن عباس: يعني الحصون والمدائن {7}، ونحو هذا روي عن ابن عباس، قال: كالقصر العظيم {42}، وهو اختيار الفراء {43}، وابن قتيبة {44}. وذكرنا تفسير القصر عند قوله: ﴿وَيَجْعَلْ لَكَ قُصُورًا﴾ [الفرقان: 10] {45}القول الثاني: في ""القصر"" أنها جمع قصْرة -ساكنة الصاد- مثل: جمْرة، وجمْر، وتمْرة، وتمْر {46}.قال المبرد: يقال للواحدة من جزل الحطب الغليظ: قصرة، والجمع: قصر {7}.قال الحسن: هو الجزل من الخشب {48}.وقال عبد الرحمن بن [عابس {49}] {50}: سألت ابن عباس عن ""القصر"" فقال: خشب كنا ندخره للشتاء نقطعه، كنا نسميه القصر {51}.وهو قول سعيد بن جبير {52}، ومقاتل {7}، إلا أنهم قالوا: هي أصول النخل، والشجر العظام.ولعل هذا التفسير على قراءة من قرأ بفتح ""الصاد"" {54} على أن الزجاج قال في ""التسكين"" القصر: جمع قصرة، وهو الغليظ من الشجر {55}."
  77,26,""
  77,27,"77:26"
  77,28,"77:26"
  77,29,"77:26"
  77,30,"77:26"
  77,31,"77:26"
  77,32,"77:26"
  77,33,"قوله عز وجل: ﴿كَأَنَّهُ جِمَالَتٌ صُفْرٌ﴾ يعني: كان ذلك الشرر.قال ابن قتيبة: ووقع تشبيه الشرر بـ[القصر] {1} في مقاديره، ثم شبهه في لونه بالجمالات الصُّفر {2}.(والجمالات: جمع جِمَال كما يقال: رجالٌ ورجالات، وبُيُوتٌ، وبيوتاتٌ، ومن قرأ ""جمالة"" {3}، فهي جمع: جَمَل، كما قالوا: حجر، وحجارة، وَذَكر وذِكارة) {4}.هذا قول الفراء {5}، والمبرد {6}، وزاد أبو علي فقال: ""جمال"": جمع بالألف، والتاء، على صحيح البناء، كما جمع على تكسيره في قولهم: ""جمائل""، وأما جمالة، فإن التاء لحقت جمالاً لتأنيث الجمع، كما لحقت في: فحْل وفِحالة، وذَكر وذِكارة، ومثل لحاق ""الهاء"" في فِعالة لحاقها في [فُعوله] {7} نحو: عمومة، وخيوطة {8} {9}.وقوله: ﴿صُفْرٌ﴾قال ابن عباس: يريد الإبل السود، يقال له: أورق، وأصفر {6}.قال الكلبي: الصفر: السود {6}، {12}، وهو قول مقاتل {13}، وقتادة {14}.قال الفراء: الصفر: سُود الإبل، ألا ترى أسوَدَ من الإبل إلا وهو مشربٌ صفرة، لذلك سمت العرب سودَ الإبل: صفراً، كما سمّوا أبيض الظباء أُدْماً لما يعلوها من الكدرة في بياضها {15}.ونحو هذا قال الزجاج {16}، وغيره {17}، وأنشدوا {18}:تِلْكَ خَيْلي منها وتِلْكَ ركابيهُنَّ صُفْرٌ أولادُها كَالزَّبيبِ {19}أي: سود.قال ابن قتيبة: والشرر إذا تطاير فسقط وفيه بقية من لون النار أشْبه شيء بالإبل السود لما يشوبها من الصفرة {20}."
  77,34,""
  77,35,"قال: ﴿هَذَا يَوْمُ لَا يَنْطِقُونَ﴾، قال الكلبي: هذا في بعض مواطن يوم القيامة لا يتكلمون، ويتكلمون في ساعة أخرى {1} {2}.وروى قتادة أن رجلاً جاء إلى عكرمة، فقال: أرأيت قول الله: ﴿هَذَا يَوْمُ لَا يَنْطِقُونَ﴾، ﴿ثُمَّ إِنَّكُمْ يَوْمَ الْقِيَامَةِ عِنْدَ رَبِّكُمْ تَخْتَصِمُونَ﴾ [الزمر: 31]، فقال: إنها مواقف، فأما موقف منها فتكلموا، واختصموا، ثم ختم الله على أفواههم فتكلمت أيديهم، وأرجلهم، فحينئذ لا ينطقون {3}.وقال مقاتل: هذا في بعض المواطن حين يختم الله على أفواههم مقدار أربعين سنة {1}، ونحو هذا ذكر الفراء {5}، والزجاج {6}.قال الفراء: وأراد بقوله: ""يوم لا ينطقون"" تلك الساعة، وذلك القدر من الوقت الذي لا ينطقون فيه، كما تقول: أتيتك يوم يقدمُ فلان، والمعنى: ساعة يقدم، وليس باليوم كله؛ لأن القدوم إنما يكون في ساعة يسيرة، ولو كان يوماً كله، لما جاز إضافته إلى الفعل لسرعة انقضاء القدوم، فإنه لا يمتد يوماً كله، وإنما استجازت العرب ذلك لأنهم يريدون: آتيك إذا قدم فلان، وإذا يقدم [فإذاً] {7} يطلبان الفعل، فلما كان اليوم والليل، وجميع المواقيت في معناهما أضيفت إلى فعل، ويفعَل {8}.وقال أهل المعاني: معنى قوله: ""لا ينطقون"" أي بما فيه لهم حجة، ومن نطق بما لا يفيد، فكأنه لم ينطق، وهذا كما تقول لمن تكلم بما لا يفيد: تكلمت ولم تتكلم {9}. يدل على صحة هذا المعنى ما روي عن بعضهم {10}: أنه قال: وأي حجة لهم يقيمونها، أم بأي عذر يعتذرون، وقد أعرضوا عن [مُنعمهم] {11}، وجحدوا ربوبيته."
  77,36,"قوله تعالى: ﴿وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾ قال الفراء: [رويت] {1}: بالفاء أن يكون نسقاً على ما قبلها، واختير ذلك؛ لأن الآيات بالنون، ولو قيل: فيعتذروا لم يوافق الآيات، وقد قال الله: ﴿لَا يُقْضَى عَلَيْهِمْ فَيَمُوتُوا﴾ [فاطر: 36] بالنصب، وكلٌّ صواب، ومثله: ﴿مَنْ ذَا الَّذِي يُقْرِضُ اللَّهَ قَرْضًا حَسَنًا فَيُضَاعِفَهُ﴾ [البقرة: 245، الحديد 11] بالنصب، والرفع {2}.والعرب تستحب وفاق الفواصل كما تستحب وفاق القوافي، والقرآن نزل على ما تستحب العرب {3} من موافقة المقاطع، ألا ترى أنه قال: ﴿إِلَى شَيْءٍ نُكُرٍ﴾ [القمر: 6]، فثقل في ""اقتربت"" لأن آياتها مثقلة.وقال في موضع آخر: ﴿وَعَذَّبْنَاهَا عَذَابًا نُكْرًا﴾ [الطلاق: 8]، فاجتمع القراء {4} على تثقيل الأول، وتخفيف الثاني ليوافق كل منهما ما قبله. وقال: ﴿الشَّمْسُ وَالْقَمَرُ بِحُسْبَانٍ﴾ [الرحمن: 5] وقال في موضع آخر: ﴿عَطَاءً حِسَابًا﴾ [النبأ: 36]، وهو كثير.وأما رفع يعتذرون بالعطف على ""يؤذن"" أي ليس يؤذن، ولا يعتذرون، هذا لم يؤذن لهم لم يعتذروا.قوله تعالى: ﴿هَذَا يَوْمُ الْفَصْلِ﴾ أي القضاء والفصل بين أهل الجنة والنار، وأهل الحق والباطل.﴿جَمَعْنَاكُمْ﴾ يعني مكذبي هذه الأمة.﴿وَالْأَوَّلِينَ﴾ يعني الذين كذبوا سائر النبيين.قوله: ﴿فَإِنْ كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ﴾ قال عطاء: يريد: كنتم في الدنيا تحاربون محمداً -ﷺ-، وتحاربونني، فاليوم حَاربون {5}.وقال الكلبي: يقول: إن استطعتم أن تصنعوا شيئاً فاصنعوا {5}.وقال مقاتل: يقول: فإن كان لكم حيلة فاحتالوا لأنفسكم {7}.ثم ذكر المؤمنين فقال:"
  77,37,""
  77,38,"77:37"
  77,39,"77:37"
  77,40,"77:37"
  77,41,"﴿إِنَّ الْمُتَّقِينَ﴾ قال عطاء: يريد المهاجرين والأنصار، والتابعين بإحسان {1}.وقال الكلبي {2}، ومقاتل {3}: إن المتقين للشرك بالله.﴿فِي ظِلَالٍ﴾ يعني: ظلال الشجر، وظلال [أكنان {4}] {5} القصور.ثم قال لكفار مكة:﴿كُلُوا وَتَمَتَّعُوا قَلِيلًا﴾ يريد في الدنيا إلى منتهى آجالهم.﴿وَإِذَا قِيلَ لَهُمُ ارْكَعُوا لَا يَرْكَعُونَ﴾ إذا أمروا بالصلوات الخمس لا يصلون مع محمد -ﷺ-. {6} قوله تعالى: ﴿فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ﴾.قال مقاتل {7}، وغيره {8}: يقول: إن لم يصدقوا بهذا القرآن، فبأي كتاب بعد هذا القرآن يصدقون، ولا كتاب بعد القرآن كقوله: ﴿فَبِأَيِّ حَدِيثٍ بَعْدَ اللَّهِ وَآيَاتِهِ يُؤْمِنُونَ﴾ [الجاثية: 6].وقال أبو إسحاق: أي بأي حديث يؤمنون بعد القرآن الذي أتاهم فيه البيان، وهو معجز دليل على الإسلام {9}؟"
