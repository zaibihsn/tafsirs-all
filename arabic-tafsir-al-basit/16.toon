tafsir[128]{c,v,t}:
  16,1,"﴿أَتَى أَمْرُ اللَّهِ﴾ قال ابن عباس: يريد أتى عذابُ الله {1}، وقال الحسن وابن جريج: أي عقابُه لمن أقام على الإشراك به والتكذيب لرسوله {2}، وهذا القول في معنى ﴿أَمْرُ اللَّهِ﴾ هاهنا هو اختيار الزجاج؛ قال: ﴿أَمْرُ اللَّهِ﴾: ما وعدهم الله من المجازاة على كفرهم من أصناف العذاب، واحتج بقوله: ﴿حَتَّى إِذَا جَاءَ أَمْرُنَا وَفَارَ التَّنُّورُ﴾ [هود: 40]، أي: جاء ما وعدناهم به، وبقوله: ﴿أَتَاهَا أَمْرُنَا لَيْلًا أَوْ نَهَارًا﴾ {3} [يونس: 24]. وفسّر آخرون هذا العذاب؛ فقال: هو الأمر بالسيف، وقالوا: هذا جواب النضر بن الحارث حين قال: ﴿فَأَمْطِرْ عَلَيْنَا حِجَارَةً﴾ الآية [الأنفال: 32]، فأنزل الله: ﴿أَتَى أَمْرُ اللَّهِ فَلَا تَسْتَعْجِلُوهُ﴾ {4}، أي: لا تطلبوه قبل حينه، وهذا كما تقول لمن يطلب أمرًا يستعجل فيه، أتاك الأمر فلا تستعجل.وقال جماعة من المفسرين: ﴿أَمْرُ اللَّهِ﴾ هاهنا الساعة {5}؛ وذلك أن المكذبين بها استعجلوها، فقل لهم: ﴿أَتَى أَمْرُ اللَّهِ﴾. قال أبو إسحاق: استبطاؤا {6} أمْرَ الله، فأعلم اللهُ أن ذلك عنده في القرب بمنزلة ما قد أتى، كما قال: ﴿اقْتَرَبَتِ السَّاعَةُ وَانْشَقَّ الْقَمَرُ﴾ [القمر: 1]، وكما قال: ﴿ومَا أَمْرُ السَّاعَةِ إِلَّا كَلَمْحِ الْبَصَرِ﴾ {7} [النحل: 77]؛ وعلى هذا، إنما قال لِمَا لَم يأت بعد أتى؛ لأنه آت لا محالة، والعربُ إذا ذكرت شيئًا قَرُبَ وقوعه أخرجته مخرج الواجب، كقوله تعالى: ﴿وَنَادَى أَصْحَابُ الْجَنَّةِ أَصْحَابَ النَّار﴾ [الأعراف: 44]، وقد مر.وقوله تعالى: ﴿سُبْحَانَهُ﴾ هو قال ابن عباس: نَزَّه نفسه {8}، وقال الزجاج: تنزيه له وبراءة من السوء {9}، ﴿وَتَعَالَى﴾ أي: ارتفع وتعاظم بأعلى صفات المدح عن أن يكون له شريك، و (ما) في قوله: ﴿عَمَّا﴾ يجوز أن تكون (ما) المصدر، والتقدير: عن إشراكهم، والمعنى عن إشراكهم به غيره، فحُذف للعلم، ويجوز أن تكون بمعنى الذي؛ أي: ارتفع عن الذي أشركوا به {10}؛ لأنهم ﴿لَا يَخْلُقُونَ شَيْئًا وَهُمْ يُخْلَقُونَ﴾."
  16,2,"قوله تعالى: ﴿يُنَزِّلُ الْمَلَائِكَةَ﴾ روى عطاء عن ابن عباس قال: يريد جبريل وحده {1}، وذكرنا فيما تقدم جوازَ تَسْمِيةِ الواحد باسم الجمع إذا كان ذلك الواحدُ رئيسًا مقدمًا؛ كقوله تعالى: ﴿الَّذِينَ قَالَ لَهُمُ النَّاسُ﴾ الآية [آل عمران: 173] {2}.وقوله تعالى: ﴿بِالروحَ من أَمرِهِ﴾ وقال ابن عباس: بالوحي {3}، وهو كلام الله، هذا قول الربيع والحسن {4}، وهو الاختيار في معنى الروح هاهنا، قال الزجاج: الروح ما كان فيه من أمر الله حياةً للنفوس بالإرشاد إلى أمر الله {5}.وقال أبو العباس في هذه الآية وفي قوله: ﴿يُلْقِي الرُّوحَ مِنْ أَمْرِهِ﴾ [غافر: 15]، ولقوله: ﴿وكَذَلِكَ أَوْحَيْنَا إِلَيْكَ رُوحًا مِنْ أَمْرِنَا﴾ [الشورى: 52] هذا كله معناه الوحي {6}؛ سُمّي روحًا لأنه حياةٌ من موت الكفرِ، فصار يحيا به الناس؛ كالروح الذي يحيا {7} به الجسد.وقال أبو عبيدة: الروح هاهنا جبريل {8}، وعلى هذا الباء في بالروح بمعنى (مع) كقولهم: خرج بثيابه، أي: ومعه ثيابه، وركب الأمير بسلاحه، والأول الوجه، ومعنى ﴿مِنَ أَمرِهِ﴾، أي: من فعله في الوحي {9}.وقوله تعالى: ﴿عَلَى مَنْ يَشَاءُ مِنْ عِبَادِهِ﴾ يريد النَّبِيّين الذين يختصهم من عباده بالرسالة والوحي بقوله: ﴿أَن أَنذِرُواْ﴾، قال الزجاج: ﴿أَن﴾ بدل من الروح، المعنى: ﴿يُنَزِّلُ الْمَلَائِكَةَ﴾ بأن أنذروا {10}.والمعنى: أنذروا أهل الكفر بأنه لا إله إلا أنا، أي مروهم بتوحيدي وأن لا يشركوا بي شيئًا {5}، والخطاب للنَّبِيّين المعنيين بقوله: ﴿مَنْ يَشَاءُ مِنْ عِبَادِهِ﴾، وهذا يدل أن معنى الروح هاهنا الوحي، إذا بُدّل منه الإنذار، ومعنى إنذارِهم بأنه لا إله إلا هو إعلامهم بذلك مع تخويفهم لو لم يقروا، ثم ذكر ما يدل على توحيده، فقال:"
  16,3,"﴿خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ بِالْحَقِّ﴾ ومعنى هذا مذكور في قوله: ﴿وَهُوَ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ بِالْحَقّ﴾ [الأنعام: 73].وقوله تعالى: ﴿عَمَّا يشركِوُنَ﴾ ذكرنا معناه آنفًا {1}."
  16,4,"وقوله تعالى: ﴿خَلَقَ الْإِنْسَانَ مِنْ نُطْفَةٍ﴾، قال أبو إسحاق: اختصر هاهنا، وذكر تقلبَ أحوال الإنسان في غير مكان من القرآن {1}.قال ابن عباس: يريد إني خلقت، قال المفسرون: نزلت هذه الآية والتي في آخر سورة يس: ﴿أوَلَمْ يَرَ الْإِنْسَانُ أَنَّا خَلَقْنَاهُ مِنْ نُطْفَةٍ﴾ [يس: 77] في قصة أُبي بن خلف وإنكاره البعث {2}.وقوله تعالى: ﴿فَإِذَا هُوَ خَصِيمٌ مُبِينٌ﴾، الخصيم بمعنى المخاصم، ذكرنا ذلك عند قوله: ﴿وَلَا تَكُنْ لِلْخَائِنِينَ خَصِيمًا﴾ [النساء: 105]، هذا قول أهل اللغة.قالوا: خصيمك الذي يخاصمك، وفعيل بمعنى مُفَاعل معروف؛ كالنسيب بمعنى المناسب، والعشير بمعنى المعاشر، والأكيل والشريب، ويجوز أن يكون خصيم فاعلًا من خَصِم يَخْصم بمعنى اختصم، وبه قرأ حمزة {3} قوله: ﴿تَأْخُذُهُمْ وَهُمْ يَخِصِّمُون﴾ {4} [يس: 49].وقوله تعالى: ﴿مُبِينٌ﴾ أي ظاهر، ومعناه: ظاهر الخصومة، ويجوز أن يكون مبين؛ أي يُبين عن نفسه الخصومة بالباطل، وذكر أهل المعاني لهذه الآية معنيين؛ أحدهما: أنه عرّفنا قدرته في إخراجه من النطفة ما هذه حاله وصفته، والثاني: أنه ذَكر فاحشَ ما ارتكب من تضييع حق نعمة الله بالخصومة في الكفر به {5}."
  16,5,"قوله تعالى: ﴿وَالْأَنْعَامَ خَلَقَهَا﴾، يعني الإبل والبقر والغنم، وتم الكلام ثم ابتدأ فقال: ﴿لَكُمْ فِيهَا دِفْءٌ﴾، ويجوز أن يكون تمام الكلام عند قوله: ﴿لَكُمْ﴾ ثم يبتدئ فيقول: ﴿فِيهَا دِفٌ﴾.قال صاحب النظم: أحسن الوجهين أن يكون الوقف عند قوله: ﴿خَلَقَهَا﴾؛ لقوله في النسق على ما قبلها: ﴿وَلَكُم فِيهَا جَمَال﴾ {1}.وأما الدفء، فقال الفراء وجميع أهل اللغة: هو ما انتفع به من أوبارها وأشعارها وأصوافها، أراد ما يلبسون منها ويبتنون {2}، فالدفء عند أهل اللغة: ما يُستدفأ به من الأكسية والأبنية {3}، قال الأصمعي: ويكون الدفء السخونة، يقال: اقعد في دفء هذا الحائط، أي في كنّه {4}، وقال الفراء في المصادر: يقال للرجل: دَفَيْت فأنت تدفأ دَفْأً، ساكنة الفاء مفتوحة الدال، ودِفْآء بالكسر والمد، وزاد غيرُه دَفاءةً ودَفاءً.وروى الحرَّاني عن ابن السِّكِّيت: يقال: هذا رجل دَفْآنُ وامرأة دَفْأى، ويوم دَفِيءٌ وليلة دفيئةٌ، وكذلك بيت دَفِيء، وغرفة دَفيئةٌ، على فَعيل وفعيلة، وما كان الرجل دَفْآن، ولقد دَفِئَ، وما كان البيت دَفِئًا، ولقد دَفُؤَ {5}. الفَراء: دَفُؤَتْ ليلَتُنا ويومُنا دفأةً، ويقال: أدفأه فَدَفِئَ {6}، وإبل مُدْفِئة: كثيرة؛ لأن بعضَها يُدْفِئُ بعضًا بأنفاسها {7}، وإبل مُدْفأَةٌ ومدفآت: كثيرات الأوبار {8}، قال الشماخ:وكيفَ يضيِعُ صاحِبُ مُدْفَآتٍ ... على أثْباجِهِنَّ مِنَ الصَّقِيعِ {9}ونحو هذا قال عامة المفسرين في الدفء {10}، إلا ما روي عن ابن عباس من طريق عكرمة، ﴿لَكُمْ فِيهَا دِفْءٌ وَمَنَافِعُ﴾ قال: النسل {11}، وروى الأزهري عن ابن هاجك {12} بإسناده عن ابن عباس، ﴿لَكُمْ فِيهَا دِفْءٌ﴾ قال: نسل كل دابة {13}.قال {14} الأزهري: وهذا يوافق قول الأموي {15}، روى أبوعبيد عنه: الدفءُ {16} عند العرب: نتاج الإبل وألبانها والانتفاع بها {17}، قال الفراء: وكتبت دفء بغير همز؛ لأن الهمزة إذا سَكن ما قبلها حُذفت من الكتاب، وذلك لخفاء الهمزة إذا سُكِتَ {18} عليها، فلما سَكَنَ ما قبلها ولم يَقْدِروا على هَمْزِها في الْسَّكْت، كان سكوتهم كأنه على الفاء، وكذلك قوله: ﴿يُخْرِجُ الْخَبْءَ﴾ [النمل: 25] و ﴿مِلْءُ الْأَرْضِ﴾ [آل عمران: 91] {19}.وقوله تعالى: ﴿وَمَنَافِعُ﴾ يعني النسل والدّر والركوب، ﴿وَمِنْهَا تَأْكُلُونَ﴾ قال ابن عباس: يريد من لحومها {20}."
  16,6,"قوله تعالى: ﴿وَلَكُمْ فِيهَا جَمَالٌ﴾ أي زينة، كما قال: ﴿الْمَالُ وَالْبَنُونَ زِينَةُ الْحَيَاةِ الدُّنْيَا﴾ [الكهف: 46]، والمال ليس يخص الورِق والعين، وأكثر مال العرب الإبل، كما أن أكثر أموال أهل البصرة النخل.وقوله تعالى: ﴿حِينَ تُرِيحُونَ﴾، الإراحة: ردّ الإبل بالعَشي إلى مُراحِها حيث تأوِي إليه ليلًا {1}، قال ابن عباس: يريد حِينَ خروج العرب أيام الربيع بالماشية إلى الخِصب، يعني أن الإراحة أكثر ما تكون أيام الربيع إذا سقط الغيث، وكثر الكلأ، وخرجت العرب للنجعة، وتركت مياهها، وأحسنُ ما تكون النَّعم في ذلك الوقت {2}، ولذلك ستر رسولُ الله -ﷺ- وجَهه لمّا رأى نَعَمَ بني المصطلق وقد عَبِست في أبوالها، وذكرنا هذا في آخر سورة الحجر.وقوله تعالى: ﴿وَحِينَ تَسْرَحُونَ﴾ يقال: سَرَّح القومُ إبِلَهم سَرْحًا إذا أخرجوها بالغداة إلى المَرْعَى، واسم ذلك المال السَّرْحُ، وسَرَح المالُ نفسُه سُرُوحًا: رَعَى بالغَدَاة {3}."
  16,7,"قوله تعالى: ﴿وَتَحْمِلُ أَثْقَالَكُمْ﴾ جمع الثقل، وهو متاع المسافر وحَشَمُه، ﴿إِلَى بَلَدٍ لَمْ تَكُونُوا بَالِغِيهِ إِلَّا بِشِقِّ الْأَنْفُسِ﴾ قال ابن عباس: يريد من مكة إلى اليمن، وإلى الشام، وإلى مصر {1}، هذا قوله، والمراد: كل بلد لو تكلفتم بلوغه على غير الإبل شق عليكم {2}، وخص ابن عباس اليمن والشام؛ لأن متاجر أهل مكة كانت إلى هذه الوجوه، وليس قول من خص البلد بمكة بشيء {3}؛ والشِّقُّ المَشَقَّةُ، والشِّقُّ: نصفُ الشيء، وكِلا المعنيين في الشق سائغ في معنى الآية، ذكرهما الفراء؛ وقال أكثر القراء: على كسر الشين {4}، ومعناه إلا بِجَهْدِ الأنفس، وكأنه الاسم، وكأن الشِّقَّ فعلٌ، قال: ويجوز في قوله: ﴿إِلَّا بِشِقِّ الْأَنْفُسِ﴾ أن يذهب إلى أن الجَهْدَ يُنْقِص من قوةِ الرجل ونَفَسِه حتى يجعله قد ذهب بالنصف من بدنه أو قوته، فيكون الكسر على أنه كالنصف، ويقال: المال بيني وبينكم بشَقِّ الشعر؛ وشِقِّ الشَعَر، وهما متقاربان، فإذا قالوا: شَقَقْتُ عليك شقًّا، نصبوا {5}.وقال في ""المصادر"": شققت عليه شقًّا، وشق الصبح، وشق بابه إذا طلع، شقوقًا منهما، وشققت الثوب شقًّا لا غير.قال ابن شميل: شَقَّ عليَّ ذلك الأمر مشقة، أي: ثقل عليّ {6}، فجاء من هذا أن الشَّق بالفتح مصدر شَقَّ عليه الأمر، أي: أثقله عليه، ومنه قوله -ﷺ-: ""لولا أن أَشُقَّ على أمتي"" {7}؛ شَقَّ الأمْرُ عليه مَشَقَّةً، فهو واقع ومطاوع {8}، والشق: الاسم منه، وشَقَّ الشيءَ شقًّا، وشق بنفسه شُقوقًا.وقوله تعالى: ﴿إِنَّ رَبَّكُمْ لَرَءُوفٌ رَحِيمٌ﴾ يريد أنه مَنّ عليكم وتفضَّل بإنعامه بالنعم التي لكم فيها هذه المنافع والمرافق {9}."
  16,8,"قوله تعالى: ﴿وَالْخَيْلَ وَالْبِغَالَ وَالْحَمِيرَ لِتَرْكَبُوهَا وَزِينَةً﴾ قال الفراء: نُصبت ﴿وَزِينَةً﴾ على: وجعلها زينة، مثل قوله: ﴿وَزَيَّنَّا السَّمَاءَ الدُّنْيَا بِمَصَابِيحَ وَحِفْظًا﴾ {1} [فصلت: 12] المعنى: وحفظناها حفظًا، ولو لم يكن في (الزينة) ولا في ﴿وَحِفظَا﴾ وَاوٌ لنصبتَها بالفعل الذي قبلها لا بالإضمار، ومثله: أعطيتك درهمًا ورغبة في الأجر، المعنى أعطيتكه {2} رغبةً، فلو ألقيت الواو لم يحتج إلى ضمير؛ لأنه متصل بالفعل الذي قبله {3}، وقال أبو إسحاق: نُصبت ﴿وَزِينَةً﴾ على أنها مفعول لها، المعنى: وخلقها للزينة {4}.قال أصحابنا: والآية لا تدل على تحريم لحوم الخيل، وإن ذكرت البغال والحمير؛ لأن القصد بهذه الآية بيانُ إباحةِ الركوب وإظهار المنّة بأنْ خَلق لنا من الحيوان ما نقضي عليه حوائجنا ونتجمَّل به، وكيف تدل على تحريمها والسورة مكية؟ ولحوم الحُمُر الأهلية حُرِّمت عام خيبر {5}، فلو دَلَّت على تحريم لحم الخيل لَدَلَّت على تحريم لحم الحُمُر حتى {6} تُحَرَّم عند نزولها، ولحوم الخيل حلال بالسنة والأخبار فيها كثيرة {7}.وقوله تعالى: ﴿وَيَخْلُقُ مَا لَا تَعْلَمُونَ﴾ روي عن ابن عباس أنه قال: لم يسمه فالله أعلم {8}. وروى عطاء عنه، ومقاتل عن الضحاك عنه، قال: يريد أنّ عن يمين العرش نهرًا من نور؛ مثل السموات السبع والأرضين السبع والبحار السبع يدخل جبريل فيه كل سحر فيغتسل فيزاد نورًا إلى نوره وجمالًا إلى جماله، وعِظَمًا إلى عِظَمِه، ثم ينتفض فيخلق الله من كل نفضة تقع من ريشه كذا وكذا ألف ملك، يدخل منهم كل يوم سبعون ألفًا البيت المعمور، وفي الكعبة سبعون ألفًا، لا يعودون إليه إلى أن تقوم الساعة {9}.وقال آخرون: يعني مما أعد في الجنة لأهلها وما أعد في النار لأهلها {10}.وقال السدي وقتادة: يعني السوس في الثياب، والدود في الفواكه {11}."
  16,9,"قوله تعالى: ﴿وَعَلَى اللَّهِ قَصْدُ السَّبِيلِ﴾ القصد: استقامة الطريق، يقال: طريق قصد وقاصد إذا أداك إلى مطلوبك، وقصد بك ما تريد {1}، واختلفوا في معنى هذه الآية، فأكثر المفسرين على أن المعنى: وعلى الله بيان قصد السبيل بالكتب والرسل والحجج {2}، وهو قول جابر وقتادة والسدي {3}، ورُوي ذلك عن ابن عباس {4} واختاره الفراء {5} والزجاج {6}، وعلى هذا: الآية من باب حذف المضاف؛ لأن التقدير: وعلى الله بيان قصد السبيل، ثم قال: ﴿وَمِنهَا جَآِئرٌ﴾، أي: عادل مائل، ومعنى الجور في اللغة: الميل عن الحق {7}، والكناية في منها تعود على السبيل، وهي مؤنثة في لغة الحجاز، يعني: ومن السبيل ما هو جاثر غير قاصد للحق {8}. قال الكلبي: يعني اليهودية والنصرانية والمجوسية {9}. وقال ابن المبارك: يعني الأهواء والبدع {10}.روى عطاء عن ابن عباس في هذه الآية، قال: من أراد أن يهديه سهل له طريق الإيمان، ومن أراد أن يُضلَّه وعَّر عليه طريق الإيمان {11}، يعني المنافق والكافر؛ شَدُدَ عليه الغُسْلُ من الجنابة والوُضوءُ للصلاة، ويَثْقُلُ عليه صيام شهر رمضان من اثني عشر شهرًا، ثم بين أن المشيئة إليه، فقال: ﴿وَلَوْ شَاءَ لَهَدَاكُمْ أَجْمَعِينَ﴾، يريد: فلو شاء لأرشدكم أجمعين حتى لا يختلف عليك يا محمد أحد، هذا كلامه، والذي ذكرنا في هذه الآية هي طريقة المفسرين. وفي الآية وجه آخر، وهو أن المعنى: أن قصد السبيل الذي هو الحنفية والإسلام على الله؛ أن يؤدي إلى رضا الله وثوابه وجزائه {12}؛ كقوله: ﴿قَالَ هَذَا صِرَاطٌ عَلَيَّ مُسْتَقِيمٌ﴾ [الحجر: 41]، أي: أنه يؤدي إلى جزائي وكرامتي، فهو طريق عليّ، وهذا مذهب مجاهد، قال: على الله طريق الحق {13}، وبه قال عبد الله بن المبارك {14}، وهو أقوى القولين؛ لأنه صح من غير إضمار ولا شبهة للقدرية {15}؛ لأنهم يقولون على التفسير الأول: أضاف قصد السبيل إليه.ثم قال: ﴿ومنها جائزٌ﴾ وهو ضده، فلم يضف إلى نفسه {16}، وجوابهم عن هذا أن الجائر أيضًا منه، وإن لم يضف إلى نفسه، ولكنه ذكر ذلك على الإطلاق {17}، وابن عباس قد بَيَّنَ ذلك كما حكينا، ولا شبهة لهم في الآية على القول الثاني."
  16,10,"قوله تعالى: ﴿هُوَ الَّذِي أَنْزَلَ﴾ إلى قوله: ﴿وَمِنهُ شَجَرٌ﴾، قال أهل اللغة: الشجر أصناف، فأما جِلُّ الشجر فعظامه التي تبقى على الشتاء، وأما دِقُّ الشجر فصنفان: أحدهما يبقى له أَرُومَةٌ {1} في الشتاء وَينْبت في الربيع، ومنها ما لا يبقى له ساق في الشتاء؛ كالبقول {2}، وقال أبو إسحاق: كلُ ما يَنْبُت على الأرض فهو شجر: نُطْعِمُها {3} اللحم إذا عَزَّ الشَّجَرْ {4}ويعني أنهم يُسقون الخيل اللبن إذا أجدبت الأرض {5}، وقال ابن قتيبه في هذه الآية: يعني الكلأ {6}، ومعنى الآية: أنه ينبت بالماء الذي أنزل من السماء ما يرعاه الراعيةُ من ورق الشجر وجلّها؛ لأن الإبل يرعى جِلَّ الشجر. قال ابن السِّكِّيت: يقال: شاجرَ المالُ، إذا رعى العُشبَ والبَقْلَ فلم يَبْق منها شيء، فصار إلى الشجر يَرْعاه {7}.وقوله تعالى: ﴿فِيهِ تُسِيمُونَ﴾، أي: في الشجر تَرْعَون مواشيكم، يقال: أَسِمْت الماشية إذا خليتها ترعى، وسَامَت هي تَسُومُ سَوْمًا إذا رَعَتْ حيثُ شاءت، فهي سَوَامٌ وسَائِمَةٌ {8}، قال الزجاج: أُخِذَ ذلك من السّومة؛ وهي العلامة ، وتأويلها أنها تُؤثِّر في الأرض برَعْيِها علامات {9}، وقال غيره: لأنها تُعَلَّمُ الإرسالَ {10} في المرعى {11}."
  16,11,"قوله تعالى: ﴿يُنْبِتُ لَكُمْ﴾ قراءة العامة بالتاء {1}، وقرأ أبو بكر عن عاصم بالنون {2} والياء أشكل لما تقدم من الإفراد {3}، والنون لا يمتنع أيضًا، ويقال: نبت {4} البقل (وأنبته الله، وقد روي: أنبت البقل) {5}، والأصمعي يأبى إلا نبت، ويزعم أن قصيدة زهير التي فيها:حتى إذا أنبت البَقْلُ {6}متّهمة {7}.وقوله تعالى: ﴿الزَّرْعَ﴾ قال ابن عباس: يريد الحبوب {8}، ﴿وَالزَّيْتُونَ﴾ جمع زيتونة، يقال: الشجرة نفسُها زيتونة، ولثمرها زيتونة، والمجميع الزيتون، ﴿وَالنَّخِيلَ﴾ يقال: نخلة ونخل ونخيل.وقوله تعالى: ﴿وَمِنْ كُلِّ الثَّمَرَاتِ﴾، أي: وينبت من كل الثمرات، فحُذف لأن ما سبق يدل عليه."
  16,12,"قوله تعالى: ﴿وَسَخَّرَ لَكُمُ اللَّيْلَ وَالنَّهَارَ﴾ إلى قوله: ﴿مُسَخَّرَاتٌ﴾، قراءة العامة بالنصب في هذه المنسوقات كلها {1}، وهو الوجه لاستقامتها في المعنى، وإذا استقامت في معنى واحد استقامت في إعراب واحد، وقد جاء التسخير في الشمس والقمر والنجوم، وهو قوله: ﴿وَسَخَّرَ لَكُمُ الشَّمْسَ وَالْقَمَرَ دَائِبَيْنِ﴾ [إبراهيم: 33]، وقوله: ﴿وَهُوَ الَّذِي جَعَلَ لَكُمُ النُّجُومَ﴾ [الأنعام: 97]، فكما حملت على التسخير في هاتين كذلك وجب أن يحمل على التسخير في هذه السورة.وقوله تعالى: ﴿مُسَخَّرَاتٍ﴾ حال مؤكدة؛ لأن تسخيرها قد عُرف بقوله: ﴿وَسَخَّر﴾ فجاءت الحال مؤكدة، ومجيء الحال مؤكدة في التنزيل وغيره كثير؛ كقوله: ﴿وَهُوَ الْحَقُّ مُصَدِّقًا﴾ [البقرة: 91]. و:أنا ابنُ دارَة معروفًا {2} و:كَفَى بالنأيِ من أسماءَ كاف {3}وقرأ ابنُ عامر: ﴿وَالشَّمْسَ وَالْقَمَرَ وَالنُّجُومَ مُسَخَّرَاتٍ﴾ رفعًا {4}؛ كأنه قطعها عن سخر لئلا يجعل الحال مؤكدة، فابتدأ الشمس والقمر والنجوم، وجعل مسخرات خبرًا عنها؛ لأنه لا يقال: ذللت هذا الشيء مُذللا، ووهبت لك هذا موهوبًا، إلا في التأكيد النادر، وروى حفص عن عاصم: ﴿مُسَخَّرَاتٍ﴾ بالرفع وحدها {5}؛ ووجه ذلك أنه لم يجعلها حالاً مؤكدة، وجعلها خبر ابتداء محذوف؛ كأنه قال بَعدُ: هي مسخراتٌ، فحذف المبتدأ وأضمر لدلالة الخبر عليه، وقد عُلم التسخير بما تقدم، وكون ﴿مُسَخَّرَاتٍ﴾ حالًا مؤكدة أسوغ من كونها خبرَ مبتدأ محذوف؛ لأن الخبر ينبغي أن يكون مفيدًا، لم يجيء إلا كذلك، والحالُ تجيء مؤكِدة {6}؛ ألا ترى إلى قوله:إذا كان يومٌ ذو كَواكِبَ أَشْنَعَا {7}حمله على الحال ولم يحمله على الخبر {8}."
  16,13,"قوله تعالى: ﴿وَمَا ذَرَأَ لَكُمْ﴾ أي لأجلكم، وهو عطف على ما قبله من المسخرات.وقوله تعالى: ﴿مُخْتَلِفًا أَلْوَانُهُ﴾ أي هيأته ومناظره، يعني الدواب والأشجار وغيرها، ونصب مختلفًا على الحال، وذو الحال: ﴿وَمَا﴾ العامل فيها قوله: ﴿سَخَّرَ﴾."
  16,14,"قوله تعالى: ﴿وَهُوَ الَّذِي سَخَّرَ الْبَحْرَ﴾ أي ذَلَّله للركوب والغوص، ﴿لِتَأْكُلُوا مِنْهُ لَحْمًا طَرِيًّا﴾ قال ابن الأعرابي: لحم طري غير مهموز، وقد طرو طرواة.وقال الفراء في ""المصادر"": ما كان طريًّا، ولقد طري يطرى طراءً ممدود وطراوةً، كما يقال: شقي يشقى شقاءً وشقاوةً، قال ابن عباس: يريد السمك والحيتان {1}، ﴿وَتَسْتَخْرِجُوا مِنْهُ حِلْيَةً تَلْبَسُونَهَا﴾ قال: يريد الدر واللؤلؤ والمرجان والزبرجد والياقوت، وربما وجدوا فيه الذهب.قال أبو علي: الحِلْيَة والحُلِي واحد، كما يقال: بِرْكَة للمصدر وبِرَك {2}.وقوله تعالى: ﴿وَتَرَى الْفُلْكَ مَوَاخِرَ فِيهِ﴾ يجوز أن يكون هذا فصلاً مبتدأً غير معطوف على ما قبله، ويجوز أن يكون معطوفًا على ما قبله.واختلف ألفاظ المفسرين في تفسير الماخر؛ فروى ابن عباس أنه قال: جواري {3}، وقال في رواية عطاء: يريد ملججين فيه، وأهل البحر يقولون: مَخَرْنا، يريد لججنا؛ إذا انقطع البر عنهم فلم يروه، وقال قتادة ومقاتل: مقبلة ومدبرة {4}.قال الكلبي: يذهب ويجيء {5}.وقال الحسن: مواقر {6}.وقال أبو عبيدة: صوائح {7}، ونحو هذا قال الفراء {8}، وكل هذا معان وليس بتفسير، وتفسير المواخر ما ذكره أهل اللغة.قال المنذري: سمعت أحمد بن يحيي يقول وسئل عن المواخر، فقال: الماخرةُ السفينةُ التي تَمْخَرُ الماءَ؛ تدفعه وتدفع الموج بصدرها {9}، قال: وأنشدني الحرَّانيُّ عن ابن السكيت أنه أنشده للراجز في صفة نساء ضرائر:وصارَ أمثالَ الفغا ضرائري ... مُقَدِّماتٍ أَيْدِيَ المَواخِرِ {10}قال: الماخِرُ: الذي يَشقُّ الماءَ إذا سَبحَ، يصف نساءً تَصْخَبْنَ وتَسْتعِنَّ بأيديهن كأنهن سوابح {11}، والفغا: ضرب من التمر غليظ {12}، يقال: ما الذي أفغاك، أي: أغضبك وورّمك.وقال أبو الهيثم: مَخْرُ السفينةِ: شَقُّها الماءَ بصدرها {9}.وقال الفراء: يقال: مَخَرَتْ تَمْخُرُ وتَمْخَرُ {14} مَخرًا ومخُورًا.قال الأزهري: والقول في تفسير المواخر ما قاله ثعلب وأبو الهيثم؛ أنها تشق الماء شقًّا {15}، وسمعت أعرابيًّا يقول: مَخَرَ الذئبُ شاةً، أي شقَّ بطنَها {16}، وأصل المخر الشق، ومنه الحديث: ""إذا أراد أحدكم الخلا فليتمخر الريح"" {17}. قال أبو عبيد: يعني أن ينظر مجراها فلا يستقبلها {18}، فأما ما ذكره المفسرون فإنه يصح في المعنى؛ لأنها لا تشق الماءَ إلا إذا كانت جارية موقرة ويسمع لجريها وشقها الماءَ صوتٌ، وهي تشق الماء مقبلةً ومدبرةً، وذاهبةً وجائيةً.وقوله تعالى: ﴿وَلِتَبْتَغُوا مِنْ فَضْلِهِ﴾ يعني لتركبوا للتجارة فتطلبوا الربح من فضل الله."
  16,15,"قوله تعالى: ﴿وَأَلْقَى فِي الْأَرْضِ رَوَاسِيَ﴾ يريد جبالًا ثابتة، ﴿أَنْ تَمِيدَ بِكُمْ﴾ يعني لئلا تميد على قول الكوفيين، وكراهة أن تميد على قول البصريين، وذكرنا هذا عند قوله: ﴿يُبَيِّنُ اللَّهُ لَكُمْ أَنْ تَضِلُّوا﴾ [النساء: 176]، والميد: الحركة والاضطراب يمينًا وشمالاً، ماد يميد ميدًا {1}، قال ابن عباس: يريد أُوَتّدُها بالجبال لئلا تميد بأهلها.وقوله تعالى: ﴿وَأَنْهَارًا﴾ قال يريد: النِّيل {2} والفُرات ودِجلة {3} وسَيْحَان {4} وجَيْحَان {5}، ونصب: ﴿وَأَنْهَارًا﴾ بتقدير: وجعل، ودَلَّ: ألقى عليه، قال أبو إسحاق: لأن معنى ﴿وَأَلْقَى فِي الْأَرْضِ رَوَاسِيَ﴾: جعل فيها رواسي، يدل عليه قوله: ﴿وَالْجِبَالَ أَوْتَادًا﴾ {6} [النبأ: 7].وقوله تعالى: ﴿وَسُبُلَاَ﴾ قال ابن عباس: يريد طُرقًا إلى كل بلاد {7}، ﴿وَلَعَلَّكُمْ تَهْتَدُونَ﴾: لكي تهتدوا إلى مقاصدكم من البلاد فلا تضلون."
  16,16,"قوله تعالى: ﴿وَعَلَامَاتٍ﴾ منسوقة {1} على ما قبلها، والعلامة صورة يعلم بها المعنى من خط أو لفظ أو إشارة أو هيئة، وأصلها مشتق من العلم، واختلفوا في معناها؛ فقال الكلبي والقرظي: يعني الجبال {2}، وهي علامات للطرق بالنهار كالنجوم بالليل، وعلى هذا تَمَّ الكلام هاهنا، وبقية الآية ابتداء مع خبره، وهذا قول الأخفش {3}، وقال ابن عباس في رواية عطاء: يريد نجوم السماء، والوجه هو الأول {4}؛ لأنها {5} معطوفة على ما خلقت في الأرض، والنجوم لم تخلق في الأرض، ولأنه لو كان المراد بالعلامات النجوم لقال: وبها يهتدون، فلما قال: ﴿وَبِالنَّجْمِ﴾ دَلَّ أن المراد بالعلامات غيرُ النجم.وقوله تعالى: ﴿وَبِالنَّجْمِ هُمْ يَهْتَدُونَ﴾ قال مجاهد وإبراهيم: أراد جميع النجوم {6}، واختاره الزجاج؛ فقال: النجم والنجوم في معنى واحد، كما يقال: كثر الدِّرهم في أيدي الناس والدَّراهم {7}، وقال عطاء عن ابن عباس: يعني الجَدْي {8}، وقال السدي: يعني الثُّريا وبَنات نَعْش {9}، وقال الكلبي: يعني الفَرْقَدين والجَدْي {10}، وهو اختيار الفراء {11}، ﴿همْ يَهْتَدُونَ﴾ أي إلى الطريق والقبلة في البر والبحر."
  16,17,"قوله تعالى: ﴿أَفَمَنْ يَخْلُقُ كَمَنْ لَا يَخْلُقُ﴾ قال ابن عباس: يريد ما ذكر في هذه السورة، ومن يخلق هو الله عَزَّ وَجَلَّ، ﴿كَمَنْ لَا يَخْلُقُ﴾ يريد الأوثان؛ كقوله: ﴿هَذَا خَلْقُ اللَّهِ﴾ الآية. [لقمان: 11] وإنما قال: ﴿كَمَنْ لَا يَخْلُقُ﴾ للوثن لاقترانه في الذكر مع الخالق؛ كقوله: ﴿فَمِنْهُمْ مَنْ يَمْشِي عَلَى بَطْنِهِ﴾ الآية [النور: 45] قال الفراء: والعرب تقول: اشتَبه عليّ الراكبُ وجمله، فلا أدري مَنْ ذا ومنْ ذا؟ حيثُ جَمَعَها وأحدُهما إنسان؛ صَلحت (مَنْ) فيهما {1}، وقيل: إنهم لما عبدوها ذُكرت بلفظ (مَنْ) {2}؛ كقوله: ﴿أَلَهُمْ أَرْجُلٌ﴾ الآية [الأعراف: 195]، وقد مر.وقوله: ﴿أَفَلَا تَذَكَّرُونَ﴾ قال ابن عباس: يريد المشركين، يقول: أفلا تتعظون كما اتعظ المؤمنون {3}، قال أصحابنا: وهذه الآية دليل على أن الخالق واحد، وإنما يتميز الخالق من المخلوق بالقدرة على اختراع الخلق، فمن جعل نفسه خالقًا لأفعاله التي يفعلها فقد نصب نفسه خالقًا شريكًا لله في الخلق {4}، وقال أهل التأويل: معنى هذه الآية: إنكار تشبيه من يخلق بمن لا يخلق بالتسوية بينهما في العبادة، كما {5} لا يجوز أن يُسوّى بين من ينعم ومن لا ينعم في الشكر {6}."
  16,18,"قوله تعالى: ﴿وَإِنْ تَعُدُّوا نِعْمَتَ اللَّهِ لَا تُحْصُوهَا﴾ ذكرنا تفسيره في سورة إبراهيم {1}، وقال ابن عباس في هذه الآية: يريد أنّ نِعمي أكثر مما يُحصي أو يُعرف؛ منها ظاهر ومنها باطن.قوله تعالى: ﴿إِنَّ اللَّهَ لَغَفُورٌ﴾ أي لِما منكم من تقصير شكر نعمه، ﴿رَحِيمٌ﴾: بكم حيث لم يُقصْها عنكم بتقصيركم."
  16,19,""
  16,20,"وقوله تعالى: ﴿وَالَّذِينَ يَدْعُونَ﴾ قراءة العامة بالتاء {1}؛ لأن ما قبل هذه الآية كلها خطاب للكفار، وقرأ عاصم بالياء في: ﴿يَدْعُونَ﴾ {2} إخبارًا عن المشركين الذين يعبدون الأصنام من دون الله، ثم وصفها."
  16,21,"فقال: ﴿أَمْوَاتٌ﴾، قال الزجاج: أي وهم أموات {1}، وقال الفراء: وإن شئت رددت على أنه خبر للذين، كأنه قال: والذين تدعون من دون الله أموات، والأموات في هذا الموضع يعني بها أنها لاروح فيها {2}.وقوله تعالى: ﴿غَيْرُ أَحْيَاءٍ﴾ تأكيد {3}؛ إذ قد يقال للحي هو كالميت في البعد من أن يعلم.وقوله تعالى: ﴿وَمَا يَشْعُرُونَ أَيَّانَ يُبْعَثُونَ﴾ قال ابن عباس: وذلك أن الله تعالى يبعث الأصنام لها أرواح ومعها شياطينها فيتبرؤون من عابديهم، ثم يؤمر بالشياطين والذين كانوا يعبدونها إلى النار {4}، وقال أبو إسحاق: أي وما يشعرون متى يبعثون، و ﴿أيَّانَ﴾ في موضع نصب بقوله: ﴿يُبْعَثُونَ﴾، ولكنه مبني غيرُ مُنَوَّن {5} لأنه بمعنى الاستفهام، ولا يُعرب كما لا يُعرب متى وكيف وأين، إلا أن النون فتحت لالتقاء الساكنين {6}، واختير الفتح على الكسر؛ لأن الفتح أشبه بالألف وأخف معها، وذكرنا معنى أيّان عند قوله: ﴿أَيَّانَ مُرْسَاهَا﴾ [الأعراف: 187]، وقد تضمنت هذه الآية البيان عما تُوْجِبه صفة من ليس بحي من الامتناع أن يكون منه فعل، لاستحالة ذلك، ذكر الله ذلك في الآية الأولى؛ أن أصنامهم مخلوقة غير خالقة، وذكر في هذه الآية أنها مع كونها مخلوقةً مواتٌ غيرُ ذات روح وأنها مبعوثة، وهي لا تعلم متى وقت بعثها، وكل هذا يدل على جهل من عبدها أو أشركها بالله تعالى."
  16,22,"قوله تعالى: ﴿إِلَهُكُمْ إِلَهٌ وَاحِدٌ﴾ مضى الكلام في هذا في سورة البقرة [162].وقوله تعالى: ﴿فَالَّذِينَ لَا يُؤْمِنُونَ بِالْآخِرَةِ﴾ الآية دخلت الفاء للإتباع دون العطف، ذكر الله تعالى دلائل وحدانيته ثم أخبر أنه واحد لا نظير له ولا كفء ولا شريك، ثم أتبع هذا إنكار الكفار وحدانيته، وقال: ﴿قُلُوبُهُمْ مُنْكِرَةٌ﴾، أي: جاحدة غير عارفة ولا مُقِرَّة بالحق من توحيد الله، وقال ابن عباس: منكرة لهذا القرآن {1}، وذكرنا معنى الإنكار عند قوله: ﴿نَكِرَهُمْ﴾ في سورة هود [70].وقوله تعالى: ﴿وَهُمْ مُسْتَكْبِرُونَ﴾، أي: ممتنعون من قبول الحق، والاستكبار: الترفع بترك الإذعان للحق، قال ابن عباس: ﴿وَهُمْ مُسْتَكْبِرُونَ﴾: عن عبادة الله."
  16,23,"قوله: ﴿لَا جَرَمَ أَنَّ اللَّهَ﴾ الآية، ذكرنا معنى لا جرم، والخلاف فيه في سورة هود عند) {1} قوله ﴿لَا جَرَمَ أَنَّهُمْ فِي الْآخِرَةِ هُمُ الْأَخْسَرُونَ﴾ [هود: 22] ، وليس يحتمل هاهنا من تلك الأقوال إلا قولًا واحدًا، وهو أن يكون بمعنى: حقًّا، وبهذا فسره ابن عباس {2} واختاره الزجاج، فقال: حقًّا أن الله {3}، ومذهبه في لا جرم في سورة هود غير هذا {4}؛ فمعنى لا جرم هاهنا: تأكيدٌ وقَسمٌ ﴿أَنَّ اللَّهَ يَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ﴾، وتأكيد ذلك تأكيد جزائهم؛ كأنه قيل: يجازيهم بما يسرون وما يعلنون؛ لأنه يعلم ذلك.وقوله تعالى: ﴿إِنَّهُ لَا يُحِبُّ الْمُسْتَكْبِرِينَ﴾، أي: لا يثيبهم ولا يمدحهم ولا يرضى عنهم {5}."
  16,24,"قوله تعالى: ﴿وَإِذَا قِيلَ لَهُمْ مَاذَا أَنْزَلَ رَبُّكُمْ قَالُوا أَسَاطِيرُ الْأَوَّلِينَ﴾، معنى أساطير الأولين ذكرناه في سورة الأنعام [25]، قال ابن عباس: نزلت في النضر بن الحارث وأصحابه؛ كان خرج إلى الحِيرَة فاشترى أحاديث كَليلة ودِمنة وأساطير الأولين، وكان يقول: تعالوا أقرأ عليكم ما يقرأ محمد على أصحابه؛ أساطير الأولين {1}.وقال أبو إسحاق في هذه الآية: (ما) مبتدأة و (ذا) في موضع الذي، المعنى: ما الذي أنزل ربكم؟ وأساطير مرفوعة على الجواب؛ كأنهم قالوا: الذي أَنْزَلَ أساطيرُ الأولين؛ الذي يذكرون أنه منزلٌ أساطيرُ الأولين، أي أكاذيبهم {2}، وشرح أبو علي هذا فقال: رُفِعَ الأساطيرُ؛ لأن ذا بعد {3} ما بمنزلة الذي {4}، ولم يُجعل معها بمنزلة اسم واحد، فكأنه قال: ما الذي أنزل ربكم؟ فقيل: أساطير الأولين، أي الذي أنزله أساطير الأولين، فَيُضَم المبتدأ الذي كان خبرًا في سؤال السائل، على هذا يرتفع الأساطير في قول سيبويه {5}، قال: وروي عن أبي زيد وغيره من النحويين أنهم قالوا: لم يُقِرُّوا بإنزال الله لذلك، فكأنهم لم يجعلوا أساطير الأولين خبر الذي أنزل، وعلى هذا يرتفع الأساطير بخبر ابتداء محذوف؛ كأنه قيل الذي يعنون والذي يسألون عنه أساطير الأولين، فحذف المبتدأ لدلالة ما في السؤال عليه {6}، ووجه قول سيبويه: إذا جعلت أساطير الأولين خبر (ذا) الذي هو بمعنى الذي في قوله: ﴿مَاذَا أَنْزَلَ رَبُّكُمْ﴾ أن يكون المعنى: الذي أنزله ربكم عندكم وفي قولكم أساطير الأولين؛ كما جاء: ﴿وَقَالُوا يَا أَيُّهَ السَّاحِرُ ادْعُ لَنَا رَبَّكَ﴾ [الزخرف: 49] ، وكما قالوا: ﴿يَا أَيُّهَا الَّذِي نُزِّلَ عَلَيْهِ الذِّكْرُ﴾ [الحجر: 6]، أي: عنده وعند من تبعه، فيمكن أن يُجعلَ الأساطيرُ خبر من غير أن يُقِرُّوا بالإنزال على الوجه الذي ذكرنا، وهذا معني قول أبي إسحاق، أي الذي يذكرون أنه منزل أساطير الأولين."
  16,25,"قوله تعالى: ﴿لِيَحْمِلُوا أَوْزَارَهُمْ﴾ الآية، اللام في ﴿لِيَحْمِلُوا﴾ لام العاقبة، وهم لم يقولوا للقرآن: أساطير الأولين، ليحملوا الأوزار؛ ولكن لما كانت عاقبتهم ذلك بهذا القول، جاز أن يقال: فعلوا ذلك له؛ كقوله عز وجل: ﴿فَالْتَقَطَهُ آلُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّا وَحَزَنًا﴾ [القصص: 8]، وهم لم يلتقطوا لذلك، وكما قال النابغة:جاءت لِتُطعِمَه لحمًا ويَفْجعها بابن ... فقد أطعمتْ لحمًا وقد فَجعا {1}يعني بقرًا جاءت مع عجلها للرعي، فوقع الذئب على عجلها فأكله، فزعم أنها جاءت لذلك، وهي لم تجئ له.قوله تعالى: ﴿كَامِلَةٌ﴾، قال صاحب النظم: أي أن غيرهم لا يحمل عنهم من أوزارهم شيئًا، ويجوز أن يكون المعنى: أنهم لا يُكفَّر عنهم شيء من ذنوبهم بما يصيبهم في الدنيا من نكبة وبلية كالمؤمنين {2}؛ لأنهم {3} كفار، فهم يرِدون الآخرة بما اكتسبوا من الآثام كلها.وقوله تعالى: ﴿وَمِنْ أَوْزَارِ الَّذِينَ يُضِلُّونَهُمْ﴾ لأنهم كانوا رؤساء، فلما قالوا في القرآن: إنه أساطير الأولين، اقْتُدي بهم فيه، فحُمل عليهم من أوزارهم، يبين هذا ما روي أن النبيّ -ﷺ- قال: ""أيّما داعٍ دعا إلى ضلالة فاتُّبع فإن عليه أوزارَ من اتَّبَعه، من غير أن يَنقصَ من أوزارهم شيء"" {4}.فهؤلاء لمّا كانوا دعاةَ الضلالة، حُمِّلوا من أوزار من اتبعهم.و (من) في قوله: ﴿وَمِنْ أَوْزَارِ الَّذِينَ يُضِلُّونَهُمْ﴾ ليست للتبعيض؛ لأنها لو كانت للتبعيض لخفَّ عن الأَتْبَاعِ بعضُ أوزارهم يحمل الرؤساء ذلك، ولكنها للجنس، أي ليحملوا من جنس أوزار الأتباع، وإنما ذلك لأن النبيّ -ﷺ- قال: ""من غير أن ينقص من أوزارهم شيء""، ولو جعلنا المحمولَ من أوزار الأتباع نقصت أوزارهم، فليس يأتي التابعُ بجنس من الذنب في ضلالته إلا وعلى المتبوع مثلُ ذلك، كما قال -ﷺ-: ""فإن عليه مثل أوزار من اتبعه"".وقوله تعالى: ﴿بِغَيْرِ عِلْمٍ﴾، أي: بجهل، يريد أن هؤلاء المتبوعين يُضِلّون من اتبعهم جهلًا منهم بما يفعلون من احتقاب {5} أوزارهم ومثل أوزار من اتبعهم، ثم ذم الله صنيعهم فقال: ﴿أَلَا سَاءَ مَا يَزِرُونَ﴾، ومضى تفسير هذا وتفسير الوزر عند قوله: ﴿وَهُمْ يَحْمِلُونَ أَوْزَارَهُمْ عَلَى ظُهُورِهِم﴾ الآية [الأنعام: 31]."
  16,26,"قوله تعالى: ﴿قَدْ مَكَرَ الَّذِينَ مِنْ قَبْلِهِمْ﴾ قال جماعة المفسرين: يعني نمرود بن كنعان، بَنَى صرحًا طويلًا ورام منه الصعود إلى السماء ليقاتل أهلها {1}. ومعنى المكر هاهنا: التدبيرُ الفاسد؛ روى ثعلب عن ابن الأعرابي في قوله: ﴿وَمَكَرُوا مَكْرًا﴾ [النمل: 50] قال: دبروا {2}، والمراد في هذه الآية {3} تدبيره في بناء الصرح لقتال أهل السماء.وقوله تعالي: ﴿فَأَتَى اللَّهُ بُنْيَانَهُمْ﴾، أي: أتى أمرُ الله، وهي الريح التي خربتها وحركتها، وهو ما ذكر المفسرون؛ أن الله تعالى أرسل ريحًا فألقت رأس الصرح في البحر وخَرَّ عليهم الباقي {4}، فأمْرُ الله الذي أتى البنيان يجوز أن يكون الريح، ويجوز أن يكون أمره للبنيان بالانهدام، فالآية من باب حذف المضاف؛ وحذف المضاف هاهنا للتهويل والتعظيم، وقد سبق بيان هذا في قوله: ﴿إِلَّا أَنْ يَأْتِيَهُمُ اللَّهُ﴾ [البقرة: 210]، والبنيان اسم للبناء.وقوله تعالى: ﴿مِنَ الْقَوَاعِدِ﴾ قال أبو إسحاق: أي من أساطين البناء التي تَعْمِده {5}، وذكرنا معنى القواعد للبناء في سورة البقرة [127].وقوله تعالى: ﴿فَخَرَّ عَلَيْهِمُ السَّقْفُ مِنْ فَوْقِهِمْ﴾، أي: سقط عليهم البيوت؛ على أصحاب نمرود {6}، وذِكْر ﴿مِنْ فَوْقِهِمْ﴾ ليدل أنهم كانوا تحته، إذ {7} يقول القائل: تهدمت عليّ المنازل، ولم يكن تحتها، هذا قول ابن الأنباري، قال: والعرب تقول: تداعت علينا الدار، وخَرِب علينا الحانوت، وإن لم يكونوا تحته {8}، ويجوز أن يكون للتأكيد.وقوله تعالى: ﴿وَأَتَاهُمُ الْعَذَابُ مِنْ حَيْثُ لَا يَشْعُرُونَ﴾، أي: من حيث ظنوا أنهم منه في أمان، وقال عطاء عن ابن عباس: يريد بالبعوضة؛ يعني التي أهلك بها نمرود {9}."
  16,27,"قوله تعالى: ﴿ثُمَّ يَوْمَ الْقِيَامَةِ يُخْزِيهِم﴾، معنى الإخزاء ذكرنا عند قوله: ﴿إِنَّكَ مَنْ تُدْخِلِ النَّارَ فَقَدْ أَخْزَيْتَهُ﴾ [آل عمران: 192].وقوله تعالى: ﴿وَيَقُولُ أَيْنَ شُرَكَائِيَ﴾ قال الزجاج: شركائي حكايته لقولهم، والله لا شريك له، والمعنى: أين الذين في دعواكم أنهم شركائي {1}.قال أبو علي: سبحانه لم يثبت بهذا الكلام له شريكًا، وإنما أُضيف على حسب ما كانوا يقولونه وينسبونه، وكما أُضيفت هذه الإضافة كذلك أضيفت إليهم في قوله: ﴿أَيْنَ شُرَكَاؤُكُمُ الَّذِينَ كُنْتُمْ تَزْعُمُونَ﴾ [الأنعام: 22]، وفي أخرى: ﴿وَقَالَ شُرَكَاؤُهُمْ مَا كُنْتُمْ إِيَّانَا تَعْبُدُونَ﴾ [يونس: 28]، فإنما أُضيفوا هذه الإضافة على حسب ما كانوا يسمونه ويعتقدونه فيهم؛ كقوله: ﴿وَقَالُوا يَا أَيُّهَ السَّاحِرُ ادْعُ لَنَا رَبَّكَ﴾ [الزخرف: 49]، وقوله: ﴿يَا أَيُّهَا الَّذِي نُزِّلَ عَلَيْهِ الذِّكْرُ إِنَّكَ لَمَجْنُونٌ﴾ [الحجر: 6]، وقد تقع الإضافة لبعض الملابسة دون التحقيق، كقول الشاعر {2}:إذا قُلْتُ قَدْني قَال باللهِ حَلْفَةً ... لَتُغْنيَ عَنِّي ذا إنائِكَ أَجْمَعَا {3}فأضاف الإناء إليه لشربه منه، والإناء في الحقيقة لمن سقى به دون من شرب منه، وهذا كما يقول لمن يحمل خشبة ونحوها: خذ طَرَفَكَ وآخذ طَرَفي، فتَنْسِبُ إليه الطرف الذي يليه كم تنسب إلى نفسك الطرف الذي يليك، فعلى هذا تجري الإضافة في قوله: ﴿شُرَكَائِيَ﴾ {4}، ومعنى: ﴿أَيْنَ شُرَكَائِيَ﴾ أي: أين هم لا يحضرونكم فيدفعوا عنكم العذاب.وقوله تعالى: ﴿الَّذِينَ كُنْتُمْ تُشَاقُّونَ فِيهِمْ﴾ قال ابن عباس: تخالفون {5}.قال أهل المعاني: معناه يكونون في أمر الشركاء في جانب والمسلمون في جانب، لا يكونون معهم يدًا واحدة {6}؛ يخالفونهم فيها فيعبدونهما ولا يعبدون الله، وقرأ نافع بكسر النون {7}.ووجهه ما ذكرنا في قوله: ﴿فَبِمَ تُبَشِّرُونَ﴾ [الحجر: 54] المعنى على هذه القراءة ما رواه عطاء عن ابن عباس، قال: يريد تنازعوني فيهم وتتخذونهم أولياء من دوني، وعلى هذا معنى مخالفتهم الله في الشركاء {8} مخالفتهم أمر الله؛ كما ذكرنا في قوله: ﴿شَاقُّوا اللَّهَ وَرَسُولَهُ وَمَنْ يُشَاقِقِ اللَّهَ وَرَسُولَهُ﴾ [الأنفال: 130].وقوله تعالى: ﴿قَالَ الَّذِينَ أُوتُوا الْعِلْمَ﴾ قال ابن عباس: يريد الملائكة {9}، وقال آخرون: هم المؤمنون {10}؛ يقولون حين خزى الكفار في القيامة: ﴿إِنَّ الْخِزْيَ الْيَوْمَ﴾: عليهم لا علينا."
  16,28,"قوله تعالى: ﴿الَّذِينَ تَتَوَفَّاهُمُ الْمَلَائِكَةُ ظَالِمِي﴾ ذكرنا معنى هذا في سورة النساء.وقوله تعالى: ﴿فَأَلْقَوُا السَّلَمَ﴾ قال ابن عباس: استسلموا وأقروا لله بالربوبية {1}، وقال السدّي: انقادوا واستسلموا عند الموت {2}.قال الزجاج: ذكر السَّلَمَ، وهو الصلح، بإزاء المشاقة {3}، يريد أن الله تعالى أخبر عنهم بالمشاقة في الدنيا، فأخبر أنهم عند الموت ينقادون ويتبرؤون من الشرك، كما ذكره ابن عباس.وقوله تعالى: ﴿مَا كُنَّا نَعْمَلُ مِنْ سُوءٍ﴾ أي قالوا: ما كنا نعمل من سوء، قال ابن عباس: يريد الشرك {4}، فقالت الملائكة ردًّا عليهم وتكذيبًا لهم: ﴿بَلَى إِنَّ اللَّهَ عَلِيمٌ بِمَا كُنْتُمْ تَعْمَلُونَ﴾ [من التكذيب والشرك، ومعنى (بلى): رد لقولهم ﴿مَا كُنَّا نَعْمَلُ مِنْ سُوءٍ﴾، وقد ذكرنا معنى (بلى)] {5} عند قوله: ﴿إِلَّا أَنْ يَأْتِيَهُمُ اللَّهُ﴾ [البقرة: 210]."
  16,29,"وقوله تعالى: ﴿فَلَبِئْسَ مَثْوَى الْمُتَكَبِّرِينَ﴾ قال ابن عباس: يريد مقام المتكبرين عن التوحيد وعبادة الله عز وجل {1}، كقوله: ﴿إِنَّهُمْ كَانُوا إِذَا قِيلَ لَهُمْ لَا إِلَهَ إِلَّا اللَّهُ يَسْتَكْبِرُونَ﴾ [الصافات: 35]."
  16,30,"قوله تعالى: ﴿وَقِيلَ لِلَّذِينَ اتَّقَوْا﴾ قال ابن عباس: يريد الذين خافوا الله وصدقوا نَبِيَّه وأيقنوا أنه لا إله غيره، ﴿مَاذَا أَنْزَلَ رَبُّكُمْ﴾ قال المفسرون: هذا كان في أيام المواسم، يأتي الرجل مكة فيَسأل المشركين عن محمد وأمره، فيقولون: إنه ساحر وكاهن وكذاب، (فيأتي المؤمنين ويسألهم عن محمد وما أتى به من الكتاب وما أنزل الله عليه، فيقول) {1} المؤمنون خيرًا {2}، قال ابن عباس: يريد ثوابًا؛ يعني أنهم إذا سُئلوا عن ما أنزل الله على محمد، قالوا: أنزل عليه الخير عن ثواب المحسن، فقالوا: أنزل ثوابًا، أي ذِكْرَه، ولهذا نصب خيرًا؛ لأنه على معنى أنزل خيرًا، ويكون هذا على أن (ما) و (ذا) كالشيء الواحد، والمعنى: أيُّ شيءٍ أنزل؟ ﴿قَالُوا خَيْرًا﴾ على جواب ماذا، أي: أنزل خيرًا، ثم فَسَّرَ ذلك الخير؛ فقال: ﴿لِلَّذِينَ أَحْسَنُوا فِي هَذِهِ الدُّنْيَا حَسَنَة﴾ قال ابن عباس: يريد: قالوا: لا إله إلا الله {3}، وهذا على أن قوله: ﴿لِلَّذِينَ أَحْسَنُوا﴾ إخبارًا عن الله تعالى، أخبر أن من أحسن في الدنيا فله جزاء ذلك عند الله حسنة، قال ابن عباس: يريد مضعفة بعشر {4}، ودلّ بهذا على أن الذي قاله المؤمنون {5} اكتسبوا به حسنة، والوجهان ذكرهما أبو إسحاق {6}.وقوله تعالى: ﴿وَلَدَارُ الْآخِرَةِ﴾ يعني الجنة، ومضى الكلام في هذا في سورة الأنعام [32].وقوله تعالى: ﴿وَلَنِعْمَ دَارُ الْمُتَّقِينَ﴾، أي: ولَنِعْمَ دارُ المتقين دار الآخرة، فحذفت لسبق ذكرها، هذا إذا لم تجعل هذه الآية متصلة بما بعدها، [وإن جعلتها متصلة] {7} قلت: ﴿وَلَنِعْمَ دَارُ الْمُتَّقِينَ (30) جَنَّاتُ عَدْنٍ﴾ فترفع جنات على أنها اسم لنعم؛ كما تقول: نعم الدار دار ينزلها."
  16,31,"قوله تعالى: ﴿جَنَّاتُ عَدْنٍ﴾ ذكرنا وجهَ ارتفاعها إن كانت موصولة، وإن كانت مقطوعة، فقال الزجاج: جنات مرفوعة بإضمار هي؛ كأنك لمّا قلت: ﴿وَلَنِعْمَ دَارُ الْمُتَّقِينَ﴾، قيل: أي دار هذه الممدوحة؟ فقلت على جواب السائل: جنات عَدْن، أي هي جناتُ عَدْن {1}، وإن شئت رفعتها على الاستئناف وجعلت يدخلونها الخبر، هذا قول الفراء {2}، وعند الزجاج: يجوز أن يكون الخبر نِعم دار المتقين؛ لأنه قال: وان شئت رفعت على الابتداء، ويكون المعنى: جناتُ عَدْنٍ نِعْمَ دارُ المتقين {3}."
  16,32,"قوله تعالى: ﴿الَّذِينَ تَتَوَفَّاهُمُ الْمَلَائِكَةُ﴾ الذين في موضع نصب؛ لأنه صفة المتقين في قوله: ﴿كَذَلِكَ يَجْزِي اللَّهُ الْمُتَّقِينَ﴾.قولى تعالى: ﴿طَيِّبِينَ﴾، أي: بأعمالهم الصالحة، خلاف من يتوفاهم خبيثين بأعمالهم القبيحة، قال الكلبي: طيبين من الشرك {1}، وقال مجاهد: زاكية أفعالهم وأقوالهم {2}."
  16,33,"قوله تعالى: ﴿هَلْ يَنْظُرُونَ إِلَّا أَنْ تَأْتِيَهُمُ الْمَلَائِكَةُ﴾ نظير هذه الآية في سورة البقرة [آية: 210]، وآخر سورة الأنعام [آية: 158]، وقد مر، والمعنى: هل ينظرون إلا الموت؛ لأن الملائكة إنما تأتيهم لقبض أرواحهم، ﴿أَوْ يَأْتِيَ أَمْرُ رَبِّكَ﴾ قال ابن عباس: يريد القتل وغيره، وقال قتادة ومجاهد: يعني القيامة {1}.وقال الزجاج: ما وعدهم الله به من عذابه {2}.قال صاحب النظم: إنهم لا ينتظرون ذلك على الحقيقة؛ لأنهم كانوا لا يؤمنون بالله، كيف ينتظرون أمره؟! ولكن لمّا كان امتناعهم من الدخول في الإيمان موجبًا عليهم إتيان أمر الله والملائكة بما قدّر عليهم من العذاب، وكان عاقبة أمرهم إلى ذلك، أضيف ذلك إليهم على المجاز والسعة، وجعل مجيء ذلك انتظارًا منهم له؛ فكأنه عز وجل قال: هل يكون مدة إقامتهم على كفرهم إلا مقدار إيقاعي بهم وإنزالي العذاب عليهم، وهذا كما قلنا في لام العاقبة في مواضع، لمّا كانت العاقبة تؤدي إلى ذلك جُعل سببًا له وإن لم يكن في الحقيقة كذلك؛ كقوله: ﴿فَالْتَقَطَهُ آلُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّا﴾ الآية [القصص: 8]، وقد مر {3}، وهذا الذي ذكره صاحب النظم وجه جيد في هذه الآية لم يذكره في نظيرها في سورة البقرة والأنعام.وقوله تعالى: ﴿كَذَلِكَ فَعَلَ الَّذِينَ مِنْ قَبْلِهِمْ﴾ يريد كفار الأمم الماضية، وفي الآية حذف على قول الزجاج؛ لأنه قال: أي كذلك فعلوا فأتاهم أمرُ الله بالعذاب {4}، ﴿وَمَا ظَلَمَهُمُ اللَّهُ﴾: بتعذيبهم ﴿وَلَكِنْ كَانُوا أَنْفُسَهُمْ يَظْلِمُونَ﴾: بإقامتهم على الشرك وكفران ما أنعم الله عليهم، وإن شئت حملت الكلام على التقديم والتأخير فقلت: التقدير: ﴿كَذَلِكَ فَعَلَ الَّذِينَ مِنْ قَبْلِهِمْ﴾، ﴿فَأَصَابَهُمْ سَيِّئَاتُ مَا عَمِلُوا﴾ الآية، ﴿وَمَا ظَلَمَهُمُ اللَّهُ﴾ الآية، وهو قول ابن عباس: يريد جزاء ما عملوا من الشرك {5}، ﴿وَحَاقَ بِهِمْ مَا كَانُوا بِهِ يَسْتَهْزِئُونَ﴾: من العذاب والنقمة."
  16,34,"16:33"
  16,35,"قوله تعالى: ﴿وَقَالَ الَّذِينَ أَشْرَكُوا﴾ يعني أهل مكة، ﴿لَوْ شَاءَ اللَّهُ مَا عَبَدْنَا مِنْ دُونِهِ مِنْ شَيْءٍ﴾: من البحيرة {1} والسائبة {2} وسائر ما حرموا، نظير هذه الآية في سورة الأنعام [آية: 148]، ومضى الكلام هناك مستقصى، على أن أبا إسحاق قال هاهنا: إن المشركين قالوا هذا على جهة الهزء؛ كما قال قوم شعيب له: ﴿إِنَّكَ لَأَنْتَ الْحَلِيمُ الرَّشِيدُ﴾ [هود: 87]، ولو قالوا هذا معتقدين لكانوا مؤمنين ولكنهم قالوا مستهزئين، وكذلك هؤلاء لو قالوا مُحَقِّقِينَ، ما قيل: إنهم مكذبون، كما كَذَّب الذين من قبلهم {3}، وهو قوله: ﴿كَذَلِكَ فَعَلَ الَّذِينَ مِنْ قَبْلِهِمْ﴾، أي: من تكذيب الرسل وتحريم ما أحل الله، قال ابن عباس: يريد عمرو بنَ لُحَيٍّ وأصحابَه {4}، ﴿فَهَلْ عَلَى الرُّسُلِ إِلَّا الْبَلَاغُ الْمُبِينُ﴾ قال: يريد: قد بَلَّغْتَ رسالتي وبَلَّغَ مَن قبلك، يعني ليس عليهم إلا التبليغ، فأما الهداية فهو إلى الله تعالى؛ يهدي من يشاء ويضل من يشاء، وقد حَقَّقت هذا فيما بعد، وهو:"
  16,36,"قوله: ﴿وَلَقَدْ بَعَثْنَا فِي كُلِّ أُمَّةٍ رَسُولًا﴾، يعني كما بعثناك في هؤلاء، ﴿أَنِ اعْبُدُوا اللَّهَ﴾ تعالى، أي: بعبادة الله تعالى، والتقدير: بأن اعبدوا الله، فحذف الجار، ﴿وَاجْتَنِبُوا الطَّاغُوتَ﴾، أي: الشيطانَ وكلَّ من يدعو إلى الضلالة، ﴿فَمِنْهُمْ مَنْ هَدَى اللَّهُ﴾: أرشده، {وَمِنْهُمْ مَنْ حَقَّتْ عَلَيْهِ الضَّلَالَةُ} قال ابن عباس: يريد في سابق علمي {1}.وقال الزجاج: أعلم اللهُ أنه بَعَثَ الرسلَ بالأمر بالعبادة، وهو من وراء الإضلال والهداية، وهذا يدل على أنهم لو قالوا: ﴿لَوْ شَاءَ اللَّهُ مَا عَبَدْنَا﴾ الآية، معتقدين لكانوا صادقين {2}، ومعنى ﴿حَقَّتْ عَلَيْهِ الضَّلَالَةُ﴾: وجب عليهم الكفر، كما قال: ﴿فَرِيقًا هَدَى وَفَرِيقًا حَقَّ عَلَيْهِمُ الضَّلَالَةُ﴾ [الأعراف: 30]، وكقوله: ﴿إِنَّ الَّذِينَ حَقَّتْ عَلَيْهِمْ كَلِمَتُ رَبِّكَ لَا يُؤْمِنُونَ﴾ [يونس: 96]، ثم قال: ﴿فَسِيرُوا﴾ الآية، أي: فسيروا معتبرين في الأرض بآثار الأمم المكذبة، فتعرفوا أن العذاب بإزائكم كما نزل بهم، ثم أكد أن من حقَّت عليه الضلالة لا يهتدي."
  16,37,"فقال -عز من قائل-: ﴿إِنْ تَحْرِصْ عَلَى هُدَاهُمْ﴾ أي إن تطلب بجهدك ذلك، ﴿فَإِنَّ اللَّهَ لَا يَهْدِي مَنْ يُضِلُّ﴾، أي: من يُضلُّه، فالراجع إلى الموصول الذي هو (مَنْ) محذوف مقدر {1}، وهذا كقوله: ﴿مَنْ يُضْلِلِ اللَّهُ فَلَا هَادِيَ لَهُ﴾ [الأعراف: 186]، وكقوله: ﴿فَمَنْ يَهْدِيهِ مِنْ بَعْدِ اللَّهِ﴾ [الجاثية: 23]، أي: من بعد إضلال الله إياه {2}، وقرأ أهل الكوفة يَهْدِي بفتح الياء {3}، وهو يحتمل وجهين: {4}أحدهما: أن المعنى فإن الله لا يُرْشد من أضله، وبهذا فَسَّره ابن عباس {5}.والثاني: أنّ يَهْدِي بمعنى يَهْتَدي، قال الفراء: والعرب تقول: قد هَدَّي الرجلُ؛ يريدون قد اهتدى، ومثله قوله: ﴿أَمَّنْ لَا يَهِدِّي إِلَّا أَنْ يُهْدَى﴾ {6} [يونس: 35]، قال ابنُ مجاهد {7}: ولم يختلفوا في ﴿يُضِلُّ﴾ أنه مضومُ الياء {8}."
  16,38,"قوله تعالى: ﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ﴾ مضى الكلام في هذا في سورة الأنعام [109]، قال ابن عباس: أغلظوا في الأيمان تكذيبًا منهم بقدرة الله على البعث بعد الموت {1}، فقال الله تعالى ردًّا عليهم: ﴿بَلَى وَعْدًا عَلَيْهِ حَقًّا﴾، أي: لَيَبْعَثَنَّهم وعدًا عليه حقًّا، وهو مصدر مؤكد؛ أي وعدَ البعثِ وعدًا حقًّا لا خُلْفَ فيه؛ لأنه إذا قال يبعثهم دَلَّ على وعدٍ بالبعث وعدًا."
  16,39,"قوله تعالى: ﴿لِيُبَيِّنَ لَهُمُ الَّذِي يَخْتَلِفُونَ فِيهِ﴾ من أمر البعث، واختلافهم فيه: ذهابهم إلى خلاف ما ذهب إليه المؤمنون، واللام في قوله: ﴿لِيُبَيِّنَ﴾ متعلقة بالبعث، المعنى: بلى يبعثهم ليبين لهم، قال الزجاج: ويجوز أن تكون متعلقة بقوله: ﴿وَلَقَدْ بَعَثْنَا فِي كُلِّ أُمَّةٍ رَسُولًا﴾، (ويكون المعنى: بعثنا في كل أمة رسولاً) {1}؛ ليبين لهم اختلافهم وأنهم كانوا من قبله على ضلالة {2}، فعلى هذا لا يعود البيان إلى بيان البعث، وعلى القول الأول: يعود إلى بيان البعث بعد الموت، وهو قول ابن عباس {3}؛ لأنه قال: ﴿لِيُبَيِّنَ لَهُمُ الَّذِي يَخْتَلِفُونَ فِيهِ﴾: بهذا الوعد الذي قال: ﴿وَعْدًا عَلَيْهِ حَقًّا﴾، ﴿وَلِيَعْلَمَ الَّذِينَ كَفَرُوا أَنَّهُمْ كَانُوا كَاذِبِينَ﴾: فيما أقسموا فيه."
  16,40,"قوله تعالى: ﴿إِنَّمَا قَوْلُنَا لِشَيْءٍ﴾ الآية. قال ابن عباس: أخبر بقدرته وقوته، يريد ليس كما يتكلف المخلوقون من الأعوان والاله أمر الله أوحى من ذلك {1}. وقال الزجاج: أعلمهم الله سهولة خلق الأشياء عليه، فأعلم أنه متى أراد الشيء كان {2}.قال ابن الأنباري: وقع اسم الشيء على المعلوم عند الله عز وجل قبل الخلق؛ لأنه بمنزلة ما قد عوين وشوهد {3}.قال الفراء: القول مرفوع بقوله: ﴿أَنْ نَقُولَ﴾ كما تقول: إنما قولنا الحق، هذا كلامه {4}، وبيانه ما ذكره الزجاج، فقال: ﴿قَوْلُنَا﴾ رفع بالابتداء وخبره: ﴿أَنْ نَقُولَ﴾، المعنى: إنما قولنا لكل مراد قولنا كن، فإن قيل كيف خاطب المعدوم بقوله: ﴿كُنْ﴾، قلنا: هذا تمثيل لنفس الكلفة والمعاناة، ومخاطبةُ الخلق بما يعقلون ليس أنه يخاطب المعدوم؛ لأن ما أراد الله عز وجل فهو كائن على كل حال، وعلى ما أراده من الإسراع، لو أراد خلق الدنيا والسموات والأرض في قدر لمح البصر لَقَدَر على ذلك، ولكن العباد خُوطبوا بما يعقلون {5}، وذكرنا في سورة البقرة عند قوله: ﴿وَإِذَا قَضَى أَمْرًا فَإِنَّمَا يَقُولُ لَهُ كُنْ فَيَكُونُ﴾ [آية:117] أجوبة سوى هذا.واختلفوا في قوله: ﴿فَيَكُونُ﴾، فقرأه أكثرُ القراء بالرفع {6} على: (فهو يكون)، قال الفراء: الرفع على أن تجعل ﴿أَنْ نَقُولَ لَهُ﴾ كلامًا تامًّا يخبر بأنه سيكون؛ كما تقول للرجل: إنّما يكفيه أن آمره، فيفعلُ بعد ذلك ما يؤمر {7}، برفع فيفعلُ؛ على معنى فهو يفعل وسيفعل، وقرأ ابن عامر والكسائي: ﴿فَيَكُونُ﴾ نصبًا {8}، عطفًا على ﴿أَنْ نَقُولَ﴾، المعنى: أن نقول فيكون، هذا قول جميع النحويين {9}.قال الزجاج: ويجوز أن يكون نصبًا على جواب كن {10}.قال أبو علي: هذا الوجه الذي أجازه من النصب في يكون لم يجزه أحد من أصحابنا غيرُه، ولم أعلم لغيره إجازةً له على هذا الوجه، ووجدت الكسائي يقول: إنه سمعه من العرب أكثر من خمسين مرة بالنصب، وما علمته حَمَل ذلك على أنه جواب، ولكن على (أنْ)، وحَمْلُه على الجواب غيرُ سائغ؛ لأن (كُنْ) وإن كان على لفظ الأصل فليس القصد به هاهنا الأمر، إنما هو -والله أعلم- الإخبار عن كون الشيء وحدوثه، وإلى هذا ذهب أبو العباس وغيره {11}، وقد ذكرنا هذا في سورة البقرة {12}."
  16,41,"قوله تعالى: ﴿وَالَّذِينَ هَاجَرُوا فِي اللَّهِ مِنْ بَعْدِ مَا ظُلِمُوا﴾ الآية. قال الفراء: ﴿وَالَّذِينَ﴾ موضعها رفع {1}؛ يريد أن هذا كلام مستأنفٌ لا تعلق له ما قبله، قال المفسرون: نزلت هذه الآية في قوم آذاهم المشركون وعذبوهم بمكة؛ صهيب وبلال وخَبَّاب {2}، ومعنى ﴿هَاجَرُوا فِي اللَّهِ﴾: هاجروا في رضا الله وطلب ثوابه.وقوله تعالى: ﴿لَنُبَوِّئَنَّهُمْ فِي الدُّنْيَا حَسَنَةً﴾ قال الشعبي وقتادة: بوأهم الله المدينة {3}، وعلى هذا يكون التقدير: لنُبَوّئَنهم في الدنيا دارًا حسنة أو بلدة حسنة، يعني المدينة؛ فإن الله تعالى جعلها لهم دار هجرة، وجعل لهم أنصارًا من المؤمنين فيها، وجمعهم فيها مع النبيّ -ﷺ-، وقال مجاهد: لنَرْزُقنّهم في الدنيا {4}.وقال الضحاك: يعني بالحسنة: النصر والفتح {5}، وعلى هذا تقدير الآية: لنبوئنهم في الدنيا ولنرزقنهم حسنة أو لنعطينهم حسنة، فحذف ذلك اكتفاءً بالأول كقوله {6}:علفتها تبنًا وماءً باردًا {7} وهذا باب قد مرّ منه كثير، فيكون معنى الآية: أنزلهم المدينة وأطعمهم الغنيمة، وهذا الوجه اختيار الفراء؛ لأنه قال في هذه الآية: نزول المدينة ولنُحَلِّلنَّ لهم الغنائم {8}، وعلى هذا التفسير حذف من الآية شيئان: المفعول الثاني للتَّبوِئة، والفعل الناصب للحسنة.وقوله تعالى: ﴿وَلَأَجْرُ الْآخِرَةِ أَكْبَرُ لَوْ كَانُوا يَعْلَمُونَ﴾ قال ابن عباس: يريد أن أمر الجنّة أعظم وأكثر {9} من أن يعلمه أحدٌ ويقدر أحدٌ على وصفه {10}، وما ظنُّك بما قال الله له: أكبر."
  16,42,"قوله تعالى: ﴿الَّذِينَ صَبَرُوا﴾، في محل ﴿الَّذِينَ﴾ وجوه: أحدهما: أن يكون بدلاً من المضمر في: ﴿لَنُبَوِّئَنَّهُمْ﴾، ويجوز أن يكون على تقدير: هم الذين، قال ابن عباس: أثنى عليهم ومدحهم بالصبر، فقال: ﴿الَّذِينَ صَبَرُوا﴾ يريد على دينهم وعلى عذاب المشركين إيّاهم، وهم في ذلك واثقون بالله متوكلون عليه."
  16,43,"قوله تعالى: ﴿وَمَا أَرْسَلْنَا مِنْ قَبْلِكَ إِلَّا رِجَالًا نُوحِي إِلَيْهِمْ﴾ قال المفسرون {1}: إن مشركي مكة أنكروا نبوة محمد -ﷺ-، قالوا: الله أعظم من أن يكون رسوله بشرًا، فهلا بعث إلينا ملكًا {2}، فقال الله: ﴿وَمَا أَرْسَلْنَا﴾ أي إلى الأمم الماضية، ﴿إِلَّا رِجَالًا﴾: آدميين لا ملائكة، أعلمَ اللهُ أن الرسلَ بشر، إلا أنهم يُوحَى إليهم، فقال: ﴿إِلَّا رِجَالًا نُوحِي إِلَيْهِمْ﴾، نظير هذه الآية في أواخر سورة يوسف {3}.وقوله تعالى: ﴿فَاسْأَلُوا أَهْلَ الذِّكْرِ إِنْ كُنْتُمْ لَا تَعْلَمُونَ﴾ فقال ابن عباس: يريد أهل التوراة الذين آمنوا من قريظة والنضير {4}، قال: والذكر التوراة {5}، وتلا قوله: ﴿وَلَقَدْ كَتَبْنَا فِي الزَّبُورِ مِنْ بَعْدِ الذِّكْرِ﴾ [الأنبياء: 105]، ﴿الذِّكْرِ﴾ يعني التوراة، وهذا قول عامة المفسرين: أن أهل الذكر هم أهل الكتاب؛ يعني المؤمنين منهم في قول الأكثرين {6}.وقال أبو إسحاق: قيل: فاسألوا أهل الكُتب الذين يشهدون بهذا {7}، لا من أجل أنهم من أهل هذه الملة، ولكن أهل الكتاب يعترفون أن {8} الأنبياء كلهم بشر، فعلى هذا؛ المراد بأهل الذكر: أهل العلم بأخبار الماضين ومن أُنبِّئهم من الرسل، والذكر المراد به العلم؛ لأنه مقرون بالذكر ومتعلق به، إذ العالم من يذكر الدليل ولا يكون ساهيًا عنه، فحَسُن أن يقع الذكر موقع العلم.وقال الزجاج: ويجوز -والله أعلم- قيل لهم: سلوا كلَّ من يُذْكَرُ بعلم، وافق هذه الملة أو خالفها {9}.قال أهل المعاني: وفي هذه الآية دليل على أن الخصم إذا التبس عليه أمر رَدّ إلى أهل العلم بذلك {10}."
  16,44,"قوله تعالى: ﴿بِالْبَيِّنَاتِ وَالزُّبُرِ﴾ اختلفوا في الجالب لهذه الباء {1}؛ فعند الفراء: لا يجوز أن تتعلق بأرسلنا المذكور في الآية الأولى؛ لأن صلة ما قبل إلاَّ لا تتأخر بعد إلاَّ، ولكنّه يقول: تقدير الآية: أرسلناهم بالبينات {2}، فالباء تتعلق بأرسلناهم المضمر المدلول عليه بأرسلنا المذكور، قال: ومثله قوله: ما ضرب إلا أخوك زيدًا، وما مرّ إلا أخوك يزيد، تريد ما مرّ إلا أخوك، ثم تقول: مرّ يزيد، فهذا إنما يجوز على كلامين، ولا يجوز أن يكون ما بعد إلاَّ موصولاً بما قبله، ومن هذا الجنس قول الشاعر:نُبِّئْتُهُمْ عَذَّبُوا بالنّارِ جارَتهَمْ ... وهل يُعذِّبُ إلاّ اللهُ بالنّارِ {3}وقال الكسائي: (إلاّ) في قوله: ﴿إِلَّا رِجَالًا﴾ بمعنى غير؛ كقوله: ﴿لَوْ كَانَ فِيهِمَا آلِهَةٌ إِلَّا اللَّهُ لَفَسَدَتَا﴾ [الأنبياء: 22]، (قال: المعنى لو كان فيهما آلهة غير الله لفسدتا) {4}، واحتجّ بقول الشاعر {5}:أَبَنِي لُبَيْنَى لَسْتُمُ بِيَدٍ ... إلاّ يَدٍ لَيْسَتْ لَها عَضُدُ {6} فقال. (إلاّ) هاهنا بمعنى غير؛ لأنه لا يمكن إعادة خافض بضمير {7}، قال الفراء: وقد ذهب في هذا مذهبًا {8}، ومن قال الذكر في الآية الأولى بمعنى العلم {9}، جعل الباء من صلته؛ كأنه قيل: سَلوا أهل العلم بالبينات والزبر {10}؛ وهي ما أنزل الله على الأنبياء من الحجج الواضحة والكتب، ﴿وَأَنْزَلْنَا إِلَيْكَ الذِّكْرَ﴾ يعني القرآن {11}، ﴿لِتُبَيِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَيْهِمْ﴾: في هذا الكتاب من الحلال والحرام، والوعد والوعيد، ﴿وَلَعَلَّهُمْ يَتَفَكَّرُونَ﴾: في ذلك فيعتبرون."
  16,45,"قوله تعالى: ﴿أَفَأَمِنَ الَّذِينَ مَكَرُوا السَّيِّئَاتِ﴾ قال ابن عباس: يريد المشركين؛ أهلَ مكة وما حول المدينة {1}.وقوله تعالى: ﴿مَكَرُوا السَّيِّئَاتِ﴾ قال الكلبي: عملوا السيئات، يعني عبادة غير الله {2}، وكذلك قال قتادة: يعني الشرك {3}، وعلى هذا سمي عبادتهم الأوثانَ مكرًا، لأن المكر في أصل اللغة: السعي بالفساد {4}، وذكرنا هذا فيما تقدم {5}، وعبادة غير الله من أفسد السعي.وقوله تعالى: ﴿أَنْ يَخْسِفَ اللَّهُ بِهِمُ الْأَرْضَ﴾ قال ابن عباس: كما خَسف بقارون {6}، ومعنى الخسف في اللغة: سُؤُوخُ الأرضِ بما عليها {7}، قال أبو زيد والأصمعي: خَسَفَ المكانُ يَخْسِفُ، وخَسَفَهُ الله {8}. ومعنى الاستفهام في قوله: ﴿أَفَأَمِنَ﴾ الإنكار؛ أي: يجب أن لا يأمنوا عقوبة تلحقهم كما لحقت المكذبين من قبلهم.وقوله تعالى: ﴿أَوْ يَأْتِيَهُمُ الْعَذَابُ مِنْ حَيْثُ لَا يَشْعُرُونَ﴾ قال الكلبي: من حيث لا يعلمون بهلاكهم {9}، قال ابن عباس: يريد يوم بدر وما كانوا يُقدِّرون ذلك ولا يشعرونه {10}"
  16,46,"قوله تعالى: ﴿أَوْ يَأْخُذَهُمْ فِي تَقَلُّبِهِمْ﴾ قال ابن عباس: يريد في تجارتهم واختلافهم إلى اليمن وإلى الشام {1}، وهذا قول قتادة والكبي، قالا: ﴿فِي تَقَلُّبِهِمْ﴾: في أسفارهم {2}، وقال مقاتل: في ليلهم ونهارهم {3}، يريد في تقلبهم في كل الأحوال ليلاً ونهارًا، فيدخل في هذا تقلبهم على الفرش يمينًا وشمالًا، ﴿فَمَا هُمْ بِمُعْجِزِينَ﴾ أي بممتنعين ولا فائتين {4} الله، قال ابن عباس: يريد أن الله لا يعجزه شيء أراده."
  16,47,"قوله تعالى: ﴿أَوْ يَأْخُذَهُمْ عَلَى تَخَوُّفٍ﴾، التخوف: تَفَعُّل من الخوف، يقال: خفت الشيء وتخوَّفته، قال الزجاج: أي أو يأخذهم بعد أن يخيفهم؛ بأن يهلك فرقة فتخاف التي تليها {1}، وهذا معنى قول الضحاك والكلبي، يعني: (يعذب طائفة ويدع طائفة) {2}، فيتخوف الذين يَدَعْهم مثل ما أصاب الآخرين {3}، ونحو هذا قال الحسن {4}؛ والمعنى يأخذهم على تخوفهم الهلاك لما سبق من هلاك طائفة منهم، وقال ابن عباس وعامة المفسرين: على تَنَقُّص؛ إما {5} بقتل أو بموت {6}، يعني: ينقص من أطرافهم ونواحيهم الشيء بعد الشيء حتى يُهْلِك جميعَهم {7}. أخبرني العروضي عن الأزهري، قال: أخبرني المنذري عن الحرّانيِّ عن ابن السِّكِّيت، قال: يقال: هو يَتَخَوَّفُ المالَ ويتَحَوَّفُه، أي يتَنَقَّصُهُ ويأخذُ من أطرافه، وأنشد لابن مقبل {8}:تخوَّفَ السَّيْرُ منها تَامِكًا قَرِدًا ... كما تَخَوَّفَ عُودَ النَّبْعةِ السَّفَنُ {9} {10}وروى شمر عن ابن الأعرابي: تَخوَّفْتُ الشيء وتَخيّفْتُه، وتَخَوَّفْتُهُ وتَخَيَّفْتُهُ إذا تَنَقَّصَتُه {11}.قال أهل المعاني: معنى التنقص: أنه يؤخذ الأول فالأول حتى لا يبقى منهم أحد، وتلك حال يُخافُ معها الفناء ويُتخوفُ الهلاكُ {12}، فمعنى ﴿يَأْخُذَهُمْ عَلَى تَخَوُّفٍ﴾، أي: على حال تنقصهم، يأخذهم الأول فالأول حتي يأتي الأخذ على الجميع.وقوله تعالى: ﴿فَإِنَّ رَبَّكُمْ لَرَءُوفٌ رَحِيمٌ﴾ قال الزجاج: أي من رأفته أمهل وجعل فسحة للتوبة {13}، وهو معنى قول المفسرين: إذ لم يعجل عليم بالعقوبة والإهلاك {14}، وأَخَّر عنهم هذه العقوبات التي ذكرها مع قدرته عليها."
  16,48,"قوله تعالى: ﴿أَوَلَمْ يَرَوْا﴾ قراءة العامة بالياء {1}؛ لأن ما قبله غيبة، وهو قوله: ﴿أَنْ يَخْسِفَ اللَّهُ بِهِمُ الْأَرْضَ أَوْ يَأْتِيَهُمُ الْعَذَابُ﴾، ﴿أَوْ يَأْخُذَهُمْ﴾ كذلك: ﴿أَوَلَمْ يَرَوْا﴾، وكان النبيّ -ﷺ- وأصحابه قد رأوا ذلك وتيقنوه فلا يحسن أن يقال لهم: ﴿أَوَلَمْ يَرَوْا﴾.وقرأ حمزة والكسائي: ﴿تَرَوا﴾ بالتاء {2}، على الخطاب لجميع الناس {3}.وقوله تعالى: ﴿إِلَى مَا خَلَقَ اللَّهُ مِنْ شَيْءٍ﴾ قال المفسرون وأهل المعاني: أراد من شيء له ظل من جبل وشجر وبناء وجسم قائم {4}، وهذا معنى قول ابن عباس: يريد الشجر والنبات.وقوله تعالى: (يَتَفَيَّأُ ظِلالُهُ) إخبار عن قوله: ﴿شَيْءٍ﴾، وليس بوصف له، و ﴿يَتَفَيَّأُ﴾: يتفعل من الفيء، يقال: فاء الظل يفيء فيئًا، إذا رجعَ وعادَ بعد ما كان ضياءُ الشمس نسخَه، وأصلُ الفيء الرجوع {5}، ومنه فَيءُ المولي {6}، وذكرنا ذلك في قوله: ﴿فَإِنْ فَاءُوا فَإِنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾ [البقرة: 226]، وكذلك فيءُ المسلمين؛ لِمَا يعود على المسلمين من مال مَنْ خالف دينهم بلا قتال {7}، وسنذكر ذلك في قوله: ﴿مَا أَفَاءَ اللَّهُ عَلَى رَسُولِهِ﴾ [الحشر: 7] إن شاء الله. وأصلُ هذا كله من الرجوع، فإذا عُدِّي (فَاءَ) عُدّي بزيادة الهمزة أو تضعيف العين، فمِمَّا عُدّي بنقل الهمزة قوله: ﴿مَا أَفَاءَ اللَّهُ﴾، وبالتضعيف فاءَ الظلُّ، وفَيّأه الله فتفيّأ، وتَفيَّأ مطاوع فَيَّأَ {8}.قال الأزهري: وتفيؤ الظلال رُجوعها بعد انتصاف النهار وانتعال الأشياء {9}، قال: وأخبرني المنذري عن أبي طالب النحوي أنه قال: التفيؤ لا يكون إلا بالعشي؛ ما انصرفت عنه الشمس، وقد بينه الشاعر {10} فقال:فلا الظلَّ من بَرْد الضُّحى تستطيعُهُ ... ولا الفيءَ من بردِ العشيِّ تذَوُق {11}وقال أبو علي الفارسي: الظل ما كان قائمًا لم تنسخه الشمس، فإذا نسخته الشمس ثم زال ضياء الشمس الناسخ للظل فاء الظل، أي رجع كما كان أولاً {12}، فهذا هو الفيء، وُيسمى الظل أيضًا، ولا يسمى الأول فيأً.قال ثعلب: أخبرت عن أبي عبيدة أن رؤبة قال: كُلُّ ما كانت عليه الشمسُ فزالت عنه فهو فيءٌ وظلٌّ، وما لم تكن عليه الشمس فهو ظِلٌّ {13}، على أن أبا زيد أنشد للنابغة الجعدي: فسلامُ الإلهِ يَغْدو {14} عليهمْ ... وفُيوءُ الفرْدَوْسِ ذاتُ الظِّلالِ {15}فهذا الشعر قد أوقع فيه الفيء على ما لم تنسخه الشمس، وجمعه على فيوء؛ مثل بيت وبيوت؛ لأن ما في الجنة يكون ظلًّا ولا يكون فيئًا؛ لأن ضياء الشمس لم تنسخه، ففاء بعد النسخ، وأكثر ما تقول العرب في جمعٍ {16} أفياء؛ وهو للعدد القليل، وفيوء؛ للكثير كالبيوت والعيون.وقوله تعالى: ﴿ظِلَالُهُ﴾ أضاف الظلال إلى مفرد، ومعناه الإضافة إلى ذوي الظلال؛ لأن الذي يعود إليه الضمير واحدٌ يدل على الكثرة، وهو قوله: ﴿إِلَى مَا خَلَقَ اللَّهُ﴾، وهذا مثل: ﴿لِتَسْتَوُوا عَلَى ظُهُورِهِ﴾ [الزخرف: 13] ، فأضاف الظهور، وهو جمع، إلى ضمير مفرد؛ لأنه يعود إلى واحدٍ يُرادُ به الكثرة، وهو قوله: ﴿مَا تَرْكَبُونَ﴾ {17} [الزخرف: 12].وأما قول المفسرين في: (يَتَفَيَّأُ ظِلالُهُ) قال ابن عباس: يتميل {18}، وهو معنى وليس بتفسير؛ لأنه إذا قرن بقوله: ﴿عَنِ الْيَمِينِ وَالشَّمَائِلِ﴾ صار المعنى: أنه يتميل عن الجوانب، ومعنى تفيؤ الظلال: أن يعود الظل بعد نسخ الشمس إياه، وأما معنى تفيؤها عن اليمين والشمائل (فهو أن يكون للأشجار فيء عن اليمين والشمائل) {19}، إذا كانت الشمس يمين الشخص كان الفيء عن شماله، وإذا كانت على شماله كان الفيء عن يمينه، فهذا وجه ذكره بعضُ أهل التأويل {20}، والذي عليه المفسرون، قال قتادة والضحاك وابن جريج: أما اليمين فأول النهار، وأما الشمال فآخر النهار {21}، وقد بين الكلبي هذا، فقال: إذا طلعت الشمس وأنت متوجه إلى القبلة كان الظل قدامك، فإذا ارتفعت كان عن يمينك، فإذا كان بعد ذلك كان خلفك، فإذا كان قبل أن تغرب الشمس كان على يسارك، فهذا تفيؤه عن اليمين والشمائل {22}، ووحد اليمين والمراد الجمع، ولكنه اقتصر فيه على الواحد في اللفظ للإيجاز؛ كقوله: ﴿وَيُوَلُّونَ الدُّبُرَ﴾ [القمر: 45] وقول الفرزدق:بِفي الشَّامِتِينَ الصَّخْرُ إنْ كانَ هَدَّنِي ... رَزيَّةُ شِبْلَيْ مُخْدِرٍ في الضَّراغمِ {23} هذا قول الأخفش وجميع أهل المعاني {24}.وقال الفراء: كأنه إذا وَحَّد ذهب إلى واحد من ذوات الظلال، وإذا جمع ذهب إلى كلها {25}، وذلك أن قوله: ﴿مَا خَلَقَ اللَّهُ مِنْ شَيْءٍ﴾ لفظه واحد ومعناه الجمع على ما بينا، فيحمل كلا الأمرين.وقوله تعالى: ﴿سُجَّدًا لِلَّهِ﴾ قال المفسرون: ميلانها سجودها، {26} وشرح ابن قتيبة هذا شرحًا شافيًا فقال: أصل السجود التّطَأطُؤ والميل، يقال: سجد البعير وأُسجد إذا طأطأ رأسَه لِيُرْكَب، وسجدت النخلة إذا مالت لكثرة العمل، ثم قد يُستعارُ السجودُ فيوضع موضع الاستسلام والطاعة والذل، ومن الأمثال المبتذلة: اسْجُدْ للقرد في زمانه {27}، يراد اخضع للئيم في دولته، ولا يُراد معنى سجود الصلاة، والشمس والظل خَلقان مُسخَّران لأَنْ يُعَاقِبَ كلُّ واحدٍ منهما صاحِبَه بغير فصْلٍ، فالظلُّ في أول النهار قبل طلوع الشمس يَعُمُّ الأرضَ، كما تَعُمُّها ظلمةُ الليل، ثم تطلُع الشمسُ فتَعُمُّ الأرضَ إلا بما {28} سترته الشُّخُوصُ، فإذا سَتَرَ الشخص شيئًا عاد الظلُّ، فرجوعُ الظلِّ بعد أن كان شمسًا ودورانُه من جانب إلى جانب هو سُجُودُه؛ لأنه مستسلم منقاد مطيع بالتَّسخير، وهو في ذلك يميل، والميل سجود، وكذلك قوله: ﴿وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَانِ﴾ [الرحمن: 6]، أي يستسلِمَان لله بالتسخير {29}، وهذه الآية كقوله: ﴿وَظِلَالُهُمْ بِالْغُدُوِّ وَالْآصَالِ﴾ [الرعد: 15]، وقد مر بيانه وشرحه.وقوله تعالي: ﴿وَهُمْ دَاخِرُونَ﴾، أي: صاغرون، وهذا لفظ المفسرين {30}، يقال: دَخَرَ يَدْخَر دُخُورًا، أي صَغُرَ يَصْغُرُ صغَارًا، وهو الذي يَفعلُ ما تأمره شاء أو (أبى {31}.قال الزجاج: هذه الأشياء مجبولة على الطاعة {32}.وقال الأخفش في قوله: ﴿وَهُمْ دَاخِرُونَ﴾) {33} ذَكَّرَ، وهم من غير الإنس؛ لأنه لما وصفهم بالطاعة أشبهوا ما يعقل {34}."
  16,49,"قوله تعالى: ﴿وَلِلَّهِ يَسْجُدُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ﴾ الآية. قد ذكرنا السجود يكون على نوعين: سجود هو عبادة؛ كسجود المسلمين لله، وسجود هو خضوع واستكانة؛ وهو سجود ما [لا] {1} يعقل وسجود الجمادات، فإن هذه الأشياء بما فيها من الدلالة على الحاجة إلى مُدَبَّر وصانع ساجدة؛ أي خاضعة متذللة، وقال: ﴿مَا فِي السَّمَاوَاتِ﴾ لأن (ما) و (من) يتعاقبان، و (ما) أعمّ من (من) ألا ترى أنه قد قال في أخرى: ﴿وَلِلَّهِ يَسْجُدُ مَنْ فِي السَّمَاوَاتِ وَالْأَرْضِ طَوْعًا وَكَرْهًا﴾ [الرعد: 15].وقوله تعالى: ﴿مِنْ دَابَّةٍ﴾ قال الفراء: دخل (من) هاهنا؛ لأن (ما) مُبْهم، فلو أسقطت (من) لأشبه أن تكون الدابة حالاً لها، فأدخل (من) ليدُلّ {2} على أنه تفسير لـ (ما) {3}، ومثل هذا كثير في كتاب الله؛ قال تعالى: ﴿مَا أَصَابَكَ مِنْ حَسَنَةٍ﴾ [النساء: 79]، وقال: ﴿وَمَنْ يَعْمَلْ مِنَ الصَّالِحَاتِ مِنْ ذَكَرٍ﴾ [النساء: 124]، وقال: ﴿أَوَلَمْ يَرَوْا إِلَى مَا خَلَقَ اللَّهُ مِنْ شَيْءٍ﴾ [النحل: 48] لم يقل في شيء منه بطرح (مِنْ)؛ لما ذكرنا من أنّ (ما) و (مِنْ) غير مؤقّتتين {4}، ومثله قول الشاعر: فثبتَ اللهُ ما آتاك من حَسَنٍ ... وحيثُ ما يقض أمرًا صالحًا يكن {5}وقال آخر:عُمْرًا حَييت ومَن يشناك من أحد ... يَلْق الهوان ويلق الذُلَّ والغِيَرا {6}فدلّ مجيء (من) على أنه لم يرد أن يكون ما جاء من النكرات حالاً للأسماء التي قبلها، ودلَّ على أنه مُترجِم على معنى (مَن) و (مَا)، ومثل هذا قوله: ﴿وَمَا أَنْفَقْتُمْ مِنْ شَيْء﴾ [سبأ: 39]؛ لأن الشيء لا يكون حالاً، ولكنه مترجم، فأمَّا قولهم: لله دَرُّه رجلاً {7}، فالرجلُ مترجِم لما قبله وتفسير وليس بحال، إنّما الحال الذي ينتقل؛ مثل القيام والقعود، وجاز سقوط (مِنْ) في هذا الموضع {8}؛ لأن الذي قبله مؤقت، فجاز أن يُذكرَ بطرح (مِن) كالحال {9}، وقال الأخفش في قوله: ﴿مِنْ دَابَّةٍ﴾ يريد: (من الدواب، واجتزأ بالواحد؛ كما تقول: ما أتاني من رجل مثله {10}، وقال ابن عباس في قوله: ﴿مِنْ دَابَّةٍ﴾) {11}: يريد كلَّ ما {12} دَبَّ على الأرض {13}.وقوله تعالى: ﴿وَالْمَلَائِكَةُ﴾ أخرجهم بالذكر تخصيصًا وتفصيلاً؛ كقوله: ﴿فِيهِمَا فَاكِهَةٌ وَنَخْلٌ وَرُمَّانٌ﴾ {14} [الرحمن: 68]، وقوله تعالى: ﴿لَّهِ وَمَلَائِكَتِهِ وَرُسُلِهِ وَجِبْرِيلَ وَمِيكَالَ﴾ {15} [البقرة: 98] وقال الزجاج: المعنى: ولله يسجد ما في السموات من الملائكة، وما في الأرض من دابة والملائكة؛ أي: وتسجد ملائكة الأرض {16}، وفي الأرض ملائكة موكلون بالعباد {17}، وقيل: إنما ذكرهم على التخصيص لخروجهم من صفة الدبيب بما جعل لهم من الأجنحة {18}، والله أعلم.وقوله تعالى: ﴿وَهُمْ لَا يَسْتَكْبِرُونَ﴾ قال ابن عباس: يريد عن عبادة الله {19}، وهذا صفة من يسجد لله سجود عبادة، فأما من له سجود الخضوع دون سجود العبادة، فمعنى لا يستكبرون في صلتهم أنهم يذعنون للخالق والصانع بالتسخير والتذليل وما فيهم من الضرورة إلى صانع فطرهم وخلقهم وأنشأهم ودبَّرهم، ويجوز أن يكون قوله: ﴿وَهُمْ لَا يَسْتَكْبِرُونَ﴾ من صفة الملائكة خاصة {20}؛ لأن الآية التي بعد هذا تختص بصفتهم."
  16,50,"قوله تعالى: ﴿يَخَافُونَ رَبَّهُمْ مِنْ فَوْقِهِم﴾ الآية. ذكر أهل العلم وأصحاب المعاني في هذه الآية، قولين {1}؛ أحدهما: أن الآية من باب حذف المضاف، على تقدير يخافون عقاب ربهم من فوقهم {2}؛ لأن أكثر ما يأتي العقاب المهلك من فوق، سيّمَا والآية في صفة الملائكة، والآخر: أن الله تعالى لما كان موصوفًا بأنه علىٌّ ومتعال علو الرتبة في القدرة، حَسُن أن يقال: ﴿مِنْ فَوْقِهِمْ﴾ ليدل على أنه في أعلى مراتب القادرين {3}، وهذا معنى قول أبي إسحاق: ﴿يَخَافُونَ رَبَّهُمْ﴾: خوف مُجِلِّين {4}، ويدل على صحة هذا المعني قوله تعالى: ﴿وَهُوَ الْقَاهِرُ فَوْقَ عِبَادِهِ﴾ [الأنعام: 61]، وقوله إخبارًا عن فرعون: ﴿وَإِنَّا فَوْقَهُمْ قَاهِرُونَ﴾ [الأعراف: 127]، وقد روى مجاهد عن ابن عباس في قوله: ﴿يَخَافُونَ رَبَّهُمْ مِنْ فَوْقِهِمْ﴾ قال: ذاك مخافة الإجلال {5}، وذهب بعض الناس إلى أن قوله: ﴿مِنْ فَوْقِهِمْ﴾ من صفة الملائكة {6}، والمعنى: أن الملائكة الذين هم فوق بني آدم وفوق ما في الأرض من دابة يخافون الله مع علو رتبتهم، فلأن يخاف من دونهم أولى {7}.وقوله تعالى: ﴿وَيَفْعَلُونَ مَا يُؤْمَرُونَ﴾ قال المفسرون: يعني الملائكة {8}، وهذا كقوله في آية أخرى: ﴿لَا يَعْصُونَ اللَّهَ مَا أَمَرَهُمْ﴾ الآية [التحريم: 6]."
  16,51,"قوله تعالى: ﴿وَقَالَ اللَّهُ لَا تَتَّخِذُوا إِلَهَيْنِ اثْنَيْنِ﴾ قال الزجاج: ذكر اثنين توكيدًا لقوله: ﴿إِلَهَيْنِ﴾، كما ذكر الواحد في قوله: ﴿إِلَهًا وَاحِدًا﴾ {1} [التوبة: 31]. وقال صاحب النظم: فيه تقديم وتأخير؛ يريد: لا تتخذوا اثنين إلهين {2}، أي: الاثنان لا يكونان ولا واحدٌ منهما إلهًا، ولكن اتخذوا الواحد الذي لا يجوز أن يكون له ثانٍ إلهًا، يدل على هذا قوله: ﴿إِنَّمَا هُوَ إِلَهٌ وَاحِدٌ﴾، وقوله: ﴿فَإِيَّايَ فَارْهَبُونِ﴾ من تلوين الخطاب."
  16,52,"وقوله تعالى: ﴿وَلَهُ الدِّينُ وَاصِبًا﴾، الدين: الطاعة هاهنا، والواصب: الدائم، و [هو] {1} قول ابن عباس وجميع المفسرين {2}؛ يقال وصب الشىء يصب وصوبًا إذا دام {3}، قال الله تعالى: ﴿وَلَهُمْ عَذَابٌ وَاصِبٌ﴾ [الصافات: 9] ويقال: واظَبَ على الشيء وواصَبَ عليه إذا داوم {4}، قال أبو إسحاق: أي طاعته واجبة أبدًا {5}، وقال عبد الله بن مسلم {6}: ليس من أحد يُدان له ويطاوع إلا انقطع ذلك عنه بزوال أو هلكة، غير الله عز وجل؛ فإن الطاعة تدوم له {7}، ثم قال: ﴿أَفَغَيْرَ اللَّهِ تَتَّقُونَ﴾، أي: أفغير الله الذي قد أبان لكم أنه واحدٌ، وأنه خالق كل شيء، وأمر أن لا يُتخذ معه إلَهٌ، تتقون."
  16,53,"قوله تعالى: ﴿وَمَا بِكُمْ مِنْ نِعْمَةٍ فَمِنَ اللَّهِ﴾ قال ابن عباس: يريد من نعمة الإسلام وصحة الأبدان {1}، أي ما أعطاكم الله من صحة في جسم أو سعة في رزق أو متاع بمال وولد، فكل ذلك من الله، ودخلت الفاء في قوله: ﴿فَمِنَ اللَّهِ﴾؛ لأن الباء في: ﴿بِكُمْ﴾ متصلة بفعل مضمر، المعنى: ما يكن بكم أو ما حل بكم من نعمة فمن الله {2}، وقد شرحنا هذه المسألة في قوله: ﴿وَمَنْ تَطَوَّعَ خَيْرًا فَإِنَّ اللَّهَ شَاكِرٌ عَلِيمٌ﴾ [البقرة: 158] وفي قوله: ﴿الَّذِينَ يُنْفِقُونَ أَمْوَالَهُمْ بِاللَّيْلِ وَالنَّهَارِ﴾ الآية [البقرة: 274].وقوله تعالى: ﴿ثُمَّ إِذَا مَسَّكُمُ الضُّرُّ﴾ قال ابن عباس: يريد الأسقام والأمراض والحاجة {3}، ﴿فَإِلَيْهِ تَجْأَرُونَ﴾، أي: (ترفعون أصواتكم بالاستغاثة، وهو معنى قول المفسرين: يتضرعون بالدعاء {4}، يقال: جأر ويجأر) {5} جُؤارًا، وهو الصوت الشديد؛ كصوت البقرة {6}، قال الأعشى يصف بقرة:وكان النَّكيرُ أَنْ تُضيفَ وتَجْأرَا {7} فهذا {8} ذهب جُؤَار البقرة، وقال عدي بن زيد في جُؤَار الإنسان:إنَّني والله فاقْبَلْ حَلْفَتِي ... بأَبِيل كلما صَلَّى جَأَرْ {9}(أي رئيس النصارى) {10}."
  16,54,"قوله تعالى: ﴿ثُمَّ إِذَا كَشَفَ الضُّرَّ عَنْكُمْ﴾ الآية. قال ابن عباس في قوله: ﴿إِذَا فَرِيقٌ﴾ يريد أهل النفاق {1}، وقال الكلبي: يعني الكفار {2}، وهو اختيار الزجاج؛ قال: هذا خاص فيمن كفر {3}، وقابل كشف الضّر عنه بالجحود والكفر."
  16,55,"قوله تعالى: ﴿لِيَكْفُرُوا بِمَا آتَيْنَاهُمْ﴾، أي: ليجحدوا نعمة الله في كشف الضرّ عنهم، واللام هاهنا يحتمل أن تكون لام كي {1}، ويكون المعنى: أنهم أشركوا بالله غيره ليجحدوا نعمته، فاللام بيان عما هو بمنزلة العلة التي يقع لأجلها الشرك، وهؤلاء أشركوا بالعبادة ليكفروا النعمة {2}، ويحتمل أن تكون اللام للعاقبة {1}، ويكون المعنى: أنهم جعلوا ما رزقناهم وأنعمنا به عليهم سببًا إلى الكفر، كما قلنا في قوله: ﴿رَبَّنَا إِنَّكَ آتَيْتَ فِرْعَوْنَ﴾ إلى قوله: ﴿لِيُضِلُّوا عَنْ سَبِيلِكَ﴾ [يونس: 88]، وقد مر، وذكر أبو إسحاق الوجهين أيضًا في اللام هاهنا {4}.وقوله تعالى: ﴿فَتَمَتَّعُوا﴾ لفظ أمر لتهدد؛ كقوله: ﴿قُلْ آمِنُوا بِهِ أَوْ لَا تُؤْمِنُوا﴾ [الإسراء: 107]، ﴿فَسَوْفَ تَعْلَمُونَ﴾: عاقبة أمركم وما ينزل بكم من العذاب."
  16,56,"قوله تعالى: ﴿وَيَجْعَلُونَ لِمَا لَا يَعْلَمُونَ﴾ يعني الأوثان؛ لا يعلمون ضرًّا ولا نفعًا، ومفعول العلم هاهنا محذوف، والتقدير: لما لا يعلمون له حقًّا ولا فيه ضرًّا ونفعًا، قال مجاهد: يعلمون أن الله خلقهم ويضرهم وينفعهم، ثم يجعلون لما لا يعلمون أنه ينفعهم ويضرهم {1}، ونحو هذا قال قتادة وابن زيد: هم مشركو العرب جعلوا لأوثانهم جزءًا من أموالهم {2}، وقد بينّا {3} مذهبهم في هذا عند قوله: ﴿هَذَا لِلَّهِ بِزَعْمِهِمْ وَهَذَا لِشُرَكَائِنَا﴾ [الأنعام: 136] جعلوا نصيبًا من الحرث والأنعام يتقربون به إلى الله تعالى، ونصيبًا يتقربون به إلى الأصنام والحجارة على ما يجب أن يتقربوا إلى الله، وعلى هذا: العِلمُ مسند إلى المشركين، وهو قول عامة المفسرين {4}.وقال صاحب النظم: قوله: ﴿يَعْلَمُونَ﴾ هاهنا لازم ليس بمتعَدّ؛ لأنه الأصنام ومضاف إليها، والتأويل لِمَا ليس لها {5}؛ لأنها موات لا معارف لها ولا حس، وأخرجها في قوله: (ما) مخرج غير الآدميين ومن [لا] {6} يفهم، وفي قوله: ﴿لَا يَعْلَمُونَ﴾ مخرج من يفهم، ومثله قوله: ﴿وَتَرَاهُمْ يَنْظُرُونَ إِلَيْكَ﴾ {7} [الأعراف: 198]، وحمله المعنى ﴿وَيَجْعَلُونَ﴾، أي. المشركون، ﴿لِمَا لَا يَعْلَمُونَ﴾ أي للشركاء الذين لا يعلمون شيئًا ولا معرفة لهم ولا حس، ﴿نَصِيبًا مِمَّا رَزَقْنَاهُمْ﴾، هذا كلامه، ولعل هذا القول أقرب؛ لأنه لا يحتاج فيه إلى تقدير محذوف، قال صاحب النظم: ولو كان هذا العلم مضافاً إلى المشركين لاستحال المعنى؛ لأنه لا يحتمل أن يجعلوا نصيبًا من رزقهم لما لا يعلمونه {8}، ثم خاطبهم بعد الخبر عنهم، فقال: ﴿تَاللَّهِ لَتُسْأَلُنَّ﴾ أي سؤال توبيخ حتى يعترفوا به على أنفسهم؛ لأن سؤال التوبيخ هو الذي لا جواب لصاحبه إلا ما يظهر فيه فضيحتة {9}.وقوله تعالى: ﴿عَمَّا كُنْتُمْ تَفْتَرُونَ﴾ أي تتقولونه على الله من أنه أمركم بذلك."
  16,57,"قوله تعالى: ﴿وَيَجْعَلُونَ لِلَّهِ الْبَنَاتِ﴾ قال المفسرون: هؤلاء خزاعة {1} وكنانة {2} زعموا أن الملائكة بنات الله {3}، ثم نَزَّه نفسه فقال: ﴿سُبْحَانَهُ﴾ أي تنزيهًا عما زعموا.وقوله تعالى: ﴿وَلَهُمْ مَا يَشْتَهُونَ﴾ أجاز الفراء في (ما) وجهين؛ أحدهما: أن يكون في محل النصب على معنى: ويجعلون لأنفسهم ما يشتهون، والثاني: أن يكون رفعًا على الابتداء؛ كأنه تم الكلام عند قوله: ﴿سُبْحَانَهُ﴾، ثم ابتدأ فقال: ﴿وَلَهُمْ مَا يَشْتَهُونَ﴾ يعني البنين، وهذا كقوله: ﴿أَمْ لَهُ الْبَنَاتُ وَلَكُمُ الْبَنُونَ﴾ {4} [الطور: 39] ، ثم اختار الوجه الثاني فقال: لو كان نصبًا لقال: ولأنفسهم ما يشتهون؛ لأنك تقول: جعلتَ لنفسِك كذا وكذا، ولا تقول: جَعلتَ لك {5}، و {6} الزجاج أجاز {7} الوجه الأول {8} وقال: (ما) في موضع رفع لا غير، المعنى: ولهم الشيء الذي يشتهونه، ولا يجوز النصب؛ لأن العرب تقول: جَعَل لنفْسِه ما يشتهي، ولا تقول جَعَل زيدٌ له ما يَشْتهىِ، وهو يعني نفسه {9}."
  16,58,"قوله تعالى: ﴿وَإِذَا بُشِّرَ أَحَدُهُمْ بِالْأُنْثَى﴾ أي أُخبر بولادة بنت، والتبشير هاهنا بمعنى الإخبار أو بمعنى حقيقة التبشير على ما بينا في قوله: ﴿وَبَشِّرِ الَّذِينَ آمَنُوا﴾ [البقرة: 25]؛ لأن الحزن يؤثر في البَشَرة كما يؤثر السرور، يدل على هذا قوله: ﴿ظَلَّ وَجْهُهُ مُسْوَدًّا﴾ قال الزجاج: أي متغيرًا تَغَيُّرَ مغتم، ويقال لمن لَقِي مكروها: قد اسود وجهه غمَّا وحُزْنًا {1}، وشرح أبو علي هذا فقال: ليس المعنى على السواد الذي هو خلاف البياض، ولكن على ما يلحق من غضاضة عن مذمة {2}، ونَزَّلُوا ولادةَ الأنثى -وإن لم يكن من فِعْلِهم- منزلةَ ما يكونُ من فِعْلِهم مما يلحق من أجله العار، وعلى ضِدِّ هذا يمدحون بالبياض من لم يلحقه عار، من ذلك قوله {3}:وأَوْجُهُهُمْ بيضُ المَسَافِرِ غُرَّان {4} يريد أنهم لا يرتكبون ما يُدَنِّس الوجه، وعلى هذا المعنى وصفهم الرجلَ بالبياض في المدح لا على معنى بياض اللون ونصوعه، قال قتادة في هذه الآية: هذا صنيع مشركي العرب، فأما المؤمن فهو حقيق أن يرضى بما قسم الله له {5}.وقوله تعالى: ﴿وَهُوَ كَظِيمٌ﴾ أي ممتلئ غمًّا {6}، وفسرنا هذا الحرف في سورة يوسف [84]."
  16,59,"قوله تعالى: ﴿يَتَوَارَى﴾، أي: يختفي ويتغيب، وقد ذكرنا هذا الحرف وتفسيره في قوله: ﴿مَا وُورِيَ عَنْهُمَا﴾ [الأعراف: 20].وقوله تعالى: ﴿مِنَ الْقَوْمِ مِنْ سُوءِ مَا بُشِّرَ بِهِ﴾ قال المفسرون: كان الرجل في الجاهلية إذا ضرب امرأتَه المخاضُ توارى إلى أن يعلم ما يُولدُ له، فإن كان ذكرًا سُرَّ به وابتهج، وإن كانت أُنثى اكتأب لها وحزن ولم يظهر للناس أيامًا، يُدبِّر كيف يصنع في أمرها {1}، وهو قوله: ﴿أَيُمْسِكُهُ عَلَى هُونٍ﴾ أي أيحبسه، والإمساك هاهنا بمعنى الحبس، كقوله: ﴿أَمْسِكْ عَلَيْكَ زَوْجَكَ﴾ [الأحزاب: 37]، والكناية تعود على ما في قوله: ﴿مَا بُشِّرَ بِهِ﴾، والهُون: الهَوَان {2}.قال ابن شميل: إنه لَيَهُون علي هَوْنًا وهَوانًا {3}، وأهنته هَوْنًا وهوانًا، وذكرنا هذا في سورة الأنعام عند قوله: ﴿عَذَابَ الْهُونِ﴾ [آية: 93].قال المفسرون: كان أحدُهم في الجاهلية إذا وُلِدت له بنتٌ ضاق بها ذرعًا، فلم يدر ما يصنع بها؛ أَيَدُسُّها تحت التراب أو يتهاون بها فيُلْقِيها {4}، والهَوان على قول أكثرهم يعود إلى المولودة على معنى أنه سيهينها في التعب والعمل، ويمسكها على هوان منه لها.وقال عطاء عن ابن عباس في قوله: ﴿أَيُمْسِكُهُ عَلَى هُونٍ﴾ يريد على رغم أنفه وعلى الكراهية منه {5}، وعلى هذا القول، الهوان راجع إلى الوَالِد {6}؛ لأنه يمسكه على رضا بهوان نفسه وكراهته، واختاره الفراء فقال: لا يدري أيدفنها أم يصبر عليها وعلى مكروهها {7}.وقوله تعالى: ﴿أَمْ يَدُسُّهُ فِي التُّرَابِ﴾ أي يخفيه، والدس: إخفاء الشيء {8}، وهذا على ما كانوا يفعلونه من الوأد في الجاهلية، والجملة التي وقع عليها الاستفهام من الإمساك أو {9} الوأد متعلقة بمحذوف يدل عليه القَسَم في الاستفهام، على تقدير ﴿يَتَوَارَى مِنَ الْقَوْمِ﴾ مقدرًا: أيمسكه أم يدسه، أو مفكرًا أو مدبرًا، أي يُقَلِّبُ رأيه في أحد الأمرين.وقال صاحب النظم: قوله: ﴿أَيُمْسِكُهُ﴾ متصل في النظم بقوله: ﴿وَهُوَ كَظِيمٌ﴾، والكظيم بمعنى الكاظم، ومعنى الكظم: ستر الشيء في القلب وترك إظهاره {10}، ومنه: ﴿وَالْكَاظِمِينَ الْغَيْظَ﴾ [آل عمران: 134]، والتأويل: وهو كاظم، ﴿أَيُمْسِكُهُ عَلَى هُونٍ أَمْ يَدُسُّهُ فِي التُّرَابِ﴾، أي: أن هذا المعنى في قلبه من شدة الغَمّ وهو يكظمه ولا يظهره.وقوله تعالى: ﴿أَلَا سَاءَ مَا يَحْكُمُونَ﴾ قال ابن عباس والمفسرون: بئس ما حكموا أن جعلوا لمن يعرفون بأنه خالقهم البنات؛ اللاتي محلهن منهم هذا المحل، ونسبوه إلى اتخاذ الولد، وجعلوا لأنفسهم البنين {11}، نظير هذه الآية قوله: ﴿أَلَكُمُ الذَّكَرُ وَلَهُ الْأُنْثَى (21) تِلْكَ إِذًا قِسْمَةٌ ضِيزَى﴾ [النجم:21، 22]."
  16,60,"قوله تعالى: ﴿لِلَّذِينَ لَا يُؤْمِنُونَ بِالْآخِرَةِ مَثَلُ السَّوْءِ﴾ قال ابن عباس والكلبي: يريد العذاب والنار.﴿وَلِلَّهِ الْمَثَلُ الْأَعْلَى﴾: شهادة أن لا إله إلا الله {1}، وهذا قول قتادة، ورُوي عنه ﴿الْمَثَلُ الْأَعْلَى﴾: الإخلاص والتوحيد {2}، وهذا قول المفسرين في هذه الآية، لا أدري لم قيل للعذاب: المثل السَّوء، وللإخلاص: المثل الأعلى.وقال قوم: المثلُ السَّوء: الصفةُ السَّوء؛ من احتياجهم إلى الولد وكراهيتهم الإناث خوفَ العَيلة والعَار {3}، ﴿وَلِلَّهِ الْمَثَلُ الْأَعْلَى﴾: الصفة العليا من تنزهه وبراءته عن الولد، وهذا قول صحيح، والمَثْلُ يَردُ {4} كثيرًا بمعنى الصفة، وقد بَيَّنا ذلك مستقصي في قوله: ﴿مَثَلُ الْجَنَّةِ﴾ في سورة الرعد [آية: 35] وإن أنكر ذلك بعض المتأخرين {5}، فقد رُوي عن المقدمين من أئمة اللغة المثل بمعنى الصفة {6}.وقال ابن كيسان: ﴿مَثَلُ السَّوْءِ﴾: ما ضَرب اللهُ للأصنام وعبدتها من الأمثال {7}؛ مِثلُ قوله: ﴿مَثَلُ الَّذِينَ اتَّخَذُوا مِنْ دُونِ اللَّهِ أَوْلِيَاءَ﴾ الآية. [العنكبوت: 41]. وقوله تعالى: ﴿يَا أَيُّهَا النَّاسُ ضُرِبَ مَثَلٌ فَاسْتَمِعُوا لَهُ﴾ الآية [الحج: 73]، ولله المثل الأعلى نحو قوله: ﴿اللَّهُ نُورُ السَّمَاوَاتِ وَالْأَرْضِ مَثَلُ نُورِهِ﴾ الآية [النور: 35].فإن قيل كيف جاء ﴿وَلِلَّهِ الْمَثَلُ الْأَعْلَى﴾ مع قوله: ﴿فَلَا تَضْرِبُوا لِلَّهِ الْأَمْثَالَ﴾؟ [النحل: 74] قيل: لأنه بمعنى الأمثال التي توجب الأشباه، فأما الأمثال التي يضربها الله من غير شَبَه له بخلقه فحقٌّ وصوابٌ؛ لما فيها من الحِكم {8}."
  16,61,"قوله تعالى: ﴿وَلَوْ يُؤَاخِذُ اللَّهُ النَّاسَ﴾ قال ابن عباس: يريد المشركين، ﴿بِظُلْمِهِمْ﴾ قال: يريد بافترائهم على الله، ﴿مَا تَرَكَ عَلَيْهَا مِنْ دَابَّةٍ﴾ قال: يريد من {1} مفتر، هذا قوله في رواية عطاء {2}، ومعناه: أنه لو عاجلهم بالعقوبة على كفرهم ما أمهلهم طرفة عين ولأخلى وجه الأرض عنهم، والكناية في: ﴿عَلَيْهَا﴾ تعود إلى الأرض ولم يسبق لها ذكر، ولكن ذكر الدابة تدل على الأرض؛ فإنها تَدُبّ عليها، وكثير ما يُكَنّي عن الأرض وإن لم يتقدم ذكرها؛ لأنه لا يُشْكِل، يقولون: ما عليها مثل فلان، وما عليها أكرم من فلان؛ يعنون على الأرض {3}، وعلى هذا التفسير الدابة تختص بالمفتري، وقال سائر المفسرين: يعني دواب الأرض؛ روى السدي عن أصحابه في قوله: ﴿مَا تَرَكَ عَلَيْهَا مِنْ دَابَّةٍ﴾ يقول لأقحط المطر، فلم يبق في الأرض دابة إلا هلكت {4}، ورُوي عن ابن مسعود أنه قرأ هذه الآية، فقال: كاد {5} أن يَهْلِكَ الجُعَلُ {6} في جُحْره بذنب ابن آدم {7}، وقال قتادة في هذه الآية: قد فَعَل ذلك زمان نوح {8}، والمعنى على هذا: أن شؤم ذنوب المشركين كاد أن يصيب دواب الأرض حتى تهلك بسبب ذلك، لولا حلم الله وتأخيره العقوبة، كما روى عن أبي حمزة الثُّمالي {9} أنه قال: يحبس المطر فيَهلكَ كلُ شيء {10}.وقال أهل المعاني: معنى الآية، أن الله تعالى لو أهلك الآباء بكفرهم لم يكن الأبناء {11}، فكانت الأرض تبقى خالية، وقد ضرب الله لهلاك الخلق وخلو الأرض عن سكانها أجلاً، فهو يؤخرهم إلى أجل مُسَمّى كي يتوالدوا، والأجل المسمى في هذه الآية: القيامة، في قول عطاء عن ابن عباس {12}، ﴿فَإِذَا جَاءَ أَجَلُهُمْ﴾ يريد أجل القيامة، وفي قول الآخرين: يعني منتهى الأجل وانقضاء العمر {13}، ولعل الأقرب هذا؛ فإن المشركين يؤاخذون بالعقوبة إذا انقضت أعمارهم وخرجوا من الدنيا، ووجه القول الأول: أن معظم العذاب يوافيهم يوم القيامة، وذكرنا معنى: ﴿لَا يَسْتَأْخِرُونَ سَاعَةً وَلَا يَسْتَقْدِمُونَ﴾ في سورة الأعراف: [34]."
  16,62,"قوله تعالى: ﴿وَيَجْعَلُونَ لِلَّهِ مَا يَكْرَهُونَ﴾، معنى ﴿يَجْعَلُونَ﴾ هاهنا يصفونه بذلك ويحكمون به له، لقولك: جعلت زيدًا أعلى الناس؛ وذكرنا معاني الجَعَل عند قوله: ﴿مَا جَعَلَ اللَّهُ مِنْ بَحِيرَةٍ﴾ [المائدة: 103].وقوله تعالى: ﴿مَا يَكْرَهُونَ﴾ يعني البنات في قول جميع المفسرين {1}، والمعنى: ﴿وَيَجْعَلُونَ لِلَّهِ مَا يَكْرَهُونَ﴾: لأنفسهم، ﴿وَتَصِفُ أَلْسِنَتُهُمُ الْكَذِبَ أَنَّ لَهُمُ الْحُسْنَى﴾ قال الفراء والزجاج: موضع ﴿أَنَّ﴾ نصب؛ لأنه عبارة عن الكذب وبدل منه، المعنى: وتصف ألسنتهم أن لهم الحسنى {2}.وأما تفسير ﴿الْحُسْنَى﴾ فكثير من المفسرين على أنه الغلمان والبنون، وهو {3} قول السدي ومجاهد وقتادة {4}، قال يمان بن رِئاب {5}: ﴿الْحُسْنَى﴾: الجنة {6}، وهو معنى قول ابن عباس في رواية عطاء {7}، واختيار الزجاج {8}، قال: المعنى يصفون أن لهم مع قولهم هذا القبيح من الله الجزاء الحسن {9}، فحصل في ﴿الْحُسْنَى﴾ هاهنا قولان؛ الأول: على أنهم قالوا: لله البنات ولنا البنون، والثاني: على أنهم حكموا لأنفسهم بالجنة والثواب من الله إن كان محمد صادقًا {10} في البعث؛ لأنهم كانوا لا يؤمنون بالمعاد، ولعل الأقرب في تفسير الحسنى: الجنة، وفي الآية ما يدل على هذا، وهو قوله: ﴿لَا جَرَمَ أَنَّ لَهُمُ النَّار﴾، فردَّ عليهم قولَهم وأثبت لهم النار، فدلّ هذا أنهم حكموا لأنفسهم بالجنة، قال الزجاج: (لا) ردٌّ لقولهم، المعنى ليس ذلك كما وصفوا، جَرَمَ فعلُهم هذا، أي كَسَبَ النارَ {11}، فعلى هذا (أنَّ) يكون في محل النصب بوقوع الكسبِ عليه، وقال قطرب: (أنَّ) في موضع رفع، المعنى: وجب أنَّ لهم النار {12} ، وقيل: لا بُدَّ ولا محالةَ أن لهم النّار، وذكرنا فيما تقدم استقصاء الكلام في هذا الحرف {13}.وقوله تعالى: ﴿وَأَنَّهُمْ مُفْرَطُونَ﴾ أي مُتْرَكون {14} مَنْسِيُّون في النار، قاله الكلبي ومجاهد والضحاك {15}.وقال قتادة: مُعَجَّلُون إلى النار {16}، وهو قول الحسن، والقول الأول اختيار أبي عبيدة {17} والفراء {18}، قال الكسائي: يقال: ما أَفْرَطْتُ من القوم أحدًا {19}، وقال الفراء: العرب تقول أَفْرَطتُ منهم ناسًا، أي خَلَّفتهم ونسِيتُهم {20}، ومَنْ قال: مُعَجَّلُون، وهو الاختيار {21}؛ فوَجْههُ {22} ما قال أبو زيد وعيره: فرَطَ الرجلُ أصحابَه يَفْرُطُهم فِراطا وفُرُوطًا، إذا تقدمهم إلى الماء ليصلح الدِّلاء والأرْسَان {23}، وأنشدوا {24}:فأثارَ فارِطُهم غَطَاطًا جُثَّمًا ... أصواتُها كتَراطُنِ الفُرْسِ {25} وأَفْرَط للقوم الفَارِطُ، وفَرَّطُوه: إذا قدَّموه، فمعنى قوله: ﴿مُفْرَطُونَ﴾ من هذا، كأنهم أُعجلوا إلى النار؛ فهم فيها فَرْطٌ للذين يدخلون بعدهم {26}.وقال أبو إسحاق: معنى ﴿مُفْرَطُونَ﴾: مُقَدَّمُون إلى النّار {27}، وقرأ نافع بكسر الراء {28}.قال الفراء: يقول: كانوا مُفْرِطين على أنفسهم في الذنوب {29}، ونحوه قال الزجاج: المعنى على أنهم أَفْرَطُوا في مَعْصِية الله {27}.قال ابن عباس في رواية عطاء: أفرطوا في الافتراء على الله.وقال أبو علي: كأنه من أَفْرَطَ؛ أي صارَ فَرَطٌ، مِثْلُ: أقْطَفَ {31} وأجْرَبَ، أي هم ذَوو فَرَطٍ إلى النّار {32}؛كأنهم قد أَرْسَلُوا من يُهيئ لهم مواضعَهم منها."
  16,63,"قوله تعالى: (﴿تَاللَّهِ لَقَدْ أَرْسَلْنَا إِلَى أُمَمٍ مِنْ قَبْلِكَ﴾ قال ابن عباس: يعزي الله نبيه -ﷺ- بهذا {1} يقول) {2}: ﴿لَقَدْ أَرْسَلْنَا إِلَى أُمَمٍ﴾ يعني رسلًا وأنبياءَ من قبلك، ﴿فَزَيَّنَ لَهُمُ الشَّيْطَانُ﴾: حتى عَصَوا وكذبوهم، ﴿فَهُوَ وَلِيُّهُمُ الْيَوْمَ﴾ (يحتمل معنيين؛ أحدهما: أن المراد بهذا كفار قريش، يقول: الشيطان وليهم اليوم) {2}؛ يتولى إغواءهم وصرفهم عنك كما فعل بكفار الأمم قبلك {4}، فيكون قد رجع عن الإخبار عن {5} الأمم الماضية إلى الإخبار عن كفار مكة. الثاني: أنه أراد باليوم يوم القيامة، يقول: فهو ولي أولئك الذين زَيَّن لهم أعمالهم يوم القيامة {6}، ومن كان الشيطان ولِيَّه ذلك اليوم دخل {7} النار، وأطلق اسم اليوم على يوم القيامة لشهرة ذلك اليوم."
  16,64,"قوله تعالى: ﴿وَمَا أَنْزَلْنَا عَلَيْكَ الْكِتَابَ﴾ قال ابن عباس: يريد ما قص من أخبار الأمم الخالية في القرآن، ﴿إِلَّا لِتُبَيِّنَ لَهُمُ الَّذِي اخْتَلَفُوا فِيهِ﴾، قال: يريد لاتخاذ الحجة عليهم، كأن المعنى: إلا لتُبَيِّن لهم ما يختلفون في من الدين والأحكام؛ فيذهبون فيها إلى خلاف ما يذهب إليه المسلمون، فَتقومُ الحجةُ عليهم بدعائك وبيانك.وقوله تعالى: ﴿وَهُدًى وَرَحْمَةً﴾ قال أبو إسحاق: بنصب ﴿رَحْمَتَ﴾؛ لأن المعنى: وما أنزلنا عليك الكتاب إلا للهداية والرحمة، فهو مفعول له {1}."
  16,65,"قوله تعالى: ﴿وَاللَّهُ أَنْزَلَ مِنَ السَّمَاءِ مَاءً﴾ إلى قوله: ﴿يَسْمَعُونَ﴾ أخبر الله تعالى أنه هو الذي أنزل المطرَ فأخصبت الأرض به بعد جُدُوبتها وُيبُوستها، وفي ذلك آية ودلالة على قدرته على البعث والإحياء بعد الإماتة لمن سمع ذلك سَماعَ اعتبارٍ وتَفَكُّر."
  16,66,"قوله تعالى: ﴿وَإِنَّ لَكُمْ فِي الْأَنْعَامِ لَعِبْرَةً﴾ الآية. ذكرنا معنى العبرة في سورة آل عمران عند قوله: ﴿لَعِبْرَةً لِأُولِي الْأَبْصَارِ﴾ [آية: 13].وقوله تعالى: ﴿نُسْقِيكُمْ مِمَّا فِي بُطُونِهِ﴾ مَنْ فتح النون {1} فحجته ظاهرة يقول: سقيته حتى رَوِي، أسقيه، قال الله تعالى ﴿وَسَقَاهُمْ رَبُّهُمْ شَرَابًا طَهُورًا﴾ [الإنسان:21]، وقال: ﴿وَالَّذِي هُوَ يُطْعِمُنِي وَيَسْقِينِ﴾ [الشعراء: 79]، وقال: ﴿وَسُقُوا مَاءً حَمِيمًا﴾ [محمد: 15]، وما كان للشفة فهو بفتح النون؛ ومن ضَمَّ النونَ {2} فهو من قولك: أسقاه إذا جعل له شِربًا كقوله: ﴿وَأَسْقَيْنَاكُمْ مَاءً فُرَاتًا﴾ [المرسلات: 27]، وقوله: ﴿فَأَسْقَيْنَاكُمُوهُ﴾ [الحجر: 22]، والمعنى هاهنا إنا جعلناه في كثرته وإدامته كالسُّقْيَا، واختار أبو عبيدة الضَّمَّ وقال: لأنه شِرْبٌ دائم {3}، وأكثر ما يقال في هذا المعنى: أَسْقَيْت، وذكرنا الكلام في سقى وأسقى في سورة الحجر {4}.واختلف النحويون في علة تذكير الكناية في قوله: ﴿مِمَّا فِي بُطُونِهِ﴾، وهي راجعة إلى الأنعام، فقال أبو إسحاق: الأنعام لفظه لفظ جمع، وهو اسم للجنس يذكر ويؤنث، يقال: وهو الأنعام، وهي الأنعام، ﴿نُسْقِيكُمْ مِمَّا فِي بُطُونِهِ﴾، وفي موضع آخر: ﴿مِمَّا فِي بُطُونِهَا﴾ {5} [المؤمنون: 21].وهذا مذهب سيبويه، قال في ذِكْرِه إن الاسم الواحد يجيء على أَفْعَال، قال: يقال: هو الأنْعَام، وقال: ﴿فِي بُطُونِهِ﴾ {6}، فذهب إلى أنه اسم مذكر يقع للجميع كالقوم والنفر والرهط، وقال الفراء: النَّعَمُ والأنعامُ شيء واحد، فرجع التذكير إلى معنى النَّعَم إذ كان يؤدي عن معنى الأنعام، وأنشد {7}:وطاب ألْبانُ اللِّقَاح وَبردْ {8}وفرحع إلى اللبن {9}؛ لأن اللبن والألبان في معنى واحد {10}، والدليل على أن النَّعَمَ مذكر قول الراجز {11}:أَكُلَّ عَامٍ نَعَمٌ تَحْوُونَهُ ... يُلْقِحُهُ قَوْمٌ وتَنْتُجُونه {12} قال الكسائي: أراد مما في بطون ما ذكرنا {13}، قال الفراء: وهو صواب، أنشدني بعضهم:مِثْلُ الفِراخِ نَتَقَتْ حَواصِلُه {14} {15}وقال المبرد: هذا فاشٍ في القرآن وفي كلامهم، مثل: ﴿فَلَمَّا رَأَى الشَّمْسَ بَازِغَةً قَالَ هَذَا رَبِّي﴾ [الأنعام: 78]، بمعنى هذا الشيء الطالع، وكذلك قوله: ﴿كَلَّا إِنَّهُ تَذْكِرَةٌ (54) فَمَنْ شَاءَ ذَكَرَهُ﴾ [المدثر: 54، 55]، أي: ذَكَرَ هذا الشيء، وكذلك: ﴿وَإِنِّي مُرْسِلَةٌ إِلَيْهِمْ بِهَدِيَّةٍ﴾ النمل: 35]، ثم قال: ﴿فَلَمَّا جَاءَ سُلَيْمَانَ﴾ [النمل: 36]، ولم يقل: جاءت؛ لأن المعنى: جاء الشيءُ الذي ذكرنا {16}.قال أبو عبيد: وسمعت الكسائي يُنْشِد ما هو أشد من هذا {17}:وعَفْرَاءُ أَدْنَى الناسِ مِنِّي مَوَدَةً ... وعَفراءُ عَنِّي المُعْرِضُ الْمُتَوَانِي {18}قال وأنشدنا الأحمر {19}:إذ {20} الناسُ نَاسٌ والبِلَادُ بِغِرَّةٍ ... وإِذْ أُمُّ عَمَّارٍ صَدِيقٌ مُسَاعِفُ {21} فهذا التذكير في هذه الأشياء أشَدُّ منه في الأنعام، ومثله كثير {22}، وإنما توَجَّه على معنى هذا الشخص والسواد وكل شيء، فالشيء يَشْرَكُه في اسمه، فالأصل التذكير؛ لأن الشيء مذَكَّر، غير أن الشيء إذا كان تأنيثه حقيقيًّا فلا بد من أن يؤنث في مستقيم الكلام، لا يَحْسُن أن يقول: جَارِيتُك ذهب ولا غلامك ذهبت، بحمله على النَّسْمَة {23}، وذهب المؤرج في هذا إلى وجه آخر؛ وهو أن الكناية تعود إلى ما في قوله: ﴿مِمَّا فِي بُطُونِهِ﴾ وأضمر اللبن؛ كأنه قيل: نسقيكم مما في بطونه اللبن، ﴿مِنْ بَيْنِ فَرْثٍ وَدَمٍ لَبَنًا﴾ أراد أنه يُسقى من أَيِّها كان ذا لبن؛ لأنه ليس لكلها لبن {24}، واختار صاحب النظم هذا الوجه وزاده بيانًا فقال: الأنعام يقع على الذكر والأنثى، والصغير والكبير، والحائل {25} والحامل، وذات الدَّرّ والبِلَى {26}، فلما ذَكَرَ عز وجل مُجْمَلَه في أول الفصل، وليس الدّرُّ إلا لبعضها؛ مَيَّزَ واختص منها في الخبر ذات الدّر دون سائرها. فقوله: ﴿مِمَّا﴾ مِثْلُ قولك: مِنْ الَّتي، إلا أنه لمّا ذَكَرَ (الَّتي) بلفظ (ما) ذَكَرَ الكناية؛ لأن (ما) لا تبين فيه تذكير ولا تأنيث، فكأنه مذكر، والتقدير: نُسقيكم مِن التي في بطونها لبن، ﴿مِنْ بَيْنِ فَرْثٍ وَدَمٍ لَبَنًا﴾، وأضمر ذِكرَ اللبن لعلم المخاطب بذلك، ولمجيء {27} ذِكرِ اللبن فيما بعده.وقوله تعالى: ﴿مِنْ بَيْنِ فَرْثٍ وَدَمٍ لَبَنًا﴾، الفَرْثُ: سِرْجين الكرش {28}، قال ابن عباس: يريد العلف الذي يكون في الكرش، وروى الكلبي عن أبي صالح عنه أنه قال: إذا استقر العَلَفُ في الكرش صار أسفله فَرْثًا وأعلاه دمًا وأوسطه لبنًا، فيجري الدمُ في العروق واللبنُ في الضَّرع ويبقى الفَرْثُ كما هو {29}، فذلك قوله: ﴿مِنْ بَيْنِ فَرْثٍ وَدَمٍ لَبَنًا خَالِصًا﴾: لا يَشُوبُه الدم ولا الفرث، ﴿سَائِغًا لِلشَّارِبِينَ﴾: جائزًا في حلوقهم لذيذًا هنيئًا، يقال: ساغَ الشَّرَابُ في الحلق وأَسَاغَهُ صاحِبُه {30}، ومنه قوله: ﴿وَلَا يَكَادُ يُسِيغُهُ﴾ [إبراهيم: 17] وقد مر، والآية بيان عن إقامة الدلالة على الصانع حيث جعل العَلَف وهو جنس واحد أنواعًا في بطن الدابة، فإذا تفكر العاقلُ عَلِمَ أن ذلك بقدرة الله الذي لا إله إلا هو، قال أصحابنا: وهذه الآية تدل على أن مَنِيّ الآدمي لا يكون نجسًا وإن كان في باطنه مجاورًا للنجاسات كاللبن؛ فإنه يخرج طاهرًا من بين نجسين {31}.كذلك يجوز أن يخرج المنيّ طاهرًا وإن جرى في طريق النجاسة {32} {33}."
  16,67,"قوله تعالى: ﴿وَمِنْ ثَمَرَاتِ النَّخِيلِ وَالْأَعْنَابِ﴾ الآية.قال صاحب النظم: تأويل الآية: ولكم من ثمرات النخيل والأعناب ما تتخذون منه سكرًا {1}؛ لأنه لو كان مبتدأً ومنقطعًا مما قبله لوجب أن يقال: منها؛ لأن تأويله يكون راجعًا على قوله: ﴿ثَمَرَاتِ النَّخِيلِ وَالْأَعْنَابِ﴾ على ما نظم، وتتخذون من ثمرات النخيل والأعناب سكرًا.والعرب تضمر (ما) و (من) كقوله تعالي: ﴿وَإِذَا رَأَيْتَ ثَمَّ﴾ {2} [الإنسان: 20]، ﴿وَمَا مِنَّا إِلَّا لَهُ﴾ {3} [الصافات: 164] وذكرنا {4} هذا قديمًا.والأعناب عطف على الثمرات لا على النخيل؛ لأنه يصير التقدير: ومن ثمرات الأعناب، والأعناب ثمار، ولكنه ومن الأعناب، وأمَّا السكر فروى سعيد بن جبير وشهر بن حَوْشب وعمرو {5} بن سفيان {6} عن ابن عباس أنه قال: السَّكَر ما حُرِّم من ثمرتيهما، والرزق الحسن ما أُحلَّ من ثمرتيهما {7}، وقال في رواية عطاء: سَكَرًا يريد ما أَسْكَر، وهذا قبل أن يحرم الخمر.﴿وَرِزْقًا حَسَنًا﴾ يريد الخَلَّ والزبيب والتمر وكل ما يُتَّخَذ من النخيل والأعناب {8}، وهذا قول عامة المفسرين؛ قالوا: السكر هي الخمر بعينها، والسكر حرام، والرزق الحسن حلال، وقالوا: نزلت هذه قبل تحريم الخمر {9}، ونزل تحريمها في سورة المائدة {10}.والسَّكَر في اللغة: الخمر {11}، وقال جرير: إذا رَوِينَ على الخِنْزِيرِ من سَكَرٍ ... نادَيْنَ يا أعظمَ القِسِّين جُرْداناَ {12}وهذا القول هو اختيار الفراء {13} والزجاج {14}.وقال أبو عبيدة بوحده: السَّكَر: الطعام، واحتج بقوله {15}:جَعَلْتَ أعْرَاضَ الكِرَامِ سَكَرا {16}أي جعلتَ ذَمَّهم {17} طُعْمًا لك {18}.قال الزجاج: هذا بالخمر أشبَهُ منه بالطعام، المعنى: جعلْتَ تتخمَّرُ بأعراضِ الكرام، وهو أبينُ فيما يقال: يبترك {19} في أعراض الناس {20}؛ يتخَمَّر بهم.وقوله تعالى: ﴿إِنَّ فِي ذَلِكَ لَآيَةً لِقَوْمٍ يَعْقِلُونَ﴾ قال ابن عباس: يريد عقلوا عن الله قدرَته وما لا يقدر عليه أحدٌ غيرُه وحدَه، فصَدَّقوا نَبِيَّه وأيْقَنُوا بالثواب والعقاب."
  16,68,"قوله تعالى: ﴿وَأَوْحَى رَبُّكَ﴾ الآية. وَحَى وأوحَى واحد {1}، وهو الإلهام هاهنا، قال المفسرون: ألهَمَها وقذف في أنفسها {2}، وذكرنا معنى الوحي والإيحاء {3} عند قوله: ﴿إِنَّا أَوْحَيْنَا إِلَيْكَ﴾ [النساء: 163] وفي مواضع. وقوله تعالي: ﴿إِلَى النَّحْلِ﴾، النَّحْل: زنبور {4} العَسَلِ، والواحدة نَحْلَة {5}.قال الزجاج: جائز أن يكون سمي نحلًا؛ لأن الله عز وجل نحل الناس العسل الذي يخرج من بطونها، وقال غيره: النَّحْل يذكر ويؤنث {6}، وهي مؤنثة في لغة الحجاز؛ ولذلك أنثها الله تعالى، وكذلك كل جمع ليس بينه وبين واحده إلا الهاء.وقال أهل المعاني: الله تعالى أوحى إلى كل دابة وذي روح وحي الإلهام في التماس منافعها واجتناب مضارِّهَا، فذكر من ذلك أمر النحل؛ لأن فيها من لطيف الصنعة وبديع الخلق ما فيه أعظم معتبر، بأن ألهمها اتخاذ المنازل والمساكن {7}، وذلك قوله: ﴿أَنِ اتَّخِذِي مِنَ الْجِبَالِ بُيُوتًا وَمِنَ الشَّجَرِ﴾، قال ابن عباس: هي تتخذ من الجبال لأنفسها إذا كانت لا أصحاب لها {8}.وقوله تعالى: ﴿وَمِمَّا يَعْرِشُونَ﴾، أي: يبنون ويسقفون، وفيه لغتان: قُرئ بها ضَمُّ الراء {9} وكسرها {10} مثل يَعْكِفون ويَعْكُفون.قال ابن عباس: يريد ما يعرش الناس لها من الجِبَاح {11}؛ وهو: خلايا النحل {12}.وقال ابن زيد في قوله: ﴿وَمِمَّا يَعْرِشُونَ﴾ هو الكروم {13}، ولا معنى للكروم هاهنا؛ لأنها لا تأوي الكُرُومَ، والمعنى ما قاله ابن عباس أن معنى يعرشون: يبنون لها من خلاياها، ويعرشون صحيح في البناء للكروم، ولكن المراد هاهنا في البناء للنحل لا الكَرْم.قال أهل المعاني: لولا التسخير وإلهام الله تعالى ما كانت تأوي إلى ما يبني لها الناس من بيوتها {14}."
  16,69,"قوله تعالى: ﴿ثُمَّ كُلِي مِنْ كُلِّ الثَّمَرَاتِ﴾ قال ابن قتيبة: أي من الثمرات، وكل هاهنا لا يقع على العموم، كقوله: ﴿وَأُوتِيَتْ مِنْ كُلِّ شَيْءٍ﴾ [النمل: 23]، وقوله: ﴿تُدَمِّرُ كُلَّ شَيْءٍ﴾ {1} [الأحقاف: 25].وقوله تعالى: ﴿فَاسْلُكِي سُبُلَ رَبِّكِ﴾ قال ابن عباس: يريد طُرقَ ربك {2}، تطلب فيها الرعي، ﴿ذُلُلًا﴾ جمع ذَلُول، وهو المنقاد اللين المُسَخَّر، يقال: فرس ذلول بَيِّن الذُّلِ {3}.قال مجاهد: لا يتوعَّرُ عليها مكان سلكته {4}، فعلى هذا الذُّلُلُ من صفة السُّبُل، والنحل يرعى الأماكن البعيدة ذات الغِيَاضِ {5}، الأشْبَهُ: لا تتوعر عليها لتذليل الله لها إياها، وهذا القول اختيار الزجاج؛ لأنه قال في قولهه: ﴿سُبُلَ رَبِّكِ ذُلُلًا﴾، أي: قد ذَلَّلَها الله لك وسَهَّلَ عليك مَسالِكَها {6}.وقال قتادة: ذُلُلًا يعني مطيعة {7}، وهو اختيار ابن قتيبة؛ لأنه قال: منقادة بالتَّسْخِير {8}، وعلى هذا الذُّلُلُ من نعت النَّحل، وحكى الفراء القولين، فقال: ذُلُلًا نعتُ للسبيل، ويقال: نعت للنحل؛ أي ذُلِّلَت لأن يخرج الشراب من بطنها {9}.وقوله تعالى: ﴿يَخْرُجُ مِنْ بُطُونِهَا﴾ رجوع من الخطاب إلى الخبر، ﴿شَرَابٌ مُخْتَلِفٌ أَلْوَانُهُ﴾ قال ابن عباس: منه أحمر وأبيض وأصفر {10}.قال أبو إسحاق: هي تأكل الحامضَ والمُرَّ وما لا يُوصفُ طعمُهُ فيحيل اللهُ ذلك عَسَلًا يخرج من بطونها، إلا أنها تلقيه من أفواهها؛ كالريق الذي يخرج من فم ابن آدم {11}.قوله تعالى: ﴿فِيهِ شِفَاءٌ لِلنَّاسِ﴾ أكثرُ المفسرين على أن الكناية تعود إلى قوله: ﴿شَرَابٌ﴾، وهو العسل، وقالوا: إن في العسل شفاء للناس {12}، فإن قيل: قد رأينا من يَضُرُّه العسل، فكيف يكون فيه شفاء للناس؟! أجاب عن هذا الزجاج، وقال: الماء حياة كل شيء، وقد رأينا من يقتله الماء إذا أخذه على ما يُضَادُّه من علة في البدن {13}، وهذا معنى قول السدي: فيه شفاء للأوجاع التي شفاؤها فيه {14}.وروي عن مجاهد: ﴿فِيهِ شِفَاءٌ لِلنَّاسِ﴾: أي في القرآن {15}.قال أبو [إسحاق] {16} وهذا القول إذا فُسِّرَ عُلم أنه حَسَنٌ، المعنى فيما قصصنا عليكم من قصة النحل في القرآن وسائر القصص التي تدل على أن الله واحدٌ، شفاء للناس {17}، وعلى هذا كون القرآن شفاء؛ أن فيه بيان الحلال والحرام، والدليل على وحدانية الله تعالى، ونفيًا لما يتخالج ويعترض من الشكوك، يدل على هذا قوله تعالى [في] {18} وصفه القرآن: ﴿وَشِفَاءٌ لِمَا في الصُّدُورِ﴾ [يونس: 57].(وقال ابن مسعود: العسل فيه شفاء من كل داء، والقرآن شفاء لما في الصدور {19}) {20}، وذكر الفراء والزجاج القولين جميعًا {21}.واختار قوم القول الأول؛ وقالوا: إنه أليق بظاهر الكتاب {22}، واحتجوا بما أخبرناه أبو إسحاق بن أبي منصور المقرئ {23} أنا عبد الله بن حامد {24}، أنا مكي بيت عبدان {25}، أنا عبد الرحمن بن بشر {26}، أنا يحيى بن سعيد {27}، عن شعبة عن قتادة عن أبي المتوكل {28}، عن أبي سعيد الخدري، قال: جاء رجل إلى النبي -ﷺ- فقال: إن أخي تشتكي بطنه فقال: ""اسقه عسلًا"" فذهب ثم رجع فقال: قد سقيته فلم يغن عنه شيئًا، فقال عليه السلام: "" اذهب واسقه عسلاً، فقد صدق الله وكذب بطنُ أخيك، وسقاه فبرأ كأنما أُنْشِط من عقال"" {29}، وتاوَّلُوا في قوله: ""صدق الله"" قوله تعالى: ﴿فِيهِ شِفَاءٌ لِلنَّاسِ﴾.وقوله تعالى: ﴿إِنَّ في ذَلِكَ لَآيَةً لِقَوْمٍ يَتَفَكَّرُونَ﴾ قال ابن عباس: يريد في عظمة الله وقدرته {30}."
  16,70,"قوله تعالى: ﴿وَاللهُ خَلَقَكُمْ﴾ الآية. قال المفسرون: ولم تكونوا شيئًا {1}، ﴿ثُمَّ يَتَوَفَّاكُمْ﴾ عند إنقضاء آجالكم، ﴿وَمِنْكُمْ مَنْ يُرَدُّ إِلَى أَرْذَلِ الْعُمُرِ﴾ وهو أَرْدَاه وأَوْضَعه، يقال: رَذُلَ الشيء يَرْذُلُ رَذَالَةً، وأَرْذَلَه غيره {2}، ومنه قوله: ﴿إِلَّا الَّذِينَ هُمْ أَرَاذِلُنَا﴾ [هود: 27]، ﴿وَاتَّبَعَكَ الْأَرْذَلُونَ﴾ [الشعراء: 111]. روى أسباط عن السُّدّي: ﴿إِلَى أَرْذَلِ الْعُمُرِ﴾ قال: الخرف {3}، ونحوه قوله: ﴿ثُمَّ رَدَدْنَاهُ أَسْفَلَ سَافِلِينَ﴾ [التين: 5]، ونظير هذه الآية لفظًا ومعنى في الحج {4}، وقال مقاتل: ﴿أَرْذَلِ الْعُمُرِ﴾: الهرم {5}، وقال قتادة: تسعون سنة {6}، روي عن علي -رضي الله عنه- قال: ﴿أَرْذَلِ الْعُمُرِ﴾: خمس وسبعون سنة {7}.قوله تعالى: ﴿لِكَيْ لَا يَعْلَمَ بَعْدَ عِلْمٍ شَيْئًا﴾ أي ليرجع إلى حال الطفولية بنسيان ما كان علم؛ للكِبَر، قال ابن عباس: كي يصير كالصبي الذي لا عقل له {8}.وقال أبو إسحاق: معنى قوله: ﴿لِكَيْ لَا يَعْلَمَ بَعْدَ عِلْمٍ شَيْئًا﴾، أي: ليريكم من قدرته أنه كما قدّر إماتته وإحياءَه، إنه علي نقله من العلم إلى الجهل قادر {9}.قال عطاء عن ابن عباس: ليس هذا في المسلمين، والمسلم لا يزداد في طول العمر والبقاء عند الله إلا كرامة وعقلاً ومعرفة {10}، وقال في قوله: ﴿ثُمَّ رَدَدْنَاهُ أَسْفَلَ سَافِلِينَ﴾ [التين: 5]، يريد الكافر، ثم استثنى المؤمنين فقال: ﴿إِلَّا الَّذِينَ آمَنُوا﴾ {11} [التين: 6].ونحو هذا روى عاصم {12} عن عكرمة، قال: من قرأ القرآن لم يُردَّ إلى أرذل العمر حتى لا يعلم بعد علم شيئًا {13}، وقال في قوله: ﴿إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّلِخَتِ﴾: قرؤوا القرآن {14}.وقوله تعالى: ﴿إِنَّ اللهَ عَلِيمٌ﴾ قال ابن عباس: يريد بما صنع بأوليائه وأعدائه، ﴿قَدِيرٌ﴾: على ما يريد {15}."
  16,71,"قوله تعالى: ﴿وَاللهُ فَضَّلَ بَعْضَكُمْ عَلَى بَعْضٍ في الرِّزْقِ﴾: كَثَّر وقَلَّلَ، وبَسَطَ وقَبَضَ، ووَسَّعَ وضَيَّقَ، ﴿فَمَا الَّذِينَ فُضِّلُوا﴾: في الرزق وأُعطوا الفضْل، ﴿بِرَادِّي رِزْقِهِمْ عَلَى مَا مَلَكَتْ أَيْمَانُهُمْ﴾، يقول: لا يردّ المولى على ما ملكت يمينه مما رُزق شيئًا حتى يكون المولى والمملوك في المال سواء.قال أبو إسحاق: أي قد فَضَّلَ اللهُ المُلاَّكَ على ممالِيكِهِم، فجعلَ المملوك لا يقدر على مِلْكٍ من مَوْلَاه، وأعلم أن المالكَ ليس يَرُدُّ على مملوكه من فضل ماله حتى يستوي حالهما في الملك {1}، وهذا مَثَلٌ ضربه اللهُ مثلًا للمشركين في تَصْيِيرِهم عباد الله شركاء له، فقال: إذا لم يكن عبيدكم معكم سواء في الملك، فكيف تجعلون عبيدي معي سواء؟! وقال صاحب النظم: معنى الفاء في قوله: ﴿فَهُمْ فِيهِ سَوَاءٌ﴾ حتى {2}؛ لأن التأويل: ﴿فَمَا الَّذِينَ فُضِّلُوا﴾: بجاعلي رزقهم لعبيدهم حتى يكون عبيدهم فيه معهم سواء في الملك، فقدله: ﴿فَهُمْ فِيهِ سَوَاءٌ﴾ صفة لما تَقَدَّمه من الخبر لا جوابٌ له؛ ولو كان جوابًا له لكان قد أوجب أن يكون المولى والعبيد في ذلك سواء، وهو عز وجل إنما أراد أنهم لا يستوون في الملك، ونظير هذه الآية قوله تعالى: ﴿ضَرَبَ لَكُمْ مَثَلًا مِنْ أَنْفُسِكُمْ﴾ إلى قوله: ﴿فَأَنْتُمْ فِيهِ سَوَاءٌ﴾ [الروم: 28] بمعنى: حتى أنتم فيه سواء إليّ، هل يشاركونكم في أموالكم حتى تكونوا أنتم وهم فيه سواء.وهذا الذي ذكرنا هو قول جميع المفسرين في هذه الآية؛ قال مجاهد: هذا مَثَلُ آلهة الباطل مع الله {3}.وقال السدي: يقول: فكما لا يرد أحدهم على مملوكه مما رزقه الله حتى يكون مثله، فلذلك لا أكون أنا وهذا الصنم الذي هو من خلقي ومما ملكت سواءً فيما خلقت {4}.وقال قتادة: يقول: هذا الذي فُضِّل في المال والولد لا يشرك عبدَه في ماله وزوجته، يقول: قد رضيتَ بذلك لله ولم ترض به لنفسك، فجعلت لله شريكًا في خلقه وملكه {5}.وروي عن ابن عباس أنه قال: نزلت هذه الآية في نصارى نجران حين قالوا: عيسى ابن مريم ابن الله {6}.قال الفراء: فهذا مثل ضربه الله للذين قالوا: إن عيسى ابنه، فقال: أنتم لا تُشركون عبيدكم فيما ملكتم، فتكونون سواءً فيه، فكيف جعلتم عَبْدَه شريكًا له تعالى {7}، وتلخيص معنى الآية، أنه يقول: إنكم كلكم (من بني آدم وأنتم بينكم فيما ملكت أيمانكم، وأنتم {8} كلكم) {9} بشر، فكيف تشركون بين الله وبين الأصنام وأنتم لا ترضون لأنفسكم فيمن هو مثلكم بالشركة.وقوله تعالى: ﴿أَفَبِنِعْمَةِ اللهِ يَجْحَدُونَ﴾ قرأه العامة: يجحدون بالياء {10}؛ لأنه يراد به غير المسلمين، والمسلمون لا يخاطبون بجحدهم نعمة الله، وقرأ عاصم في رواية أبي بكر بالتاء {11}؛ على تقدير: قل لهم: أفبنعمة الله -بهذه الأشياء التي تقدم اقتصاصها- تجحدون بالإشراك به.وذكر الزجاج في هذا وجهين، أحدهما: أفبِأنْ أَنْعَمَ اللهُ عليكم اتَّخَذْتُم النِّعَمَ لتجحدوا وتشركوا به الأصنام؛ فعلى هذا النعمة بمعنى الإنعام.والثاني: قال أفبما أنعم الله به عليكم بأن بَيَّنَ لكم ما تحتاجون إليه تجحدون {12}، وعلى هذا، النِّعْمَة: اسم لما أَنعمَ اللهُ عليهم لا مصدر، والباء في: ﴿أَفَبِنِعْمَةِ﴾ يجوز أن تكون زيادة {13}؛ لأن الجحود لا يُعدَّى بالباء، وهذا قول المفضَّل كما يقول: خذ الخطام وبالخطام، وتعلقت زيدًا وبه {14}، ويجوز أن يراد بالجحود: الكفر {15}، فعُدِّيَ بالباء لمعنى الكفر {16}."
  16,72,"قوله تعالى: ﴿وَاللهُ جَعَلَ لَكُمْ مِنْ أَنْفُسِكُمْ أَزْوَاجًا﴾ قال المفسرون: يعني النساء؛ خَلَقَ حواءَ من ضلع آدم {1}، {وَجَعَلَ لَكُمْ مِنْ أَزْوَاجِكُمْ بَنِينَ وَحَفَدَةً} اختلفوا في تفسير الحفدة، فقال ابن عباس في رواية الوالبي: هم الأختان {2}، وهو قول ابن مسعود وإبراهيم وسعيد بن جبير، قالوا: هم الأصهار؛ أَخْتَان [الرجل] {3} علي بناته {4}، وقال في رواية أبي حمزة {5} عنه: من أعانك فقد حفدك أما سمعت قول الشاعر {6}:حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُسلَمتْ ... بأكُفِّهِنَ أَزِمَّةُ الأجْمَالِ {7} {8} فعلي هذا الحفدة: الأعوان، وهذا قول مجاهد والحسن والسدي وعكرمة، قالوا: هم الأنصار والأعوان والخدم {9}، غير أن السدي وعكرمة قالا: هم ولده الذين يعينونه {10}، ونحوه قال قتادة وعطاء {11}، وقال في رواية سعيد بن جبير ومجاهد: إنهم ولد الولد {12}، وقال في رواية العوفي: هم بنو امرأة الرجل، ليسوا منه، وهو قول ابن زيد والضحاك {13}.وأصلُ الحَفَدَةِ من الحَفْد، وهو: الخِفَّةُ في الخدمة والعمل، يقال: حفد يَحْفِدُ حَفْدًا وحَفُودًا وحَفَدانًا إذا أسرع {14}، ومنه الدعاء: (وإليك نسعى ونحفد) {15}، قال أبو عبيدة: الحَفَدُ: الأعوان، يقال: حفدني، وهو حافدي {16}، وأنشد لطرفة:يَحْفِدون الضيفَ في أبياتِهمْ ... كَرَمًا ذلك منهم غيرَ ذُلّ {17}قال أبو عبيد: وفيه لغة أخرى؛ أَحْفَدَ إِحْفادًا، وأنشد للراعي:أَخَبَّ بِهن الْمُخْلِفَان وأَحْفَدَا {18}قال: خَدَمَا {19}، قال الليث: ومثله الاحْتِفادُ {20}، فالحفدة جمع الحافد، والحافد: كل من يخف في خدمة أو يسرع في العمل بطاعتك، ويقال في جمعه: الحَفَدُ، بغير هاء، كما يقال: الرصد والعيب، فمعنى الحفدة في اللغة: الأعوان والخدم، ثم هؤلاء الأعوان مَنْ هم على ما ذكره المفسرون، والأولى بأن يفسر بأعوان حصلوا للرجل [نْ قِبَل المرأة؛ لأن الله تعالى قال. ﴿وَجَعَلَ لَكُمْ مِنْ أَزْوَاجِكُمْ بَنِينَ وَحَفَدَةً﴾ وأعوان الرجل لا] {21} من قِبَل امرأته لا يكونون ممن عناهم {22} الله بقوله هاهنا: ﴿وَحَفَدَةً﴾ {23}.قوله تعالى: ﴿وَرَزَقَكُمْ مِنَ الطَّيِّبَاتِ﴾ قال ابن عباس: يريد من أنواع الثمار والحبوب والحيوان {24}، ﴿أَفَبِالْبَاطِلِ يُؤْمِنُونَ﴾ قال ابن عباس: يعني بالأصنام {25}، وقال مقاتل: يعني بالشيطان {26}، وقال عطاء: يعني {27} تُصدِقوا أن لي شريكًا وصاحبة وولدًا {28}، ﴿وَبِنِعْمَتِ اللهِ هُمْ يَكْفُرُونَ﴾، رُوي عن ابن عباس: أنه قال: يعني التوحيد {29}، وقيل: أراد بما أنعم الله عليهم مما أحل لهم يكفرون؛ فيحرمونه ويجحدون تحليله {30}، يعني ما حَرَّمُوا على أنفسهم من الأنعام والحرث، وذكرنا وجهين في قوله: ﴿أَفَبِنِعْمَةِ اللَّهِ يَجْحَدُونَ﴾، والوجهان هاهنا جائزان."
  16,73,"قوله تعالى: ﴿وَيَعْبُدُونَ مِنْ دُونِ اللَّهِ مَا لَا يَمْلِكُ لَهُمْ رِزْقًا مِنَ السَّمَاوَاتِ﴾ يعني الغيث الذي يأتي من جهتها، ﴿وَالْأَرْضِ﴾ يعني النبات والثمار التي تخرج منها.وقوله تعالى: ﴿مِنَ السَّمَاوَاتِ وَالْأَرْضِ﴾، (من) صفة النكرة التي هي: ﴿رِزْقًا﴾ كأنه قيل: لا يملك لهم رزقًا من الغيث والنبات.وقوله تعالى: ﴿شَيْئًا﴾ قال الأخفش: جعل الشيء بدلًا من الرزق، وهو في معنى: لا يملكون رزقًا قليلًا ولا كثيرًا {1}، أي لا يملكون أن يرزقهم شيئًا من السموات والأرض، وقال الفراء: نصب ﴿شَيْئًا﴾ بوقوع الرزق عليه {2}، كما قال: ﴿أَلَمْ نَجْعَلِ الْأَرْضَ كِفَاتًا (25) أَحْيَاءً وَأَمْوَاتًا﴾ [المرسلات: 25، 26] أي: تكْفِت الأحياء والأموات، ومثله: ﴿أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ (14) يَتِيمًا ذَا مَقْرَبَةٍ﴾ {3} [البلد: 15،14].وقوله تعالى: ﴿وَلَا يَسْتَطِيعُونَ﴾ أي لا يقدرون على شيء، وليست لهم استطاعة، وجمع هاهنا؛ لأن (ما) في مذهب جمع لآلهتهم التي يعبدون، فَوَحَّدَ ﴿يَمْلِكُ﴾ على لفظ (ما) {4} وجمع يستطيعون على المعنى {5}."
  16,74,"وقوله تعالى: ﴿فَلَا تَضْرِبُوا لِلَّهِ الْأَمْثَالَ﴾ قال المفسرون: يعني لا تُشَبِّهُوهُ بخلقه {1}، وقال الزجاج: أي لا تجعلوا لله مِثْلاً؛ لأنه واحدٌ لا مِثْلَ له {2}، فعلى هذا ضَرْبُ المَثَل، استُعْمِل في التَّشْبِيه؛ لأن أكثرَ ما يُضْرَب المَثْلُ إنما يُضْرب لتشبيه وصف بوصف أو ذات بذات، وتعالى الله عن أن يُشْبِهَ شيئًا أو يُشْبِهَهُ شيءٌ في ذاته وصفاته.وقوله تعالى: ﴿إِنَّ اللهَ يَعْلَمُ﴾ قال ابن عباس: يريد ما يكون قبل أن يكون وما هو كائن إلى يوم القيامة {3}، ﴿وَأَنْتُمْ لَا تَعْلَمُونَ﴾: قَدْرَ عظمتي؛ حيث أشركتم بي وعَجَّزْتُمُوني أن أبعثَ خلقي."
  16,75,"قوله تعالى: ﴿ضَرَبَ الله مَثَلًا﴾ أي بَيَّنَ الله شِبْهًا فيه بيانٌ للمقصود، ثم ذكر ذلك فقال: ﴿عَبْدًا مَمْلُوكًا﴾ إلى قوله: ﴿سِرًّا وَجَهْرًا﴾ قال مجاهد في هذه الآية والتي تليها: كل هذا مَثَلُ إله الحق وما يُدْعَى من دونه من الباطل {1}.وقال السُّدي: هذا مَثَلٌ ضربه الله للآلهة؛ يقول: كما لا يستوي عندكم عبد مملوك لا يقدر من أمره على شيء ورجل حُرٌّ قد رُزق رزقًا حسنًا فهو ينفق منه سِرًّا وجَهرًا لا يخاف من أحد، فكذلك أنا وهذه الآلهة التي تَدْعُون، ليست تملك شيئًا وأنا الذي أملك وأرزق مَنْ شئت {2}، وهذا القول هو اختيار الفراء {3}، والزجاج قال: بَيَّنَ اللهُ لهم أمرَ ضلالتهم وبعدهم عن الطريق في عبادتهم الأوثان، فذكر أن المالك المقتدر على الإنفاق والعاجز الذي لا يقدر أن ينفق لا يستويان، فكيف يُسَوَّى بين الحجارة التي لا تتحرك ولا تعقل وبين الله الذي هو على كل شيء قدير، وهو رازقُ جميع خلقه {4}.وفي الآية قول آخر، وهو: أن هذا مثل للمؤمن والكافر؛ قال عطاء عن ابن عباس: يريد أبا جهل بن هشام وأبا بكر الصديق {5}، وقال قتادة: هو الكافر لا يعمل بطاعة الله ولا ينفق خيرًا، ﴿وَمَنْ رَزَقْنَاهُ مِنَّا رِزْقًا حَسَنًا﴾ هو المؤمن يطيع الله في نفسه وماله {6}، فعلى هذا القول: الكافر لمَّا لم ينفق في طاعة الله صار كالعبد الذي لا يملك شيئًا، والمؤمن ينفق في الخير وفي طاعة الله، فليسا يستويان، كذلك قال الله تعالى: ﴿هَلْ يَسْتَوُونَ﴾ وجمع الفعل؛ لأن المراد بقوله: ﴿عَبْدًا مَمْلُوكًا﴾، وقوله تعالى: ﴿وَمَنْ رَزَقْنَاهُ مِنَّا﴾، الشُّيوع في الجنس لا التخصيص {7}.واختار ابن قتيبة القول الأول {8}؛ فقال: هذا مثل ضربه الله لنفسه ولمن عُبد دُونَه، فقدله: ﴿عَبْدًا مَمْلُوكًا لَا يَقْدِرُ عَلَى شَيْءٍ﴾ مَثَلُ من عُبِد مِن دونه؛ لأنه عاجزٌ مُدَبَّرٌ مملوكٌ لا يقدر على نفع ولا ضرّ، ثم قال: ﴿وَمَنْ رَزَقْنَاهُ﴾ إلى قوله: ﴿وَجَهْرًا﴾ وهذا مَثَلُه جلَّ وعز؛ لأنه الواسع الجواد القادر الرَّزاق عباده جَهْرًا من حيث يعلمون وسرًّا من حيث لا يعلمون، قال: وهذا القول أعجب إليّ؛ لأن المَثَل توسَّط كلامين؛ هما لله جلّ وعز؛ أما الأول فقوله: ﴿وَيَعْبُدُونَ مِنْ دُونِ اللهِ﴾ الآية. فهذا {9} لله ومن عُبِدَ من دونه، (وأما الآخر فقوله) {10} بعد إنقضاء المثل: ﴿الْحَمْدُ لِلَّهِ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ﴾ {11}، ومعنى قوله: ﴿الْحَمْدُ لِلَّهِ﴾ هاهنا: أنه بَيَّنَ أن له الحمدَ على ما فعل بأوليائه، وأنعم عليهم بالتوحيد، هذا معنى قول ابن عباس {12}.وقال غيره: بَيَّنَ أن له جميعَ الحمد، وأنه المستحق للحمد دون ما يعبدون من دونه؛ لأنه لا يَدَ للأصنام عندهم، ولا نعمة لها عليهم {13}، ومعنى قوله: ﴿بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ﴾ يقول: أكثر هؤلاء المشركين لا يعلمون أن الحمد لي؛ لأن جميع النعمة مني، وذكر الأكثر وهو يريد الجميع.قال أهل المعاني: عزل البعض احتقارًا له أن يُذْكَر، وقال آخرون: هو من الخاص في صِيَغِهِ، الذي هو عموم في معناه، والمعنى: بل هم لا يعلمون {14}، ثم زاد في البيان، فقال:"
  16,76,"﴿وَضَرَبَ الله مَثَلًا رَجُلَيْنِ﴾ قال أبو زيد: رجل أبْكَم وهو العَيُّ المُفْحَمُ، وقد بَكِمَ بَكَمًا وبَكَامَةً، وقال أيضًا: الأبْكَمُ: الأقْطَعُ اللِّسَانِ؛ وهو العَيُّ بالجوابِ الذي لا يُحْسِنُ وَجْهَ الكَلَامِ {1}؛ لأنه لا يَفْهَم ولا يُفْهَم عنه.وقوله تعالى: ﴿وَهُوَ كَلٌّ عَلَى مَوْلَاهُ﴾، أي: هذا الأبكم ثِقْلٌ وَوَبَالٌ على صاحبه وقرينه وابن عمه وَوَلِيِّه، والكلّ: الذي هو عِيالٌ وثِقْلٌ على صاحبه {2}.قال أهل المعاني: وأصله من الغِلَظ الذي هو نقيض الحدة، يقال: كَلّ السكينُ كلولاً، إذا غَلُظَ شفرته فلم يقطع، وكَلَّ لسانه إذا لم ينبعث في القول لِغِلَظه وذهاب حَدّه، وكَلّ عن الأمر يَكَلُّ إذا ثقل عليه فلم ينبعث فيه، فهو يَكَلُّ إذا لم ينفذ في الأمر {3}.وقوله تعالى: ﴿أَيْنَمَا يُوَجِّهْهُ﴾ أي أينما {4} يرسله، ومعنى التوجيه: أن ترسل صاحبك في وجه من الطريق، يقال: وجهته إلى موضع كذا فتوَجَّه إليه {5}.وقوله تعالى: ﴿لَا يَأْتِ بِخَيْرٍ﴾ لأنه عاجز لا يُحْسِن ولا يَفْهَم ما يُقَال له ولا يُفْهَم عنه، ﴿هَلْ يَسْتَوِي هُوَ﴾ أي هذا الأبكم الذي هو بهذا الوصف، ﴿وَمَنْ يَأْمُرُ بِالْعَدْلِ﴾ أي ومن هو قادر تام التمييز متكلم ناطق بالحق، آمرٌ بالعدل قادرٌ على الأمور مُصَرِّفٌ لها على أحسن الوجوه، ﴿وَهُوَ عَلَى صِرَاطٍ مُسْتَقِيمٍ﴾ قال ابن عباس: يريد على دين مستقيم {6}.وللمفسرين في هذه الآية قولان كما ذكرنا في الآية الأولى، فمن قال في المثل الأول أنه مَثَلُ الأوثان والله تعالى، قال في هذه الآية أيضًا: إن هذا مَثَلٌ كالأول، وهو قول مجاهد والسدي وقتادة {7}، واختيار الفراء {8} والزجاج {9} وابن قتيبة {10}.قال مجاهد: كل هذا مَثَلُ إله الحق وما يُدْعَى من دونه من الباطل {11}وقال السدي: أما الأبكم فمِثْلُ الصنم؛ لأنه أَبْكَمُ لا ينطق، وهو كَلّ على عابديه؛ يُنْفِقون عليه ولا يُنْفِق هو عليهم ولا يَرْزقُهم، ﴿أَيْنَمَا يُوَجِّهْهُ﴾: الصنم من شرق أو غرب لا يأت بخير، يقول: لا يرزقهم ولا ينفعهم، ﴿هَلْ يَسْتَوِي هُوَ وَمَنْ يَأْمُرُ بِالْعَدْلِ﴾، والذي يأمر بالعدل: الله تبارك وتعالى، ونحو هذا قال قتادة {12}.وقال الزجاج: هل يستوي القادرُ التامُ التمييزِ والعاجزُ الذي لا يُحْسِن ولا يأتي بخير، فكيف تُسَوُّون بين الله عز وجل وبين الأحجار {13}.وقال ابن قتيبة: هذا مَثَلُ آلهتهم؛ لأنها بُكْمٌ صُمّ عُمْيٌ، ثِقْلٌ على من عبدَها في خدمتها، وهي لا تأتيه بخير {14}.ثم قال: ﴿هَلْ يَسْتَوِي هُوَ وَمَنْ يَأْمُرُ بِالْعَدْلِ وَهُوَ عَلَى صِرَاطٍ مُسْتَقِيمٍ﴾ فجعل هذا المَثَلَ لنفسه، وقال في قوله: ﴿وَهُوَ كَلٌّ عَلَى مَوْلَاهُ﴾ هذا مثل للصنم الذي عبدوه، ﴿وَهُوَ كَلٌّ عَلَى مَوْلَاهُ﴾؛ لأنه يحمله إذا ظَعَن، وُيحَوِّلَه من مكان إلى مكان إذا تحرك، فقال الله تعالى: ﴿هَلْ يَسْتَوِي﴾: هذا الصنم الكَلّ، ﴿وَمَنْ يَأْمُرُ بِالْعَدْلِ﴾، وهو استفهام معناه التوبيخ، كأنه قال: لا تُسَوُّوا بين الصنمِ الكَلِّ وبين الخالق عز وجل {15}.وقال آخرون: هذا مثل للمؤمن والكافر، وهو قول ابن عباس في رواية عطية {16}.ثم اختلفوا فيمن نزل، فروى يَعْلَى بن مُنْيَةَ {17} عن ابن عباس: أنها نزلت في عثمان بن عفان ومولاه؛ كان عثمان -رضي الله عنه- ينفق عليه ويكفيه المؤونة، وكان مولاه يكره الإسلام، وينهاه عن الصدقة ويمنعه من النفقة {18}.وقال في رواية عطاء، الأبكم: أُبي بن خلف الجمحي، ﴿وَهُوَ كَلٌّ عَلَى مَوْلَاهُ﴾ يريد كَلّ على قومه، كان يؤذيهم، ﴿هَلْ يَسْتَوِي هُوَ﴾، يريد أبي ابن خلف، ﴿وَمَنْ يَأْمُرُ بِالْعَدْلِ﴾، يريد حمزة وعثمان بن مظعون {19}."
  16,77,"قوله تعالى: ﴿وَلِلَّهِ غَيْبُ السَّمَاوَاتِ﴾ قال أبو إسحاق: معناه: ولله عِلْمُ غيبِ السموات والأرض {1}، وذكرنا الكلام في معنى غيب السموات والأرض في آخر آية من سورة هود [123].وقوله تعالى: ﴿وَمَا أَمْرُ السَّاعَةِ﴾: الوقت الذي تقوم فيه القيامة، سُمِّيت ساعة لأنها تفجأ الناس في ساعة، فيموت الخلق في صيحة {2}.وقوله تعالى: ﴿إِلَّا كَلَمْحِ الْبَصَرِ﴾ قال ابن الأعرابي: اللمح: النظر بسرعة {3}، يفال: لمحه ببصره لمحًا ولمحانًا {4}، أنشد الفراء:لمحان أقنى فوق طود يافع ... بعضَ العُدَاة دُجُنَّة وظلالا {5} قال ابن عباس في قوله: ﴿وَمَا أَمْرُ السَّاعَةِ﴾، يريد: القيامة، ﴿إِلَّا كَلَمْحِ الْبَصَرِ﴾، يريد: النظر.وقال قتادة: هو أن يقول: كن، فهو ﴿كَلَمْحِ الْبَصَرِ﴾ {6}.وقال السدي: هو كلمح العين من السرعة، ﴿أَوْ هُوَ أَقْرَبُ﴾: من ذلك إذا أردناه {7}، وشرح أبو إسحاق معنى هذا فقال: الساعةُ اسم لإمَاتَةِ الخَلق وإحْيائِهِم، أعلم الله تعالى أنّ البَعْثَ والإحْيَاءَ في قدرته ومشيئته، ﴿كَلَمْحِ الْبَصَرِ أَوْ هُوَ أَقْرَبُ﴾، ليس يريد أنَّ السَّاعةَ تأتي في أقربَ من لمح البصر، ولكنه يصف سرعةَ القدرةِ على الإتيان بها {1}، ومعنى (أو) في قوله: ﴿أَوْ هُوَ أَقْرَبُ﴾: أن أمرها يكون على إحدى منزلتين: إما لمح البصر، وإما أقرب، فأدخل (أو) لِشَكّ المخاطب؛ أي كونوا في تقدير سرعة كونها على هذا الشك، وهذا معنى قول قطرب: أراد أن يطويه عنّا {9}، وقيل: إنّ (أو) هاهنا بمنزلة بل {10}.وأنشدوا {11}:أوْ أنتِ في العَينِ أَمْلَحُ {12}"
  16,78,"قوله تعالى: ﴿وَاللهُ أَخْرَجَكُمْ مِنْ بُطُونِ أُمَّهَاتِكُمْ لَا تَعْلَمُونَ شَيْئًا﴾ أي أخرجكم غير عالمين بمعنى: أخرجكم جاهلين.وقوله تعالى: ﴿وَجَعَلَ لَكُمُ السَّمْعَ وَالْأَبْصَارَ وَالْأَفْئِدَةَ﴾ عطف {1} على قوله: ﴿أَخْرَجَكُمْ﴾، وجَعْلُ السمعِ كان قبل الإخراجِ ولم يكن بعده، وتأخيره في الذكر وتَقَدُّمُ الإخراجِ لا يدل على أن الجَعْلَ للسمع تأخر عن الإخراج؛ لأن الواو لا توجب الترتيب {2}، ذكرنا هذا في مواضع، والمعنى: خلق لكم الحواس التي بها تعلمون وتقفون على ما تجهلون، قال ابن عباس في هذه الآية: يريد لتسمعوا مواعظ الله وتُبْصِروا ما أنعم الله به عليكم منذ أخرجكم من بطون أمهاتكم إلى أن صرتم رجالًا، وتعقلوا عظمة الله {3}، ﴿وَالْأَفْئِدَةَ﴾ جمع الفؤاد؛ نحو غراب وأغربة {4}.قال الزجاج: ولم يجمع فؤاد على أكثر العدد؛ لم يُقَل فيه: فِئْدان، كما قيل في غُراب وغِرْبَان {5}."
  16,79,"قوله تعالى: ﴿أَلَمْ يَرَوْا إِلَى الطَّيْرِ مُسَخَّرَاتٍ﴾، أي: مذللات في جَوِّ السماء، وهو الهواء، قال الزجاج: ﴿جَوِّ السَّمَاءِ﴾: الهواءُ البعيدُ من الأرض {1}، وهذا حث على الاستدلال بها على مُسَخِّرٍ سَخَّرها، ومُدَبِّرٍ مَكَّنَها من التصرف في جو السماء، وهو الله تعالى.وقوله تعالى: ﴿مَا يُمْسِكُهُنَّ إِلَّا اللَّهُ﴾ يعني في حال القَبْض والبَسْط والاصطفاف، كقوله تعالى: ﴿أَوَلَمْ يَرَوْا إِلَى الطَّيْرِ فَوْقَهُمْ صَافَّاتٍ وَيَقْبِضْنَ﴾ الآية. [الملك: 19]."
  16,80,"قوله تعالى: ﴿وَاللَّهُ جَعَلَ لَكُمْ مِنْ بُيُوتِكُمْ سَكَنًا﴾ الآية. السَّكَن: المَسْكَن، أنشد الفراء {1}: جاء الشِّتاءُ ولَمَّا أتَّخِذْ كِنَنًا {2} ... يا وَيْحَ نَفْسِيَ {3} من حَفْر القراميص {4}والسَّكَنُ: ما سَكَنْت، وقال الزجاج: أي مَوْضِعًا تَسْكُنُون فيه {5}، قال مجاهد وغيره: يعني المساكن من الحجر والمدر {6}.وقال ابن عباس: يريد مساكن تستر عوراتكم وحُرَمَكُم، وذلك أن الله تعالى خلق الخشب والمدر والآلة التي بها يمكن تسقيف البيوت وبناؤها {7}.وقوله تعالى: ﴿وَجَعَلَ لَكُمْ مِنْ جُلُودِ الْأَنْعَامِ﴾ يعني الأنطاع {8} والأُدم، ﴿بُيُوتًا﴾ يعني القِبَاب والخِيَام والفَسَاطِيط {9}، ﴿تَسْتَخِفُّونَهَا يَوْمَ ظَعْنِكُمْ﴾، أي: يَخِفُّ عليكم حَمْلُها في أسفاركم {10}، قال ابن عباس: يريد إذا ظعنتم الربيع، وفيه قراءتان: تسكين العين {11} وتحريكها {12}، وهما لغتان؛ كالشعْر والشعَر، والنهْر والنهَر، قال الفراء: والعرب تفعل ذلك بما كان ثانيه إحدى الستة الأحرف {13}، وأنشد {14}:له نَعَلٌ لا تَطَّبِي الكَلْبَ ريحُها ... وإن وُضِعت بين المجالس شُمَّت {15} {16} قال أبو علي: لا يجوز أن يكون الظَّعْنُ مخففًا من الظَّعَنِ، كعَضْد من عَضُد، ألا ترى أن من خفف عَضْدًا لم يخفف؛ نحو: حَمَلٍ {17} وَرَسَنٍ {18}، قال الأزهري: والظَّعْنُ: سير البادية لنُجْعة أو حضور ماء أو طلب مَرْتَع أو تَحَوُّل من ماء إلى ماء ومن بلد إلى بلد، وقد ظَعَنوا يَظْعَنون، وقد يقال لكل شاخص لسفر: ظاعِن، وهو ضدّ الخافض {19}.وقوله تعالى: ﴿وَيَوْمَ إِقَامَتِكُمْ﴾ قال مقاتل: أي لا يثقل عليكم الحالتين {20}.وقوله تعالى: ﴿وَمِنْ أَصْوَافِهَا وَأَوْبَارِهَا وَأَشْعَارِهَا﴾ قال المفسرون وأهل اللغة: الأصواف للضأن، والأوبار للإبل، والأشعار للمعز {21}.وقوله تعالى: ﴿أَثَاثًا﴾ الأثاث: أنواع المتاع من متاع البيت؛ من الفُرُش والأكسية {22}، قال الفراء: ولا واحد له، كما أن المتاع لا واحد له، قال: ولو جمعت لقلت: أَثِثَّة في القليل وأُثُثٌ في الكثير {23}.وقال أبو زيد: واحدتها أَثَاثَةٌ {24}.قال ابن عباس في قوله: ﴿أَثَاثًا﴾ يريد طَنَافِس {25} وبُسطًا وثيابًا وكسوة {26}، قال الخليل: وأصله من قولهم: أثَّ النَّباتُ والشَّعر إذا كثر {27}وقوله تعالى: ﴿وَمَتَاعًا﴾ أي ما يمتعون به.وقوله تعالى: ﴿إِلَى حِينٍ﴾ قال عطاء عن ابن عباس: يريد إلى حين البلى {28}.وروي عنه: ﴿إِلَى حِينٍ﴾: الموت {29}، ومثله قال مجاهد، وأَبْهَم قتادة؛ فقال: إلى أجل {30}، وحكى الفراء القولين فقال: يقول: يكتفون بأصوافها إلى أن يموتوا، ويقال: إلى الحين بعد الحين {31}."
  16,81,"قوله تعالى: ﴿وَاللَّهُ جَعَلَ لَكُمْ مِمَّا خَلَقَ ظِلَالًا﴾ قال عطاء عن ابن عباس: يريد ظلال الغمام والسحاب {1}؛ كما قال: ﴿وَظَلَّلْنَا عَلَيْكُمُ الْغَمَامَ﴾ [البقرة: 57] يريد لتقيكم من حر الشمس ومن شدة البرد، وقال الكلبي: ﴿مِمَّا خَلَقَ﴾ يعني البيوت {1}، وقال قتادة: يعني الشجر {3}، واختاره الزجاج. فقال: أي جعل لكم من الشجر ما تَسْتَظِلُّون به {4} {5}.وقوله: ﴿وَجَعَلَ لَكُمْ مِنَ الْجِبَالِ أَكْنَانًا﴾ قالوا: يعني الغيران والأسْرَاب {6}، وواحد الأَكْنَان كِنٌّ، على قياس حِمْل وأَحْمَال {7}، والكِنُّ: كل شيء وقى شيئًا، ويقال: اسْتَكَنَّ واكْتَنَّ، إذا صار في كِنّ {8} {9} ﴿وَجَعَلَ لَكُمْ سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾ السرابيل: القُمُص، واحدها سربال {10}، قال الفراء: سَرْبَلْتُ الرجلَ إذا لَبَّسْتَه سَرْبَلَةً وسِرْبَالًا {11}، وأنشد:عَمّى أبو مالك بالمجدِ سَرْبَلَني ... ودَنَّس العبد عبد القيس سربالي {12}قال أبو إسحاق: كلُ ما لَبِسْتَه فهو سربالٌ؛ من قميص أو دِرْع أو جَوْشَنٍ أو غيره {13}، قال ابن عباس وقتادة: هي القُمُص من الكَتّان، والقطن والصوف {14}، قال الفراء: ولم يقل: والبرد، وهي تقي الحرّ والبرد، فترك؛ لأن معناه معلوم {15}، قال الزجاج: ولم يقل: وتقيكم البردَ؛ لأن ما وَقَى من الحرّ وَقَى من البرد {16}، فعندهما أنه اكتفى بذكر أحدهما عن الآخر لدلالة المذكور على الآخر، وقال عطاء الخرساني: الذين خوطبوا بهذا أهل حَرّ في بلادهم فحاجتهم إلى ما يقي الحرّ أشد، لذلك لم يذكر البرد؛ لأن القوم خُوطبوا على قدر معرفتهم، كما قال: ﴿وَمِنْ أَصْوَافِهَا وَأَوْبَارِهَا وَأَشْعَارِهَا﴾: وما جعل من غير ذلك أعظم، ولكنهم كانوا أصحابَ وَبَر وشَعَر، وكذلك قوله: ﴿وَيُنَزِّلُ مِنَ السَّمَاءِ مِنْ جِبَالٍ فِيهَا مِنْ بَرَدٍ﴾ [النور: 43] يُعَجِّبُهم بذلك، وما أنزل من الثلج أعظم ولكنهم كانوا لا يعرفونه {17}، قال المبرد: والقرآن قد أحاط بمن يخاطب وبمن يكون بعده، وأحاط بالغائب كما أحاط بالحاضر، ولكن العرب من شأنها إذا كان الشيئان مجازهما واحدًا في ضر أو نفع فذكروا أحدهما علم أن الآخر مثله، فلما ذكر الحرَّ صار كأنه ذكر البرد أيضًا، لما يعلم أنها لا تقي شيئًا دون شيء {18}.وقوله تعالى: ﴿وَسَرَابِيلَ تَقِيكُمْ بَأْسَكُمْ﴾ قال المفسرون: يعني دروع الحديد {19}، ومعنى البأس: الشدة، ويريد هاهنا شدة الطعن والضرب والرمي {20}.وقوله تعالى: ﴿كَذَلِكَ﴾ أي مِثْل ما جعل هذه الأشياء، وخلقها لكم وأنعم بها عليكم، ﴿يُتِمُّ نِعْمَتَهُ عَلَيْكُمْ﴾ يريد: نعمة الدنيا؛ لأن {21} الخطاب لأهل مكة يدل على هذا.قوله تعالى: ﴿لَعَلَّكُمْ تُسْلِمُونَ﴾ قال ابن عباس: لعلكم يا أهل مكة تُخْلِصون لله الربوبية وتعلمون أنه لا يقدر على هذا أحدٌ غيره {22}، فتوحدوه وتصدقوا أنبياءه، ثم قال بعد أن بَيَّنَ لهم الآيات:"
  16,82,"﴿فَإِنْ تَوَلَّوْا فَإِنَّمَا عَلَيْكَ الْبَلَاغُ الْمُبِينُ﴾ أي عليك أن تُبلِّغَ الرسالةَ والآياتِ الدالةَ على التوحيد وصدقك، ولا يَلْزَمك تقصيرٌ مِنْ أجل تَوَلِّيهم، وهذا تسلية للنبي -ﷺ- عما يلحقه عند توليهم عنه."
  16,83,"قوله تعالى: ﴿يَعْرِفُونَ نِعْمَتَ اللَّهِ ثُمَّ يُنْكِرُونَهَا﴾ قال السدي: يعني محمدًا -ﷺ- {1}، وهذا القول اختيار أبي إسحاق؟ قال: يعرفون أن أمر النبي -ﷺ- حقٌّ ثم يُنكرون ذلك {2}، وقال مجاهد: يعني ما عَدَّدَ من النِّعَم في هذه السورة، يعرفون أنها كلَّها نِعَمٌ عليهم، ولكن ينكرون أنها من الله تعالى، يقولون: هذه النعم كانت لآبائنا فورثناها منهم {3}، وقال الكلبي: أقروا بأنها كلها من الله، وقالوا: لكنها بشفاعة آلهتنا {4}، [وهذا] {5} القول اختيار الفراء؛ قال: ﴿يَعْرِفُونَ نِعْمَتَ اللَّهِ﴾ يعني الكفار، إذا قيل لهم مَنْ رزقكم؟ قالوا: الله، ثم يقولون: بشفاعة آلهتنا فيشركون، فذلك إنكارهم نعمته {6}، ونحو هذا روى عطاء عن ابن عباس، قال: يُقِرُّون أنه لا يفعل هذا أحدٌ غيرُه، وهو المستحق للعبادة؛ لأنه المنعم عليهم دون غيره {7}.وقوله تعالى: ﴿وَأَكْثَرُهُمُ الْكَافِرُونَ﴾ قال أصحاب التأويل: إنما قال وأكثرهم؛ لأن فيهم من لم تقم عليه الحجة ممن [لم] {8} يبلغ حَدَّ التكليف؛ ومنهم من هو ناقص العقل مأووف {9} فأراد بالأكثر: البالغين الأصحاء الذين هم المقصودون بالخطاب وإقامة الحجة عليهم {10}، وقال الحسن: المعنى: وجميعهم الكافرون {11}، وعلى هذا ذكر الأكثر والمراد الجميع؛ لأن عُظْمَ الشيءِ يقوم مقام جميعه، فَذِكر الأكثرِ كذِكْرِ الجميع، وهذا كقوله: ﴿الْحَمْدُ لِلَّهِ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ﴾ [النحل: 75] وذكرنا هناك وجهين آخرين، وهذه الآية تدل على أن المعاند كافرٌ، وإن عرف بقلبه إذا لم يُقِرّ بلسانه وأنكر في الظاهر."
  16,84,"قوله تعالى: ﴿وَيَوْمَ نَبْعَثُ مِنْ كُلِّ أُمَّةٍ شَهِيدًا﴾، أي: وذَكِّرهم يوم نبعث أو وأَنْذرهم يوم نبعث، قال ابن عباس: يريد يوم القيامة {1}، ﴿مِنْ كُلِّ أُمَّةٍ شَهِيدًا﴾ يريد الأنبياء يشهدون على الأمم بما فعلوا من التصديق والتكذيب.وقوله تعالى: ﴿ثُمَّ لَا يُؤْذَنُ لِلَّذِينَ كَفَرُوا﴾ قال الكلبي: لا يؤذن لهم في الكلام والاعتذار {2}؛ كقوله: ﴿وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾ [المرسلات: 36].وقوله تعالى: ﴿وَلَا هُمْ يُسْتَعْتَبُونَ﴾ استعتَبَ فلان إذا طلب أن يُعْتَب، أي: يُرْضَى {3}، واستعتبت فلانًا إذا طلبت منه أن يرجع إلى رضا صاحبه {4}، فمعنى قوله: ﴿وَلَا هُمْ يُسْتَعْتَبُونَ﴾ أي لا يُطلب منهم أن {5} يرجعوا إلى ما يُرضي اللهَ؛ لأن الآخرة ليست بدار تكليف، كما قال ابن عباس في هذه الآية، قال: يريد انقطع العتاب وانقطعت المعذرة وحَلّ بهم الخزي، تلخيص معنى الآية: أنهم لا يُمَكَّنُونَ من عذر فيتكَلَّمون به، ولا يُكَلَّمُون أيضًا في الرجوع في العُتْبَى، وأصل هذا الحرف من العتب وهو الموجدة، يقال: عتب عليه إذا وجد عليه، وأعتبه إذا زال عنه عتبُه؛ بأن ترك ما كان يعتب عليه من أجله، واستعتبه إذا طلب منه الإعتاب {6}."
  16,85,"قوله تعالى: ﴿وَإِذَا رَأَى الَّذِينَ ظَلَمُوا﴾ قال ابن عباس: يريد أشركوا {1}، ﴿الْعَذَابَ﴾ يريد النار، ﴿فَلَا يُخَفَّفُ عَنْهُمْ﴾، أي: العذاب، ﴿وَلَا هُمْ يُنْظَرُونَ﴾، أي: لا يؤخرون ولا يمهلون؛ لأن التوبة هناك غير مرجوة؛ لانقضاء الأمد المضروب لقبول التوبة ودخول وقت العذاب، وهذه الآية تأكيد لما قبلها؛ يريد أنهم يعجل لهم العقوبة في الآخرة من غير إنصات {2} لعذر منهم أو عتاب معهم."
  16,86,"قوله تعالى: ﴿وَإِذَا رَأَى الَّذِينَ أَشْرَكُوا شُرَكَاءَهُمْ﴾ قال ابن عباس: يريد الذين اتخذوهم {1} من دون الله آلهة {2}، وذلك أن اللهَ يبعثُ كلَّ مَنْ كان يَعْبُدون من دون الله، فيتبعوهم حتى يوردوهم النار، وَوُصِفُوا بأنهم شركاؤهم: لأنهم جعلوا لهم نصيبًا في أموالهم، ولأنهم جعلوهم شركاء في العبادة {3}، ﴿قَالُوا رَبَّنَا هَؤُلَاءِ شُرَكَاؤُنَا الَّذِينَ كُنَّا نَدْعُو مِنْ دُونِكَ﴾، أي: كنا نعبدهم من دونك، ﴿فَأَلْقَوْا إِلَيْهِمُ الْقَوْلَ﴾ قال الكلبي: أجابوهم {4}، وقال مجاهد: حدثوهم {5}، وقال الفراء: رَدَّت عليهم قولهم {6}: ﴿إِنَّكُمْ لَكَاذِبُونَ﴾ {7}، وذكر المفسرون في تكذيب الأصنام إيّاهم وجوهًا؛ أحدها: أنها كذبتهم في استحقاق العبادة، والمعنى: ﴿إِنَّكُمْ لَكَاذِبُونَ﴾: في أَنَّا نستحق العبادة {8}، الثاني: ﴿إِنَّكُمْ لَكَاذِبُونَ﴾: في أَنَّا دعوناكم إلى العبادة، وهذا قول الفراء {9}، وقيل: ﴿إِنَّكُمْ لَكَاذِبُونَ﴾: في تسميتنا آلهة وأربابًا {10}، وكل هذا تكذيب من الآلهة {11} للكفار بما لم يُخْبِر به عنهم؛ لأنه ليس في الآية أن الكفار ادعوا أنها دعتهم إلى عبادتها، ولا أنها كانت تستحق العبادة، ولا أنهم سموها آلهة، وإن كانوا قد فعلوا ذلك، ولكن لم يُخبِر عنهم في هذه الآية بهذه الأشياء حتى ينصرف التكذيب إلى ذلك، والمفسرون قالوا هذا على الاحتمال، ولم أر لواحد من أئمة التفسير قولًا منسوبًا إليه مما حكيت غير الفراء، والذي يوافق الظاهر أن يقال: إن الشركاء كانت جمادًا مواتًا ما كانت تعرف عبادة عابديها، فقالت: ﴿إِنَّكُمْ لَكَاذِبُونَ﴾: في عبادتكم إيَّانَا، ما كنا نعرف ذلك ولا علم لنا بعبادتكم، فظهر عند ذلك فضيحة الكفار، حيث عبدوا من لم يشعر بالعبادة، يدل على هذا قوله: ﴿كَلَّا سَيَكْفُرُونَ بِعِبَادَتِهِمْ﴾ [مريم: 82]، والله أعلم."
  16,87,"قوله تعالى: ﴿وَأَلْقَوْا إِلَى اللَّهِ يَوْمَئِذٍ السَّلَمَ﴾ قال ابن عباس: يريد استسلموا وأقروا لله بالربوبية {1}، قال الكلبي: استسلم العابد والمعبود {2}، وقال قتادة: يقول: ذَلُّوا واستسلموا يومئذ لحكم الله {3}، وذكرنا معنى إلقاء السَّلَم عند قوله: ﴿وَلَا تَقُولُوا لِمَنْ أَلْقَى إِلَيْكُمُ السَّلَامَ﴾ [النساء: 94].وقوله تعالى: ﴿وَضَلَّ عَنْهُمْ مَا كَانُوا يَفْتَرُونَ﴾ قال ابن عباس: يريد ذهب ما زَيَّنَ لهم الشيطان أن لله شريكًا أو ولدًا وصاحبة {4}، وقال غيره: بطل ما كانوا يُؤَمِّلُون ويكذبون؛ من أن آلهتم تشفع لهم {5}."
  16,88,"قوله تعالى: ﴿الَّذِينَ كَفَرُوا وَصَدُّوا عَنْ سَبِيلِ اللَّهِ﴾ قال ابن عباس: يريد عن طاعة الله {1}، ﴿زِدْنَاهُمْ عَذَابًا فَوْقَ الْعَذَابِ﴾ قال ابن مسعود: عقارب لها أنيابٌ أمثالُ النخلِ الطِّوالِ {2}، وروي عنه: أفاعي {3}، وقال السدي. إن أهل النار إذا جزعوا من حَرّها استغاثوا، بضحضاحِ ماءٍ في النار، فإذا أتوه بلغتهم عقارب كأنها البغال، وأفاعي كأنها البَخَاتِي {4}، فضربتهم فذلك الزيادة {5}، وقال أبو المنهال {6}: إنهم يستغيثون بالنار فرارًا من تلك الأفاعي والعقارب وهربًا {7}."
  16,89,"قوله تعالى: ﴿وَيَوْمَ نَبْعَثُ فِي كُلِّ أُمَّةٍ شَهِيدًا﴾ قال ابن عباس: يريد الأنبياء {1}، قال المفسرون: كل نبي شاهد على أمته، وهو أعدل شاهد عليها {2}، ووجه انتصاب (ويوم) ذكرنا عند قوله: ﴿وَيَوْمَ نَبْعَثُ فِي كُلِّ أُمَّةٍ شَهِيدًا﴾ [النحل: 84] و ﴿فِي كُلِّ أُمَّةٍ﴾ هاهنا كقوله: ﴿وَلَقَدْ بَعَثْنَا فِي كُلِّ أُمَّةٍ رَسُولًا﴾ [النحل: 36] فيجوز أن يكون من صلة الشهيد؛ كأنه قيل: ويوم نبعث شهيدًا في كل أمة.وقوله تعالى: ﴿عَلَيْهِمْ مِنْ أَنْفُسِهِمْ﴾: الأنبياء شهداء {3} على أممهم بما فعلوا، وهم من أنفسهم؛ لأن كلَّ نبي بُعث من قومه إليهم، ﴿وَجِئْنَا بِكَ شَهِيدًا عَلَى هَؤُلَاءِ﴾ قال ابن عباس: يريد على قومك {4}، وتم الكلام هاهنا، ثم قال: ﴿وَنَزَّلْنَا عَلَيْكَ الْكِتَابَ تِبْيَانًا لِكُلِّ شَيْءٍ﴾ قال مجاهد: يعني لِمَا أَمَر به وما نهى عنه {5}. وقال أهل المعاني: يعني لكل شيء من أمور الدين بالنص عليه أو الإحالة على ما يوجب العلم به من بيان النبيّ -ﷺ- أو إجماع، فهو الأصل والمفتاح لعلوم {6} الدين {7}، أخبرني سعيد بن محمد بقراءتي عليه عن ابن مُقْسِم عن الزجاج، قال: تبيان اسمٌ في معنى البيان، ومِثلُ التِّبْيَان {8} [التِّلْقَاء] {9}، وأخبرني أبو الحسين الفسوي {10} فيما قرأته عليه عن حمد بن محمد عن أبي عمر {11} عن ثعلب عن الكوفيين، والمبرد عن البصريين، قالا: لم يأت من المصادر على تِفْعَال إلا حرفان تبيان وتلقاء، فإذا تركت هذين استوى لك القياس، فقلتَ في كل مصدر: تَفْعَال بفتح التاء مثل: تَسْيَار وتَهْمَام، وقلت في كل اسم: تِفْعَال بكسرها، مثل: تِقْصَار وتِمْثَال {12}، وانتصاب قوله: ﴿تِبْيَانًا﴾ على أنه مفعول له؛ أي للبيان."
  16,90,"وقوله تعالى: ﴿إِنَّ اللَّهَ يَأْمُرُ بِالْعَدْلِ وَالْإِحْسَانِ﴾ قال ابن عباس في رواية الوالبي: العدل: شهادة أن لا إله إلا الله، والإحسان: أداء الفرائض {1}، وقال في رواية عطاء: العدل: خلع الأنداد، والإحسان: تعبد الله كأنك تراه {2}، وأن تحب للناس ما تحب لنفسك. إن كان مؤمنًا أحببت أن يزداد إيمانًا، وإن كان كافرًا أحببت أن يكون أخاك في الإسلام {3}.وقال في رواية باذان {4}: العدل: التوحيد، والإحسان: الإخلاص فيه {5}، وقال آخرون: يعني بالعدل: في الأفعال، والإحسان: في الأقوال {6}، ولا يفعل إلا ما هو عدل ولا يقول إلا ما هو حسن {7}.وقوله تعالى: ﴿وَإِيتَاءِ ذِي الْقُرْبَى﴾ قال عطاء عن ابن عباس: يريد صلة القرابة {8} من فضل ما رزقك الله، فإن لم يكن عندك فضل فدعاء {9}، وروى أبو سلمة {10} عن أبيه أن رسول الله -ﷺ- قال: ""إنّ أعْجَلَ الطاعةِ ثَوابًا صِلةُ الرحم، [حتى] {11} إن أهل البيت ليكونون فُجَّارًا فَتُنْمَى أموالُهُم ويَكثُرُ عددُهم إذا وصلُوا أرحامَهُم"" {12}.وقوله تعالى: ﴿وَيَنْهَى عَنِ الْفَحْشَاءِ﴾ قال في رواية علي: يقول: الزنى {13}، وقال في رواية عطاء: يريد البخل عن حقوق الله، وجميع الذنب صغيره وكبيره {14}، وقال آخرون: الفحشاء: ما قبح من قول أو فعل {15}.(وقوله تعالى ﴿وَالْمُنْكَرِ﴾ قال في الروايتين: الشرك والكفر بالله {16}، وقال غيره: المنكر ما لا يعرف في شريعة ولا سنة {17}) {18}.وقوله تعالى: ﴿وَالْبَغْيِ﴾ قال علي عن ابن عباس: الكِبْر والظلم {19}، وقال عطاء عنه: أن تبغي على أخيك {20}.وقال أهل المعاني في هذه الآية: إنما جمعت الأوصاف الثلاثة للبيان عن تفصيل المنهي عنه؛ فالفحشاء قد تكون بما يفعله الإنسان مما لا يظهر أمره وهو مما يعظم قبحه، والمنكر: ما يظهر للناس مما يجب إنكاره، والبغي: ما يتطاول به من الظلم لغيره، ولا يكون إلا من الفاعل على غيره، والظلم قد يكون ظلم الفاعل لنفسه {21}، وفي حديث أبي سلمة عن أبيه: ""وإن أعجلَ المعصيةِ عقابًا: البغي واليمين الفاجرة؛ تُذهبُ المالَ وتَتركُ البيتَ بَلَاقِع"" {22}.وروى مجاهد عن ابن عباس قال: لو {23} أن جبلًا بغى على جبل لدُكَّ الباغي منهما {24}، وقال خالد الربعي {25}: إن مما يعجل عقوبته ولا يؤخر الأمانة تُخَان، والإحسانُ يُكْفَر، والرحم تُقْطَع، والبغي على الناس {26}.وقوله تعالى: ﴿يَعِظُكُمْ لَعَلَّكُمْ تَذَكَّرُونَ﴾ قال ابن عباس: يريد ينهاكم عن هذا كله ويأمركم أن تتحاضوا على ما فيه لله رضا؛ لكي تتعظوا {27}، قال ابن مسعود: إن أجمع آية في القرآن لخير وشر هذه الآية {28}، وقال أهل المعاني: ذكر الله تعالى في الآية الأولى؛ فقال: ﴿وَنَزَّلْنَا عَلَيْكَ الْكِتَابَ تِبْيَانًا لِكُلِّ شَيْءٍ﴾، ثم بين في هذه الآية المأمور به والمنهي عنه مجملًا، فما من شيء يُحتاجُ إليه في أمر دينهم مما يجب أن يؤتى أو يترك إلا وقد اشتملت عليه هذه الآية {29}."
  16,91,"قوله تعالى: ﴿وَأَوْفُوا بِعَهْدِ اللَّهِ إِذَا عَاهَدْتُمْ﴾ قال المفسرون وأهل العلم: العهد الذي يجب الوفاء به فهو الذي يحسن فعله، فإذا عاهد يجب الوفاء به {1}، قال ابن عباس في هذه الآية: والوعد من العهد {2}، وقال ميمون بن مِهْران: من عاهدته فَفِ له بعهده مسلمًا كان أو كافرًا؛ فإنما العهد لله {3}.وقوله تعالى: ﴿وَلَا تَنْقُضُوا الْأَيْمَانَ بَعْدَ تَوْكِيدِهَا﴾ قال مجاهد: يعني تغليظ الحلف {4}، وقال ابن عباس بعد تشديدها {5}، وإنما قال: بعد توكيدها؛ فرقًا بين الأيمان المؤكدة بالعزم والعقد، وبين لغو اليمين {6}.قال أبو إسحاق: يقال: وَكَّدتُ وأَكَّدْتُ لغتان جيدتان، والأصل الواوُ والهمزة بدل منها {7}.وقوله تعالى: ﴿وَقَدْ جَعَلْتُمُ اللَّهَ عَلَيْكُمْ كَفِيلًا﴾ هذه واو الحال؛ أي لا تنقضوها، وقد جعلتم الله كفيلًا عليكم بالوفاء، وذلك أن من حلف بالله تعالى فكأنه أكفل الله تعالى بالوفاء بما حلف عليه {8}، ﴿إِنَّ اللَّهَ يَعْلَمُ مَا تَفْعَلُونَ﴾ قال ابن عباس: يريد لا يخفى عليه شيء {9}."
  16,92,"قوله تعالى: ﴿وَلَا تَكُونُوا كَالَّتِي نَقَضَتْ غَزْلَهَا﴾ الآية. قال ابن عباس: هي امرأة من قريش كان لها وسوسة، وكانت تغزل عند الحجر يومها ثم تغدو فتنقضه {1}، وقال الكلبي: كان يقال لها: رايطة، وقيل: رَيْطة {2}، وتُلَقَّب جعر {3}، وكانت حمقاء تغزل الغزل هي وجواريها، فإذا غزلت وأبرمت أمرتهنَّ فنقضنَ ما غزلن {4}.وقوله تعالى: ﴿مِنْ بَعْدِ قُوَّةٍ﴾ قال مجاهد: من بعد إمرارٍ {5} وفتلٍ {6}، يعني من بعد قوة للغزل؛ بإمرارها {7} وفَتْلِها.وقوله تعالى: ﴿أَنْكَاثًا﴾ قال: واحدها نِكْث، وهو الغَزْل من الصوف والشَّعَر؛ يُبْرَم ويُنْسَج، فإذا أَخْلَقَت النَّسِيْجَة، قُطِّعَتْ ونُكِثَتْ خُيوطُها المُبْرمة وخُلِطَت بالصوفِ ومِيشتْ {8}، ثم غُزِل ثانية، والنَّكْثُ المصدر، ومن هذا قيل: نَكَث فلانٌ عهدَه إذا نقضه بعد إحكامه؛ كما يُنْكَث خيطُ الصوف بعد إبرامه {9}، وأنشد أبو عبيدة {10} للمُسَيَّب بن عَلَس {11}:عن غَيرِ مَقْلِيَةٍ وأنَّ حِبَالَها ... لَيْسَتْ بأنكاث ولا أقطاع {12} قال أبو إسحاق: ﴿أَنْكَاثًا﴾ منصوب؛ لأنه بمعنى المصدر؛ لأن معنى: نكثت نَقَضْتُ، ومعنى نقضت: نكثت {13}، وهذا غلط منه لأن الأنكاث جمع نكث، وهو {14} اسم لا مصدر، فكيف يكون الأنكاث بمعنى المصدر، ولو كان {15} نكثًا لصح ما قال، ولكن أنكاثًا مفعول ثانٍ، كما تقول: كسره أقطاعًا، وفرقه أجزاءً على معنى جعله أقطاعًا وأجزاءً {16}، وهاهنا تم الكلام، والآية متصلة بما قبلها، والمعنى: ﴿وَأَوْفُوا بِعَهْدِ اللَّهِ إِذَا عَاهَدْتُمْ وَلَا تَنْقُضُوا الْأَيْمَانَ بَعْدَ تَوْكِيدِهَا﴾ فتكونوا إن فعلتم كامرأة غزلت غزلًا وقَوَّتْ مِرَّتَهُ فلما اسْتَحْكَم نقضته فجعلته أنكاثًا، وهذا كلام [ابن] {17} قتيبة {18}، ثم قال: ﴿تَتَّخِذُونَ أَيْمَانَكُمْ دَخَلًا بَيْنَكُمْ﴾ الدَّخَلُ والدَّغَلُ: الغِش والخيانة {19}، قال الليث: ويخفف الدَّخل ويُثَقَّل {20}، قال الفراء: يعني دَغَلًا وخديعة {21}.(وقال الزجاج: أي غِشًّا وغِلاًّ، وكل ما دخله عيب قيل: هو مَدْخُول، وفيه دَخَل، قال: و ﴿دَخَلًا﴾ منصوب) {22}؛ لأنه مفعول له، والمعنى: تتخذون أيمانكم للغش والدَّغَل {23}، قال غيره: الدَّخَل: ما أُدْخِل في الشيء على فساد {24}.وقوله تعالى: ﴿أَنْ تَكُونَ أُمَّةٌ هِيَ أَرْبَى مِنْ أُمَّةٍ﴾، أَرْبَى: أي أكثر، من رَبَا الشيءُ يَرْبُو إذا كثر {25}، قال مجاهد: كانوا يحالفون الحلفاء فيجدون أكثر منهم وأعزّ، فينقضون حِلْف هؤلاء ويحالفون هؤلاء الذين هم أعزّ، فنُهوا عن ذلك {26}، والمعنى: بأن يكون أو لأن يكون، فموضع (أن) نصب بإسقاط الخافض، على قول من نصب، (ومن أبقى حُكْمَ الخافض) {27} قال موضعه خفض، قال ابن قتيبة: أي لأن يكون قوم أغنى من قوم، وقوم أعلى من قوم، تريدون أن تقْتَطِعوا بأيمانكم حقوقًا لهؤلاء، (فتجعلوها لهؤلاء) {28}، وقال الفراء: معناه لا تغدروا بقوم لقلّتهم وكثرتكم أو قِلّتكم وكثرتهم، وقد غَرَّرتموهم بالأيمان فسكَنُوا إليها {21}.وبيان هذه الجملة: أن القوم إذا عاهدوا قومًا أكثر من الذين عاهدوا فهم أمة أربى من أمة، لا يجوز لهم أن يغدروا، وكذلك إن كان على القلب من هذا {30} وعاهدوهم؛ دخلوا في حلفهم خوفًا منهم لم يجز لهم الغدر، وتلخيص التأويل: النهي عن أن يحلف على ما هو منطوٍ على خلافه وأن يغر غيره بيمينه.وقوله تعالى: ﴿تَتَّخِذُونَ أَيْمَانَكُمْ﴾ ظاهره إخبار ومعناه النهي، والتقدير: لا تكونوا كتلك المرأة؛ متخذين أيمانكم للغش، بأن يكون قوم أكثر من قوم، قال الفراء: وموضع ﴿أَرْبَى﴾ نصب، وإن شئت رفعت؛ كما تقول: أظن رجلًا يكون هو أفضل منك، و (أفضل) النصبُ على العِمَاد {31}، والرفع على أن تجعل (هو) اسمًا {21}، قال الزجاج: موضع ﴿أَرْبَى﴾ رفعٌ ولا يجوز أن تكون نصبًا وهي تكون عمادًا؛ لأن العماد والفصل لا يكون مع النكرات وإنما يكون مع المعارف، كقوله: ﴿تَجِدُوهُ عِنْدَ اللَّهِ هُوَ خَيْرًا﴾ [المزمل: 20]، والهاء في تجدوه معرفة، و ﴿أُمَّةٌ﴾ هاهنا نكرة {33}.وقوله تعالى: ﴿إِنَّمَا يَبْلُوكُمُ اللَّهُ بِهِ﴾ أي بما يأمركم وينهاكم، وقد تَقَدَّم ذكر الأمر والنهي، والكناية راجعة إلى الأمر، أي يختبركم الله بالأمر بالوفاء، وقال بعضهم: الكناية راجعة إلى التكليف {34}، وأمره ونهيه بمعنى التكليف، ومعنى ﴿يَبْلُوكُمُ﴾: يعاملكم معاملة المختبر، وذكرنا هذا في قوله: ﴿وَلَنَبْلُوَنَّكُمْ﴾ [البقرة: 155].وقوله تعالى: ﴿وَلَيُبَيِّنَنَّ لَكُمْ يَوْمَ الْقِيَامَةِ مَا كُنْتُمْ فِيهِ تَخْتَلِفُونَ﴾ أي في الدنيا، قال المفسرون: أي من شأن البعث والقرآن {35}، وقال أهل المعاني: هو عام فيما يقع الاختلاف فيه من الأصول والفروع {36}."
  16,93,"قوله تعالى: ﴿وَلَوْ شَاءَ اللَّهُ لَجَعَلَكُمْ أُمَّةً وَاحِدَةً﴾ قال ابن عباس: يريد على ملة وعلى دين واحد {1}، ﴿وَلَكِنْ يُضِلُّ مَنْ يَشَاءُ وَيَهْدِي مَنْ يَشَاءُ﴾ قال: يريد الضلالة بعينها والهدى بعينه، ﴿وَلَتُسْأَلُنَّ عَمَّا كُنْتُمْ تَعْمَلُونَ﴾ قال: يريد في الدنيا، وهذه الآية صريحة {2} في تكذيب القدرية؛ حيث أضاف الضلالة والهداية إلى نفسه، وجعلها لمن شاء من خلقه بالمشيئة الأزلية التي لا يجوز عليها الحدوث، ثم أخبر أنهم يسألون عن أعمالهم، فبان أن الأمر على ما أخبر الله تعالى في قوله: ﴿لَا يُسْأَلُ عَمَّا يَفْعَلُ وَهُمْ يُسْأَلُونَ﴾ [الأنبياء: 23] وقد قال نوف البكالي: قال [عُزير] {3}: يارب خلق خلقًا فتضل من تشاء وتهدي من تشاء، فقيل: يا عُزير أعرض عن هذا، فأعاد ذلك، فقيل: أعرض عن هذا، فأعاد فقيل: أعرض عن هذا وإلا مُحِيْتَ عن النُّبُوة، أنا لا أسئل عما أفعل وهم يسألون {4}."
  16,94,"قوله تعالى: ﴿لَا تَتَّخِذُوا أَيْمَانَكُمْ دَخَلًا بَيْنَكُمْ﴾ الآية. استأنف نهيًا عن أيمان الخديعة والمكر، توكيدًا للمنع عنها، ولِمَا ذكر من الوعيد بعدها؛ وهو قوله: ﴿فَتَزِلَّ قَدَمٌ بَعْدَ ثُبُوتِهَا﴾ قال ابن عباس: يريد تزل عن الإيمان بعد المعرفة بالله، قال أبو عبيدة: وزليل القدم مثل لكل مبتلى بعد عافية أو ساقط في وَرْطَة بعد سلامة {1}، وأنشد ابن جرير على هذا:سَيَمْنَعُ منكَ السَّبْقُ إن كُنْتَ سابِقًا ... وتُقْتَلُ إن زَلَّتْ بِكَ القدمان {2}لم يُرد حقيقة زلَّة القدم، ولكن أراد إن تأخر فرسُك عن غاية السباق وقعت في ورطة التأخر، وهذا البيت في قصة رهان داحس {3}، قال المفسرون: وهذا في نهي الذين بايعوا رسول الله -ﷺ- عن نقض عهده {4}؛ لأن هذا الوعيد إنما يُستَحقُّ في نقض معاهدة رسول الله -ﷺ- لا {5} في نقض عهد قبيلة، (ولكن من عاهد رسول الله -ﷺ-) {6} على الإسلام ونصرة الدين ثم نقض العهد سقط عن درجة الإيمان، يدل على هذا قوله: ﴿وَتَذُوقُوا السُّوءَ﴾ أي العذاب، ﴿بِمَا صَدَدْتُمْ﴾ أي بصدكم عن سبيل الله، (يريد أنهم إذا نقضوا العهد مع النبي -ﷺ-) {7} صدوا الناس عنه واستحقوا العذاب، فنهوا عن ذلك بذكر الوعيد عليه.وقوله تعالى: ﴿وَلَكُمْ عَذَابٌ عَظِيمٌ﴾ قال ابن عباس: يريد في الآخرة {8}، وهذا قطعٌ بإيجاب العذاب إن فَعلوا ما نُهوا عنه، كأنه قيل: ﴿وَلَكُمْ عَذَابٌ عَظِيمٌ﴾ إن اتخذتم أيمانكم دخلًا، ودلَّ ما تَقَدَّم من النهي على هذا المحذوف، ثم زاد توكيدًا، فقال:"
  16,95,"﴿وَلَا تَشْتَرُوا بِعَهْدِ اللَّهِ ثَمَنًا قَلِيلًا﴾ قال ابن عباس: يريد عرض الدنيا وإن كان كثيرًا {1}؛ لأن ما يذهب ويبلى قليل، وذكرنا ما في هذا عند قوله: ﴿إِنَّ الَّذِينَ يَشْتَرُونَ بِعَهْدِ اللَّهِ﴾ الآية. [آل عمران: 77] قال المفسرون: يقول: لا تنقضوا عهودكم، تطلبون بنقضها عِوضًا من الدنيا {2} ﴿إِنَّمَا عِنْدَ اللَّهِ﴾: من الثواب على الوفاء ﴿خَيْرٌ لَكُمْ إِنْ كُنْتُمْ تَعْلَمُونَ﴾: ذلك، ثم بين أن ما عنده خير بقوله:"
  16,96,"﴿مَا عِنْدَكُمْ يَنْفَدُ﴾، أي: يفنى وينقطع، يعني الدنيا، ﴿وَمَا عِنْدَ اللَّهِ﴾، أي: من الثواب والكرامة، ﴿بَاقٍ﴾: دائم لا ينقطع، قال ابن عباس: يريد لا ينفد؛ كلما أخذت منه وأكلت منه صار مكانه مثلُه، فمعنى [لا] {1} يفنى هذا، وهذا ردّ على من قال: إن نعيم أهل الجنة ينقطع، ﴿وَلَنَجْزِيَنَّ الَّذِينَ صَبَرُوا﴾ قال ابن عباس: يريد على دينهم وعمّا نهاهم الله {2}، ﴿بِأَحْسَنِ مَا كَانُوا يَعْمَلُونَ﴾ يعني الطاعات، وجعلها أحسن أعمالهم؛ لأن ما عداها من الحَسَن مباح، فما كان مباحًا من العمل فهو حسن ولا يستحق عليه جزاء {3}، وما كان طاعة لله تعالى فهو الأحسن الذي وعد الله عليه الجزاء، ومن جزاه الله بأحسن عمله غفر له ذنوبه، وهذه الآيات زجر عن الأيمان الكاذبة فيما كانت، وحَثٌّ على الوفاء بالعهود والأيمان، وذكر الكلبي: أن هذه الآيات نزلت في امرئ القيس بن عابس الكندي {4}، وفي خصمه عيدان ابن أشوع {5}؛ كان يَدَّعي عليه أرضًا اقتطعها له، وأراد امرؤ {6} القيس أن يحلف، فلما سمع هذه الآيات بكى وأقَرَّ له بحقه {7}."
  16,97,"قوله تعالى: ﴿فَلَنُحْيِيَنَّهُ حَيَاةً طَيِّبَةً﴾ قال ابن عباس في رواية أبي الربيع {1} وأبي مالك: هي الرزق الطيب الحلال {2}، ونحو هذا روى الكلبي عن أبي صالح عنه قال: لنجعلن رزقه حلالًا {3}.وقال في رواية عطاء: يريد عبادة الله وأكل الحلال {4}.وقال في رواية عكرمة: هي القناعة {5}، وهو قول القرظي ووهب {6} ومجاهد. وقال في رواية الوالبي: هي السعادة {7}.وقال قتادة: هي رزق يوم بيوم {8}.وكان النبيّ -ﷺ- يقول في دعائه: ""قنعني بما رزقتني"" {9}.وفيما روى أبو هريرة: أن النبي -ﷺ- كان يدعو: ""اللهم اجعل رزق آل محمد كفافًا"" {10}.فقول من قال: إنه القناعة، حسن مختار؛ لأنه لا يطيب في الدنيا إلا عيش القانع، والمكدود بطلبها لا تطيب حياته {11}.وقال السدي: ﴿حَيَاةً طَيِّبَةً﴾ يعني في القبر {12}.قال الحسن وسعيد بن جبير: ﴿حَيَاةً طَيِّبَةً﴾: في الآخرة {13}، فعلى هذا هذه الحياة في الجنة، روى عوف {14} عن الحسن قال: لا تطيب الحياة لأحد إلا في الجنة {15}."
  16,98,"قوله تعالى: ﴿فَإِذَا قَرَأْتَ الْقُرْآنَ فَاسْتَعِذْ بِاللَّهِ﴾ الآية. قال الزجاج وجميع أصحاب المعاني: معناه: إذا أردت أن تقرأ القرآن فاستعذ {1}، ليس معناه استعذ بعد أن تقرأ القرآن؛ ومثله إذا أكلت فقل: بسم الله {2}، وقد ذكرنا هذا عند قوله: ﴿إِذَا قُمْتُمْ إِلَى الصَّلَاةِ﴾ [المائدة: 6]، وبينا حكم (إذا) في وقوع (ما) بعدها مستقبلًا في أوائل سورة البقرة وإجماع الفقهاء أن الاستعاذة تكون قبل القراءة {3}.وبه وردت الأخبار {4}، وذهب أبو هريرة -رضي الله عنه- إلى أن الاستعاذة بعد القراءة، وهو مذهب مالك {5}، وداود {6}، كأنهم أخذوا بظاهر الآية {7}، وذلك جهل بمقاييس العربية {8}."
  16,99,"قوله تعالى: ﴿إِنَّهُ لَيْسَ لَهُ سُلْطَانٌ عَلَى الَّذِينَ آمَنُوا﴾ قال ابن عباس ومجاهد وعكرمة والمفسرون: ليس له حجة {1}.وقال أهل المعاني: طريق يتسلط به عليهم {2}، وقد بينا هذا عند قوله: ﴿إِنَّ عِبَادِي لَيْسَ لَكَ عَلَيْهِمْ سُلْطَانٌ﴾ في سورة الحجر [آية: 42]، والمختار أن يقال: ليس له سلطان الإغواء، وهو معنى قول المفسرين: ليس له حجة، أي: لا حجة له على المؤمنين في إغوائهم إلى الضلالة."
  16,100,"﴿إِنَّمَا سُلْطَانُهُ عَلَى الَّذِينَ يَتَوَلَّوْنَهُ﴾ قال ابن عباس: يطيعونه {1}، يقال: توَلَّيْتُه، أي: أطعته، وتَوَلَّيْتُ عنه، أي: أعرضت عنه، وذكرنا هذا عند قوله: ﴿وَمَنْ يَتَوَلَّ اللَّهَ وَرَسُولَهُ﴾ [المائدة: 56].وقوله تعالى: ﴿وَالَّذِينَ هُمْ بِهِ مُشْرِكُونَ﴾ قال مجاهد: يعني يعدلون برب العالمين {2}، فعلى هذا الكناية في به تعود إلى اسم الله تعالى.وقال عطاء عن ابن عباس: يريد يطيعونه في الشرك، وعلى هذا الكناية راجعة إلى الشرك، وهذا قول الربيع {3}، والمعنى على هذا القول: والذين هم بسببه وطاعته فيما يدعو إليه مشركون، قال صاحب النظم: وهذا كما تقول للرجل إذا تكلم بكلمة مؤدية إلى الكفر، كفرت بهذه الكلمة؛ أي: من أجلها وبقولك إياها {4}، فلذلك قوله: ﴿وَالَّذِينَ هُمْ بِهِ﴾، أي: من أجله وحمله إياه مشركون بالله {5}."
  16,101,"قوله تعالى: ﴿وَإِذَا بَدَّلْنَا آيَةً مَكَانَ آيَةٍ﴾ قال الكلبي وغيره: كان إذا نزلت آية ألين منها، يقول كفار قريش: والله ما محمد إلا يسخر بأصحابه، يأمرهم اليوم بأمر وغدًا بأمر؛ وأنه ليتكذَّبه ويأتيهم به من عند نفسه، فأنزل الله: ﴿وَإِذَا بَدَّلْنَا آيَةً مَكَانَ آيَةٍ﴾ {1}، قال مجاهد: رفعناها وأنزلنا غيرها {2}، وقال قتادة: هو كقوله: ﴿مَا نَنْسَخْ مِنْ آيَةٍ﴾ {3} الآية [البقرة: 106] وقال الفراء: إذا نسخنا آية فيها تشديد مكان آية ألينَ منها {4}، ومعنى التبديل: رَفْعُ الشيء مع وضع غيره مكانه {5}، وتبديل الآية: رفعها {6} بآية غيرها، وهو نسخها بآية سواها.وقوله تعالى: ﴿وَاللَّهُ أَعْلَمُ بِمَا يُنَزِّلُ﴾، أي: مِن الناسخ والمنسوخ، والتغليظ والتخفيف؛ هو أعلم بجميع ذلك في مصالح العباد، وهذا اعتراض دخل في الكلام يتضمن توبيخ الكفار على قولهم: ﴿إِنَّمَا أَنْتَ مُفْتَرٍ﴾، أي إذا كان هو أعلم بما ينزل، ما بالهم ينسبون محمدًا إلى الافتراء لأجل التبديل والنسخ.وقوله تعالى: ﴿بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ﴾، أي: لا يعلمون حقيقة القرآن، وفائدة النسخ والتبديل في أن ذلك لمصلحة العباد؛ كالاستصلاح بإرسال نبي بعد نبي، والكلام في ذكر أكثرهم دون جميعهم قد مضى في موضعين من هذه السورة {7}."
  16,102,"قوله تعالى: ﴿قُلْ نَزَّلَهُ﴾، أي: نَزَل به، أي بالقرآن، ﴿رُوحُ الْقُدُسِ﴾ وهو جبريل، ومضى تفسير روح القدس في سورة البقرة [87]، ﴿مِنْ رَبِّكَ﴾ (من) صلة للقرآن، أي نَزَّل القرآنَ من ربك، أي: من كلام ربك جبريلُ، ﴿بِالْحَقِّ﴾ أي بالأمر الحق الصحيح الثابت لا الباطل، ﴿لِيُثَبِّتَ الَّذِينَ آمَنُوا﴾ بما فيه من الحجج والآيات، فيزدادوا بها تصديقًا ويقينًا.وقوله تعالى: ﴿وَهُدًى﴾، أي: وهو هدى، فهو خبر ابتداء محذوف."
  16,103,"قوله تعالى: ﴿وَلَقَدْ نَعْلَمُ أَنَّهُمْ يَقُولُونَ إِنَّمَا يُعَلِّمُهُ بَشَرٌ﴾ اختلفوا في هذا البشر الذي نَسبَ المشركون النبي -ﷺ- إلى التعليم منه؛ فقال ابن عباس في رواية عكرمة: هو عَبْدٌ لبني عامر بن لُؤيّ، يقال له: يعيش {1}، وهذا قول قتادة إلا أنه قال: كان لبني الحضرمي، وكان يقرأ الكتب، وقال في رواية عطاء: يريد عداس؛ غلام عتبة بن ربيعة {2}.وروى طلحة بن عمرو {3} عن عطاء أن خديجة {4} كانت تختلف إلى صَيْقَل {5} على الصفا والمروة؛ عبد لبني الحضرمي صاحب كتب، فكانت تخبره بما كان يرى محمد -ﷺ- فكان يقول لها لئن كنت صادقة ليوشكن نبي العرب أن يخرج، وكان اسمَه جَبرٌ وكانت قريش تقول: إنما عبد بني الحضرمي يعلم خديجة، وتعلم خديجة محمدًا، زاد شبل: وكان يتكلم بالرومية {6}، وهذا قول مجاهد وابن إسحاق {7}.وروي عن ابن عباس أنه قال: هذا كان قينًا {8} بمكة نصرانيًّا أعجمي اللسان اسمه بَلْعَام {9}.وقال السدي: هو رجل نصراني كان بمكة، يقال له: أبو ميسرة، يتكلم بالرومية {10}.وقال الكلبي: هو عايش -غلام حويطب بن عبد العزى-، ويسار -أبو فكيهة مولى ابن الحضرمي-، وكانا قد أسلما فأنزل الله تعالى ردًّا عليهم وتكذيبًا لهم فيما قالوا: ﴿لِسَانُ الَّذِي يُلْحِدُونَ إِلَيْهِ أَعْجَمِيٌّ﴾ {11}.معنى الإلحاد في اللغة: الميل، يقال: لَحَدَ وأَلْحَدَ؛ إذا مال عن القصد، ومنه يقال للعادل عن الحق: ملحد {12}، وقراءة العامة ضم الياء من الإلحاد {13} وهو أشهر اللغتين، وقرئ بفتح الياء من لحد {14}، والأوْلى ضَم الياء؛ لأنه لغة التنزيل {15}، يدل عليه قوله: ﴿وَمَنْ يُرِدْ فِيهِ بِإِلْحَادٍ﴾ [الحج: 25]، والإلحاد قد يكون بمعنى: الإمالة، ومنه يقال: أَلْحَدْتُ له لَحْدًا إذا حفرته في جانب القبر مائلٍ عن الاستواء، وقَبْرٌ مُلْحَدٌ ومَلْحُودٌ {16}، وفُسِّر الإلحاد في هذه الآية بالقولين، فقال الفراء: يُمِيلُون من الميل {17}.وقال الزجاج: لسانُ الذي يميلُون القَوْلَ إليه أعجميٌّ {18}.وقال ابن قتيبة: أي يُومِئون إليه ويزعمون أنه يُعلِّمك {19}.وقوله تعالى: ﴿أَعْجَمِيٌّ﴾ قال أبو الفتح الموصلي: اعلم أن (ع ج م) إنما وضعت في كلام العرب للإبهام والإخفاء، وضد البيان والإيضاح، من ذلك قولهم: رجل أعْجم وامرأة عَجْماء، إذا كانا لا يُفصحان ولا يُبينان كلامهما، وكذلك {20} العُجْمُ والعَجَمُ، وعَجَمُ الزبيب {21} سُمّي لاستتارته وخفائه بما هو عَجَمٌ له، والعَجْماء: البهيمة؛ لأنها لا توضِّح عما في نفسها، ومن ذلك تسميتهم صلاتي الظهر والعصر العَجْماوتين؛ لما كانتا لا يُفْصَح فيهما بالقراءة، قال أبو علي: ومن ذلك: عَجَمْتَ العُودَ؛ إما لأنك لما أدخلتَه لتِعُضَّه {22} وقد أخفيته، وإما لأنك قد ضغطت بعض أجزائه بالعَجْمِ، وأدخلت بعضها في بعض فأخفيتها، وربما سمّت {23} العرب الأخرسَ الأعجم؛ وعُجْمة الرمل {24}: أشدّه تراكمًا، سمي بذلك لتداخله واستبهام أمره على سُلاَّكِه، يقال: استعجمت الدارُ إذا صَمَّت فلم تجب سائلها، قال امرؤ القيس:صَمَّ صَداها وعَفا رسمُها ... واستَعجمتْ عن مَنْطق السائلِ {25}وأما قولهم: أعْجمتُ الكتاب، فمعناه: أزلت عجمته واستعجامه بالإيضاح والتبين، وأَفْعَلْتُ قد يأتي والمراد به: السَّلْب؛ كقولهم: أشكيت، إذا أزلتَ ما يشكوه {26}، وهذا الذي ذكرنا هو أصل معنى هذا الحرف {27}، والعرب تسمي كل من لا يعرف لغته {28} ولا يتكلم بلسانهم أعجم وأعجميًّا، قال كثير: وما زال كتمانيك حتى كأنني ... بِرَدِّ جَوابِ السائِلي عنك أعجمُ {29}قال الفراء وأحمد بن يحيى: الأعجم: الذي في لسانه عُجمة وإن كان من العرب، والأعجمي والعجمي: الذي أصله من العجم {30}.قال ابن الأنباري: وقولهما هو الصحيح عندنا.وقال أبو علي الفارسي: الأعجمي: الذي لا يُفصح من العرب كان أو من العجم، ألا تراهم أنهم قالوا: زياد الأعجم؛ لأنه كانت في لسانه عُجمة {31} وكان عربيًّا {32}، وقال {33} لصلاة النهار عَجْمَاء أي: تُخفى فيه القراءة ولا تبَيَّن، وتُسمي العربُ من لا يتبين كلامه من أي صنف كان من الناس أعجم، ومنه قول الحِمَّاني {34}:سَلُّومُ: لو أَصْبَحتِ وسْطَ الأَعْجمِ بالرومِ أو بالتُّركِ أو بالديلمإذًا لَزُرناكِ ولو بِسُلَّمِ {35}قال: وسط الأعجم ولم يقل: وسط العجم؛ لأنه جعل كل من لا يتبين كلامه أعجم، فكأنه قال: وسط القبيل الأعجم، وينبغي أن يكون الأعجمي بالياء فيه للنسب، نسب إلى الأعجم الذي لا يُفْصِح، وهو في المعنى كالأعجمي، ويجوز أن يقال: رجل أعجمي فيراد به ما يراد بالأعجم بغير ياء النسب، كما يُقال: أحمر وأحمريّ، ودَوّارٍ ودَوَّارِي {36}.ومعنى الآية هو {37} أن الله تعالى قال: لسان هذا البشر الذي يزعمون أنه يعلمك أعجمي لا يُفصح ولا يتكلم بالعربية، فكيف يُتَعَلَّم عنه ما هو أعلى طبقات البيان؟! وهو قوله: ﴿وَهَذَا﴾ يعني القرآن، ﴿لِسَانٌ عَرَبِيٌّ مُبِينٌ﴾، قال ابن عباس: يريد الذي نزل على محمد عربي مبين، أفصح ما يكون من العربية، وأبْيَنه لسان سعد بن بكر بن هوازن الذين أرضعوا النبي -ﷺ- {38}؛ واللسان بمعنى الكلام واللغة، وذكرنا هذا مستقصى عند قوله: ﴿وَمَا أَرْسَلْنَا مِنْ رَسُولٍ إِلَّا بِلِسَانِ قَوْمِهِ﴾ [إبراهيم: 4]، ومعنى العربي واشتقاقه ذكرنا عند قوله: ﴿الْأَعْرَابُ أَشَدُّ كُفْرًا﴾ [التوبة: 97] وقال الفراء والزجاج في هذه الآية: يقال: عَرَبَ لِسَانُه عَرابَةً وعُروبةً {39}."
  16,104,""
  16,105,"قوله تعالى: ﴿إِنَّمَا يَفْتَرِي الْكَذِبَ﴾ الآية. قال الكلبي: نافح الله تعالى بهذه الآية عن رسول الله -ﷺ- ودافع عنه حيث قالوا: تَقَوَّله واخترعه وأتى به من عند بشر وافتراه، فقال: ﴿إِنَّمَا يَفْتَرِي الْكَذِبَ﴾: المشركون، ثم سَمَّاهم الكاذبين، وحصر فيهم الكذب بقوله: ﴿وَأُولَئِكَ هُمُ الْكَاذِبُونَ﴾، وقال أبو إسحاق: أي إنما يفتري الكذب الذين إذا رأوا الآيات التي لا يقدر عليها إلا الله كذَّبُوا بها، فهؤلاء أكذبُ الكَذَبَةِ {1}، وفي الآية أبلغ زجر عن الكذب؛ حيث أخبر الله تعالى أنه إنما يفتري الكذب من لا يؤمن، ولذلك قال النبيّ -ﷺ- حين قيل له: (هل يَكْذِبُ المؤمن؟ قال: ""لا""، ثم قرأ هذه الآية) {2}.وقال صاحب النظم في هذه الآية: أعلم الله أن الذي يفتري الكذب هو الذي لا يؤمن بآيات الله، ثم عطف على هذا قوله: ﴿وَأُولَئِكَ هُمُ الْكَاذِبُونَ﴾ وفائدة ذلك؛ أن قوله: ﴿إِنَّمَا يَفْتَرِي الْكَذِبَ﴾ فِعْلٌ وليس بنعت، وقوله تعالى: ﴿وَأُولَئِكَ هُمُ الْكَاذِبُونَ﴾ نعتٌ، والفعل قد يكون لازمًا وقد لا يكون، والنعت {3} لا يكون إلا دائمًا، يبين هذا أنه تعالى قال: ﴿وَعَصَى آدَمُ رَبَّهُ فَغَوَى﴾ [طه: 121]، ولا يجوز أن يقال: إن آدم عاصٍ وغاوٍ؛ لأن النعت أبلغ من الفعل، ولهذا قال الله: ﴿وَأُولَئِكَ هُمُ الْكَاذِبُونَ﴾ أي أن هذا نعت لازم لهم وعادة من عاداتهم، لا فِعْلٌ يزول عن قريب، وهذا كما تقول: كذبت وأنت كاذب، فيكون قولك: أنت كاذب، زيادة في الوصف بالكذب {4}."
  16,106,"قوله تعالى: ﴿مَنْ كَفَرَ بِاللَّهِ مِنْ بَعْدِ إِيمَانِهِ﴾ الآية. أكثر المفسرين على أن الآية نزلت في عمار بن ياسر؛ أخذه المشركون فلم يتركوه حتى سَبَّ النبيّ -ﷺ- وذكر آلهتم بخير ثم تركوه، فلما أتى رسول الله -ﷺ- قال: ""ما وراءك؟ قال: شَرٌّ يا رسول الله، ما تُرِكتُ حتى نِلتُ مِنْك، وذكرتُ آلهتم بخير. قال: كيف تجد قلبك؟ قال: مطمئنًا بالإيمان. قال: إن عادوا لك فعد لهم بما قلت"" {1}.واختلفوا في محل (مَنْ) مِن الإعراب، فقال الأخفش: هو ابتداء، وخبره محذوف مكتفى منه بخبر (مَنْ) الثانية في قوله: ﴿وَلَكِنْ مَنْ شَرَحَ بِالْكُفْرِ صَدْرًا﴾ {2}؛ كقولك: من يأتينا فمن يحسن نكرمه {3}، فجواب الأول محذوف قد كفى منه الثاني، وقال أبو إسحاق: (مَنْ) في موضع رفع على البدل مِن الكاذبين {4}، ولا يجوز أن يكون رفعًا بالابتداء؛ لأنه لا خبر هاهنا للابتداء؛ لأن قوله: ﴿مَنْ كَفَرَ بِاللَّهِ مِنْ بَعْدِ إِيمَانِهِ﴾ ثم استثنى فقال: ﴿إِلَّا مَنْ أُكْرِهَ﴾: على الكفر، يكفر بلسانه وقلبه مطمئن {5} بالإيمان {6}، والقول الأول أظهر في معنى الآية؛ لأن {7} هذه قصة مستأنفة، وكلام لا تعلق له بما تقدم، يدل عليه من التفسير ما رواه علي بن أبي طلحة عن ابن عباس في هذه الآية، قال: أخبر الله سبحانه أنه من كفر بعد إيمانه فعليه غضب من الله وله عذاب عظيم، فأما من أُكره فتكلم بلسانه وخالفه قلبه بالإيمان لِيَنْجُو بذلك من عدوه فلا حرج عليه؛ لأن الله سبحانه إنما يأخذ العباد بما عقدت عليه قلوبهم {8}، فجعل ابن عباس قوله: ﴿فَعَلَيْهِمْ غَضَبٌ﴾ خبر قوله: ﴿مَنْ كَفَرَ بِاللَّهِ﴾.وقوله تعالى: ﴿وَلَكِنْ مَنْ شَرَحَ بِالْكُفْرِ صَدْرًا﴾، أي: فتحه ووسعه لقبول {9} الكفر، وذكرنا معنى الشرح في سورة الأنعام {10}، وانتصب صدرًا على أول مفعول للشرح، والتقدير: ولكن من شرح بالكفر صدره، وحذف الهاء منه لأنه لا يُشْكِل بصدر غيره، إذ البشر لا يقدر على شرح صدر غيره، فهو نكرة يراد بها المعرفة، ويدل عليها معنى الكلام، ""وهذه الآية تدل على أنّ المُكْرَهَ على كلمة الكفر إذا تَلَفَّظ بها مُكْرَهًا لا يحكم بكفره إذا كان قلبه مطمئنًا بالإيمان {11}، ولذلك أبطل الشافعي طلاق المكره وعتاقه وعقوده، ولم يجعل لها حكمًا {12}، ودلّت الآية على أن حقيقة الكفر إنما تكون بالقلب دون اللسان {13}."
  16,107,"قوله تعالى: ﴿ذَلِكَ بِأَنَّهُمُ اسْتَحَبُّوا﴾، أي: ذلك الشرح وذلك الكفر {1}، بأنهم أحبّوا الدنيا واختاروها على الآخرة، قال الكلبي: والمراد بقوله: ﴿وَلَكِنْ مَنْ شَرَحَ بِالْكُفْرِ صَدْرًا﴾ عبد الله بن سعد بن أبي سرح ومن ارتد عن الدين وطابت نفسه بالكفر {2}، وذلك باستحبابهم الدنيا وبأن الله لا يهديهم ولا يريد هدايتهم، ثم وصفهم بأنهم مطبوع على قلوبهم وسمعهم وأبصارهم."
  16,108,"فقال: ﴿أُولَئِكَ الَّذِينَ طَبَعَ اللَّهُ﴾ الآية. والكلام في هذا مضى {1}.وقوله تعالى: ﴿وَأُولَئِكَ هُمُ الْغَافِلُونَ﴾ قال ابن عباس: عما يراد بهم {2}، ثم حكم لهم بالخسار وأكَّدَ ذلك،"
  16,109,"فقال: ﴿لَا جَرَمَ أَنَّهُمْ فِي الْآخِرَةِ﴾ قال ابن عباس: يريد حقًا إنهم في الآخرة هم المغبونون {1}، قال أبو إسحاق: (أنَّ) يصلح أن تكون في موضع رفع، على أَنّ (لا) رَدٌّ لكلام، والمعنى: وجب أنَّهُم، قال: ويجوز أن تكون في موضع نَصْبٍ على أن المعنى: جَرَمَ فِعْلُهُمْ هذا، ﴿أَنَّهُمْ فِي الْآخِرَةِ هُمُ الْخَاسِرُونَ﴾ أي كَسَب {2}."
  16,110,"قوله تعالى: ﴿ثُمَّ إِنَّ رَبَّكَ لِلَّذِينَ هَاجَرُوا مِنْ بَعْدِ مَا فُتِنُوا﴾ قال المفسرون: نزلت في المستضعفين من المؤمنين الذين كانوا بمكة، عَمَّار وصُهيب وبلال، ودونهم الذين عُذِّبُوا في الله وارتدوا على الكفر وأعطوهم بعضَ ما أرادوا لِيَسْلَمُوا من شَرِّهم، ثم (هاجروا إلى النبيّ -ﷺ- {1}.[قال ابن عباس: يريد الذين كانوا يُعَذَّبون بمكة، ﴿هَاجَرُوا) {2} مِنْ بَعْدِ مَا فُتِنُوا﴾ قال: من بعد ما عُذِّبُوا، ﴿ثُمَّ جَاهَدُوا﴾: مع النبي -ﷺ-] {3}، ﴿وَصَبَرُوا﴾: على الدين والجهاد {4}.وقوله تعالى: ﴿إِنَّ رَبَّكَ﴾ إعادة وتكريرٌ لما ذكر في الآية؛ وذلك لتطاول الكلام، وأجيب كلاهما بجواب واحد، وهذا من القبيل الذي ذكرنا في قوله: ﴿مَنْ كَفَرَ بِاللَّهِ﴾ الآية.وقوله تعالى: ﴿مِنْ بَعْدِهَا﴾: تلك الفتنة وتلك الفعلة التي فعلوها وهي تلفظهم بكلمة الكفر، ﴿لَغَفُورٌ رَحِيمٌ﴾، وذلك أن الرخصة لم تكن نازلة في ذلك الوقت حين تلفظوا بالكفر تقية، وإنما نزلت بعد ذلك فأخبر الله تعالى بعد ذلك أنه قد غفر لهم ذلك، هذا قول عامة أهل التأويل {5}.وقال عطاء عن ابن عباس: ﴿إِنَّ رَبَّكَ مِنْ بَعْدِهَا﴾ يريد من بعد ما خرجوا إلى النبيّ -ﷺ- وصاروا عنده بالمدينة، غفر الله لهم مقامهم بمكة وتثبطهم بها، عفا الله ذلك عنهم {6}، فعلى هذا الكناية في ﴿بَعْدِهَا﴾ تعود إلى الهجرة، ودلّ عليها: ﴿هَاجَرُوا﴾، والمغفرة لمقامهم بمكة وتخلفهم عن النبيّ -ﷺ- بعد خروجه، وقرأ ابن عامر فَتنوا، بفتح الفاء {7}، ومعنى هذا ﴿للذينَ هاجَروا مِن بعدِ ما فَتنُوا﴾ أنفسهم بإظهار ما أظهروا للتقية، وجعل ذلك فتنة؛ لأن الرخصة فيه لم تكن نزلت بعد {8}.وذهب قوم من المفسرين إلى أن الآية نزلت في قوم من الذين كانوا يُعذِّبون المستضعفين بمكة، آمنوا وهاجروا إلى النبيّ -ﷺ- {9} فقال الله تعالى: ﴿ثُمَّ إِنَّ رَبَّكَ لِلَّذِينَ هَاجَرُوا مِنْ بَعْدِ مَا فُتِنُوا ثُمَّ جَاهَدُوا وَصَبَرُوا إِنَّ رَبَّكَ مِنْ بَعْدِهَا لَغَفُورٌ رَحِيمٌ﴾ الآية."
  16,111,"قوله تعالى: ﴿يَوْمَ تَأْتِي كُلُّ نَفْسٍ﴾ لآية. قال أبو إسحاق: ﴿يَوْمَ﴾ منصوب على أحد شيئين، على معنى: ﴿إِنَّ رَبَّكَ مِنْ بَعْدِهَا لَغَفُورٌ رَحِيمٌ﴾، ﴿يَوْمَ تَأْتِي﴾، ويجوز ذَكِّرْهم يوم، أو اذْكُر يوم؛ لأن معنى القرآن العِظة والإنْذَارُ والتَّذْكير {1}.وقوله تعالى: ﴿كُلُّ نَفْسٍ﴾ أراد كلَّ إنسان وكلَّ واحد، ولقوله: ﴿تُجَادِلُ عَنْ نَفْسِهَا﴾ ولم يقل يُجَادَل عنها، قال المفسرون: وهذا يوم القيامة كل أحد لا يهمه إلا نفسه، فهو مخاصم ومحتج عن نفسه لا يتفرغ إلى غيره؛ وذلك أن لجهنم زفرة يقع كل أحد جاثيًا على ركبتيه، حتى إن إبراهيم ليدلي بالخُلَّة، فيقول: يارب، أنا خليلك إبراهيم، لا أسألك إلا نفسي {2}.وقوله تعالى: ﴿وَتُوَفَّى كُلُّ نَفْسٍ مَا عَمِلَتْ﴾ قال ابن عباس: يريد ثوابها غير منتقص، والتقدير: ثواب ما عملت أو جزاء ما عملت، فحذف المضاف، ﴿وَهُمْ لَا يُظْلَمُونَ﴾ قال: يريد لا ينقصون."
  16,112,"قوله تعالى: ﴿وَضَرَبَ اللَّهُ مَثَلًا﴾ الآية. معنى ضَرْبِ المثلِ بيان المُشبَّه والمُشبَّه به، وهاهنا ذَكَرَ المُشبَّه به ولم يذكر المُشَبَّه لوضوحه عند المخاطبين، والآية عند عامة المفسرين: نازلة في أهل مكة وما امتُحِنوا به من الخوف والجوع، بعد الأمن والنعمة، بتكذيبهم النبيّ -ﷺ-، وتقدير الآية: ضربَ اللهُ لقريتكم مَثَلاً، أي: بين الله لها شَبَهًا، ثم قال: ﴿قَرْيَةٍ﴾ فيجوز أن تكون القرية بدلاً من مثلًا؛ لأنها هي الممثل بها؛ فهي المثل، ويجوز أن يكون المعنى: ﴿ضَرَبَ اللَّهُ مَثَلًا﴾: مَثَلَ قرية، فحذف المضاف وهذا قول الزجاج {1}.والمفسرون كلهم قالوا: (أراد بالقرية مكة، يعنون أنه أراد مكة في تمثيلها بقرية صفتها ما ذُكِر {2}؛ كما قالوا) {3} في قوله: ﴿مَثَلُهُمْ كَمَثَلِ الَّذِي اسْتَوْقَدَ نَارًا﴾ [البقرة: 17]، أراد بالذي استوقد: المنافقين؛ أي أرادهم بهذا المثل، لا أنهم كانوا يستوقدون النار، ولكن أَشْبَه حالُهم حالَه، كذلك أشبهت حالُ مكة حالَ هذه القرية، والكلام في جميع صفات القرية جرى على القرية، والمُرادُ أهلُها؛ لأن الطمأنينة والأمن وإتيان الرزق حقيقتها لأهلها لا لها، يدل على هذا قوله في آخر الآية: ﴿بِمَا كَانُوا يَصْنَعُون﴾، ولم يقل: بما صنعت.وقوله تعالى: ﴿كَانَتْ آمِنَة﴾، أي: ذات أمن؛ يأمن فيها أهلها لا يُغَارُ عليهم، كما قال: ﴿أَوَلَمْ يَرَوْا أَنَّا جَعَلْنَا حَرَمًا آمِنًا وَيُتَخَطَّفُ النَّاسُ مِنْ حَوْلِهِمْ﴾ [العنكبوت: 67]، وجاز وصفها بالأمن وإن كان لأهلها؛ لأنها مكانُ الأمن وظرفٌ له، والظروف من الأزمنة والأمكنة توصف بمحالها، كما يقال: يوم طيب وبارد وحار.وقوله تعالى: ﴿مُطْمَئِنَّةً﴾، أي: قارة ساكنة بأهلها، لايحتاجون إلى الانتقال عنها لخوف أو ضيق، وهو قوله: ﴿يَأْتِيهَا رِزْقُهَا رَغَدًا مِنْ كُلِّ مَكَانٍ﴾؛ لأن الله جعل أفئدة من الناس تهوي إليهم، فأرزاقهم تأتيهم في بلدهم، يُجْلَب إليها من كل بلد، كما قال تعالى: ﴿يُجْبَى إِلَيْهِ ثَمَرَاتُ كُلِّ شَيْءٍ﴾ [القصص: 57].وقوله تعالى: ﴿فَكَفَرَتْ بِأَنْعُمِ اللَّه﴾، الأنعم: جمع نِعْمة، مثل شِدَّة وأَشُدّ، هذا قول سيبويه {4}، وقال غيره: يجوز أن يكون جمع نُعْمَى؛ كما يقال: بؤسى وأبؤس {5}، وأنشد: وعندي قروض الخير والشر كله ... فبُؤسِي لذي بُؤسَى ونُعْمَى بأنْعُمِي {6}وكفرانهم بأنعم الله تكذيبهم النبيّ -ﷺ- ومخالفتهم أمر الله فيما يأمرهم به.وقوله تعالى: ﴿فَأَذَاقَهَا اللَّهُ لِبَاسَ الْجُوعِ وَالْخَوْفِ﴾ قال المفسرون: عذَّبهم اللهُ بالجوع سبع سنين حتى أكلوا الجِيَفَ والعظام المحرقة والعلهز {7}.وقوله تعالى: ﴿وَالْخَوْف﴾، قالوا: يعني من النبيّ -ﷺ- ومن السرايا التي كان يبعثها إليهم فيطوفون بهم {8}.قال ابن قتيبة: وأصل الذَّوَاقِ بالفم، ثم قد {9} يُستعار فيوضع موضع الابتلاء والاختبار، تقول في الكلام: نَاظِرْ فُلانًا وذُقْ ما عنده، أي تعرَّف واختبر، واركب الفرسَ وذقه، وأنشد الشماخ في وصف قوس:فذاقَ فأعْطَتْهُ من اللّين جَانبًا ... كفى {10} ولَهَا أن يُغْرِقَ السَّهْمَ حَاجِزُ {11}يريد أنه راز {12} القوس بالنزع ليعلم؛ ألَيِّنَةٌ هي أم صلبةٌ.قال: ولباس الجوع والخوف: ما ظهر عليهم من سوء آثارهما بالضُّمْرِ والشُّحوب، ونَهْكَةِ {13} البدن، وتغيّر الحال، وكُسُوف البال، فكما يقول: تَعَرَّفْتُ سوء أثرِ الخوف والجوع على فلان، وذقت بمعنى: تعرفتُ، واللِّبَاسُ بمعنى: سوء الأثر {14}، كذلك تقول: ذقتُ لِبَاسَ الجوع والخوف، وأذاقني الله ذلك {15}.وقال أبو علي: ﴿لِبَاسَ الْجُوعِ وَالْخَوْفِ﴾ المعنى فيه: مقارنة {16} الجوع لهم ومَسُّه إيّاهم؛ كمخالطة الذائق ما يذوقه، واللابس ما يَلْبَسُه، واتصاله بما وقع عليه الذوق، وكذلك لباس الجوع هو مَسُّه لهم كمَسّ الثوب للابسه، وأنشد لجرير:وقد لَبِسَتْ بَعْدَ الزّبَيرِ مُجَاشعٌ ... ثيابَ التي حاضَتْ ولَمْ تَغْسلِ الدّمَا {17}يريد أن العار والسُّبَّة لحقتهم، واتصل بهم لغدرهم، فجعل ذلك لباسًا {18}، فعلى ما ذكر ابن قتيبة معنى ﴿فَأَذَاقَهَا اللَّهُ لِبَاسَ الْجُوعِ وَالْخَوْفِ﴾ عَرَّفَها سوءَ أثرهما، وعلى ما ذكر أبو علي، جعل الجوع والخوف تَمَسَّانها وتُلابِسَانِها.وروي عن أبي {19} عمرو أنه قرأ: ﴿وَالْخَوْف﴾ نصبًا {20} بأنْ على الإذاقة {21}، والوجه قراءة العامة على معنى: فأذاقهم الله لباس الجوع ولباس الخوف، يدل عليه أن في حرف أُبي: لباسَ الخوف والجوع {22}، فقد جعل للخوف لباسًا كما جعل للجوع، وحَمْلُه على الخفض باللباس أولى من حمله على الإذاقة؛ لأن اللباس أقرب إليه، فحمله على الأقرب أولى، وليكونا محمولين على عامل واحد، كما كان في قوله: ﴿وَلَنَبْلُوَنَّكُمْ بِشَيْءٍ مِنَ الْخَوْفِ وَالْجُوعِ﴾ [البقرة: 155]، الحمل على عامل واحد {23}.وقوله تعالى: ﴿بِمَا كَانُوا يَصْنَعُونَ﴾ قال ابن عباس: يريد بفعلهم بالنبيّ -ﷺ- حيث كذبوه وأخرجوه من مكة وما هموا به من قتله {24}.قال الفراء: ولم يقل بما صنعت، ومثله في القرآن كثير، منه قوله: ﴿فَجَاءَهَا بَأْسُنَا بَيَاتًا أَوْ هُمْ قَائِلُون﴾ [الأعراف: 4] ولم يقل: قائلة، فإذا قال: ﴿قَائِلُون﴾ ذهب إلى الرجال، وإذا قال: قائلة، فإنما يعني أيضًا أهلها، ومثله: ﴿فَحَاسَبْنَاهَا حِسَابًا شَدِيدًا﴾ إلى قوله: ﴿فَذَاقَتْ﴾ {25} [الطلاق: 8 - 9]."
  16,113,"قوله تعالى: ﴿وَلَقَدْ جَاءَهُمْ﴾ يعني أهل مكة، ﴿رَسُولٌ مِنْهُمْ﴾ يعني مِنْ نسبهم يعرفونه بأصله ونسبه، ﴿فَكَذَّبُوهُ فَأَخَذَهُمُ الْعَذَاب﴾، قال ابن عباس: يعني الجوع الذي كان بمكة {1}، وقال مجاهد: يعني القتل ببدر {2}؛ وهو اختيار الزجاج {3}."
  16,114,"قوله تعالى: ﴿فَكُلُوا مِمَّا رَزَقَكُمُ اللَّهُ﴾ الآية.قال ابن عباس: ﴿فَكُلُوا﴾: يا معشر المؤمنين، ﴿مِمَّا رَزَقَكُمُ اللَّهُ﴾، يريد من الغنائم {1}.وقال الكلبي: إن رؤساء أهل مكة كَلَّمُوا رسولَ الله -ﷺ- حين جُهِدوا، قالوا: عاديت الرجال فما بال النساء والصبيان، وكانت المِيرَة {2} قد قطعت عنهم بأمر رسول الله -ﷺ- فأَذِن في الحَمْل إليهم، فَحُمِل إليهم الطعام {3}، فقال الله تعالى: ﴿فَكُلُوا مِمَّا رَزَقَكُمُ اللَّهُ﴾ الآية. والقول ما قاله ابن عباس، يدل عليه قوله بعد هذه الآية:"
  16,115,"﴿إِنَّمَا حَرَّمَ عَلَيْكُمُ الْمَيْتَةَ﴾ وهذا خطاب للمسلمين لا لكفار مكة، وهاتان الآيتان سبق تفسيرهما في سورة البقرة {1}."
  16,116,"قوله تعالى: ﴿وَلَا تَقُولُوا لِمَا تَصِفُ أَلْسِنَتُكُمُ الْكَذِبَ هَذَا حَلَالٌ وَهَذَا حَرَامٌ﴾ الآية. قال مجاهد: يعني البحيرة والسائبة {1}.وقال ابن عباس: يعني قولهم: ﴿وَقَالُوا مَا فِي بُطُونِ هَذِهِ الْأَنْعَامِ خَالِصَةٌ لِذُكُورِنَا وَمُحَرَّمٌ عَلَى أَزْوَاجِنَا﴾ {2} [الأنعام: 139]، واختلفوا في وجه انتصاب الكذب؛ فقال الأخفش: جعل (ما تصف) اسمًا للفعل؛ كأنه قال: ولا تقولوا لوصف ألسنتِكم الكذب {3}، ونحو هذا قال الكسائي {4}. والزجاج {5}، سِوى أنْ قال صاحب النظم: واللام في (لِمَا) لامُ سبب وأجل، كما يقال: فعلت هذا لك، أي لأجلك وبسببك {6}، والمعنى: ولا تقولوا لأجل وصفكم الكذب هذا حلال وهذا حرام؛ أي إنكم تُحِلُّون وتُحَرِّمون لأجل الكذب لا لغير، فليس لتحريمكم وتحليلكم معنى وسبب إلا الكذب فقط، فلا تفعلوا ذلك، هذا معنى قوله: إن دخول اللام في (لِمَا) سبب لقوله: ﴿هَذَا حَلَالٌ وَهَذَا حَرَامٌ﴾، وذكر وجهين آخرين في انتصاب الكذب؛ أحدهما: أن نصبه على نفي الخافض {7}، على تأويل لِمَا تصف ألسنتكم كذبًا؛ على جهة التفسير {8} أو الحال، ثم ألحق به الألف واللام؛ كما قال الشاعر {9}:وما قومي بِثَعْلَبةَ بنِ بَكْرٍ ... ولا بفَزَارة الشُّعْرِ الرِّقابَا {10}انتصب الرقاب على معنى التفسير هذا كلامه {11}، والقول قول الأخفش والكسائي، والإشارة بقوله ﴿هَذَا﴾ و ﴿وَهَذَا﴾ إلى ما كانوا يحلونه ويحرمونه.وقوله تعالى: ﴿لِتَفْتَرُوا عَلَى اللَّهِ الْكَذِبَ﴾، وذلك أنهم كانوا ينسبون ذلك التحريم إلى الله تعالى، ويقولون إنه أمَرَنا بذلك، وقوله: ﴿لِتَفْتَرُوا عَلَى اللَّهِ الْكَذِبَ﴾ بدل من قوله: ﴿لِمَا تَصِفُ أَلْسِنَتُكُمُ الْكَذِبَ﴾؛ لأن وصفهم الكذب هو افتراء على الله، ففسر ذلك الوصف والكذب بالافتراء على الله، ثم أوعد المفترين، وقال: ﴿إِنَّ الَّذِينَ يَفْتَرُونَ عَلَى اللَّهِ الْكَذِبَ لَا يُفْلِحُونَ﴾."
  16,117,"ثم بين أن ما هم فيه من نعيم الدنيا يزول عنهم عن قريب، فقال: ﴿مَتَاعٌ قَلِيلٌ﴾، قال الزجاج: المعنى: متاعهم متاع قليل، أي يَتَمتَّعون {1}، وقال ابن عباس: يريد متاع الدنيا قليل {2}، وقيل: لهم متاع قليل ثم يردون إلى عذاب أليم {3}، وهو قوله: ﴿وَلَهُمْ عَذَابٌ أَلِيمٌ﴾ {4}."
  16,118,"قوله تعالى: ﴿وَعَلَى الَّذِينَ هَادُوا حَرَّمْنَا مَا قَصَصْنَا عَلَيْكَ مِنْ قَبْلُ﴾ قال السدي وقتادة: يعني ما ذَكر في سورة الأنعام: ﴿وَعَلَى الَّذِينَ هَادُوا حَرَّمْنَا كُلَّ ذِي ظُفُرٍ﴾ {1} [الآيه: 146].وقوله: ﴿وَمَا ظَلَمْنَاهُمْ﴾، أي: بتحريم ما حرمنا عليهم، ﴿وَلَكِنْ كَانُوا أَنْفُسَهُمْ يَظْلِمُونَ﴾، ثم عطف على هذا بالمغفرة لمن تاب منهم ومن غيرهم بعد المعصية، فقال:"
  16,119,"﴿ثُمَّ إِنَّ رَبَّكَ لِلَّذِينَ عَمِلُوا السُّوءَ بِجَهَالَةٍ﴾، قال ابن عباس في (هذه الآية: يريد بـ ﴿السُّوءَ﴾: الشرك {1}، ﴿ثُمَّ تَابُوا مِنْ بَعْدِ ذَلِكَ﴾: السوء، ﴿وَأَصْلَحُوا﴾، قال ابن عباس) {2}: يريد آمنوا وصدقوا وقاموا لله بفرائضه وانتهوا عن معاصيه {3}.وقال أهل المعاني: شَرَطَ مع التوبة الإصلاح؛ للاستدعاء إلى الصلاح وترك الاغترار بما سلف من التوبة {4}.وقوله تعالى: ﴿إِنَّ رَبَّكَ مِنْ بَعْدِهَا﴾ أي من بعد تلك الجهالة {5} ﴿لَغَفُورٌ رَحِيمٌ﴾."
  16,120,"قوله تعالى: ﴿إِنَّ إِبْرَاهِيمَ كَانَ أُمَّةً﴾ قال ابن مسعود وابن عباس في رواية الكلبي: مُعَلِّمًا للخير، وهو قول أكثر أهل التفسير {1}.قال ابن الأعرابي: يقال للرجل العالم: أُمَّة، والأُمَّةُ: الرجل الجامع للخير {2}.وقال ابن عباس في رواية {3} الضحاك في قوله: ﴿كَانَ أُمَّةً﴾ قال: كان على الإسلام ولم يمكن في زمانه أحدٌ على الإسلام غيرُه {4}، فلذلك قال الله تعالى: ﴿كَانَ أُمَّةً﴾.وقال مجاهد: كان مؤمنًا وحده والناس كفار كلهم، وهو قول إبراهيم {5}، وقال ابن قتيبة: أي إماما يَقْتَدِى به الناس؛ لأنه ومن اتبعه أُمَّة، فَسُمِّي أُمَّة؛ لأنه سبب الاجتماع {6}، هذا وجه قول من قال: أُمَّةً: معلمًا للخير.ومن قال: أُمَّةً أي: مؤمنًا وحده؛ فلأنه اجتمع عنده من خلال الخير ما يكون مِثْلُه في أُمَّة، ومن هذا يقال: فلان أُمَّة وحْدَه، أي هو يقوم مقام أمة {7}، والكلام في وجوه الأمة ومعانيها قد تقدم {8}.وقوله تعالى: ﴿قَانِتًا لِلَّه﴾ قال ابن عباس والجميع: مطيعًا لله {9}.وقوله تعالى: ﴿حَنِيفًا﴾ قال ابن عباس: يريد أنه أول من اختتن وأقام مناسك الحج وضَحَّى، هذه صفة الحنيفية {10}، والقنوت والحنيفية مما تقدم القول فيه {11}.وقوله تعالى: ﴿وَلَمْ يَكُ مِنَ الْمُشْرِكِينَ﴾ قال ابن عباس: يريد أخلص لله التوحيد صبيًّا وكبيرًا {12}، وذكرنا وجه حذف النون مِنْ يكن عند قوله: ﴿فَلَا تَكُ فِي مِرْيَةٍ مِمَّا يَعْبُدُ هَؤُلَاءِ﴾ {13} في سورة هود [109]."
  16,121,""
  16,122,"قوله تعالى: ﴿وَآتَيْنَاهُ فِي الدُّنْيَا حَسَنَةً﴾ قال علي بن أبي طلحة عن ابن عباس: يقول: الذكر الحسن {1}، وقال في رواية عطاء: يريد الصدق والوفاء والعبادة {2}.وقال الحسن: النبوة {3}. وقال مجاهد: لسان صدق في الآخرين {4}.وقال الكلبي: الثناء الحسن من بعده {5}.وقال مقاتل: يعني الصلوات عليه مقرونًا بالصلاة على محمد -ﷺ-؛ وهو قول المتشهد: اللهم صل على محمد وعلى آل محمد كما صليت على إبراهيم {6}، وهذه الأقوال متقاربة وجملتها تعود إلى تنويه الله بِذِكْره في الدنيا بطاعته لربه، ومسارعته إلى مرضاته، وإخلاصه في عبادته، حتى صار إمامًا يُقْتَدَى به، قال قتادة: فليس من أهل دين إلا يتولونه ويرضون به {7}.وقوله تعالى: ﴿وَإِنَّهُ فِي الْآخِرَةِ لَمِنَ الصَّالِحِينَ﴾ وهو أيضًا كان في الدنيا من الصالحين، فلذلك قال: إن [من] {8} بمعنى (مع)، وقال أهل المعاني: إنما قال: ﴿وَإِنَّهُ فِي الْآخِرَةِ لَمِنَ الصَّالِحِينَ﴾، ولم يقل: في أعلى منازل الصالحين بحسب ما تقتضيه حاله من الفضل؛ لمدح من هو منهم، والترغيب في الصلاح ليكون صاحبُه في جَنْبِه إبراهيم، وناهيك بهذا الترغيب في الصلاح، وبهذا المدح لإبراهيم أن يُشَرَّفَ جُمْلة هو فيها، حتى يصير الاستدعاء إليه بأنه فيها {9}.قوله تعالى: ﴿ثُمَّ أَوْحَيْنَا إِلَيْكَ أَنِ اتَّبِعْ مِلَّةَ إِبْرَاهِيمَ حَنِيفًا﴾ الآية. هذا يدل على أن دين محمد -ﷺ- دين إبراهيم، وشريعته كشريعته؛ حيث أُمر باتباعه وأُمرنا باتباعه، وهو الأفضل بسبقه إلى القول بالحق والعمل به من غير تقصير، وفيه قال عبد الله بن عمرو: أُمر باتباعه في مناسك الحج كما علَّم جبريلُ إبراهيمَ عليهما السلام {10}."
  16,123,""
  16,124,"قوله تعالى: ﴿إِنَّمَا جُعِلَ السَّبْتُ عَلَى الَّذِينَ اخْتَلَفُوا فِيهِ﴾ الآية. قال مجاهد: اختلفوا فيه واتبعوه وتركوا الجمعة {1}.وقال السدي: إن الله فرض على اليهود الجمعة فأبوا، وقالوا: يا موسى، إن الله لم يخلق يومًا أثقل علينا ولا أبغض إلينا من يوم الجمعة، فاجعل لنا يوم السبت، فلما جعل لهم السبت استحلوا منه ما حرم عليهم {2}.وقال الكلبي عن أبي صالح عن ابن عباس: أمرهم موسى بالجمعة فقال: تفرغوا لله في كل سبعة أيام يومًا واحدًا فاعبدوه في يوم الجمعة ولا تعملوا فيه شيئًا من صنعتكم، فأبوا أن يقبلوا ذلك وقالوا: لا نبغي إلا اليوم الذي فُرغ فيه من الخلق، يوم السبت، فجُعل عليهم السبت وشُدِّدَ عليهم فيه، ثم جاءهم عيسى بالجمعة، فقال النصارى: لا نريد أن يكون عِيدُهم بعد عيدنا فاتخذوا الأحد، هذا الذي ذكرنا هو قول أكثر المفسرين في هذه الآية {3}، وهو معنى ما روى أبو هريرة أن النبيَّ -ﷺ- قال: ""إن الله كتب الجمعة على من كان قبلنا فاختلفوا فيه وهدانا الله له فالناس لنا فيه تبع اليهود غدًا والنصارى بعد غد"" {4} {5}.وعلى هذا القول معنى قوله: ﴿عَلَى الَّذِينَ اخْتَلَفُوا فِيهِ﴾، أي: اختلفوا فيه على نبيهم موسى؛ حيث أمرهم بالجمعة فاختاروا السبت، فاختلافهم في السبت كان اختلافًا على نبيهم في ذلك اليوم {6}، أي لأجله لأنهم اختاروه ولم يختلفوا في اختياره، وهذا مما أشكل على كثير من المفسرين حتى قال بعضهم: معنى الاختلاف في السبت أن بعضهم قال هو أعظم الأيام حرمة؛ لأن الله فرغ فيه من خلق الأشياء، وقال آخرون: لا بل الأحد؛ لأن الله ابتدأ خلق الأشياء فيه {7}، وهذا غلط؛ لأن اليهود لم يكونوا فريقين في يوم السبت، وإنما اختار الأحد النصارى بعدهم بزمان طويل.وقال بعض المفسرين أيضًا: أكثر اليهود قالوا: نريد اليوم الذي فرغ الله فيه من خلق الأشياء، وكان شرذمة منهم يرغبون في الجمعة، فهذا اختلافهم {8}، وهذا القول أيضًا في الفساد كالأول، ولم يرو {9} أحدٌ أن اليهود اختلفوا في اختيار السبت حتى مال بعضهم إلى الجمعة، ولكن لمّا أشكل على هؤلاء وجه اختلافهم في السبت تخبطوا واضطربوا حتى أتوا بما لا وجه له.وفي الآية قولٌ ثانٍ، وهو ما رواه عطاء عن ابن عباس قال: ﴿عَلَى الَّذِينَ اخْتَلَفُوا فِيهِ﴾، يريد تهاونوا وصادوا فيه وتعدوا {10}.وقال قتادة: استحله بعضهم وحرمه بعضهم {11}.وهذا قول سعيد بن جبير، وعلى هذا معنى اختلافهم في السبت: اختلافهم في استحلاله بالصيد فيه، وتحريمُه: ما ذكر الله تعالى قصتهم في سورة الأعراف [163] زمن داود، والوجه هو القول الأول؛ لأن السبت جعل عليهم من أول ما اختاروه لا من زمن داود -عليه السلام-، ومعنى فجعل عليهم: أي جعل ذلك اليوم عقوبة وتشديدًا عليهم، ولم يجعل لهم ذلك اليوم كما ذكر الكلبي: أنهم لما تركوا الجمعة وأرادوا السبت بَدَلَها، جعل عليهم السبت وشدّد عليهم فيه، والآية تدل على نسخ ما سبق من الشريعة في السبت بشريعة محمد -ﷺ-، حيث أخبر أن السبت جعل عليهم ولم يجعل علينا.وذكر بعض أهل المعاني أن وجه اتصال معنى هذه الآية بمعنى الآية السابقة هو: أنه لمّا أُمر النبيّ -ﷺ- باتباع الحق، حذر من الاختلاف عليه فيه بما ذكر من حال الذين اختلفوا على نبيهم في السبت بما ليس لهم أن يختلفوا فيه، فشدد عليهم أمره وضيق {12}.وذكر أبو إسحاق القولين في هذه الآية فقال: جاء في التفسير أنهم أُمروا بأن يتخذوا الجمعة عيدًا، فخالفوا وقالوا: نريد يوم السبت، واختار القول الأول فقال: هو أدل على ما جاء في الاختلاف في السبت {13}."
  16,125,"قوله تعالى: ﴿ادْعُ إِلَى سَبِيلِ رَبِّكَ﴾ قال ابن عباس: دين ربك {1}.﴿بِالْحِكْمَةِ﴾ قال أهل التفسير: بالنبوة {2}، ﴿وَالْمَوْعِظَةِ الْحَسَنَةِ﴾ يعني مواعظ القرآن، ﴿وَجَادِلْهُمْ بِالَّتِي هِيَ أَحْسَنُ﴾ أي افتلهم عما هم عليه، غير فظ ولا غليظ القلب في ذلك، أي ألن لهم جانبك {3}، ومعنى: {بِالَّتِي هِيَ أَحْسَنُ} بالكلمة التي هي أحسن.قال مجاهد: أي أعرض عن أذاهم إياك كله {4}، قال: لا تقابلهم بسوء، وهذا قبل الأمر بالقتال.وقال عطاء عن ابن عباس: ﴿بِالَّتِي هِيَ أَحْسَنُ﴾ بلا إله إلا الله {5}، كأنه قال: جادلهم بهذه الكلمة، ﴿إِنَّ رَبَّكَ هُوَ أَعْلَمُ﴾ إلى آخرها، معناه: هو أعلم بالفريقين، فهو يأمرك فيهما بما فيه الصلاح."
  16,126,"قوله تعالى: ﴿وَإِنْ عَاقَبْتُمْ فَعَاقِبُوا﴾ الآية. هذه الآية فيها ثلاثة أقوال للمفسرين:أحدها: وهو الذي عليه العامة، أنها نزلت لمّا قال النبيّ -ﷺ- حين نظر إلى حمزة وقد مُثِّلَ به: ""والله لأمثلن بسبعين منهم مكانك""، فنزل جبريل والنبيّ -ﷺ- واقف بعد، بخواتيم سورة النحل، فصبر رسول الله -ﷺ- وكفّر عن يمينه وأمسك عما أراد، هذا قول ابن عباس في رواية عطاء وأبي بن كعب والشعبي {1}، وعلى هذا قالوا: سورة النحل كلها مكية إلا هذه الآيات الثلاث، فإنها نزلت بالمدينة {2}.القول الثاني: أن هذا كان قبل الأمر بالسيف والجهاد حين كان المسلمون قد أمروا بقتال من يقاتلهم ولا يبدؤوا بالقتال، وهو قوله: ﴿وَقَاتِلُوا فِي سَبِيلِ اللَّهِ الَّذِينَ يُقَاتِلُونَكُمْ وَلَا تَعْتَدُوا﴾ [البقرة: 190]، وفي هذه الآية أُمروا أن يعاقبوا بمثل ما أصابهم من العقوبة ولا يزيدوا، فلما نزلت سورة برآءة نُسخت هذه الآية، كما نُسخ قولُه: ﴿وَقَاتِلُوا فِي سَبِيلِ اللَّهِ﴾ الآية. وهذا قول ابن عباس والضحاك {3}.القول الثالث: أن هذه الآية نزلت في نهي المظلوم أن ينال من ظالمه أكثر مما نال منه ، وهذا قول مجاهد وإبراهيم وابن سيرين وسفيان {4}؛ قال مجاهد في هذه الآية: لا تعتدوا {5}.وقال ابن سيرين: يقول: إنْ أَخذَ رجلٌ منك شيئًا فخذ منه مثله {6}، ونحوه لفظ إبراهيم.وقال سفيان: لا تأخذ دينارًا مكان درهم {7}، وعلى هذا القول: الآية محكمة {8}.غير أن علي بن أبي طلحة روى عن ابن عباس أنه قال: نزلت هذه الآية وقوله: ﴿فَمَنِ اعْتَدَى عَلَيْكُم﴾ الآية، [البقرة: 194] وقوله: ﴿وَلَمَنِ انْتَصَرَ بَعْدَ ظُلْمِهِ﴾ [الشورى: 41]، وقوله: ﴿وَجَزَاءُ سَيِّئَةٍ سَيِّئَةٌ مِثْلُهَا﴾ الآية، [الشورى:41] بمكة، والمسلمون يومئذ قليل، ليس لهم سلطان يقهر المشركين، فأمر الله المسلمين أن يجازوا بمثل ما أتى إليهم أو يصبروا فهو أمثل، فلما هاجر رسول الله -ﷺ- إلى المدينة وأعز الإسلام، أَمرَ المسلمين أن ينتهوا في مظالمهم إلى {9} سلطانهم، وأن لا يعدو بعضهم على بعض كأهل الجاهلية، فقال: ﴿وَمَنْ قُتِلَ مَظْلُومًا فَقَدْ جَعَلْنَا لِوَلِيِّهِ سُلْطَانًا﴾ الآية. [الإسراء: 33] يقول: ينصره السلطان حتى ينصفه من ظالمه، فمن انتصر لنفسه دون السلطان فهو عاص مسرف قد عمل بحمية الجاهلية ولم يرض بحكم الله {10}، فعلى هذا نُسخ من الآية أن يتولى المظلوم أخذَ القصاص، بل يجب أن يرفع ذلك إلى السلطان حتى يعاقب خصمه بمثل ما عاقبه، ثم أخبر أن الصبر خير وأفضل، فقال: ﴿وَلَئِنْ صَبَرْتُم﴾، أي: عن المجازاة بالمُثْلَة، أو على ما يصيبكم من أذى المشركين، أو على ظلم من ظلمكم، ﴿لَهُوَ﴾، أي: الصبر، ﴿خَيْرٌ لِلصَّابِرِينَ﴾."
  16,127,"ثم أمر نبيه -عليه السلام- بالصبر عزمًا، فقال: ﴿وَاصْبِرْ وَمَا صَبْرُكَ إِلَّا بِاللَّهِ﴾، أي: بتوفيقه ومعونته، ﴿وَلَا تَحْزَنْ عَلَيْهِمْ﴾، أي: على المشركين بإعراضهم عنك، وقيل: على قتلى {1} أُحد؛ فإنهم أفضوا إلى رحمة الله وكرامته {2}.وقوله: ﴿وَلَا تَكُ فِي ضَيْقٍ مِمَّا يَمْكُرُون﴾، قراءة العامة بفتح الضاد {3}، واختاره أبو عبيد، وقال: لأن الضِّيق بالكسر في قلة المعاش والمساكن، وما كان في القلب فإنه الضَّيْق {4}.وقال أبو عمرو: الضَّيْق، بفتح الضاد: الغَمُّ، والضِّيق، بالكسر: الشدة {5}، ونحو هذا قال الفراء: الضَّيْق: ما ضاق عنه صدرك، والضَّيق: ما يكون في الذي يتسع؛ مثل الدار والثوب وأشباه ذلك {6}.وقال أبو عبيدة: ضَيْق تخفيف ضَيِّق، مثل مَيِّت، يقال: أمر ضَيْق وضَيّق {7}.وقال أبو الحسن الأخفش: الضيق: مصدر ضاق يضيق ضَيْقًا، وضِيْقًا، لغتان في المصدر {8}.قال أبو علي: وينبغي أن يحمل ضيق هاهنا على أنه مصدر لا على ما قال أبو عبيدة؛ لأن فيه {9} إقامة الصفة مقام الموصوف من غير ضرورة {10}، ولأن المعنى: لا تكن في ضيق، أي لا يضق {11} صدرك من مكرهم، كما قال: ﴿وَضَائِقٌ بِهِ صَدْرُكَ﴾ [هود: 12]، وليس المعنى: ولا تَكُ في أمرٍ ضَيِّق {12}، وقرأ ابن كثير في ﴿ضِيق﴾ بكسر الضاد {13}، وهما لغتان كما قال أبو الحسن، فمن كسر في معنى من فتح {14}، وذكرنا أبلغ وأتم من هذا في سورة النمل [آية: 70]."
  16,128,"قوله تعالى: ﴿إِنَّ اللَّهَ مَعَ الَّذِينَ اتَّقَوْا﴾ قال ابن عباس: يريد خَافَوْني ولم يشركوا بي شيئًا، ﴿وَالَّذِينَ هُمْ مُحْسِنُونَ﴾ يريد موحدون، وقال الحسن: اتقوا الله فيما حرم عليهم وأحسنوا فيما افترض عليهم {1}، ونحوه قال الكلبي: اتقوا الفواحش والكبائر {2}.﴿وَالَّذِينَ هُمْ مُحْسِنُونَ﴾: في العمل. وقال الزجاج في هذه الآية: قد وعدوا النصر {3}، أي أن الله ناصرهم كما قال: ﴿لَا تَحْزَنْ إِنَّ اللَّهَ مَعَنَا﴾ [التوبة: 40]."
