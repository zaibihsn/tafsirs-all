tafsir[19]{c,v,t}:
  82,1,"﴿إِذَا السَّمَاءُ انْفَطَرَتْ﴾، قال المفسرون {1}: انفطارهَا: انشقاقها {2}، كقوله: ﴿وَيَوْمَ تَشَقَّقُ السَّمَاءُ﴾ [المزمل: 18]، وقوله: {السَّمَاءُ مُنْفَطِرٌ بِهِ} [الفرقان: 25]قال الخليل: ولم يأت هذا على الفعل، إنما هو كقوله: مُرْضِعٌ، وحَامل، وحائض، ولو كان على الفعل لكان: منفطرة، كما قال: ﴿إِذَا السَّمَاءُ انْفَطَرَتْ﴾ {3}."
  82,2,""
  82,3,"﴿وَإِذَا الْبِحَارُ فُجِّرَتْ﴾، فجرت بعضها في بعض، فصارت بحرًا واحدًا، واختلط العذب بالملح، (هذا قول جماعة المفسرين) {1} {2}.وقال الحسن {3}، والضحاك {4}: فجرت فذهب مَاؤها ويبست."
  82,4,"﴿وَإِذَا الْقُبُورُ بُعْثِرَتْ﴾، قال أبو عبيدة {1}، (والمبرد) {2} {3}: أثيرت وقلب أسفلها أعلاها كقولك: بعثرت المتاع، إذا قلبته، والبحثرة، والبعثرة {4} {5} إثارة الشيء بقلب باطنه إلى ظاهره.وقال الليث: بعثر يبعثر بعثرة إذا قلب التراب {6}.قال ابن عباس {7}، والكلبي {2}، ومقاتل {2}: يريد عند البعث بحثت عن الموتى فأخرجوا منها {10}.وقال أبو إسحاق: أي قلب ترابها وبُعث الموتى الذين فيها {11}."
  82,5,"(قوله تعالى) {1}: ﴿عَلِمَتْ نَفْسٌ مَا قَدَّمَتْ وَأَخَّرَتْ﴾، قال عكرمة: ما أدت إلى الله مما أمَرها به، ومَا ضيعت {2} مما أمرت به {3}.وقال ابن مسعود: ما قدمت من خير ومَا أخرت من سُنة استن بها بعده {4}.وهو قول (الكلبي {5}، ومجاهد {5}، وقتادة {7}، وعطاء {8}، والقرظي {5} {10}.وهذه الآية مفسرة في قوله {11} [القيامة: 13]."
  82,6,"(قوله) {1}: ﴿يَا أَيُّهَا الْإِنْسَانُ﴾ {2}، مخاطبة للكفار. لقوله: ﴿مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ﴾ (أي مَا خدعك، وسول إليك الباطل حتى أضعت ما وجب عليك) {3}والمعنى: مَا الذي أمنك من عقابه، ويقال: غره بفلان، إذا أمنه المحذور من جهته وهو غير مأمون، وهذا كقوله ﴿وَلَا يَغُرَّنَّكُمْ بِاللَّهِ الْغَرُورُ﴾ [فاطر: 5].قال (عطاء عن) {1} ابن عباس: نزلت في الوليد بن المغيرة {5}.وقال الكلبي: نزلت في أبي الأشدين كَلَدة بن أسيد، وذلك أنه ضرب النبي -ﷺ- {6}، فلم يعاقبه الله وأنزل هذه الآية {7}.يقول: مَا الذي غرك بربك الكريم المتجاوز عنك إذ لم يعاقبك عَاجلًا بكفرك.وذكر المفسرون: الذي غره، فقال قتادة: غره العدو المسلط عليه، يعني الشيطان {8}.وقال الربيع بن خيثم {9}: غره الجهل {10}، وهو يروى مرفوعًا {11}.وقال مقاتل: غره عفو الله عنه حين لم يعاقبه في أول أمره {12}.﴿الَّذِي خَلَقَكَ﴾، قال {13}: أي من نطفة ولم تك شيئا، ثم سواك رجلًا تسمع وتبصر {14}.وقوله {15} (تعالى) {16}: ﴿فَعَدَلَكَ﴾، قال الفراء: جعلك معتدلًا، معدل {17} الخلق {18}.وقال أبو علي الفارسي: عَدّل خلقك فأخرجك في أحسن تقويم، وهيّأ فيك بلطفِ الخلقِة وتعديلها ما قَدَرْتَ به على مَا لم يقدرْ عليه غيرك {19}.قال عطاء عن ابن عباس: جعلك قائمًا معتدلًا حسن الصورة {20}.وقال مقاتل: يريد (عدل) {1} خلقك في العينين، والأذنين، واليدين، والرجلين، ولم يجعله كله واحدًا {22}.وعلى هذا المعنى عدل بين ما خلق لك من الأعضاء التي في الإنسان منها اثنان.وقرأ الكوفيون: ""فعدلك"" بالتخفيف {23}.قال الفراء: ووجهه فصرفك {24} إلى أي صورة شاء، قال: والتشديد أحسن الوجهين؛ لأنك تقول: عدلك إلى كذا، كما تقول: عدلك إلى كذا، ولا يحسن عدلتك فيه {25}، ففي القراءة الأولى جعل ""في"" من قوله، ﴿فِي أَيِّ صُورَةٍ﴾ صلة للتركيب، وهو حسن.وفي القراءة الثانية: جعل صلة لقوله: ""فعدلك""، وهو ضعيف، هذا معنى كلامه {15}.ونحو هذا ذكر أبو عبيد حجة لاختيار التشديد {27}.وقال أبو علي {28}: على معنى التخفيف عَدلَ بعضه ببعض فكنت معتدل الخلقة متناسبها، فلا تفاوت فيها {29}، ولا يلزم على هذا ما لزم {30} الفراء."
  82,7,""
  82,8,"وقوله {1} (تعالى) {2}: ﴿فِي أَيِّ صُورَةٍ مَا شَاءَ رَكَّبَكَ﴾قال مجاهد: في صورة أب، أو خال، أو عم {3}، ويدل على صحة هذا ما روى أن النبي -ﷺ- قال {4}: ""وإذا استقرت النطفة في الرحم أحضرها الله كل نسب بينها وبين آدم"" {5}.وذكر الفراء {6}، والزجاج {7} قولًا آخر: ""في أي صورة ما شاء ركبك"" إما طويلًا، وإما قصيرًا، وإما مستحسنًا، وإما غير ذلك، و""ما"" في قوله: ""مَا شاء"" صلة مؤكدة.وقال {8} أبو صالح {9}، ومقاتل {10}: يقول إن شاء ركبك في غير صورة الإنسان من صورة كلب، أو صورة حمار، أو صورة خنزير، أو قرد.وعلى هذا يكون ""مَا"" في معنى الشرط، والجزاء، فيكون المعنى: في أي صورة مَا شاء أن يركبك فيها ركبك. ذكره أبو إسحاق {11}."
  82,9,"فقال: ﴿كَلَّا﴾ {1}، قال مقاتل: أي لا يؤمن هذا الإنسان {2}.ثم قال: ﴿بَلْ تُكَذِّبُونَ بِالدِّينِ﴾، يعني بالجزاء والحساب فيزعمون أنه غير {3} كائن {4}.ثم أعلم أن أعمالهم محفوظة عليهم فقال: ﴿وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ﴾، أي من الملائكة يحفظون عليكم أعمالكم {5}."
  82,10,""
  82,11,"ثم نعتهم فقال: ﴿كِرَامًا كَاتِبِينَ﴾، قال الكلبي: يعني على ربهم {1}. وهو مفسر في قوله: ﴿كِرَامٍ بَرَرَةٍ﴾ [عبس: 16]﴿كَاتِبِينَ﴾، يكتبون أعمال بني آدم."
  82,12,"﴿يَعْلَمُونَ مَا تَفْعَلُونَ﴾، من خير أو شر فيكتبونه عليكم {1}."
  82,13,"﴿إِنَّ الْأَبْرَار﴾ {1}، قال عطاء {2} {3}، ومقاتل {4}: يريد أولياء الله المطيعين في الدنيا.﴿لَفِي نَعِيمٍ﴾ الجنة في الآخرة."
  82,14,"﴿وَإِنَّ الْفُجَّارَ﴾ يريد الذين كذبوا النبي-ﷺ-.﴿لَفِي جَحِيمٍ﴾ عظيم من النار."
  82,15,"﴿يَصْلَوْنَهَا﴾ {1} يلزمونها {2} مقاسين وهجها {3}.﴿يَوْمَ الدِّينِ﴾ أي يوم الجزاء، وهو يوم القيامة."
  82,16,""
  82,17,"ثم عظم ذلك اليوم فقال: ﴿وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ﴾."
  82,18,""
  82,19,"ثم أخبر عنه فقال: ﴿يَوْمَ لَا تَمْلِكُ نَفْسٌ لِنَفْسٍ شَيْئًا﴾ {1}، قال أبو إسحاق: الرفع {2} في ""يوم"" على الصفة لقوله: ﴿يَوْمُ الدِّينِ﴾ -قال- ويجوز أن يكون رفعًا بإضمار ""هو"" فيكون المعنى: هو يوم الدين يوم لا تملك، -قال- ويجوز أن يكون في موضع رفع، وهو مبني على الفتح لإضافته إلى قوله: ""يوم لا تملك"" ومَا أضيف إلى غير المتمكن {3} قد يبنى على الفتح، وإن كان في موضع رفع أو جر كما قال:لم يَمْنَع الشُّرْبَ مِنَهم غَيْرَ أن نَطقَتَ ... حَمَامَةٌ في غصُون ذاتِ أوْ قَالِ {4} فبنى {5} (""غير"" على) {6} الفتح لما أضيف {7} إلى قوله نطقت -قال- وجائز أن يكون نصبه على معنى هذه الأشياء المذكورة فيكون {8} يوم لا تملك نفس لنفس شيئا {9}.وذكر أبو علي وجهًا آخر للنصب وهو: أن اليوم لما جرى في أكثر الأمر ظرفًا ترك على مَا كان يكون عليه في أكثر أمره، والدليل على ذلك: ما اجتمع عليه القراء، والعرب في قولهم: ﴿مِنْهُمُ الصَّالِحُونَ وَمِنْهُمْ دُونَ ذَلِكَ﴾ [الأعراف: 168]، ﴿وَأَنَّا مِنَّا الصَّالِحُونَ وَمِنَّا دُونَ ذَلِكَ﴾ [الجن: 11]، ولا يرفع ذلك أحد، ومما يقوى النصب قوله: ﴿وَمَا أَدْرَاكَ مَا الْقَارِعَةُ (3) يَوْمَ يَكُونُ النَّاسُ﴾ [القارعة: 3 - 4] وقوله: ﴿يَسْأَلُونَ {10} أَيَّانَ يَوْمُ الدِّينِ (12) يَوْمَ {11} هُمْ عَلَى النَّارِ يُفْتَنُونَ﴾ [الذاريات: 12 - 13]، فالنصب في ﴿يَوْمَ لَا تَمْلِكُ﴾ مثل هذا.قال أبو الحسن {12}: ولو رفع ذلك كله كان جيدًا {13}والذي ذكر أبو إسحاق من البناء على الفتح إنما يجوز أن يكون ذلك عند الخليل، وسيبويه، إذا كانت الإضافة إلى الفعل الماضي نحو:على حين عاتبت {14}ومع الفعل المستقبل لا يجوز البناء عندهم ويجوز ذلك في قول الكوفيين {15} -وقد ذكرنا هذه المسألة {16} عند قوله: {هَذَا يَوْمُ يَنْفَعُ الصَّادِقِينَ} {17}، قال مقاتل: يعني لا تقدر نفس لنفس، يعني للكفار شيئا من المنفعة {18}.قوله تعالى {19}: ﴿وَالْأَمْرُ يَوْمَئِذٍ لِلَّهِ﴾، قال: يقول: لا يملك الأمر غيره وحده، قال قتادة: ليس ثم أحد يقضي شيئًا {16} أو يصنع شيئًا إلا الله رب العالمين {21}.والمعنى: أن الله تعالى لم يُمَلِّك في ذلك اليوم أحدًا شيئًا من الأمور كما ملكهم في دار الدنيا."
