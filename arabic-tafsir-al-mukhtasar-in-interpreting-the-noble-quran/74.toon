tafsir[56]{c,v,t}:
  74,1,"يا أيها المُتَغَشِّي بثيابه (وهو النبي صلى الله عليه وسلم)."
  74,2,"انهض فخوِّف من عذاب الله."
  74,3,"وعَظِّمْ ربك."
  74,4,"وطهِّر نفسك من الذنوب وثيابك من النجاسات."
  74,5,"وابتعد عن عبادة الأوثان."
  74,6,"ولا تمنن على ربك بأن تستكثر عملك الصالح."
  74,7,"واصبر لله على ما تلاقيه من الأذى."
  74,8,"فإذا نُفِخَ في القرن النفخة الثانية."
  74,9,"فذلك اليوم يوم شديد."
  74,10,"على الكافرين بالله وبرسله غير سهل."
  74,11,"اتركني - أيها الرسول - ومن خلقته وحيدًا في بطن أمه دون مال أو ولد (وهو الوليد بن المُغِيرة)."
  74,12,"وجعلت له مالًا كثيرًا."
  74,13,"وجعلت له بنين حاضرين معه ويشهدون المحافل معه لا يفارقونه لسفر لكثرة ماله."
  74,14,"وبسطت له في العيش والرزق والولد بسطًا."
  74,15,"ثم يطمع مع كفره بي أن أزيده بعد ما أعطيته من ذلك كله."
  74,16,"ليس الأمر كما تصوّر، إنه كان معاندًا لآياتنا المنزلة على رسولنا مكذبًا بها."
  74,17,"سأكلفه مشقة من العذاب لا يستطيع تحمّلها."
  74,18,"إن هذا الكافر الذي أنعمت عليه بتلك النعم فكّر فيما يقوله في القرآن لإبطاله، وقدّر ذلك في نفسه."
  74,19,"فلُعِن وعُذِّب كيف قَدَّر."
  74,20,"ثم لعن وعذّب كيف قَدَّر."
  74,21,"ثم أعاد النظر والتروِّي فيما يقول."
  74,22,"ثم قَطَّب وجهه وكَلَح حين لم يجد ما يطعن به في القرآن."
  74,23,"ثم أدبر عن الإيمان، واستكبر عن اتباع النبي صلى الله عليه وسلم."
  74,24,"فقال: ليس هذا الذي جاء به محمد كلام الله، بل هو سحر يرويه عن غيره."
  74,25,"ليس هذا كلام الله، بل هو كلام الإنس."
  74,26,"سأدخل هذا الكافر طبقة من طبقات النار، وهي سَقَر يقاسي حرّها."
  74,27,"وما أعلمك - يا محمد - ما سَقَر؟!"
  74,28,"لا تُبْقِي شيئًا من المُعَذَّب فيها إلا أتت عليه، ولا تتركه، ثم يعود كما كان، ثم تأتي عليه، وهكذا دَوَالَيْك."
  74,29,"شديدة الإحراق والتغيير للجلود."
  74,30,"عليها تسعة عشر مَلَكًا، وهم خَزَنتها."
  74,31,"وما جعلنا خَزَنة النار إلا ملائكة، فلا طاقة للبشر بهم، وما جعلنا عددهم هذا إلا اختبارًا للذين كفروا بالله؛ ليقولوا ما قالوا فيُضاعَف عليهم العذاب، وليتيقّن اليهود الذين أعطوا التوراة، والنصارى الذين أعطوا الإنجيل حين نزل القرآن مصدقًا لما في كتابيهم، وليزداد المؤمنون إيمانًا عندما يوافقهم أهل الكتاب، ولا يرتاب اليهود والنصارى والمؤمنون، وليقول المترددون في الإيمان، والكافرون: أي شيء أراده الله بهذا العدد الغريب؟! مثل إضلال مُنْكِر هذا العدد وهداية المُصَدِّق به، يُضِلُّ الله من شاء أن يضلّه ويهدي من شاء أن يهديه، وما يعلم جنود ربك من كثرتها إلا هو سبحانه، وما النار إلا تذكرة للبشر يعلمون بها عظمة الله سبحانه."
  74,32,"ليس القول كما يزعم بعض المشركين أنه يكفي أصحابه خَزَنة جهنم حتى يُجْهِضهم عنها، أقسم الله بالقمر."
  74,33,"وأقسم بالليل حين ولّى."
  74,34,"وأقسم بالصبح إذا أضاء."
  74,35,"إنّ نار جهنم لإحدى البلايا العظيمة."
  74,36,"ترهيبًا وتخويفًا للناس."
  74,37,"لمن شاء منكم - أيها الناس - أن يتقدم بالإيمان بالله والعمل الصالح، أو يتأخر بالكفر والمعاصي."
  74,38,"كل نفس بما كسبته من الأعمال مأخوذة، فإما أن توبقها أعمالها، وإما أن تخلِّصها وتنقذها من الهلاك."
  74,39,"إلا المؤمنين فإنهم لا يُؤْخذون بذنوبهم، بل يتجاوز عنها لما لهم من عمل صالح."
  74,40,"وهم يوم القيامة في جنات يسأل بعضهم بعضًا."
  74,41,"عن الكافرين الذين أهلكوا أنفسهم بما عملوا من المعاصي."
  74,42,"يقولون لهم: ما أدخلكم في جهنم؟"
  74,43,"فيجيبهم الكفار قائلين: لم نكن من الذين يؤدون الصلاة الواجبة في الحياة الدنيا."
  74,44,"ولم نكن نطعم الفقير مما أعطانا الله."
  74,45,"وكنا مع أهل الباطل ندور معهم أينما داروا، ونتحدث مع أهل الضلال والغواية."
  74,46,"وكنا نكذب بيوم الجزاء."
  74,47,"وتمادينا في التكذيب به حتى جاءنا الموت، فحال بيننا وبين التوبة."
  74,48,"فما تنفعهم يوم القيامة وساطة الشافعين من الملائكة والنبيين والصالحين؛ لأن من شرط قَبول الشفاعة الرضا عن المشفوع له."
  74,49,"أي شيء جعل هؤلاء المشركين معرضين عن القرآن؟!"
  74,50,"كأنهم في إعراضهم ونفورهم منه حُمُر وَحْش شديدة النفور."
  74,51,"نفرت من أسد خوفًا منه."
  74,52,"بل يريد كل واحد من هؤلاء المشركين أن يصبح عند رأسه كتاب منشور يخبره أن محمدًا رسول من الله، وليس سبب ذلك قلة البراهين أو ضعف الحجج، وإنما هو العناد والاستكبار."
  74,53,"ليس الأمر كذلك، بل السبب في تماديهم في ضلالهم أنهم لا يؤمنون بعذاب الآخرة، فبقوا على كفرهم."
  74,54,"ألا إن هذا القرآن موعظة وتذكير."
  74,55,"فمن شاء أن يقرأ القرآن ويتعظ به قرأه واتعظ به."
  74,56,"وما يتعظون إلا أن يشاء الله أن يتعظوا، هو سبحانه أهل لأن يُتَّقَى بامتثال أوامره واجتناب نواهيه، وأهل لأن يغفر ذنوب عباده إذا تابوا إليه."
