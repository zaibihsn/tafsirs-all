tafsir[15]{c,v,t}:
  91,1,"أقسم الله بالشمس، وأقسم بوقت ارتفاعها بعد طلوعها من مشرقها."
  91,2,"وأقسم بالقمر إذا تبع أثرها بعد غروبها."
  91,3,"وأقسم بالنهار إذا كشف ما على وجه الأرض بضوئه."
  91,4,"وأقسم بالليل إذا يغشى وجه الأرض، فيصير مظلمًا."
  91,5,"وأقسم بالسماء، وأقسم ببنائها المتقن."
  91,6,"وأقسم بالأرض، وأقسم ببسطها؛ ليسكن الناس عليها."
  91,7,"وأقسم بكل نفس، وأقسم بخلق الله لها سوية."
  91,8,"فأفهمها من غير تعليم ما هو شرّ لتجتنبه، وما هو خير لتأتيه."
  91,9,"قد فاز بمطلوبه من طهّر نفسه بتحليتها بالفضائل، وتخليتها عن الرذائل."
  91,10,"وقد خسر من دَسَّ نفسه مخفيًا إياها في المعاصي والآثام."
  91,11,"كذبت ثمود نبيها صالحًا بسبب مجاوزتها الحدّ في ارتكاب المعاصي، واقتراف الآثام."
  91,12,"حين قام أشقاهم بعد انتداب قومه له."
  91,13,"فقال لهم رسول الله صالح عليه السلام: اتركوا ناقة الله، وشِرْبها في يومها، فلا تتعرضوا لها بسوء."
  91,14,"فكذبوا رسولهم في شأن الناقة، فقتلها أشقاهم مع رضاهم بما فعل، فكانوا شركاء في الإثم، فأطبق الله عليهم عذابه، فأهلكهم بالصيحة بسبب ذنوبهم، وسوّاهم في العقوبة التي أهلكهم بها."
  91,15,"فعل الله بهم من العذاب ما أهلكهم غير خائف سبحانه من تبعاته."
