tafsir[44]{c,v,t}:
  70,1,"دعا داعٍ من المشركين على نفسه وقومه بعذاب إن كان هذا العذاب حاصلًا، وهو سخرية منه، وهو واقع يوم القيامة."
  70,2,"للكافرين بالله، ليس لهذا العذاب من يرده."
  70,3,"من الله ذي العلو والدرجات والفواضل والنعم."
  70,4,"تصعد إليه الملائكة وجبريل في تلك الدرجات، في يوم القيامة؛ وهو يوم طويل مقداره خمسون ألف سنة."
  70,5,"فاصبر - أيها الرسول - صبرًا لا جَزَع فيه ولا شكوى."
  70,6,"إنهم يرون هذا العذاب بعيدًا مستحيل الوقوع."
  70,7,"ونراه نحن قريبًا واقعًا لا محالة."
  70,8,"يوم تكون السماء مثل المُذَاب من النحاس والذهب وغيرهما."
  70,9,"وتكون الجبال مثل الصوف في الخِفَّة."
  70,10,"ولا يسأل قريب قريبًا عن حاله؛ لأن كل واحد مشغول بنفسه."
  70,11,"يشاهد كل إنسان قريبه لا يخفى عليه، ومع ذلك لا يسأل أحد أحدًا لهول الموقف، يودّ من استحق النار أن يقدم أولاده للعذاب بدلًا منه."
  70,12,"ويفتدي بزوجته وأخيه."
  70,13,"ويفتدي بعشيرته الأقربين منه، الذين يقفون معه في الشدائد."
  70,14,"ويفتدي بمن في الأرض جميعًا من الإنس والجن وغيرهما، ثم يسلّمه ذلك الافتداء، وينقذه من عذاب النار."
  70,15,"ليس الأمر كما تمنّى هذا المجرم، إنها نار الآخرة تلتهب وتشتعل."
  70,16,"تفصل جلدة الرأس فصلًا شديدًا من شدة حرّها واشتعالها."
  70,17,"تنادي من أعرض عن الحق، وأبعد عنه ولم يؤمن به ولم يعمل."
  70,18,"وجَمَع المال، وضنّ بالإنفاق منه في سبيل الله."
  70,19,"إن الإنسان خُلِق شديد الحرص."
  70,20,"إذا أصابه ضُرٌّ من مرض أو فقر كان قليل الصبر."
  70,21,"وإذا أصابه ما يُسَرُّ به من خَصْب وغنًى كان كثير المنع لبذله في سبيل الله."
  70,22,"إلا المصلّين، فهم سالمون من تلك الصفات الذميمة."
  70,23,"الذين هم على صلاتهم مواظبون، لا ينشغلون عنها، ويؤدونها في وقتها المحدد لها."
  70,24,"والذين في أموالهم نصيب محدد مفروض."
  70,25,"يدفعونه للذي يسألهم وللذي لا يسألهم ممن حرم الرزق لأي سبب كان."
  70,26,"والذين يصدّقون بيوم القيامة، يوم يجازي الله كلًّا بما يستحقّه."
  70,27,"والذين هم من عذاب ربهم خائفون، مع ما قدموا من أعمالهم الصالحة."
  70,28,"إن عذاب ربهم مخوف لا يأمنه عاقل."
  70,29,"والذين هم لفروجهم حافظون بسترها وإبعادها عن الفواحش."
  70,30,"إلا من زوجاتهم أو ما ملكوا من الإماء، فإنهم غير ملومين في التمتع بهنّ بالوطء فما دونه."
  70,31,"فمن طلب الاستمتاع بغير ما ذُكِر من الزوجات والإماء، فأولئك هم المتجاوزون لحدود الله."
  70,32,"والذين هم لما ائتمنوا عليه من الأموال والأسرار وغيرهما، ولعهودهم التي عاهدوا عليها الناس - حافظون، لا يخونون أماناتهم، ولا ينقضون عهودهم."
  70,33,"والذين هم قائمون بشهاداتهم على الوجه المطلوب، لا تؤثر قرابة ولا عداوة فيها."
  70,34,"والذين هم على صلاتهم يحافظون؛ بأدائها في وقتها، وبطهارة وطمأنينة، لا يشغلهم عنها شاغل."
  70,35,"أولئك الموصوفون بتلك الصفات في جنات مُكْرَمون؛ بما يلقونه من النعيم المقيم، والنظر إلى وجه الله الكريم."
  70,36,"فما الذي جرّ هؤلاء المشركين من قومك - أيها الرسول - حَوَاليك مسرعين إلى التكذيب بك؟!"
  70,37,"محيطون بك عن يمينك وشمالك جماعات جماعات."
  70,38,"أيأمل كل واحد منهم أن يدخله الله جنة النعيم، يتنعم بما فيها من النعيم المقيم، وهو باقٍ على كفره؟!"
  70,39,"ليس الأمر كما تصوّروا، إنا خلقناهم مما يعرفونه، فقد خلقناهم من ماء حقير، فهم ضعفاء لا يملكون لأنفسهم نفعًا ولا ضرًّا، فكيف يتكبرون؟!"
  70,40,"أقسم الله تعالى بنفسه، وهو رب المشارق والمغارب للشمس والقمر وسائر الكواكب، إنا لقادرون."
  70,41,"على تبديلهم بغيرهم ممن يطيع الله، ونهلكهم، لا نعجز عن ذلك، ولسنا بمغلوبين متى أردنا إهلاكهم وتبديلهم بغيرهم."
  70,42,"فاتركهم - أيها الرسول - يخوضوا فيما هم فيه من الباطل والضلال، ويلعبوا في حياتهم الدنيا إلى أن يلاقوا يوم القيامة الذي كانوا يوعدون به في القرآن."
  70,43,"يوم يخرجون من القبور سراعًا كأنهم إلى عَلَمٍ يتسابقون."
  70,44,"ذليلة أبصارهم، تغشاهم ذلة، ذلك هو اليوم الذي كانوا يوعدون به في الدنيا، وكانوا لا يبالون به."
