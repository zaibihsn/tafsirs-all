tafsir[21]{c,v,t}:
  92,1,"أقسم الله بالليل إذا يغطي ما بين السماء والأرض بظلمته."
  92,2,"وأقسم بالنهار إذا تكشّف وظهر."
  92,3,"وأقسم بخلقه النوعين: الذكر والأنثى."
  92,4,"إن عملكم - أيها الناس - لمختلف، فمنه الحسنات التي هي سبب دخول الجنة، والسيئات التي هي سبب دخول النار."
  92,5,"فأما من أعطى ما يلزمه بذله؛ من زكاة ونفقة وكفارة، واتقى ما نهى الله عنه."
  92,6,"وصدَّق بما وعده الله به من الخَلَف."
  92,7,"فسنُسَهِّل عليه العمل الصالح، والإنفاق في سبيل الله."
  92,8,"وأما من بخل بماله فلم يبذله فيما يجب عليه بذله فيه، واستغنى بماله عن الله فلم يسأل الله من فضله شيئًا."
  92,9,"وكذَّب بما وعده الله من الخَلَف ومن الثواب على إنفاق ماله في سبيل الله."
  92,10,"فسنُسَهِّل عليه عمل الشرّ، ونُعَسِّر عليه فعل الخير."
  92,11,"وما يغني عنه ماله الذي بخل به شيئًا إذا هلك، ودخل النار."
  92,12,"إن علينا أن نبيّن طريق الحق من الباطل."
  92,13,"وإن لنا لَلْحياة الآخرة ولنا الحياة الدنيا، نتصرّف فيهما بما نشاء، وليس ذلك لأحد غيرنا."
  92,14,"فحذّرتكم - أيها الناس - من نار تتوقد إن أنتم عصيتم الله."
  92,15,"لا يقاسي حرّ هذه النار إلا الأشقى وهو الكافر."
  92,16,"الذي كذَّب بما جاء به الرسول صلى الله عليه وسلم، وأعرض عن امتثال أمر الله."
  92,17,"وسيُباعَد عنها أتقى الناس أبو بكر رضي الله عنه."
  92,18,"الذي ينفق ماله في وجوه البر ليتطهر من الذنوب."
  92,19,"ولا يبذل ما يبذل من ماله ليكافئ نعمة أنعم بها أحد عليه."
  92,20,"لا يريد بما يبذله من ماله إلا وجه ربه العالي على خَلْقِه."
  92,21,"ولسوف يرضى بما يعطيه الله من الجزاء الكريم."
