tafsir[50]{c,v,t}:
  77,1,"أقسم الله بالرياح المتتابعة مثل عُرف الفرس."
  77,2,"وأقسم بالرياح الشديدة الهبوب."
  77,3,"وأقسم بالرياح التي تنشر المطر."
  77,4,"وأقسم بالملائكة التي تنزل بما يفرق بين الحق والباطل."
  77,5,"وأقسم بالملائكة التي تنزل بالوحي."
  77,6,"تنزل بالوحي إعذارًا من الله إلى الناس، وإنذارًا للناس من عذاب الله."
  77,7,"إن الذي توعدون به من البعث والحساب والجزاء لواقع لا محالة."
  77,8,"فإذا النجوم مُحِيَ نورها وذهب ضوؤها."
  77,9,"وإذا السماء شُقَّت لتنزّل الملائكة منها."
  77,10,"وإذا الجبال اقتُلِعت من مكانها فَفُتِّتَتْ حتى تصير هباءً."
  77,11,"وإذا الرسل جُمِعت لوقت محدد."
  77,12,"ليوم عظيم أُجِّلت للشهادة على أممها."
  77,13,"ليوم الفصل بين العباد، فيتبين المحق من المبطل، والسعيد من الشقي."
  77,14,"وما أعلمك - أيها الرسول - ما يوم الفصل؟!"
  77,15,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين الذين يكذبون بما جاءت به الرسل من عند الله."
  77,16,"ألم نهلك الأمم السابقة لما كفرت بالله وكذبت رسلها؟!"
  77,17,"ثم نتبعهم المكذبين من المتأخرين، فنهلكهم كما أهلكناهم."
  77,18,"مثل الإهلاك لتلك الأمم نهلك المجرمين المكذبين بما جاء به محمد صلى الله عليه وسلم."
  77,19,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بوعيد الله بالعقاب للمجرمين."
  77,20,"ألم نخلقكم - أيها الناس - من ماء حقير قليل وهو النُّطْفة."
  77,21,"فجعلنا ذلك الماء المَهِين في مكان مَحْروز وهو رحم المرأة."
  77,22,"إلى مُدّة معلومة هي مدّة الحمل."
  77,23,"فقدَّرنا صفة المولود وقَدْرَه ولونه وغير ذلك، فنعم القادرون لذلك كله نحن."
  77,24,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بقدرة الله."
  77,25,"ألم نجعل الأرض تضمّ الناس جميعًا."
  77,26,"تضمّ أحياءهم بالسكن عليها وعمارتها، وأمواتهم بالدفن فيها."
  77,27,"وجعلنا فيها جبالًا ثوابتَ، تمنعها من الاضطراب، عاليات، وأسقيناكم - أيها الناس - ماءً عذبًا، فمن خلق ذلك ليس عاجزًا عن بعثكم."
  77,28,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بنعم الله عليهم."
  77,29,"ويقال للمكذبين بما جاءت به رسلهم: سيروا - أيها المكذبون - إلى ما كنتم به تكذبون من العذاب."
  77,30,"سيروا إلى ظل من دخان النار مفترق ثلاث فرق."
  77,31,"ليس فيه برد الظلال، ولا يمنع لهيب النار وحرّها أن ينفذ إليكم."
  77,32,"إن النار تقذف بشرارات، كل شرارة مثل القصر في عظمها."
  77,33,"كأن الشرارات التي تقذف بها في سوادها وضخامتها جِمال سود."
  77,34,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بعذاب الله."
  77,35,"هذا يوم لا يتكلمون فيه بشيء."
  77,36,"ولا يُؤْذَن لهم أن يعتذروا إلى ربهم من كفرهم وسيئاتهم، فيعتذرون إليه."
  77,37,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بأخبار هذا اليوم."
  77,38,"هذا يوم الفصل بين الخلائق، جمعناكم والأمم السابقة في صعيد واحد."
  77,39,"فإن كانت لكم حيلة تحتالون بها للنجاة من عذاب الله فاحتالوا عليّ."
  77,40,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بيوم الفصل."
  77,41,"إن المتقين لربهم بامتثال أوامره واجتناب نواهيه، في ظلال أشجار الجنة الوارفة، وعيون الماء العذبة الجارية."
  77,42,"وفواكه مما يشتهون أكله."
  77,43,"ويقال لهم: كلوا من الطيبات، واشربوا شرابًا هنيئًا لا مُنَغِّص فيه؛ بما كنتم تعملون في الدنيا من الأعمال الصالحات."
  77,44,"إنا مثل هذا الجزاء الذي جزيناكم به نجزي المحسنين لأعمالهم."
  77,45,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بما أعد الله للمتقين."
  77,46,"ويقال للمكذبين: كلوا وتمتعوا بملذات الحياة وقتًا قليلًا في الدنيا، إنكم بكفركم بالله وتكذيبكم رسله مجرمون."
  77,47,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين بجزائهم يوم الدين."
  77,48,"وإذا قيل لهؤلاء المكذبين: صلّوا لله لا يصلّون له."
  77,49,"هلاك وعذاب وخسران في ذلك اليوم للمكذبين الذين يكذبون بما جاءت به الرسل من عند الله."
  77,50,"فإذا لم يؤمنوا بهذا القرآن المنزل من ربهم فبأي حديث غيره يؤمنون؟!"
