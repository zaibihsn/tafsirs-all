tafsir[96]{c,v,t}:
  56,1,"إذا قامت القيامة لا محالة."
  56,2,"لن توجد نفس تكذّب بها كما كانت تكذّب في الدنيا."
  56,3,"خافضة للكفار الفجار بإدخالهم في النار، رافعة للمؤمنين المتقين بإدخالهم في الجنة."
  56,4,"إذا حُرِّكت الأرض تحريكًا عظيمًا."
  56,5,"وفُتِّتت الجبال تفتيتًا."
  56,6,"فكانت من التفتيت غبارًا منتشرًا لا ثبات لها."
  56,7,"وكنتم أصنافًا ثلاثة في ذلك اليوم:"
  56,8,"فأصحاب اليمين الذين يأخذون كتبهم بأيمانهم، ما أعلى وأعظم منزلتهم!"
  56,9,"وأصحاب الشمال الذين يأخذون كتبهم بشمائلهم، ما أخسّ وأسوأ منزلتهم!"
  56,10,"والسابقون بفعل الخيرات في الدنيا هم السابقون في الآخرة لدخول الجنة."
  56,11,"أولئك هم المقربون عند الله."
  56,12,"في جنات النعيم، يتنعمون بأصناف النعيم."
  56,13,"جماعة من هذه الأمة ومن الأمم السابقة."
  56,14,"وقليل من الناس في آخر الزمان هم من السابقين المقربين."
  56,15,"على أَسِرّة منسوجة بالذهب."
  56,16,"متكئين على هذه الأسرّة متقابلين بوجوههم، لا ينظر أحدهم قفا غيره."
  56,17,"يدور عليهم لخدمتهم وِلْدان لا ينالهم هَرَم ولا فناء."
  56,18,"يدورون عليهم بأقداح لا عُرَى لها، وأباريق لها عُرًى، وكأس من خمر جارية في الجنة لا تنقطع."
  56,19,"ليست كخمر الدنيا، فلا يلحق شاربها صداع، ولا ذهاب عقل."
  56,20,"ويدور عليهم هؤلاء الوِلْدان بفاكهة مما يختارون."
  56,21,"ويدورون بلحم طير مما تشتهيه أنفسهم."
  56,22,"ولهم في الجنة نساء واسعات العيون في جمال."
  56,23,"كأمثال اللؤلؤ المَصُون في صَدَفه."
  56,24,"ثوابًا لهم على ما كانوا يعملونه من الأعمال الصالحات في الدنيا."
  56,25,"لا يسمعون في الجنة فاحش كلام، ولا ما يلحق صاحبه إثم."
  56,26,"لا يسمعون إلا سلام الملائكة عليهم، وسلام بعضهم على بعض."
  56,27,"وأصحاب اليمين - الذين يُعطون كتبهم بأيمانهم - ما أعظم مكانتهم وشأنهم عند الله!"
  56,28,"في سِدْر مقطوع الشوك، لا أذى فيه."
  56,29,"وفي موز متراكم مصفوف بعضه إلى بعض."
  56,30,"وظل ممدود مستمرّ لا يزول."
  56,31,"وماء جار لا يتوقف."
  56,32,"وفاكهة كثيرة لا تنحصر."
  56,33,"لا تنقطع عنهم أبدًا، فليس لها موسم، ولا يحول دونها مانع في أي وقت أرادوها."
  56,34,"وفرش مرفوعة عالية توضع على الأسرّة."
  56,35,"إنا أنشأنا الحور المذكورات إنشاءً غير مألوف."
  56,36,"فصيّرناهنّ أبكارًا لم يُلْمَسن من قبل."
  56,37,"مُتَحَبِّبات إلى أزواجهنّ، مستويات في السنّ."
  56,38,"أنشأناهنّ لأصحاب اليمين الذين يؤخذ بهم ذات اليمين علامة على سعادتهم."
  56,39,"هم جماعة من أمم الأنبياء السابقين."
  56,40,"وجماعة من أمة محمد صلى الله عليه وسلم وهي آخر الأمم."
  56,41,"وأصحاب الشمال - الذين يعطون كتبهم بشمالهم - ما أسوأ حالهم ومصيرهم!"
  56,42,"في رياح شديدة الحرارة، وفي ماء شديد الحرارة."
  56,43,"وفي ظل دخان مُسْودّ."
  56,44,"لا طيّب الهبوب، ولا حسن المنظر."
  56,45,"إنهم كانوا قبل ما صاروا إليه من العذاب مُتَنَعِّمين في الدنيا، لا هَمَّ لهم إلا شهواتهم."
  56,46,"وكانوا يصممون على الكفر بالله وعبادة الأصنام من دونه."
  56,47,"وكانوا ينكرون البعث فيقولون استهزاءً واستبعادًا له: أإذا متنا وصرنا ترابًا وعظامًا نَخِرة أنبعث بعد ذلك؟!"
  56,48,"أَوَ يبعث آباؤنا الأولون الذين ماتوا قبلنا؟!"
  56,49,"قل - أيها الرسول - لهؤلاء المنكرين للبعث: إن الأولين من الناس والمتأخرين منهم."
  56,50,"سيُجْمعون يوم القيامة لا محالة للحساب والجزاء."
  56,51,"ثم إنكم - أيها المكذبون بالبعث، الضالون عن الصراط المستقيم - لآكلون يوم القيامة من ثمرِ شجرِ الزَّقُّوم، وهو شرّ ثمر وأخبثه."
  56,52,"56:51"
  56,53,"فمالئون من ذلك الشجر المُرِّ بطونكم الخاوية."
  56,54,"فشاربون عليه من الماء الحار الشديد الحرارة."
  56,55,"فمكثرون من شربه كما تكثر الإبل من الشرب بسبب داء الهُيَام."
  56,56,"هذا المذكور من الطعام المرّ والماء الحارّ هو ضيافتهم التي يُسْتَقبلون بها يوم الجزاء."
  56,57,"نحن خلقناكم - أيها المكذبون - بعد أن كنتم عدمًا، فهلَّا صدَّقتم بأنا سنبعثكم أحياء بعد موتكم؟!"
  56,58,"أفرأيتم - أيها الناس - ما تقذفونه من المني في أرحام نسائكم؟!"
  56,59,"أأنتم تخلقون ذلك المني، أم نحن الذين نخلقه؟!"
  56,60,"نحن قدرنا بينكم الموت، فلكل واحد منكم أجل لا يتقدم عليه ولا يتأخر، وما نحن بعاجزين."
  56,61,"على أن نبدل ما أنتم عليه من الخلق والتصوير مما علمتموه، وننشئكم فيما لا تعلمونه من الخلق والتصوير."
  56,62,"ولقد علمتم كيف خلقناكم الخلق الأول، أفلا تعتبرون وتعلمون أن الذي خلقكم أول مرة قادر على بعثكم بعد موتكم؟!"
  56,63,"أفرأيتم ما تلقونه من البذر في الأرض؟!"
  56,64,"أأنتم الذين تنبتون ذلك البذر، أم نحن الذين ننبته؟!"
  56,65,"لو نشاء جعْل ذلك الزرع حطامًا لجعلناه حطامًا بعد أن أوشك على النضج والإدراك، فظللتم بعد ذلك تتعجبون مما أصابه."
  56,66,"تقولون:إنا لمعذبون بخسارة ما أنفقناه."
  56,67,"بل نحن محرومون من الرزق."
  56,68,"أفرأيتم الماء الذي تشربون منه إذا عطشتم؟!"
  56,69,"أأنتم أنزلتموه من السحاب في السماء، أم نحن الذين أنزلناه؟!"
  56,70,"لو نشاء جعْل ذلك الماء شديد الملوحة لا يُنْتَفع به شربًا ولا سقيًا لجعلناه شديد الملوحة، فلولا تشكرون الله على إنزاله عَذْبًا رحمة بكم."
  56,71,"أفرأيتم النار التي توقدونها لمنافعكم؟!"
  56,72,"أأنتم الذين أنشأتم الشجرة التي توقَد منها، أم نحن الذين أنشأناها رفقًا بكم؟!"
  56,73,"نحن صيّرنا هذه النار تذكرة لكم تذكركم بنار الآخرة، وصيّرناها منفعة للمسافرين منكم."
  56,74,"فنزِّه - أيها الرسول - ربك العظيم عما لا يليق به."
  56,75,"أقسم الله بأماكن النجوم ومواقعها."
  56,76,"وإن القَسَم بهذه المواقع - لو تعلمون عظمه - لعظيم؛ لما فيه من الآيات والعبر التي لا تنحصر."
  56,77,"إن القرآن المقروء عليكم - أيها الناس - قرآن كريم؛ لما فيه من المنافع العظيمة."
  56,78,"في كتاب مَصُون عن أعين الناس، وهو اللوح المحفوظ."
  56,79,"لا يمسّه إلا الملائكة المطهَّرون من الذنوب والعيوب."
  56,80,"مُنَزَّل من رب الخلائق على نبيه محمد صلى الله عليه وسلم."
  56,81,"أفبهذا الحديث أنتم - أيها المشركون - مكذبون غير مصدقين؟!"
  56,82,"وتجعلون شكركم لله على ما رزقكم به من النعم أنكم تكذبون به، فتنسبون المطر إلى النَّوْء، فتقولون: مُطِرنا بنَوْء كذا ونَوْء كذا؟!"
  56,83,"فهلَّا إذا وصلت الروح الحلقوم."
  56,84,"وأنتم في ذلك الوقت تنظرون المُحْتَضَر بين أيديكم."
  56,85,"و نحن بعلمنا وقدرتنا وملائكتنا أقرب إلى ميتكم منكم، ولكن لا تشاهدون هؤلاء الملائكة."
  56,86,"فهلَّا - إن كنتم، كما تزعمون، غير مبعوثين لمجازاتكم على أعمالكم -"
  56,87,"ترجعون هذه الروح التي تخرج من ميتكم إن كنتم صادقين؟! ولا تستطيعون ذلك."
  56,88,"فأما إن كان الميت من السابقين إلى الخيرات."
  56,89,"فله راحة لا تعب بعدها، ورزق طيب، ورحمة، وله جنة يتنعم فيها بما تشتهيه نفسه."
  56,90,"وأما إن كان الميت من أصحاب اليمين فلا تهتمّ لشأنهم، فلهم السلامة والأمن."
  56,91,"56:90"
  56,92,"وأما إن كان الميت من المكذبين بما جاء به الرسول صلى الله عليه وسلم الضالين عن الصراط المستقيم."
  56,93,"فضيافته التي يستقبل بها ماء حارٌّ شديد الحرارة."
  56,94,"وله احتراق بنار الجحيم."
  56,95,"إن هذا الذي قصصناه عليك - أيها الرسول - لهو حق اليقين الذي لا مِرْية فيه."
  56,96,"فنزِّه اسم ربك العظيم، وقدِّسْه عن النقائص."
