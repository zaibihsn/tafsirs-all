tafsir[78]{c,v,t}:
  55,1,"الرحمن ذو الرحمة الواسعة."
  55,2,"علّم الناس القرآن بتسهيل حفظه، وتيسير فهم معانيه."
  55,3,"خلق الإنسان سويًّا، وأحسن تصويره."
  55,4,"علّمه كيف يُبِين عمَّا في ضميره نطقًا وكتابة."
  55,5,"الشمس والقمر قَدَّرهما؛ يسيران بحساب متقن؛ ليعلم الناس عدد السنين والحساب."
  55,6,"وما لا ساق له من النبات والشجر يسجدان لله سبحانه منقادَينِ مستسلمَينِ له."
  55,7,"والسماء رفعها فوق الأرض سقفًا لها، وأثبت العدل في الأرض، وأمر به عباده."
  55,8,"أثبت العدل لئلا تجوروا - أيها الناس - وتخونوا في الوزن والكيل."
  55,9,"وأقيموا الوزن بينكم بالعدل، ولا تنقصوا الوزن أو الكيل إذا كلتم أو وزنتم لغيركم."
  55,10,"والأرض وضعها مُهَيَّأة لاستقرار الخلق عليها."
  55,11,"فيها الأشجار التي تثمر الفواكه، وفيها النخل ذات الأوعية التي يكون منها التمر."
  55,12,"وفيها الحب ذو التِّبْن كالبُر والشعير، وفيها النباتات التي تستطيبون رائحتها."
  55,13,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,14,"خلق آدم عليه السلام من طين يابس تسمع له صلصلة، مثل الطين المطبوخ."
  55,15,"وخلق أبا الجن من لهب خالص من الدخان."
  55,16,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,17,"رب مَشْرِقَي الشمس ومغربيها شتاءً وصيفًا."
  55,18,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,19,"خلط الله البحرين المالح والعَذْب يلتقيان فيما تراه العين."
  55,20,"بينهما حاجز يمنع كلًّا منهما أن يطغى على الآخر حتى يبقى العَذْب عَذْبًا والمالح مالحًا."
  55,21,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,22,"يخرج من مجموع البحرين كبار الدُّر وصغاره."
  55,23,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,24,"وله سبحانه وتعالى وحده التصرف في السفن الجارية في البحار مثل الجبال."
  55,25,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,26,"كل من على وجه الأرض من الخلائق هالك لا محالة."
  55,27,"ويبقى وجه ربك - أيها الرسول - ذو العظمة والإحسان والتفضل على عباده، فلا يلحقه فناء أبدًا."
  55,28,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,29,"يسأله كل من في السماوات من الملائكة، ومن في الأرض من الجن والإنس؛ حاجاتِهم، كل يوم هو في شأن من شؤون عباده؛ من إحياء وإماتة ورزق وغير ذلك."
  55,30,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,31,"سنفرغ لحسابكم - أيها الإنس والجن - فنجازي كلًّا بما يستحقه من ثواب أو عقاب."
  55,32,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,33,"ويقول الله يوم القيامة إذا جمع الجن والإنس: يا معشر الجن والإنس، إن استطعتم أن تجدوا لكم مخرجًا من ناحية من نواحي السماوات والأرض فافعلوا، ولن تستطيعوا أن تفعلوا ذلك إلا بقوة وبينة، وأنَّى لكم ذلك؟"
  55,34,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,35,"يُرْسَل عليكما - أيها الإنس والجن - لهب من النار خالٍ من الدخان، ودخان لا لهب فيه، فلا تستطيعان الامتناع من ذلك."
  55,36,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,37,"فإذا تشققت السماء لنزول الملائكة منها فكانت حمراء مثل الدهن في إشراق لونه."
  55,38,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,39,"ففي ذلك اليوم العظيم لا يُسْأل إنس ولا جنّ عن ذنوبهم؛ لعلم الله بأعمالهم."
  55,40,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,41,"يُعْرف المجرمون يوم القيامة بعلامتهم وهي سواد الوجوه وزرقة العيون، فتُضَمّ نواصيهم إلى أقدامهم فيرمون في جهنم."
  55,42,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,43,"ويقال لهم توبيخًا: هذه جهنم التي يكذب بها المجرمون في الدنيا أمام أعينهم لا يستطيعون إنكارها."
  55,44,"يتردَّدون بينها وبين ماء حارٍّ شديد الحرارة."
  55,45,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,46,"وللذي خاف القيام بين يدي ربه في الآخرة فآمن وعمل صالحًا - جنتان."
  55,47,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,48,"وهاتان الجنتان ذواتا أغصان عظيمة نضرة مثمرة."
  55,49,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,50,"في الجنتين عينان تجريان خلالهما بالماء."
  55,51,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,52,"فيهما من كل فاكهة يُتَفَكَّه بها صنفان."
  55,53,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,54,"متكئين على فرش بطائنها من الديباج الغليظ، وما يُجْنَى من الثمار والفواكه من الجنتين قريب يتناوله القائم والجالس والمتكئ."
  55,55,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,56,"فيهن نساء قصرن نظرهنّ على أزواجهنّ، لم يَفْتَضِضْ بكارتهنّ قبل أزواجهنّ إنس ولا جانّ."
  55,57,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,58,"كأنهنّ الياقوت والمرجان جمالًا وصفاء."
  55,59,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,60,"ما جزاء من أحسن بطاعة ربه إلا أن يحسن الله جزاءه؟!"
  55,61,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,62,"ومن دون هاتين الجنتين المذكورتين جنتان أخريان."
  55,63,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,64,"قد اشتدّت خضرتهما."
  55,65,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,66,"في هاتين الجنتين عينان شديدتا الفَوَران بالماء، لا ينقطع فَوَران مائهما."
  55,67,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,68,"في هاتين الجنتين فاكهة كثيرة ونخل عظيم ورُمَّان."
  55,69,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,70,"في هذه الجنان نساء طيبات الأخلاق حسان الوجوه."
  55,71,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,72,"حور مستورات في الخيام صونًا لهنّ."
  55,73,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,74,"لم يقترب منهنَّ قبل أزواجهنّ إنس ولا جانّ."
  55,75,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,76,"متكئين على وسائد مغطاة بأغطية خضر، وفرش حسان."
  55,77,"فبأي نعم الله الكثيرة عليكم - يا معشر الجن والإنس - تكذبان؟!"
  55,78,"تعاظم وكثر خير اسم ربك ذي العظمة والإحسان والتفضل على عباده."
