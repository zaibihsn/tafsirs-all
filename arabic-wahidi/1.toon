quran[7]{c,v,t}:
  1,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بسم الله الرحمن الرحيم﴾</span> أَيْ: ابدؤوا أوِ افتتحوا بتسمية الله تيمُّناً وتبرُّكاً و <span class="qpc-hafs">﴿الله﴾</span> : اسمٌ تفرَّد الباري به سبحانه يجري فِي وصفه مجرى أسماء الأعلام لا يُعرف له اشتقاق وقيل: معناه: ذو العبادة التي بها يُقصد <span class="qpc-hafs">﴿الرَّحمن الرَّحيم﴾</span> : صفتان لله تعالى معناهما: ذو الرَّحمة أَي: الرَّحمة لازمةٌ له وهي إرادة الخير ولا فرق بينهما مثل: ندمانٍ ونديم</p></div>"
  1,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الحمدُ لله﴾</span> هو الثَّناء لله والشُّكرُ له بإنعامه <span class="qpc-hafs">﴿ربِّ العالمين﴾</span> : مالك المخلوقات كلها</p></div>"
  1,3,""
  1,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مالك يوم الدِّين﴾</span> مأخوذٌ من المِلْك والمِلْك مأخوذٌ من المُلْك أَيْ: قاضي يوم الجزاء والحساب لأنَّه متفرِّدٌ في ذلك اليوم بالحكم</p></div>"
  1,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إيَّاك نعبدُ﴾</span> أَيْ: نخصُّك ونقصدك بالعبادة وهي الطَّاعة مع الخضوع <span class="qpc-hafs">﴿وإيَّاك نستعين﴾</span> : ومنك نطلب المعونة</p></div>"
  1,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿اهدنا الصراط المستقيم﴾</span> أَيْ: دُلَّنا عليه واسلكْ بنا فيه وثبِّتنا عليه</p></div>"
  1,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صراط الذين أنعمتَ عليهم﴾</span> بالهداية وهم قومُ موسى وعيسى عليهما السَّلام قبل أن يُغيِّروا نعمَ الله عز وجل وقيل: هم الذين ذكرهم الله عز وجل في قوله تعالى <span class="qpc-hafs">﴿فأولئك مع الذين أنعم الله عليهم﴾</span> الآية <span class="qpc-hafs">﴿غير المغضوب عليهم﴾</span> أَيْ: غير الذين غضبتَ عليهم وهم اليهود ومعنى الغضب من الله تعالى: إرادةُ العقوبة <span class="qpc-hafs">﴿ولا الضَّالين﴾</span> أَيْ: ولا الذين ضلُّوا وهم النَّصارى فكأنَّ المسلمين سألوا الله تعالى أن يهديهم طريق الذين أنعم عليهم ولم يغضب عليهم كما غضب على اليهود ولم يضلُّوا عن الحقِّ كما ضلَّت النَّصارى</p></div>"
