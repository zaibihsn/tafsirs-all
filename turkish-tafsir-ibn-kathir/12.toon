  12,12,""
  12,13,""
  12,14,""
  12,15,""
  12,16,"Akşam üstü ağlaya ağlaya babalarına geldiler."
  12,17,""
  12,18,""
  12,19,""
  12,20,""
  12,21,""
  12,22,""
  12,23,""
