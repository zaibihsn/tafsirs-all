tafsir[42]{c,v,t}:
  80,1,""
  80,2,"Kendisine a´ma geldi diye."
  80,3,""
  80,4,""
  80,5,"Ama kendisini müstağni gören."
  80,6,""
  80,7,"Halbuki onun temizlenmemesinden sana ne?"
  80,8,""
  80,9,""
  80,10,""
  80,11,""
  80,12,"Dileyen onu düşünüp öğüy alır."
  80,13,""
  80,14,"Yüceltilmiş ve temizlenmiştir."
  80,15,"Katiblerin elleriyle."
  80,16,""
  80,17,"Canı çıksın o insanın. Ne de nankördür o."
  80,18,"Neden yaratmış onu?"
  80,19,""
  80,20,"Sonra ona tutacağı yolu kolaylaştırmış."
  80,21,""
  80,22,"Sonra dilediğinde onu tekrar çıkaracak."
  80,23,"Hayır; Allah´ın emrettiğini yerine getirmemiştir."
  80,24,"Öyle ya insan yiyeceğine bir baksın."
  80,25,""
  80,26,"Sonra toprağı iyiden iyiye yardık."
  80,27,"Böylece orada tane bitirdik."
  80,28,""
  80,29,""
  80,30,"Sık ve bol ağaçlı bahçeler."
  80,31,"Meyve ve mer´a."
  80,32,"Sizin ve hayvanlarınızın faydalanması için."
  80,33,"O büyük gürültü geldiği zaman;"
  80,34,""
  80,35,"Anasından ve babasından."
  80,36,"Eşinden ve oğullarından."
  80,37,"O gün; herkesin kendisine yeter bir işi vardır."
  80,38,""
  80,39,""
  80,40,""
  80,41,"Bir karanlık bürümüştür."
  80,42,"İşte bunlar; kafirler ve facirlerdir."
