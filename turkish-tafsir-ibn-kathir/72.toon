tafsir[28]{c,v,t}:
  72,1,""
  72,2,""
  72,3,"Muhakkak ki Rabbımızın şanı yücedir. O; eş ve çocuk edinmemiştir."
  72,4,"Doğrusu bizim beyinsizimiz; Allah´a karşı yalanlar söylüyormuş."
  72,5,"Doğrusu öyle zannettik ki; insanlar ve cinnler Allah´a karşı asla yalan söylemezler."
  72,6,"Doğrusu insanlardan bazı kimseler; cinnlerden bir takım kimselere sığınırlardı da onların azgınlıklarını artırırlardı."
  72,7,""
  72,8,""
  72,9,""
  72,10,""
  72,11,""
  72,12,""
  72,13,""
  72,14,""
  72,15,"Kendilerine yazık edenlere gelince; onlar da cehenneme odun oldular."
  72,16,""
  72,17,""
  72,18,""
  72,19,""
  72,20,"De ki: Ben; ancak Rabbıma yalvarırım. Ve O´na hiç kimseyi ortak koşmam."
  72,21,""
  72,22,""
  72,23,""
  72,24,""
  72,25,""
  72,26,"Gaybı bilendir. Gaybını kimseye açıklamaz."
  72,27,"Ancak beğenip seçtiği bir peygamber müstesnadır. Çünkü onun önünden ve ardından gözcüler koyar."
  72,28,""
