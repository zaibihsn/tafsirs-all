tafsir[19]{c,v,t}:
  82,1,"Gök yarıldığı zaman;"
  82,2,"Yıldızlar saçıldığı zaman;"
  82,3,"Denizler kaynaştığı zaman;"
  82,4,"Kabirlerin içi dışına getirildiği zaman;"
  82,5,"Kişi neyi takdim edip neyi te´hir ettiğini bilir."
  82,6,"Ey insan; keremi bol Rabbına karşı seni ne aldattı?"
  82,7,""
  82,8,"Seni istediği şekilde terkib etmiştir."
  82,9,""
  82,10,"Halbuki sizin üzerinizde koruyucular vardır."
  82,11,"Çok şerefli yazıcılar."
  82,12,"Ne yaptığınızı bilirler."
  82,13,"Şüphesiz ki iyiler; Cennettedirler."
  82,14,""
  82,15,"Din günü oraya girerler."
  82,16,"Ve orada kaybolacak değildirler."
  82,17,"Din gününün ne olduğunu sen nereden bileceksin."
  82,18,""
  82,19,""
