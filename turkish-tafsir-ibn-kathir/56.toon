tafsir[96]{c,v,t}:
  56,1,""
  56,2,"Onun vukuunu hiç bir yalanlayıcı yoktur."
  56,3,""
  56,4,"Yer; sarsıldıkça sarsıldığı;"
  56,5,""
  56,6,"Dağılmış toz haline geldiği zaman;"
  56,7,"Siz üç sınıf olmuşsunuzdur:"
  56,8,"Sağcılar; o sağcılar ne mutludurlar."
  56,9,"Solcular; o solcular ne bahtsızdırlar."
  56,10,"Önde olanlar da öncüdürler."
  56,11,"İşte onlar en çok gözde olanlardır."
  56,12,"Naim cennetlerindedirler."
  56,13,""
  56,14,"Birazı da sonrakilerden."
  56,15,"Murassa tahtlar üzerindedirler."
  56,16,"Karşılıklı olarak üzerinde yaslanırlar."
  56,17,"Ölümsüz civanlar etraflarında dolaşırlar."
  56,18,""
  56,19,""
  56,20,""
  56,21,""
  56,22,"Şahin gözlü huriler de;"
  56,23,"Saklı inci misali."
  56,24,"Yapmakta olduklarına karşılık olarak."
  56,25,""
  56,26,""
  56,27,"Sağcılar; ne bahtiyardır o sağcılar."
  56,28,""
  56,29,""
  56,30,""
  56,31,""
  56,32,""
  56,33,"Bitip tükenmeyen ve yasaklanmayan."
  56,34,"Yükseltilmiş döşekler üstündedirler."
  56,35,""
  56,36,"Ve onları el değmemişler kıldık."
  56,37,"Eşlerine düşkün hep bir yaşıtlar."
  56,38,"Sağcılar için."
  56,39,""
  56,40,"Bir çoğu da sonrakilerdendir."
  56,41,"Solcular da. Solcular kimlerdir?"
  56,42,""
  56,43,"Ve kapkara dumandan bir gölge içindedirler."
  56,44,""
  56,45,"Çünkü onlar; bundan önce refahla şımarmışlardı."
  56,46,"Ve büyük günah işlemekte direnip dururlardı."
  56,47,""
  56,48,"Önce gelmiş geçmiş atalarımız da mı?"
  56,49,""
  56,50,"Belli bir günün belli bir vaktinde mutlaka toplanacaklardır."
  56,51,""
  56,52,"Muhakkak ki yiyeceksiniz zakkum ağacından."
  56,53,"Karınlarınızı dolduracaksınız hep ondan."
  56,54,"Üstüne de içeceksiniz o kaynar sudan."
  56,55,"Susamış develerin suya saldırışı gibi içeceksiniz."
  56,56,"İşte ceza günü onlara sunulacak ziyafet budur."
  56,57,""
  56,58,"Söyleyin öyleyse; dökmekte olduğunuz meni nedir?"
  56,59,""
  56,60,""
  56,61,"Yerinize benzerlerinizi getirmekte ve sizi bilemeyeceğiniz bir yaratılışla tekrar var etmekte."
  56,62,"Andolsun ki; ilk yaratılışınızı bildiniz. İyice düşünmeli değil misiniz?"
  56,63,"Şimdi Bana; ekmekte olduğunuzu haber verin."
  56,64,""
  56,65,""
  56,66,""
  56,67,"Daha doğrusu biz mahrumlarız."
  56,68,""
  56,69,""
  56,70,"İsteseydik onu tuzlu bir su kılardık. Öyleyse şükretmeli değil misiniz?"
  56,71,""
  56,72,""
  56,73,""
  56,74,"Öyleyse Rabbını o büyük adıyla tesbih et."
  56,75,"Hayır yıldızların yerleri üzerine yemin ederim;"
  56,76,""
  56,77,"Şüphesiz o; şerefli bir Kur´an´dır."
  56,78,"Korunmuş bir kitabdadır."
  56,79,"Ona arınmış olanlardan başkası dokunamaz."
  56,80,"Alemlerin Rabbından indirilmedir."
  56,81,""
  56,82,"Rızkınızı yalanlamakla mı çıkarıyorsunuz?"
  56,83,"Hele can boğaza gelince;"
  56,84,"O vakit görürsünüz siz."
  56,85,""
  56,86,""
  56,87,"Onu geri çevirsenize. Şayet sadıklar iseniz."
  56,88,"Eğer o kişi gözdelerden ise;"
  56,89,""
  56,90,"Şayet sağcılardan ise;"
  56,91,"Selem sana sağcılardan."
  56,92,"Eğer sapık yalanlayıcılardan ise;"
  56,93,""
  56,94,"Ve cehenneme atılış."
  56,95,"Şüphesiz ki bu; kesin gerçeğin kendisidir."
  56,96,"Öyleyse Rabbını büyük adıyla tesbih et."
