tafsir[36]{c,v,t}:
  83,1,"Ölçüde ve tartıda hile yapanların vay haline."
  83,2,"Onlar ki; insanlardan bir şey aldıkları zaman kendileri ölçerek tam alırlar."
  83,3,""
  83,4,""
  83,5,"Büyük bir gün için."
  83,6,""
  83,7,""
  83,8,"Siccin´in ne olduğunu sen nereden bileceksin?"
  83,9,"Yazılmış bir kitabtır."
  83,10,""
  83,11,"Onlar ki; din gününü yalanlarlar."
  83,12,""
  83,13,""
  83,14,""
  83,15,""
  83,16,""
  83,17,""
  83,18,""
  83,19,"İlliyyin´in ne olduğunu sen nereden bileceksin?"
  83,20,"Yazılmış bir kitabdır."
  83,21,"Gözde melekler onu görür."
  83,22,""
  83,23,"Tahtlar üzerinde temaşa ederler."
  83,24,""
  83,25,""
  83,26,""
  83,27,"Onun katkısı yüce kaynaktandır."
  83,28,"Bir pınar ki; gözdeler ondan içerler."
  83,29,""
  83,30,"Yanlarından geçtiklerinde birbirlerine göz kırparlardı."
  83,31,""
  83,32,""
  83,33,""
  83,34,""
  83,35,""
  83,36,""
