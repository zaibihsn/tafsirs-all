tafsir[78]{c,v,t}:
  55,1,"Rahman."
  55,2,"Kur´an´ı öğretti."
  55,3,"İnsanı yarattı."
  55,4,"Ona beyanı öğretti."
  55,5,""
  55,6,"Bitkiler ve ağaçlar da secde ederler."
  55,7,""
  55,8,"Tartıda haksızlık etmeyin."
  55,9,""
  55,10,"Yeri de yaratıklar için alçalttı."
  55,11,""
  55,12,"Yapraklı taneler ve kokulu bitkiler var."
  55,13,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,14,"İnsanı pişmiş çamur gibi kupkuru bir balçıktan yaratmıştır."
  55,15,"Cinnleri de yalın bir alevden yaratmıştır."
  55,16,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,17,""
  55,18,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,19,"İki denizi birbirine kavuşmak üzere salıvermiştir."
  55,20,""
  55,21,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,22,"Her ikisinden de inci ve mercan çıkar."
  55,23,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,24,"Denizde yüzen koca dağlar gibi gemiler de O´nundur."
  55,25,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,26,"Onun üzerinde her bulunan fanidir."
  55,27,"Ancak celal ve ikram sahibi Rabbının zatı baki kalacaktır."
  55,28,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,29,"Göklerde ve yerde kim varsa hepsi O´ndan ister. O; her gün bir şe´n üzeredir."
  55,30,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,31,"Ey insanlar ve cinnler; yakında size de yöneleceğiz"
  55,32,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,33,"Ey cinnler ve insanlar topluluğu; göklerin ve yerin çevresinden geçip gitmeye gücünüz yetiyorsa geçip gidin. Ama üstün bir güç olmadan geçemezsiniz."
  55,34,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,35,"Üzerinize dumansız bir alev ve ateşsiz bir duman gönderilir de birbirinizi kurtaramaz ve yardımlaşamazsınız."
  55,36,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,37,""
  55,38,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,39,""
  55,40,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz. _"
  55,41,"Suçlular simalarından tanınırlar da perçemlerinden ve ayaklarından tutulurlar."
  55,42,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,43,""
  55,44,"Onlar bununla kaynar su arasında dolaşır dururlar."
  55,45,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,46,"Rabbının makamından korkana iki cennet vardır."
  55,47,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,48,"Her ikisi çeşit çeşit ağaçlarla doludur."
  55,49,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,50,"İkisinde de akmakta olan iki pınar vardır."
  55,51,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,52,"İkisinde de her tür meyveden çift çift vardır."
  55,53,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,54,"Hepsi de örtüleri atlastan döşemelere yaslanırlar. İki cennetin meyvelerini de kolayca toplarlar."
  55,55,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,56,""
  55,57,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,58,"Sanki onlar yakut ve mercandırlar."
  55,59,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,60,""
  55,61,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,62,"O ikisinden başka iki cennet daha vardır."
  55,63,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,64,"Koyu yeşildirler."
  55,65,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,66,"İkisinde de durmadan fışkıran iki kaynak vardır."
  55,67,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,68,""
  55,69,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,70,""
  55,71,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,72,"Otağlar içinde korunmuş huriler vardır."
  55,73,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,74,""
  55,75,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,76,"Yeşil yastıklara ve güzel işlemeli döşeklere yaslanırlar."
  55,77,"Şu halde Rabbınızın hangi nimetlerini yalan sayabilirsiniz?"
  55,78,"Celal ve ikram sahibi Rabbının adı ne yücedir."
