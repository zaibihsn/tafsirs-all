tafsir[11]{c,v,t}:
  93,1,""
  93,2,"Ve sükuna erdiğinde geceye."
  93,3,""
  93,4,""
  93,5,""
  93,6,"O; seni öksüz bulup da barındırmadı mı?"
  93,7,"Seni şaşırmış bulup da doğru yola eriştirmedi mi?"
  93,8,"Seni fakir bulup da zenginleştirmedi mi?"
  93,9,"O halde sakın yetime kahretme."
  93,10,"Ve bir şey isteyeni azarlama."
  93,11,"Rabbının nimetine gelince ondan sözet."
