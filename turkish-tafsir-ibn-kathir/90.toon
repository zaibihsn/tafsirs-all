tafsir[20]{c,v,t}:
  90,1,"Şu beldeye yemin ederim;"
  90,2,"Sen de bu beldede oturmuşsun."
  90,3,""
  90,4,""
  90,5,""
  90,6,""
  90,7,"Kimsenin kendisini görmediğini mi sanıyor?"
  90,8,"Biz; onun için iki göz var etmedik mi?"
  90,9,"Bir dil ve iki dudak."
  90,10,"Biz; ona iki de yol gösterdik."
  90,11,""
  90,12,"Sarp yokuşun ne olduğunu sen nereden bileceksin?"
  90,13,"Bir kul azad etmektir."
  90,14,""
  90,15,""
  90,16,"Yahut yerde sürünen bir yoksula."
  90,17,""
  90,18,""
  90,19,""
  90,20,"Onlara sımsıkı kapatılmış bir ateş vardır."
