tafsir[24]{c,v,t}:
  59,1,""
  59,2,""
  59,3,""
  59,4,""
  59,5,"Herhangi bir hurma ağacını kesmeniz veya kesmeyip gövdeleri üzerinde bırakmanız hep Allah´ın izniyledir. Bir de fasıkları rüsvay etmek içindir."
  59,6,""
  59,7,""
  59,8,""
  59,9,""
  59,10,""
  59,11,""
  59,12,"Andolsun ki; eğer onlar çıkarılsalar; onlarla beraber çıkmazlar. Eğer onlara savaş açılırsa; yardım etmezler. Yardıma gitseler bile; mutlaka gerisin geri dönerler. Sonra da kendileri yardım görmezler."
  59,13,""
  59,14,""
  59,15,"Kendilerinden az önce geçmiş ve işlerin vebalini tatmış olanların durumu gibidir. Onlar için elim bir azab vardır."
  59,16,""
  59,17,"Nihayet ikisinin de akıbeti; içinde ebediyyen kalacakları ateştir. İşte zalimlerin cezası budur."
  59,18,""
  59,19,""
  59,20,"Cehennem ashabı ile cennet ashabı bir değildir. Cennet ashabı; işte onlardır kurtuluşa erenler."
  59,21,""
  59,22,""
  59,23,""
  59,24,""
