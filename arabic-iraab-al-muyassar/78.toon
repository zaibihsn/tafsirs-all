quran[40]{c,v,t}:
  78,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عم﴾</span></span>: عن حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبني على السكون المقدر على الألف المحذوفة في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، وحذفت الألف من ما الاستفهامية لدخول حرف الجر عليها، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، لأنه من الأفعال الخمسة، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿عم يتساءلون﴾</span></span> ابتدائية لا محل لها من الإعراب.</p></div>"
  78,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عن النبأ﴾</span></span>: عن حرف جر، والنبأ اسم مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span> وعلامة جره الكسرة، والجار والمجرور متعلقان بفعل محذوف تقديره: يتساءلون.</p><p><span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿النبأ﴾</span></span> مجرور بالكسرة، والجملة لا محل لها من الإعراب، لأنها استئناف بياني.</p></div>"
  78,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>: اسم موصول مبني على السكون في محل جر نعت ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿النبأ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>: ضمير مبني على السكون في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span>: في حرف جر، والهاء ضمير مبني على الكسر في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مختلفون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مختلفون﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مرفوع بالواو، لأنه جمع مذكر سالم، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم فيه مختلفون﴾</span></span> صلة الاسم الموصول لا محل لها من الإعراب.</p></div>"
  78,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا﴾</span></span>: حرف ردع وزجر.</p><p><span class="hlt"><span class="qpc-hafs">﴿سيعلمون﴾</span></span>: السين حرف استقبال، ويعلمون فعل مضارع مرفوع وعلامة رفعه ثبوت النون، لأنه من الأفعال الخمسة، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل، ومفعول سيعلمون محذوف، أي: سيعلمون ما يحل بهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيعلمون...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  78,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿كلا﴾</span></span>: حرف ردع وزجر.</p><p><span class="hlt"><span class="qpc-hafs">﴿سيعلمون﴾</span></span>: السين حرف استقبال، ويعلمون فعل مضارع مرفوع وعلامة رفعه ثبوت النون، لأنه من الأفعال الخمسة، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل، ومفعول سيعلمون محذوف، أي: سيعلمون ما يحل بهم، والجملة لا محل لها من الإعراب معطوفة على سابقتها.</p></div>"
  78,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه السكون، وكسرت اللام لالتقاء الساكنين، والفاعل مستتر تقديره نحن.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span>: مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span> منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿مهادا﴾</span></span>: مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span> منصوب بالفتحة، والجعل ههنا بمعنى التصيير، أو يكون الجعل بمعنى الخلق و<span class="hlt"><span class="qpc-hafs">﴿مهادا﴾</span></span> حال، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  78,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والجبال﴾</span></span>: الواو حرف عطف مبني على الفتح، والجبال: مفعول به أول لفعل محذوف يدل عليه الفعل المذكور في الآية السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أوتادا﴾</span></span>: مفعول به ثانٍ للفعل المحذوف منصوب بالفتحة. والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span> لا محل لها من الإعراب.</p></div>"
  78,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخلقناكم﴾</span></span>: الواو حرف عطف، وخلق: فعل ماض مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل، والكاف ضمير مبني في محل نصب مفعول به، والميم علامة على الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿أزواجا﴾</span></span>: حال من مفعول <span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span> منصوبة بالفتحة، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span>: الواو حرف عطف مبني على الفتح، وجعل فعل ماض مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿نومكم﴾</span></span>: نوم مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> منصوب بالفتحة، والكاف ضمير مبني في محل جر مضاف إليه، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿سباتا﴾</span></span>: مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> منصوب بالفتحة، والجعل ههنا بمعنى التصيير، أو يكون الجعل بمعنى الخلق و<span class="hlt"><span class="qpc-hafs">﴿سباتا﴾</span></span> حال، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span>: الواو حرف عطف مبني على الفتح، وجعل فعل ماضٍ مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span>: مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لباسا﴾</span></span>: مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> منصوب بالفتحة. والجعل ههنا بمعنى التصيير، أو بمعنى الخلق و<span class="hlt"><span class="qpc-hafs">﴿لباسا﴾</span></span> حال، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span>: الواو حرف عطف مبني على الفتح، وجعل فعل ماض مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span>: مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿معاشا﴾</span></span>: مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> منصوب بالفتحة. والجعل ههنا بمعنى التصيير، أو بمعنى الخلق، و<span class="hlt"><span class="qpc-hafs">﴿معاشا﴾</span></span> حال، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبنينا﴾</span></span>: الواو حرف عطف، وبنى: فعل ماض مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوقكم﴾</span></span>: ظرف مكان منصوب بالفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿بنينا﴾</span></span>، والكاف ضمير مبني في محل جر مضاف إليه، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبعا﴾</span></span>: مفعول به منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿شدادا﴾</span></span>: نعت منصوب بالفتحة لـ<span class="hlt"><span class="qpc-hafs">﴿سبعا﴾</span></span>، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span>: الواو حرف عطف مبني على الفتح، وجعل فعل ماضٍ مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿سراجا﴾</span></span>: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهاجا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سراجا﴾</span></span> منصوب وعلامة نصبه الفتحة، والجعل هنا بمعنى الخلق فقط، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنزلنا﴾</span></span>: الواو حرف عطف مبني على الفتح، وأنزل فعل ماض مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من المعصرات﴾</span></span>: من حرف جر، والمعصرات اسم مجرور بالكسرة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثجاجا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ثجاجا﴾</span></span> منصوب وعلامة نصبه الفتحة، والجملة لا محل لها من الإعراب معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  78,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنخرج﴾</span></span>: اللام لام التعليل، ونخرج: فعل مضارع منصوب بأن المضمرة بعد اللام وعلامة نصبه الفتحة، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن نخرج﴾</span></span> مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: الباء حرف جر، والهاء ضمير مبني على الكسر في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نخرج﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿حبا﴾</span></span>: مفعول به منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونباتا﴾</span></span>: الواو حرف عطف و<span class="hlt"><span class="qpc-hafs">﴿نباتا﴾</span></span> اسم معطوف على <span class="hlt"><span class="qpc-hafs">﴿حبا﴾</span></span> منصوب بالفتحة، والجملة تعليلية لا محل لها من الإعراب.</p></div>"
  78,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجنات﴾</span></span>: الواو حرف عطف، وجنات اسم معطوف على <span class="hlt"><span class="qpc-hafs">﴿حبا﴾</span></span> منصوب بالكسرة، لأنه جمع مؤنث سالم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألفافا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ مبني على الفتح لا محل له من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: اسم إن منصوب وعلامة نصبه الفتحة، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفصل﴾</span></span>: مضاف إليه مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماض ناقص مبني على الفتح، واسمه ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿ميقاتا﴾</span></span>: خبر كان منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن يوم الفصل...﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  78,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم الفصل﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله.</p><p><span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span>: حرف جر مبني.</p><p><span class="hlt"><span class="qpc-hafs">﴿الصور﴾</span></span>: اسم مجرور وعلامة جره الكسرة، والجار والمجرور في محل رفع نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتأتون﴾</span></span>: الفاء حرف عطف مبني، وتأتون: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، لأنه من الأفعال الخمسة، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتون﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفواجا﴾</span></span>: حال من فاعل تأتون منصوبة وعلامة نصبها الفتحة.</p></div>"
  78,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفتحت﴾</span></span>: الواو حرف عطف مبني على الفتح، وفتحت فعل ماض مبني لما لم يسمَّ فاعله، والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: نائب فاعل مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكانت﴾</span></span>: الفاء حرف عطف مبني، وكانت فعل ماض ناقص مبني على الفتح، والتاء للتأنيث، واسمه ضمير مستتر تقديره: هي، عائد على السماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿أبوابا﴾</span></span>: خبر كان منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿فتحت﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span> لا محل لها من الإعراب.</p></div>"
  78,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسيرت﴾</span></span>: الواو حرف عطف مبني على الفتح، وسيرت فعل ماض مبني لما لم يسمَّ فاعله، والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجبال﴾</span></span>: نائب فاعل مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكانت﴾</span></span>: الفاء حرف عطف مبني، وكانت فعل ماض ناقص مبني على الفتح، والتاء للتأنيث، واسمه ضمير مستتر تقديره: هي، عائد على السماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿سرابا﴾</span></span>: خبر كان منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيرت﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span> لا محل لها من الإعراب.</p></div>"
  78,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ مبني على الفتح لا محل له من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿جهنم﴾</span></span>: اسم إن منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>: فعل ماض ناقص مبني على الفتح، والتاء للتأنيث، واسمه ضمير مستتر تقديره هي.</p><p><span class="hlt"><span class="qpc-hafs">﴿مرصادا﴾</span></span>: خبر كان منصوب، وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن جهنم...﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  78,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للطاغين﴾</span></span>: اللام حرف جر مبني، والطاغين: اسم مجرور وعلامة جره الياء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرصادا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مآبا﴾</span></span>: خبر كان الثاني منصوب وعلامة نصبه الفتحة.</p></div>"
  78,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لابثين﴾</span></span>: حال من الطاغين منصوبة وعلامة نصبها الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: في حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لابثين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحقابا﴾</span></span>: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لابثين﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يذوقون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، لأنه من الأفعال الخمسة، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: في حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذوقون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بردا﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، ولا: حرف لتوكيد النفي.</p><p><span class="hlt"><span class="qpc-hafs">﴿شرابا﴾</span></span>: اسم معطوف على <span class="hlt"><span class="qpc-hafs">﴿بردا﴾</span></span> منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يذوقون﴾</span></span> في محل نصب حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لابثين﴾</span></span>.</p></div>"
  78,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة وحصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿حميما﴾</span></span>: بدل من <span class="hlt"><span class="qpc-hafs">﴿شرابا﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وغساقا﴾</span></span>: الواو حرف عطف، وغساقا: اسم معطوف على <span class="hlt"><span class="qpc-hafs">﴿حميما﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>: مفعول مطلق لفعل محذوف، أي: يُجزون جزاء، منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وفاقا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>: إن حرف ناسخ مبني على الفتح لا محل له من الإعراب، والهاء ضمير مبني في محل رفع اسم إن، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: فعل ماض ناقص مبني على الفتح، واسمه ضمير مستتر تقديره هم.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يرجون﴾</span></span>: فعل مضارع مرفوع بثبوت النون، لأنه من الأفعال الخمسة، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسابا﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرجون﴾</span></span> في محل نصب خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا لا يرجون﴾</span></span> في محل رفع خبر إن، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  78,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذبوا﴾</span></span>: الواو حرف عطف، وكذب فعل ماضٍ مبني على الضم وواو الجماعة ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذابا﴾</span></span>: مفعول مطلق منصوب وعلامة نصبه الفتحة، وهو مصدر في بعض اللغات، والجملة لا محل لها من الإعراب معطوفة على سابقتها.</p></div>"
  78,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكل﴾</span></span>: الواو اعتراضية مبنية على الفتح. وكل: مفعول به لفعل محذوف، منصوب على الاشتغال وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>: مضاف إليه مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحصيناه﴾</span></span>: فعل ماضٍ مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل، والهاء ضمير مبني في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿كتابا﴾</span></span>:  مصدر في موضع الحال منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكل شيء أحصيناه﴾</span></span> اعتراضية لا محل لها من الإعراب.</p></div>"
  78,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذوقوا﴾</span></span>: الفاء حرف للاستئناف مبني على الفتح، وذوقوا فعل أمر مبني على حذف النون وواو الجماعة ضمير في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلن﴾</span></span>: الفاء حرف عطف، ولن حرف نفي ونصب واستقبال مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿نزيدكم﴾</span></span>: فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span> وعلامة نصبه الفتحة، والفاعل ضمير مستتر تقديره نحن، والكاف ضمير مبني في محل نصب مفعول به أول، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span>: مفعول به ثانٍ منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن نزيكم﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿فذوقوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فذوقوا﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  78,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ مبني على الفتح لا محل له من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مفازا﴾</span></span>: اسم إن المؤخر منصوب وعلامة نصبه الفتحة، والجملة استئنافية لا محل لها من الإعراب.</p></div>"
  78,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حدائق﴾</span></span>: بدل من <span class="hlt"><span class="qpc-hafs">﴿مفازا﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأعنابا﴾</span></span>: الواو حرف عطف، وأعنابا معطوف على <span class="hlt"><span class="qpc-hafs">﴿حدائق﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكواعب﴾</span></span>: الواو حرف عطف، وكواعب: معطوف على <span class="hlt"><span class="qpc-hafs">﴿حدائق﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أترابا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كواعب﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكأسا﴾</span></span>: الواو حرف عطف، وكأسا: معطوف على <span class="hlt"><span class="qpc-hafs">﴿حدائق﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿دهاقا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كأسا﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لغوا﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذابا﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿لغوا﴾</span></span> منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يسمعون﴾</span></span> في محل نصب حال.</p></div>"
  78,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>: مفعول مطلق لفعل محذوف، أي: يُجزون جزاء، منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: اسم مجرور وعلامة جره الكسرة، والكاف ضمير مبني في محل جر مضاف إليه، والجار والمجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عطاء﴾</span></span>: بدل من <span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسابا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عطاء﴾</span></span> منصوب وعلامة نصبه الفتحة.</p></div>"
  78,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: بدل مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماوات﴾</span></span>: مضاف إليه مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿والأرض﴾</span></span>: الواو حرف عطف، والأرض معطوف على السماوات مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو حرف عطف، وما اسم موصول مبني على السكون في محل جر معطوف على السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span>: بين ظرف مكان منصوب وعلامة نصبه الفتحة متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. والضمير في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يملكون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يملكون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿خطابا﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يملكون﴾</span></span> في محل نصب حال من <span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>.</p></div>"
  78,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: ظرف زمان منصوب وعلامة نصبه الفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لا يملكون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يقوم﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الروح﴾</span></span>: فاعل يقوم مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿والملائكة﴾</span></span>: الواو حرف عطف، والملائكة معطوف على الروح مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿صفا﴾</span></span>: حال منصوبة وعلامة نصبها الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يتكلمون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يتكلمون﴾</span></span> في محل نصب حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول مبني على السكون في محل رفع بدل من فاعل <span class="hlt"><span class="qpc-hafs">﴿يتكلمون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span>: فعل ماض مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: فاعل أذن مرفوع وعلامة رفعه الضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذِنَ﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال﴾</span></span>: الواو حرف عطف، وقال فعل ماض مبني على الفتح، والفاعل ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿صوابا﴾</span></span>: نائب عن المفعول المطلق لأنه صفة المصدر، منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  78,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: ذا اسم إشارة مبني على السكون في محل رفع مبتدأ، واللام للبعد، والكاف ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span>: بدل مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحق﴾</span></span>: خبر مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن﴾</span></span>: الفاء فصيحة مبنية على الفتح، ومن اسم شرط جازم في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿شاء﴾</span></span>: فعل ماض مبني على الفتح في محل جزم فعل الشرط، والفاعل ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿شاء﴾</span></span> في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>: فعل ماض مبني على الفتح في محل جزم جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى﴾</span></span>: حرف جر مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span>: اسم مجرور وعلامة جره الكسرة، والهاء ضمير مبني على الكسر في محل جر مضاف إليه، والجار والمجرور متعلقان بحال محذوف من <span class="hlt"><span class="qpc-hafs">﴿مآبا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مآبا﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك اليوم﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  78,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ مبني على الفتح لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني على السكون في محل نصب اسم <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنذرناكم﴾</span></span>: أنذر: فعل ماضٍ مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني على السكون في محل رفع فاعل، والكاف ضمير مبني في محل نصب مفعول به أول، والميم علامة الجمع، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنذرناكم﴾</span></span> في محل رفع خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span>: مفعول به ثانٍ منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿قريبا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span> منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: ظرف زمان منصوب وعلامة نصبه الفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿المرء﴾</span></span>: فاعل ينظر مرفوع وعلامة رفعه الضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينظر المرء﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مبني على السكون في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قدمت﴾</span></span>: قدم فعل ماض مبني على الفتح، والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿يداه﴾</span></span>: يدا فاعل قدم مرفوع وعلامة رفعه الألف، والهاء ضمير مبني في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمت يداه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقول﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الكافر﴾</span></span>: فاعل يقول مرفوع وعلامة رفعه الضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول الكافر﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿ينظر المرء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف للتنبيه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليتني﴾</span></span>: ليت حرف ناسخ ناصب مبني على الفتح، والنون للوقاية، والياء ضمير مبني في محل نصب اسم <span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا ليتني﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span>: فعل ماض ناقص مبني على السكون والتاء ضمير مبني في محل رفع اسم كان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترابا﴾</span></span>: خبر كنت منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span>.</p></div>"
