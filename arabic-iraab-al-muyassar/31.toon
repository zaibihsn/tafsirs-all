quran[34]{c,v,t}:
  31,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  31,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب الحكيم﴾</span></span>: تلك: مبتدأ، وآيات: خبر، والكتاب: مضاف إليه، والحكيم: صفة للكتاب.</p></div>"
  31,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هدى ورحمة للمحسنين﴾</span></span>: هدى: حال من الآيات، والواو عاطفة، ورحمة: معطوف على هدى منصوب، وللمحسنين: جار ومجرور متعلقان بمحذوف صفة لرحمة.</p></div>"
  31,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يقيمون الصلاة ويؤتون الزكاة وهم بالآخرة هم يوقنون﴾</span></span>: الذين: نعت للمحسنين، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقيمون الصلاة﴾</span></span> صلة الذين لا محل لها من الإعراب. ويؤتون الزكاة: عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿يقيمون الصلاة﴾</span></span> داخل في حيز الصلة، والواو عاطفة، وهم: مبتدأ، وبالآخرة: جار ومجرور متعلقان بيوقنون، وهم الثانية تأكيد للأولى، ويوقنون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوقنون﴾</span></span>: خبر هم الأولى وجملة <span class="hlt"><span class="qpc-hafs">﴿هم بالآخرة ...﴾</span></span> معطوفة على جملة الصلة.</p></div>"
  31,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك على هدى من ربهم﴾</span></span>: أولئك: اسم إشارة مبني على الكسر في محل رفع مبتدأ والكاف حرف خطاب، وعلى هدى: جار ومجرور متعلقان بمحذوف خبر لـ<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>، ومن ربهم: جار ومجرور متعلقان بمحذوف صفة لهدى، والجملة استئنافية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأولئك هم المفلحون﴾</span></span>: الواو عاطفة، وأولئك: مبتدأ، وهم: ضمير فصل لا محل له من الإعراب، والمفلحون: خبر أولئك. أو هم: مبتدأ، والمفلحون: خبر المبتدأ هم، والجملة الاسمية <span class="hlt"><span class="qpc-hafs">﴿هم المفلحون﴾</span></span> في محل رفع خبر أولئك.</p></div>"
  31,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يشتري لهو الحديث ليضل عن سبيل الله بغير علم﴾</span></span>: الواو استئنافية، ومن الناس: جار ومجرور متعلقان بخبر مقدم، ومن: اسم موصول مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشتري لهو الحديث﴾</span></span> صلة مَن لا محل لها من الإعراب. وليضل: اللام للتعليل، ويضل: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل المضارع في تأويل مصدر مجرور بلام التعليل والجار والمجرور متعلقان بيشتري. وعن سبيل الله: جار ومجرور ولفظ الجلالة مضاف إليه والجار والمجرور متعلقان بيضل. وبغير: جار ومجرور متعلقان بحال من فاعل يشتري، وعلم: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يشتري...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويتخذها هزوا﴾</span></span>: الواو عاطفة ويتخذها: عطف على ليضل، ويتخذها: فعل مضارع وفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿يتخذ﴾</span></span> الأول، وهزوا: مفعول <span class="hlt"><span class="qpc-hafs">﴿يتخذ﴾</span></span> الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك لهم عذاب مهين﴾</span></span>: أولئك: مبتدأ، ولهم: خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، وعذاب: مبتدأ مؤخر، ومهين: صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم عذاب﴾</span></span>: خبر أولئك.</p></div>"
  31,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا تتلى عليه آياتنا ولى مستكبرا﴾</span></span>: الواو عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، وتتلى: فعل مضارع مبني لما لم يسمَّ فاعله، وعليه: جار ومجرور متعلقان بتتلى، وآياتنا: نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتلى﴾</span></span> في محل جر بإضافة الظرف إليها، وولى: فعل ماض وفاعل مستتر وجملة <span class="hlt"><span class="qpc-hafs">﴿ولّى﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومستكبرا: حال من فاعل ولّى.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأن لم يسمعها﴾</span></span>: كأنْ: مخففة من الثقيلة، واسمها: ضمير الشأن المحذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يسمعها﴾</span></span> خبر كأن، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأن لم يسمعها﴾</span></span> في محل نصب حال ثانية من فاعل ولّى.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأن في أذنيه وقرا﴾</span></span>: كأنّ: ناسخة من أخوات إنّ، وفي أذنيه: خبر كأنّ المقدم، ووقرا: اسم كأنّ المؤخر، والجملة حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿لم يسمعها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فبشره بعذاب أليم﴾</span></span>: الفاء فصيحة، وبشره: فعل أمر، وفاعله ضمير مستتر تقديره أنت، والهاء مفعول به. بعذاب: جار ومجرور متعلقان ببشِّره، وأليم: صفة.</p></div>"
  31,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات لهم جنات النعيم﴾</span></span>: إن حرف ناسخ، والذين اسمها، وآمنوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span>: فعل وفاعل ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، ولهم: جار ومجرور متعلقان بخبر مقدم، وجنات: مبتدأ مؤخر، والنعيم: مضاف إليه، والجملة الاسمية <span class="hlt"><span class="qpc-hafs">﴿لهم جنات النعيم﴾</span></span> خبر إن. وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الذين ...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  31,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خالدين فيها﴾</span></span>: خالدين: حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>، وفيها: جار ومجرور متعلقان بخالدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعد الله حقا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وعد﴾</span></span> مفعول مطلق لفعل محذوف. ولفظ الجلالة مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿حقًّا﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة والتقدير: حق ذلك حقا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو العزيز الحكيم﴾</span></span>: الواو عاطفة، وهو: مبتدأ، والعزيز: خبر أول، والحكيم: خبر ثان.</p></div>"
  31,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق السماوات بغير عمد ترونها﴾</span></span>: خلق: فعل ماض، وفاعله مستتر تقديره هو، والسماوات: مفعول به، وبغير عمد: جار ومجرور ومضاف إليه والجار والمجرور في محل نصب حال من السماوات، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترونها﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عمد﴾</span></span> أو في محل نصب حال من السماوات، أو مستأنفة لا محل لها من الإعراب، والضمير راجع إلى السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿وألقى في الأرض رواسي أن تميد بكم وبث فيها من كل دابة﴾</span></span>: الواو عاطفة على جملة <span class="hlt"><span class="qpc-hafs">﴿خلق ...﴾</span></span>، وألقى: فعل ماض، وفاعله مستتر تقديره هو يعود على الله سبحانه، وفي الأرض: جار ومجرور متعلقان بألقى، ورواسي: صفة لمفعول به محذوف، أي: جبالا رواسي. وأن: مصدرية تنصب الفعل المضارع، وتميد: فعل مضارع منصوب وفاعله مستتر تقديره هي، وأنْ والفعل المضارع في محل نصب مفعول لأجله على تقدير مضاف، أي: خشيةَ أن تميد. وبكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تميد﴾</span></span>، وبث: عطف على <span class="hlt"><span class="qpc-hafs">﴿ألقى﴾</span></span>، وبث: فعل ماض، والفاعل مستتر تقديره هو، والمفعول محذوف والتقدير: وبث فيها دواب من كل دابة، وفيها: جار ومجرور متعلقان ببث، ومن كل دابة: جار ومجرور ومضاف إليه، والجار والمجرور متعلقان بصفة لمفعول بث المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنزلنا من السماء ماء فأنبتنا فيها من كل زوج كريم﴾</span></span>: الواو عاطفة، وأنزلنا: فعل وفاعل، ومن السماء: جار ومجرور متعلقان بأنزلنا أو بحال من <span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span>، وماء: مفعول به، فأنبتنا: عطف على أنزلنا، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، ومن كل: جار ومجرور متعلقان بصفة لمفعول محذوف والتقدير: فأنبتنا نباتًا كائنًا من كل زوج. وزوج: مضاف إليه، وكريم: صفة لزوج.</p></div>"
  31,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا خلق الله فأروني ماذا خلق الذين من دونه﴾</span></span>: هذا: مبتدأ، وخلق الله: خبر. فأروني: الفاء الفصيحة، وأروني: فعل أمر يحتاج لثلاثة مفاعيل: الياء أولها، وجملة الاستفهام المعلقة <span class="hlt"><span class="qpc-hafs">﴿ماذا خلق ...﴾</span></span> سدت مسد المفعولين الباقيين. أو <span class="hlt"><span class="qpc-hafs">﴿أروني﴾</span></span> بمعنى أخبروني، فتتعدى لمفعولين، أولهما ضمير المتكلم، وثانيهما الجملة الاستفهامية. وماذا: اسم استفهام في محل نصب مفعول مقدم لخلق، وخلق الذين: فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل الظالمون في ضلال مبين﴾</span></span>: بل: حرف إضراب، والظالمون: مبتدأ، وفي ضلال: خبر، ومبين: صفة لضلال.</p></div>"
  31,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا لقمان الحكمة أن اشكر لله﴾</span></span>: الواو استئنافية، واللام: جواب لقسم محذوف، وقد: حرف تحقيق، وآتينا: فعل وفاعل، ولقمان: مفعول به أول، والحكمة: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا لقمان...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. اشكر: فعل وفاعل مستتر، ولله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اشكر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يشكر فإنما يشكر لنفسه﴾</span></span>: الواو استئنافية، ومن: اسم شرط جازم في محل رفع مبتدأ، ويشكر: فعل الشرط مجزوم بالسكون، والفاء: في جواب الشرط، وإنما: كافة ومكفوفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإنما يشكر...﴾</span></span> في محل جزم جواب الشرط، وجملتا الشرط والجواب في محل رفع خبر المبتدأ الذي هو اسم الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يشكر...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن كفر فإن الله غني حميد﴾</span></span>: الواو عاطفة، ومن: اسم شرط جازم في محل رفع مبتدأ، وكفر: فعل ماض، وفاعله مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفر﴾</span></span> في محل جزم فعل الشرط، والفاء: رابطة لجواب الشرط، وإن حرف ناسخ، ولفظ الجلالة اسمها، وغني: خبر أول لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وحميد: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملتا الشرط والجواب في محل رفع خبر المبتدأ الذي هو اسم الشرط. وجملة <span class="hlt"><span class="qpc-hafs">﴿من كفر﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿من يشكر﴾</span></span>.</p></div>"
  31,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قال لقمان لابنه﴾</span></span>: الواو استئنافية، وإذ: اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، أو ظرف متعلق بالفعل المقدر الذي دلت عليه واو العطف، والتقدير: وآتيناه الحكمة إذ قال، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال لقمان﴾</span></span> في محل جر بالإضافة، ولابنه: جار ومجرور متعلقان بقال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو يعظه﴾</span></span>: الواو: واو الحال، وهو: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعظه﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو يعظه﴾</span></span> حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا بني لا تشرك بالله﴾</span></span>: يا: حرف نداء، وبني: منادى مضاف لياء المتكلم، ولا: ناهية، وتشرك: فعل مضارع مجزوم بلا الناهية، وبالله: جار ومجرور متعلقان بتشرك، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا بني ...﴾</span></span> مقول القول في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الشرك لظلم عظيم﴾</span></span>: إن: حرف ناسخ، والشرك: اسمها، واللام المزحلقة، وظلم: خبر إن، وعظيم: صفة، والجملة تعليل للنهي لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذ قال لقمان...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  31,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووصينا الإنسان بوالديه حملته أمه وهنا على وهن وفصاله في عامين﴾</span></span>: الواو اعتراضية، ووصينا: فعل وفاعل، والإنسان: مفعول به، وبوالديه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وصينا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وصينا الإنسان بوالديه﴾</span></span>: اعتراضية لا محل لها من الإعراب، وحملته أمه: فعل ماضٍ ومفعول به وفاعل، ووهنًا: مصدر في موضع الحال من أمه، وعلى وهن: جار ومجرور متعلقان بنعت لـ<span class="hlt"><span class="qpc-hafs">﴿وهنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿حملته أمه ...﴾</span></span>: اعتراضية بين المفسِّر والمفسَّر لا محل لها من الإعراب، والواو: عاطفة، وفصاله: مبتدأ، وفي عامين: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن اشكر لي ولوالديك﴾</span></span>: أن: تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. واشكر: فعل أمر وفاعله مستتر تقديره أنت، ولي: جار ومجرور متعلقان باشكر، ولوالديك: عطف على لي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلي المصير﴾</span></span>: إلَيَّ: جار ومجرور متعلقان بخبر مقدم، والمصير: مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿إلي المصير﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية أو تعليلية.</p></div>"
  31,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن جاهداك على أن تشرك بي ما ليس لك به علم فلا تطعهما﴾</span></span>: الواو عاطفة، وإن: شرطية، وجاهداك: فعل ماض وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاهداك﴾</span></span> في محل جزم فعل الشرط، وعلى: حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن تشرك﴾</span></span> في تأويل مصدر مجرور بعلى والجار والمجرور متعلقان بجاهداك، وبي: جار ومجرور متعلقان بتشرك، وما: اسم موصول مفعول به، وليس: فعل ناقص، ولك: خبر ليس المقدم، وبه: جار ومجرور متعلقان بعلم، وعلم: اسم ليس المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> صلة الموصول لا محل لها من الإعراب. فلا: الفاء رابطة لجواب الشرط، ولا ناهية، وتطعهما: فعل مضارع مجزوم بلا، والفاعل مستتر تقديره أنت، والهاء مفعول به، والميم والألف حرفان دالان على التثنية، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا تطعهما﴾</span></span> في محل جزم جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿وصاحبهما في الدنيا معروفا﴾</span></span>: الواو عاطفة، وصاحبهما: فعل أمر وفاعل مستتر تقديره أنت ومفعول به، وفي الدنيا: جار ومجرور متعلقان بحال، ومعروفا: صفة لمصدر محذوف، أي: صحابا معروفا، أو منصوب بنزع الخافض، أي: بالمعروف.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتبع سبيل من أناب إلي﴾</span></span>: الواو عاطفة، واتبع: فعل أمر، وفاعله مستتر تقديره أنت، وسبيل: مفعول به، ومن: مضاف إليه، وجملة أناب: صلة مَن لا محل لها من الإعراب. وإليَّ: جار ومجرور متعلقان بأناب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم إلي مرجعكم فأنبئكم بما كنتم تعملون﴾</span></span>: ثم: حرف عطف للترتيب مع التراخي، وإليَّ: خبر مقدم، ومرجعكم: مبتدأ مؤخر. فأنبئكم: الفاء عاطفة، وأنبئكم: فعل مضارع، وفاعل مستتر تقديره أنا، والكاف مفعول به، وبما: جار ومجرور متعلقان بأنبئكم، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة تعملون: خبرها.</p></div>"
  31,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا بني إنها إن تك مثقال حبة من خردل﴾</span></span>: يا: حرف نداء، وبني: منادى مضاف لياء المتكلم، وإنّ حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، وإنْ: شرطية، وتَكُ: فعل مضارع مجزوم لأنه فعل الشرط، وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، واسم تَكُ مستتر، ومثقال: خبر تَكُ، وحبة: مضاف إليه، ومن خردل: جار ومجرور متعلقان بصفة لحبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتكن في صخرة أو في السماوات أو في الأرض يأت بها الله إن الله لطيف خبير﴾</span></span>: فتكن: عطف على تَكُ، واسم تكن: مستتر تقديره هي، وفي صخرة: خبر تكن، و<span class="hlt"><span class="qpc-hafs">﴿أو في السماوات أو في الأرض﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿في صخرة﴾</span></span>، ويأت: جواب الشرط، وعلامة جزمه حذف حرف العلة، وبها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span>، والله: فاعل، وإن حرف ناسخ، ولفظ الجلالة اسمها، ولطيف خبير: خبراها.</p></div>"
  31,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا بني أقم الصلاة وأمر بالمعروف وانه عن المنكر واصبر على ما أصابك﴾</span></span>: يا: حرف نداء، وبني: منادى مضاف لياء المتكلم، وأقم: فعل أمر وفاعله مستتر وجوبًا تقديره أنت، والصلاة: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿وأمر بالمعروف وانه عن المنكر واصبر على ما أصابك﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أقم الصلاة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ذلك من عزم الأمور﴾</span></span>: إن: حرف ناسخ، وذلك: اسم إن، ومن عزم: جار ومجرور متعلقان بخبر إن، والأمور: مضاف إليه.</p></div>"
  31,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تصعر خدك للناس ولا تمش في الأرض مرحا﴾</span></span>: الواو حرف عطف، ولا: ناهية، وتصعر: فعل مضارع مجزوم بلا، وفاعله مستتر تقديره أنت، وخدك: مفعول به، وللناس: جار ومجرور متعلقان بتصعر، ولا تمش: عطف على <span class="hlt"><span class="qpc-hafs">﴿ولا تصعر﴾</span></span>، وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمش﴾</span></span>، ومرحًا: مصدر وقع موقع الحال، أو نعت لمصدر محذوف، أي: مشيًا مرحًا، أو: مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يحب كل مختال فخور﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يحب﴾</span></span>: خبرها، وكل: مفعول يحب، ومختال: مضاف إليه، وفخور: عطف على مختال.</p></div>"
  31,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واقصد في مشيك﴾</span></span>: الواو: عاطفة، واقصد: فعل أمر، وفاعله مستتر تقديره أنت، وفي مشيك: جار ومجرور متعلقان باقصد.</p><p><span class="hlt"><span class="qpc-hafs">﴿واغضض من صوتك﴾</span></span>: الواو: عاطفة، واغضض: فعل أمر، وفاعله مستتر تقديره أنت، ومن صوتك: جار ومجرور متعلقان باغضض أو متعلقان بصفة لموصوف محذوف، أي: اغضض شيئا من صوتك .</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أنكر الأصوات لصوت الحمير﴾</span></span>: إن حرف ناسخ، وأنكر اسمها، والأصوات: مضاف إليه، واللام المزحلقة للتأكيد، وصوت الحمير: خبر إن.</p></div>"
  31,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تروا أن الله سخر لكم ما في السماوات وما في الأرض﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، والهمزة للاستفهام الإنكاري أو التقريري، ولم: حرف نفي وقلب وجزم، وتروا: فعل مضارع مجزوم بلم وعلامة جزمه حذف النون، وواو الجماعة فاعل، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة سخر: خبر أنّ، ولكم: جار ومجرور متعلقان بسخر، وما: مفعول به، وفي السماوات: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. وما في الأرض: عطف على <span class="hlt"><span class="qpc-hafs">﴿ما في السماوات﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أن الله سخر...﴾</span></span> سدت مسد مفعولي تروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأسبغ عليكم نعمه ظاهرة وباطنة﴾</span></span>: الواو عاطفة، وأسبغ: فعل ماض، وفاعله مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسبغ﴾</span></span>معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿سخر﴾</span></span>، وعليكم: جار ومجرور متعلقان بأسبغ، ونعمه: مفعول به، وظاهرة: حال، وباطنة: عطف على ظاهرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يجادل في الله بغير علم ولا هدى ولا كتاب منير﴾</span></span>: الواو استئنافية، ومن الناس: خبر مقدم، ومَن: اسم موصول في محل رفع مبتدأ مؤخر. وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span> صلة الموصول لا محل لها من الإعراب. وفي الله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، وبغير علم: جار ومجرور متعلقان بحال من فاعل يجادل. وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب، ولا هدى: الواو عاطفة، ولا: لتأكيد النفي، وهدى: معطوف على <span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span> مجرور، ولا كتاب: الواو عاطفة، ولا: لتأكيد النفي، وكتاب: معطوف على <span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span> مجرور، ومنير: صفة لكتاب.</p></div>"
  31,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم اتبعوا ما أنزل الله قالوا بل نتبع ما وجدنا عليه آباءنا﴾</span></span>: الواو عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بإضافة الظرف إليها، ولهم: جار ومجرور متعلقان بقيل، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span> مقول القول، وما: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزل الله﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم، وبل: حرف إضراب وهي عاطفة على جملة محذوفة، أي: قالوا لا نتبع ما أنزل الله بل نتبع ...إلخ. ونتبع: فعل مضارع مرفوع، وفاعله مستتر تقديره نحن، وما: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وعليه: جار ومجرور متعلقان بوجدنا أو متعلقان بمفعول وجدنا الثاني، أي: وجدنا آباءنا عاكفين عليه، وآباءنا: مفعول وجدنا الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولو كان الشيطان يدعوهم إلى عذاب السعير﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو: فيها وجهان: أحدهما أن تكون عاطفة على محذوف، وثانيهما أنها حالية، وعلى كل حال لا بد من تقدير محذوف، والتقدير: أيتبعونه ولو كان الشيطان يدعوهم. ولو: شرطية، وجوابها محذوف تقديره: اتبعوه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولو كان الشيطان﴾</span></span> في محل نصب حال من فاعل يتبعونه المقدرة، وكان فعل ماض ناقص، والشيطان اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعوهم﴾</span></span> خبر كان، وإلى عذاب: جار ومجرور متعلقان بيدعوهم، والسعير: مضاف إليه.</p></div>"
  31,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يسلم وجهه إلى الله وهو محسن فقد استمسك بالعروة الوثقى﴾</span></span>: الواو استئنافية، ومن: اسم شرط جازم في محل رفع مبتدأ، ويسلم: فعل مضارع مجزوم لأنه فعل الشرط، وفاعله مستتر تقديره هو، ووجهه: مفعول به، وإلى الله: جار ومجرور متعلقان بيسلم، والواو: واو الحال، وهو: مبتدأ، ومحسن: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو محسن﴾</span></span> حال من فاعل يسلم. فقد: الفاء: رابطة لجواب الشرط، وقد: حرف تحقيق، واستمسك: فعل ماض، وفاعله مستتر تقديره هو، وبالعروة: جار ومجرور متعلقان باستمسك، والوثقى: صفة للعروة، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقد استمسك﴾</span></span> في محل جزم جواب الشرط، وجملتا الشرط والجواب في محل رفع خبر المبتدأ الذي هو اسم الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يسلم وجهه...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإلى الله عاقبة الأمور﴾</span></span>: إلى الله: جار ومجرور متعلقان بخبر مقدم، وعاقبة: مبتدأ مؤخر، والأمور: مضاف إليه.</p></div>"
  31,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن كفر فلا يحزنك كفره﴾</span></span>: الواو عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿من كفر﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿من يسلم﴾</span></span>، ومن: اسم شرط جازم في محل رفع مبتدأ، وكفر: فعل ماض في محل جزم فعل الشرط، وفاعله مستتر تقديره هو، والفاء: رابطة لجواب الشرط، ولا: ناهية، ويحزنك: فعل مضارع مجزوم بلا، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا يحزنك كفره﴾</span></span> في محل جزم جواب الشرط. وجملتا الشرط والجواب في محل رفع خبر المبتدأ الذي هو اسم الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلينا مرجعهم فننبئهم بما عملوا﴾</span></span>: إلينا: جار ومجرور متعلقان بخبر مقدم، ومرجعهم: مبتدأ مؤخر. فننبئهم: الفاء: عاطفة، وننبئهم: فعل مضارع، والفاعل ضمير مستتر تقديره نحن، والهاء مفعول به، والميم علامة الجمع. وبما: جار ومجرور متعلقان بننبئهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله عليم بذات الصدور﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وعليم: خبر إن، وبذات: جار ومجرور متعلقان بعليم، والصدور: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله عليم بذات الصدور﴾</span></span> لا محل لها من الإعراب، لأنها تعليل لجملة <span class="hlt"><span class="qpc-hafs">﴿فننبئهم بما عملوا﴾</span></span>.</p></div>"
  31,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نمتعهم قليلا ثم نضطرهم إلى عذاب غليظ﴾</span></span>: استئناف بياني لا محل لها من الإعراب، ونمتعهم: فعل مضارع وفاعل مستتر ومفعول به، وقليلا: صفة لمصدر محذوف، أي: نمتعهم متاعًا قليلا، أو صفة لظرف زمان محذوف، أي: نمتعهم زمانا قليلا. ثم: حرف عطف للترتيب مع التراخي، ونضطرهم: فعل وفاعل مستتر ومفعول به، وإلى عذاب: جار ومجرور متعلقان بنضطرهم، وغليظ: صفة لعذاب.</p></div>"
  31,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم من خلق السماوات والأرض ليقولن الله﴾</span></span>: الواو استئنافية، واللام موطئة للقسم، وإن: شرطية، وسألتهم: فعل ماض في محل جزم فعل الشرط وفاعل ومفعول به، ومن: اسم استفهام مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span> في محل رفع خبر، والجملة الاسمية <span class="hlt"><span class="qpc-hafs">﴿من خلق السماوات والأرض﴾</span></span> في محل نصب مفعول به ثان لسألتهم. ليقولن: اللام واقعة في جواب القسم، ويقولن: فعل مضارع حذفت منه نون الرفع لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين في محل رفع فاعل، والله: خبر لمبتدأ محذوف، أي: هو الله، أو مبتدأ حذف خبره، أي: الله خالقها. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل الحمد لله﴾</span></span>: قل: فعل أمر، وفاعله مستتر تقديره أنت، والحمد: مبتدأ، ولله: جار ومجرور متعلقان بخبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿الحمد لله﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أكثرهم لا يعلمون﴾</span></span>: بل: حرف إضراب، وأكثرهم: مبتدأ، وجملة  <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر.</p></div>"
  31,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لله ما في السماوات والأرض﴾</span></span>: لله: جار ومجرور متعلقان بخبر مقدم، وما: مبتدأ مؤخر، وفي السماوات: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. والأرض: معطوف على السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله هو الغني الحميد﴾</span></span>: إن: حرف ناسخ، ولفظ الجلالة اسم إن، وهو: ضمير فصل، والغني: خبر إن مرفوع، والحميد: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  31,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو أنما في الأرض من شجرة أقلام﴾</span></span>: الواو استئنافية، ولو: حرف شرط غير جازم، وأنما: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسمها، وفي الأرض: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. ومن شجرة: جار ومجرور متعلقان بحال من الاسم الموصول، وأقلام: خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿والبحر يمده من بعده سبعة أبحر ما نفدت كلمات الله﴾</span></span>: الواو حالية أو عاطفة، والبحر: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمده﴾</span></span> خبره، ويمده: فعل مضارع والهاء مفعول به مقدم، ومن بعده: جار ومجرور متعلقان بحال من <span class="hlt"><span class="qpc-hafs">﴿سبعة أبحر﴾</span></span> والضمير مضاف إليه، وسبعة: فاعل يمده، وأبحر: مضاف إليه. وما: نافية، ونفدت: فعل ماض، وكلمات الله: فاعل ولفظ الجلالة مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولو أنما في الأرض...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله عزيز حكيم﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وعزيز: خبر إن مرفوع، وحكيم: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  31,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما خلقكم ولا بعثكم إلا كنفس واحدة﴾</span></span>: ما: نافية، وخلقكم: مبتدأ، والواو: حرف عطف، ولا: لتأكيد النفي، وبعثكم: معطوف على خلقكم، وإلا: أداة حصر، وكنفس: الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر خلْق على حذف مضاف، والتقدير: إلا مثل خلق وبعث نفس واحدة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله سميع بصير﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وسميع: خبر إن مرفوع، وبصير: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  31,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الله يولج الليل في النهار ويولج النهار في الليل﴾</span></span>: الهمزة للاستفهام التقريري، ولم: حرف نفي وقلب وجزم، وترَ: مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه حذف حرف العلة، وفاعله مستتر تقديره أنت، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يولج الليل في النهار﴾</span></span>: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يولج النهار في الليل﴾</span></span>: معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿يولج الليل في النهار﴾</span></span>، وأنّ وما بعدها سدت مسد مفعولي تَرَ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسخر الشمس والقمر كل يجري إلى أجل مسمى وأن الله بما تعملون خبير﴾</span></span>: الواو عاطفة، وسخر: عطف على يولج، والشمس: مفعول سخر، والقمر: عطف على الشمس، وكل: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجري﴾</span></span> خبر، وإلى أجل: جار ومجرور متعلقان بيجري، مسمى: نعت لأجل، وأن حرف ناسخ، ولفظ الجلالة اسمها، وبما: جار ومجرور متعلقان بخبير، وتعملون: فعل وفاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وخبير: خبر أن.</p></div>"
  31,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأن الله هو الحق﴾</span></span>: ذلك: مبتدأ، والباء حرف جر، وأن حرف ناسخ، ولفظ الجلالة اسمها، وهو: ضمير فصل لا محل له من الإعراب، والحق: خبر أن، أو هو: مبتدأ، والحق: خبر هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو الحق﴾</span></span> خبر أن، وأن واسمها وخبرها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بمحذوف خبر ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن ما يدعون من دونه الباطل﴾</span></span>: الواو عاطفة، وأن: حرف ناسخ، وما: اسم أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. ومن دونه: جار ومجرور متعلقان بحال من مفعول يدعون المحذوف والتقدير: وأن ما يدعونه من دونه. والباطل: خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن الله هو العلي الكبير﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، ولفظ الجلالة اسمها، وهو: مبتدأ، والعلي: خبر أول لأن، والكبير: خبر ثان لأن، والجملة الاسمية <span class="hlt"><span class="qpc-hafs">﴿هو العلي الكبير﴾</span></span> خبر أن.</p></div>"
  31,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الفلك تجري في البحر بنعمت الله﴾</span></span>: الهمزة للاستفهام التقريري، ولم: حرف نفي وقلب وجزم، وتر: فعل مضارع مجزوم بلم، وأن حرف ناسخ، والفلك اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري في البحر﴾</span></span> خبر أن، وبنعمة الله: جار ومجرور متعلقان بتجري أو متعلقان بمحذوف حال من فاعل تجري، أي: مصحوبة بنعمته.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليريكم من آياته﴾</span></span>: اللام للتعليل، ويريكم: فعل مضارع منصوب بأن مضمرة بعد اللام، والفاعل مستتر تقديره هو، والكاف مفعول به أول، والميم علامة الجمع، وأن المضمرة والفعل المضارع في تأويل مصدر مجرور بلام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>. ومن آياته: جار ومجرور في محل نصب مفعول به ثان ليريكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لكل صبار شكور﴾</span></span>: إن: حرف ناسخ، وفي ذلك: جار ومجرور متعلقان بخبر إن المقدم، واللام المزحلقة، وآيات: اسم إن، ولكل: جار ومجرور متعلقان بصفة لآيات، وصبار: مضاف إليه، وشكور: صفة لصبار.</p></div>"
  31,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا غشيهم موج كالظلل دعوا الله مخلصين له الدين﴾</span></span>: الواو عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، وغشيهم: فعل ماض والضمير مفعول به، وموج: فاعل، وكالظلل: جار ومجرور متعلقان بصفة لموج، وجملة <span class="hlt"><span class="qpc-hafs">﴿غشيهم﴾</span></span> في محل جر بإضافة الظرف إليها، ودعوا: فعل وفاعل، والله: لفظ الجلالة مفعول دعوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعوا الله﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومخلصين: حال من فاعل دعوا، وله: جار ومجرور متعلقان بمخلصين، والدين: مفعول لمخلصين، لأن <span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span> اسم فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما نجاهم إلى البر فمنهم مقتصد﴾</span></span>: الفاء عاطفة، ولما: ظرف بمعنى حين متضمن معنى الشرط، ونجاهم: فعل ماض، وفاعله مستتر تقديره هو، والهاء مفعول به، وإلى البر: جار ومجرور متعلقان بنجاهم، والفاء: رابطة لجواب الشرط، ومنهم: جار ومجرور متعلقان بخبر مقدم، ومقتصد: مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يجحد بآياتنا إلا كل ختار كفور﴾</span></span>: الواو استئنافية، وما: نافية، ويجحد: فعل مضارع مرفوع، وبآياتنا: جار ومجرور متعلقان بيجحد، وإلا: أداة حصر، وكل: فاعل، وختار: مضاف إليه، وكفور: صفة لختار، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما يجحد بآياتنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  31,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس اتقوا ربكم واخشوا يوما لا يجزي والد عن ولده﴾</span></span>: يا أيها: يا: حرف نداء، وأيُّ: منادى مبني على الضم في محل نصب، وها: للتنبيه، والناس: عطف بيان، واتقوا ربكم: فعل أمر وفاعل ومفعول به، واخشوا: عطف على اتقوا، ويومًا: مفعول به، ولا: نافية، ويجزي والد: فعل وفاعل، وعن ولده: جار ومجرور متعلقان بيجزي، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يجزي والد عن ولده﴾</span></span> في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿يومًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا مولود هو جاز عن والده شيئا﴾</span></span>:  الواو عاطفة، ولا: لتأكيد النفي، ومولود: مبتدأ، وهو: ضمير فصل، وجازٍ: خبر مرفوع بضمة مقدرة على الياء المحذوفة، أو هو: مبتدأ ثان، وجازٍ: خبر للمبتدأ الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو جاز﴾</span></span> في محل رفع خبر المبتدأ الأول، وعن والده: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاز﴾</span></span>، وشيئا: مفعول به لاسم الفاعل <span class="hlt"><span class="qpc-hafs">﴿جاز﴾</span></span> أو نائب عن المفعول المطلق، أي: شيئا من الجزاء. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا مولود ...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿لا يجزي...﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن وعد الله حق﴾</span></span>: إن: حرف ناسخ، ووعد: اسم إن، ولفظ الجلالة مضاف إليه، وحق: خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تغرنكم الحياة الدنيا﴾</span></span>: الفاء فصيحة، أي: إذا علمتم أن وعد الله حق فلا تغرنكم الحياة الدنيا، ولا: ناهية، وتغرنكم: فعل مضارع مبني على الفتح في محل جزم بلا الناهية والضمير مفعول به، والحياة: فاعل تغرنكم، والدنيا: صفة للحياة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يغرنكم بالله الغرور﴾</span></span>: الواو عاطفة، ولا: ناهية، ويغرنكم: فعل مضارع مبني على الفتح في محل جزم بلا الناهية والضمير مفعول به، وبالله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغرنكم﴾</span></span>، والغرور: فاعل يغرنكم، والجملة معطوفة على سابقتها.</p></div>"
  31,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله عنده علم الساعة وينزل الغيث ويعلم ما في الأرحام﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وعنده: ظرف متعلق بمحذوف خبر مقدم، وعلم الساعة: مبتدأ مؤخر ومضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿عنده علم الساعة﴾</span></span> خبر إن، والواو عاطفة، وينزل الغيث: فعل مضارع وفاعل مستتر ومفعول به، ويعلم: فعل مضارع وفاعله مستتر تقديره هو، وما: اسم موصول في محل نصب مفعول به، وفي الأرحام: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تدري نفس ماذا تكسب غدا﴾</span></span>: الواو حرف عطف، وما: نافية، وتدري: فعل مضارع، ونفس: فاعل، وماذا: اسم استفهام في محل نصب مفعول مقدم لتكسب، وغدا: ظرف متعلق بتكسب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ماذا تكسب غدا﴾</span></span> في محل نصب مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿تدري﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما تدري نفس...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿إن الله عنده علم الساعة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تدري نفس بأي أرض تموت﴾</span></span>: الواو حرف عطف، وما: نافية، وتدري: فعل مضارع مرفوع، ونفس: فاعل، وبأي: جار ومجرور متعلقان بتموت، وأرض: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿بأي أرض تموت﴾</span></span> في محل نصب مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿تدري﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله عليم خبير﴾</span></span>: إن: حرف ناسخ، ولفظ الجلالة اسمها، وعليم: خبر إن مرفوع، وخبير: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
