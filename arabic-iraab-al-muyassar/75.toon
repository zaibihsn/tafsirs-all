quran[40]{c,v,t}:
  75,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية، أو صلة لتقوية القسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>: فعل مضارع مرفوع، والفاعل، تقديره: أنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بيوم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>، ويوم مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿القيامة﴾</span></span>: مضاف إليه.</p></div>"
  75,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، ولا نافية، أو صلة لتقوية القسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>: فعل مضارع مرفوع، والفاعل مستتر تقديره: أنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالنفس﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿اللوامة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿النفس﴾</span></span>، والجملة عطف على الجملة السابقة، وجواب القسم محذوف، أي: لتبعثنّ، دلّ عليه ما بعده.</p></div>"
  75,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أيحسب﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، ويحسب فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألن﴾</span></span>: أن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، ولن حرف نفي ونصب واستقبال.</p><p><span class="hlt"><span class="qpc-hafs">﴿نجمع﴾</span></span>: فعل مضارع منصوب، والفاعل مستتر تقديره نحن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن نجمع عظامه﴾</span></span> في محل رفع خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿عظامه﴾</span></span>: مفعول به منصوب، والهاء مضاف إليه، وأن المخففة وما في حيِّزها سادة مسد مفعولي يحسب، وجملة الاستفهام <span class="hlt"><span class="qpc-hafs">﴿أيحسب...﴾</span></span> استئناف بياني لا محل لها من الإعراب.</p></div>"
  75,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بلى﴾</span></span>: حرف جواب لإبطال النفي في <span class="hlt"><span class="qpc-hafs">﴿لن نجمع عظامه﴾</span></span>، أي: بلى نجمعها.</p><p><span class="hlt"><span class="qpc-hafs">﴿قادرين﴾</span></span>: حال من فاعل الفعل المقدر المدلول عليه بحرف الجواب، أي بلى نجمعها قادرين.</p><p><span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: حرف مصدري ونصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿نسوي﴾</span></span>: فعل مضارع منصوب، والفاعل ضمير مستتر، تقديره: نحن، وأن المصدرية وما في حيِّزها في تأويل مصدر مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادرين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بنانه﴾</span></span>: مفعول به.</p></div>"
  75,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: للإضراب الانتقالي.</p><p><span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span>: فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليفجر﴾</span></span>: اللام للتعليل، ويفجر: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وفاعله مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> يعود على الإنسان، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ المضارعِ مجرورٌ بلام التعليل، واللام ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span>، ومفعول يريد محذوف يدل عليه التعليل في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿ليفجر أمامه﴾</span></span> والتقدير: يريد الإنسان شهواته ومعاصيه. أو اللام في <span class="hlt"><span class="qpc-hafs">﴿ليفجر﴾</span></span> صلة، ويفجر فعل مضارع منصوب بأن مقدَّرة بعد اللام، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يفجر﴾</span></span> مفعول يريد والتقدير: يريد الإنسانُ الفجورَ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أمامه﴾</span></span>: أمام ظرف منصوب، وهو مضاف، والهاء مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أيحسب﴾</span></span> أو مستأنفة لا محل لها من الإعراب.</p></div>"
  75,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يسأل﴾</span></span>: فعل مضارع مرفوع، وفاعله مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيان﴾</span></span>: اسم استفهام في محل نصب على الظرفية الزمانية، وهو متعلق بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: مبتدأ مؤخر، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿القيامة﴾</span></span>: مضاف إليه. والجملة في موضع نصب على الحال من فاعل يريد أو من فاعل يفجر، أو مستأنفة للتعجيب من حال سؤالهم عن وقت يوم القيامة وهو سؤال استهزاء لاعتقادهم استحالة وقوعه فلا محل لها من الإعراب، أو بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> فلا محل لها من الإعراب.</p></div>"
  75,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء استئنافية، وإذا ظرف لما يستقبل من الزمن متعلق بالجواب، وهو: يقول.</p><p><span class="hlt"><span class="qpc-hafs">﴿برق﴾</span></span>: فعل ماض مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿البصر﴾</span></span>: فاعل مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿برق البصر﴾</span></span> في محل جر بإضافة الظرف إليها، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  75,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخسف﴾</span></span>: فعل ماض مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿القمر﴾</span></span>: فاعل مرفوع، والجملة عطف على الجملة السابقة.</p></div>"
  75,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجمع﴾</span></span>: فعل ماضٍ مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span>: نائب فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿والقمر﴾</span></span>: الواو عاطفة، والقمر معطوف على الشمس مرفوع.</p></div>"
  75,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>: فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: فاعل مرفوع، وجملة يقول الإنسان لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة والتقدير: يقول الإنسان يوم إذ برق البصر وخسف القمر وجمع الشمس والقمر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أين﴾</span></span>: أين اسم استفهام في محل نصب ظرف مكان، والظرف متعلق بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿المفر﴾</span></span>: مبتدأ مؤخر.</p></div>"
  75,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا﴾</span></span>: حرف ردع وزجر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿وزر﴾</span></span>: اسم لا مبني على الفتح، وخبرها محذوف، أي: موجود متاح لهم.</p></div>"
  75,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى ربك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، ورب مضاف، والكاف مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بالخبر المحذوف الذي تعلق به الجار والمجرور، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ برق البصر ...إلخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿المستقر﴾</span></span>: مبتدأ مؤخر.</p></div>"
  75,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ينبأ﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: نائب فاعل مرفوع. وجملة <span class="hlt"><span class="qpc-hafs">﴿ينبأ الإنسان﴾</span></span> استئنافية، لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ينبأ﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ برق البصر...إلخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span>: فعل ماض مبني على الفتح، والفاعل مستتر، تقديره: هو. وجملة <span class="hlt"><span class="qpc-hafs">﴿قَدَّم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخر﴾</span></span>: فعل ماض مبني على الفتح، والفاعل مستتر، تقديره: هو. وجملة <span class="hlt"><span class="qpc-hafs">﴿أخر﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span> الصلة لا محل لها من الإعراب.</p></div>"
  75,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: حرف عطف وإضراب انتقالي.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: مبتدأ مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿على نفسه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصيرة﴾</span></span>، ونفس مضاف، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿بصيرة﴾</span></span>: خبر مرفوع.</p></div>"
  75,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span>: الواو حالية من الفاعل المستكن في <span class="hlt"><span class="qpc-hafs">﴿بصيرة﴾</span></span> ولو شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألقى﴾</span></span>: فعل ماضٍ، وهو فعل الشرط، وفاعله مستتر، تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿معاذيره﴾</span></span>: مفعول به، وجواب الشرط محذوف، أي: ما ساغت، وما قبلت.</p></div>"
  75,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: ناهية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تحرك﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحرك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لسانك﴾</span></span>: مفعول به، ولسان مضاف، والكاف مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتعجل﴾</span></span>: اللام لام التعليل، وتعجل فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، واللام ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحرك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعجل﴾</span></span>، والضمير في <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> للقرآن.</p></div>"
  75,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿جمعه﴾</span></span>: اسم إن المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقرآنه﴾</span></span>: الواو عاطفة، وقرآنه عطف على جمعه، وقرآن مضاف، والهاء مضاف إليه.</p></div>"
  75,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء عاطفة، وإذا ظرف لما يستقبل من الزمن.</p><p><span class="hlt"><span class="qpc-hafs">﴿قرأناه﴾</span></span>: فعل ماضٍ مبني على السكون، لاتصاله بـ<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> الفاعلين، والهاء مفعول به، وجملة قرأناه في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاتبع﴾</span></span>: الفاء رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، واتبع فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿قرآنه﴾</span></span>: قرآن مفعول به، وهو مضاف، والهاء مضاف إليه.</p></div>"
  75,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بخبر إن المقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿بيانه﴾</span></span>: بيان اسم إن المؤخر، وهو مضاف، والهاء مضاف إليه.</p></div>"
  75,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا﴾</span></span>: حرف ردع وزجر.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: حرف إضراب انتقالي.</p><p><span class="hlt"><span class="qpc-hafs">﴿تحبون﴾</span></span>: فعل مضارع مرفوع، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿العاجلة﴾</span></span>: مفعول به.</p></div>"
  75,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتذرون﴾</span></span>: فعل مضارع مرفوع، والواو فاعل، والجملة عطف على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span>: مفعول به.</p></div>"
  75,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجوه﴾</span></span>: مبتدأ مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ناضرة﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ تقوم القيامة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ناضرة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿وجوه﴾</span></span>، أو خبر أول.</p></div>"
  75,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى ربها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناظرة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ناظرة﴾</span></span>: خبر وجوه.</p></div>"
  75,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووجوه﴾</span></span>: الواو عاطفة، ووجوه مبتدأ مرفوع، والجملة عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿باسرة﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ تقوم القيامة.</p><p><span class="hlt"><span class="qpc-hafs">﴿باسرة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿وجوه﴾</span></span>، أو خبر أول.</p></div>"
  75,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تظن﴾</span></span>: فعل مضارع مرفوع، والفاعل مستتر، تقديره: هي، والجملة خبر وجوه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span>: فعل مضارع منصوب، وهو مبني لما لم يسمَّ فاعله، وأن وما في حيِّزها سدّت مسدّ مفعولي <span class="hlt"><span class="qpc-hafs">﴿تظن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاقرة﴾</span></span>: نائب فاعل.</p></div>"
  75,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا﴾</span></span>: حرف ردع وزجر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: ظرف لما يستقبل من الزمن.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلغت﴾</span></span>: فعل ماض، والتاء للتأنيث، والفاعل مستتر، تقديره: هي، وجملة بلغت في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿التراقي﴾</span></span>: مفعول به.</p></div>"
  75,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل﴾</span></span>: الواو عاطفة، وقيل فعل ماضٍ مبني لما لم يسمَّ فاعله.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: استفهام في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿راق﴾</span></span>: خبر مرفوع، وعلامة رفعه الضمة المقدرة على الياء المحذوفة لالتقاء الساكنين. وجملة مقول القول هي نائب الفاعل.</p></div>"
  75,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وظن﴾</span></span>: الواو عاطفة، وظن فعل ماضٍ، والفاعل مستتر، تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنه﴾</span></span>: أن حرف ناسخ، والهاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفراق﴾</span></span>: خبر أن مرفوع، وأن وما في حيِّزها في موضع النصب، سدّت مسدّ مفعولي <span class="hlt"><span class="qpc-hafs">﴿ظن﴾</span></span>.</p></div>"
  75,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والتفت﴾</span></span>: الواو عاطفة، والتفت فعل ماضٍ، والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿الساق﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالساق﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿التفت﴾</span></span>.</p></div>"
  75,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى ربك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدّم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: ظرف متعلق بالخبر المحذوف الذي تعلق به الجار والمجرور، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جمل أربع والتقدير: يوم إذ بلغت التراقي وقيل من راق وظن أنه الفراق والتفّت الساق بالساق.</p><p><span class="hlt"><span class="qpc-hafs">﴿المساق﴾</span></span>: مبتدأ مؤخر.</p></div>"
  75,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span>: الفاء عاطفة، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿صدق﴾</span></span>: فعل ماضٍ، وفاعله مستتر تقديره: هو، أي: الإنسان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿صلى﴾</span></span>: فعل ماضٍ، وفاعله مستتر تقديره: هو، والجملة عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿أيحسب الإنسان أن لن نجمع عظامه﴾</span></span>، وقيل: عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿يسأل أيّان يوم القيامة﴾</span></span>.</p></div>"
  75,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكن﴾</span></span>: الواو عاطفة، ولكن مخففة مهملة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذب﴾</span></span>: فعل ماضٍ، وفاعله مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتولى﴾</span></span>: الواو فعل ماضٍ، وفاعله مستتر تقديره: هو، والجملة عطف على ما سبقها.</p></div>"
  75,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذهب﴾</span></span>: فعل ماضٍ، وفاعله مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى أهله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذهب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يتمطى﴾</span></span>: فعل مضارع مرفوع، والفاعل مستتر، تقديره: هو، وجملة يتمطى حالية من فاعل <span class="hlt"><span class="qpc-hafs">﴿ذهب﴾</span></span>.</p></div>"
  75,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولى﴾</span></span>: مبتدأ مرفوع بضمة مقدرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولى﴾</span></span>: الفاء عاطفة، وأولى معطوف على الأولى.</p></div>"
  75,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب والتراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولى﴾</span></span>: مبتدأ مرفوع بضمة مقدرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولى﴾</span></span>: الفاء عاطفة، وأولى معطوف على الأولى،</p><p>والجملة عطف على ما قبلها.</p></div>"
  75,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يترك﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله منصوب، ونائب الفاعل مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿سدى﴾</span></span>: حال من الضمير في يترك.</p></div>"
  75,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم﴾</span></span>: الهمزة للاستفهام التقريري الإنكاري، ولم حرف نفي، وقلب، وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يك﴾</span></span>: فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه السكون المقدّر على النون المحذوفة للتخفيف، واسم يك مستتر تقديره: هو، أي: الإنسان.</p><p><span class="hlt"><span class="qpc-hafs">﴿نطفة﴾</span></span>: خبر كان منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿من مني﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿يمنى﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله مرفوع، ونائب الفاعل مستتر، تقديره: هو، يعود على المني، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمنى﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مني﴾</span></span>.</p></div>"
  75,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب والتراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماضٍ ناقص، واسمها مستتر، تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿علقة﴾</span></span>: خبر كان منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فخلق﴾</span></span>: الفاء عاطفة للترتيب والتعقيب، وخلق فعل ماضٍ، والفاعل: هو، أي: الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسوى﴾</span></span>: الفاء عاطفة للترتيب والتعقيب، وسوى فعل ماضٍ، والفاعل: هو، أي: الله، والجملة عطف على ما تقدّم.</p></div>"
  75,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فجعل﴾</span></span>: الفاء عاطفة للترتيب والتعقيب، وجعل فعل ماضٍ، والفاعل: هو، أي: الله، والجملة عطف على ما تقدّم.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الزوجين﴾</span></span>: مفعول <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿الذكر﴾</span></span>: بدل منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿والأنثى﴾</span></span>: عطف على الذكر.</p></div>"
  75,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أليس﴾</span></span>: الهمزة للاستفهام الإنكاري التقريري، وليس فعل ماض ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: اسم ليس.</p><p><span class="hlt"><span class="qpc-hafs">﴿بقادر﴾</span></span>: الباء حرف جر صلة، وقادر مجرور لفظًا منصوب محلا خبر ليس.</p><p><span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span>: فعل مضارع منصوب، والفاعل: هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يحيي﴾</span></span> اسم مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الموتى﴾</span></span>: مفعول به.</p></div>"
