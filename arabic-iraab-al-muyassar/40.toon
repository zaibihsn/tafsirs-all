quran[85]{c,v,t}:
  40,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  40,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيل الكتاب من الله العزيز العليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿تنزيل الكتاب﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿العزيز العليم﴾</span></span> صفتان.</p></div>"
  40,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿غافر الذنب وقابل التوب شديد العقاب ذي الطول﴾</span></span>: صفات للفظ الجلالة في الآية السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿إليه المصير﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿المصير﴾</span></span> مبتدأ مؤخر.</p></div>"
  40,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما يجادل في آيات الله إلا الذين كفروا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿في آيات الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل ماض، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يغررك تقلبهم في البلاد﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿يغررك﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿تقلبهم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في البلاد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقلبهم﴾</span></span>.</p></div>"
  40,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قبلهم قوم نوح والأحزاب من بعدهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span> فعل ماض، والتاء للتأنيث، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿قوم نوح﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الأحزاب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿قوم نوح﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهمت كل أمة برسولهم ليأخذوه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿همت﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كل أمة﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿برسولهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿همت﴾</span></span>، واللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿يأخذوه﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والواو فاعل، والهاء مفعول به، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿همت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجادلوا بالباطل ليدحضوا به الحق فأخذتهم فكيف كان عقاب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿جادلوا﴾</span></span> فعل ماض، والواو فاعل، وهو عطف على <span class="hlt"><span class="qpc-hafs">﴿همت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالباطل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جادلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليدحضوا﴾</span></span> اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿يدحضوا﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جادلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدحضوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الحق﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فأخذتهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جادلوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فكيف﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عقاب﴾</span></span> اسم كان مرفوع وعلامة رفعه ضمة مقدرة على ما قبل ياء المتكلم المحذوفة.</p></div>"
  40,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك حقت كلمت ربك على الذين كفروا أنهم أصحاب النار﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أو في محل رفع خبر لمبتدأ محذوف، أي: والأمر مثل ذلك، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿كلمة ربك﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على الذين كفروا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقت﴾</span></span>، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أنهم أصحاب النار﴾</span></span> بدل مرفوع من <span class="hlt"><span class="qpc-hafs">﴿كلمة ربك﴾</span></span>، أو في منصوب بنزع الخافض، وهو لام التعليل.</p></div>"
  40,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يحملون العرش ومن حوله يسبحون بحمد ربهم ويؤمنون به﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يحملون﴾</span></span> فعل مضارع والواو فاعل والعرش مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحملون العرش﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول في محل رفع عطفا على المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿حوله﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بحمد﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: ملابسين للحمد، و<span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسبحون بحمد ربهم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويستغفرون للذين آمنوا ربنا وسعت كل شيء رحمة وعلما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يستغفرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستغفرون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وهي فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف حذف منه حرف النداء، وجملة النداء مقول قول محذوف في محل نصب على الحال، أي: قائلين، و<span class="hlt"><span class="qpc-hafs">﴿وسعت﴾</span></span> فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كل شيء﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿رحمة وعلمًا﴾</span></span> تمييزان، والتمييز هنا محول عن الفاعل، أي: وسعت رحمتك كل شيء، ووسع علمك كل شيء.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاغفر للذين تابوا واتبعوا سبيلك﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span> فعل دعاء، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تابوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿اتبعوا سبيلك﴾</span></span> فعل ماض والواو فاعل، وسبيلك مفعول به، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿للذين تابوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقهم عذاب الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قِ﴾</span></span> فعل دعاء مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الجحيم﴾</span></span> مفعول به ثان.</p></div>"
  40,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربنا وأدخلهم جنات عدن التي وعدتهم ومن صلح من آبائهم وأزواجهم وذرياتهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿أدخلهم﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أدخلهم﴾</span></span> فعل دعاء، والفاعل مستتر تقديره: أنت، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿جنات عدن﴾</span></span> مفعول به ثان على السعة، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعدتهم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول في محل نصب عطف على مفعول <span class="hlt"><span class="qpc-hafs">﴿أدخلهم﴾</span></span>، أو على مفعول <span class="hlt"><span class="qpc-hafs">﴿وعدتهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿صلح﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من آبائهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿أزواجهم وذرياتهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿آبائهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك أنت العزيز الحكيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> مبتدأ، والعزيز الحكيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span>، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إنك﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> ضمير فصل لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الحكيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  40,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقهم السيئات ومن تق السيئات يومئذ فقد رحمته﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قهم﴾</span></span> فعل أمر، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿السيئات﴾</span></span> مفعول به ثان، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿تق﴾</span></span> فعل الشرط مجزوم وعلامة جزمه حذف حرف العلة، و<span class="hlt"><span class="qpc-hafs">﴿السيئات﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقِ﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ يؤاخَذ بها. <span class="hlt"><span class="qpc-hafs">﴿فقد﴾</span></span> الفاء: رابطة لجواب الشرط، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أخزيته﴾</span></span> فعل ماض، والتاء فاعل، والهاء مفعول به، والجملة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وذلك هو الفوز العظيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الفوز العظيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الفوز العظيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p></div>"
  40,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين كفروا ينادون لمقت الله أكبر من مقتكم أنفسكم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل ماض، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿ينادون﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿ينادون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، واللام لام الابتداء، و<span class="hlt"><span class="qpc-hafs">﴿مقت الله﴾</span></span> مبتدأ، والإضافة من إضافة المصدر لفاعله، والمفعول به محذوف، أي: إياكم، و<span class="hlt"><span class="qpc-hafs">﴿أكبر﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من مقتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أنفسكم﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿مقتكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ تدعون إلى الإيمان فتكفرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: مقتكم إذ تدعون، أو: اذكروا إذ تدعون، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو هي نائب الفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الإيمان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فتكفرون﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تكفرون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل.</p></div>"
  40,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا أمتنا اثنتين وأحييتنا اثنتين فاعترفنا بذنوبنا فهل إلى خروج من سبيل﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿أمتنا﴾</span></span> فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير متصل في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿اثنتين﴾</span></span> نائب مفعول مطلق، لأنه عدده، و<span class="hlt"><span class="qpc-hafs">﴿أحييتنا اثنتين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أمتنا اثنتين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اعترفنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بذنوبنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعترفنا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿إلى خروج﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿سبيل﴾</span></span> مجرور لفظًا مرفوع محلا على أنه مبتدأ مؤخر.</p></div>"
  40,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلكم بأنه إذا دعي الله وحده كفرتم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بأنه﴾</span></span> الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿دعي﴾</span></span> فعل ماض مبني لما لم يسم فاعله، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعي﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿وحده﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿كفرتم﴾</span></span> فعل ماض، والتاء فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفرتم﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، وجملة الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿أنه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿بأنه...﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يشرك به تؤمنوا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يشرك﴾</span></span> فعل الشرط مجزوم، وهو فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف سد مسد نائب الفاعل، و<span class="hlt"><span class="qpc-hafs">﴿تؤمنوا﴾</span></span> جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالحكم لله العلي الكبير﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿الحكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، و<span class="hlt"><span class="qpc-hafs">﴿العلي الكبير﴾</span></span> صفتان.</p></div>"
  40,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي يريكم آياته وينزل لكم من السماء رزقا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، والكاف مفعول به أول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آياته﴾</span></span> مفعول به منصوب بالكسرة، و<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، وهو عطف على <span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يتذكر إلا من ينيب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يتذكر﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ينيب﴾</span></span> فعل مضارع مرفوع والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينيب﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  40,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فادعوا الله مخلصين له الدين ولو كره الكافرون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ادعوا﴾</span></span> فعل أمر، والواو فاعل، ولفظ الجلالة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الدين﴾</span></span> مفعول به، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كره الكافرون﴾</span></span> فعل وفاعل، والمفعول به محذوف، أي: إخلاصكم، أو: دعوتكم.</p></div>"
  40,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رفيع الدرجات ذو العرش يلقي الروح من أمره على من يشاء من عباده لينذر يوم التلاق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رفيع الدرجات﴾</span></span> خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذو العرش﴾</span></span> خبر ثان، و<span class="hlt"><span class="qpc-hafs">﴿يلقي الروح﴾</span></span> فعل مضارع، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿الروح﴾</span></span> مفعول به، والجملة خبر ثالث، و<span class="hlt"><span class="qpc-hafs">﴿من أمره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقي﴾</span></span>، أو بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿الروح﴾</span></span>، أي: حال كونه ناشئًا من أمره، و<span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من عباده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span> اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿ينذر﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقي﴾</span></span>، والفاعل هو: الله، أو الروح، أو من يشاء، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿ينذر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿التلاق﴾</span></span> مضاف إليه.</p></div>"
  40,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم هم بارزون لا يخفى على الله منهم شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم التلاق﴾</span></span> بدل كل من كل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بارزون﴾</span></span> خبر، والجملة الاسمية في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يخفى﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخفى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿يخفى﴾</span></span> وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يخفى ...﴾</span></span> حال من ضمير <span class="hlt"><span class="qpc-hafs">﴿بارزون﴾</span></span>، أو خبر ثان، وقيل: هي مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمن الملك اليوم لله الواحد القهار﴾</span></span>: الجملة مقول قول محذوف، أي: يقوله تعالى ويجيب نفسه، والقول معطوف على ما قبله، أو مستأنف في جواب سؤال مقدر، كأنه قيل: فماذا يكون حينئذ؟ فقيل: يقال: لمن الملك...؟ و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف تقديره: الملك لله، و<span class="hlt"><span class="qpc-hafs">﴿الواحد القهار﴾</span></span> نعتان لله.</p></div>"
  40,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اليوم تجزى كل نفس بما كسبت﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span>، والكلام تتمة للمقول، و<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿كل نفس﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة أو ظرفية، و<span class="hlt"><span class="qpc-hafs">﴿كسبت﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كسبت﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا ظلم اليوم إن الله سريع الحساب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿ظلم﴾</span></span> اسمها المبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿سريع الحساب﴾</span></span> خبرها.</p></div>"
  40,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنذرهم يوم الآزفة إذ القلوب لدى الحناجر كاظمين﴾</span></span>: الواو عاطفة على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أنذرهم﴾</span></span> فعل أمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿يوم الآزفة﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم الآزفة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القلوب﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لدى الحناجر﴾</span></span> ظرف متعلق بمحذوف خبر، والجملة في محل جر بالإضافة، <span class="hlt"><span class="qpc-hafs">﴿كاظمين﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿القلوب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما للظالمين من حميم ولا شفيع يطاع﴾</span></span>: الجملة حال من أصحاب القلوب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿للظالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿لا شفيع﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يطاع﴾</span></span> فعل مضارع مبني لما لم يسم فاعله، ونائب الفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يطاع﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شفيع﴾</span></span>.</p></div>"
  40,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعلم خائنة الأعين وما تخفي الصدور﴾</span></span>: الجملة خبر رابع للمبتدأ المحذوف الذي أخبر بـ<span class="hlt"><span class="qpc-hafs">﴿رفيع الدرجات﴾</span></span> وما بعده، أو هو خبر من أخبار <span class="hlt"><span class="qpc-hafs">﴿هو الذي يريكم﴾</span></span> أو هي في محل نصب على الحال، أو هي تعليلية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: هو، أي الله تعالى، و<span class="hlt"><span class="qpc-hafs">﴿خائنة الأعين﴾</span></span> مفعول به، والإضافة بمعنى من، أي: الخائنة من الأعين، فعلى هذا <span class="hlt"><span class="qpc-hafs">﴿خائنة﴾</span></span> نعت لمحذوف، أي العين الخائنة، أو <span class="hlt"><span class="qpc-hafs">﴿خائنة﴾</span></span> مصدر، كالعاقبة والكاذبة، أي: يعلم خيانة الأعين، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿خائنة الأعين﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تخفي الصدور﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  40,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله يقضي بالحق﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة يقضي فعل مضارع مرفوع، والفاعل تقديره: هو، وجملة يقضي خبر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>، أو بمحذوف حال، أي: متلبسًا به.</p><p><span class="hlt"><span class="qpc-hafs">﴿والذين يدعون من دونه لا يقضون بشيء﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، والعائد محذوف، أي: يدعونهم من دونه، بمعنى: يعبدونهم، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يقضون﴾</span></span> فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بشيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يقضون بشيء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله هو السميع البصير﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿السميع البصير﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿السميع البصير﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  40,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يسيروا في الأرض فينظروا كيف كان عاقبة الذين كانوا من قبلهم﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو عاطفة على مقدر يقتضيه المقام، أي: أغفلوا ولم يسيروا، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فينظروا﴾</span></span> الفاء سببية، أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ينظروا﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من أن والفعل معطوف على مصدر مأخوذ من الكلام السابق، والتقدير: أولم يكن سير فيكن نظر؟ أو مجزوم عطفًا على <span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عاقبة﴾</span></span> اسمها، والجملة في محل نصب على المفعولية لـ<span class="hlt"><span class="qpc-hafs">﴿ينظروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانوا هم أشد منهم قوة وآثارا في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قوة﴾</span></span> تمييز، و<span class="hlt"><span class="qpc-hafs">﴿آثارًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿قوة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آثارًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم الله بذنوبهم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بذنوبهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذهم﴾</span></span>، والباء للسببية، أي: بسبب ذنوبهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لهم من الله من واق﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿واق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿واق﴾</span></span> مجرور لفظًا مرفوع محلا على أنه اسم <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> المؤخر.</p></div>"
  40,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأنهم كانت تأتيهم رسلهم بالبينات﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، والباء حرف جر للسببية، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وأن مع مدخولها في محل جر بالباء، والجار والمجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿تأتيهم﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿رسلهم﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتيهم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>، واسمها مستتر تقديره: هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأتيهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكفروا فأخذهم الله﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل ماض، والواو فاعل، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿تأتيهم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فأخذهم الله﴾</span></span> فعل ومفعول به وفاعل، وهي عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿فكفروا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه قوي شديد العقاب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿قوي﴾</span></span> خبر أول، و<span class="hlt"><span class="qpc-hafs">﴿شديد العقاب﴾</span></span> خبر ثان.</p></div>"
  40,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا موسى بآياتنا وسلطان مبين﴾</span></span>: الواو استئنافية، واللام جواب القسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا موسى﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، أو متعلقان بمحذوف حال، أي: متلبسًا بـ<span class="hlt"><span class="qpc-hafs">﴿آياتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت.</p></div>"
  40,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى فرعون وهامان وقارون فقالوا ساحر كذاب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلى فرعون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هامان وقارون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span> فعل ماض والواو فاعل، وهو عطف على <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ساحر كذاب﴾</span></span> خبران لمبتدأ محذوف، أي: هو ساحر كذاب.</p></div>"
  40,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم بالحق من عندنا قالوا اقتلوا أبناء الذين آمنوا معه واستحيوا نساءهم﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرفية حينية، أو رابطة حرفية، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عندنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم وهو <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اقتلوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿أبناء الذين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿استحيوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اقتلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كيد الكافرين إلا في ضلال﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كيد الكافرين﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كيد﴾</span></span>.</p></div>"
  40,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون ذروني أقتل موسى﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ذروني﴾</span></span> فعل أمر، والواو فاعل، والياء مفعول به، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿أقتل﴾</span></span> فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر تقديره: أنا، يعود على القائل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليدع ربه﴾</span></span>: الواو عاطفة، واللام لام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿يدع﴾</span></span> فعل مضارع مجزوم بلام الأمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني أخاف أن يبدل دينكم﴾</span></span>: الجملة تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف مصدري ونصب، و<span class="hlt"><span class="qpc-hafs">﴿يبدل﴾</span></span> فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿دينكم﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو أن يظهر في الأرض الفساد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أن يظهر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن يبدل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يظهر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الفساد﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿يظهر﴾</span></span>.</p></div>"
  40,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى إني عذت بربي وربكم من كل متكبر لا يؤمن بيوم الحساب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span> فعل ماض، والتاء فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span> خبر إن، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿من كل متكبر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمن﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿متكبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بيوم الحساب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>.</p></div>"
  40,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال رجل مؤمن من آل فرعون يكتم إيمانه﴾</span></span>: كلام مستأنف لا محل له من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿قال رجل﴾</span></span> فعل ماض، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿مؤمن﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من آل فرعون﴾</span></span> جار ومجرور متعلقان بمحذوف نعت ثان إن كان الرجل قبطيًّا، والتقدير: وقال رجل مؤمن منسوب من آل فرعون، وإن كان الرجل إسرائيليًّا فالجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكتم﴾</span></span> في موضع المفعول الثاني لـ<span class="hlt"><span class="qpc-hafs">﴿يكتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكتم إيمانه﴾</span></span> صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتقتلون رجلًا أن يقول ربي الله﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿تقتلون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿رجلًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف مصدري ونصب، و<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع منصوب، وأن ما في حيزها في محل نصب مفعول لأجله، أي: لأجل هذا القول من غير روية وتدبر وتأمل، وقيل: ظرف على تقدير مضاف، أي: وقت أن يقول، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبره، أو بالعكس، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد جاءكم بالبينات من ربكم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من ربكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يك كاذبًا فعليه كذبه وإن يك صادقًا يصبكم بعض الذي يعدكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يك﴾</span></span> فعل الشرط مجزوم وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، وهي فعل مضارع ناقص ناسخ، واسمها ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿كاذبًا﴾</span></span> خبرها، <span class="hlt"><span class="qpc-hafs">﴿فعليه﴾</span></span> الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿كذبه﴾</span></span> مبتدأ مؤخر، والجملة الاسمية في محل جزم جواب الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن يك صادقًا يصبكم بعض الذي يعدكم﴾</span></span> عطف على الجملة السابقة، و<span class="hlt"><span class="qpc-hafs">﴿يصبكم﴾</span></span> فعل مضارع مجزوم في جواب الشرط، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعض﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿يصبكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعدكم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يهدي من هو مسرف كذاب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span> فعل مضارع، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مسرف﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿كذاب﴾</span></span> خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو مسرف﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهدي من...﴾</span></span> خبر إن.</p></div>"
  40,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا قوم لكم الملك اليوم ظاهرين في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بما تعلق به الخبر، و<span class="hlt"><span class="qpc-hafs">﴿ظاهرين﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظاهرين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن ينصرنا من بأس الله إن جاءنا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينصرنا﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرنا﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من بأس الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينصرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿جاءنا﴾</span></span> فعل ماض مبني على الفتح في محل جزم فعل الشرط، والجواب محذوف دل عليه ما قبله، أي: فمن ينصرنا، وفاعل <span class="hlt"><span class="qpc-hafs">﴿جاءنا﴾</span></span> يعود على <span class="hlt"><span class="qpc-hafs">﴿بأس الله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال فرعون ما أريكم إلا ما أرى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أريكم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أريكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أهديكم إلا سبيل الرشاد﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿سبيل الرشاد﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أهديكم﴾</span></span>، أو نصب بنزع الخافض.</p></div>"
  40,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذي آمن يا قوم إني أخاف عليكم مثل يوم الأحزاب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> فعل ماض، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوم الأحزاب﴾</span></span> مضاف إليه.</p></div>"
  40,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مثل دأب قوم نوح وعاد وثمود والذين من بعدهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> عطف بيان، أو بدل لـ<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿دأب﴾</span></span> مضاف إليه، ولا بد من تقدير مضاف محذوف، أي: مثل جزاء وعادة من كفر قبلكم من تعذيبهم في الدنيا، <span class="hlt"><span class="qpc-hafs">﴿وعاد وثمود والذين من بعدهم﴾</span></span> عطف على ما سبق، و<span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول. وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما الله يريد ظلما للعباد﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، ولفظ الجلالة اسم ما، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> خبر ما، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية غير عاملة، ولفظ الجلالة مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للعباد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span>.</p></div>"
  40,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم إني أخاف عليكم يوم التناد﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿إني أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم التناد﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>.</p></div>"
  40,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم تولون مدبرين ما لكم من الله من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> بدل من يوم الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿تولون﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿مدبرين﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لكم من الله من عاصم﴾</span></span> في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يضلل الله فما له من هاد﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يضلل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿هاد﴾</span></span> اسم مجرور لفظًا مرفوع محلا على أنه مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يضلل...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  40,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءكم يوسف من قبل بالبينات﴾</span></span>: كلام معطوف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span> فعل ماض، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوسف﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: من قبل موسى، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما زلتم في شك مما جاءكم به﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما زلتم﴾</span></span> فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا هلك قلتم لن يبعث الله من بعده رسولا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية لقوله: <span class="hlt"><span class="qpc-hafs">﴿ما زلتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿هلك﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿قلتم﴾</span></span> فعل ماض والتاء فاعل، والجملة لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span> حرف نفي ونصب واستقبال، و<span class="hlt"><span class="qpc-hafs">﴿يبعث﴾</span></span> فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك يضل الله من هو مسرف مرتاب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يضل الله﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مسرف مرتاب﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو مسرف﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  40,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يجادلون في آيات الله بغير سلطان أتاهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يجادلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في آيات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بغير﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿أتاهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، والفاعل مستتر، والجملة في محل جر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادلون﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿كبر مقتا عند الله وعند الذين آمنوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كبر﴾</span></span> فعل ماض، والفاعل محذوف دل عليه السياق، أي: كبر جدالهم، و<span class="hlt"><span class="qpc-hafs">﴿مقتا﴾</span></span> تمييز منصوب بالفتحة، و<span class="hlt"><span class="qpc-hafs">﴿عند﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مقتا﴾</span></span>، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عند الذين آمنوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عند الله﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> من الفعل والفاعل، صلة الموصول لا محل لها من الإعراب. وجملة: <span class="hlt"><span class="qpc-hafs">﴿كبر...﴾</span></span> في محل رفع خبر الاسم الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك يطبع الله على كل قلب متكبر جبار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، عامله <span class="hlt"><span class="qpc-hafs">﴿يطبع﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يطبع الله﴾</span></span> فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿على كل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يطبع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قلب﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿متكبر﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿جبار﴾</span></span> نعت مجرور.</p></div>"
  40,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون يا هامان ابن لي صرحا لعلي أبلغ الأسباب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿هامان﴾</span></span> منادى مفرد مبني على الضم، و<span class="hlt"><span class="qpc-hafs">﴿ابن﴾</span></span> فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره: أنت، والجملة مقول قول فرعون، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف حال أو بـ<span class="hlt"><span class="qpc-hafs">﴿ابن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿صرحًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span> حرف رجاء ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أبلغ الأسباب﴾</span></span> فعل ماض ومفعول به، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span>.</p></div>"
  40,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أسباب السماوات فأطلع إلى إله موسى وإني لأظنه كاذبا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أسباب السماوات﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿الأسباب﴾</span></span> في الآية السابقة، بدل كل من كل، <span class="hlt"><span class="qpc-hafs">﴿فأطلع﴾</span></span> الفاء فاء السببية، و<span class="hlt"><span class="qpc-hafs">﴿أطلع﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد فاء السببية جوابًا للأمر <span class="hlt"><span class="qpc-hafs">﴿ابنِ﴾</span></span> في الآية السابقة، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق، أي: ليكُنْ بناءٌ منك فاطلاعٌ مني، و<span class="hlt"><span class="qpc-hafs">﴿إلى إله موسى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أطلع﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وإني﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿أظنه﴾</span></span> فعل مضارع، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿كاذبًا﴾</span></span> مفعول به ثان، والجملة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك زين لفرعون سوء عمله وصد عن السبيل﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: تزيينًا مثلَ ذلك زُيِّن لفرعون سوءُ عمله، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿لفرعون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سوء عمله﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿صد﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، عطف على <span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عن السبيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كيد فرعون إلا في تباب﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كيد فرعون﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في تباب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كيد﴾</span></span>.</p></div>"
  40,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذي آمن يا قوم اتبعون أهدكم سبيل الرشاد﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿قال الذي﴾</span></span> فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿اتبعون﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، وياء المتكلم المحذوفة في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أهدكم﴾</span></span> فعل مضارع مجزوم، لأنه جواب الطلب وعلامة جزمه حذف حرف العلة، والفاعل مستتر تقديره: أنا، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿سبيل الرشاد﴾</span></span> مفعول به ثان، أو منصوب بنزع الخافض.</p></div>"
  40,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا قوم إنما هذه الحياة الدنيا متاع وإن الآخرة هي دار القرار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span> بدل، و<span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span> نعت، و<span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿دار القرار﴾</span></span> خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿دار القرار﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>، والجملة خبر إن.</p></div>"
  40,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من عمل سيئة فلا يجزى إلا مثلها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span> فعل ماض في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿سيئة﴾</span></span> مفعول به، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يجزى﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿مثلها﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يجزى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن عمل صالحا من ذكر أو أنثى وهو مؤمن﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> شرطية في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span> فعل ماض في محل جزم فعل الشرط، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿صالحًا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا، و<span class="hlt"><span class="qpc-hafs">﴿من ذكر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿أو أنثى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من ذكر﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وهو مؤمن﴾</span></span> الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مؤمن﴾</span></span> خبر، والجملة نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك يدخلون الجنة يرزقون فيها بغير حساب﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span> اسم إشارة مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدخلون الجنة﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>، والجملة في محل جزم جواب الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرزقون﴾</span></span> حال، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بغير﴾</span></span> نعت للمفعول به المحذوف، أي: يرزقون رزقًا واسعًا بلا حساب ولا تبعة.</p></div>"
  40,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم ما لي أدعوكم إلى النجاة وتدعونني إلى النار﴾</span></span>: الواو عاطفة، ويا: أداة نداء، وقوم: منادى مضاف إلى ياء المتكلم المحذوفة، وياء المتكلم المحذوفة: ضمير مبني في محل جر مضاف إليه، وما: اسم استفهام مبتدأ، ولي: جار ومجرور متعلقان بمحذوف خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أدعوكم﴾</span></span>: فعل مضارع، وفاعل مستتر، والكاف: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدعوكم﴾</span></span>: حالية، وإلى النجاة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدعوكم﴾</span></span>، وتدعونني: فعل مضارع مرفوع بثبوت النون، والواو: فاعل، والنون للوقاية، والياء: مفعول به، وإلى النار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعونني﴾</span></span> في محل نصب حال من مقدر أي: وما لكم تدعونني، والجملة المقدرة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ما لي﴾</span></span>.</p></div>"
  40,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تدعونني لأكفر بالله وأشرك به ما ليس لي به علم﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿تدعونني﴾</span></span> في محل نصب بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿تدعونني﴾</span></span> الأولى، و<span class="hlt"><span class="qpc-hafs">﴿لأكفر﴾</span></span>: اللام للتعليل، وأكفر: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والفاعل مستتر تقديره أنا، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدعونني﴾</span></span>، وبالله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكفر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أشرك﴾</span></span>: الواو عاطفة، وأشرك: فعل مضارع، والفاعل مستتر، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشرك﴾</span></span>، وما: اسم موصول في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس لي به علم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وليس: فعل ماض ناقص، ولي: جار ومجرور متعلقان بمحذوف خبر مقدم، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، وعلم: اسم ليس المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا أدعوكم إلى العزيز الغفار﴾</span></span>: الواو عاطفة، وأنا: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أدعوكم﴾</span></span>: فعل، وفاعل مستتر، والكاف: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدعوكم﴾</span></span>: خبر، وإلى العزيز: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدعوكم﴾</span></span>، والغفار: نعت مجرور.</p></div>"
  40,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا جرم أنما تدعونني إليه ليس له دعوة في الدنيا ولا في الآخرة﴾</span></span>: لا نافية، وجرم: فعل ماض، وأن وما في حيزها فاعل جرم، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسمها، وحقها أن تكتب مفصولة، لأن ما اسم موصول بمعنى الذي، لكنها رسمت موصولة اتباعًا لسنة المصحف، وتدعونني: فعل مضارع مرفوع بثبوت النون، والواو: فاعل، والنون للوقاية، والياء: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعونني﴾</span></span> صلة الموصول لا محل لها من الإعراب، وإليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدعونني﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>: خبر أن، وليس: فعل ماض ناقص، وله: خبر ليس المقدم، ودعوة: اسمها المؤخر، وفي الدنيا: جار ومجرور متعلقان بمحذوف نعت لدعوة. <span class="hlt"><span class="qpc-hafs">﴿ولا في الآخرة﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> صلة لتوكيد النفي، وفي الآخرة: جار ومجرور متعلقان بمحذوف نعت لدعوة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن مردنا إلى الله وأن المسرفين هم أصحاب النار﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، ومردنا اسمها، وإلى الله: جار ومجرور متعلقان بمحذوف خبر إن. <span class="hlt"><span class="qpc-hafs">﴿وأن المسرفين﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، والمسرفين اسمها، وهم: ضمير فصل لا محل له من الإعراب، أو مبتدأ، وأصحاب: خبر أن أو خبر هم، والجملة خبر أن، والنار: مضاف إليه.</p></div>"
  40,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فستذكرون ما أقول لكم وأفوض أمري إلى الله﴾</span></span>: الفاء الفصيحة، والسين: حرف استقبال، وتذكرون: فعل مضارع، والواو: فاعل، وما: مفعول به، وأقول: فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أقول﴾</span></span>: صلة الموصول لا محل لها من الإعراب. ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقول﴾</span></span>، وأفوض: الواو عاطفة، وأفوض: فعل مضارع، والفاعل مستتر، وأمري: مفعول به، والياء: مضاف إليه، وإلى الله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفوض﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله بصير بالعباد﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وبصير خبرها، وبالعباد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصير﴾</span></span>.</p></div>"
  40,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فوقاه الله سيئات ما مكروا وحاق بآل فرعون سوء العذاب﴾</span></span>: الفاء عاطفة على محذوف يقتضيه السياق، أي: لما توعدوه بالقتل فطلبوه فلم يقدروا عليه فوقاه الله. و<span class="hlt"><span class="qpc-hafs">﴿وقاه الله﴾</span></span>: فعل ماض، ومفعول به أول مقدم، وفاعل مؤخر، وسيئات: مفعول به ثان، أو نصب بنزع الخافض، وما: موصولة في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿مكروا﴾</span></span>: فعل ماض، والواو: فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿مكروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. أو أن ما: مصدرية، فهي وما بعدها في تأويل مصدر مضاف إليه مجرور، وحاق: فعل ماض، وبآل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حاق﴾</span></span>، وفرعون: مضاف إليه، وسوء: فاعل، والعذاب: مضاف إليه.</p></div>"
  40,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿النار يعرضون عليها غدوا وعشيا﴾</span></span>: النار: خبر لمبتدأ محذوف، أي: هي، أو تعرب بدلًا من سوء العذاب، وعلى هذين الوجهين تعرب جملة <span class="hlt"><span class="qpc-hafs">﴿يعرضون﴾</span></span> حالًا، أو تعرب <span class="hlt"><span class="qpc-hafs">﴿النار﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعرضون﴾</span></span> خبر، وعليها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعرضون﴾</span></span>، وغدوًّا: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعرضون﴾</span></span>، وعشيا: عطف على <span class="hlt"><span class="qpc-hafs">﴿غدوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم الساعة أدخلوا آل فرعون أشد العذاب﴾</span></span>: الواو عاطفة، ويوم: ظرف متعلق بقول محذوف، أي: يقول الله يوم تقوم الساعة، و<span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span>: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span> في محل جر مضاف إليه، وأدخلوا: فعل أمر مبني على حذف النون، والواو: فاعل، وآل: مفعول به، وفرعون: مضاف إليه، وأشد: مفعول به ثان بتضمين <span class="hlt"><span class="qpc-hafs">﴿أدخلوا﴾</span></span> معنى أذيقوا، والعذاب: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدخلوا﴾</span></span>: في محل نصب مقول قول مقدر.</p></div>"
  40,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ يتحاجون في النار فيقول الضعفاء للذين استكبروا﴾</span></span>: الواو استئنافية، وإذ: اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر يا محمد لقومك. ويتحاجون: فعل مضارع مرفوع بثبوت النون، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتحاجون﴾</span></span>: في محل جر بالإضافة، وفي النار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتحاجون﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقول الضعفاء﴾</span></span>: فعل مضارع، وفاعل، وللذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، واستكبروا: فعل ماض، والواو: فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿استكبروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا كنا لكم تبعا فهل أنتم مغنون عنا نصيبا من النار﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: خبرها، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ولكم: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿تبعًا﴾</span></span>، أو متعلقان به إذا اعتبر مصدرًا، وتبعا خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا لكم تبعا﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مقول القول، <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span>: الفاء عاطفة، وهل: حرف استفهام، وأنتم: مبتدأ، ومغنون: خبره، وعنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مغنون﴾</span></span>، ونصيبًا: مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿مغنون﴾</span></span>، ومن النار: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نصيبًا﴾</span></span>.</p></div>"
  40,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين استكبروا إنا كل فيها﴾</span></span>: قال الذين: فعل ماض، وفاعل، واستكبروا: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿استكبروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وإنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وكل: مبتدأ ساغ الابتداء به لما فيه من معنى العموم، وفيها: جار ومجرور متعلقان بمحذوف خبر كل، والجملة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله قد حكم بين العباد﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وقد: حرف تحقيق، وحكم: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد حكم﴾</span></span>: خبر إن، وبين: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿حكم﴾</span></span>، والعباد: مضاف إليه.</p></div>"
  40,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين في النار لخزنة جهنم ادعوا ربكم يخفف عنا يوما من العذاب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span>: فعل ماض، وفاعل. وفي النار: جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب. ولخزنة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجهنم: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ادعوا﴾</span></span>: فعل أمر مبني على حذف النون، والواو: فاعل، وربكم: مفعول به، والجملة مقول القول، ويخفف: فعل مضارع مجزوم لأنه جواب الطلب، والفاعل مستتر، وعنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخفف﴾</span></span>، ويومًا: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يخفف﴾</span></span> أيضًا، ومن العذاب: جار ومجرور متعلقان بمحذوف صفة لمحذوف هو مفعول يخفف، أي: يخفف عنا شيئًا من العذاب في يوم.</p></div>"
  40,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أولم تك تأتيكم رسلكم بالبينات﴾</span></span>: قالوا: فعل وفاعل، والضمير يعود لخزنة جهنم، والهمزة للاستفهام، والواو عاطفة، ولم: حرف نفي وقلب وجزم، وتك: فعل مضارع مجزوم، وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، واسم تك مستتر، وتأتيكم: فعل مضارع، والكاف: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتيكم﴾</span></span> خبر، ورسلكم: فاعل تأتيكم، وقد تنازعه كل من تك وتأتيكم، فأعطى فاعلًا للثاني وأضمر في الأول. وبالبينات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأتيكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بلى﴾</span></span>: قالوا: فعل وفاعل، وبلى: حرف جواب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا فادعوا﴾</span></span>: قالوا: فعل وفاعل، فادعوا: الفاء الفصيحة، وادعوا: فعل أمر مبني على حذف النون، والواو: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما دعاء الكافرين إلا في ضلال﴾</span></span>: الواو للحال، وما نافية، ودعاء: مبتدأ، والكافرين: مضاف إليه، وإلا: أداة حصر، وفي ضلال: جار ومجرور متعلقان بمحذوف خبر دعاء.</p></div>"
  40,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا لننصر رسلنا والذين آمنوا في الحياة الدنيا ويوم يقوم الأشهاد﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ننصر رسلنا﴾</span></span>: فعل، وفاعل مستتر، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ننصر رسلنا﴾</span></span>: خبر إن، والذين: عطف على رسلنا، وآمنوا: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وفي الحياة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننصر﴾</span></span>، والدنيا: نعت مجرور، ويوم: ظرف زمان منصوب على الظرفية متعلق بمحذوف دل عليه قوله: <span class="hlt"><span class="qpc-hafs">﴿ننصر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يقوم الأشهاد﴾</span></span>: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقوم الأشهاد﴾</span></span>: في محل جر بإضافة الظرف إليها.</p></div>"
  40,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم لا ينفع الظالمين معذرتهم ولهم اللعنة ولهم سوء الدار﴾</span></span>: يوم: بدل من كلمة <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> في الآية السابقة، ولا نافية، وينفع: فعل مضارع، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ينفع﴾</span></span> في محل جر بإضافة الظرف إليها، والظالمين: مفعول به، ومعذرتهم: فاعل، والهاء: مضاف إليه، والواو عاطفة، ولهم: جار ومجرور متعلقان بمحذوف خبر مقدم، واللعنة: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لهم سوء الدار﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿لهم اللعنة﴾</span></span>، والدار: مضاف إليه.</p></div>"
  40,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى الهدى وأورثنا بني إسرائيل الكتاب﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد: حرف تحقيق، وآتينا: فعل وفاعل، وموسى: مفعول به أول، والهدى: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا...﴾</span></span> مستأنفة لا محل لها من الإعراب، وأورثنا: الواو عاطفة، وأورثنا: فعل وفاعل، وبني: مفعول به أول، وإسرائيل: مضاف إليه، والكتاب: مفعول به ثان.</p></div>"
  40,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هدى وذكرى لأولي الألباب﴾</span></span>: هدى: نصبت على أنها مفعول لأجله، أو على أنها مصدر في موضع الحال، وذكرى: عطف على هدى، ولأولي: جار ومجرور متعلقان بمحذوف نعت لذكرى، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذكرى﴾</span></span>، والألباب: مضاف إليه.</p></div>"
  40,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر إن وعد الله حق واستغفر لذنبك﴾</span></span>: الفاء الفصيحة، واصبر: فعل أمر، والفاعل مستتر، وإن حرف ناسخ، ووعد اسمها، ولفظ الجلالة مضاف إليه، وحق خبر إن، واستغفر: الواو عاطفة، واستغفر: فعل أمر، والفاعل مستتر، ولذنبك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استغفر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبح بحمد ربك بالعشي والإبكار﴾</span></span>: الواو عاطفة، وبحمد: جار ومجرور متعلقان بمحذوف حال، وربك: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بالعشي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبح﴾</span></span>، والإبكار: معطوف على العشي مجرور.</p></div>"
  40,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يجادلون في آيات الله بغير سلطان أتاهم﴾</span></span>: إن حرف ناسخ، والذين اسمها، ويجادلون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادلون﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وفي آيات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادلون﴾</span></span>، وبغير: جار ومجرور متعلقان بمحذوف حال، وسلطان: مضاف إليه، وأتاهم: فعل، وفاعل مستتر، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتاهم﴾</span></span>: نعت لسلطان.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في صدورهم إلا كبر ما هم ببالغيه﴾</span></span>: إنْ نافية، وفي صدورهم: جار ومجرور متعلقان بمحذوف خبر مقدم، وإلا: أداة حصر، وكبر: مبتدأ مؤخر، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إنّ﴾</span></span>، وما: نافية حجازية تعمل عمل ليس، وهم: اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿ببالغيه﴾</span></span>: الباء حرف جر صلة، وبالغيه: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما هم ببالغيه﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كبر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستعذ بالله إنه هو السميع البصير﴾</span></span>: الفاء الفصيحة، واستعذ: فعل أمر، وفاعله مستتر تقديره أنت، وبالله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استعذ﴾</span></span>، وإن حرف ناسخ، والهاء اسمها، وهو: ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿السميع البصير﴾</span></span>: خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو أن <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿السميع البصير﴾</span></span>: خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة من المبتدأ والخبر في محل رفع خبر إن.</p></div>"
  40,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لخلق السماوات والأرض أكبر من خلق الناس ولكن أكثر الناس لا يعلمون﴾</span></span>: اللام: لام الابتداء، وخلق: مبتدأ، والسماوات: مضاف إليه، والأرض: معطوف على السماوات مجرور، وأكبر: خبر، ومن خلق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكبر﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس﴾</span></span>: الواو للحال، ولكن حرف ناسخ، وأكثر اسمها، والناس: مضاف إليه، ولا: نافية، ويعلمون: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span>: خبر إن.</p></div>"
  40,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يستوي الأعمى والبصير والذين آمنوا وعملوا الصالحات ولا المسيء﴾</span></span>: الواو: عطف على ما تقدم، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿يستوي الأعمى﴾</span></span>: فعل مضارع وفاعل، والبصير: عطف على الأعمى، <span class="hlt"><span class="qpc-hafs">﴿والذين﴾</span></span>: الواو عاطفة من باب عطف جملة على جملة والتقدير: وما يستوي الذين ...، والذين: فاعل للفعل المقدر، وآمنوا: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span>: فعل، وفاعل، ومفعول به. <span class="hlt"><span class="qpc-hafs">﴿ولا المسيء﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: صلة لتوكيد النفي، والمسيء: عطف على الذين.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تتذكرون تذكرا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تتذكرون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قليلا ما تتذكرون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  40,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الساعة لآتية لا ريب فيها﴾</span></span>: إن حرف ناسخ، والساعة اسمها، واللام المزحلقة، وآتية: خبر إن، ولا: نافية للجنس، وريب: اسمها، وفيها: خبرها، والجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لكن أكثر الناس لا يؤمنون﴾</span></span>: الواو حالية، ولكن: حرف استدراك ونصب، وأكثر: اسمها، والناس: مضاف إليه، ولا: نافية، ويؤمنون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span>: خبر لكن.</p></div>"
  40,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال ربكم ادعوني أستجب لكم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قال ربكم﴾</span></span>: فعل ماض وفاعل، وادعوني: فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء مفعول به، والجملة مقول القول، وأستجب: فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أستجب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقال ربكم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يستكبرون عن عبادتي سيدخلون جهنم داخرين﴾</span></span>: إن حرف ناسخ، والذين اسمها، ويستكبرون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span>: صلة الذين لا محل لها من الإعراب. وعن عبادتي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span>، والياء: مضاف إليه، وسيدخلون: السين للاستقبال، ويدخلون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيدخلون﴾</span></span>: خبر إن، وجهنم: مفعول به على السعة، وداخرين: حال.</p></div>"
  40,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله الذي جعل لكم الليل لتسكنوا فيه والنهار مبصرا﴾</span></span>: الله: مبتدأ، والذي: خبره، وجعل: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>: صلة الموصول لا محل لها من الإعراب. ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، أو متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والليل: مفعول به، ولتسكنوا: اللام للتعليل، وتسكنوا فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والواو: فاعل، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسكنوا﴾</span></span>، والنهار: عطف على الليل، ومبصرًا: حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لذو فضل على الناس ولكن أكثر الناس لا يشكرون﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وذو: خبر إن، وفضل: مضاف إليه، وعلى الناس: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ولكنَّ أكثر الناس﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، وأكثر اسمها، والناس: مضاف إليه، ولا: نافية، ويشكرون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يشكرون﴾</span></span>: خبر لكن.</p></div>"
  40,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلكم الله ربكم خالق كل شيء﴾</span></span>: اسم الإشارة: مبتدأ، والله: خبر أول، وربكم: خبر ثان، والكاف: مضاف إليه، وخالق: خبر ثالث، وكل: مضاف إليه وهو مضاف، وشيء: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر رابع.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنى تؤفكون﴾</span></span>: الفاء الفصيحة، وأنى: اسم استفهام بمعنى كيف في محل نصب حال، وتؤفكون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  40,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك يؤفك الذين كانوا بآيات الله يجحدون﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي:  مثلَ أفككم يؤفك الذين...، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ويؤفك: فعل مضارع مبني لما لم يسمَّ فاعله، والذين: نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وكان فعل ماض ناقص، وواو الجماعة اسمها، وبآيات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>، ويجحدون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>: خبر كان.</p></div>"
  40,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله الذي جعل لكم الأرض قرارا والسماء بناء وصوركم فأحسن صوركم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والله: مبتدأ، والذي: خبره، وجعل: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>: صلة الموصول لا محل لها من الإعراب. ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والأرض: مفعول به أول، وقرارًا: مفعول به ثان، <span class="hlt"><span class="qpc-hafs">﴿والسماء بناء﴾</span></span>: معطوفان على <span class="hlt"><span class="qpc-hafs">﴿الأرض قرارا﴾</span></span> منصوبان، وصوركم: فعل وفاعل مستتر ومفعول به، فأحسن: الفاء عاطفة، وأحسن: فعل ماض، والفاعل مستتر، وصوركم: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقكم من الطيبات ذلكم الله ربكم﴾</span></span>: الواو عاطفة، ورزقكم: فعل، وفاعل مستتر، والكاف: مفعول به، ومن الطيبات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقكم﴾</span></span>، وذلكم: مبتدأ، والله: خبر، وربكم: خبر ثان، والكاف: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتبارك الله رب العالمين﴾</span></span>: الفاء: حرف عطف، وتبارك: فعل ماض، والله: فاعل، ورب: نعت لله، والعالمين: مضاف إليه.</p></div>"
  40,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الحي﴾</span></span>: هو: مبتدأ، والحي: خبر، <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> في محل رفع خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فادعوه مخلصين له الدين﴾</span></span>: الفاء الفصيحة، وادعوه: فعل أمر، وفاعل، ومفعول به، ومخلصين: حال، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span>، والدين: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحمد لله رب العالمين﴾</span></span>: الحمد: مبتدأ، ولله: جار ومجرور متعلقان بمحذوف خبر، ورب: صفة لله، والعالمين: مضاف إليه مجرور وعلامة جره الياء نيابة عن الكسرة، لأنه ملحق بجمع المذكَّر السالم، والجملة مقول لقول محذوف هو حال من فاعل فادعوه، أي قائلين: <span class="hlt"><span class="qpc-hafs">﴿الحمد لله ...﴾</span></span>، أو مستأنفة على أنها من كلامه ذاته سبحانه، وهي لا محل لها من الإعراب.</p></div>"
  40,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إني نهيت أن أعبد الذين تدعون من دون الله لما جاءني البينات من ربي﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني نهيت...﴾</span></span> في محل نصب مقول القول، وإن حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿نهيت﴾</span></span>: خبر إن، ونهيت: فعل ماض مبني لما لم يسمَّ فاعله، والتاء: نائب فاعل، وأن: حرف مصدري ونصب، وأعبد: فعل مضارع منصوب، والفاعل مستتر، والذين: اسم موصول في محل نصب مفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما بعدها منصوب بنزع الخافض، أي: عن عبادة الذين تدعون، وتدعون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب، ومن دون الله: الجار والمجرور متعلقان بمحذوف حال، ولفظ الجلالة: مضاف إليه، ولما: ظرف بمعنى حين في محل نصب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نهيت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جاءني البينات﴾</span></span>: فعل ماض، والياء مفعول به مقدم، والبينات فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءني﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأمرت أن أسلم لرب العالمين﴾</span></span>: الواو عاطفة، وأمرت: فعل ماض، والتاء فاعل، وأن: حرف مصدري ونصب، وأسلم: فعل مضارع منصوب، والفاعل مستتر، وأن وما في حيزها نصب بنزع الخافض، أي: بالإسلام، ولرب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسلم﴾</span></span>، والعالمين: مضاف إليه.</p></div>"
  40,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي خلقكم من تراب ثم من نطفة ثم من علقة﴾</span></span>: هو: مبتدأ، والذي: خبر، وخلقكم: فعل ماض، والفاعل مستتر، والكاف: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. ومن تراب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span>، والكلام مستأنف لا محل له من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿ثم من نطفة ثم من علقة﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من تراب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم يخرجكم طفلا﴾</span></span>: عطف أيضًا، ويخرجكم: فعل مضارع، وفاعل مستتر، والكاف: مفعول به، وطفلًا: حال من الكاف في <span class="hlt"><span class="qpc-hafs">﴿يخرجكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لتبلغوا أشدكم ثم لتكونوا شيوخا﴾</span></span>: عطف أيضًا، واللام للتعليل، وتبلغوا: فعل مضارع منصوب بأن مضمرة بعد اللام، والواو: فاعل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بفعل محذوف، تقديره: ثم يبقيكم، <span class="hlt"><span class="qpc-hafs">﴿لتكونوا﴾</span></span>: اللام: للتعليل، وتكونوا: فعل مضارع ناقص منصوب بأن مضمرة بعد اللام، والواو: اسم <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>، وشيوخا: خبرها، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بفعل محذوف، تقديره: ثم يبقيكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومنكم من يتوفى من قبل﴾</span></span>: الواو عاطفة، ومنكم: جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول مبني في محل رفع مبتدأ، ويتوفى: فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، ومن قبل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتوفى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتبلغوا أجلا مسمى ولعلكم تعقلون﴾</span></span>: الواو عاطفة، ولتبلغوا: اللام للتعليل، وتبلغوا: فعل مضارع منصوب بأن مضمرة بعد اللام، والواو: فاعل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بفعل محذوف، تقديره: ثم يبقيكم، وأجلًا: مفعول به، ومسمى: نعت، ولعلكم: الواو عاطفة، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة تعقلون: خبر لعل، وتعقلون: فعل مضارع، والواو فاعل.</p></div>"
  40,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي يحيي ويميت فإذا قضى أمرا فإنما يقول له كن فيكون﴾</span></span>: هو: مبتدأ، والذي: خبره، ويحيي: فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span>: صلة الموصول لا محل لها من الإعراب. ويميت: عطف على يحيي، فإذا: الفاء عاطفة، وإذا: ظرف مستقبل في محل نصب متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، وقضى: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قضى﴾</span></span>: في محل جر بإضافة الظرف إليها، وأمرًا: مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإنما﴾</span></span>: الفاء رابطة، وإنما: كافة ومكفوفة، ويقول: فعل مضارع، والفاعل مستتر تقديره هو، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، وكن: فعل أمر تام، وفاعل مستتر تقديره أنت. <span class="hlt"><span class="qpc-hafs">﴿فيكون﴾</span></span>: الفاء استئنافية، ويكون: فعل مضارع تام مرفوع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span>: خبر لمبتدأ محذوف، أي فهو يكون، أو أنها معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> أو <span class="hlt"><span class="qpc-hafs">﴿كن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فيكون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  40,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر إلى الذين يجادلون في آيات الله أنى يصرفون﴾</span></span>: الهمزة للاستفهام، ولم: حرف نفي وقلب وجزم، وتر: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والفاعل مستتر تقديره أنت، وإلى الذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، ويجادلون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادلون﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وفي آيات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، ولفظ الجلالة: مضاف إليه، وأنى: اسم استفهام في محل نصب حال، ويصرفون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  40,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين كذبوا بالكتاب وبما أرسلنا به رسلنا فسوف يعلمون﴾</span></span>: الذين: اسم موصول في محل جر بدل من <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> في الآية السابقة، أو في محل رفع خبر لمبتدأ محذوف، أو في محل نصب على الذم، أو في محل رفع مبتدأ وخبره <span class="hlt"><span class="qpc-hafs">﴿فسوف يعلمون﴾</span></span>. وكذبوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وبالكتاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، وبما: الواو عاطفة، والباء: حرف جر، وما: اسم موصول في محل جر، وأرسلنا: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ورسلنا: مفعول به. و<span class="hlt"><span class="qpc-hafs">﴿فسوف يعلمون﴾</span></span>: الفاء استئنافية، وسوف: حرف استقبال، ويعلمون: فعل مضارع مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿فسوف يعلمون﴾</span></span> مستأنفة لا محل لها من الإعراب، أو في محل رفع خبر، على اعتبار <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مبتدأ، والفاء رابطة لما في الموصول من رائحة الشرط.</p></div>"
  40,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ الأغلال في أعناقهم والسلاسل يسحبون﴾</span></span>: إذ: ظرف لما مضى من الزمن أريد به المستقبل متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> في الآية السابقة، أو اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، والأغلال: مبتدأ، وفي أعناقهم: جار ومجرور متعلقان بمحذوف خبر، والهاء: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿الأغلال في أعناقهم﴾</span></span> في محل جر مضاف إليه، والسلاسل: في إعرابها ثلاثة أوجه:</p><p>أحدها: أنه معطوف على الأغلال، وأخبر عن النوعين بالجار، فالجار في نية التأخير. والتقدير: إذ الأغلال والسلاسل في أعناقهم.</p><p>الثاني: أنه مبتدأ، وخبره محذوف لدلالة خبر الأول عليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿يسحبون﴾</span></span> على الوجهين المتقدمين في محل نصب حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿أعناقهم﴾</span></span>، أو مستأنفة لا محل لها من الإعراب.</p><p>الثالث: أنه مبتدأ أيضا، وخبره الجملة من قوله: <span class="hlt"><span class="qpc-hafs">﴿يسحبون﴾</span></span>. ولا بد من ذكر يعود عليه منها. والتقدير: والسلاسل يسحبون بها. حذف لقوة الدلالة عليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسحبون﴾</span></span> في محل رفع خبر على هذا الوجه.</p></div>"
  40,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في الحميم ثم في النار يسجرون﴾</span></span>: في الحميم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسحبون﴾</span></span>، ثم: حرف عطف للتراخي، وفي النار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسجرون﴾</span></span>، ويسجرون: فعل مضارع، والواو فاعل، والجملة عطف على ما قبلها.</p></div>"
  40,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم قيل لهم أين ما كنتم تشركون﴾</span></span>: ثم: حرف عطف، وقيل: فعل ماض مبني لما لم يسمَّ فاعله، لهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وأين: اسم استفهام في محل نصب على الظرفين المكانية، والظرف متعلق بمحذوف خبر مقدم، وما: اسم موصول مبتدأ مؤخر، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿تشركون﴾</span></span>: خبر كان، وتشركون: فعل مضارع، والواو فاعل، وجملة مقول القول <span class="hlt"><span class="qpc-hafs">﴿أين ...﴾</span></span> في محل رفع نائب فاعل.</p></div>"
  40,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من دون الله قالوا ضلوا عنا﴾</span></span>: من دون: جار ومجرور متعلقان بمحذوف حال من مفعول به محذوف لـ<span class="hlt"><span class="qpc-hafs">﴿تشركون﴾</span></span> في الآية السابقة، ولفظ الجلالة: مضاف إليه، وقالوا: فعل وفاعل، وضلوا: فعل، وفاعل، وعنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ضلوا عنا﴾</span></span>: مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل لم نكن ندعو من قبل شيئا كذلك يضل الله الكافرين﴾</span></span>: بل: حرف إضراب انتقالي، ولم: حرف نفي وقلب وجزم، ونكن: فعل مضارع ناقص مجزوم بلم، واسمها مستتر تقديره نحن، وجملة <span class="hlt"><span class="qpc-hafs">﴿ندعو﴾</span></span> خبرها، وندعو: فعل مضارع، والواو: فاعل، ومن قبل: جار ومجرور متعلقان بمحذوف حال، وشيئًا: مفعول به، وكذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يضل الله الكافرين﴾</span></span>: فعل مضارع، وفاعل، ومفعول به.</p></div>"
  40,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلكم بما كنتم تفرحون في الأرض بغير الحق﴾</span></span>: ذلكم: اسم الإشارة مبتدأ، وبما: الباء: حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مبني في محل جر، و الجار والمجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: مصدرية، وهي وما بعدها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بمحذوف خبر، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تفرحون﴾</span></span>: خبر كان، وتفرحون: فعل مضارع، والواو فاعل، وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفرحون﴾</span></span>، وبغير: جار ومجرور متعلقان بمحذوف حال، والحق: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبما كنتم تمرحون﴾</span></span>: الواو عاطفة، وبما: الباء: حرف جر، وما: اسم موصول مبني في محل جر، و الجار والمجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. أو ما: مصدرية، وهي وما بعدها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بمحذوف خبر، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمرحون﴾</span></span>: خبر كان، وتمرحون: فعل مضارع، والواو فاعل.</p></div>"
  40,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادخلوا أبواب جهنم خالدين فيها فبئس مثوى المتكبرين﴾</span></span>: ادخلوا: فعل أمر مبني على حذف النون، والواو فاعل، والجملة مقول قول محذوف، وأبواب: مفعول به على السعة، وجهنم: مضاف إليه، وخالدين: حال، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدين﴾</span></span>، والفاء عاطفة، وبئس: فعل ماض جامد لإنشاء الذم، ومثوى: فاعل بئس، والمتكبرين: مضاف إليه، والمخصوص بالذم محذوف، تقديره: هي.</p></div>"
  40,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر إن وعد الله حق﴾</span></span>: الفاء استئنافية، واصبر: فعل أمر، وفاعله مستتر تقديره أنت، وإن حرف ناسخ، ووعد اسمها، ولفظ الجلالة مضاف إليه، وحق خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿فاصبر...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإما نرينك بعض الذي نعدهم أو نتوفينك فإلينا يرجعون﴾</span></span>: الفاء عاطفة، وإن الشرطية مدغمة في ما الصلة، ونرينك: فعل الشرط مبني على الفتح لاتصاله بنون التوكيد الثقيلة في محل جزم، والفاعل مستتر تقديره نحن، والكاف: مفعول به، وبعض: مفعول به ثان، والذي: اسم موصول مبني في محل جر مضاف إليه، ونعدهم: فعل مضارع، وفاعل مستتر، والهاء: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعدهم﴾</span></span>: صلة الذي لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿أو نتوفينك﴾</span></span>: أو: حرف عطف، ونتوفينك: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، في محل جزم، والفاعل مستتر، والكاف: مفعول به، والفاء رابطة، وإلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، ويرجعون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل، والجملة في محل رفع خبر لمبتدأ محذوف تقديره: هم، والجملة الاسمية جواب للشرط الثاني، وهو <span class="hlt"><span class="qpc-hafs">﴿نتوفينك﴾</span></span>، وجواب الشرط الأول محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿فذاك أمر بيِّن﴾</span></span>، والجملة الشرطية استئنافية لا محل لها من الإعراب.</p></div>"
  40,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا رسلا من قبلك﴾</span></span>: الواو استئنافية، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿رسلا﴾</span></span>: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من قبلك﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسلا﴾</span></span> أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> والكاف مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿منهم من قصصنا عليك ومنهم من لم نقصص عليك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل رفع مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span>: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span> صلة الاسم الموصول <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿منهم من قصصنا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسلا﴾</span></span> أو مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿ومنهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل رفع مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>: حرف نفي وجزم وقلب، و<span class="hlt"><span class="qpc-hafs">﴿نقصص﴾</span></span>: فعل مضارع مجزوم بلم، والفاعل مستتر تقديره نحن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم نقصص﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.  و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقصص﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿منهم من لم نقصص عليك﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿منهم من قصصنا عليك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لرسول أن يأتي بآية إلا بإذن الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لرسول﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿أن يأتي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span> فعل مضارع منصوب بأن، والفاعل مستتر تقديره هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يأتي﴾</span></span> اسم كان المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿بآية﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بإذن﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، واسم الجلالة مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما كان لرسول...﴾</span></span> معطوفة على سابقتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء أمر الله قضي بالحق وخسر هنالك المبطلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿أمر﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: اسم الجلالة مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء أمر الله﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span>: فعل ماض مبني لما لم يُسَمَّ فاعله، ونائب الفاعل مستتر تقديره هو، أي: الأمرُ، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من نائب الفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قضي بالحق﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، <span class="hlt"><span class="qpc-hafs">﴿وخسر﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿خسر﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هنالك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هنا﴾</span></span> اسم إشارة في محل نصب ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خسر﴾</span></span>، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿المبطلون﴾</span></span>: فاعل خسر، وجملة <span class="hlt"><span class="qpc-hafs">﴿خسر هنالك المبطلون﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿قضي بالحق﴾</span></span>.</p></div>"
  40,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله الذي جعل لكم الأنعام لتركبوا منها ومنها تأكلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>: اسم موصول في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> فعل ماض بمعنى خلق، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأنعام﴾</span></span>: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل لكم الأنعام﴾</span></span> صلة الذي لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لتركبوا﴾</span></span>: اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿تركبوا﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وواو الجماعة فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل مجرور بلام التعليل، ولام التعليل ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لمفعول مقدر للفعل <span class="hlt"><span class="qpc-hafs">﴿تركبوا﴾</span></span>، أي: لتركبوا بعضا منها، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبعيض. <span class="hlt"><span class="qpc-hafs">﴿ومنها﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول مقدر للفعل <span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span>، أي: وتأكلون بعضا منها، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبعيض، وجملة <span class="hlt"><span class="qpc-hafs">﴿منها تأكلون﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿لتركبوا منها﴾</span></span> على المعنى، فإن قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿لتركبوا منها﴾</span></span> في معنى <span class="hlt"><span class="qpc-hafs">﴿منها تركبون﴾</span></span>، أو قوله: <span class="hlt"><span class="qpc-hafs">﴿منها تأكلون﴾</span></span> في معنى <span class="hlt"><span class="qpc-hafs">﴿لتأكلوا منها﴾</span></span>.</p></div>"
  40,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكم فيها منافع ولتبلغوا عليها حاجة في صدوركم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿منافع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منافع﴾</span></span>: مبتدأ مؤخر، وقوله: <span class="hlt"><span class="qpc-hafs">﴿ولكم فيها منافع﴾</span></span> عطف على المعنى أيضا، أي: ولتنتفعوا بمنافع فيها، <span class="hlt"><span class="qpc-hafs">﴿ولتبلغوا﴾</span></span>: الواو عاطفة، واللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿تبلغوا﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وواو الجماعة فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل <span class="hlt"><span class="qpc-hafs">﴿تبلغوا﴾</span></span> مجرور بلام التعليل، ولام التعليل ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل في <span class="hlt"><span class="qpc-hafs">﴿تبلغوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حاجة﴾</span></span>: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في صدوركم﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حاجة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لتبلغوا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿لتركبوا﴾</span></span> أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعليها وعلى الفلك تحملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وعليها﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحملون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وعلى الفلك﴾</span></span>: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿وعليها﴾</span></span>، والجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿على الفلك﴾</span></span> متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحملون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تحملون﴾</span></span>: فعل مضارع مبني لما لم يُسَمَّ فاعله، وواو الجماعة نائب فاعل.</p></div>"
  40,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويريكم آياته﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span>: فعل مضارع، والفاعل مستتر تقديره هو، والكاف مفعول به أول، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿آياته﴾</span></span>: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span> والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريكم آياته﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿جعل لكم الأنعام﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأي آيات الله تنكرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأي﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> اسم استفهام مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تنكرون﴾</span></span> وهو مقدم وجوبًا لأن أسماء الاستفهام لها الصدارة، والاستفهام للتوبيخ، و<span class="hlt"><span class="qpc-hafs">﴿آيات الله﴾</span></span>: مضاف إليه، وكلمة آيات مضافة إلى اسم الجلالة، واسم الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿تنكرون﴾</span></span>: فعل مضارع مرفوع، وواو الجماعة فاعل، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿يريكم آياته﴾</span></span>.</p></div>"
  40,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يسيروا في الأرض فينظروا كيف كان عاقبة الذين من قبلهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿أفلم﴾</span></span>: الهمزة: للاستفهام الإنكاري التوبيخي، والفاء: عاطفة على مقدر، أي: أقعدوا فلم يسيروا، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وجزم وقلب، و<span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>: فعل مضارع مجزوم بلم وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فينظروا﴾</span></span>: الفاء عاطفة على <span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span> أو سببية، و<span class="hlt"><span class="qpc-hafs">﴿ينظروا﴾</span></span> فعل مضارع إما مجزوم عطفًا على <span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>، وإما منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل معطوف على مصدر مأخوذ من الكلام السابق والتقدير: أفلم يكن منهم سير فنظر؟ وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span>: اسم استفهام في محل نصب خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿عاقبة﴾</span></span>: اسم كان المؤخر، والذين: اسم موصول في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والضمير المتصل مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿كيف كان عاقبة الذين من قبلهم﴾</span></span> في محل نصب مفعول للفعل <span class="hlt"><span class="qpc-hafs">﴿ينظروا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانوا أكثر منهم وأشد قوة وآثارا في الأرض﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span>: خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قوة﴾</span></span>: تمييز، <span class="hlt"><span class="qpc-hafs">﴿وآثارًا﴾</span></span> عطف على قوة، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آثارًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما أغنى عنهم ما كانوا يكسبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، أو استفهامية في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الثانية: اسم موصول في محل رفع فاعل، أي: ما أغنى عنهم الذي كانوا يكسبونه، أو مصدرية والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما كانوا يكسبون﴾</span></span> فاعل أغنى، أي: ما أغنى عنهم كسبهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أغنى...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿كانوا أكثر منهم...﴾</span></span>.</p></div>"
  40,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءتهم رسلهم بالبينات فرحوا بما عندهم من العلم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فلما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرف للزمن الماضي متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فرحوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جاءتهم﴾</span></span>: فعل ماض، والتاء للتأنيث، والهاء مفعول به مقدم، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿رسلهم﴾</span></span>: فاعل، والضمير المتصل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءتهم﴾</span></span> أو متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿رسلهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فرحوا﴾</span></span> فعل ماض، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فرحوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عندهم﴾</span></span>: ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، أي: بما استقر عندهم، والعائد فاعل استقر المقدر، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من العلم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من العائد المقدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فرحوا بما عندهم﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وحاق بهم ما كانوا به يستهزئون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وحاق﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿حاق﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حاق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول في محل رفع فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، وواو الجماعة اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>: فعل مضارع، وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span> خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا به يستهزئون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿حاق بهم ما كانوا...﴾</span></span> معطوفة على جواب الشرط.</p></div>"
  40,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأوا بأسنا قالوا آمنا بالله وحده﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فلما﴾</span></span>: الفاء: للعطف والتعقيب، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرف للزمن الماضي متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿رأوا﴾</span></span>: فعل ماض، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بأسنا﴾</span></span>: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأوا بأسنا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وحده﴾</span></span>: حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنا بالله وحده﴾</span></span> مقول القول في محل نصب، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا آمنا...﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكفرنا بما كنا به مشركين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كفرنا﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشركين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مشركين﴾</span></span> خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا به مشركين﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وكفرنا بما كنا...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿آمنا بالله وحده﴾</span></span> داخلة في حيز القول.</p></div>"
  40,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلم يك ينفعهم إيمانهم لما رأوا بأسنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فلم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وجزم وقلب، و<span class="hlt"><span class="qpc-hafs">﴿يكُ﴾</span></span> فعل مضارع ناقص مجزوم بلم، وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، واسم <span class="hlt"><span class="qpc-hafs">﴿يكُ﴾</span></span> ضمير الشأن مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿ينفعهم﴾</span></span>: فعل مضارع، والهاء مفعول به، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿إيمانهم﴾</span></span> فاعل ينفعهم، والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينفعهم إيمانهم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿يكُ﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿إيمانهم﴾</span></span> اسم كان وجملة <span class="hlt"><span class="qpc-hafs">﴿ينفعهم﴾</span></span> خبرها المقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يك ينفعهم﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿قالوا آمنا...﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرف بمعنى حين متضمن معنى الشرط متعلقة بالجواب المقدر، و<span class="hlt"><span class="qpc-hafs">﴿رأوا﴾</span></span>: فعل ماض، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بأسنا﴾</span></span>: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأوا بأسنا﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿سنت الله التي قد خلت في عباده﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سنة﴾</span></span>: مفعول مطلق لفعل محذوف، أي: سنَّ الله ذلك سنة، أو منصوب على التحذير فهو مفعول به لفعل مقدر، أي: احذروا سنة الله في المكذبين، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span>: اسم موصول في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سنة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿خلت﴾</span></span> فعل ماض والفاعل مستتر تقديره هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد خلت﴾</span></span> صلة الاسم الموصول <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿في عباده﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلت﴾</span></span> والهاء مضاف إليه، والجملة استئناف بياني أو اعتراضية، وهي على كلا الوجهين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وخسر هنالك الكافرون﴾</span></span>: الواو: عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿خسر﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هنالك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هنا﴾</span></span> اسم إشارة في محل نصب ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خسر﴾</span></span>، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿الكافرون﴾</span></span>: فاعل خسر، وجملة <span class="hlt"><span class="qpc-hafs">﴿خسر هنالك الكافرون﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿لم يك ينفعهم إيمانهم﴾</span></span>.</p></div>"
