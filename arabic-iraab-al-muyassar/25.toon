quran[77]{c,v,t}:
  25,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تبارك الذي نزل الفرقان على عبده ليكون للعالمين نذيرا﴾</span></span>: تبارك فعل ماض جامد، والذي فاعله، وجملة نزل الفرقان صلة الذي لا محل لها من الإعراب، وعلى عبده جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، واللام للتعليل، ويكون فعل مضارع ناقص منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للعالمين﴾</span></span> جار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذيرا﴾</span></span>، واسم يكون مستتر تقديره: هو، ونذيرًا خبر يكون.</p></div>"
  25,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي له ملك السماوات والأرض ولم يتخذ ولدا﴾</span></span>: الذي بدل من الموصول الأول، أو خبر لمبتدأ محذوف، أو منصوب على المدح، وما بعده تمام الصلة للموصول الأول، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر مقدم، وملك السماوات والأرض مبتدأ مؤخر، والجملة صلة الموصول لا محل لها من الإعراب، ولم يتخذ ولدًا عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم يكن له شريك في الملك وخلق كل شيء فقدره تقديرا﴾</span></span>: عطف على ما سبق، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر يكن المقدم، وشريك اسمها المؤخر، وفي الملك جار ومجرور متعلقان بشريك، وخلق عطف على ما سبق أيضا، وكل شئ مفعول خلق، فقدره: الفاء عاطفة، وقدره فعل ماض، وفاعل مستتر، ومفعول به، وتقديرًا مفعول مطلق.</p></div>"
  25,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتخذوا من دونه آلهة لا يخلقون شيئا وهم يخلقون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>، وآلهة مفعول اتخذوا الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿واتخذوا من دونه آلهة﴾</span></span> مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يخلقون شيئًا﴾</span></span> صفة لآلهة. <span class="hlt"><span class="qpc-hafs">﴿وهم يخلقون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ويخلقون بالبناء لما لم يسمَّ فاعله خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يملكون لأنفسهم ضرا ولا نفعا ولا يملكون موتا ولا حياة ولا نشورا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا يملكون﴾</span></span> جملة معطوفة على ما تقدم، ولأنفسهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يملكون﴾</span></span>، وضرًّا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا نفعًا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿ضرًّا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ولا يملكون موتًا﴾</span></span>: لا صلة لتوكيد النفي، <span class="hlt"><span class="qpc-hafs">﴿ولا يملكون موتا ولا حياة ولا نشورا﴾</span></span> مثل <span class="hlt"><span class="qpc-hafs">﴿ولا يملكون ضرا ولا نفعا﴾</span></span>.</p></div>"
  25,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا إن هذا إلا إفك افتراه﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والذين فاعل قال، وجملة كفروا صلة الذين لا محل لها من الإعراب، وإن نافية، وهذا مبتدأ، وإلا أداة حصر، وإفك خبر هذا، وجملة افتراه صفة لإفك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأعانه عليه قوم آخرون فقد جاءوا ظلما وزورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أعانه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿افتراه﴾</span></span>، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعانه﴾</span></span>، والضمير للإفك المفترى، وقوم فاعل، وآخرون صفة قوم، والفاء الفصيحة، وقد حرف تحقيق، وجاءوا فعل وفاعل، وقد تضمن معنى فعل فعُدِّيَ تعديته، وظلمًا مفعوله، أو هو -أي: الفعل- على بابه فلم يتعد، وظلمًا منصوب بنزع الخافض، أو منصوب على الحال المؤولة، أي: ظالمين، وزورًا عطف على <span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span>.</p></div>"
  25,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا أساطير الأولين اكتتبها فهي تملى عليه بكرة وأصيلا﴾</span></span>: الواو عاطفة، وقالوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أساطير الأولين﴾</span></span> خبر لمبتدأ محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿اكتتبها﴾</span></span> حالية، أو أساطير الأولين مبتدأ، وجملة اكتتبها خبر. <span class="hlt"><span class="qpc-hafs">﴿فهي﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة تملى خبر، ونائب الفاعل مستتر، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تملى﴾</span></span>، وبكرة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تملى﴾</span></span>، وأصيلًا عطف على بكرة.</p></div>"
  25,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أنزله الذي يعلم السر في السماوات والأرض﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، وجملة أنزله مقول القول، والهاء مفعول به، والذي فاعل، وجملة يعلم السر صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان غفورا رحيما﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان...﴾</span></span> خبرها، وكان فعل ماض ناقص ناسخ، واسمها مستتر، وغفورا خبر أول لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، ورحيمًا خبر ثان لها، وهي جملة لا محل لها من الإعراب، لأنها تعليلية.</p></div>"
  25,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا مال هذا الرسول يأكل الطعام ويمشي في الأسواق﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقالوا فعل وفاعل، وما اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهذا﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، والرسول بدل من اسم الإشارة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأكل الطعام﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿يأكل الطعام﴾</span></span> فعل وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمشي في الأسواق﴾</span></span> عطف عليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لولا أنزل إليه ملك فيكون معه نذيرا﴾</span></span>: لولا حرف تحضيض، وأنزل فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وملك نائب فاعل، والفاء فاء السببية، ويكون فعل مضارع منصوب بأن مضمرة بعد فاء السببية، لأنها جواب التحضيض، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق، أي: هلا كان نزول ملك فكونه معه نذيرا. واسم يكون مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> أي: المَلَك، ومعه ظرف مكان متعلق بمحذوف حال، ونذيرًا خبر يكون.</p></div>"
  25,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو يلقى إليه كنز أو تكون له جنة يأكل منها﴾</span></span>: أو حرف عطف، ويلقى فعل مضارع مبني لما لم يسمَّ فاعله، وكنز نائب فاعل، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقى﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿أو تكون له جنة﴾</span></span>: عطف على ما تقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأكل منها﴾</span></span> صفة لجنة، وهذان الفعلان معطوفان على أنزل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال الظالمون إن تتبعون إلا رجلا مسحورا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الظالمون﴾</span></span> فعل وفاعل، وإن نافية، وتتبعون فعل مضارع وفاعل، وإلا أداة حصر، ورجلًا مفعول به، ومسحورًا صفة.</p></div>"
  25,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿انظر كيف ضربوا لك الأمثال فضلوا فلا يستطيعون سبيلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> فعل أمر وفاعل مستتر تقديره: أنت، وكيف اسم استفهام في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضربوا﴾</span></span>، والأمثال مفعول به. <span class="hlt"><span class="qpc-hafs">﴿فضلوا﴾</span></span>: الفاء عاطفة، وضلوا فعل ماض وفاعل. <span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يستطيعون سبيلًا﴾</span></span>: فعل مضارع وفاعل ومفعول به.</p></div>"
  25,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تبارك الذي إن شاء جعل لك خيرا من ذلك﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿تبارك الذي﴾</span></span> فعل وفاعل، وقيل: على تقدير مضاف محذوف، أي: خير الذي، وإن شرطية، وشاء فعل ماض في محل جزم فعل الشرط، وجعل جواب الشرط، والجملة الشرطية صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعل الثاني، وخيرًا مفعول جعل الأول، و<span class="hlt"><span class="qpc-hafs">﴿من ذلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿جنات تجري من تحتها الأنهار ويجعل لك قصورا﴾</span></span>: جنات بدل من <span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span>، وجملة تجري صفة لجنات، و<span class="hlt"><span class="qpc-hafs">﴿من تحتها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، والأنهار فاعل تجري، ويجعل فعل مضارع معطوف على محل جعل الواقع جوابًا للشرط، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعل الثاني، وقصورًا مفعول أول.</p></div>"
  25,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل كذبوا بالساعة وأعتدنا لمن كذب بالساعة سعيرا﴾</span></span>: بل حرف للإضراب، وكذبوا فعل وفاعل، وبالساعة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span> فعل وفاعل، ولمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذب بالساعة﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿سعيرًا﴾</span></span> مفعول به.</p></div>"
  25,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذا رأتهم من مكان بعيد سمعوا لها تغيظا وزفيرا﴾</span></span>: الجملة الشرطية في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سعيرًا﴾</span></span>، لأنه مؤنث بمعنى النار، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأتهم﴾</span></span> في محل جر بإضافة إذا إليها، و<span class="hlt"><span class="qpc-hafs">﴿من مكان﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿سمعوا﴾</span></span> جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنها كانت في الأصل صفة، وتغيظًا مفعول به، وزفيرًا عطف عليه.</p></div>"
  25,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا ألقوا منها مكانا ضيقا مقرنين دعوا هنالك ثبورا﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span> مجرورة بإضافة الظرف إليها، وهو متعلق بالجواب وهو <span class="hlt"><span class="qpc-hafs">﴿دعوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، ومنها جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿مكانًا﴾</span></span>، لأنه في الأصل صفة له، ومكانًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span>، وضيقًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مكانًا﴾</span></span>، ومقرنين حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span>، وجملة دعوا لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والواو فاعل دعوا، وهنالك اسم إشارة في محل نصب على الظرفية المكانية، وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿دَعَوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ثبورًا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿دعوا﴾</span></span>، أو مفعول مطلق لفعل محذوف والتقدير: ثبرنا ثبورا.</p></div>"
  25,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا تدعوا اليوم ثبورا واحدا وادعوا ثبورا كثيرا﴾</span></span>: الجملة مقول القول محذوف تقديره: فيقال لهم، وهذا المحذوف معطوف على ما قبله، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تدعوا﴾</span></span> فعل مضارع مجزوم بلا الناهية، والواو فاعل تدعوا، و<span class="hlt"><span class="qpc-hafs">﴿ثبورًا﴾</span></span> مفعول به، أو مفعول مطلق، و<span class="hlt"><span class="qpc-hafs">﴿واحدا﴾</span></span> نعت، وادعوا فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ثبورا﴾</span></span> مفعول به، أو مفعول مطلق، وكثيرًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ثبورًا﴾</span></span>.</p></div>"
  25,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أذلك خير أم جنة الخلد التي وعد المتقون كانت لهم جزاء ومصيرا﴾</span></span>: قل فعل أمر وفاعله مستتر وجوبًا تقديره: أنت، والهمزة للاستفهام، وذلك مبتدأ، وخير خبر، وأم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿جنة الخلد﴾</span></span> عطف على ذلك، واسم الموصول صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعد المتقون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، وهي جملة فعلية من فعل ونائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت لهم﴾</span></span> حالية من <span class="hlt"><span class="qpc-hafs">﴿جنة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة، واسم كانت مستتر تقديره: هي، وجزاء خبر كانت، ومصيرًا عطف على جزاء.</p></div>"
  25,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم فيها ما يشاءون خالدين كان على ربك وعدا مسئولا﴾</span></span>: الجملة حال ثانية من <span class="hlt"><span class="qpc-hafs">﴿جنة الخلد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ مؤخر، وجملة يشاءون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وخالدين حال لازمة من فاعل يشاءون، وكان فعل ماض ناقص، واسمها مستتر يعود على الوعد المفهوم من قوله: <span class="hlt"><span class="qpc-hafs">﴿وعد المتقون﴾</span></span>، أو على <span class="hlt"><span class="qpc-hafs">﴿ما يشاءون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على ربك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وعدًا﴾</span></span>، ومسؤولًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وعدًا﴾</span></span>.</p></div>"
  25,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يحشرهم وما يعبدون من دون الله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف والتقدير: واذكر يوم يحشرهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿قل أذلك خير...﴾</span></span>، وجملة يحشرهم في محل جر مضاف إليه، والهاء مفعول به، وما موصول معطوف على الهاء، أو منصوب على المعية، وجملة يعبدون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> الجار والمجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيقول أأنتم أضللتم عبادي هؤلاء أم هم ضلوا السبيل﴾</span></span>: فيقول عطف على يحشرهم، و<span class="hlt"><span class="qpc-hafs">﴿أأنتم﴾</span></span> الهمزة للاستفهام، وأنتم مبتدأ، وجملة أضللتم خبر، وعبادي مفعول به، وهؤلاء اسم إشارة صفة لعبادي، أو بدل من عبادي، وأم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة ضلوا خبره، والسبيل مفعول به منصوب.</p></div>"
  25,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا سبحانك ما كان ينبغي لنا أن نتخذ من دونك من أولياء﴾</span></span>: سبحانك نائب مفعول مطلق منصوب بفعل محذوف، والكاف مضاف إليه، وما نافية، وكان فعل ماض ناقص، وجملة ينبغي خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، وأن وما في حيزها فاعل ينبغي، واسم كان مستتر يعود على المصدر المؤول على سبيل التنازع، وفاعل نتخذ مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من دونك﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول نتخذ الثاني، ومن حرف جر صلة، وأولياء مجرور لفظًا  منصوب محلًّا على أنه مفعول نتخذ الأول، أو بالعكس.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن متعتهم وآباءهم حتى نسوا الذكر وكانوا قوما بورا﴾</span></span>: الواو عاطفة، ولكن مخففة مهملة للاستدراك، و<span class="hlt"><span class="qpc-hafs">﴿متعتهم﴾</span></span> فعل وفاعل، ومفعول به، وآباءهم الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿آباءهم﴾</span></span> عطف على الهاء، أو مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿نسوا الذكر﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وقومًا خبرها، وبورًا صفة.</p></div>"
  25,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقد كذبوكم بما تقولون فما تستطيعون صرفا ولا نصرا﴾</span></span>: الفاء الفصيحة، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كذبوكم﴾</span></span>: فعل وفاعل ومفعول به، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوكم﴾</span></span>، وجملة تقولون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء عاطفة، وما نافية، وتستطيعون فعل مضارع وفاعل، وصرفًا مفعول، و<span class="hlt"><span class="qpc-hafs">﴿لا نصرًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿صرفًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يظلم منكم نذقه عذابا كبيرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، ويظلم فعل الشرط، ومنكم جار ومجرور متعلقان بمحذوف حال، أي: كائنًا منكم أيها المكلفون، ونذقه جواب الشرط، والفعل وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، والهاء مفعول نذقه الأول، وعذابًا مفعول نذقه الثاني، وكبيرًا صفة.</p></div>"
  25,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلنا قبلك من المرسلين إلا إنهم ليأكلون الطعام ويمشون في الأسواق﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل وفاعل، وقبلك ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، أو بمحذوف صفة لمفعول أرسلنا، والمعنى: <span class="hlt"><span class="qpc-hafs">﴿وما أرسلنا قبلك أحدًا من المرسلين﴾</span></span>، ونحوه قوله تعالى: <span class="hlt"><span class="qpc-hafs">﴿وما منا إلا له مقام معلوم﴾</span></span>، على معنى: <span class="hlt"><span class="qpc-hafs">﴿وما منا أحد﴾</span></span>، وإلا أداة حصر، وجملة إنهم حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأكلون الطعام﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمشون في الأسواق﴾</span></span> عطف على: <span class="hlt"><span class="qpc-hafs">﴿ليأكلون الطعام﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا بعضكم لبعض فتنة أتصبرون﴾</span></span>: الواو عاطفة، وجعلنا عطف على ما تقدم، أو مستأنفة لا محل لها من الإعراب، وجعلنا فعل وفاعل، وبعضكم مفعول به أول، ولبعض جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لفتنة، وفتنة مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، والهمزة للاستفهام، ومعنى الاستفهام: الأمر، أي: اصبروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان ربك بصيرا﴾</span></span>: الواو حالية، أو استئنافية، وكان فعل ماض ناقص، وربك اسمها، وبصيرًا خبرها، والجملة في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  25,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين لا يرجون لقاءنا لولا أنزل علينا الملائكة أو نرى ربنا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة لا يرجون صلة الذين لا محل لها من الإعراب، ولقاءنا مفعول به، ولولا أداة تحضيض، وأنزل فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، والملائكة نائب فاعل، والجملة مقول قولهم، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿نرى ربنا﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿أنزل علينا الملائكة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقد استكبروا في أنفسهم وعتوا عتوا كبيرا﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، واستكبروا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في أنفسهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكبروا﴾</span></span>، أو متعلقان بمحذوف حال، وعتوا فعل ماض وفاعل، وعتوًّا مفعول مطلق، وكبيرًا صفة له.</p></div>"
  25,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يرون الملائكة لا بشرى يومئذ للمجرمين ويقولون حجرا محجورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به منصوب لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرون﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الملائكة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا بشرى﴾</span></span> لا: نافية للجنس، وبشرى: اسم لا، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بمحذوف خبر لا، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، و<span class="hlt"><span class="qpc-hafs">﴿للمجرمين﴾</span></span> جار ومجرور متعلقان بخبر لا، والجملة مقول قول محذوف، أي: يقولون: لا بشرى، وجملة القول حال من الملائكة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿حجرًا﴾</span></span> مفعول مطلق لفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿محجورًا﴾</span></span> صفة.</p></div>"
  25,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقدمنا إلى ما عملوا من عمل فجعلناه هباء منثورا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب،  وقدمنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدمنا﴾</span></span>، وجملة عملوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من عمل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span> فعل وفاعل ومفعول به أول، وهباء مفعول به ثان، ومنثورًا صفة.</p></div>"
  25,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أصحاب الجنة يومئذ خير مستقرا وأحسن مقيلا﴾</span></span>: أصحاب مبتدأ، والجنة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، أي: يوم إذ يكون ما ذكر من عدم التبشير وقولهم حجرا محجورا وجعل أعمالهم هباء منثورا، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مستقرًّا﴾</span></span> تمييز، <span class="hlt"><span class="qpc-hafs">﴿وأحسن مقيلًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿خير مستقرًّا﴾</span></span>.</p></div>"
  25,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تشقق السماء بالغمام﴾</span></span>: الواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> السابق في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿يوم يرون الملائكة﴾</span></span>، أي: اذكر يوم يرون الملائكة ويوم تشقق السماء بالغمام، وجملة تشقق في محل جر بالإضافة، والسماء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالغمام﴾</span></span> الباء للسببية، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشقق﴾</span></span>، أو الباء للملابسة، والجار والمجرور في موضع نصب على الحال، أو الباء بمعنى عن، أي: عن الغمام، كقوله: <span class="hlt"><span class="qpc-hafs">﴿يوم تشقق الأرض عنهم﴾</span></span>، فتتعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تشقق﴾</span></span> أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونزل الملائكة تنزيلا﴾</span></span>: الواو عاطفة، ونزل فعل ماض مبني لما لم يسمَّ فاعله، والملائكة نائب فاعل، وتنزيلًا مفعول مطلق.</p></div>"
  25,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الملك يومئذ الحق للرحمن﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، أي: يوم إذ تشقق السماء...، و<span class="hlt"><span class="qpc-hafs">﴿الحق﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للرحمن﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان يوما على الكافرين عسيرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، واسمها ضمير مستتر تقديره: وكان اليوم، و<span class="hlt"><span class="qpc-hafs">﴿يومًا﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿على الكافرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عسيرًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عسيرًا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿يومًا﴾</span></span>.</p></div>"
  25,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يعض الظالم على يديه﴾</span></span>: الواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> السابق في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿يوم يرون الملائكة﴾</span></span>، أي: اذكر يوم يرون الملائكة ويوم تشقق السماء بالغمام ويوم يعض الظالم على يديه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعض﴾</span></span> في محل جر مضاف إليه، والظالم فاعل <span class="hlt"><span class="qpc-hafs">﴿يعض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على يديه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعض﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يقول يا ليتني اتخذت مع الرسول سبيلا﴾</span></span>: الجملة نصب على الحال من فاعل <span class="hlt"><span class="qpc-hafs">﴿يعض﴾</span></span>، أي: قائلًا، و<span class="hlt"><span class="qpc-hafs">﴿يا ليتني﴾</span></span> يا حرف نداء، والمنادى محذوف، أو <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> لمجرد التنبيه، و<span class="hlt"><span class="qpc-hafs">﴿ليتني﴾</span></span> ليت حرف ناسخ للتمني، والنون للوقاية، والياء اسم ليت، وجملة اتخذت خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مع الرسول﴾</span></span> ظرف مكان متعلق بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذت﴾</span></span>، وسبيلًا مفعول اتخذت الأول.</p></div>"
  25,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا ويلتى ليتني لم أتخذ فلانا خليلا﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿ويلتا﴾</span></span> منادى مضاف إلى ياء المتكلم المنقلبة ألفًا، و<span class="hlt"><span class="qpc-hafs">﴿ليتني﴾</span></span>: ليت حرف ناسخ للتمني، والنون للوقاية، والياء اسم ليت، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم أتخذ﴾</span></span> خبرها، وفلانًا مفعول به أول، وخليلًا مفعول به ثان.</p></div>"
  25,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد أضلني عن الذكر بعد إذ جاءني﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، وأضلني فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عن الذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أضلني﴾</span></span>، والجملة تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أضلني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل جر مضاف إليه، أي: بعد وقتِ مجيئه، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءني﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الشيطان للإنسان خذولا﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿كان الشيطان﴾</span></span> كان فعل ماض ناقص، والشيطان اسم كان، <span class="hlt"><span class="qpc-hafs">﴿للإنسان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خذولًا﴾</span></span>، وخذولًا خبر كان.</p></div>"
  25,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الرسول يا رب إن قومي اتخذوا هذا القرآن مهجورا﴾</span></span>: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿وقال الذين لا يرجون لقاءنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قال الرسول﴾</span></span> فعل وفاعل، ويا حرف نداء، ورب منادى مضاف إلى ياء المتكلم، وإن حرف ناسخ، وقوم اسم إن، والياء مضاف إليه، وجملة اتخذوا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مفعول أول لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>، والقرآن بدل من اسم الإشارة، ومهجورًا مفعول به ثان.</p></div>"
  25,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، والتقدير: جعلًا مثلَ ذلك جعلنا، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿لكل نبي﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿من المجرمين﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكفى بربك هاديا ونصيرا﴾</span></span>: الواو عاطفة، وكفى فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بربك﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مجرور لفظًا فاعل كفى محلًّا، وهاديًا تمييز، ونصيرًا عطف على <span class="hlt"><span class="qpc-hafs">﴿هاديا﴾</span></span>.</p></div>"
  25,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الذين لا محل لها من الإعراب، ولولا حرف تحضيض، ونزل فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، والقرآن نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿جملة﴾</span></span> حال، وواحدة صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك لنثبت به فؤادك ورتلناه ترتيلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر مقدر مؤكد لفعل محذوف، وتقدير الكلام: نزلناه تنزيلًا مثل ذلك التنزيل الذي قدحوا فيه واقترحوا خلافه، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿لنثبت﴾</span></span> تعليل لـ<span class="hlt"><span class="qpc-hafs">﴿نزلناه﴾</span></span> المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نثبت﴾</span></span>، والفاعل مستتر تقديره: نحن، وفؤادك مفعول به، ورتلناه فعل ماض عطف على نزلناه المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وترتيلًا مفعول مطلق.</p></div>"
  25,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يأتونك بمثل إلا جئناك بالحق وأحسن تفسيرا﴾</span></span>: الواو عاطفة. ولا نافية. ويأتونك: فعل وفاعل ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿بمثل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتونك﴾</span></span>. وإلا: أداة حصر. و<span class="hlt"><span class="qpc-hafs">﴿جئناك﴾</span></span>: فعل وفاعل ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئناك﴾</span></span>. والاستثناء مفرغ من أعم الأحوال، فمحل الجملة النصب على الحال. و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿الحق﴾</span></span>. وتفسيرًا: تمييز.</p></div>"
  25,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يحشرون على وجوههم إلى جهنم﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب. والذين: اسم موصول في محل رفع على أنه خبر لمبتدأ محذوف، أي: هم الذين، أو في محل نصب على الذم، أي: أذم الذين، أو مبتدأ وخبره جملة <span class="hlt"><span class="qpc-hafs">﴿أولئك شر مكانا﴾</span></span>، أو يكون قوله: <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span> بدل من الموصول وخبر الموصول قوله: <span class="hlt"><span class="qpc-hafs">﴿شر مكانا﴾</span></span>. وجملة يحشرون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على وجوههم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مقلوبين على وجوههم، و<span class="hlt"><span class="qpc-hafs">﴿إلى جهنم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحشرون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك شر مكانا وأضل سبيلا﴾</span></span>: أولئك: مبتدأ، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>. وشر: خبر لـ<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>، أو خبر لـ<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>. ومكانًا: تمييز. <span class="hlt"><span class="qpc-hafs">﴿وأضل سبيلًا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿شر مكانًا﴾</span></span>.</p></div>"
  25,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب وجعلنا معه أخاه هارون وزيرا﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وآتينا موسى فعل وفاعل ومفعول به، والكتاب مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿آتينا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا...﴾</span></span> مستأنفة لا محل لها من الإعراب، وجعلنا عطف على آتينا، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف مكان متعلق بمحذوف هو المفعول الثاني لجعلنا، وأخاه هو المفعول الأول، وهارون بدل من <span class="hlt"><span class="qpc-hafs">﴿أخاه﴾</span></span>، أو عطف بيان، و<span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span> حال، أو وزيرًا هو المفعول الثاني، وتعلق الظرف <span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> بمحذوف نصب على الحال.</p></div>"
  25,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقلنا اذهبا إلى القوم الذين كذبوا بآياتنا فدمرناهم تدميرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقلنا﴾</span></span> عطف على ما تقدم، وقلنا فعل وفاعل، وجملة اذهبا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿إلى القوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذهبا﴾</span></span>، والذين نعت للقوم، وجملة كذبوا صلة الذين لا محل لها من الإعراب، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، والفاء عاطفة على محذوف، أي: فذهبا إليهم فكذبوهما فدمرناهم، و<span class="hlt"><span class="qpc-hafs">﴿دمرناهم﴾</span></span> فعل وفاعل ومفعول به، وتدميرًا مفعول مطلق.</p></div>"
  25,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقوم نوح لما كذبوا الرسل أغرقناهم﴾</span></span>: الواو عاطفة، وقوم نوح مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده، أي: وأغرقنا قوم نوح، أو معطوف على الهاء في دمرناهم، أي: ودمرنا قوم نوح، ولما ظرف بمعنى حين، أو رابطة متضمنة معنى الشرط، وكذبوا الرسل فعل وفاعل ومفعول به، وجملة أغرقناهم جواب شرط غير جازم لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعلناهم للناس آية وأعتدنا للظالمين عذابا أليما﴾</span></span>: الواو عاطفة، وجعلناهم عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعلناهم الثاني، وآية مفعول جعلناهم الأول، وأعتدنا عطف على جعلناهم، وللظالمين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أليما﴾</span></span> صفة.</p></div>"
  25,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعادا وثمود وأصحاب الرس وقرونا بين ذلك كثيرا﴾</span></span>: الواو عاطفة، وعادًا مفعول به لفعل محذوف، تقديره: أهلكنا، أو دمرنا، و<span class="hlt"><span class="qpc-hafs">﴿ثمود وأصحاب الرس وقرونًا﴾</span></span> عطف عليه، وكثيرًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قرونًا﴾</span></span>.</p></div>"
  25,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكلا ضربنا له الأمثال وكلا تبرنا تتبيرا﴾</span></span>: كُلًّا: مفعول به لفعل محذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿ضربنا﴾</span></span> تفسيرية لا محل لها من الإعراب. وضربنا: فعل ماض وفاعل. و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضربنا﴾</span></span>. والأمثال: مفعول به. وكلًّا: مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تبرنا﴾</span></span>. وتبرنا: فعل وفاعل. وتتبيرًا: مفعول مطلق.</p></div>"
  25,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أتوا على القرية التي أمطرت مطر السوء﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأتوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على القرية﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتوا﴾</span></span>، والتي صفة للقرية، وجملة أمطرت صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، ومطر: نائب عن المفعول المطلق، لأنه اسم مصدر، والسوء: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يكونوا يرونها بل كانوا لا يرجون نشورا﴾</span></span>: الهمزة للاستفهام المتضمن معنى الإنكار، والفاء عاطفة لعطف مدخولها على مقدر يقتضيه المقام، وجملة يرونها خبر يكونوا، بل حرف إضراب، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرجون﴾</span></span> خبرها، ونشورًا مفعول به.</p></div>"
  25,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا رأوك إن يتخذونك إلا هزوا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة رأوك مجرورة بإضافة الظرف إليها، وإن نافية، ويتخذونك فعل وفاعل ومفعول، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وإلا أداة حصر، وهزوًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يتخذونك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أهذا الذي بعث الله رسولا﴾</span></span>: الجملة في محل نصب على الحال من الواو في يتخذونك على تقدير القول، أي: قائلين، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، والذي خبره، وجملة بعث صلة الذي لا محل لها من الإعراب، والعائد محذوف، أي: بعثه، ولفظ الجلالة فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿بعث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span> حال من ضمير المفعول المحذوف أي: مرسلا.</p></div>"
  25,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كاد ليضلنا عن آلهتنا لولا أن صبرنا عليها﴾</span></span>: إن مخففة من الثقيلة مهملة، وكاد: فعل ماض ناقص، واسم كاد مستتر تقديره: هو، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿يضلنا﴾</span></span> فعل مضارع وفاعل مستتر ومفعول به، وجملة يضلنا خبر كاد، و<span class="hlt"><span class="qpc-hafs">﴿عن آلهتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضلنا﴾</span></span>، ولولا حرف امتناع لوجود متضمن معنى الشرط، وأن وما في حيزها مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صبرنا﴾</span></span>، والخبر محذوف، أي: موجود، والجواب محذوف، أي: لصرفنا عنها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسوف يعلمون حين يرون العذاب من أضل سبيلا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وسوف حرف استقبال، ويعلمون فعل مضارع وفاعل، وحين ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>، وجملة يرون في محل جر بإضافة الظرف إليها، ومَن استفهام مبتدأ، وأضل خبره، وسبيلًا تمييز، والجملة في محل نصب سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> التي علقت عن العمل بالاستفهام.</p></div>"
  25,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أرأيت من اتخذ إلهه هواه﴾</span></span>: الهمزة للاستفهام، ورأيت فعل وفاعل، أي: أخبرني، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مفعول رأيت الأول، وجملة اتخذ صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وإلهه مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>، وهواه مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفأنت تكون عليه وكيلا﴾</span></span>: الجملة في محل نصب مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿رأيت﴾</span></span>، والهمزة للاستفهام، والفاء عاطفة على مقدر، أي: أنت تحرص على إيمانه، وأنت مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> خبره، واسم تكون ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span>، ووكيلًا خبر تكون.</p></div>"
  25,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم تحسب أن أكثرهم يسمعون أو يعقلون﴾</span></span>: أم: حرف عطف، وهي منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أتحسب ...، والاستفهام للإنكار، وأن وما في حيزها سدت مسد مفعولي تحسب، وجملة يسمعون خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ويعقلون عطف على يسمعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هم إلا كالأنعام بل هم أضل سبيلا﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وإلا أداة حصر، <span class="hlt"><span class="qpc-hafs">﴿كالأنعام﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأنعام﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف عطف وإضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وأضل خبره، وسبيلًا تمييز.</p></div>"
  25,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر إلى ربك كيف مد الظل ولو شاء لجعله ساكنا﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، وكيف اسم استفهام في محل نصب على الحال، وجملة مد الظل مستأنفة لا محل لها من الإعراب، وقيل: الرؤية قلبية، والمعنى: ألم تعلم، وقد علقت <span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> <span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> عن العمل، فجملة مد الظل في محل نصب مفعول به، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span> الواو حالية، ولو شرطية، وشاء فعل ماض، والفاعل مستتر، واللام واقعة في جواب لو، وجملة جعله لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والهاء مفعول جعل الأول، وساكنًا مفعوله الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلنا الشمس عليه دليلا﴾</span></span>: ثم عطف، وجعلنا فعل وفاعل، والشمس مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دليلا﴾</span></span>، ودليلًا مفعول به ثان.</p></div>"
  25,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم قبضناه إلينا قبضا يسيرا﴾</span></span>: ثم حرف عطف، وقبضناه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قبضناه﴾</span></span>، وقبضًا مفعول مطلق، ويسيرًا صفة.</p></div>"
  25,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي جعل لكم الليل لباسا والنوم سباتا وجعل النهار نشورا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة جعل صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿لباسًا﴾</span></span>، والليل مفعول جعل الأول، ولباسًا مفعوله الثاني، والنوم سباتًا عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿جعل النهار نشورًا﴾</span></span> عطف أيضًا.</p></div>"
  25,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي أرسل الرياح بشرا بين يدي رحمته﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿أرسل الرياح﴾</span></span> فعل ومفعول به، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span> صلة الذي لا محل لها من الإعراب، وبشرًا حال، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بشرًا﴾</span></span>، ويدي رحمته مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنزلنا من السماء ماء طهورا﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، وماء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿طهورا﴾</span></span> صفة.</p></div>"
  25,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنحيي به بلدة ميتا ونسقيه مما خلقنا أنعاما وأناسي كثيرا﴾</span></span>: لام التعليل حرف جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> لبيان العلة في إنزاله، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نحيي﴾</span></span>، وبلدة مفعول به، وميتًا صفة لبلدة، ونسقيه عطف على نحيي، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> متعلقان بمحذوف حال، وأنعامًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نسقيه﴾</span></span>، وأناسي كثيرًا عطف على <span class="hlt"><span class="qpc-hafs">﴿أنعامًا﴾</span></span>.</p></div>"
  25,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صرفناه بينهم ليذكروا﴾</span></span>: عطف على ما تقدم، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وصرفناه فعل، وفاعل، ومفعول به، والضمير يعود على الماء، أو على القول الذي مر فيه ذكر إنشاء السحاب وإنزال القطر، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليذكروا﴾</span></span> اللام للتعليل، ويذكروا فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفناه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأبى أكثر الناس إلا كفورا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبى أكثر﴾</span></span> فعل وفاعل، والجملة عطف على ما تقدم، وإلا أداة حصر، وكفورًا مفعول به.</p></div>"
  25,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو شئنا لبعثنا في كل قرية نذيرا﴾</span></span>: الواو عاطفة، ولو شرطية، وشئنا فعل وفاعل، ومفعول المشيئة محذوف، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة بعثنا لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في كل قرية﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، ونذيرًا مفعول به.</p></div>"
  25,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا تطع الكافرين وجاهدهم به جهادا كبيرا﴾</span></span>: الفاء الفصيحة، ولا ناهية، وتطع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر تقديره: أنت، والكافرين مفعول به، وجاهدهم فعل أمر، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاهدهم﴾</span></span>، والضمير للقرآن، وجهادًا مفعول مطلق، وكبيرًا صفة.</p></div>"
  25,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي مرج البحرين هذا عذب فرات وهذا ملح أجاج﴾</span></span>: الواو عاطفة، والكلام معطوف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿مرج البحرين﴾</span></span> صلة الذي لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا عذب﴾</span></span> استئنافية لا محل لها من الإعراب، أو مقول لقول محذوف في موضع الحال، أي: مقولًا فيهما، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، وعذب خبره، وفرات خبر ثان، و<span class="hlt"><span class="qpc-hafs">﴿هذا ملح أجاج﴾</span></span> عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل بينهما برزخا وحجرا محجورا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿مرج﴾</span></span> داخل في حيز الصلة، وجعل فعل ماض، وفاعله ضمير مستتر، تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف في موضع المفعول الثاني لجعل، وبرزخًا مفعول به أول، وحجرًا محجورًا عطف على <span class="hlt"><span class="qpc-hafs">﴿برزخًا﴾</span></span>، وقيل: منصوبان بقول مقدر.</p></div>"
  25,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي خلق من الماء بشرا فجعله نسبا وصهرا﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، وبشرًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فجعله﴾</span></span> الفاء عاطفة، وجعله فعل، وفاعل مستتر، ومفعول به أول، ونسبًا مفعول به ثان، وصهرًا عطف على <span class="hlt"><span class="qpc-hafs">﴿نسبًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان ربك قديرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، كان فعل ماض ناقص ناسخ، وربك اسمها، وقديرًا خبرها.</p></div>"
  25,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله ما لا ينفعهم ولا يضرهم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة لا ينفعهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة ولا يضرهم عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿لا ينفعهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الكافر على ربه ظهيرا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كان الكافر﴾</span></span> كان فعل ماض ناقص، والكافر اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿على ربه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span>، وظهيرًا خبر كان.</p></div>"
  25,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلناك إلا مبشرا ونذيرا﴾</span></span>: ما نافية، وأرسلناك فعل ماض، وفاعل، ومفعول به، وإلا أداة حصر، ومبشرًا حال، ونذيرًا عطف على <span class="hlt"><span class="qpc-hafs">﴿مبشرًا﴾</span></span>.</p></div>"
  25,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل ما أسألكم عليه من أجر﴾</span></span>: قل فعل أمر، وجملة ما أسألكم مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span> وتقدم عليه، ومن حرف جر صلة، وأجر مجرور لفظًا منصوب محلا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أسألكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من شاء أن يتخذ إلى ربه سبيلا﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿من شاء﴾</span></span> مستثنى منقطع، لأنه من غير الجنس، أي: لا أطلب منكم أجرًا لنفسي، لكن من شاء أن ينفق أمواله في سبيل الله ولوجهه خالصًا فليفعل، وأن وما في حيزها مفعول المشيئة، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربه﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يتخذ﴾</span></span>، وسبيلًا مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿يتخذ﴾</span></span>.</p></div>"
  25,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتوكل على الحي الذي لا يموت وسبح بحمده﴾</span></span>: الواو عاطفة، وتوكل فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على الحي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكل﴾</span></span>، والذي صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يموت﴾</span></span> صلة الذي لا محل لها من الإعراب، وسبح عطف على توكل، و<span class="hlt"><span class="qpc-hafs">﴿بحمده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا بحمده.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكفى به بذنوب عباده خبيرا﴾</span></span>: الواو حرف عطف، وكفى فعل ماض، والباء حرف جر صلة، والهاء مجرور لفظًا مرفوع محلًّا على أنه فاعل، وبذنوب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبيرًا﴾</span></span>، وخبيرًا تمييز، وقيل: حال.</p></div>"
  25,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي خلق السماوات والأرض وما بينهما في ستة أيام﴾</span></span>: الذي نعت، أو بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>، أو مبتدأ، وجملة خلق السماوات والأرض صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما بينهما﴾</span></span> عطف على السماوات، والظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في ستة أيام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم استوى على العرش الرحمن فاسأل به خبيرا﴾</span></span>: ثم حرف عطف، واستوى عطف على خلق، و<span class="hlt"><span class="qpc-hafs">﴿على العرش﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استوى﴾</span></span>، والرحمن خبر <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>، أو خبر لمبتدأ محذوف، أي: هو الرحمن، <span class="hlt"><span class="qpc-hafs">﴿فاسأل﴾</span></span> الفاء الفصيحة، واسأل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبيرًا﴾</span></span>، وخبيرًا مفعول به، أو الباء بمعنى عن، والجار والمجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿فاسأل﴾</span></span>.</p></div>"
  25,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم اسجدوا للرحمن﴾</span></span>: الواو استئنافية، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> مجرورة بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وجملة اسجدوا للرحمن مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا وما الرحمن﴾</span></span>: قالوا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> جواب شرط غير جازم لا محل لها من الإعراب، والواو صلة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، والرحمن خبر. وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنسجد لما تأمرنا وزادهم نفورا﴾</span></span>: الهمزة للاستفهام، ونسجد فعل مضارع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسجد﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأمرنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وزادهم فعل وفاعل يعود على القول، والهاء مفعول به، ونفورًا مفعول به ثان، أو تمييز.</p></div>"
  25,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تبارك الذي جعل في السماء بروجا وجعل فيها سراجا وقمرا منيرا﴾</span></span>: تبارك فعل ماض جامد، والذي فاعله، وجملة جعل صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، أو متعلقان بمحذوف مفعول ثان، وبروجًا مفعول به، وما بعده عطف عليه.</p></div>"
  25,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي جعل الليل والنهار خلفة لمن أراد أن يذكر أو أراد شكورا﴾</span></span>: كلام معطوف على ما قبله، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل الليل والنهار﴾</span></span> صلة الذي لا محل لها من الإعراب، وخلفة مفعول به ثان لجعل إن كانت بمعنى صير، أو حال إن كانت بمعنى خلق، قيل: ولا بد من تقدير مضاف، أي: ذوي خلفة، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لخلفة، وجملة أراد صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يذكر﴾</span></span> منصوب على المفعولية لـ<span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span>، ومفعول يذكر محذوف، أي: ما فاته في أحدهما، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وأراد شكورًا عطف على أراد الأولى.</p></div>"
  25,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعباد الرحمن الذين يمشون على الأرض هونا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وعباد مبتدأ، والرحمن مضاف إليه، وما بعده صفات، وخبر عباد في آخر السورة، وهو قوله تعالى: <span class="hlt"><span class="qpc-hafs">﴿أؤلئك يجزون الغرفة﴾</span></span>، والذين خبر عباد، أو صفة، وجملة يمشون صلة الذين لا محل لها من الإعراب، وعلى الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمشون﴾</span></span>، وهونًا مصدر وضع في موضع الحال، أي: هينين، أو نائب عن المفعول المطلق، لأنه صفة للمصدر، أي: مشيًا هونًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا خاطبهم الجاهلون قالوا سلاما﴾</span></span>: الواو عاطفة، والجملة معطوفة على ما قبلها، فهي من حيز الصلة لا محل لها من الإعراب، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة خاطبهم الجاهلون في محل جر بإضافة الظرف إليها، وجملة قالوا لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وسلامًا: مفعول به، أو مفعول مطلق لفعل محذوف والتقدير: نسلم سلاما.</p></div>"
  25,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين يبيتون لربهم سجدا وقياما﴾</span></span>: الواو عاطفة، والذين عطف على الموصول الأول، وجملة يبيتون صلة الذين لا محل لها من الإعراب، والواو اسم يبيتون، و<span class="hlt"><span class="qpc-hafs">﴿لربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سجدًا﴾</span></span>، وسجدًا خبر <span class="hlt"><span class="qpc-hafs">﴿يبيتون﴾</span></span>، أو حال على جعلها تامة، وقياما عطف على <span class="hlt"><span class="qpc-hafs">﴿سجدًا﴾</span></span>.</p></div>"
  25,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين يقولون ربنا اصرف عنا عذاب جهنم﴾</span></span>: الواو عاطفة، والذين عطف أيضًا، وجملة يقولون صلة الذين لا محل لها من الإعراب، وربنا منادى مضاف محذوف منه حرف النداء، واصرف فعل دعاء، وعذاب جهنم مفعول اصرف، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن عذابها كان غراما﴾</span></span>: الجملة تعليلية لا محل لها من الإعراب، وإن حرف ناسخ، وعذابها اسمها، وجملة كان خبر إن، واسم كان ضمير مستتر تقديره: هو، وغرامًا خبر كان.</p></div>"
  25,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنها ساءت مستقرا ومقاما﴾</span></span>: إن: حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها. وجملة <span class="hlt"><span class="qpc-hafs">﴿ساءت﴾</span></span> خبرها. وساءت: فعل ماض جامد، والتاء للتأنيث، وفاعل ساءت ضمير مستتر تقديره: هي. ومستقرًّا: تمييز. ومقامًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿مستقرًّا﴾</span></span>. والمخصوص بالذم محذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنها ساءت...﴾</span></span> تعليلية.</p></div>"
  25,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين إذا أنفقوا لم يسرفوا ولم يقتروا﴾</span></span>: الواو عاطفة، والذين عطف على ما تقدم، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة أنفقوا في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يسرفوا ولم يقتروا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان بين ذلك قواما﴾</span></span>: الواو عاطفة، أو حالية، وكان فعل ماض ناقص ناسخ، واسمها ضمير مستتر، أي: وكان الإنفاق، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوامًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مضاف إليه، وقوامًا خبر كان، أو <span class="hlt"><span class="qpc-hafs">﴿بين ذلك﴾</span></span> ظرف متعلق بمحذوف خبر كان، وقواما هي الحال.</p></div>"
  25,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين لا يدعون مع الله إلها آخر﴾</span></span>: الواو عاطفة، والذين عطف على ما تقدم أيضًا، وجملة لا يدعون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> جار ومجرور متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، وإلهًا مفعول به، وآخر صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يقتلون النفس التي حرم الله إلا بالحق ولا يزنون﴾</span></span>: الواو عاطفة، ولا يقتلون عطف على <span class="hlt"><span class="qpc-hafs">﴿ولا يدعون﴾</span></span>، والنفس مفعول به، والتي صفة، وجملة حرم الله صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقتلون﴾</span></span>، أو بمحذوف حال، فالاستثناء من أعم الأحوال، أي: إلا مستحقين، <span class="hlt"><span class="qpc-hafs">﴿ولا يزنون﴾</span></span> معطوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يفعل ذلك يلق أثاما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويفعل فعل الشرط، وفاعله ضمير مستتر تقديره: هو، وأثامًا مفعول به.</p></div>"
  25,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يضاعف له العذاب يوم القيامة ويخلد فيه مهانا﴾</span></span>: يضاعف بدل من يلق، لأنهما في معنى واحد، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضاعف﴾</span></span>، والعذاب نائب فاعل، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يضاعف﴾</span></span> أيضًا، ويخلد عطف على يضاعف، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخلد﴾</span></span>، ومهانًا حال من فاعل يخلد.</p></div>"
  25,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من تاب وآمن وعمل عملا صالحا﴾</span></span>: إلا أداة استثناء، ومن استثناء من الجنس في موضع نصب، وجملة تاب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وآمن عطف على تاب، وكذلك عمل، وعملًا مفعول مطلق، أو مفعول به، وصالحًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك يبدل الله سيئاتهم حسنات﴾</span></span>: الفاء رابطة لما في الموصول من رائحة الشرط، وأولئك مبتدأ، والإشارة إلى الموصول وهو من، وجملة يبدل خبر أولئك، ولفظ الجلالة فاعل، وسيئاتهم مفعول، وحسنات مفعول ثان ليبدل، أو نصب على نزع الخافض، <span class="hlt"><span class="qpc-hafs">﴿وكان الله غفورا رحيما﴾</span></span>: الواو استئنافية، وكان فعل ماض ناقص، ولفظ الجلالة اسمها، وغفورًا خبرها الأول، ورحيمًا خبرها الثاني، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  25,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن تاب وعمل صالحا فإنه يتوب إلى الله متابا﴾</span></span>: الواو عاطفة، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، وتاب فعل ماض في محل جزم فعل الشرط، وعمل عطف على تاب، وصالحًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. <span class="hlt"><span class="qpc-hafs">﴿فإنه﴾</span></span> الفاء رابطة للجواب، لأنه جملة اسمية، وإن حرف ناسخ، والهاء اسمها، وجملة يتوب خبرها، وإلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتوب﴾</span></span>، ومتابًا نائب مفعول مطلق لأنه مصدر ميمي، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن تاب وعمل...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  25,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين لا يشهدون الزور﴾</span></span>: الواو عاطفة، والذين عطف على الموصولات السابقة، وجملة لا يشهدون صلة الذين لا محل لها من الإعراب، والزور منصوب بنزع الخافض، والزور مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مروا باللغو مروا كراما﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة مروا مجرورة بإضافة الظرف إليها، ومروا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿باللغو﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مروا﴾</span></span>، وجملة مروا الثانية لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وكرامًا حال.</p></div>"
  25,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين إذا ذكروا بآيات ربهم لم يخروا عليها صما وعميانا﴾</span></span>: جملة لم يخروا لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخروا﴾</span></span>، وصمًّا حال، وعميانًا حال ثانية.</p></div>"
  25,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين يقولون ربنا هب لنا من أزواجنا وذرياتنا قرة أعين واجعلنا للمتقين إماما﴾</span></span>: عطف على ما تقدم، وربنا منادى مضاف محذوف منه حرف النداء، وهب فعل دعاء، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أزواجنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وقرة أعين مفعول هب، واجعلنا فعل دعاء، وفاعله مستتر، ومفعول أول، و<span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إمامًا﴾</span></span>، وإماما مفعول ثان.</p></div>"
  25,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك يجزون الغرفة بما صبروا ويلقون فيها تحية وسلاما﴾</span></span>: الجملة حالية من المتقين، أو خبر <span class="hlt"><span class="qpc-hafs">﴿عباد الرحمن﴾</span></span> على أحد القولين، وأولئك مبتدأ، وجملة يجزون الغرفة خبره، والغرفة مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يجزون﴾</span></span>، والواو نائب فاعل، وهو المفعول الأول، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجزون﴾</span></span>، وما مصدرية، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿يلقون﴾</span></span> عطف على يجزون، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿تحية﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يلقون﴾</span></span>، لأنه مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿سلامًا﴾</span></span> عطف على تحية.</p></div>"
  25,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خالدين فيها حسنت مستقرا ومقاما﴾</span></span>: خالدين حال، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدين﴾</span></span>، وحسنت فعل ماض، والفاعل مستتر يعود على الغرفة، ومستقرًّا تمييز، ومقامًا عطف على <span class="hlt"><span class="qpc-hafs">﴿مستقرًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿حسنت﴾</span></span> حال ثانية من الغرفة.</p></div>"
  25,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل ما يعبأ بكم ربي لولا دعاؤكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، وفاعله مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يعبأ﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعبأ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿دعاؤكم﴾</span></span> مبتدأ خبره محذوف وجوبًا، وجواب لولا محذوف مفهوم من السياق، أي: لولا دعاؤكم ما عبأ بكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقد كذبتم فسوف يكون لزاما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقد﴾</span></span> الفاء: استئناف وتعليل لكونهم لا يُعبأ بهم، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كذبتم﴾</span></span> فعل ماض، وضمير المخاطبين المتصل في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقد كذبتم﴾</span></span> مستأنفة تعليلية لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فسوف﴾</span></span> الفاء: تفريعية، وسوف: حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span> فعل مضارع ناقص، واسم يكون مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿لزامًا﴾</span></span> خبر يكون، وجملة <span class="hlt"><span class="qpc-hafs">﴿سوف يكون لزاما﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿فقد كذبتم﴾</span></span>.</p></div>"
