quran[60]{c,v,t}:
  51,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذاريات﴾</span></span>: الواو حرف قسم وجر، والذاريات مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذروًا﴾</span></span>: مفعول مطلق، والعامل فيه اسم الفاعل، والمفعول به محذوف.</p></div>"
  51,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالحاملات وقرا﴾</span></span>: الفاء حرف عطف، والحاملات عطف على الذاريات، ووقرًا مفعول به لاسم الفاعل.</p></div>"
  51,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالجاريات﴾</span></span>: الفاء حرف عطف، والجاريات عطف على ما قبله أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿يسرا﴾</span></span>: مصدر في موضع الحال، أي: ذات يسر أو ميسرة، أو: نائب عن المفعول المطلق لأنه صفة المصدر، أي: جريا يسرا.</p></div>"
  51,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالمقسمات أمرا﴾</span></span>: الفاء عاطفة، والمقسمات معطوف أيضًا، وأمرًا مفعول به لاسم الفاعل.</p></div>"
  51,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما توعدون لصادق﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل نصب اسم <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف، أي: توعدونه. واللام المزحلقة. وصادق خبر إن. أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية مع ما بعدها في محل نصب اسم <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أي: إن وعدكم لصادق. وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنما توعدون لصادق﴾</span></span> لا محل لها من الإعراب، لأنها جواب القسم.</p></div>"
  51,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن الدين لواقع﴾</span></span>: الواو عاطفة، وإن للتوكيد والنصب، والدين: اسمها منصوب، لواقع اللام مزحلقة وواقع خبر إن، وجملة إن الدين لواقع معطوفة على إن ما توعدون لصادق.</p></div>"
  51,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسماء ذات الحبك﴾</span></span>: الواو حرف قسم وجر، والسماء مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم. وذات: نعت للسماء. والحبك: مضاف إليه. وجملة القسم استئنافية لا محل لها من الإعراب.</p></div>"
  51,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنكم لفي قول مختلف﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، واللام المزحلقة، وفي قول: جار ومجرور متعلقان بمحذوف خبر إن، ومختلف نعت لقول. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنكم لفي قول مختلف﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم.</p></div>"
  51,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يؤفك عنه من أفك﴾</span></span>: الضمير للقرآن، أو للرسول، ويؤفك فعل مضارع مبني لما لم يسمَّ فاعله، وعنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤفك﴾</span></span>، ومن اسم موصول في محل رفع نائب فاعل، وأفك فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿أُفِكَ﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤفك﴾</span></span> في محل جر نعت ثانٍ لقول.</p></div>"
  51,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قتل الخراصون﴾</span></span>: الجملة دعائية لا محل لها من الإعراب، وقتل فعل ماض مبني لما لم يسمَّ فاعله، والخراصون نائب فاعل.</p></div>"
  51,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين هم في غمرة ساهون﴾</span></span>: الذين صفة الخراصون، وهم مبتدأ، وفي غمرة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ساهون﴾</span></span>، وساهون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم في غمرة ساهون﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول.</p></div>"
  51,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يسألون أيان يوم الدين﴾</span></span>: يسألون فعل مضارع مرفوع بثبوت النون، والواو فاعل، وأيان اسم استفهام في محل نصب ظرف زمان، وهو متعلق بمحذوف خبر مقدم، ويوم الدين مبتدأ مؤخر، والجملة في محل نصب مفعول يسألون.</p></div>"
  51,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم هم على النار يفتنون﴾</span></span>: يوم مفعول فيه ظرف زمان، متعلق بفعل محذوف تقديره: يقع، أو يجيء، وهم مبتدأ، وجملة يفتنون خبره، وعلى النار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفتنون﴾</span></span>، وعلى بمعنى في، والجملة في محل جر بإضافة يوم إليها.</p></div>"
  51,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذوقوا فتنتكم هذا الذي كنتم به تستعجلون﴾</span></span>: الجملة مقول قول محذوف، أي: ويقال لهم حين التعذيب: ذوقوا. وذوقوا فعل أمر مبني على حذف النون، والواو فاعل، وكان فعل ماض ناقص، والتاء اسمها، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستعجلون﴾</span></span>، وجملة تستعجلون خبر كان.</p></div>"
  51,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في جنات وعيون﴾</span></span>: إن حرف ناسخ، والمتقين اسمها، وفي جنات: جار ومجرور متعلقان بمحذوف خبر إن، وعيون عطف على جنات.</p></div>"
  51,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿آخذين ما آتاهم ربهم﴾</span></span>: آخذين حال من الضمير المستكن في خبر إن، أي: استقروا راضين بما أعطاهم مسرورين به، وما اسم موصول في محل نصب مفعول به لآخذين، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتاهم ربهم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا قبل ذلك محسنين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا﴾</span></span> تعليل لما ذكر، وقبل ذلك ظرف متعلق بمحسنين، ومحسنين خبر كانوا.</p></div>"
  51,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: فعل ماض ناقص، وواو الجماعة اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نعت لظرف زمان محذوف، أي: زمانا قليلا، أو: نائب عن مفعول مطلق محذوف، أي: كانوا يهجعون من الليل هجوعًا قليلًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿من الليل﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: حرف صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يهجعون﴾</span></span>: فعل مضارع مرفوع بثبوت النون والواو فاعل، وجملة يهجعون خبر كان. وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا قليلا من الليل ما يهجعون﴾</span></span> في محل رفع بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿كانوا قبل ذلك محسنين﴾</span></span> بدل بعض من كل. أو هي جملة تفسيرية لا محل لها من الإعراب.</p></div>"
  51,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبالأسحار هم يستغفرون﴾</span></span>: الواو حرف عطف، وبالأسحار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستغفرون﴾</span></span>، والباء بمعنى في، وهم مبتدأ، وجملة يستغفرون خبر، وقدم متعلق الخبر لجواز تقديم العامل.</p></div>"
  51,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي أموالهم حق للسائل والمحروم﴾</span></span>: الواو حرف عطف، وفي أموالهم: جار ومجرور متعلقان بمحذوف خبر مقدم، وحق مبتدأ مؤخر، وللسائل: جار ومجرور متعلقان بمحذوف صفة، والمحروم عطف على السائل، والجملة معطوفة على خبر كان، فهي خبر ثالث.</p></div>"
  51,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي الأرض آيات للموقنين﴾</span></span>: الواو عاطفة، أو استئنافية، وفي الأرض خبر مقدم، وآيات مبتدأ مؤخر، وللموقنين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وفي الأرض...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  51,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي أنفسكم أفلا تبصرون﴾</span></span>: الواو عاطفة، وفي أنفسكم: جار ومجرور متعلقان بمحذوف خبر حذف مبتدؤه، والتقدير: آيات، والهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف مقدر، ولا نافية، وتبصرون فعل مضارع مرفوع بثبوت النون والواو فاعل.</p></div>"
  51,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي السماء رزقكم وما توعدون﴾</span></span>: الواو عاطفة. وفي السماء: جار ومجرور متعلقان بمحذوف خبر مقدم. ورزقكم مبتدأ مؤخر. والواو عاطفة. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوف على <span class="hlt"><span class="qpc-hafs">﴿رزقكم﴾</span></span> مرفوع. و<span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله. والواو نائب فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف.</p></div>"
  51,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فورب السماء والأرض إنه لحق مثل ما أنكم تنطقون﴾</span></span>: الفاء استئنافية. والواو: حرف قسم وجر. و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> مجرور بالواو. والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم. و<span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> مضاف إليه مجرور وعلامة الجر الكسرة. و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> عطف على السماء. و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها. واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span> خبرها. و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مبني على الفتح في محل رفع نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span>، وسبب البناء فيه أنه أضيف إلى مبني. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة في محل جر بالإضافة إلى مثل. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ. و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسم إن. وجملة <span class="hlt"><span class="qpc-hafs">﴿تنطقون﴾</span></span> خبرها. وجملة <span class="hlt"><span class="qpc-hafs">﴿أنكم﴾</span></span> في محل جر بالإضافة، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة، والجملة خبر لمبتدأ محذوف، أي: هو أنكم.</p></div>"
  51,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل أتاك حديث ضيف إبراهيم المكرمين﴾</span></span>: هل حرف استفهام، وأتاك فعل ومفعول به مقدم، وضيف إبراهيم مضاف إليه، والمكرمين نعت لضيف.</p></div>"
  51,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿حديث﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿المكرمين﴾</span></span> في الآية السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>: فعل ماض، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span>: الفاء عاطفة، وقالوا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلامًا﴾</span></span>: مفعول به، أو نائب مفعول مطلق أي: نسلِّم سلاما.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض، وفاعله مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>: مبتدأ، ساغ الابتداء به مع أنه نكرة لتضمنه معنى الدعاء، والخبر محذوف تقديره: سلام عليكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>: خبر لمبتدأ محذوف تقديره: وأنتم، أو هم.</p><p><span class="hlt"><span class="qpc-hafs">﴿منكرون﴾</span></span>: صفة لقوم.</p></div>"
  51,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فراغ إلى أهله فجاء بعجل سمين﴾</span></span>: الفاء عاطفة على مقدر يقتضيه السياق، أي: فبادر إلى إكرامهم دون أن يشعرهم، وراغ فعل ماض، وفاعل مستتر، وإلى أهله: جار ومجرور متعلقان براغ، فجاء عطف للتعقيب، وبعجل: جار ومجرور متعلقان بجاء، وسمين صفة لعجل.</p></div>"
  51,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقربه إليهم قال ألا تأكلون﴾</span></span>: عطف على ما تقدم، وإليهم: جار ومجرور متعلقان بقربه، وألا أداة استفهام، ولا نافية، والاستفهام للعرض أو الإنكار، وتأكلون فعل مضارع مرفوع، والجملة مقول القول.</p></div>"
  51,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوجس منهم خيفة﴾</span></span>: الفاء عاطفة على مقدر يقتضيه السياق، وأوجس فعل ماض والفاعل مستتر تقديره هو، وخيفة مفعول أوجس.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لا تخف وبشروه بغلام عليم﴾</span></span>: لا ناهية، وتخف فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وبشروه فعل ماض، وفاعل، ومفعول به، وبغلام: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشروه﴾</span></span>، وعليم نعت غلام.</p></div>"
  51,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقبلت امرأته في صرة فصكت وجهها وقالت عجوز عقيم﴾</span></span>: عطف أيضًا على مقدر لا بُدَّ منه، وامرأته فاعل فأقبلت، وفي صرة: جار ومجرور متعلقان بمحذوف حال، فصكت عطف على <span class="hlt"><span class="qpc-hafs">﴿فأقبلت﴾</span></span>، ووجهها مفعول به، وقالت عطف أيضًا، وعجوز خبر لمبتدأ محذوف، أي أنا عجوز، وعقيم صفة.</p></div>"
  51,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا كذلك قال ربك إنه هو الحكيم العليم﴾</span></span>: قالوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: قولًا مثل ذلك الذي قلنا، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿قال ربك﴾</span></span> فعل وفاعل، وإن حرف ناسخ، والهاء اسمها، وهو ضمير فصل لا محل له من الإعراب، والحكيم خبر إن، العليم خبر ثان لإن.</p></div>"
  51,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فما خطبكم أيها المرسلون﴾</span></span>: قال فعل ماض، وفاعله مستتر، أي إبراهيم، والفاء الفصيحة، وما اسم استفهام مبتدأ، وخطبكم خبر، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى محذوف منه حرف النداء، وهو مبني على الضم، لأنه نكرة مقصودة، وها للتنبيه، والمرسلون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p></div>"
  51,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا أرسلنا إلى قوم مجرمين﴾</span></span>: فعل وفاعل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وأرسل فعل ماض مبني لما لم يسم فاعله، ونا نائب فاعل، وجملة أرسلنا خبر إن، وإن وما في حيزها مقول القول، وإلى قوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ومجرمين نعت.</p></div>"
  51,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنرسل عليهم حجارة من طين﴾</span></span>: اللام للتعليل، ونرسل فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والفاعل مستتر تقديره: نحن، وعليهم: جار ومجرور متعلقان بنرسل، وحجارة مفعول به، ومن طين نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حجارة﴾</span></span>، ولام التعليل ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p></div>"
  51,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مسومة عند ربك للمسرفين﴾</span></span>: مسومة صفة ثانية لحجارة، أو حال منها، لأنها وصفت بالجار والمجرور، وعند ربك الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مسومة﴾</span></span>، وللمسرفين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسومة﴾</span></span> أيضًا.</p></div>"
  51,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخرجنا من كان فيها من المؤمنين﴾</span></span>: الفاء الفصيحة، لأنها أفصحت عن جمل قد حذفت، وأخرجنا فعل وفاعل، ومن مفعول، وكان فعل ماض ناقص، واسمها مستتر تقديره: هم، وفيها جار ومجرور متعلقان بمحذوف خبر كان، ومن المؤمنين حال، وجملة كان صلة الموصول لا محل لها من الإعراب، والضمير بقوله فيها يعود إلى قرى قوم لوط.</p></div>"
  51,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما وجدنا فيها غير بيت من المسلمين﴾</span></span>: الفاء عاطفة، وما نافية، ووجدنا فعل وفاعل، وغير بيت مفعول به، ومن المسلمين صفة.</p></div>"
  51,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا فيها آية للذين يخافون العذاب الأليم﴾</span></span>: الواو عاطفة، وتركنا فعل وفاعل، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، وآية مفعول به، وللذين صفة لآية، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخافون العذاب الأليم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  51,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي موسى إذ أرسلناه إلى فرعون بسلطان مبين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿في موسى﴾</span></span> جار ومجرور عطف على <span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿وتركنا فيها آية﴾</span></span> بإعادة الجار فيتعلق الجار والمجرور بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> من حيث المعنى، ويكون التقدير: وتركنا في قصة موسى آية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلناه﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إلى فرعون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بسلطان﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مؤيّدًا، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت.</p></div>"
  51,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتولى بركنه وقال ساحر أو مجنون﴾</span></span>: الفاء حرف عطف، وتولى فعل ماض، وفاعله مستتر يعود إلى فرعون، وبركنه حال من ضمير فرعون، وقال عطف على تولى، وساحر خبر لمبتدأ محذوف، أي: هو ساحر، وأو حرف عطف للإبهام على السامع، أو للشك، ومجنون عطف على ساحر.</p></div>"
  51,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذناه وجنوده فنبذناهم في اليم وهو مليم﴾</span></span>: الفاء حرف عطف، وأخذناه فعل وفاعل ومفعول به، وجنوده معطوف على مفعول أخذناه، وقيل: مفعول معه. فنبذناهم في اليم عطف على أخذناه، وفي اليم: جار ومجرور متعلقان بنبذناه. وهو: الواو للحال، وهو ضمير منفصل في محل رفع مبتدأ، ومليم خبر، والجملة في محل نصب حال من مفعول نبذناهم، أو من مفعول أخذناه.</p></div>"
  51,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي عاد إذ أرسلنا عليهم الريح العقيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿في عاد﴾</span></span> جار ومجرور عطف على <span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿وتركنا فيها آية﴾</span></span> بإعادة الجار فيتعلق الجار والمجرور بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> من حيث المعنى، ويكون التقدير: وتركنا في قصة عاد آية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الريح﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿العقيم﴾</span></span> نعت للريح.</p></div>"
  51,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما تذر من شيء أتت عليه إلا جعلته كالرميم﴾</span></span>: ما نافية، وتذر فعل مضارع مرفوع، وفاعله مستتر تقديره: هي، أي: الريح، والجملة حال من الريح، ومن حرف جر صلة، وشيء مجرور لفظًا منصوب محلًّا لأنه مفعول به، وجملة أتت عليه صفة لشيء، وإلا أداة حصر، وجعلته فعل وفاعل مستتر ومفعول به، والجملة في موضع المفعول الثاني لـ<span class="hlt"><span class="qpc-hafs">﴿تذر﴾</span></span>، كأنه قيل: ما تترك من شيء إلا مجعولًا، و<span class="hlt"><span class="qpc-hafs">﴿كالرميم﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلته﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الرميم﴾</span></span> مضاف إليه.</p></div>"
  51,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفي ثمود إذ قيل لهم تمتعوا حتى حين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿في ثمود﴾</span></span> جار ومجرور عطف على <span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿وتركنا فيها آية﴾</span></span> بإعادة الجار فيتعلق الجار والمجرور بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> من حيث المعنى، ويكون التقدير: وتركنا في قصة ثمود آية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمتعوا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span> مجرور بـ حتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمتعوا﴾</span></span>.</p></div>"
  51,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعتوا عن أمر ربهم فأخذتهم الصاعقة وهم ينظرون﴾</span></span>: الفاء حرف عطف للترتيب الإخباري، وعتوا فعل وفاعل، وعن أمر ربهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عتوا﴾</span></span>، فأخذتهم الصاعقة عطف على عتوا، والواو للحال، وهم مبتدأ، وجملة ينظرون خبر، والجملة في محل نصب على الحال.</p></div>"
  51,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما استطاعوا من قيام وما كانوا منتصرين﴾</span></span>: الفاء عاطفة، وما نافية، واستطاعوا فعل وفاعل، ومن حرف جر صلة، وقيام مجرور لفظًا منصوب محلا لأنه مفعول به، والواو عاطفة، وما نافية، وكانوا فعل ماض ناقص، والواو اسمها، ومنتصرين خبرها.</p></div>"
  51,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقوم نوح من قبل إنهم كانوا قوما فاسقين﴾</span></span>: الواو عاطفة، وقوم منصوب بفعل محذوف مفهوم ضمنًا، أي: وأهلكنا قوم نوح، ولك أن تقدره: واذكر قوم نوح، ومن قبل: من حرف جر، وقبل ظرف مبني على الضم لانقطاعه عن الإضافة لفظًا لا معنى، والجار والمجرور متعلقان بمحذوف حال، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة كانوا قومًا فاسقين خبرها، وجملة إن وما بعدها لا محل لها من الإعراب، لأنها تعليل لهلاكهم.</p></div>"
  51,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسماء بنيناها بأيد﴾</span></span>: الواو استئنافية. والسماء: منصوب على الاشتغال، والتقدير: بنينا السماء بنيناها. وبنيناها: فعل وفاعل ومفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿بنيناها﴾</span></span> تفسيرية لا محل لها من الإعراب. وجملة بنينا السماء عطف على الجملة الفعلية السابقة، وبأيد جار ومجرور متعلقان بمحذوف حال من فاعل بنيناها، أي متلبسين بقوة، أو من مفعوله، أي متلبسة بقوة، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بنيناها﴾</span></span>، فتكون الباء للسببية، أي: بسبب قدرتنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿والسماء بنيناها بأيد﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لموسعون﴾</span></span>: الواو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وموسعون خبرها، والجملة في محل نصب على الحال من فاعل بنيناها، أو من مفعوله.</p></div>"
  51,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض فرشناها فنعم الماهدون﴾</span></span>: الواو عاطفة، والأرض: نصب على الاشتغال، والتقدير: فرشنا الأرض فرشناها، وفرشناها: فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فرشناها﴾</span></span> تفسيرية لا محل لها من الإعراب، والفاء عاطفة، ونعم: فعل ماض جامد لإنشاء المدح، والماهدون: فاعل نعم، والمخصوص بالمدح محذوف، أي: نحن، والجملة خبر له.</p></div>"
  51,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن كل شيء خلقنا زوجين لعلكم تذكرون﴾</span></span>: الواو عاطفة، ومن كل شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، أي: خلقنا من كل شيء زوجين، أو متعلقان بمحذوف حال من زوجين، لأنه في الأصل صفة له، والتقدير: خلقنا زوجين كائنين من كل شيء، وخلقنا فعل وفاعل، وزوجين مفعول به، ولعل حرف ناسخ يفيد الترجي، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة تذكرون خبرها.</p></div>"
  51,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ففروا إلى الله﴾</span></span>: الفاء الفصيحة، ولا بد من تقدير مضاف محذوف، أي: إلى ثوابه، وفروا فعل أمر مبني على حذف النون، والواو فاعل، وإلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فروا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم منه نذير مبين﴾</span></span>: إن حرف ناسخ، والياء اسمها، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذير﴾</span></span>، وكذلك يتعلق منه، ولك أن تعلقه بمحذوف على أنه حال من نذير، لأنه في الأصل صفة له، ونذير خبر إني، ومبين نعت نذير.</p></div>"
  51,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجعلوا مع الله إلها آخر﴾</span></span>: الواو عاطفة، ولا ناهية، وتجعلوا فعل مضارع مجزوم بلا، والواو فاعله، ومع الله ظرف مكان متعلق بمحذوف في موضع المفعول الثاني، وإلهًا: مفعول تجعلوا الأول وآخر نعت <span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم منه نذير مبين﴾</span></span>: إن حرف ناسخ، والياء اسمها، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذير﴾</span></span>، وكذلك يتعلق منه، ولك أن تعلقه بمحذوف على أنه حال من نذير، لأنه في الأصل صفة له، ونذير خبر إني، ومبين نعت نذير، وهذه الجملة تكرير للتأكيد، فالأولى مرتبة على ترك الإيمان والطاعة، والثانية مرتبة على الإشراك.</p></div>"
  51,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك ما أتى الذين من قبلهم﴾</span></span>: كذلك: جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: الأمر والشأن. وما نافية. وأتى فعل ماض. والذين مفعوله المقدم. ومن قبلهم: جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رسول﴾</span></span>: من: حرف جر صلة. ورسول مجرور بمن لفظًا مرفوع محلًّا، لأنه فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا قالوا ساحر أو مجنون﴾</span></span>: إلا أداة حصر. وقالوا فعل وفاعل. وساحر خبر لمبتدأ محذوف تقديره: أنت، وأو حرف عطف، ومجنون عطف على ساحر، وقد تقدم معنى العطف، وجملة إلا قالوا في محل نصب على الحال من الذين من قبلهم، كأنه قيل: ما أتى الذين من قبلهم رسول إلا في حال قولهم هو ساحر أو مجنون، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذلك ما أتى...﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  51,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتواصوا به بل هم قوم طاغون﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي التعجبي، وتواصوا فعل ماض وفاعل، والواو فاعل تواصوا، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تواصوا﴾</span></span>، وبل حرف إضراب وعطف، وهم مبتدأ، وقوم خبر، وطاغون نعت قوم.</p></div>"
  51,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتول عنهم فما أنت بملوم﴾</span></span>: الفاء الفصيحة، فتول: فعل أمر مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء تعليلية للأمر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بملوم﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿ملوم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  51,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وذكر فإن الذكرى تنفع المؤمنين﴾</span></span>: الواو عاطفة، وذكر فعل أمر، وفاعله مستتر تقديره: أنت، والفاء تعليل للأمر، وإن حرف ناسخ، والذكرى اسمها، وجملة تنفع المؤمنين خبرها.</p></div>"
  51,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما خلقت الجن والإنس إلا ليعبدون﴾</span></span>: الواو عاطفة، وما نافية، وخلقت فعل وفاعل، والجن مفعول به، والإنس عطف على الجن، وإلا أداة حصر، واللام للتعليل، أو للعاقبة، ويعبدون فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وعلامة نصبه حذف النون، والنون المذكورة للوقاية، والواو فاعل، وياء المتكلم المحذوفة في محل نصب مفعول به، ولام التعليل ومدخولها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقت﴾</span></span>.</p></div>"
  51,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أريد منهم من رزق وما أريد أن يطعمون﴾</span></span>: ما نافية، وأريد فعل مضارع مرفوع، وفاعله مستتر تقديره: أنا، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أريد﴾</span></span>، ومن حرف جر صلة، ورزق مجرور لفظًا منصوب محلًّا لأنه مفعول بـ<span class="hlt"><span class="qpc-hafs">﴿أريد﴾</span></span>، والواو حرف عطف، ما أريد عطف على مثيلتها، وأن حرف مصدري ونصب ويطمعون فعل مضارع منصوب بأن، وياء المتكلم المحذوفة مفعول به، وأن وما في حيزها في تأويل مصدر مفعول به، أي: وما أريد إطعامهم إياي.</p></div>"
  51,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله هو الرزاق ذو القوة المتين﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وهو ضمير فصل لا محل له  من الإعراب، والرزاق خبر إن الأول، وذو القوة خبر ثانٍ، والمتين خبر ثالث، وقيل: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الرزاق﴾</span></span> أو لـ<span class="hlt"><span class="qpc-hafs">﴿ذو﴾</span></span>.</p></div>"
  51,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن للذين ظلموا ذنوبا مثل ذنوب أصحابهم فلا يستعجلون﴾</span></span>: الفاء الفصيحة، وإن حرف ناسخ، وللذين جار ومجرور في محل نصب خبر مقدم لإن، وجملة ظلموا صلة الموصول لا محل لها من الإعراب. وذنوبًا اسم إن المؤخر، ومثل ذنوب أصحابهم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذنوبًا﴾</span></span>، والفاء عاطفة لترتيب النهي عن الاستعجال، ولا ناهية، ويستعجلون فعل مضارع مجزوم بلا، وعلامة جزمه حذف النون، والواو فاعل، والنون المذكورة المكسورة للوقاية، والياء المحذوفة مفعول به.</p></div>"
  51,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فويل للذين كفروا من يومهم الذي يوعدون﴾</span></span>: الفاء عاطفة لترتيب ثبوت الويل لهم، وويل مبتدأ ساغ الابتداء به لما تضمنه من معنى الدعاء، وللذين خبره، وجملة كفروا صلة الموصول لا محل لها من الإعراب. ومن يومهم صفة لويل، وقيل: إنها بمعنى في، والذي صفة ليومهم، ويوعدون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة يوعدون صلة الذي لا محل لها من الإعراب.</p></div>"
