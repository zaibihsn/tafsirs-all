quran[46]{c,v,t}:
  79,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنازعات﴾</span></span>: الواو حرف للقسم والجر، والنازعات اسم مجرور بواو القسم وعلامة جره الكسرة، والجار والمجرور متعلقان بفعل محذوف، أي: أقسم، وجملة القسم ابتدائية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿غرقا﴾</span></span>: نائب عن المفعول المطلق مرادف لعامله <span class="hlt"><span class="qpc-hafs">﴿النازعات﴾</span></span>، منصوب وعلامة نصبه الفتحة، وجواب القسم محذوف، أي: لنبعثن.</p></div>"
  79,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والناشطات﴾</span></span>: الواو حرف عطف، والناشطات معطوف على <span class="hlt"><span class="qpc-hafs">﴿النازعات﴾</span></span> مجرور، وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿نشطا﴾</span></span>: مفعول مطلق منصوب وعلامة نصبه الفتحة.</p></div>"
  79,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسابحات﴾</span></span>: الواو حرف عطف، والسابحات معطوف على <span class="hlt"><span class="qpc-hafs">﴿النازعات﴾</span></span> مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحا﴾</span></span>: مفعول مطلق منصوب وعلامة نصبه الفتحة.</p></div>"
  79,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالسابقات﴾</span></span>: الفاء حرف عطف للترتيب، والسابقات معطوف على <span class="hlt"><span class="qpc-hafs">﴿النازعات﴾</span></span> مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبقا﴾</span></span>: مفعول مطلق منصوب وعلامة نصبه الفتحة.</p></div>"
  79,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالمدبرات﴾</span></span>: الفاء حرف عطف للترتيب والتعقيب، والسابقات معطوف على <span class="hlt"><span class="qpc-hafs">﴿النازعات﴾</span></span> مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أمرا﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة.</p></div>"
  79,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: ظرف زمان منصوب، وعلامة نصبه الفتحة، متعلق بجواب القسم المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترجف﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الراجفة﴾</span></span>: فاعل ترجف مرفوع وعلامة رفعه الضمة، والجملة في محل جر بإضافة الظرف إليها.</p></div>"
  79,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تتبعها﴾</span></span>: تتبع فعل مضارع مرفوع وعلامة رفعه الضمة، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير مبني في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿الرادفة﴾</span></span>: فاعل تتبع مرفوع وعلامة رفعه الضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتبعها الرادفة﴾</span></span> في محل نصب حال من <span class="hlt"><span class="qpc-hafs">﴿الراجفة﴾</span></span>.</p></div>"
  79,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قلوب﴾</span></span>: مبتدأ مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف زمان منصوب وعلامة نصبه الفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿واجفة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذٍ﴾</span></span> اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: قلوب واجفة يوم إذ ترجف الراجفة تتبعها الرادفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿واجفة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قلوب﴾</span></span> مرفوع، وعلامة رفعه الضمة.</p></div>"
  79,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أبصارها﴾</span></span>: مبتدأ مرفوع وعلامة رفعه الضمة، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿خاشعة﴾</span></span>: خبر مرفوع وعلامة رفعه الضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿خاشعة أبصارهم﴾</span></span> في محل رفع خبر للمبتدأ الأول <span class="hlt"><span class="qpc-hafs">﴿قلوب﴾</span></span>.</p></div>"
  79,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل، وجملة يقولون خبر لمبتدأ محذوف تقديره هم، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم يقولون﴾</span></span> في محل نصب حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئنا﴾</span></span>: الهمزة للاستفهام، إن حرف ناسخ ناصب مبني على الفتح لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمردودون﴾</span></span>: اللام المزحلقة، ومردودون خبر إن مرفوع وعلامة رفعه الواو، وجملة <span class="hlt"><span class="qpc-hafs">﴿أئنا لمردودون﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحافرة﴾</span></span>: اسم مجرور وعلامة جره الكسرة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مردودون﴾</span></span>.</p></div>"
  79,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئذا﴾</span></span>: الهمزة للاستفهام الإنكاري، وإذا ظرف لما يستقبل من الزمان متضمن معنى الشرط مبني على السكون في محل نصب متعلق بما دل عليه <span class="hlt"><span class="qpc-hafs">﴿مردودون﴾</span></span>، أي: نرد.</p><p><span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: فعل ماض ناقص مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني على السكون في محل رفع خبر اسم كان.</p><p><span class="hlt"><span class="qpc-hafs">﴿عظاما﴾</span></span>: خبر كان منصوب وعلامة نصبه الفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿نخرة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عظاما﴾</span></span> منصوب وعلامة نصبه الفتحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> في محل جر بإضافة الظرف إليها، وجواب <span class="hlt"><span class="qpc-hafs">﴿أئذا﴾</span></span> محذوف دل عليه <span class="hlt"><span class="qpc-hafs">﴿مردودون﴾</span></span>، أي: نرد.</p></div>"
  79,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض مبني على الضم، وواو الجماعة ضمير مبني على السكون في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿تلك﴾</span></span>: التاء اسم إشارة مبني على السكون في محل رفع مبتدأ، واللام للبعد والكاف ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span>: حرف مبني على الفتح للجواب والجزاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿كرة﴾</span></span>: خبر تلك مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿خاسرة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كرة﴾</span></span> مرفوع وعلامة رفعه الضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿تلك إذًا كرة خاسرة﴾</span></span> في محل نصب مقول القول.</p></div>"
  79,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما﴾</span></span>: الفاء حرف استئناف، وإن حرف ناسخ مبني على الفتح لا محل له من الإعراب، وما كافة لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> عن عملها.</p><p><span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>: ضمير منفصل مبني على الفتح في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿زجرة﴾</span></span>: خبر هي مرفوع وعلامة رفعه الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿زجرة﴾</span></span> مرفوع وعلامة رفعه الضمة، والجملة استئنافية لا محل لها من الإعراب.</p></div>"
  79,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء حرف عطف، وإذا فجائية.</p><p><span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>: ضمير مبني على الفتح في محل رفع مبتدأ، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالساهرة﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مرفوع وعلامة رفعه الضمة، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿إنما هي زجرة واحدة﴾</span></span> لا محل لها من الإعراب.</p></div>"
  79,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span>: أداة استفهام مبنية على السكون لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتاك﴾</span></span>: أتى فعل ماضٍ مبني على الفتح، والكاف ضمير مبني في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿حديث﴾</span></span>: فاعل أتى مرفوع وعلامة رفعه الضمة وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span>: مضاف إليه مجرور بكسرة مقدرة على الألف، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  79,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: ظرف لما مضى من الزمن مبني على السكون في محل نصب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿حديث﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ناداه﴾</span></span>: نادى فعل ماض مبني على الفتح، والهاء ضمير مبني في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span>: رب فاعل نادى مرفوع، وعلامة رفعه الضمة وهو مضاف، والهاء ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالواد﴾</span></span>: الباء حرف جر مبني على الكسر، و<span class="hlt"><span class="qpc-hafs">﴿الواد﴾</span></span> اسم مجرور وعلامة الجر كسرة مقدرة على الياء المحذوفة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناداه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿المقدس﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الوادي﴾</span></span> مجرور وعلامة جره الكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿طوى﴾</span></span>: بدل من الوادي مجرور بكسرة مقدرة على الألف، وجملة <span class="hlt"><span class="qpc-hafs">﴿ناداه﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  79,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span>: فعل أمر مبني على السكون والفاعل ضمير مستتر تقديره أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى﴾</span></span>: حرف جر مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>: اسم مجرور وعلامة جره الفتحة، لأنه ممنوع من الصرف، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ مبني على الفتح لا محل له من الإعراب، والهاء ضمير مبني في محل نصب اسم <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿طغى﴾</span></span>: فعل ماض مبني على الفتح، والفاعل ضمير مستتر تقديره هو عائد على فرعون، وجملة <span class="hlt"><span class="qpc-hafs">﴿طغى﴾</span></span> في محل رفع خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span> في محل نصب مقول قول محذوف.</p></div>"
  79,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span>: الفاء حرف عطف مبني على الفتح، وقل فعل أمر مبني على السكون والفاعل ضمير مستتر تقديره أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span>: أداة استفهام مبنية على السكون لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span>: جار ومجرور متعلقان بخبر محذوف لمبتدأ محذوف، أي: رغبة كائنة لك، وجملة الاستفهام في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: حرف مصدري ناصب مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿تزكى﴾</span></span>: فعل مضارع منصوب وعلامة نصبه فتحة مقدرة على الألف والفاعل ضمير مستتر تقديره أنت، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن تزكى﴾</span></span> مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿إلى﴾</span></span>، والجار والمجرور متعلقان برغبة المحذوفة.</p></div>"
  79,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأهديك﴾</span></span>: الواو حرف عطف، وأهديك فعل مضارع منصوب وعلامة نصبه الفتحة معطوف على <span class="hlt"><span class="qpc-hafs">﴿تزكى﴾</span></span>، والفاعل ضمير مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>، والكاف ضمير مبني في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى﴾</span></span>: حرف جر مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: رب اسم مجرور وعلامة جره الكسرة وهو مضاف والكاف ضمير مبني في محل جر مضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهديك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتخشى﴾</span></span>: الفاء حرف عطف، فعل مضارع منصوب وعلامة نصبه الفتحة المقدرة معطوف على <span class="hlt"><span class="qpc-hafs">﴿تزكى﴾</span></span>، والفاعل ضمير مستتر تقديره أنت.</p></div>"
  79,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأراه﴾</span></span>: الفاء حرف عطف، وأراه فعل ماضٍ وفاعله ضمير مستتر تقديره هو، والهاء ضمير في محل نصب مفعول <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span> الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿الآية﴾</span></span>: مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الآية﴾</span></span> منصوب.</p></div>"
  79,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذب﴾</span></span>: الفاء حرف عطف، وكذب فعل ماضٍ وفاعله ضمير مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعصى﴾</span></span>: الواو حرف عطف، وكذب فعل ماضٍ وفاعله ضمير مستتر تقديره هو، وجملتا <span class="hlt"><span class="qpc-hafs">﴿كذب﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿عصى﴾</span></span> معطوفتان على <span class="hlt"><span class="qpc-hafs">﴿أُراه﴾</span></span>.</p></div>"
  79,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿أدبر﴾</span></span>: فعل ماضٍ وفاعله ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدبر﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿عصى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يسعى﴾</span></span>: فعل مضارع مرفوع والفاعل ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسعى﴾</span></span> في محل نصب حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿أدبر﴾</span></span>.</p></div>"
  79,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فحشر﴾</span></span>: الفاء حرف عطف، وحشر فعل ماضٍ وفاعله ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنادى﴾</span></span>: الفاء حرف عطف، ونادى فعل ماض وفاعله ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿فحشر﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أدبر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فنادى﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿فحشر﴾</span></span>.</p></div>"
  79,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span>: الفاء حرف عطف، وقال فعل ماض وفاعله ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿فنادى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>: ضمير في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span>: رب خبر والضمير في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأعلى﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنا ربكم﴾</span></span>: في محل نصب مقول القول.</p></div>"
  79,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذه﴾</span></span>: الفاء حرف عطف، وأخذ فعل ماض، والهاء ضمير مبني في محل نصب مفعول به مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخذه﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿نكال﴾</span></span>: مفعول لأجله منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span>: مضاف إليه مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿والأولى﴾</span></span>: معطوف على الآخرة مجرور بكسرة مقدرة.</p></div>"
  79,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: اسم إشارة في محل جر، والجار والمجرور في محل رفع خبر إن المقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعبرة﴾</span></span>: اللام لام الابتداء المؤكدة، وعبرة اسم إن المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عبرة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يخشى﴾</span></span>: فعل مضارع مرفوع والفاعل ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخشى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  79,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأنتم﴾</span></span>: الهمزة للاستفهام التوبيخي، وأنتم مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>: خبر مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلقا﴾</span></span>: تمييز منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: اسم معطوف مرفوع على <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بناها﴾</span></span>: بنى فعل ماض وفاعله ضمير مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span>  ضمير مبني في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿بناها﴾</span></span> في محل نصب حال.</p></div>"
  79,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رفع﴾</span></span>: فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿سمكها﴾</span></span>: مفعول به منصوب والضمير في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسواها﴾</span></span>: الفاء حرف عطف، وسواها فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو، والضمير في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رفع﴾</span></span> بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿بناها﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿سواها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿رفع﴾</span></span>.</p></div>"
  79,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأغطش﴾</span></span>: فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليلها﴾</span></span>: مفعول به منصوب والضمير في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخرج﴾</span></span>: فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿ضحاها﴾</span></span>: مفعول به منصوب والضمير في محل جر مضاف إليه، وجملتا <span class="hlt"><span class="qpc-hafs">﴿أغطش﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿أخرج﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿رفع﴾</span></span>.</p></div>"
  79,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض﴾</span></span>: الواو عاطفة، والأرض منصوب على الاشتغال بفعل محذوف يدل عليه ما بعده.</p><p><span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿دحاها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: اسم إشارة في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿دحاها﴾</span></span>: فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو، والضمير في محل نصب مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿دحاها﴾</span></span> تفسيرية لا محل لها من الإعراب.</p></div>"
  79,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أخرج﴾</span></span>: فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرج﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماءها﴾</span></span>: مفعول به منصوب والضمير في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومرعاها﴾</span></span>: الواو حرف عطف، ومرعى اسم معطوف على <span class="hlt"><span class="qpc-hafs">﴿ماءها﴾</span></span>، والضمير في محل جر مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿أخرج...﴾</span></span> تفسيرية لقوله: <span class="hlt"><span class="qpc-hafs">﴿دحاها﴾</span></span> فلا محل لها من الإعراب، أو في محل نصب حال من الأرض بإضمار <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>.</p></div>"
  79,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والجبال﴾</span></span>: الواو عاطفة، والجبال منصوب على الاشتغال بفعل محذوف يدل عليه ما بعده.</p><p><span class="hlt"><span class="qpc-hafs">﴿أرساها﴾</span></span>: فعل ماض مبني على الفتح، وفاعله ضمير مستتر تقديره هو، والضمير في محل نصب مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿أرساها﴾</span></span> تفسيرية لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿الجبال أرساها﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿الأرض بعد ذلك دحاها﴾</span></span>.</p></div>"
  79,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متاعا﴾</span></span>: مفعول لأجله منصوب، أو نائب عن المفعول المطلق لفعل محذوف، لأنه اسم مصدر، والتقدير: يمتعكم متاعا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متاعا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولأنعامكم﴾</span></span>: الواو عاطفة واللام حرف جر، وأنعامكم اسم مجرور، والضمير في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿لأنعامكم﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>.</p></div>"
  79,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء عاطفة، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span>: فعل ماض والتاء للتأنيث، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿الطامة﴾</span></span>: فاعل جاءت مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span>: نعت مرفوع لـ<span class="hlt"><span class="qpc-hafs">﴿الطامة﴾</span></span>.</p></div>"
  79,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: يوم بدل من <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يتذكر﴾</span></span>: فعل مضارع مرفوع، وجملة يتذكر في محل جر بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: فاعل يتذكر مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿سعى﴾</span></span>: فعل ماضٍ، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما سعى﴾</span></span> مفعول به.</p></div>"
  79,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبرزت﴾</span></span>: الواو حرف عطف، فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿برزت﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجحيم﴾</span></span>: نائب فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿برزت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span>: فعل مضارع مرفوع.</p></div>"
  79,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأما حرف شرط وتفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿طغى﴾</span></span>: فعل ماض مبني على الفتح، وفاعله ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿طغى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  79,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآثر﴾</span></span>: فعل ماضٍ مبني على الفتح، وفاعله ضمير مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿آثر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿طغى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span>: نعت منصوب لـ<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span>.</p></div>"
  79,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن﴾</span></span>: الفاء واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وإن حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجحيم﴾</span></span>: اسم إن منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>: ضمير فصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿المأوى﴾</span></span>: خبر إن مرفوع، والجملة في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>.</p></div>"
  79,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما﴾</span></span>: الواو عاطفة، وأما حرف شرط وتفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿خاف﴾</span></span>: فعل ماض مبني على الفتح، وفاعله ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿من خاف﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿من طغى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خاف﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿مقام﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span>: رب مضاف إليه، والضمير مضاف إليه أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونهى﴾</span></span>: الواو عاطفة، فعل ماض مبني على الفتح، وفاعله ضمير مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿ونهى﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿خاف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿النفس﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>: حرف جر مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿الهوى﴾</span></span>: اسم مجرور وعلامة جره الكسرة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نهى﴾</span></span>.</p></div>"
  79,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن﴾</span></span>: الفاء واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وإن حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span>: اسم إن منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>: ضمير فصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿المأوى﴾</span></span>: خبر إن مرفوع، والجملة في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>.</p></div>"
  79,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يسألونك﴾</span></span>: فعل مضارع مرفوع وواو الجماعة فاعل، والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>: حرف جر مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿الساعة﴾</span></span>: اسم مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيان﴾</span></span>: اسم استفهام في محل نصب على الظرف الزماني، متعلق بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿مرساها﴾</span></span>: مبتدأ مؤخر والضمير <span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿أيان مرساها﴾</span></span> تفسيرية لا محل لها من الإعراب. أو في محل نصب بقول محذوف دل عليه فعل <span class="hlt"><span class="qpc-hafs">﴿يسألونك﴾</span></span> والتقدير: <span class="hlt"><span class="qpc-hafs">﴿يقولون أيان مرساها﴾</span></span>.</p></div>"
  79,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span>: ضمير في محل رفع مبتدأ مؤخر .</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر مبني على السكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذكراها﴾</span></span>: اسم مجرور، والضمير في محل جر مضاف إليه، والجار والمجرور متعلقان بما تعلق به الخبر، والجملة لا محل لها من الإعراب.</p></div>"
  79,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى﴾</span></span>: حرف جر مبني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: رب اسم مجرور والضمير في محل جر مضاف إليه، والجار والمجرور في محل رفع خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿منتهاها﴾</span></span>: مبتدأ مؤخر، والضمير في محل جر مضاف إليه، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  79,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span>: كافة ومكفوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span>: ضمير في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿منذر﴾</span></span>: خبر مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿يخشاها﴾</span></span>: فعل مضارع مرفوع والفاعل ضمير مستتر، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخشاها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  79,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأنهم﴾</span></span>: كأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: يوم ظرف زمان منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يرونها﴾</span></span>: فعل مضارع مرفوع وواو الجماعة فاعل و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير في محل نصب مفعول به، والجملة في محل جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>: حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يلبثوا﴾</span></span>: فعل مضارع مرفوع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يلبثوا﴾</span></span> في محل رفع خبر كأن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿عشية﴾</span></span>: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يلبثوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ضحاها﴾</span></span>: معطوف على عشية منصوب بفتحة مقدرة، والضمير في محل جر مضاف إليه.</p></div>"
