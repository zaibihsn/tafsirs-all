quran[22]{c,v,t}:
  58,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد سمع الله قول التي تجادلك في زوجها وتشتكي﴾</span></span>: قد حرف تحقيق، وسمع الله فعل ماضٍ وفاعل، وقول مفعول به، والتي اسم موصول في محل جر بالإضافة، وجملة تجادلك لا محل لها من الإعراب، لأنها صلة الموصول، وتجادلك فعل مضارع، والفاعل مستتر يعود إلى المرأة المذكورة، والكاف مفعول به، وفي زوجها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجادلك﴾</span></span>، ولا بُدَّ من حذف مضاف، وتشتكي عطف على تجادلك، أو الواو حالية، والجملة في موضع نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى الله﴾</span></span>: إلى حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشتكي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله يسمع تحاوركما إن الله سميع بصير﴾</span></span>: الواو حالية، والله مبتدأ، وجملة يسمع خبر، والفاعل مستتر يعود على الله، وتحاوركما مفعول به، وإن حرف ناسخ، ولفظ الجلالة اسمها، وسميع خبرها، وبصير خبرها الثاني، والجملة تعليلية لما قبلها.</p></div>"
  58,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يظاهرون منكم من نسائهم ما هن أمهاتهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظاهرون﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بحال من الواو، أي حال كونهم منكم أيها العرب، و<span class="hlt"><span class="qpc-hafs">﴿من نسائهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يظاهرون﴾</span></span>، والضمير المتصل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿أمهاتهم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> منصوب بالكسرة نيابة عن الفتحة لأنه جمع مؤنث سالم، والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما هن أمهاتهم﴾</span></span> خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أمهاتهم إلا اللائي ولدنهم﴾</span></span>: إن نافية، وأمهاتهم مبتدأ، وإلا أداة حصر، واللائي: اسم موصول في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولدنهم﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ولدنهم﴾</span></span> فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم ليقولون منكرا من القول وزورا﴾</span></span>: الواو عاطفة، وإنهم: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، ويقولون فعل مضارع مرفوع، والواو فاعل، والجملة خبر إن، ومنكرًا صفة لمصدر محذوف، أي: قولًا منكرًا، وزورًا عطف على منكرًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله لعفو غفور﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وعفو خبر أول، وغفور خبر ثان.</p></div>"
  58,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين يظاهرون من نسائهم ثم يعودون لما قالوا فتحرير رقبة من قبل أن يتماسا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والذين مبتدأ، وجملة يظاهرون صلة الموصول لا محل لها من الإعراب، ومن نسائهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يظاهرون﴾</span></span>، وثم حرف عطف للترتيب مع التراخي، ويعودون عطف على يظاهرون، ولما اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما قالوا﴾</span></span> مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعودون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعودون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف، أي: لما قالوه. والفاء رابطة لما في الموصول من معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿تحرير رقبة﴾</span></span> مبتدأ خبره محذوف، أي: عليه تحرير رقبة، والجملة خبر الذين، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأن وما بعدها في تأويل مصدر مجرور بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلكم توعظون به والله بما تعملون خبير﴾</span></span>: ذلكم مبتدأ، والإشارة إلى الحكم المذكور، وجملة توعظون خبر، والله مبتدأ، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبير﴾</span></span>، وجملة تعملون صلة الموصول لا محل لها من الإعراب، وخبير خبر لفظ الجلالة الله.</p></div>"
  58,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن لم يجد﴾</span></span>: الفاء عاطفة، ومن اسم موصول مبتدأ، ولم حرف نفي وقلب وجزم، ويجد فعل مضارع مجزوم بـ(لم، والفاعل مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿فصيام شهرين متتابعين﴾</span></span>: الفاء رابطة، وصيام مبتدأ، وشهرين مضاف إليه، ومتتابعين صفة، والخبر محذوف، أي عليه، والجملة خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿من قبل أن يتماسا﴾</span></span>: من قبل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صيام﴾</span></span> وأن مصدرية ناصبة، ويتماسا مضارع منصوب بحذف النون والألف فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يتماسا﴾</span></span> مضاف إليه، وجملة يتماسا صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن لم يستطع﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول مبتدأ، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يستطع﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والفاعل مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإطعام ستين مسكينا﴾</span></span>: الفاء رابطة، وإطعام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ستين﴾</span></span> مضاف إليه مجرور بالكسرة، ومسكينًا تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك لتؤمنوا بالله ورسوله﴾</span></span>: ذلك اسم إشارة منصوب بمضمر، أي فعلنا ذلك لتؤمنوا. أو ذلك مبتدأ، ولتؤمنوا لام التعليل، ومدخولها خبر ذلك، وبالله: الباء حرف جار ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تؤمنوا﴾</span></span>، ورسوله عطف على لفظ الجلالة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتلك حدود الله وللكافرين عذاب أليم﴾</span></span>: الواو عاطفة، وتلك مبتدأ، وحدود الله خبر، والواو عاطفة، وللكافرين خبر مقدم، وعذاب مبتدأ مؤخر، وأليم نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>.</p></div>"
  58,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يحادون الله ورسوله كبتوا كما كبت الذين من قبلهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والذين اسمها، وجملة يحادون صلة الموصول لا محل لها من الإعراب، ولفظ الجلالة مفعول به، ورسوله عطف على الله، وجملة كبتوا خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف أي: كبتوا كبتا مثلَ كبت الذين، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿كبت﴾</span></span> فعل ماض مبني لما لم يسم فاعله، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل مضاف إليه، والذين نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد أنزلنا آيات بينات وللكافرين عذاب مهين﴾</span></span>: الواو حالية، وقد حرف تحقيق، وأنزلنا فعل وفاعل، وآيات مفعول به، وبينات صفة لآيات، و<span class="hlt"><span class="qpc-hafs">﴿للكافرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، ومهين نعت.</p></div>"
  58,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يبعثهم الله جميعا فينبئهم بما عملوا أحصاه الله ونسوه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرفٌ متعلق بالخبر الذي تعلق به الجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿للكافرين﴾</span></span>، أو متعلق بفعل محذوف تقديره: يُعذَّبون أو يُهانون، أو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مهين﴾</span></span>، أو مفعولٌ به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبعثهم﴾</span></span> في محل جر مضاف إليه، والله فاعل يبعثهم، وجميعًا حال، فينبئهم عطف على يبعثهم، وبما عملوا في موضع المفعول الثاني، وجملة عملوا صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿أحصاه الله﴾</span></span> استئنافية لا محل لها من الإعراب، والواو حالية، وجملة نسوه في محل نصب على الحال من مفعول أحصى بإضمار قد أو بدونها.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله على كل شيء شهيد﴾</span></span>: الله مبتدأ، وعلى كل شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهيد﴾</span></span>، وشهيد خبر لفظ الجلالة الله.</p></div>"
  58,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الله يعلم ما في السماوات وما في الأرض﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، وتر فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف حرف العلة، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يعلم خبرها، وقد سدت مسد مفعولي تر، وما مفعول يعلم، وفي السماوات جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. وما في الأرض عطف على ما في السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما يكون من نجوى ثلاثة إلا هو رابعهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، ويكون فعل مضارع تام، ومن حرف جر صلة، ونجوى مجرور بمن لفظًا فاعل يكون محلا، وثلاثة مضاف إليه، وإلا أداة حصر، وهو مبتدأ، ورابعهم خبر، والجملة في محل نصب على الحال، فالاستثناء مفرغ من أعم الأحوال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا خمسة إلا هو سادسهم﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا أدنى من ذلك﴾</span></span>: الواو عاطفة، ولا نافية، وأدنى معطوف على ثلاثة مجرور بالفتحة المقدرة لمنعه من الصرف، ومن ذلك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدنى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا أكثر﴾</span></span>: الواو عاطفة ولا نافية وأكثر معطوف مجرور بفتحة ظاهرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة استثناء للحصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو معهم أين ما كانوا﴾</span></span>: هو ضمير في محل رفع مبتدأ، ومعهم ظرف منصوب متعلق بمحذوف خبر وضمير الغياب في محل جر مضاف إليه، والجملة في محل نصب حال، وأينما ظرف مكان مجرد من الشرط في محل نصب متعلق بما تعلق به الخبر <span class="hlt"><span class="qpc-hafs">﴿معهم﴾</span></span>، وكان فعل ماضٍ تام والواو في محل رفع فاعل والجملة في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم ينبئهم بما عملوا يوم القيامة إن الله بكل شيء عليم﴾</span></span>: ثم حرف عطف للترتيب، وينبئهم فعل مضارع، وفاعل مستتر يعود على الله، وبما في موضع المفعول الثاني، وجملة عملوا لا محل لها من الإعراب، ويوم القيامة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ينبئهم﴾</span></span>، وإن حرف ناسخ، ولفظ الجلالة اسمها، وعليم خبرها.</p></div>"
  58,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر إلى الذين نهوا عن النجوى ثم يعودون لما نهوا عنه﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، وتر: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف حرف العلة، والفاعل مستتر تقديره: أنت، وإلى الذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نهوا عن النجوى﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول، ونهوا فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وعن النجوى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نهوا﴾</span></span>، ثم: حرف عطف للترتيب مع التراخي، ويعودون فعل مضارع مرفوع، ولما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعودون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نهوا عنه﴾</span></span> صلة الموصول لا محل لها من الإعراب، وعنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نهوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويتناجون بالإثم والعدوان ومعصية الرسول﴾</span></span>: الواو عاطفة، ويتناجون فعل مضارع معطوف على يعودون، وفي صيغة المضارع ما تقدم آنفًا من تجسيد، واستحضار، وتجدد، وبالإثم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتناجون﴾</span></span>، والعدوان عطف على الإثم، ومعصية الرسول عطف أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا جاءوك حيوك بما لم يحيك به الله﴾</span></span>: الواو عاطفة، وإذا ظرف لما يستقبل من الزمن، وجملة جاءوك في محل جر بإضافة الظرف إليها، والواو فاعل، والكاف مفعول به، وجملة حيوك لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حيوك﴾</span></span>، ولم حرف نفي وقلب وجزم، ويحيك فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف حرف العلة، والكاف مفعول به، والله فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون في أنفسهم لولا يعذبنا الله بما نقول﴾</span></span>: الواو عاطفة، أو حالية، ويقولون فعل مضارع، والواو فاعل، وفي أنفسهم جار ومجرور متعلقان بمحذوف حال، ولولا حرف تحضيض، أي: هلا، ويعذبنا الله فعل مضارع، ومفعول به مقدم، وفاعل مؤخر، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعذبنا﴾</span></span>، وما مصدرية، أو موصولة، والعائد محذوف، أي بالذي نقوله، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسبهم جهنم يصلونها﴾</span></span>: حسبهم مبتدأ، وجهنم خبر، وجملة يصلونها حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فبئس المصير﴾</span></span>: الفاء الفصيحة، وبئس فعل ماضٍ جامد لإنشاء الذم، والمصير فاعل، والمخصوص بالذم محذوف، تقديره: هي، أي: النار.</p></div>"
  58,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الذين آمنوا﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم، وها للتنبيه، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وجملة آمنوا صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا تناجيتم فلا تتناجوا بالإثم والعدوان ومعصية الرسول﴾</span></span>: إذا ظرف لما يستقبل من الزمن متضمن معنى الشرط، وجملة تناجيتم في محل جر بإضافة الظرف إليها، والفاء رابطة لجواب إذا، ولا ناهية، وتتناجوا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وبالإثم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتناجوا﴾</span></span>، والعدوان عطف على قوله بالإثم، ومعصية الرسول عطف أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتناجوا بالبر والتقوى واتقوا الله الذي إليه تحشرون﴾</span></span>: الواو عاطفة، وتناجوا فعل أمر مبني على حذف النون، والواو فاعل، بالبر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تناجوا﴾</span></span>، والتقوى عطف على البر، واتقوا الله فعل أمر وفاعل ولفظ الجلالة مفعول به، والذي صفة لله، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحشرون﴾</span></span>، وتحشرون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحشرون﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول.</p></div>"
  58,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما النجوى من الشيطان ليحزن الذين آمنوا﴾</span></span>: إنما كافة ومكفوفة، والنجوى مبتدأ، ومن الشيطان جار ومجرور متعلقان بمحذوف خبر النجوى، واللام لام التعليل، ويحزن فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف خبر ثانٍ، والذين مفعول به، وجملة آمنوا لا محل لها من الإعراب، لأنها صلة الموصول، وقيل: إن الموصول فاعل يحزن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليس بضارهم شيئا إلا بإذن الله﴾</span></span>: الواو حالية، وليس فعل ماضٍ ناقص، واسمها مستتر تقديره: هو، والباء حرف جر صلة، وضارهم مجرور لفظًا منصوب محلًّا على أنه خبر ليس، وشيئًا نائب عن المفعول المطلق، وإلا أداة حصر، وبإذن الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضارهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعلى الله فليتوكل المؤمنون﴾</span></span>: الواو عاطفة، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتوكل﴾</span></span>.</p></div>"
  58,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا قيل لكم تفسحوا في المجالس فافسحوا يفسح الله لكم﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم، وها للتنبيه، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وجملة آمنوا صلة الموصول لا محل لها من الإعراب، وإذا ظرف لما يستقبل من الزمن، متضمن معنى الشرط وجملة قيل في محل جر بإضافة الظرف إليها، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وتفسحوا فعل أمر مبني على حذف النون، والواو فاعل، وجملة تفسحوا مقول القول، وفي المجالس جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفسحوا﴾</span></span>، والفاء رابطة لجواب الشرط غير الجازم، والجملة لا محل لها من الإعراب، وافسحوا فعل أمر، والواو فاعل، ويفسح فعل مضارع مجزوم، لأنه جواب الأمر الواقع جوابًا للشرط، والله فاعل، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفسح﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل انشزوا فانشزوا﴾</span></span>: الواو عاطفة، وإذا ظرف لما يستقبل من الزمن، متضمن معنى الشرط وجملة قيل في محل جر بإضافة الظرف إليها، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وانشزوا فعل أمر مبني على حذف النون، والواو فاعل، وجملة انشزوا مقول القول، والفاء رابطة لجواب الشرط غير الجازم، والجملة لا محل لها من الإعراب، وانشزوا فعل أمر، والواو فاعل .</p><p><span class="hlt"><span class="qpc-hafs">﴿يرفع الله الذين آمنوا منكم والذين أوتوا العلم درجات﴾</span></span>: يرفع فعل مضارع مجزوم لأنه جواب الطلب، والله فاعل، والذين مفعول به، وجملة آمنوا صلة الموصول لا محل لها من الإعراب، والذين معطوف على الذين الأولى، أو هو منصوب بفعل مضمر تقديره: ويخص الذين أوتوا العلم، وجملة أوتوا صلة الموصول لا محل لها من الإعراب، وأوتوا فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب فاعل، والعلم مفعول به ثانٍ، ومنكم جار ومجرور متعلقان بمحذوف حال من فاعل آمنوا، ودرجات ظرف، أو منصوب بنزع الخافض.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله بما تعملون خبير﴾</span></span>: الواو استئنافية، والله مبتدأ، وبما تعملون جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبير﴾</span></span>، وخبير خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿والله بما...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  58,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الذين آمنوا﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم، وها للتنبيه، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وجملة آمنوا صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا ناجيتم الرسول فقدموا بين يدي نجواكم صدقة﴾</span></span>: إذا ظرف مستقبل متضمن معنى الشرط، وجملة ناجيتم في محل جر بإضافة الظرف إليها، وناجيتم فعل وفاعل، والرسول مفعول به، والفاء رابطة، وقدموا فعل أمر، والواو فاعل، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وبين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قدموا﴾</span></span>، ويدي مضاف إليه، وعلامة جره الياء، ونجواكم مضاف إليه، وصدقة مفعول به لقدموا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك خير لكم وأطهر﴾</span></span>: ذلك مبتدأ، والإشارة إلى تقديم الصدقة على المناجاة، وخير خبر، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وأطهر عطف على خير.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن لم تجدوا فإن الله غفور رحيم﴾</span></span>: الفاء عاطفة، وإن شرطية، ولم حرف نفي وقلب وجزم، وتجدوا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف النون، وهو فعل الشرط، والفاء رابطة لجواب محذوف، وجملة إن الله غفور رحيم تعليليلة.</p></div>"
  58,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأشفقتم أن تقدموا بين يدي نجواكم صدقات﴾</span></span>: الهمزة للاستفهام التقريري، وأشفقتم فعل وفاعل، وأن وما في حيزها في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشفقتم﴾</span></span>، وقيل: مفعول من أجله، ومفعول تقدموا هو صدقات، ومفعول أشفقتم محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذ لم تفعلوا﴾</span></span>: الفاء استئنافية، وإذ: ظرف فيه معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أقيموا﴾</span></span>. ولم: حرف نفي وقلب وجزم. وتفعلوا: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تفعلوا﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتاب الله عليكم﴾</span></span>: الواو اعتراضية، أو حالية. و<span class="hlt"><span class="qpc-hafs">﴿تاب الله﴾</span></span>: فعل وفاعل، وعليكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تاب﴾</span></span>. والجملة اعتراضية بين الشرط وجوابه لا محل لها من الإعراب، أو في محل نصب حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأقيموا الصلاة وآتوا الزكاة وأطيعوا الله ورسوله﴾</span></span>: الفاء رابطة للجواب. و<span class="hlt"><span class="qpc-hafs">﴿أقيموا الصلاة﴾</span></span> فعل أمر وفاعل ومفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿فإذ لم تفعلوا..﴾</span></span> مستأنفة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وآتوا الزكاة﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فأقيموا الصلاة﴾</span></span>. وكذلك قوله: <span class="hlt"><span class="qpc-hafs">﴿وأطيعوا الله ورسوله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله خبير بما تعملون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ و<span class="hlt"><span class="qpc-hafs">﴿خبير﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء: حرف جر، وما: مصدرية مؤولة مع الفعل بعدها بمصدر مجرور، أي: خبير بعملِكم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر بالباء، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبير﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿والله خبير﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  58,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر إلى الذين تولوا قوما غضب الله عليهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف حرف العلة، والفاعل مستتر تقديره: أنت. وإلى الذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، والواو فاعل، وقومًا مفعول به، وجملة غضب الله عليهم نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما هم منكم ولا منهم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، أو حال من فاعل تولوا، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ما، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية لا عمل لها و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span> الواو: حرف عطف، ولا: لتأكيد النفي، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> معطوف على منكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويحلفون على الكذب وهم يعلمون﴾</span></span>: الواو عاطفة، ويحلفون فعل مضارع مرفوع بثبوت النون، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>، فهي داخلة في حيز الصلة، وعلى الكذب حال، والواو حالية، وهم مبتدأ، وجملة يعلمون خبر هم، والجملة حال.</p></div>"
  58,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أعد الله لهم عذابا شديدا﴾</span></span>: فعل وفاعل ومفعول به، وشديدًا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم ساء ما كانوا يعملون﴾</span></span>: إن للتوكيد والنصب، وهم اسمها وساء فعل ماضٍ جامد للذم، وما اسم موصول مبني على السكون في محل رفع فاعل، وكانوا ماضٍ ناقص مبني على الضم والواو اسمه، ويعملون فعل مضارع مرفوع بثبوت النون والواو في محل رفع فاعل، وجملة ساء في محل رفع خبر إن، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة يعملون في محل نصب خبر كانوا.</p></div>"
  58,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اتخذوا أيمانهم جنة﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، أو حال، واتخذوا فعل ماضٍ، والواو فاعل، وأيمانهم مفعول به أول، وجنة مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فصدوا﴾</span></span>: الفاء عاطفة، وصدوا فعل ماضٍ وفاعل .</p><p><span class="hlt"><span class="qpc-hafs">﴿عن سبيل الله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صدوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلهم عذاب مهين﴾</span></span>: الفاء عاطفة، ولهم خبر مقدم، وعذاب مبتدأ مؤخر، ومهين نعت لعذاب.</p></div>"
  58,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لن تغني عنهم أموالهم﴾</span></span>: لن حرف نفي ونصب واستقبال، وتغني فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، وعنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>، وأموالهم فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا أولادهم﴾</span></span>: عطف على أموالهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span>: من حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span> على حذف مضاف، أي من عذاب الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span>: نائب عن المفعول المطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب النار﴾</span></span>: أولئك مبتدأ، وأصحاب النار خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿هم فيها خالدون﴾</span></span>: هم مبتدأ، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  58,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يبعثهم الله جميعا فيحلفون له كما يحلفون لكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، والجملة مستأنفة لا محل لها من الإعراب، وجملة يبعثهم في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل يبعثهم، وجميعًا حال، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يحلفون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، وله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحلفون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل بعدها مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحلفون﴾</span></span> لا محل لها من الإعراب، لأنها صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحلفون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويحسبون أنهم على شيء﴾</span></span>: الواو حالية، وجملة يحسبون حال من الواو في يحلفون له، وأن وما بعدها في تأويل مصدر سدت مسد مفعولي يحسبون، وعلى شيء جار ومجرور متعلقان بمحذوف خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إنهم هم الكاذبون﴾</span></span>: ألا أداة استفتاح وتنبيه، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وهم ضمير متصل، أو مبتدأ، والكاذبون خبر إن على الأول، وخبر هم على الثاني، والجملة خبر إن.</p></div>"
  58,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿استحوذ عليهم الشيطان فأنساهم ذكر الله﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استحوذ﴾</span></span>، والشيطان فاعله، فأنساهم عطف على استحوذ، والهاء مفعول به أول، وذكر الله مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك حزب الشيطان﴾</span></span>: أولئك مبتدأ، وحزب الشيطان خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن حزب الشيطان هم الخاسرون﴾</span></span>: ألا أداة استفتاح وتنبيه، وإن حرف ناسخ، وحزب اسمها، والشيطان مضاف إليه، وهم ضمير فصل، أو مبتدأ، والخاسرون خبر على الحالين كما تقدم.</p></div>"
  58,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يحادون الله ورسوله أولئك في الأذلين﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة يحادون صلة الموصول لا محل لها من الإعراب، ولفظ الجلالة مفعول به، ورسوله عطف على الله، وأولئك مبتدأ، وفي الأذلين خبر أولئك، والجملة خبر إن.</p></div>"
  58,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كتب الله لأغلبن أنا ورسلي﴾</span></span>: كتب الله فعل وفاعل، وقد تضمن فعل كتب معنى القسم، واللام جواب له، وأغلبن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، وأنا تأكيد لفاعل أغلبن المستتر، ورسلي عطف على الضمير.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله قوي عزيز﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وقوي خبرها، وعزيز خبرها الثاني، والجمل لا محل لها من الإعراب.</p></div>"
  58,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا تجد قوما يؤمنون بالله واليوم الآخر يوادون من حاد الله ورسوله﴾</span></span>: لا نافية، وتجد فعل مضارع مرفوع، والفاعل مستتر تقديره أنت، وقومًا مفعول به أول، وجملة يؤمنون بالله واليوم الآخر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، وجملة يوادون مفعول به ثانٍ لتجد إن كان بمعنى تعلم، وإن كان بمعنى تصادف، فالجملة حال، أو صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، ويوادون فعل وفاعل، ومن مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿حاد الله﴾</span></span> صلة الموصول لا محل لها من الإعراب. وحاد الله فعل ماضٍ، وفاعل مستتر، ومفعول به، ورسوله عطف على الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو كانوا آباءهم أو أبناءهم أو إخوانهم أو عشيرتهم﴾</span></span>: الواو حالية، ولو شرطية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وآباءهم خبرها، وما بعده عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك كتب في قلوبهم الإيمان وأيدهم بروح منه﴾</span></span>: أولئك مبتدأ، وجملة كتب خبر، وفي قلوبهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كتب﴾</span></span>، والإيمان مفعول به، وأيدهم فعل وفاعل مستتر ومفعول به، وبروح جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أيدهم﴾</span></span>، ومنه صفة لروح.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويدخلهم جنات تجري من تحتها الأنهار خالدين فيها﴾</span></span>: الواو عاطفة، ويدخلهم فعل مضارع، وفاعل مستتر، ومفعول به، وجنات مفعول به ثانٍ على السعة، وجملة تجري من تحتها الأنهار نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span>، وخالدين حال، وفيها جار ومجرور متعلقان بخالدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿رضي الله عنهم ورضوا عنه﴾</span></span>: رضي فعل ماضٍ، والله فاعل، وعنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رضي﴾</span></span>، ورضوا عنه عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك حزب الله﴾</span></span>: أولئك مبتدأ، وحزب الله خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن حزب الله هم المفلحون﴾</span></span>: ألا أداة استفتاح وتنبيه، وإن حرف ناسخ، وحزب اسمها، ولفظ الجلالة مضاف إليه، وهم ضمير فصل، أو مبتدأ، والمفلحون خبر.</p></div>"
