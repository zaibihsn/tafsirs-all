quran[111]{c,v,t}:
  12,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الر﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب المبين﴾</span></span>: تلك مبتدأ، وآيات خبر، والكتاب مضاف إليه، والمبين صفة للكتاب.</p></div>"
  12,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أنزلناه قرآنا عربيا لعلكم تعقلون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أنزلناه خبرها، وقرآنًا حال من ضمير أنزلناه، أي: الهاء، أو منصوب على البدلية من الضمير، وعربيًّا صفة، و<span class="hlt"><span class="qpc-hafs">﴿لعلكم تعقلون﴾</span></span> لعل حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> خبرها.</p></div>"
  12,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن نقص عليك أحسن القصص بما أوحينا إليك هذا القرآن﴾</span></span>: نحن مبتدأ، وجملة نقص خبر، والفاعل مستتر تقديره: نحن، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> مفعول به أو نائب عن المفعول المطلق، والقصص مضاف إليه، والباء للسببية، وما مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع ما في حيزها مجرورة بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، أي: بسبب إيحائنا، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مفعول به، والقرآن بدل من اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كنت من قبله لمن الغافلين﴾</span></span>: الواو للحال، وإن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وكنت فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من قبله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿من الغافلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كنت. وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت من قبله ...﴾</span></span> في محل رفع خبر إن.</p></div>"
  12,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال يوسف لأبيه يا أبت﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قال يا بني﴾</span></span> في الآية التالية، والتقدير: قال يعقوب يا بني لا تقصص رؤياك على إخوتك حينَ قال يوسف له كيت وكيت، أو اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره اذكر، أو في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿أحسن القصص﴾</span></span> إذا أعربنا <span class="hlt"><span class="qpc-hafs">﴿أحسن القصص﴾</span></span> مفعولا به، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال يوسف﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿لأبيه﴾</span></span> متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، ويا حرف نداء، وأبت منادى مضاف إلى ياء المتكلم التي حذفت وعوضت عنها التاء المكسورة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني رأيت أحد عشر كوكبا﴾</span></span>: الياء اسم إن، وجملة رأيت خبرها، وأحد عشر جزءان عدديان مبنيان على الفتح في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿رأيت﴾</span></span>، وكوكبًا تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿والشمس والقمر رأيتهم لي ساجدين﴾</span></span>: الواو حرف عطف، والشمس والقمر معطوفان على <span class="hlt"><span class="qpc-hafs">﴿أحد عشر كوكبًا﴾</span></span>، ورأيتهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ساجدين﴾</span></span>، وساجدين حال من مفعول رأيت.</p></div>"
  12,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا بني لا تقصص رؤياك على إخوتك﴾</span></span>: يا حرف نداء، وبني منادى مضاف لياء المتكلم، ولا ناهية، وتقصص فعل مضارع مجزوم بلا، ورؤياك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على إخوتك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقصص﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيكيدوا لك كيدا﴾</span></span>: الفاء سببية، ويكيدوا منصوب بأن مضمرة، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل معطوف على مصدر مفهوم من الكلام السابق، أي: لا يكن قصٌّ فكيد. والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكيدوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كيدًا﴾</span></span> مفعول مطلق مؤكد، وقيل أنه مفعول به، والتقدير: يصنعوا لك كيدًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الشيطان للإنسان عدو مبين﴾</span></span>: إن حرف ناسخ، والشيطان اسمها، و<span class="hlt"><span class="qpc-hafs">﴿للإنسان﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وعدو خبر إن، ومبين صفة.</p></div>"
  12,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك يجتبيك ربك ويعلمك من تأويل الأحاديث﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: اجتباءً مثلَ ذلك الاجتباء يجتبيك ربك، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يجتبيك﴾</span></span> فعل مضارع والكاف مفعول به، وربك: فاعل، ويعلمك كلام مستأنف لا محل له من الإعراب، كأنه قيل: وهو يعلمك ويتم نعمته، و<span class="hlt"><span class="qpc-hafs">﴿من تأويل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعلمك﴾</span></span>، والأحاديث مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويتم نعمته عليك وعلى آل يعقوب﴾</span></span>: عطف على يعلمك، ونعمته مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نعمته﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿يتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على آل يعقوب﴾</span></span> عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿كما أتمها على أبويك من قبل إبراهيم وإسحاق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كما أتمها﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: يتم نعمته عليك وعلى آل يعقوب إتمامًا مثل إتمامها على أبويك، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿أتمها﴾</span></span> فعل ماض وفاعله مستتر و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتمها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية والفعل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿على أبويك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتمها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿أبويك﴾</span></span> أو عطف بيان، وإسحاق عطف على إبراهيم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك عليم حكيم﴾</span></span>: إن حرف ناسخ، وربك اسمها، وعليم حكيم خبراها.</p></div>"
  12,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد كان في يوسف وإخوته آيات للسائلين﴾</span></span>: اللام جواب قسم محذوف، وقد حرف تحقيق، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿في يوسف﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿إخوته﴾</span></span> عطف على يوسف، وآيات اسم كان المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿للسائلين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>.</p></div>"
  12,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قالوا ليوسف وأخوه أحب إلى أبينا منا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> في الآية السابقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> في محل جر مضاف إليه، واللام للابتداء، و<span class="hlt"><span class="qpc-hafs">﴿أخوه﴾</span></span> عطف على يوسف، و<span class="hlt"><span class="qpc-hafs">﴿أحب﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿إلى أبينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونحن عصبة إن أبانا لفي ضلال مبين﴾</span></span>: الواو للحال، ونحن مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عصبة﴾</span></span> خبر، وإن حرف ناسخ، وأبانا اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، ومبين صفة.</p></div>"
  12,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اقتلوا يوسف أو اطرحوه أرضا يخل لكم وجه أبيكم﴾</span></span>: اقتلوا فعل أمر، والواو فاعل، ويوسف مفعول به، <span class="hlt"><span class="qpc-hafs">﴿أو اطرحوه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اقتلوا﴾</span></span>، وأرضًا نصبت بنزع الخافض، أي: في أرض، و<span class="hlt"><span class="qpc-hafs">﴿يخل﴾</span></span> جواب الأمر، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وجه﴾</span></span> فاعل، وأبيكم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتكونوا من بعده قوما صالحين﴾</span></span>: الواو عاطفة، وتكونوا عطف على <span class="hlt"><span class="qpc-hafs">﴿يخل﴾</span></span>، والواو اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وقومًا خبر، وصالحين صفة.</p></div>"
  12,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قائل منهم لا تقتلوا يوسف وألقوه في غيابت الجب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال قائل﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تقتلوا﴾</span></span> فعل مضارع مجزوم بلا، والواو فاعل، ويوسف مفعول به، وألقوه فعل أمر وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في غيابة الجب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يلتقطه بعض السيارة إن كنتم فاعلين﴾</span></span>: يلتقطه جواب الأمر مجزوم، والضمير في محل نصب مفعول به، وبعض السيارة فاعل، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وفاعلين خبرها، وجواب إن محذوف دل عليه ما قبله.</p></div>"
  12,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أبانا ما لك لا تأمنا على يوسف﴾</span></span>: قالوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا أبانا﴾</span></span> منادى مضاف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، ولا نافية، وتأمنا فعل مضارع، وفاعله مستتر تقديره: أنت، ونا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على يوسف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأمنا﴾</span></span>، وجملة لا تأمنا حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا أبانا﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تأمنا﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا له لناصحون﴾</span></span>: الواو للحال، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناصحون﴾</span></span>، واللام المزحلقة، وناصحون خبر <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>، والجملة حال من <span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿تأمنا﴾</span></span>.</p></div>"
  12,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أرسله معنا غدا يرتع ويلعب وإنا له لحافظون﴾</span></span>: أرسله فعل أمر، وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿معنا﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿غدًا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسله﴾</span></span> أيضًا، ويرتع مجزوم لأنه جواب الأمر، ويلعب عطف عليه، و<span class="hlt"><span class="qpc-hafs">﴿إنا له لحافظون﴾</span></span> الواو للحال، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حافظون﴾</span></span>، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿حافظون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>، والجملة حال من <span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿معنا﴾</span></span>.</p></div>"
  12,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إني ليحزنني أن تذهبوا به﴾</span></span>: إن حرف ناسخ، والياء اسمها، واللام المزحلقة، وجملة يحزنني خبر إن، والياء مفعول به، وأن وما في حيزها في تأويل مصدر فاعل <span class="hlt"><span class="qpc-hafs">﴿يحزنني﴾</span></span>، وبه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذهبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخاف أن يأكله الذئب﴾</span></span>: أن وما في حيزها مفعول <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، والذئب فاعل <span class="hlt"><span class="qpc-hafs">﴿يأكله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنتم عنه غافلون﴾</span></span>: الواو للحال، وأنتم مبتدأ، وغافلون خبره، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافلون﴾</span></span>.</p></div>"
  12,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لئن أكله الذئب ونحن عصبة إنا إذا لخاسرون﴾</span></span>: اللام موطئة للقسم، وإن شرطية، وأكله الذئب فعل ومفعول به وفاعل، والواو حالية، ونحن مبتدأ، وعصبة خبر، والجملة حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جواب وجزاء مهمل، و<span class="hlt"><span class="qpc-hafs">﴿خاسرون﴾</span></span> خبر إن، والجملة جواب القسم، وجملة جواب الشرط محذوفة.</p></div>"
  12,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما ذهبوا به وأجمعوا أن يجعلوه في غيابت الجب﴾</span></span>: الفاء عاطفة، ولما حينية أو رابطة، وذهبوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذهبوا﴾</span></span>، وأجمعوا عطف على ذهبوا، أو الواو للحال، والجملة حالية بتقدير: قد، وأن وما في حيزها مفعول <span class="hlt"><span class="qpc-hafs">﴿أجمعوا﴾</span></span>، أو منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿في غيابة الجب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجعلوه﴾</span></span>، وجواب لما محذوف تقديره: فعلوا به ما فعلوه من الأذى.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إليه لتنبئنهم بأمرهم هذا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، واللام واقعة في جواب قسم مقدر، وتنبئنهم فعل مضارع مبني على الفتح، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بأمرهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنبئنهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أمرهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يشعرون﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون خبر، والجملة حالية.</p></div>"
  12,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءوا أباهم عشاء يبكون﴾</span></span>: الواو عاطفة، وجاءوا فعل وفاعل، وأباهم مفعول به، وعشاء ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبكون﴾</span></span> حال من الواو.</p></div>"
  12,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أبانا إنا ذهبنا نستبق﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿إنا ذهبنا﴾</span></span> مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة ذهبنا خبر إن، وجملة نستبق حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا يوسف عند متاعنا فأكله الذئب﴾</span></span>: الواو عاطفة، وتركنا يوسف عطف على <span class="hlt"><span class="qpc-hafs">﴿ذهبنا﴾</span></span>، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، فأكله عطف، والهاء مفعول به، والذئب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت بمؤمن لنا ولو كنا صادقين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمؤمن﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مؤمن﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مؤمن﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span> الواو عاطفة، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وصادقين خبرها.</p></div>"
  12,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءوا على قميصه بدم كذب﴾</span></span>: الواو عاطفة، وجاؤوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على قميصه﴾</span></span> محله النصب على الظرفية، كأنه قيل: وجاؤوا فوق قميصه بدم، وهذا الظرف معمول لحال محذوفة من دم، والتقدير: وجاؤوا بدم كذب حال كونه كائنًا فوق قميصه، و<span class="hlt"><span class="qpc-hafs">﴿بدم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءوا﴾</span></span>، وكذب صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال بل سولت لكم أنفسكم أمرا فصبر جميل﴾</span></span>: بل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿سولت لكم أنفسكم﴾</span></span> فعل وفاعل، وأمرًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فصبر جميل﴾</span></span> خبر لمبتدأ محذوف، أو مبتدأ خبره محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله المستعان على ما تصفون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المستعان﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿المستعان﴾</span></span>، وجملة تصفون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: تصفونه.</p></div>"
  12,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءت سيارة فأرسلوا واردهم فأدلى دلوه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب،  وجاءت سيارة فعل وفاعل، فأرسلوا عطف على جاءت، والواو فاعل، وواردهم مفعول به، فأدلى عطف، ودلوه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا بشرى هذا غلام﴾</span></span>: يا حرف نداء، وبشرى منادى نكرة مقصودة، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿غلام﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأسروه بضاعة﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأسروه فعل وفاعل ومفعول.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله عليم بما يعملون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وعليم خبر، <span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span> وما مصدرية، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span> صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وشروه بثمن بخس دراهم معدودة﴾</span></span>: الواو عاطفة، وشروه فعل وفاعل ومفعول، و<span class="hlt"><span class="qpc-hafs">﴿بثمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شروه﴾</span></span>، وبخس صفة، ودراهم بدل من ثمن، ومعدودة صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكانوا فيه من الزاهدين﴾</span></span>: كانوا فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من الزاهدين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كانوا.</p></div>"
  12,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذي اشتراه من مصر لامرأته أكرمي مثواه﴾</span></span>:  الواو عاطفة، وقال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> فاعل، وجملة اشتراه صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من مصر﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿لامرأته﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة أكرمي مثواه مقول القول، وهي فعل وفاعل ومفعول.</p><p><span class="hlt"><span class="qpc-hafs">﴿عسى أن ينفعنا أو نتخذه ولدا﴾</span></span>: عسى من أفعال الرجاء، واسمها مستتر، وأن وما في حيزها خبرها، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ونتخذ فعل مضارع معطوف على <span class="hlt"><span class="qpc-hafs">﴿ينفعنا﴾</span></span>، والهاء مفعول به أول، وولدًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك مكنا ليوسف في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: وتمكينًا مثل ذلك التمكين مكَّنا، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ومكنا فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ليوسف﴾</span></span> جار ومجرور متعلقان به، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنعلمه من تأويل الأحاديث﴾</span></span>: الواو عاطفة، واللام للتعليل، ونعلمه فعل مضارع منصوب بأن مضمرة بعد اللام، والهاء مفعول به، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من تأويل الأحاديث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نعلمه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله غالب على أمره﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وغالب خبر، و<span class="hlt"><span class="qpc-hafs">﴿على أمره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غالب﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس لا يعلمون﴾</span></span>: الواو حالية، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿أكثر الناس﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبرها.</p></div>"
  12,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما بلغ أشده آتيناه حكما وعلما وكذلك نجزي المحسنين﴾</span></span>: لما حينية، أو رابطة، وبلغ أشده فعل ماض وفاعل مستتر ومفعول به، وآتيناه فعل وفاعل ومفعول به، وحكمًا مفعول به ثان، وعلمًا عطف عليه، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: وجزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به.</p></div>"
  12,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وراودته التي هو في بيتها عن نفسه وغلقت الأبواب وقالت هيت لك﴾</span></span>: جمل معطوفة، <span class="hlt"><span class="qpc-hafs">﴿وراودته التي﴾</span></span> فعل ومفعول به وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هو في بيتها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿عن نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودته﴾</span></span>، وغلقت الأبواب معطوفة على راودته، وقالت معطوفة أيضا، و<span class="hlt"><span class="qpc-hafs">﴿هيت﴾</span></span> اسم فعل ماض مبني على الفتح بمعنى: تهيأت، أو اسم فعل أمر بمعنى: أقبل، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف أي: أقول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال معاذ الله إنه ربي أحسن مثواي﴾</span></span>: معاذ الله نصب على المصدر، أي: أعوذ بالله معاذًا، و<span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> إن حرف ناسخ، والهاء اسمها، وربي خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا يفلح الظالمون﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح الظالمون﴾</span></span> خبرها، والضمير يعود للشأن هنا.</p></div>"
  12,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد همت به وهم بها لولا أن رأى برهان ربه﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، وهمت فعل ماض، والفاعل مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿همت﴾</span></span>، وهمّ فعل ماض، وفاعله: هو، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿همّ﴾</span></span>، ولولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ محذوف الخبر، أي: لولا رؤيته برهان ربه ماثلا أمامه، وجواب لولا محذوف، أي: لواقعها.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك لنصرف عنه السوء والفحشاء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: ثبتناه تثبيتًا مثلَ ذلك التثبيت، أو أريناه برهان ربه إراءً مثلَ ذلك الإراء لنصرف عنه السوء، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب. و<span class="hlt"><span class="qpc-hafs">﴿لنصرف﴾</span></span> اللام للتعليل، ونصرف: فعل مضارع منصوب بأن مضمرة بعد اللام، والفاعل مستتر تقديره: نحن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ مجرور باللام، واللام ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ثبتناه﴾</span></span> أو <span class="hlt"><span class="qpc-hafs">﴿أريناه﴾</span></span> المقدر، و<span class="hlt"><span class="qpc-hafs">﴿السوء﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الفحشاء﴾</span></span> عطف على السوء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المخلصين﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والمخلصين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عبادنا﴾</span></span>.</p></div>"
  12,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستبقا الباب وقدت قميصه من دبر﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿استبقا﴾</span></span> فعل ماض، والألف فاعل، والباب منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿قدّت قميصه﴾</span></span> قدّ فعل ماض، وفاعله: هي، وقميصه مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من دبر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو <span class="hlt"><span class="qpc-hafs">﴿قدت﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿واستبقا﴾</span></span>، أو حال، أي: وقد قدت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وألفيا سيدها لدا الباب﴾</span></span>: الواو عاطفة، وألفيا عطف على ما تقدم، والألف فاعل، وسيدها مفعول به، ولدى ظرف في محل نصب مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت ما جزاء من أراد بأهلك سوءا إلا أن يسجن أو عذاب أليم﴾</span></span>: ما اسم استفهام مبتدأ، وجزاء خبر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مضاف إليه، وجملة أراد صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وبـ<span class="hlt"><span class="qpc-hafs">﴿أهلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span>، وسوءًا مفعول به، وإلا أداة حصر، والمصدر المؤول من أن وما في حيزها بدل من جزاء، أي: إلا السجن، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وجزاء مبتدأ، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يسجن﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وعذاب عطف على المصدر المؤول، وأليم صفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول، وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، أو نكرة موصوفة وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p></div>"
  12,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هي راودتني عن نفسي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة راودتني خبر، وعن نفسي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودتني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span></span>: الواو عاطفة، وشهد شاهد فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من أهلها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة <span class="hlt"><span class="qpc-hafs">﴿شاهد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كان قميصه قد من قبل فصدقت وهو من الكاذبين﴾</span></span>: الشرط مقول قول محذوف، أي: فقال، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كان قميصه﴾</span></span> كان فعل ماض ناقص ناسخ، وقميصه اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فصدقت﴾</span></span> الفاء رابطة، وصدقت فعل ماض، والجملة جواب الشرط، أي: فقد ظهر صدقها، <span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  12,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كان قميصه قد من دبر فكذبت وهو من الصادقين﴾</span></span>: عطف على الجملة الأولى، والشرط مقول قول محذوف، أي: وقال، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كان قميصه﴾</span></span> كان فعل ماض ناقص ناسخ، وقميصه اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من دبر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فكذبت﴾</span></span> الفاء رابطة، وكذبت فعل ماض، والجملة جواب الشرط، أي: فقد ظهر كذبها، <span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  12,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأى قميصه قد من دبر قال إنه من كيدكن﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، ورأى قميصه فعل وفاعل مستتر ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد من دبر﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> جواب لما، وإن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من كيدكن﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كيدكن عظيم﴾</span></span>: إن حرف ناسخ، وكيدكن اسمها، وعظيم خبرها.</p></div>"
  12,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوسف أعرض عن هذا واستغفري لذنبك﴾</span></span>: يوسف منادى محذوف منه حرف النداء، وأعرض فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عن هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>، واستغفري فعل أمر، والياء فاعله، و<span class="hlt"><span class="qpc-hafs">﴿لذنبك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استغفري﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك كنت من الخاطئين﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وكنت فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الخاطئين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> خبر إن.</p></div>"
  12,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال نسوة في المدينة﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال نسوة﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في المدينة﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نسوة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿امرأت العزيز تراود فتاها عن نفسه قد شغفها حبا إنا لنراها في ضلال مبين﴾</span></span>: امرأة العزيز مبتدأ، وجملة تراود خبر، وفتاها مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تراود﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، وشغفها فعل وفاعل مستتر ومفعول به، وحبًّا تمييز محول عن الفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد شغفها﴾</span></span> حال من فاعل تراود، أو من مفعوله، أو خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿امرأة﴾</span></span>.</p></div>"
  12,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما سمعت بمكرهن أرسلت إليهن وأعتدت لهن متكأ وآتت كل واحدة منهن سكينا﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، وسمعت فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿بمكرهن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سمعت﴾</span></span>، وجملة أرسلت لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليهن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span>، وأعتدت عطف على أرسلت، و<span class="hlt"><span class="qpc-hafs">﴿لهن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعتدت﴾</span></span>، ومتكأ مفعول به، وآتت عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿كل واحدة﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿آتت﴾</span></span> الأول، و<span class="hlt"><span class="qpc-hafs">﴿منهن﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لواحدة، وسكينًا مفعول آتت الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالت اخرج عليهن﴾</span></span>: الواو عاطفة، وجملة اخرج مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿عليهن﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مطلاًّ عليهن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأينه أكبرنه وقطعن أيديهن﴾</span></span>: الفاء عاطفة، ولما ظرفية حينية، أو رابطة حرفية، ورأينه فعل وفاعل ومفعول به، وقطعن فعل وفاعل، وأيديهن مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقلن﴾</span></span>: فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿حاش﴾</span></span>: نائب مفعول مطلق، أي: تنزيها لله.</p><p><span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: جار ومجرور متعلقان بمحذوف تقديره أعني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما هذا بشرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بشرًا﴾</span></span> خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا إلا ملك كريم﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، وإلا أداة حصر، وملك خبر، وكريم صفة.</p></div>"
  12,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت فذلكن الذي لمتنني فيه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فذلك﴾</span></span> الفاء الفصيحة، واسم الإشارة مبتدأ، والذي خبر لمبتدأ محذوف، أي: هو الذي، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لمتنني﴾</span></span>، أي: من حبه، أو مراودته، وجملة <span class="hlt"><span class="qpc-hafs">﴿لمتنني﴾</span></span> صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولقد راودته عن نفسه فاستعصم﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وراودته فعل وفاعل ومفعول به، وعن نفسه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودته﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاستعصم﴾</span></span> الفاء عاطفة، واستعصم فعل ماض.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن لم يفعل ما آمره ليسجنن وليكونا من الصاغرين﴾</span></span>: اللام موطئة للقسم، وإن شرطية، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span> مضارع مجزوم، وهو فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به، وجملة آمره صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والضمير في <span class="hlt"><span class="qpc-hafs">﴿آمره﴾</span></span> عائد على الموصول، أي: ما آمر به، فحذف الجار كما حذف في أمرتك الخير، ومفعول <span class="hlt"><span class="qpc-hafs">﴿آمر﴾</span></span> الأول محذوف، وكان التقدير: ما آمره به، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: أمري، والضمير يعود على يوسف، أي: أمري إياه، ومعناه: موجب أمري، اللام واقعة في جواب القسم، وجواب الشرط محذوف دلّ عليه جواب القسم المذكور، والتقدير: ليسجنن وليكونن، وفي <span class="hlt"><span class="qpc-hafs">﴿يسجنن﴾</span></span> نون التوكيد الثقيلة، وفي <span class="hlt"><span class="qpc-hafs">﴿يكونن﴾</span></span> نون التوكيد الخفيفة، واسم يكون مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من الصاغرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  12,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب السجن أحب إلي مما يدعونني إليه﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ورب منادى محذوف منه حرف النداء، والسجن مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أحب﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿إليّ﴾</span></span> للتبيين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحب﴾</span></span>، وجملة يدعونني صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وهو فعل مضارع مبني على السكون على الواو، والنون الأولى نون النسوة، والثانية نون الوقاية، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعونني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإلا تصرف عني كيدهن أصب إليهن وأكن من الجاهلين﴾</span></span>: الواو عاطفة، وإن شرطية، ولا نافية، وتصرف فعل الشرط، والفاعل مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عني﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تصرف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كيدهن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أصب﴾</span></span> جواب الشرط، والفاعل مستتر، وتقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿إليهن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أصب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أكن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أصب﴾</span></span>، واسم <span class="hlt"><span class="qpc-hafs">﴿أكن﴾</span></span> مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿من الجاهلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿أكن﴾</span></span>.</p></div>"
  12,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستجاب له ربه فصرف عنه كيدهن﴾</span></span>: الفاء عاطفة، واستجاب فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان به، وربه فاعل، <span class="hlt"><span class="qpc-hafs">﴿فصرف﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فاستجاب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرف﴾</span></span>، وكيدهن مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو السميع العليم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والسميع العليم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، والسميع العليم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  12,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات ليسجننه حتى حين﴾</span></span>: ثم حرف عطف، وبدا فعل ماض، وفاعله مضمر يدل عليه <span class="hlt"><span class="qpc-hafs">﴿ليسجننه﴾</span></span>، أي: بدا لهم أن يسجنوه، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بدا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> حال، وما مصدرية، وهي مع ما في حيزها مصدر مجرور بإضافة الظرف إليه، و<span class="hlt"><span class="qpc-hafs">﴿رأوا﴾</span></span> فعل وفاعل، والآيات مفعول به، <span class="hlt"><span class="qpc-hafs">﴿ليسجننه﴾</span></span> اللام جواب قسم محذوف على تقدير القول المنصوب على الحال، أي: ظهر لهم من بعد ما رأوا الآيات قائلين: والله لنسجننه، فجملة القسم وما بعده مقول القول، ويسجننه فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، والواو المحذوفة فاعل، والنون المشددة نون التوكيد الثقيلة، والهاء مفعول به منصوب، وحتى حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span> مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسجننه﴾</span></span>.</p></div>"
  12,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ودخل معه السجن فتيان﴾</span></span>: الواو عاطفة على محذوف، ودخل فعل، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿دخل﴾</span></span>، والسجن مفعول به على السعة، وفتيان فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال أحدهما إني أراني أعصر خمرا﴾</span></span>: قال فعل، وأحدهما فاعل، والجملة استئناف بياني لا محل لها من الإعراب، وإن حرف ناسخ، والياء اسمها، وجملة أراني خبرها، والياء مفعول أراني الأول، وجملة أعصر خمرًا في محل المفعول الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني أراني﴾</span></span> مقول قول.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال الآخر إني أراني أحمل فوق رأسي خبزا تأكل الطير منه﴾</span></span>: الواو عاطفة، وقال الآخر فعل وفاعل، وإن حرف ناسخ، والياء اسمها، وجملة أراني خبرها، وجملة أحمل مفعول أراني الثاني، وفوق رأسي ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أحمل﴾</span></span>، أو بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿خبزًا﴾</span></span>، لأنه كان في الأصل صفة له، وخبزًا مفعول به، وجملة تأكل الطير منه صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خبزًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نبئنا بتأويله﴾</span></span>: فعل أمر، ونا مفعوله، والفاعل مستتر تقديره: أنت، وبتأويله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبئنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا نراك من المحسنين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نراك خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من المحسنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نراك﴾</span></span>.</p></div>"
  12,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا يأتيكما طعام ترزقانه إلا نبأتكما بتأويله قبل أن يأتيكما ذلكما مما علمني ربي﴾</span></span>: لا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يأتيكما طعام﴾</span></span> فعل مضارع ومفعول به وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترزقانه﴾</span></span> صفة لطعام، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿نبأتكما﴾</span></span> فعل وفاعل ومفعول به، وأن وما في حيزها مصدر مجرور بإضافة الظرف إليه، وجملة إلا نبأتكما نعت لطعام، أو حال منه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني تركت ملة قوم لا يؤمنون بالله وهم بالآخرة هم كافرون﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة تركت خبرها، وملة قوم مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> صفة لقوم، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وبالآخرة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وكافرون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني تركت﴾</span></span> استئنافية أو تعليلية لا محل لها من الإعراب.</p></div>"
  12,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتبعت ملة آبائي إبراهيم وإسحاق ويعقوب﴾</span></span>: الواو عاطفة، واتبعت عطف على تركت، والتاء فاعله، وملة آبائي مفعول به، وإبراهيم بدل من آبائي، وإسحاق ويعقوب عطف على إبراهيم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كان لنا أن نشرك بالله من شيء﴾</span></span>: ما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> خبرها المقدم، وإن وما في حيزها اسمها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نشرك﴾</span></span>، ومن حرف صلة، وشيء مجرور لفظًا مفعول به منصوب محلاًّ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك من فضل علينا وعلى الناس﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من فضل الله﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على الناس﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس لا يشكرون﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، وأكثر الناس اسمها، وجملة لا يشكرون خبرها.</p></div>"
  12,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا صاحبي السجن أأرباب متفرقون خير أم الله الواحد القهار﴾</span></span>: يا حرف نداء، وصاحبي السجن منادى مضاف وعلامة نصبه الياء، والسجن مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿أأرباب﴾</span></span> الهمزة للاستفهام التقريري، وأرباب مبتدأ، ومتفرقون صفة، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، وهي هنا متصلة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> عطف على أرباب، والواحد صفة، القهار صفة ثانية.</p></div>"
  12,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما تعبدون من دونه إلا أسماء سميتموها أنتم وآباؤكم﴾</span></span>: ما نافية، وتعبدون فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وإلا أداة حصر، وأسماء مفعول به، وجملة سميتموهما صفة، والتاء فاعل، وأنتم تأكيد للتاء، وآباؤكم عطف على التاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما أنزل الله بها من سلطان﴾</span></span>: ما نافية، وأنزل الله فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، ومن حرف صلة، وسلطان مجرور لفظًا مفعول به منصوب محلاًّ، والجملة نعت أو حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الحكم إلا لله أمر ألا تعبدوا إلا إياه﴾</span></span>: إن نافية، والحكم مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر الحكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمر...﴾</span></span> مستأنفة لا محل لها من الإعراب، وأن مصدرية، ولا نافية، وتعبدوا فعل مضارع منصوب بأن، وأن وما بعدها في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمر﴾</span></span>، أي: أمركم بأن لا تعبدوا، وإلا أداة حصر، وإياه مفعول تعبدوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك الدين القيم﴾</span></span>: ذلك مبتدأ، والدين خبر، والقيم صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس لا يعلمون﴾</span></span>: الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو حالية والجملة بعدها في محل نصب حال، ولكن حرف ناسخ، وأكثر الناس اسمها، وجملة لا يعلمون خبرها.</p></div>"
  12,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا صاحبي السجن أما أحدكما فيسقي ربه خمرا﴾</span></span>:  يا حرف نداء، وصاحبي السجن منادى مضاف وعلامة نصبه الياء، والسجن مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span> حرف شرط وتفصيل، وأحدكما مبتدأ، والفاء رابطة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسقي﴾</span></span> خبر أحدكما، وربه مفعول به أول، وخمرًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأما الآخر فيصلب فتأكل الطير من رأسه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وأما الآخر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span> الأولى، والآخر مبتدأ، والفاء رابطة، وجملة يصلب خبر، <span class="hlt"><span class="qpc-hafs">﴿فتأكل الطير﴾</span></span> الفاء عاطفة، وتأكل عطف على يصلب، والطير فاعل تأكل، ومن رأسه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قضي الأمر الذي فيه تستفتيان﴾</span></span>: قضي الأمر فعل ماض مبني لما لم يسمَّ فاعله، والأمر نائب فاعل، والذي صفة للأمر، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستفتيان﴾</span></span>.</p></div>"
  12,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال للذي ظن أنه ناج منهما اذكرني عند ربك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وقال﴾</span></span> عطف على ما قبله، وفاعله: يوسف، و<span class="hlt"><span class="qpc-hafs">﴿للذي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظن﴾</span></span> صلة الذي لا محل لها من الإعراب، وفاعل <span class="hlt"><span class="qpc-hafs">﴿ظن﴾</span></span> يوسف أيضًا، وأن وما في حيزها سدت مسد مفعولي ظن، وأن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ناج﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿منهما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حال كون الناجي من جملة الاثنين، وهو الساقي، وجملة اذكرني مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿عند ربك﴾</span></span> ظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنساه الشيطان ذكر ربه فلبث في السجن بضع سنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأنساه الشيطان﴾</span></span> الفاء عاطفة، وأنساه فعل ومفعول به، والضمير يعود إلى الساقي، والشيطان فاعل، وذكر مفعول به ثان، <span class="hlt"><span class="qpc-hafs">﴿فلبث﴾</span></span> الفاء عاطفة، ولبث فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿في السجن﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وبضع سنين نصب على الظرفية متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>.</p></div>"
  12,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الملك إني أرى سبع بقرات سمان يأكلهن سبع عجاف﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة أرى خبرها، وسبع بقرات مفعول به، وسمان صفة لبقرات، و<span class="hlt"><span class="qpc-hafs">﴿يأكلهن سبع﴾</span></span> فعل مضارع ومفعول به وفاعل، وعجاف صفة لسبع، وجملة يأكلهن في محل نصب حال أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بقرات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبع سنبلات خضر وأخر يابسات﴾</span></span>: الواو عاطفة، وسبع عطف على سبع الأولى، وسنبلات مضاف إليه، وخضر صفة لسنبلات، و<span class="hlt"><span class="qpc-hafs">﴿أخر﴾</span></span> عطف على سبع، ويابسات صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أخر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الملأ أفتوني في رؤياي إن كنتم للرؤيا تعبرون﴾</span></span>: أفتوني فعل أمر مبني على حذف النون، والواو فاعل، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في رؤياي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفتوني﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وهي في محل جزم فعل الشرط، وجملة تعبرون خبر كنتم، والجواب محذوف دل عليه ما قبله، أي: فأفتوني في رؤياي، وقوله: <span class="hlt"><span class="qpc-hafs">﴿للرؤيا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو خبر كنتم، وجملة تعبرون خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>.</p></div>"
  12,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أضغاث أحلام وما نحن بتأويل الأحلام بعالمين﴾</span></span>: قالوا فعل وفاعل، وأضغاث أحلام خبر لمبتدأ محذوف، أي: هذه أضغاث أحلام، والجملة مقول القول، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بتأويل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عالمين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأحلام﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بعالمين﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿عالمين﴾</span></span> مجرور بالباء لفظًا منصوب محلا على أنه خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> العاملة عمل ليس.</p></div>"
  12,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذي نجا منهما وادكر بعد أمة﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الذي﴾</span></span> فعل وفاعل، وجملة نجا صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿منهما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وادكر عطف على نجا، و<span class="hlt"><span class="qpc-hafs">﴿بعد أمة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ادكر﴾</span></span>، أو الواو حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿ادكر﴾</span></span> حالية من الموصول، أو من عائده، أي: فاعل نجا.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنا أنبئكم بتأويله فأرسلون﴾</span></span>: أنا مبتدأ، وجملة أنبئكم خبر، والكاف مفعوله، و<span class="hlt"><span class="qpc-hafs">﴿بتأويله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبئكم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فأرسلون﴾</span></span> الفاء الفصيحة، وأرسلوني فعل وأمر وفاعل ومفعول به، أي: إن شئتم تعبير الرؤيا فأرسلوني.</p></div>"
  12,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوسف أيها الصديق أفتنا في سبع بقرات سمان يأكلهن سبع عجاف وسبع سنبلات خضر وأخر يابسات﴾</span></span>: يوسف منادى محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿أيها﴾</span></span> منصوب محلاًّ على الاختصاص، لأنه مبني على الضم، والصديق صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، أو عطف بيان له تابع على اللفظ، و<span class="hlt"><span class="qpc-hafs">﴿أفتنا﴾</span></span> فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره: أنت، ونا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في سبع﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفتنا﴾</span></span>، وبقرات مضاف إليه، وجملة يأكلهن سبع عجاف في محل نصب حال أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بقرات﴾</span></span>، وما بعده عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلي أرجع إلى الناس لعلهم يعلمون﴾</span></span>: لعل حرف ناسخ، والياء اسمها، وجملة أرجع خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى الناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرجع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لعلهم يعلمون﴾</span></span> مثلها.</p></div>"
  12,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال تزرعون سبع سنين دأبا﴾</span></span>: جملة تزرعون مقول القول، وسبع سنين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تزرعون﴾</span></span>، ودأبًا حال من المأمورين، أي: دائبين، أو مصدر لفعل محذوف، أي: تدأبون دأبًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما حصدتم فذروه في سنبله إلا قليلا مما تأكلون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> شرطية أو موصولة، وهي على الحالين في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿حصدتم﴾</span></span>، وحصدتم فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿فذروه﴾</span></span> الفاء واقعة في جواب الشرط، أو الموصول، لما فيه من رائحة الشرط، وذروه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في سنبله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذروه﴾</span></span>، وإلا أداة استثناء، وقليلًا مستثنى واجب النصب، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قليلًا﴾</span></span>، وجملة تأكلون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم يأتي من بعد ذلك سبع شداد﴾</span></span>: ثم حرف عطف وتراخ، <span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿من بعد ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وسبع فاعل يأتي، وشداد صفة لسبع.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأكلن ما قدمتم لهن إلا قليلا مما تحصنون﴾</span></span>: جملة يأكلن صفة ثانية لسبع، والنون فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة قدمتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لهن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدمتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿قليلًا﴾</span></span> مستثنى، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قليلًا﴾</span></span>، وجملة تحصنون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم يأتي من بعد ذلك عام فيه يغاث الناس وفيه يعصرون﴾</span></span>: عطف على ما سبق، وجملة <span class="hlt"><span class="qpc-hafs">﴿فيه يغاث الناس﴾</span></span> متعلقة بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عام﴾</span></span>، ويعصرون عطف على <span class="hlt"><span class="qpc-hafs">﴿يغاث﴾</span></span>، أي: يعصرون الأعناب وغيرها.</p></div>"
  12,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الملك ائتوني به فلما جاءه الرسول﴾</span></span>: معطوف على محذوف، أي: لما جاءه الرسول وأخبره بتأويلها فقال الملك، وجملة <span class="hlt"><span class="qpc-hafs">﴿ائتوني به﴾</span></span> مقول القول، <span class="hlt"><span class="qpc-hafs">﴿فلما﴾</span></span> الفاء عاطفة، ولما حينية ظرفية، أو رابطة، وجاءه الرسول فعل ومفعول به مقدم وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال ارجع إلى ربك فاسأله ما بال النسوة اللاتي قطعن أيديهن﴾</span></span>: ارجع فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ارجع﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاسأله﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿ارجع﴾</span></span>، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بال﴾</span></span> خبر، والجملة في محل نصب مفعول <span class="hlt"><span class="qpc-hafs">﴿اسأله﴾</span></span> المعلقة عن العمل بالاستفهام، والنسوة مضاف إليه، واللاتي موصول صفة، وجملة قطعن أيديهن صلة <span class="hlt"><span class="qpc-hafs">﴿اللاتي﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي بكيدهن عليم﴾</span></span>: إن حرف ناسخ، وربي اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بكيدهن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span>، وعليم خبر إن.</p></div>"
  12,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ما خطبكن إذ راودتن يوسف عن نفسه﴾</span></span>: ما اسم استفهام مبتدأ، وخطبكن خبر، وإذ ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خطبكن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿راودتن﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿راودتن﴾</span></span> فعل وفاعل، ويوسف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودتن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قلن﴾</span></span>: فعل ماض، والضمير في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿حاش﴾</span></span>: نائب مفعول مطلق، أي: تنزيها لله.</p><p><span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: جار ومجرور متعلقان بمحذوف تقديره أعني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما علمنا عليه من سوء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية. و<span class="hlt"><span class="qpc-hafs">﴿علمنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علمنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، وسوء مجرور لفظًا بمن منصوب محلاًّ على أنه مفعول علمنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت امرأت العزيز الآن حصحص الحق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالت امرأة العزيز﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿الآن﴾</span></span> ظرف زمان متعلق بحصحص، والحق فاعل حصحص.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنا راودته عن نفسه﴾</span></span>: أنا مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿راودته﴾</span></span> فعل وفاعل ومفعول به في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿عن نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودته﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لمن الصادقين﴾</span></span>: الواو حرف عطف، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إنه.</p></div>"
  12,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك ليعلم أني لم أخنه بالغيب وأن الله لا يهدي كيد الخائنين﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ليعلم﴾</span></span> اللام للتعليل، ويعلم مضارع منصوب بأن مضمرة بعد لام التعليل، والجار والمجرور متعلقان بمحذوف خبر، أو <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> خبر لمبتدأ محذوف، أي: فالأمر ذلك، وأن وما بعدها في تأويل مصدر سد مسد مفعولي يعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم أخنه﴾</span></span> خبر أني، و<span class="hlt"><span class="qpc-hafs">﴿بالغيب﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل أو المفعول، أو ظرف، أي: بمكان الغيب، فيعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أخنه﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وأن الله﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أني﴾</span></span>، وجملة يهدي خبر أن، وكيد الخائنين مفعول به.</p></div>"
  12,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أبرئ نفسي إن النفس لأمارة بالسوء إلا ما رحم ربي﴾</span></span>: الواو حالية، وما نافية، وأبرئ نفسي فعل مضارع وفاعل مستتر ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿وإن النفس﴾</span></span> إن حرف ناسخ، والنفس اسمها، واللام المزحلقة، وأمارة بالسوء خبرها، وإلا أداة استثناء، وما مصدرية وموضعها النصب على الظرفية، والتقدير: إن النفس لأمارة بالسوء إلا مدة رحمة ربي، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> بمعنى مَن، والتقدير: إن النفس لتأمر بالسوء إلا لمن رحم ربي، أو: إلا نفسًا رحمها ربي فإنها لا تأمر بالسوء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي غفور رحيم﴾</span></span>: إن حرف ناسخ، وربي اسمها، وغفور رحيم خبراها.</p></div>"
  12,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الملك ائتوني به أستخلصه لنفسي﴾</span></span>: عطف على ما تقدم، وقال الملك فعل وفاعل، وجملة ائتوني به مقول القول، وأستخلصه فعل مضارع مجزوم، لأنه وقع جوابًا للأمر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما كلمه﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرف حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿كلمه﴾</span></span> فعل وفاعل مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إنك اليوم لدينا مكين أمين﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> لا محل لها من الإعراب، وإن حرف ناسخ، والكاف اسمها، واليوم ظرف متعلق بمحذوف حال، ولدينا ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مكين﴾</span></span>، ومكين خبر إن، وأمين خبر ثان.</p></div>"
  12,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال اجعلني على خزائن الأرض﴾</span></span>: اجعلني فعل أمر، والنون للوقاية، والفاعل مستتر تقديره: أنت، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على خزائن الأرض﴾</span></span> جار ومجرور متعلقان بمفعول ثان تقديره: قيمًا، أي: قيمًا على خزائن الأرض.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني حفيظ عليم﴾</span></span>: إن حرف ناسخ، والياء اسمها، وحفيظ خبرها، وعليم خبرها الثاني.</p></div>"
  12,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك مكنا ليوسف في الأرض يتبوأ منها حيث يشاء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: وتمكينًا مثلَ ذلك التمكين الظاهر مكَّنا، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿مكنا﴾</span></span> فعل وفاعل، واللام ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكنا﴾</span></span>، ومفعول مكنا محذوف، أي: الأمور، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتبوأ﴾</span></span> حالية من يوسف، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتبوأ﴾</span></span>، وحيث ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿يتبوأ﴾</span></span>، أو مفعول به له، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يشاء﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿نصيب برحمتنا﴾</span></span>: جملة استئنافية لا محل لها من الإعراب، ونصيب فعل مضارع مرفوع، والفاعل مستتر تقديره: نحن، وبرحمتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نصيب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span>: فعل وفاعل، والجملة منهما صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا نضيع﴾</span></span>: عطف على نصيب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أجر المحسنين﴾</span></span>: مفعول به.</p></div>"
  12,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولأجر الآخرة خير للذين آمنوا وكانوا يتقون﴾</span></span>: اللام لام الابتداء، وأجر مبتدأ، والآخرة مضاف إليه، وخير خبر <span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وجملة آمنوا صلة الذين لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وكانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتقون﴾</span></span> خبرها.</p></div>"
  12,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء إخوة يوسف فدخلوا عليه﴾</span></span>: الكلام معطوف على كلام سابق يفهم من سياق القصة، وجاء إخوة يوسف فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿فدخلوا عليه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاء إخوة يوسف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فعرفهم وهم له منكرون﴾</span></span>: الفاء عاطفة، وعرفهم فعل وفاعل مستتر ومفعول به، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منكرون﴾</span></span>، ومنكرون خبر.</p></div>"
  12,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جهزهم بجهازهم قال ائتوني بأخ لكم من أبيكم﴾</span></span>: الواو عاطفة، والكلام معطوف على مقدر يفهم من سياق الحوار، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حينية، أو رابطة، وجهزهم فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بجهازهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جهزهم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وقال﴾</span></span> جملة لا محل لها من الإعراب، لأنها جواب لما، و<span class="hlt"><span class="qpc-hafs">﴿ائتوني﴾</span></span> فعل أمر وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ائتوني﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بأخ﴾</span></span> جار ومجرور متعلقان به، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أبيكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة ثانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا ترون أني أوفي الكيل﴾</span></span>: الهمزة للاستفهام، ولا نافية، وترون فعل مضارع مرفوع بثبوت النون، والواو فاعل، وأن وما بعدها سدت مسد مفعولي ترون، وجملة أوفي الكيل خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا خير المنزلين﴾</span></span>: الواو عاطفة، وأنا مبتدأ، وخير المنزلين خبر.</p></div>"
  12,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن لم تأتوني به فلا كيل لكم عندي ولا تقربون﴾</span></span>: الفاء عاطفة، وإن شرطية، ولم حرف نفي وقلب وجزم، وتأتوني فعل الشرط مجزوم بلم، والفاء رابطة، ولا نافية للجنس، وكيل اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عندي﴾</span></span> ظرف متعلق بمحذوف حال، والواو عاطفة، ولا ناهية، وتقربون فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> وعلامة جزمه حذف النون، وهذه النون نون الوقاية، وحذفت ياء المتكلم تخفيفًا، وياء المتكلم المحذوفة مفعول تقربون. أو <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، وتقربون مضارع مجزوم عطفًا على محل قوله: <span class="hlt"><span class="qpc-hafs">﴿فلا كيل لكم﴾</span></span> وهو الجزم لأنه جواب الشرط، كأنه قيل: فإن لم تأتوني تُحرموا ولا تقربوا.</p></div>"
  12,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا سنراود عنه أباه وإنا لفاعلون﴾</span></span>: جملة سنراود مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نراود﴾</span></span>، وأباه مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وإنا﴾</span></span> من عطف الجمل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وفاعلون خبر إن.</p></div>"
  12,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال لفتيانه اجعلوا بضاعتهم في رحالهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لفتيانه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة اجعلوا مقول القول، وبضاعتهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في رحالهم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلهم يعرفونها إذا انقلبوا إلى أهلهم﴾</span></span>: لعل حرف ناسخ، والهاء اسمها، وجملة يعرفونها خبر لعل، وإذا ظرف لما يستقبل من الزمن وهو مضاف، وجملة انقلبوا في محل جر بإضافة الظرف إليها، والجواب محذوف، أي: فلعلهم يرجعون، و<span class="hlt"><span class="qpc-hafs">﴿إلى أهلهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انقلبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلهم يرجعون﴾</span></span>: لعل حرف ناسخ، والهاء اسمها، وجملة يرجعون خبرها.</p></div>"
  12,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما رجعوا إلى أبيهم قالوا يا أبانا منع منا الكيل﴾</span></span>: الفاء حرف عطف، ولما حينية، أو رابطة، ورجعوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى أبيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجعوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أبانا﴾</span></span> منادى مضاف، و<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span>، والكيل نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأرسل معنا أخانا نكتل وإنا له لحافظون﴾</span></span>: الفاء الفصيحة، وأرسل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿معنا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>، وأخانا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿نكتل﴾</span></span> مضارع مجزوم في جواب الطلب، <span class="hlt"><span class="qpc-hafs">﴿وإنا﴾</span></span> الواو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حافظون﴾</span></span>، واللام مزحلقة، وحافظون خبر إن، والجملة حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿نكتل﴾</span></span>.</p></div>"
  12,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هل آمنكم عليه إلا كما أمنتكم على أخيه من قبل﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وهي جواب سؤال مقدر، <span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، وآمنكم فعل مضارع وفاعل مستتر ومفعول، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنكم﴾</span></span>، وإلا أداة حصر، <span class="hlt"><span class="qpc-hafs">﴿كما أمنتكم﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: إلا أمنًا مثلَ أمني إياكم، أي: إلا ائتمانا مثل ائتماني إياكم على أخيه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿أمنتكم﴾</span></span> فعل ماض، والتاء فاعل، والكاف مفعول به، والميم علامة الجمع، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمنتكم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية والفعل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿على أخيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمنتكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: من قبل هذا الزمان.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالله خير حافظا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، وحافظًا تمييز، أو حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو أرحم الراحمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأرحم الراحمين خبر.</p></div>"
  12,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما فتحوا متاعهم وجدوا بضاعتهم ردت إليهم﴾</span></span>: لما حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿فتحوا متاعهم﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿وجدوا بضاعتهم﴾</span></span> فعل وفاعل ومفعول به، وجملة ردت إليهم في محل نصب مفعول وجدوا الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أبانا ما نبغي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا أبانا﴾</span></span> منادى مضاف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿نبغي﴾</span></span>، أي: أي شيء نبغي ونطلب من الكرامة؟ هذه أموالنا ردت إلينا، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، أي: ما بقي لنا ما نطلب.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذه بضاعتنا ردت إلينا﴾</span></span>: هذه مبتدأ، وبضاعتنا خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ردت إلينا﴾</span></span> حالية، أو <span class="hlt"><span class="qpc-hafs">﴿بضاعتنا﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ردت إلينا﴾</span></span> خبر، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك كيل يسير﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كيل﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿يسير﴾</span></span> صفة.</p></div>"
  12,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لن أرسله معكم حتى تؤتون موثقا من الله﴾</span></span>: لن حرف نفي ونصب واستقبال، وأرسله مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، وفاعل مستتر ومفعول، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسله﴾</span></span>، وحتى حرف غاية وجر، وتؤتوني فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مضمرة، والنون للوقاية، وياء المتكلم مفعول به أول، وموثقًا مفعول به ثان، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بأرسله، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿موثقا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتأتنني به إلا أن يحاط بكم﴾</span></span>: اللام واقعة في جواب القسم المدلول عليه بقوله: <span class="hlt"><span class="qpc-hafs">﴿موثقًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تأتنني﴾</span></span> مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين فاعل، والياء مفعول به، والنون المشددة للتوكيد، والنون الثالثة نون الوقاية، وإلا أداة استثناء، وأن وما في حيزها استثناء مفرغ من أعم الأحوال، أي: لتأتنني به على كل حال إلا حال الإحاطة بكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما آتوه موثقهم قال الله على ما نقول وكيل﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حينية أو رابطة، وآتوه فعل وفاعل ومفعول به أول، وموثقهم مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على ما نقول﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وكيل﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿الله على ما ...﴾</span></span> في محل نصب مقول القول.</p></div>"
  12,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال يا بني لا تدخلوا من باب واحد﴾</span></span>: يا حرف نداء، وبني منادى مضاف وعلامة نصبه الياء، لأنه ملحق بجمع المذكر السالم، ولا ناهية، وتدخلوا فعل مضارع مجزوم بلا، و<span class="hlt"><span class="qpc-hafs">﴿من باب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدخلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿واحد﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وادخلوا من أبواب متفرقة وما أغني عنكم من الله من شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ادخلوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من أبواب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادخلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متفرقة﴾</span></span> صفة، و<span class="hlt"><span class="qpc-hafs">﴿ما أغني﴾</span></span> ما نافية، وأغني فعل مضارع، وفاعله مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿عنكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span> مجرور لفظًا منصوب محلًّا على أنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الحكم إلا لله عليه توكلت وعليه فليتوكل المتوكلون﴾</span></span>: إن نافية، والحكم مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وعليه﴾</span></span> عطف جملة على جملة، و<span class="hlt"><span class="qpc-hafs">﴿فليتوكل﴾</span></span> اللام لام الأمر، ويتوكل فعل مضارع مجزوم بلام الأمر، والمتوكلون فاعل.</p></div>"
  12,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما دخلوا من حيث أمرهم أبوهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرف حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿حيث﴾</span></span> ظرف مبني على الضم في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من حيث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>، والمعنى: متفرقين، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمرهم أبوهم﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كان يغني عنهم من الله من شيء﴾</span></span>: ما نافية، وكان فعل ماض ناقص ناسخ، واسمها ضمير مستتر يعود على تفرقهم، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، وشيء مجرور لفظًا منصوب محلًّا على أنه مفعول به، وجواب لما محذوف دل عليه معنى الجملة المنفية تقديره: أصابهم ما أصابهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا حاجة في نفس يعقوب قضاها﴾</span></span>: استثناء منقطع على معنى: ولكن حاجة في نفس يعقوب قضاها، و<span class="hlt"><span class="qpc-hafs">﴿في نفس﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، ويعقوب مضاف إليه، وجملة قضاها صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حاجة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لذو علم لما علمناه﴾</span></span>: الواو للحال، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وذو علم خبر إن، وجملة علمناه صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس لا يعلمون﴾</span></span>: الواو حالية، ولكن حرف ناسخ، وأكثر الناس اسمها، وجملة لا يعلمون خبر.</p></div>"
  12,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما دخلوا على يوسف آوى إليه أخاه﴾</span></span>: لما ظرف حينية، أو رابطة، ومن حرف جر، وأخاه مفعول <span class="hlt"><span class="qpc-hafs">﴿آوى﴾</span></span>، والجملة جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إني أنا أخوك فلا تبتئس بما كانوا يعملون﴾</span></span>: إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، وأخوك خبر، والجملة خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال...﴾</span></span> مستأنفة لا محل لها من الإعراب، والفاء الفصيحة، ولا ناهية، وتبتئس مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبتئس﴾</span></span>، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة يعملون خبر كان.</p></div>"
  12,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جهزهم بجهازهم جعل السقاية في رحل أخيه﴾</span></span>: الفاء عاطفة، ولما ظرفية، أو رابطة، وجهزهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بجهازهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جهزهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل السقاية في رحل أخيه﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في رحل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم أذن مؤذن أيتها العير﴾</span></span>: ثم حرف عطف وتراخ، و<span class="hlt"><span class="qpc-hafs">﴿أذن مؤذن﴾</span></span> فعل وفاعل، أي: نادى منادٍ، وأيتها منادى محذوف منه حرف النداء وهو نكرة مقصودة مبني على الضم، وها للتنبيه، والعير صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنكم لسارقون﴾</span></span>: إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وسارقون خبرها.</p></div>"
  12,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا وأقبلوا عليهم ماذا تفقدون﴾</span></span>: الواو للحال بتقدير: قد، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تفقدون﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول خبر، وجملة تفقدون صلة الموصول لا محل لها من الإعراب.</p></div>"
  12,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا نفقد صواع الملك﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿نفقد صواع الملك﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولمن جاء به حمل بعير﴾</span></span>: الواو عاطفة، ولمن خبر مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء به﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وحمل بعير مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا به زعيم﴾</span></span>: الواو عاطفة، وأنا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زعيم﴾</span></span>، وزعيم خبر.</p></div>"
  12,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا تالله لقد علمتم ما جئنا لنفسد في الأرض وما كنا سارقين﴾</span></span>: التاء حرف جر وقسم، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> لفظ الجلالة مجرور بتاء القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: نقسم، واللام واقعة في جواب القسم، أو هو تأكيد للقسم الأول، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، وعلمتم فعل وفاعل، وما نافية، وجئنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لنفسد﴾</span></span> اللام للتعليل، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفسد﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وما كنا﴾</span></span> ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وسارقين خبرها.</p></div>"
  12,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا فما جزاؤه إن كنتم كاذبين﴾</span></span>: الفاء الفصيحة، وما اسم استفهام مبتدأ، وجزاؤه خبر، والضمير للصواع، أي: فما جزاء سرقته، أو الضمير للسارق، وإن شرطية، وكنتم فعل الشرط، وكاذبين خبر كان، وجواب إن محذوف دل عليه ما قبله، أي: فما جزاء سرقة الصواع، أو السارق.</p></div>"
  12,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا جزاؤه من وجد في رحله فهو جزاؤه﴾</span></span>: جزاؤه مبتدأ، ومن شرطية، أو موصولة مبتدأ ثان، وجملة وجد صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، أو فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿في رحله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span>، والفاء رابطة على الوجهين، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجزاؤه خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فهو جزاؤه﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> وما في حيزها خبر المبتدأ الأول، والضمير على هذا الإعراب يعود على السارق، أو <span class="hlt"><span class="qpc-hafs">﴿جزاؤه﴾</span></span> مبتدأ، والهاء تعود على المسروق، و<span class="hlt"><span class="qpc-hafs">﴿من وجد في رحله﴾</span></span> خبره، ومَن بمعنى الذي، والتقدير: وجزاء الصواع الذي وجد في رحله، أو <span class="hlt"><span class="qpc-hafs">﴿جزاؤه﴾</span></span> خبر مبتدأ محذوف، أي: المسئول عنه جزاؤه، أي: استرقاقه جزاؤه، وكانت تلك شريعة آل يعقوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نجزي الظالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: جزاءً مثلَ ذلك نجزي، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿الظالمين﴾</span></span> مفعول به.</p></div>"
  12,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبدأ بأوعيتهم قبل وعاء أخيه ثم استخرجها من وعاء أخيه﴾</span></span>: الفاء عاطفة، وبدأ فعل ماض، وفاعله مستتر، تقديره: هو، وبأوعيتهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بدأ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف زمان متعلق بمحذوف حال، ووعاء أخيه مضاف ومضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف، واستخرجها فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> تعود على الصواع، و<span class="hlt"><span class="qpc-hafs">﴿من وعاء أخيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استخرجها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: كيدًا مثلَ ذلك الكيد كدنا، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿ليوسف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كدنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span></span>: ما نافية، وكان فعل ماض ناقص ناسخ، واسمها مستتر، واللام للجحود، ويأخذ فعل مضارع منصوب بأن مضمرة بعد لام الجحود، واللام ومجرورها متعلقان بمحذوف في موضع الخبر، وأخاه مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في دين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأخذ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا أن يشاء الله﴾</span></span>: الاستثناء منقطع، أو متصل من أعم الأحوال، أي: إلا حال مشيئته وإذنه بذلك، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما كان ليأخذ أخاه...﴾</span></span> تعليلية، وقيل: تفسيرية، وعلى كلٍّ لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿نرفع درجات من نشاء﴾</span></span>: درجات منصوب على الظرفية، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فوق﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿كل ذي علم﴾</span></span> كل مضاف إليه وهي مضاف، وذي مضاف إليه وهي مضاف، وعلم مضاف إليه، وعليم مبتدأ مؤخر.</p></div>"
  12,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إن يسرق فقد سرق أخ له من قبل﴾</span></span>: إن شرطية، ويسرق فعل الشرط، والفاء رابطة لاقتران الجواب بـ<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سرق أخ﴾</span></span> فعل وفاعل، والجملة في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأسرها يوسف في نفسه ولم يبدها لهم﴾</span></span>: الفاء عاطفة، وأسرها فعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوسف﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسرها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لم يبدها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أسرها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبدها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال أنتم شر مكانا والله أعلم بما تصفون﴾</span></span>: أنتم مبتدأ، وشر خبر، ومكانًا تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنتم شر مكانًا﴾</span></span> بدل من الها، أو أن الضمير يعود على الحجة، أي: فأسر يوسف في نفسه الحجة عليهم في ادعائهم عليه السرقة ولم يبدها لهم وقال: أنتم شر مكانًا، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة تصفون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أيها العزيز إن له أبا شيخا كبيرا﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة، وها للتنبيه، والعزيز صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿أبا﴾</span></span> اسمها المؤخر، وشيخًا صفة، وكبيرًا صفة ثانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿فخذ أحدنا مكانه﴾</span></span>: الفاء الفصيحة، وخذ فعل أمر وفاعل مستتر تقديره: أنت، وأحدنا مفعول به، ومكانه ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خذ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا نراك من المحسنين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نراك خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من المحسنين﴾</span></span> جار ومجرور متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نراك﴾</span></span> على أنه مفعول ثان.</p></div>"
  12,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال معاذ الله أن نأخذ إلا من وجدنا متاعنا عنده﴾</span></span>: معاذ الله نصب على المصدر بفعل محذوف، أي: نعوذ بالله معاذًا، و<span class="hlt"><span class="qpc-hafs">﴿أن نأخذ﴾</span></span> أن وما في حيزه منصوب بنزع الخافض متعلق بنعوذ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول نأخذ، وجملة وجدنا صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، ومتاعنا مفعول وجدنا، وعنده ظرف متعلق بالفعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا إذا لظالمون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جواب وجزاء، واللام المزحلقة، وظالمون خبر إن.</p></div>"
  12,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما استيأسوا منه خلصوا نجيا﴾</span></span>: لما ظرف حينية، أو رابطة، واستيأسوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استيأسوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلصوا﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلصوا﴾</span></span> جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نجيا﴾</span></span> حال من فاعل خلصوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال كبيرهم ألم تعلموا أن أباكم قد أخذ عليكم موثقا من الله﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، وتعلموا مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وأن وما في حيزها سدت مسد مفعولي تعلموا، وأن حرف ناسخ، وأباكم اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد أخذ﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بأخذ، وموثقًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿موثقًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن قبل ما فرطتم في يوسف﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وبُنِي <span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> على الضم لانقطاعه عن الإضافة لفظًا لا معنى، أي: ومن قبل هذا، وما مصدرية، وهي مع مدخولها مبتدأ مؤخر، أي: ووقع من قبل هذا تفريطكم، و<span class="hlt"><span class="qpc-hafs">﴿في يوسف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فرطتم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أي: ومن قبل هذا الذي فرطتموه في يوسف من الجناية العظيمة، ومحل الموصول الرفع على الابتداء أيضًا، أو ما صلة، فـ<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بالفعل، وهو <span class="hlt"><span class="qpc-hafs">﴿فرطتم﴾</span></span>، والواو في <span class="hlt"><span class="qpc-hafs">﴿ومن قبل﴾</span></span> للحال، فالمعنى: ألم تعلموا أن أباكم قد أخذ عليكم موثقًا من الله والحال أنكم فرطتم في يوسف من قبل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلن أبرح الأرض حتى يأذن لي أبي﴾</span></span>: الفاء عاطفة على مقدر، أي: سأبقى في مصر ولن أبرحها، و<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span> حرف نفي ونصب واستقبال، و<span class="hlt"><span class="qpc-hafs">﴿أبرح﴾</span></span> فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، ومعناه: أفارق، فهي تامة، وفاعل أبرح مستتر تقديره: أنا، والأرض مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿يأذن﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبرح﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأذن﴾</span></span>، وأبي فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو يحكم الله لي﴾</span></span>: أو حرف عطف، ويحكم معطوف على <span class="hlt"><span class="qpc-hafs">﴿يأذن﴾</span></span>، أو منصوب بأن مضمرة في جواب النفي، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو خير الحاكمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير الحاكمين خبر.</p></div>"
  12,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ارجعوا إلى أبيكم فقولوا يا أبانا إن ابنك سرق﴾</span></span>: ارجعوا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى أبيكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ارجعوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فقولوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ارجعوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أبانا﴾</span></span> منادى مضاف، وإن حرف ناسخ، وابنك اسمها، وجملة سرق خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما شهدنا إلا بما علمنا﴾</span></span>: الواو حرف عطف، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿شهدنا﴾</span></span> فعل وفاعل، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بشهدنا، وجملة علمنا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿للغيب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حافظين﴾</span></span>، وحافظين خبر كنا.</p></div>"
  12,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واسأل القرية التي كنا فيها﴾</span></span>: الواو عاطفة، واسأل فعل أمر، وفاعله مستتر وتقديره: أنت، والقرية مفعول به، والتي صفة، وجملة كنا صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿والعير التي أقبلنا فيها﴾</span></span>: الواو عاطفة، والعير عطف على القرية، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أقبلنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لصادقون﴾</span></span>: الواو عطف، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وصادقون خبرها.</p></div>"
  12,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال بل سولت لكم أنفسكم أمرا﴾</span></span>: قال مرتب على محذوف، أي: فرجعوا فقال، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف إضراب، وسولت فعل ماض، والتاء للتأنيث، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سولت﴾</span></span>، وأنفسكم فاعل، وأمرًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فصبر جميل عسى الله أن يأتيني بهم جميعا﴾</span></span>:  الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿صبر﴾</span></span> خبر لمبتدأ محذوف، أي: صبري، وجميل نعت، وعسى من أفعال الرجاء، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> اسمها، وأن وما في حيزها خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيني﴾</span></span>، وجميعًا حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو العليم الحكيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿العليم الحكيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العليم الحكيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن.</p></div>"
  12,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتولى عنهم وقال يا أسفى على يوسف﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تولى﴾</span></span> فعل ماض، أي: أعرض عنهم، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تولى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تولى﴾</span></span>، ويا حرف نداء، وأسفا منادى مضاف لياء المتكلم المنقلبة ألفًا، و<span class="hlt"><span class="qpc-hafs">﴿على يوسف﴾</span></span> جار ومجرور متعلقان بالأسف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وابيضت عيناه من الحزن فهو كظيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وابيضت عيناه فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من الحزن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابيضت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فهو﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وكظيم خبره.</p></div>"
  12,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا تالله تفتأ تذكر يوسف حتى تكون حرضا أو تكون من الهالكين﴾</span></span>: قالوا فعل وفاعل، والتاء تاء القسم، ولفظ الجلالة مجرور بتاء القسم، والجار والمجرور متعلقان بفعل القسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿تفتأ﴾</span></span> من أخوات كان، واسمها مستتر تقديره: أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿تذكر﴾</span></span> خبرها، ويوسف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بتذكر، وحرضًا خبر تكون، واسم تكون مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وتكون فعل مضارع ناقص، واسمها مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿من الهالكين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  12,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إنما أشكو بثي وحزني إلى الله﴾</span></span>: إنما كافة ومكفوفة، وأشكو بثي فعل مضارع وفاعل مستتر ومفعول به، وحزني عطف على <span class="hlt"><span class="qpc-hafs">﴿بثي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشكو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأعلم من الله ما لا تعلمون﴾</span></span>: الواو عاطفة، وأعلم عطف على أشكو، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة لا تعلمون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا بني اذهبوا فتحسسوا من يوسف وأخيه﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿بني﴾</span></span> منادى مضاف، وعلامة نصبه الياء، لأنه ملحق بجمع المذكر السالم، واذهبوا فعل أمر وفاعل، والفاء عاطفة، وتحسسوا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من يوسف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحسسوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخيه﴾</span></span> عطف على يوسف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span></span>: الواو عاطفة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تيأسوا﴾</span></span> مجزوم بلا، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من روح الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تيأسوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا ييأس من روح الله إلا القوم الكافرون﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ييأس﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من روح الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ييأس﴾</span></span>، وإلا أداة حصر، والقوم فاعل، والكافرون صفة.</p></div>"
  12,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما دخلوا عليه﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرفية حينية، أو رابطة، ودخلوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أيها العزيز مسنا وأهلنا الضر﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة، وها للتنبيه، والعزيز صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مسنا﴾</span></span> فعل ومفعول به، وأهلنا عطف على <span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>، أو مفعول معه، والضر فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة فأوف لنا الكيل﴾</span></span>: الواو عاطفة، وجئنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ببضاعة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئنا﴾</span></span>، ومزجاة صفة، <span class="hlt"><span class="qpc-hafs">﴿فأوف﴾</span></span> الفاء عاطفة، وأوف فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوف﴾</span></span>، والكيل مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتصدق علينا إن الله يجزي المتصدقين﴾</span></span>: الواو عاطفة، وتصدق عطف على <span class="hlt"><span class="qpc-hafs">﴿فأوف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تصدق﴾</span></span>، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يجزي خبرها، والمتصدقين مفعول به.</p></div>"
  12,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</span></span>: هل حرف استفهام، وعلمتم فعل وفاعل، وما اسم موصول مفعول به، أو مصدرية، أي: فعلكم بيوسف، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فعلتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخيه﴾</span></span> عطف على يوسف، وإذ ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فعلتم﴾</span></span>، أي: فعلتم وقت جهلكم، وأنتم مبتدأ، وجاهلون خبر، والجملة الاسمية مضاف إليها الظرف.</p></div>"
  12,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أئنك لأنت يوسف﴾</span></span>: قالوا فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿أإنك﴾</span></span> الهمزة للاستفهام التقريري، وإن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وأنت مبتدأ، ويوسف خبر، والجملة خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> ضمير فصل، ويوسف خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال أنا يوسف وهذا أخي قد من الله علينا﴾</span></span>: أنا مبتدأ، ويوسف خبر، وهذا مبتدأ، وأخي خبر، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿منَّ﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منَّ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد مَنّ الله علينا﴾</span></span> استئنافية لا محل لها من الإعراب، وقيل: حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه من يتق ويصبر فإن الله لا يضيع أجر المحسنين﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يتق﴾</span></span> فعل الشرط مجزوم، وعلامة جزمه حذف حرف العلة، ويصبر عطف عليه، <span class="hlt"><span class="qpc-hafs">﴿فإن الله﴾</span></span> الفاء رابطة للجواب، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يضيع خبرها، وأجر المحسنين مفعول به، وجملة الشرط وجوابه خبر إن.</p></div>"
  12,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا تالله لقد آثرك الله علينا﴾</span></span>: التاء تاء القسم، ولفظ الجلالة مجرور بها، والجار والمجرور متعلقان بفعل محذوف تقديره: نقسم، واللام جواب القسم، وقد حرف تحقيق، وآثرك الله فعل ومفعول به وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آثرك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كنا لخاطئين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة لا عمل لها، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام الفارقة، وخاطئين خبر كنا.</p></div>"
  12,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا تثريب عليكم اليوم﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿لا تثريب﴾</span></span> مقول القول، ولا نافية للجنس، وتثريب اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، واليوم ظرف متعلق بمحذوف خبر ثان، أو بمتعلق الخبر وهو <span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span>، أو يكون الظرف متعلقا بالفعل الذي بعده.</p><p><span class="hlt"><span class="qpc-hafs">﴿يغفر الله لكم وهو أرحم الراحمين﴾</span></span>: جملة دعائية بمثابة التعليل، ويغفر الله فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأرحم الراحمين خبر.</p></div>"
  12,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهبوا بقميصي هذا فألقوه على وجه أبي يأت بصيرا﴾</span></span>: اذهبوا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بقميصي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذهبوا﴾</span></span>، والباء للتعدية، أو الجار والمجرور متعلقان بمحذوف حال، أي: اذهبوا معكم قميصي، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> نعت، أو بدل، أو عطف بيان، <span class="hlt"><span class="qpc-hafs">﴿فألقوه﴾</span></span> الفاء عاطفة، وألقوه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على وجه أبي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوه﴾</span></span>، ويأت فعل مضارع مجزوم، لأنه جواب الأمر، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بصيرًا﴾</span></span> حال، أو يكون خبرًا لـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span> على تضمينه معنى: يصير بصيرًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأتوني بأهلكم أجمعين﴾</span></span>: الواو عاطفة، وائتوني عطف على <span class="hlt"><span class="qpc-hafs">﴿اذهبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بأهلكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوني﴾</span></span>، وأجمعين تأكيد للأهل.</p></div>"
  12,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما فصلت العير قال أبوهم إني لأجد ريح يوسف لولا أن تفندون﴾</span></span>: لما ظرفية، أو رابطة، وفصلت العير فعل وفاعل، وإن حرف ناسخ، والياء اسمها، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أجد﴾</span></span> خبر إن، وريح يوسف مفعول به، ولولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ خبره محذوف، تقديره: لولا تفنيدكم موجود، وجواب لولا محذوف، أي: لصدقتموني.</p></div>"
  12,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا تالله إنك لفي ضلالك القديم﴾</span></span>: التاء تاء القسم، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مجرور بتاء القسم، والجار والمجرور متعلقان بفعل القسم، وإن حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في ضلالك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿القديم﴾</span></span> صفة.</p></div>"
  12,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أن جاء البشير ألقاه على وجهه فارتد بصيرا﴾</span></span>: لما ظرفية حينية، أو رابطة، وأن صلة، و<span class="hlt"><span class="qpc-hafs">﴿جاء البشير﴾</span></span> فعل وفاعل، وجملة ألقاه لا محل لها من الإعراب، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على وجهه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقاه﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فارتد﴾</span></span> الفاء عاطفة، وارتد فعل ماض فاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بصيرًا﴾</span></span> حال، أو <span class="hlt"><span class="qpc-hafs">﴿ارتد﴾</span></span> فعل ماض ناقص يعمل عمل <span class="hlt"><span class="qpc-hafs">﴿صار﴾</span></span>، وبصيرًا خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال ألم أقل لكم إني أعلم من الله ما لا تعلمون﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والفاعل مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span>، وإن حرف ناسخ، والياء اسمها، وجملة أعلم خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة لا تعلمون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أبانا استغفر لنا ذنوبنا إنا كنا خاطئين﴾</span></span>: يا أبانا منادى مضاف، واستغفر فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استغفر﴾</span></span>، وذنوبنا مفعول به، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا خاطئين﴾</span></span> خبر إن، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وخاطئين خبرها.</p></div>"
  12,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال سوف أستغفر لكم ربي﴾</span></span>: جملة سوف أستغفر مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أستغفر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو الغفور الرحيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والغفور الرحيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والغفور الرحيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  12,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما دخلوا على يوسف آوى إليه أبويه﴾</span></span>: عطف على محذوف، ودخلوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على يوسف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آوى﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آوى﴾</span></span>، وأبويه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال ادخلوا مصر إن شاء الله آمنين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ادخلوا مصر﴾</span></span> فعل وفاعل ومفعول به، وإن شرطية، وشاء فعل الشرط، والجواب محذوف لدلالة الكلام عليه، وجملة الشرط <span class="hlt"><span class="qpc-hafs">﴿إن شاء الله﴾</span></span>: اعتراضية بين الحال وصاحبها لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آمنين﴾</span></span> حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿ادخلوا﴾</span></span>.</p></div>"
  12,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ورفع أبويه على العرش وخروا له سجدا﴾</span></span>: الواو عاطفة، ورفع أبويه فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على العرش﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رفع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خروا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خروا﴾</span></span>، وسجدًا حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال يا أبت هذا تأويل رؤياي من قبل﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أبت﴾</span></span> منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، وتأويل خبر، ورؤياي مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جعلها ربي حقا﴾</span></span>: قد حرف تحقيق، وجعلها ربي فعل ومفعول به وفاعل، وحقًّا مفعول ثان، والجملة حال مقدرة أو مقارنة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد أحسن بي إذ أخرجني من السجن﴾</span></span>: الواو عاطفة، وقد حرف تحقيق، وأحسن فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> أيضًا، وجملة أخرجني في محل جر مضاف إليه، والفاعل مستتر، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السجن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجاء بكم من البدو من بعد أن نزغ الشيطان بيني وبين إخوتي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من البدو﴾</span></span> جار ومجرور متعلقان به أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأن وما في حيزها مصدر مجرور بإضافة الظرف إليه، والشيطان فاعل نزغ، و<span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نزغ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> عطف على الظرف الأول، ومضاف إلى <span class="hlt"><span class="qpc-hafs">﴿إخوتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي لطيف لما يشاء﴾</span></span>: إن حرف ناسخ، وربي اسمها، ولطيف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لطيف﴾</span></span>، وجملة يشاء صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو العليم الحكيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعليم الحكيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعليم الحكيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  12,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب قد آتيتني من الملك وعلمتني من تأويل الأحاديث﴾</span></span>: رب منادى مضاف لياء المتكلم المحذوفة، وحرف النداء محذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿آتيتني﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الملك﴾</span></span> من تبعيضية، وهي ومجرورها متعلقان بمحذوف صفة لمفعول به محذوف، أي: آتيتني شيئًا عظيمًا من الملك، وقيل: تبيينية فتتعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتيتني﴾</span></span>، وعلمتني عطف على آتيتني، و<span class="hlt"><span class="qpc-hafs">﴿من تأويل الأحاديث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علمتني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاطر السماوات والأرض﴾</span></span>:  نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>، أو بدل منه، أو منادى، وحرف النداء محذوف، والسماوات مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنت وليي في الدنيا والآخرة﴾</span></span>: أنت مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿وليي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وليي﴾</span></span>، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿توفني مسلما وألحقني بالصالحين﴾</span></span>: فعل دعاء، والنون للوقاية، والياء مفعول به، ومسلمًا حال، وألحقني عطف على توفني، و<span class="hlt"><span class="qpc-hafs">﴿بالصالحين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألحقني﴾</span></span>.</p></div>"
  12,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك من أنباء الغيب نوحيه إليك﴾</span></span>: ذلك اسم إشارة في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من أنباء الغيب﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، وجملة نوحيه إليك حال، أو خبر ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت لديهم إذ أجمعوا أمرهم وهم يمكرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لديهم﴾</span></span> ظرف مكان متعلق بمحذوف خبر كنت، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف زمان متعلق بالخبر المحذوف الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿لديهم﴾</span></span>، وجملة أجمعوا في محل جر بإضافة الظرف إليها، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يمكرون خبر، والجملة حالية.</p></div>"
  12,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أكثر الناس ولو حرصت بمؤمنين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span>: الواو اعتراضية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿حرصت﴾</span></span> فعل وفاعل، وجواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> محذوف دل عليه ما قبله أي: ولو حرصت على إيمان أكثر الناس فما هم بمؤمنين، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولو حرصت﴾</span></span> اعتراضية بين <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية وخبرها، لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بمؤمنين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  12,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تسألهم عليه من أجر﴾</span></span>: الواو عاطفة، وما نافية، وتسألهم فعل مضارع وفاعل مستتر، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والضمير يعود على القرآن، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، وأجر مجرور بمن لفظًا منصوب محلًّا على أنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا ذكر للعالمين﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وإلا أداة حصر، وذكر خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للعالمين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>.</p></div>"
  12,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكأين من آية في السماوات والأرض﴾</span></span>:كأين في محل رفع مبتدأ، ومن حرف صلة، وآية مجرور لفظًا بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> منصوب محلا على أنه تمييز لـ<span class="hlt"><span class="qpc-hafs">﴿كأين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يمرون عليها وهم عنها معرضون﴾</span></span>: جملة يمرون خبر لمبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿معرضون﴾</span></span>، ومعرضون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة الاسمية حالية. أو <span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> خبر لـ<span class="hlt"><span class="qpc-hafs">﴿كأين﴾</span></span>، وجملة يمرون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>.</p></div>"
  12,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يؤمن أكثرهم بالله إلا وهم مشركون﴾</span></span>: الواو عاطفة، وما نافية، ويؤمن أكثرهم فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، وإلا أداة حصر، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومشركون خبر، والجملة نصب على الحال.</p></div>"
  12,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفأمنوا أن تأتيهم غاشية من عذاب الله﴾</span></span>: الهمزة للاستفهام الإنكاري، وفيه معنى التوبيخ والتهديد، والفاء عاطفة، وأمنوا فعل وفاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن تأتيهم﴾</span></span> مفعول أمنوا، والهاء مفعول تأتي، وغاشية فاعل تأتي، و<span class="hlt"><span class="qpc-hafs">﴿من عذاب الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿غاشية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو تأتيهم الساعة بغتة وهم لا يشعرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أو تأتيهم﴾</span></span> عطف على تأتيهم السابقة، والساعة فاعل تأتيهم، وبغتة حال، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون خبر، والجملة نصب على الحال.</p></div>"
  12,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل هذه سبيلي أدعو إلى الله على بصيرة أنا ومن اتبعني﴾</span></span>: قل: فعل أمر، والفاعل مستتر. وهذه: مبتدأ. وسبيلي: خبر، والياء: ضمير مبني في محل جر مضاف إليه. وأدعو: فعل مضارع، والفاعل مستتر. و<span class="hlt"><span class="qpc-hafs">﴿إلى الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدعو﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿أدعو إلى الله﴾</span></span> تفسيرية للسبيل، أو حالية من الضمير في <span class="hlt"><span class="qpc-hafs">﴿سبيلي﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿على بصيرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدعو﴾</span></span>، أو بمحذوف حال من فاعل أدعو، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> تأكيد لفاعل أدعو المستتر، ومن اتبعني عطف على فاعل أدعو المستتر، أو <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ، وخبره محذوف، أي: ومن اتبعني يدعو أيضًا، أو <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿على بصيرة﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن اتبعني عطف على <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبحان الله وما أنا من المشركين﴾</span></span>: الواو عاطفة، وسبحان: نائب مفعول مطلق منصوب بفعل محذوف، واسم الجلالة: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿من المشركين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ما. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية غير عاملة، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المشركين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ.</p></div>"
  12,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم من أهل القرى﴾</span></span>: ما نافية، وأرسلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وإلا أداة حصر، ورجالًا مفعول به، وجملة نوحي إليهم صفة، و<span class="hlt"><span class="qpc-hafs">﴿من أهل القرى﴾</span></span> جار ومجرور متعلقان بمحذوف صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿رجالًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يسيروا في الأرض﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف، ولم حرف نفي وقلب وجزم، ويسيروا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فينظروا كيف كان عاقبة الذين من قبلهم﴾</span></span>: الفاء عاطفة، أو سببية، وينظروا فعل مضارع مجزوم عطفًا على يسيروا، أو منصوب بأن مضمرة في جواب النفي، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق، تقديره: أفلم يكن سير فنظر؟ وكيف اسم استفهام في محل نصب خبر كان مقدم، وعاقبة اسم كان، والذين مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولدار الآخرة خير للذين اتقوا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام لام الابتداء، ودار مبتدأ، والآخرة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر دار، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتقوا﴾</span></span> صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تعقلون﴾</span></span>: الهمزة للاستفهام الإنكاري التعجبي، وهي داخلة على مقدر هو المعطوف عليه بهذا العاطف، والجملة الاستفهامية مستأنفة لا محل لها من الإعراب.</p></div>"
  12,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا استيأس الرسل وظنوا أنهم قد كذبوا﴾</span></span>: حتى حرف غاية، و<span class="hlt"><span class="qpc-hafs">﴿ظنوا﴾</span></span> عطف على استيأسوا، وأن وما في حيزها سدت مسد مفعولي ظنوا، وكذبوا بالبناء لما لم يسمَّ فاعله، أي: ظنت الأمم أن الرسل أخلفوا ما وعدوا به من النصر، وجملة كذبوا خبر أنهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿جاءهم نصرنا فنجي من نشاء﴾</span></span>: جملة جاءهم لا محل لها من الإعراب، لأنها جواب إذا، وجاءهم نصرنا فعل ومفعول به وفاعل، والفاء عاطفة، ونجي بالبناء لما لم يسمَّ فاعله عطف على جاءهم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> نائب فاعل، ونشاء صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يرد بأسنا عن القوم المجرمين﴾</span></span>: الواو عاطفة، ولا نافية، ويرد بالبناء لما لم يسمَّ فاعله، وبأسنا نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عن القوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، والمجرمين صفة.</p></div>"
  12,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد كان في قصصهم عبرة لأولي الألباب﴾</span></span>: اللام جواب قسم محذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿في قصصهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان مقدم، وعبرة اسم كان مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لأولي﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عبرة﴾</span></span>، والألباب مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كان حديثا يفترى﴾</span></span>: ما نافية، وكان فعل ماض ناقص ناسخ، واسمها ضمير مستتر يعود على القرآن، وحديثًا خبرها، وجملة يفترى صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حديثًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن تصديق الذي بين يديه وتفصيل كل شيء وهدى ورحمة لقوم يؤمنون﴾</span></span>: الواو حرف عطف، ولكن مخففة مهملة، وتصديق عطف على <span class="hlt"><span class="qpc-hafs">﴿حديثًا﴾</span></span>، أو على تقدير: كان، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف صلة الموصول لا محل له من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وتفصيل كل شيء وهدى ورحمة﴾</span></span> معطوفات على <span class="hlt"><span class="qpc-hafs">﴿تصديق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، وجملة يؤمنون صفة لقوم.</p></div>"
