quran[78]{c,v,t}:
  22,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس اتقوا ربكم﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة مبني على الضم، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، واتقوا فعل أمر مبني على حذف النون، والواو فاعل، وربكم مفعول به منصوب بالفتحة، والضمير مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن زلزلة الساعة شيء عظيم﴾</span></span>: إن حرف ناسخ، وزلزلة اسم إن، والساعة مضاف إليه، وشيء خبر إن، وعظيم صفة لشيء، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن زلزلة الساعة ...﴾</span></span> تعليلية لا محل لها من الإعراب.</p></div>"
  22,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم ترونها تذهل كل مرضعة عما أرضعت وتضع كل ذات حمل حملها﴾</span></span>: يوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تذهل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترونها﴾</span></span> في محل جر بإضافة الظرف إليها، وتذهل فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿كل مرضعة﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تذهل ...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عما أرضعت﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذهل﴾</span></span>، وما موصولة، و<span class="hlt"><span class="qpc-hafs">﴿تضع كل﴾</span></span>: فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تضع﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿تذهل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذات حمل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿حملها﴾</span></span> مفعول به لتضع.</p><p><span class="hlt"><span class="qpc-hafs">﴿وترى الناس سكارى وما هم بسكارى﴾</span></span>: الواو عاطفة، وترى فعل مضارع معطوف على ترونها، وفاعل ترى مستتر تقديره أنت، والناس مفعول به، وسكارى حال، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بسكارى﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿سكارى﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما هم بسكارى﴾</span></span> في محل نصب على الحال من الناس.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن عذاب الله شديد﴾</span></span>: الواو عاطفة على محذوف، أي: هذا كله هين ولكن عذاب الله شديد.</p></div>"
  22,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يجادل في الله بغير علم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من الناس﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادل في الله﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بغير علم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من ضمير الفاعل المستتر في يجادل، أي: يجادل جاهلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويتبع كل شيطان مريد﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يتبع﴾</span></span> عطف على يجادل، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مفعول به، وشيطان مضاف إليه، ومريد صفة لشيطان، ولا بد من تقدير مضاف، أي: خطوات كل شيطان.</p></div>"
  22,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كتب عليه أنه من تولاه فأنه يضله ويهديه إلى عذاب السعير﴾</span></span>: كتب فعل ماض مبني لما لم يسمَّ فاعله، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كتب﴾</span></span>، وأن وما في حيزها في محل رفع نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فأنه﴾</span></span> خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يضله﴾</span></span> خبر أنه الثانية، وجملة الشرط خبر أنه الأولى، ويهديه عطف على يضله، و<span class="hlt"><span class="qpc-hafs">﴿إلى عذاب السعير﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهديه﴾</span></span>.</p></div>"
  22,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس إن كنتم في ريب من البعث فإنا خلقناكم من تراب ثم من نطفة ثم من علقة ثم من مضغة مخلقة وغير مخلقة لنبين لكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة مبني على الضم، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وإن شرطية وكنتم فعل ماض ناقص فعل الشرط، والتاء اسمها، وفي ريب جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من البعث﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لريب. فإنا: الفاء رابطة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span> خبرها، ومن تراب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span>،  وثم حرف عطف يفيد التراخي في تطور الخلق، وقوله مخلقة صفة لمضغة، وغير مخلقة عطف على مخلقة، ولنبين: اللام للتعليل، ونبين مضارع منصوب بأن مضمرة بعد لام التعليل، واللام مع مدخولها <span class="hlt"><span class="qpc-hafs">﴿لنبيِّن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span>، أو اللام للصيرورة والعاقبة. ومفعول نبين محذوف، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونقر في الأرحام ما نشاء إلى أجل مسمى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ونقر مضارع مرفوع، وفاعله مستتر تقديره نحن، وفي الأرحام جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقر﴾</span></span>، وما مفعول به، وجملة نشاء صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وإلى أجل مسمى جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم نخرجكم طفلا ثم لتبلغوا أشدكم﴾</span></span>: ثم عاطفة، ونخرجكم عطف على نقر، وفاعل نخرجكم ضمير مستتر تقديره نحن، والكاف مفعول به، وطفلا حال من مفعول نخرجكم. ثم لتبلغوا: لا بد من تقدير: فعل، أي: ثم نعمركم لتبلغوا أشدكم. ولتبلغوا اللام للتعليل أو الصيرورة، وتبلغوا منصوب بأن مضمرة بعد اللام، والواو فاعل، وأشدكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومنكم من يتوفى ومنكم من يرد إلى أرذل العمر لكيلا يعلم من بعد علم شيئا﴾</span></span>: الواو عاطفة، ومنكم خبر مقدم، ومن مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتوفى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ومنكم جار ومجرور متعلقان بمحذوف خبر مقدم، ومن مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿إلى أرذل العمر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، ولكيلا اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span> حرف مصدري ونصب، وهو مؤول مع ما بعده بمصدر مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> علم جار ومجرور متعلقان بمحذوف حال، لأن علم بمعنى عرف، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به ليعلم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وترى الأرض هامدة فإذا أنزلنا عليها الماء اهتزت وربت وأنبتت من كل زوج بهيج﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وترى فعل ماض، والفاعل مستتر تقديره أنت، والأرض مفعول به، وهامدة حال من الأرض. فإذا الفاء عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، والماء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿اهتزت﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وربت عطف على اهتزت، وكذلك قوله: <span class="hlt"><span class="qpc-hafs">﴿وأنبتت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من كل زوج﴾</span></span> الجار والمجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: أنبتت أشياءً أو أصنافًا كائنة من كل زوج، و<span class="hlt"><span class="qpc-hafs">﴿بهيج﴾</span></span> صفة لزوج.</p></div>"
  22,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأن الله هو الحق﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بأن الله هو الحق﴾</span></span> الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن الله﴾</span></span>: أن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والحق خبر، والمبتدأ وخبره <span class="hlt"><span class="qpc-hafs">﴿هو الحق﴾</span></span> خبر أن في محل رفع، والجار والمجرور متعلقان بخبر المبتدأ ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنه يحيي الموتى﴾</span></span>: الواو عاطفة، وأنه عطف على بأن، و<span class="hlt"><span class="qpc-hafs">﴿أنه﴾</span></span>: أن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي الموتى﴾</span></span> خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنه على كل شيء قدير﴾</span></span>: الواو عاطفة، وأنه: أن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span>: جار ومجرور ومضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدير﴾</span></span>، وقدير خبر أن.</p></div>"
  22,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن الساعة آتية لا ريب فيها﴾</span></span>: الواو عاطفة، وأن الساعة خبر لمبتدأ محذوف، أي: والأمر أن الساعة. وأن الساعة: أن حرف ناسخ، والساعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿آتية﴾</span></span> خبرها، ولا نافية للجنس، وريب اسم لا، وفيها جار ومجرور متعلقان بمحذوف خبر لا، والجملة حالية أو خبر ثان لأن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن الله يبعث من في القبور﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبعث﴾</span></span> خبرها، ومن مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في القبور﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p></div>"
  22,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يجادل في الله بغير علم ولا هدى ولا كتاب منير﴾</span></span>: الواو استئنافية، ومن الناس: خبر مقدم، ومن: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span> صلة الموصول لا محل لها من الإعراب، وفي الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span> على حذف مضاف، أي: قدرته، وصفاته، ودينه، و<span class="hlt"><span class="qpc-hafs">﴿بغير﴾</span></span> جار ومجرور متعلقان بمحذوف حال من ضمير الفاعل المستتر في يجادل، أي: يجادل جاهلا، و<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا هدى﴾</span></span>: عطف على علم، و<span class="hlt"><span class="qpc-hafs">﴿لا كتاب﴾</span></span>: عطف أيضًا، ومنير صفة لكتاب.</p></div>"
  22,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثاني عطفه ليضل عن سبيل الله﴾</span></span>: ثاني حال من فاعل يجادل، وعطفه مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ليضل﴾</span></span>: اللام للتعليل أو للعاقبة والصيرورة، ويضل فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿عن سبيل الله﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿له في الدنيا خزي ونذيقه يوم القيامة عذاب الحريق﴾</span></span>: له خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لخزي وتقدم، و<span class="hlt"><span class="qpc-hafs">﴿خزي﴾</span></span> مبتدأ مؤخر. ونذيقه: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نذيقه﴾</span></span> فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نذيقه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الحريق﴾</span></span> مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿له في الدنيا ...﴾</span></span> حالية.</p></div>"
  22,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بما قدمت يداك وأن الله ليس بظلام للعبيد﴾</span></span>: ذلك مبتدأ، وبما خبر، وقدمت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ويداك فاعل، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، <span class="hlt"><span class="qpc-hafs">﴿ليس بظلام للعبيد﴾</span></span>: اسم ليس مستتر تقديره هو، والباء حرف جر صلة، وظلام اسم مجرور لفظًا منصوب محلا خبر ليس، وللعبيد جار ومجرور متعلقان بظلام، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس بظلام للعبيد﴾</span></span> خبر أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأنّ الله ...﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المجرورة فهي في محل جر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك بما قدمت يداك﴾</span></span> مقول قول محذوف، وجملة القول حالية.</p></div>"
  22,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يعبد الله على حرف﴾</span></span>: الواو عاطفة أو استئنافية، ومن الناس خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعبد الله﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على حرف﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل يعبد، أي: مضطربًا، والجملة معطوفة، مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن أصابه خير اطمأن به وإن أصابته فتنة انقلب على وجهه خسر الدنيا والآخرة﴾</span></span>: فإن: الفاء عاطفة، وإن شرطية، وأصابه فعل ماض في محل جزم فعل الشرط، والهاء مفعول به، وخير فاعل، واطمأن فعل ماض في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اطمأن﴾</span></span>، وإن: معطوفة على إن الأولى، وأصابته فعل ماض في محل جزم فعل الشرط والتاء حرف تأنيث والهاء مفعول به، وفتنة فاعل، وانقلب جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿على وجهه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿خسر الدنيا والآخرة﴾</span></span> حال أيضًا من فاعل انقلب، والدنيا مفعول خسر، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك هو الخسران المبين﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، والخسران خبر هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو الخسران﴾</span></span> خبر ذلك، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل و<span class="hlt"><span class="qpc-hafs">﴿الخسران﴾</span></span> خبر ذلك، والمبين نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الخسران﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدعو من دون الله ما لا يضره وما لا ينفعه﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ويدعو فعل مضارع، وفاعله ضمير مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span>: الجار والمجرور متعلقان بمحذوف حال، وما: اسم موصول مفعول به، ولا نافية، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يضره﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما لا ينفعه﴾</span></span>: عطف على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك هو الضلال البعيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الضلال﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو الضلال﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الضلال﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿البعيد﴾</span></span> نعت للضلال، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدعو لمن ضره أقرب من نفعه لبئس المولى ولبئس العشير﴾</span></span>: الجملة بدل من جملة يدعو السابقة لا محل لها من الإعراب، ويدعو فعل مضارع، واللام للابتداء، أو واقعة في جواب القسم، ومَن اسم موصول مبتدأ، والفعل يدعو من أفعال القلوب متضمنة معنى يزعم، والخبر محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span>، وضره مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿أقرب﴾</span></span> خبر ضره، ومن نفعه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقرب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ضره أقرب من نفعه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لمن ضره أقرب من نفعه﴾</span></span> في محل نصب على المفعول به لأن لام الابتداء معلقة لها عن العمل. و<span class="hlt"><span class="qpc-hafs">﴿بئس﴾</span></span> فعل ماض جامد لإنشاء الذم، والمولى فاعل، والمخصوص بالذم محذوف تقديره: هو، ولبئس العشير معطوف على قوله: <span class="hlt"><span class="qpc-hafs">﴿لبئس المولى﴾</span></span>.</p></div>"
  22,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، إن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدخل﴾</span></span> خبر إن، والذين مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span> عطف على آمنوا، وجنات مفعول به ثان على السعة أو نصب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها النهار﴾</span></span> صفة لجنات.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يفعل ما يريد﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وهي  لتعليل ما تقدم. إن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span> خبر إن، وفاعل يفعل مستتر تقديره هو، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  22,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كان يظن أن لن ينصره الله في الدنيا والآخرة﴾</span></span>: من: شرطية في محل رفع مبتدأ. وكان: فعل ماض ناقص، واسم كان مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظن﴾</span></span> خبر كان، وأن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن ينصره الله﴾</span></span> خبر أن، وأن وما بعدها سدت مسد مفعولي يظن، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينصره﴾</span></span>، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليمدد بسبب إلى السماء ثم ليقطع فلينظر هل يذهبن كيده ما يغيظ﴾</span></span>: الفاء رابطة لجواب الشرط، واللام لام الأمر، ويمدد فعل مضارع مجزوم بلام الأمر، والفاعل مستتر تقديره هو، وبسبب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمدد﴾</span></span>، وإلى السماء جار ومجرور متعلقان بمحذوف صفة لسبب. <span class="hlt"><span class="qpc-hafs">﴿ثم ليقطع﴾</span></span>: عطف على فليمدد، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، ويذهبن فعل مضارع مبني على الفتح، وكيده فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول يذهبن، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغيظ﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿هل يذهبن﴾</span></span> في موضع نصب بـ<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>.</p></div>"
  22,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك أنزلناه آيات بينات﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: ومثل ذلك الإنزال البديع أنزلناه، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> فعل وفاعل ومفعول به، وآيات حال من الهاء في أنزلناه، وبينات صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن الله يهدي من يريد﴾</span></span>: الواو عاطفة على هاء أنزلناه، والمعنى: أنزلنا أن الله يهدي من يريد هدايته. أو الواو حالية وأن وما في حيزها في محل رفع لمبتدأ مضمر، أي: والأمر أن الله يهدي من يريد. وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span> خبر أن، ومن مفعول يهدي، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  22,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا والذين هادوا والصابئين والنصارى والمجوس والذين أشركوا إن الله يفصل بينهم يوم القيامة﴾</span></span>: إن الذين: إن حرف ناسخ، والذين اسمها، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وما بعده عطف على الذين، والجملة ابتدائية، وإن الثانية واسمها وخبرها <span class="hlt"><span class="qpc-hafs">﴿إن الله يفصل ...﴾</span></span>  في محل رفع خبر إن الأولى. وجملة <span class="hlt"><span class="qpc-hafs">﴿يفصل بينهم﴾</span></span> خبر إن الثانية، وبينهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يفصل﴾</span></span>، ويوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يفصل﴾</span></span>، والقيامة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله على كل شيء شهيد﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وعلى كل شيء جار ومجرور متعلقان بشهيد، وشهيد خبر إن، والجملة تعليلية.</p></div>"
  22,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الله يسجد له من في السماوات ومن في الأرض والشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس وكثير حق عليه العذاب﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وتر فعل مضارع مجزوم بلم، والفاعل مستتر تقديره أنت، والرؤية هنا علمية، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسجد له﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسجد﴾</span></span>، ومن فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، ومن عطف على <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> الأولى، <span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس﴾</span></span> معطوفات، ومن الناس جار ومجرور متعلقان بمحذوف صفة كثير، وأنّ وما في حيزها سدت مسد مفعولي تر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكثير حق عليه العذاب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كثير﴾</span></span> معطوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿حق عليه العذاب﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كثير﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿كثير﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿حق عليه العذاب﴾</span></span> خبر، والجملة عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يهن الله فما له من مكرم﴾</span></span>: الواو استئنافية أو عاطفة، ومن شرطية في محل نصب مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يهن﴾</span></span>، ولفظ الجلالة فاعل، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن حرف جر صلة، ومكرم مجرور بمن لفظًا مبتدأ مرفوع محلا، والجملة مستأنفة لا محل لها من الإعراب، أو معطوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يفعل ما يشاء﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يفعل خبرها، والجملة تعليلية.</p></div>"
  22,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذان خصمان اختصموا في ربهم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وهذان مبتدأ، وخصمان خبره، وجملة اختصموا صفة لخصمان. أو خصمان بدل من هذان وجملة اختصموا هي الخبر، وفي ربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اختصموا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالذين كفروا قطعت لهم ثياب من نار يصب من فوق رءوسهم الحميم﴾</span></span>: الفاء عاطفة، والذين مبتدأ، وجملة كفروا صلة الذين لا محل لها من الإعراب، وجملة قطعت خبر، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قطعت﴾</span></span>، وثياب نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من نار﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لثياب، وجملة يصب خبر ثان للاسم الموصول أو حالية من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> أو مستأنفة لا محل لها من الإعراب، ويصب فعل مضارع مبني لما لم يسمَّ فاعله، ومن فوق رءوسهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصب﴾</span></span>، والحميم نائب فاعل.</p></div>"
  22,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يصهر به ما في بطونهم والجلود﴾</span></span>: يصهر: مضارع مبني لما لم يسمَّ فاعله، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصهر﴾</span></span>، وما: نائب فاعل، وفي بطونهم: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، والجلود معطوف على ما، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصهر﴾</span></span> في محل نصب حال من الحميم.</p></div>"
  22,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولهم مقامع من حديد﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومقامع مبتدأ مؤخر، ومن حديد جار ومجرور متعلقان بمحذوف صفة لمقامع.</p></div>"
  22,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلما أرادوا أن يخرجوا منها من غم أعيدوا فيها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كلما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كلَّ﴾</span></span> نائب ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعيدوا﴾</span></span> متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية زمانية، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span> لا محل لها من الإعراب لأنها صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع مدخولها في تأويل مصدر مجرور بالإضافة والتقدير: كلَّ إرادة، وهو على تقدير مضاف محذوف، أي: كلَّ وقتِ إرادةٍ منهم للخروج. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة بمعنى <span class="hlt"><span class="qpc-hafs">﴿وقت﴾</span></span> والعائد محذوف والتقدير: كلَّ وقتٍ أرادوا فيه أن يخرجوا، فتكون جملة <span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span> فعل وفاعل، و المصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يخرجوا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من غم﴾</span></span>: بدل اشتمال من الجار والمجرور قبله لأنها تشمل عليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿أعيدوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿كلما﴾</span></span>، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعيدوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وذوقوا عذاب الحريق﴾</span></span>: الواو حرف عطف، والمعطوف محذوف تقديره: وقيل لهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذوقوا عذاب الحريق﴾</span></span> مقول القول المحذوف، وذوقوا فعل وفاعل، وعذاب مفعول به، والحريق مضاف إليه.</p></div>"
  22,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب. إن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدخل﴾</span></span> خبر إن، والذين مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span> عطف على آمنوا، وجنات مفعول به ثان على السعة أو نصب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها النهار﴾</span></span> صفة لجنات.</p><p><span class="hlt"><span class="qpc-hafs">﴿يحلون فيها من أساور من ذهب ولؤلؤا﴾</span></span>: يحلون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحلون﴾</span></span>، ومن أساور جار ومجرور متعلقان بنعت لمفعول محذوف، أي: يحلون حليا من أساور، ومن ذهب جار ومجرور متعلقان بمحذوف صفة لأساور، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحلون﴾</span></span> حال من الذين، و<span class="hlt"><span class="qpc-hafs">﴿لؤلؤًا﴾</span></span> عطف على محل <span class="hlt"><span class="qpc-hafs">﴿من أساور﴾</span></span>، لأن محلها النصب، وقيل منصوبة بفعل محذوف تقديره: ويؤتون لؤلؤًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولباسهم فيها حرير﴾</span></span>: الواو عاطفة، ولباسهم مبتدأ، وفيها حال، وحرير خبر.</p></div>"
  22,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span></span>: الواو عاطفة، وهدوا فعل ماض مبني لما لم يسمَّ فاعله والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الطيب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هدوا﴾</span></span>، ومن القول جار ومجرور متعلقان بمحذوف حال من الضمير المستكن في الطيب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهدوا إلى صراط الحميد﴾</span></span>: عطف على الجملة السابقة، وهدوا فعل ماض مبني لما لم يسمَّ فاعله والواو نائب فاعل، وإلى صراط: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هدوا﴾</span></span>، والحميد: مضاف إليه.</p></div>"
  22,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين كفروا ويصدون عن سبيل الله والمسجد الحرام الذي جعلناه للناس سواء العاكف فيه والباد﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن الذين: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة كفروا صلة الذين لا محل لها من الإعراب، ويصدون الواو حرف عطف، ويصدون عطف على كفروا، وعن سبيل الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المسجد الحرام﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿سبيل الله﴾</span></span>،  والذي صفة ثانية للمسجد، وجملة جعلناه صلة الذي لا محل لها من الإعراب، وجعلناه فعل وفاعل والهاء مفعول به، وللناس جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة وتقدم، وسواء مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span> إن كانت جعل متعدية لاثنين، وإن كانت متعدية لواحد أعربت سواء حالا من هاء جعلناه، والعاكف فاعل سواء لأنه مصدر وصف فهو في قوة اسم الفاعل المشتق، أي: جعلناه مستويا فيه العاكف ... إلخ. و<span class="hlt"><span class="qpc-hafs">﴿الباد﴾</span></span> بحذف الياء تبعا لرسم المصحف معطوف على العاكف، وخبر إن  محذوف تقديره خسروا أو هلكوا أو نحو ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، ويرد فعل الشرط، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، ومفعول يرد محذوف ليتناول كل ما يمكن تناوله، وبإلحاد حال، وبظلم حال أيضًا، ونذقه جواب الشرط، والفاعل مستتر تقديره نحن، والهاء في <span class="hlt"><span class="qpc-hafs">﴿نذقه﴾</span></span> مفعول به، ومن عذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذقه﴾</span></span>، وأليم صفة.</p></div>"
  22,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت أن لا تشرك بي شيئا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذ: اسم مبني على السكون في محل نصب مفعول به لفعل محذوف والتقدير: واذكر إذ بوأنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿بوأنا﴾</span></span> في محل جر مضاف إليه، وبوأنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لإبراهيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بوأنا﴾</span></span>، ومكان البيت مفعول بوأنا، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية لأنها واقعة بعد قول مقدر، أي: قائلين له لا تشرك. والجملة بعدها تفسيرية لا محل لها من الإعراب. ولا ناهية، وتشرك فعل مضارع مجزوم بلا الناهية، و<span class="hlt"><span class="qpc-hafs">﴿بي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشرك﴾</span></span>، وشيئًا مفعول تشرك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وطهر بيتي للطائفين والقائمين والركع السجود﴾</span></span>: الواو عاطفة، وطهر فعل أمر وفاعله مستتر تقديره أنت، وبيتي مفعول طهر، وللطائفين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طهر﴾</span></span>، والقائمين والركع عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿السجود﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿الركع﴾</span></span> مجرور مثله.</p></div>"
  22,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأذن في الناس بالحج يأتوك رجالا وعلى كل ضامر يأتين من كل فج عميق﴾</span></span>: أذن: فعل أمر، وفي الناس جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span>، وبالحج جار ومجرور متعلقان بمحذوف حال، أي: معلنًا، ويأتوك: مضارع مجزوم، لأنه وقع جوابًا للطلب، والواو فاعل، والكاف مفعول به. ورجالا حال، و<span class="hlt"><span class="qpc-hafs">﴿على كل ضامر﴾</span></span> عطف على رجالا، أي: يأتوك مشاةً وركبانًا. و<span class="hlt"><span class="qpc-hafs">﴿يأتين﴾</span></span> فعل مضارع مبني على السكون لاتصاله بنون النسوة، والنون فاعل، وجملة يأتين صفة لكل ضامر، و<span class="hlt"><span class="qpc-hafs">﴿من كل فج﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتين﴾</span></span>، وعميق صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فج﴾</span></span>.</p></div>"
  22,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليشهدوا منافع لهم ويذكروا اسم الله في أيام معلومات على ما رزقهم من بهيمة الأنعام﴾</span></span>: اللام للتعليل، ويشهدوا فعل مضارع منصوب بأن مضمرة بعدها، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل بعدها مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتوك﴾</span></span>، ومنافع مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمنافع، ويذكروا عطف على يشهدوا والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿اسم﴾</span></span> مفعول به، وفي أيام جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذكروا﴾</span></span>، ومعلومات صفة لأيام، و<span class="hlt"><span class="qpc-hafs">﴿على ما رزقهم﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذكروا﴾</span></span> أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿من بهيمة الأنعام﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكلوا منها وأطعموا البائس الفقير﴾</span></span>: الفاء الفصيحة، وكلوا فعل أمر وفاعل، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وأطعموا عطف على كلوا، والبائس مفعول به، والفقير صفة.</p></div>"
  22,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم ليقضوا تفثهم وليوفوا نذورهم وليطوفوا بالبيت العتيق﴾</span></span>: ثم حرف عطف، واللام لام الأمر، ويقضوا مضارع مجزوم بلام الأمر، وتفثهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ليوفوا نذورهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يقضوا تفثهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليطوفوا بالبيت﴾</span></span> عطف أيضأ، وبالبيت جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يطوفوا﴾</span></span>، والعتيق صفة للبيت.</p></div>"
  22,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: خبر مبتدأ محذوف، أي: الأمر والشأن ذلك، وقيل: مبتدأ محذوف الخبر، أي: ذلك الأمر الذي ذكرته، وقيل: في موضع نصب تقديره: امتثلوا ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يعظم حرمات الله فهو خير له عند ربه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويعظم فعل الشرط، وفاعله مستتر يعود على من، و<span class="hlt"><span class="qpc-hafs">﴿حرمات﴾</span></span> مفعول به، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير خبر، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بخير، وجملة <span class="hlt"><span class="qpc-hafs">﴿فهو خير﴾</span></span> في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من، وعند ربه: الظرف متعلق بمحذوف حال، وربه مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأحلت لكم الأنعام إلا ما يتلى عليكم﴾</span></span>: الواو عاطفة، وأحلت فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحلت﴾</span></span>، والأنعام نائب فاعل، وإلا أداة استثناء، وما مستثنى يجوز فيه الاتصال والانقطاع، فالانقطاع على أنه ذكر في آية المائدة ما ليس من جنس الأنعام كالدم ولحم الخنزير، والاتصال على صرفه إلى ما يحرم من الأنعام بسبب عارض كالموت ونحوه. وجملة يتلى صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ونائب الفاعل ضمير مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاجتنبوا الرجس من الأوثان واجتنبوا قول الزور﴾</span></span>: الفاء تفريع على قوله: <span class="hlt"><span class="qpc-hafs">﴿ومن يعظم حرمات الله﴾</span></span> واجتنبوا فعل أمر وواو الجماعة فاعل، والرجس مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الأوثان﴾</span></span> جار ومجرور متعلقان بمحذوف حال وقيل: تمييز، واجتنبوا: الواو عاطفة واجتنبوا فعل أمر وواو الجماعة فاعل، وقول الزور مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿اجتنبوا قول الزور﴾</span></span> معطوفة على سابقتها.</p></div>"
  22,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حنفاء لله غير مشركين به﴾</span></span>: حنفاء لله حال من ضمير اجتنبوا، وغير مشركين حال مؤكدة منه أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمشركين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يشرك بالله فكأنما خر من السماء فتخطفه الطير أو تهوي به الريح في مكان سحيق﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، ومن: اسم شرط جازم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يشرك بالله﴾</span></span> فعل الشرط. فكأنما: الفاء رابطة، وكأنما كافة ومكفوفة، وخر فعل ماض وفاعل مستتر، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خر﴾</span></span>، فتخطفه عطف على خر، والطير فاعل. <span class="hlt"><span class="qpc-hafs">﴿أو تهوي به الريح﴾</span></span>: عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تهوي﴾</span></span>، وفي مكان جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تهوي﴾</span></span> أيضًا، وسحيق نعت لمكان.</p></div>"
  22,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: خبر مبتدأ محذوف، أي: الأمر والشأن ذلك، وقيل: مبتدأ محذوف الخبر، أي: ذلك الأمر الذي ذكرته، وقيل: في موضع نصب تقديره: امتثلوا ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يعظم شعائر الله فإنها من تقوى القلوب﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويعظم فعل الشرط، وفاعله مستتر يعود على من، و<span class="hlt"><span class="qpc-hafs">﴿شعائر﴾</span></span> مفعول به، والفاء رابطة، وإنها: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من تقوى القلوب﴾</span></span> الجار والمجرور متعلقان بمحذوف خبر إن.</p></div>"
  22,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى ثم محلها إلى البيت العتيق﴾</span></span>: لكم خبر مقدم، وفيها جار ومجرور متعلقان بمحذوف حال، ومنافع مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿إلى أجل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمنافع، ومسمى صفة لأجل، وثم حرف عطف، ومحلها مبتدأ، وإلى البيت جار ومجرور متعلقان بمحذوف خبر، والعتيق صفة.</p></div>"
  22,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكل أمة جعلنا منسكا ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لكل أمة﴾</span></span> الجار والمجرور متعلقان بمحذوف مفعول جعلنا الثاني المقدم، وجعلنا فعل وفاعل، ومنسكًا مفعول جعلنا الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولكل أمة...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ليذكروا﴾</span></span>: اللام للتعليل، ويذكروا مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اسم﴾</span></span> مفعول به، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿على ما رزقهم﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذكروا﴾</span></span>، وجملة رزقهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من بهيمة الأنعام﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإلهكم إله واحد فله أسلموا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إلهكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> خبره، وواحد صفة. فله: الفاء عاطفة، وله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسلموا﴾</span></span>. واسلموا فعل أمر وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبشر المخبتين﴾</span></span>: الواو عاطفة، وبشر فعل أمر، وفاعله مستتر تقديره أنت، والمخبتين مفعول به.</p></div>"
  22,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين إذا ذكر الله وجلت قلوبهم والصابرين على ما أصابهم والمقيمي الصلاة ومما رزقناهم ينفقون﴾</span></span>: الذين نعت للمخبتين أو بدل منه، وإذا ظرف لما يستقبل من الزمن خافض لشرطه منصوب بجوابه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذكر الله﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجلت قلوبهم﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وإذا وفعلها وجوابها لا محل لها من الإعراب، لأنها صلة الذين، والصابرين عطف على الذين، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الصابرين﴾</span></span>، وجملة أصابهم صلة للموصول لا محل لها من الإعراب، والمقيمي الصلاة عطف أيضًا وحذفت النون للإضافة، ومما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفقون﴾</span></span>، وجملة رزقناهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿مما رزقناهم ينفقون﴾</span></span> معطوفة على صلة الذين لا محل لها من الإعراب.</p></div>"
  22,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والبدن جعلناها لكم من شعائر الله﴾</span></span>: الواو عاطفة، والبدن مفعول لفعل محذوف فهي منصوبة على الاشتغال، أي: وجعلنا البدن، وجعلناها فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلناها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من شعائر الله﴾</span></span> الجار والمجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلناها﴾</span></span>، التي هي بمعنى التصيير.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم فيها خير﴾</span></span>: لكم جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها جار ومجرور متعلقان بمحذوف حال، وخير مبتدأ مؤخر، والجملة مستأنفة لا محل لها من الإعراب، أو حال من الهاء في جعلناها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span></span>: الفاء الفصيحة، واذكروا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿اسم﴾</span></span> مفعول به، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكروا﴾</span></span>، وصواف حال من الهاء في عليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا وجبت جنوبها فكلوا منها وأطعموا القانع والمعتر﴾</span></span>: الفاء عاطفة، وإذا ظرف مستقبل، وجملة وجبت جنوبها في محل جر بإضافة الظرف إليها. فكلوا: الفاء رابطة لجواب إذا، وجملة كلوا منها لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وأطعموا القانع والمعتر: عطف على جملة كلوا منها، وأطعموا فعل وفاعل، والقانع مفعول به، والمعتر معطوف على القانع.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك سخرناها لكم لعلكم تشكرون﴾</span></span>: كذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: سخرها تسخيرًا مثل ذلك التسخير، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿سخرناها﴾</span></span> فعل وفاعل ومفعول به، والجملة حال، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخرناها﴾</span></span>، ولعلكم: لعل حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة تشكرون خبر لعل، والجملة في محل نصب على الحال من الكاف في <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>.</p></div>"
  22,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها ولكن يناله التقوى منكم﴾</span></span>: لن: حرف نفي ونصب واستقبال، وينال: فعل مضارع منصوب بلن، ولفظ الجلالة مفعول به مقدم، ولحومها فاعل ينال، ولا دماؤها عطف على لحومها. ولكن: الواو عاطفة، ولكن حرف استدراك مهمل، لأنه مخفف، ويناله فعل مضارع ومفعول به، والتقوى فاعل، ومنكم حال من التقوى.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك سخرها لكم لتكبروا الله على ما هداكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: سخرها تسخيرًا مثل ذلك التسخير، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وسخرها فعل ماض وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخرها﴾</span></span>، ولتكبروا: اللام للتعليل، وتكبروا فعل مضارع منصوب بأن مضمرة بعد لام التعليل وواو الجماعة فاعل، واللام وما في حيزها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخرها﴾</span></span>، ولفظ الجلالة مفعول به، وعلى حرف جر، وما مصدرية، أي: على هدايته إياكم. أو موصولة، أي: على ما هداكم إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكبروا﴾</span></span> لتضمينه معنى الشكر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبشر المحسنين﴾</span></span>: الواو استئنافية، وبشر: فعل أمر والفاعل مستتر تقديره أنت، والمحسنين مفعول بهن والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يدافع عن الذين آمنوا﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يدافع خبر إن، وعن الذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدافع﴾</span></span>، وجملة آمنوا صلة الذين لا محل لها من الإعراب، ومفعول يدافع محذوف تقديره: عوادي المشركين وغوائلهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يحب كل خوان كفور﴾</span></span>: تعليل للجملة السابقة، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يحب خبرها، وكل خوان مفعول به، وكفور صفة لخوان.</p></div>"
  22,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وأذن: فعل ماض مبني لما لم يسمَّ فاعله، والمأذون فيه محذوف للعلم به، أي: أذن للذين يقاتلون في القتال. وللذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span>، وجملة يقاتلون صلة الذين لا محل لها من الإعراب، ويقاتلون مضارع مبني لما لم يسمَّ فاعله والواو نائب فاعل، وبأنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span> أيضًا والباء للسببية، أي: بسبب ظلمهم. وأنهم: أن وسمها، وجملة ظلموا خبر أنهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله على نصرهم لقدير﴾</span></span>: الواو استئنافية، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وقدير خبر إن، وعلى نصرهم جار ومجرور متعلقان بقدير، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين أخرجوا من ديارهم بغير حق إلا أن يقولوا ربنا الله﴾</span></span>: الذين نعت أو بدل من <span class="hlt"><span class="qpc-hafs">﴿الذين يقاتلون﴾</span></span>، أو خبر لمبتدأ محذوف، وجملة أخرجوا صلة الذين لا محل لها من الإعراب، والواو في <span class="hlt"><span class="qpc-hafs">﴿أخرجوا﴾</span></span> نائب فاعل، ومن ديارهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجوا﴾</span></span>، وبغير حق حال، وإلا أداة استثناء، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يقولوا﴾</span></span> مستثنى منقطع منصوب. وقيل: الاستثناء مفرغ لوجود النفي بغير، و<span class="hlt"><span class="qpc-hafs">﴿أن يقولوا﴾</span></span> في محل جر على الإبدال من حق، وربنا مبتدأ، والله خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ربنا الله﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولولا دفع الله الناس بعضهم ببعض لهدمت صوامع وبيع وصلوات ومساجد يذكر فيها اسم الله كثيرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولولا حرف امتناع لوجود متضمن معنى الشرط، ودفع الله مبتدأ محذوف الخبر وجوبًا، والناس مفعول به لدفع، لأنه مصدر مضاف إلى فاعله وهو الله، وبعضهم بدل بعض من الناس، وببعض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دفع﴾</span></span>، واللام واقعة في جواب لولا، وهدمت فعل ماض مبني لما لم يسمَّ فاعله، وصوامع نائب فاعل <span class="hlt"><span class="qpc-hafs">﴿وبيع وصلوات ومساجد﴾</span></span> عطف على صوامع، وجملة يذكر صفة للمواضع المذكورة، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذكر﴾</span></span>، واسم الله نائب فاعل، وكثيرا صفة لمصدر محذوف، أي: ذكرًا كثيرًا، أو صفة لظرف زمان محذوف، أي: وقتًا كثيرًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولينصرن الله من ينصره﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام واقعة في جواب القسم، وينصرن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، ولفظ الجلالة فاعل، ومن موصولة مفعول به، وجملة ينصره صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لقوي عزيز﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وقوي خبر إن الأول، وعزيز خبر إن الثاني، وجملة إن وما بعدها لتعليل النصر.</p></div>"
  22,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين إن مكناهم في الأرض أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف ونهوا عن المنكر﴾</span></span>: الذين بدل من الذين السابقة، وإن شرطية، ومكناهم فعل ماض وفاعل ومفعول به وهو في محل جزم فعل الشرط، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكناهم﴾</span></span>، وأقاموا فعل ماض وفاعل، وهو في محل جزم جواب الشرط، والصلاة مفعول به، وما بعده عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولله عاقبة الأمور﴾</span></span>: الواو استئنافية أو عاطفة، ولله خبر مقدم، وعاقبة الأمور مبتدأ مؤخر، والجملة مستأنفة لا محل لها من الإعراب، أو معطوفة.</p></div>"
  22,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن يكذبوك فقد كذبت قبلهم قوم نوح وعاد وثمود﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن شرطية، ويكذبوك فعل الشرط والواو فاعل والكاف مفعول به. فقد: الفاء رابطة للجواب لاتصاله بـ<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>، وقد حرف تحقيق، وكذبت فعل ماض، والتاء تاء التأنيث الساكنة، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقد كذبت﴾</span></span> في محل جزم جواب الشرط، وقبلهم ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، وقوم نوح فاعل، وعاد وثمود: عطف على قوم نوح.</p></div>"
  22,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقوم إبراهيم﴾</span></span>: عطف على قوم نوح، الواو عاطفة، وقوم معطوف مرفوع، وإبراهيم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقوم لوط﴾</span></span>: إعرابها كإعراب وقوم إبراهيم.</p></div>"
  22,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأصحاب مدين وكذب موسى﴾</span></span>: الواو عاطفة، وأصحاب مدين عطف على قوم نوح، وكذب فعل ماض مبني لما لم يسمَّ فاعله، وموسى نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأمليت للكافرين ثم أخذتهم﴾</span></span>: الفاء عاطفة، وأمليت فعل وفاعل، وللكافرين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمليت﴾</span></span>، وثم حرف عطف للترتيب مع التراخي، وأخذتهم فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكيف كان نكير﴾</span></span>: الفاء عاطفة، وكيف اسم استفهام في محل نصب خبر كان المقدم، ونكير اسم كان.</p></div>"
  22,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكأين من قرية أهلكناها وهي ظالمة فهي خاوية على عروشها وبئر معطلة وقصر مشيد﴾</span></span>: الفاء استئنافية، وكأين خبرية ومحلها الرفع على الابتداء، ومن قرية جار ومجرور متعلقان بمحذوف تمييز كأين، وجملة أهلكناها من الفعل والفاعل والمفعول به خبر كأين. <span class="hlt"><span class="qpc-hafs">﴿وهي ظالمة﴾</span></span>: الواو للحال، وهي مبتدأ وظالمة خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فكأين من قرية...﴾</span></span> مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهي ظالمة﴾</span></span> نصب على الحال. فهي: الفاء عاطفة، وهي مبتدأ، وخاوية خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فهي خاوية﴾</span></span> معطوفة على جملة أهلكناها، وعلى عروشها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خاوية﴾</span></span> والمعنى: ساقطة على سقوفها بأن سقط السقف أولا ثم تهدمت الجدران عليه، أو متعلقان بمحذوف خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> والمعنى: خالية عن أهلها ثابتة على عروشها. وبئر عطف على قرية، أي: وكم من بئر، ومعطلة صفة لبئر، وقصر عطف أيضًا، ومشيد صفة لقصر.</p></div>"
  22,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يسيروا في الأرض فتكون لهم قلوب يعقلون بها أو آذان يسمعون بها﴾</span></span>: الهمزة للاستفهام، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولم حرف نفي وقلب وجزم، ويسيروا فعل مضارع مجزوم بلم والواو فاعله، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسيروا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فتكون﴾</span></span> الفاء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد فاء السببية، ولهم جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> المقدم، وقلوب اسمها المؤخر، وجملة يعقلون صفة لقلوب، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعقلون﴾</span></span>، وأو حرف عطف، وآذان عطف على قلوب، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسمعون بها﴾</span></span> صفة لآذان.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</span></span>: الفاء للتعليل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعمى الأبصار﴾</span></span> خبر. ولكن: الواو عاطفة، ولكن حرف استدراك أهمل لأنه خفف، و<span class="hlt"><span class="qpc-hafs">﴿تعمى القلوب﴾</span></span> فعل مضارع وفاعل، والتي صفة القلوب، وفي الصدور جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب.</p></div>"
  22,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويستعجلونك بالعذاب ولن يخلف الله وعده﴾</span></span>: الواو عاطفة، ويستعجلونك فعل مضارع وفاعل ومفعول به، وبالعذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجلونك﴾</span></span>، والواو عاطفة، ولن حرف نفي واستقبال، ويخلف فعل مضارع منصوب بلن، ولفظ الجلالة فاعل، ووعده مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يوما عند ربك كألف سنة مما تعدون﴾</span></span>: الواو للحال، وإن حرف ناسخ، ويوما اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿عند ربك﴾</span></span> الظرف متعلق بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿كألف﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿ألف﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿سنة﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لسنة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعدون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  22,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكأين من قرية أمليت لها وهي ظالمة ثم أخذتها وإلي المصير﴾</span></span>: الواو عاطفة، وكأين خبرية في محل رفع  مبتدأ، ومن قرية في محل نصب تمييز كأين، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمليت لها﴾</span></span> صفة لقرية. <span class="hlt"><span class="qpc-hafs">﴿وهي﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وظالمة خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهي ظالمة﴾</span></span> في محل نصب على الحال، وثم حرف عطف، وأخذتها فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخذتها﴾</span></span> معطوفة على أمليت. وإليَّ: الواو عاطفة أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿إليَّ﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والمصير مبتدأ مؤخر.</p></div>"
  22,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل يا أيها الناس إنما أنا لكم نذير مبين﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة مبني على الضم في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وإنما كافة ومكفوفة، وأنا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بنذير، ونذير خبر، ومبين صفة.</p></div>"
  22,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالذين آمنوا وعملوا الصالحات لهم مغفرة ورزق كريم﴾</span></span>: الفاء تفريعية، والذين مبتدأ، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وعملوا عطف على آمنوا، والصالحات مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومغفرة مبتدأ مؤخر، ورزق عطف على مغفرة، وكريم صفة لرزق، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم مغفرة﴾</span></span> خبر الذين.</p></div>"
  22,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين سعوا في آياتنا معاجزين أولئك أصحاب الجحيم﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة سعوا صلة الذين لا محل لها من الإعراب، وفي آياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سعوا﴾</span></span>، ومعاجزين حال، وأولئك مبتدأ ثان، وأصحاب الجحيم خبر المبتدأ الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب الجحيم﴾</span></span> خبر الذين.</p></div>"
  22,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلنا من قبلك من رسول ولا نبي إلا إذا تمنى ألقى الشيطان في أمنيته﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، وأرسلنا فعل وفاعل، ومن قبلك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> ومن لابتداء الغاية، ومن رسول: من صلة، ورسول مجرور لفظًا منصوب محلا على أنه مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ولا نبي: عطف على من رسول، وإلا أداة حصر، وإذا ظرف مستقبل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمنى﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألقى الشيطان﴾</span></span> لا محل لها من الإعراب، والجملة الشرطية في محل نصب على الاستثناء المنقطع، وفي أمنيته جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فينسخ الله ما يلقي الشيطان ثم يحكم الله آياته﴾</span></span>: الفاء استئنافية، وينسخ الله فعل مضارع وفاعل، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلقي الشيطان﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿فينسخ الله...﴾</span></span> مستأنفة لا محل لها من الإعراب، وثم حرف عطف، ويحكم الله فعل وفاعل، وآياته مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله عليم حكيم﴾</span></span>: الواو: استئنافية، ولفظ لجلالة مبتدأ، وعليم: خبر المبتدأ، وحكيم: خبر ثان، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليجعل ما يلقي الشيطان فتنة للذين في قلوبهم مرض والقاسية قلوبهم﴾</span></span>: اللام للتعليل، والفعل بعدها منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يُحْكِمُ﴾</span></span>، أي: ثم يحكم الله آياته ليجعل، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينسخ﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة أو مصدرية وهي مفعول به أول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلقي الشيطان﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وفتنة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لفتنة، و<span class="hlt"><span class="qpc-hafs">﴿في قلوبهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومرض مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿في قلوبهم مرض﴾</span></span> صلة للذين لا محل لها من الإعراب، والقاسية: عطف على الذين، وقلوبهم فاعل القاسية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الظالمين لفي شقاق بعيد﴾</span></span>: الواو حالية أو استئنافية، وإن حرف ناسخ، والظالمين اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في شقاق﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، وبعيد صفة لشقاق، والجملة في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  22,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وليعلم الذين أوتوا العلم أنه الحق من ربك فيؤمنوا به فتخبت له قلوبهم﴾</span></span>: الواو عاطفة، وليعلم عطف على ليجعل، والذين فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتوا العلم﴾</span></span> صلة الذين لا محل لها من الإعراب، والعلم مفعول به ثان لأوتوا، و<span class="hlt"><span class="qpc-hafs">﴿أنه الحق﴾</span></span> سدت مسد مفعولي يعلم، ومن ربهم جار ومجرور متعلقان بمحذوف حال، فيؤمنوا: عطف على يعلم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنوا﴾</span></span>. فتخبت: عطف على فيؤمنوا، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخبت﴾</span></span>، وقلوبهم فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله لهاد الذين آمنوا إلى صراط مستقيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، ولفظ الجلالة اسمها، ولهاد: اللام المزحلقة، وهاد خبر إن، والذين اسم موصول في محل جر مضاف إليه من إضافة اسم الفاعل إلى مفعوله، لأنه اسم فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب، وإلى صراط مستقيم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هاد﴾</span></span>.</p></div>"
  22,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يزال الذين كفروا في مرية منه﴾</span></span>: الواو عاطفة، ولا يزال فعل مضارع ناقص، والذين كفروا اسمها، وفي مرية جار ومجرور متعلقان بمحذوف خبرها، ومنه جار ومجرور متعلقان بمحذوف صفة لمرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى تأتيهم الساعة بغتة أو يأتيهم عذاب يوم عقيم﴾</span></span>: حتى حرف غاية وجر، وتأتيهم مضارع منصوب بأن مضمرة بعد حتى والهاء مفعول به، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بالاستقرار الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿في مرية﴾</span></span>، والساعة فاعل، وبغتة حال، وأو حرف عطف، ويأتيهم عطف على تأتيهم، و<span class="hlt"><span class="qpc-hafs">﴿عذاب يوم﴾</span></span> فاعل، وعقيم صفة.</p></div>"
  22,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الملك يومئذ لله يحكم بينهم﴾</span></span>: الملك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف متعلق بالخبر المحذوف الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، والتقدير: يوم إذ تأتيهم الساعة أو العذاب. و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكم بينهم﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالذين آمنوا وعملوا الصالحات في جنات النعيم﴾</span></span>: الفاء عاطفة، والذين مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على جملة آمنوا، و<span class="hlt"><span class="qpc-hafs">﴿في جنات النعيم﴾</span></span> الجار والمجرور متعلقان بمحذوف خبر.</p></div>"
  22,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين كفروا وكذبوا بآياتنا فأولئك لهم عذاب مهين﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذبوا بآياتنا﴾</span></span> معطوفة على جملة كفروا. فأولئك: الفاء رابطة لما في الموصول من رائحة الشرط، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، ومهين صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم عذاب مهين﴾</span></span> خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأولئك لهم عذاب مهين﴾</span></span> خبر الذين.</p></div>"
  22,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا ليرزقنهم الله رزقا حسنا﴾</span></span>: الواو عاطفة، والذين مبتدأ، وهاجروا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿هاجروا﴾</span></span> صلة الذين لا محل لها من الإعراب، وفي سبيل الله جار ومجرور ومضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هاجروا﴾</span></span>، وثم حرف عطف، وقُتِلُوا فعل ماض والواو نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قتلوا﴾</span></span> معطوفة على جملة هاجروا، وأو حرف عطف،  ماتوا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ماتوا﴾</span></span> معطوفة على جملة قتلوا. ليرزقنهم: اللام واقعة في جواب القسم، ويرزقنهم فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة والهاء مفعول به، ولفظ الجلالة فاعل، ورزقًا مفعول مطلق، وحسنًا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليرزقنهم الله ...﴾</span></span> خبر الذين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله لهو خير الرازقين﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر هو، والرازقين مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو خير الرازقين﴾</span></span> خبر إن.</p></div>"
  22,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليدخلنهم مدخلا يرضونه﴾</span></span>: اللام واقعة في جواب قسم مقدر، ويدخلنهم فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدخلنهم﴾</span></span> جواب القسم، ومدخلا مفعول به ثان، أو نائب مفعول مطلق لأنه مصدر ميمي، أو ظرف مكان، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرضونه﴾</span></span> صفة لمدخلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله لعليم حليم﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وعليم خبر إن، وحليم خبر ثان لإن.</p></div>"
  22,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: خبر مبتدأ محذوف، أي: الأمر ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن عاقب بمثل ما عوقب به ثم بغي عليه لينصرنه الله﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ومَن موصولة مبتدأ، وعاقب فعل ماض، وبمثل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاقب﴾</span></span>، وما موصول مضاف إليه، وعوقب فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عوقب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عوقب به﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وثم حرف عطف، وبغى فعل ماض مبني لما لم يسمَّ فاعله، وعليه جار ومجرور في محل رفع نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿بغي عليه﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿عاقب﴾</span></span>. لينصرنه: اللام واقعة في جواب القسم، وينصرنه فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة والهاء مفعول به، ولفظ الجلالة فاعل، والجملة القسمية خبر مَن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لعفو غفور﴾</span></span>: جملة تعليلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إن الله﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وعفو خبر إن، وغفور خبر ثان لإن.</p></div>"
  22,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأن الله يولج الليل في النهار ويولج النهار في الليل وأن الله سميع بصير﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وذلك مبتدأ، وبأن الله: الباء حرف جر للسببية، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يولج الليل في النهار﴾</span></span> خبر أن، ويولج الليل: فعل وفاعل مستتر ومفعول به، وفي النهار جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يولج﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿بأن الله ...﴾</span></span>إلخ مكونة من الجار والمجرور متعلقان بخبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>. ويولج النهار في الليل: عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿يولج الليل﴾</span></span>، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، وسميع خبر أن، وبصير خبر ثان لأن، وجملة <span class="hlt"><span class="qpc-hafs">﴿أن الله سميع بصير﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بأن الله ...﴾</span></span>.</p></div>"
  22,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأن الله هو الحق﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وذلك مبتدأ، وبأن الله: الباء حرف جر للسببية، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والحق خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والمبتدأ والخبر في محل رفع خبر أن، أو: هو ضمير فصل وما بعده خبر أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿بأن الله هو الحق﴾</span></span> مكونة من الجار والمجرور متعلقان بمحذوف خبر ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن ما يدعون من دونه هو الباطل﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، وما اسم موصول في محل نصب اسم أن، ويدعون فعل وفاعل، ومن دونه جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والباطل خبر هو، والمبتدأ والخبر في محل رفع خبر أن، أو: هو ضمير فصل وما بعده خبر أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأن ما يدعون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بأن الله ...﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن الله هو العلي الكبير﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿بأن الله ...﴾</span></span>، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعلي الكبير خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> والجملة خبر أن، أو هو ضمير فصل والعلي الكبير خبران لأن.</p></div>"
  22,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الله أنزل من السماء ماء فتصبح الأرض مخضرة﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وتر فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وفاعله مستتر تقديره أنت، وأن وما في حيزها سدت مسد مفعولي تر، لأنها علمية، وجملة أنزل خبر أن، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وماء مفعول به. فتصبح: الفاء عاطفة، وتصبح معطوف على أنزل، وتصبح فعل مضارع ناقص، والأرض اسم تصبح، ومخضرة خبرها. وقيل: تصبح تامة، والأرض فاعل، ومخضرة حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لطيف خبير﴾</span></span>: الجملة تعليل لما تقدم، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، ولطيف خبر إن، وخبير خبر ثان لإن.</p></div>"
  22,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿له ما في السماوات وما في الأرض﴾</span></span>: الجملة حالية أو مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر مقدم، وما مبتدأ مؤخر، وفي السماوات جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وما في الأرض عطف على ما في السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله لهو الغني الحميد﴾</span></span>: الواو عاطفة، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو الغني﴾</span></span> مبتدأ وخبر، والحميد خبر ثان لهو، والجملة خبر إن.</p></div>"
  22,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الله سخر لكم ما في الأرض والفلك تجري في البحر بأمره﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وتر مضارع مجزوم بلم، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، وجملة سخر خبر أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿أن الله ...﴾</span></span> سدت مسد مفعولي تر، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخر﴾</span></span>، وما مفعول سخر، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، والفلك عطف على ما، وجملة تجري حال من الفلك، وفي البحر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، وبأمره حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويمسك السماء أن تقع على الأرض إلا بإذنه﴾</span></span>: الواو عاطفة، ويمسك فعل مضارع، وفاعله مستتر تقديره هو، والسماء مفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن تقع﴾</span></span> مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿على الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقع﴾</span></span>، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بإذنه﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  22,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي أحياكم ثم يميتكم ثم يحييكم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبر، وجملة أحياكم صلة الذي لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي أحياكم﴾</span></span> مستأنفة لا محل لها من الإعراب، وثم حرف عطف للتراخي، ويميتكم فعل وفاعل مستتر ومفعول به، وثم حرف عطف وتراخ أيضًا، ويحييكم فعل مضارع مرفوع والفاعل مستتر والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الإنسان لكفور﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، تفيد التعليل لعدم الاعتبار والتبصر بعد هذه العبر والدلائل، وإن الإنسان: إن حرف ناسخ، والإنسان اسمها، واللام المزحلقة، وكفور خبر إن.</p></div>"
  22,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لكل أمة جعلنا منسكا هم ناسكوه﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكل أمة﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان مقدم لجعلنا، ومنسكًا هو المفعول الأول، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وناسكوه خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم ناسكوه﴾</span></span> صفة لمنسكًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا ينازعنك في الأمر﴾</span></span>: الفاء الفصيحة، ولا ناهية، وينازعنك فعل مضارع مجزوم بلا وعلامة جزمه حذف النون، والواو المحذوفة لالتقاء الساكنين هي واو الجماعة في محل رفع فاعل، والنون المشددة نون التوكيد الثقيلة ولم تؤثر في بناء المضارع لأنها لم تباشره، والكاف مفعول به، وفي الأمر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينازعنك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وادع إلى ربك﴾</span></span>: الواو عاطفة، وادع فعل أمر، وفاعله مستتر تقديره أنت، وإلى ربك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك لعلى هدى مستقيم﴾</span></span>: جملة تعليلية لا محل لها من الإعراب، وإنك: إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿على هدى﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، ومستقيم صفة لهدى.</p></div>"
  22,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن جادلوك فقل الله أعلم بما تعملون﴾</span></span>: الواو عاطفة، وإن شرطية، وجادلوك فعل ماض في محل جزم فعل الشرط، والواو فاعل، والكاف مفعول به. فقل: الفاء رابطة، وقل فعل أمر، والله مبتدأ، وأعلم خبر، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وتعملون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿الله أعلم بما تعملون﴾</span></span> في محل نصب مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> جواب الشرط.</p></div>"
  22,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله يحكم بينكم يوم القيامة فيما كنتم فيه تختلفون﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، والله مبتدأ، وجملة يحكم خبر، وبينكم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span>، ويوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span> أيضًا، والقيامة مضاف إليه، وفيما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span>، وجملة كنتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وكنتم: كان حرف ناسخ، والتاء اسمها، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تختلفون﴾</span></span>، وتختلفون فعل وفاعل، وجملة تختلفون خبر كنتم.</p></div>"
  22,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تعلم أن الله يعلم ما في السماء والأرض﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وتعلم فعل مضارع مجزوم، وفاعله مستتر تقديره أنت، وأن وما في حيزها سدت مسد مفعولي يعلم. وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يعلم خبر أن، وما مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في السماء﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، والأرض عطف على السماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ذلك في كتاب﴾</span></span>: جملة تعليلة لما سبق، وإن ذلك: إن حرف ناسخ، وذلك اسمها، وفي كتاب جار ومجرور متعلقان بمحذوف خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ذلك على الله يسير﴾</span></span>: جملة تعليلة أيضا، وإن حرف ناسخ، وذلك اسمها، ويسير خبر إن، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسير﴾</span></span>.</p></div>"
  22,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله ما لم ينزل به سلطانا وما ليس لهم به علم﴾</span></span>: الواو استئنافية، ويعبدون فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وما موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم ينزل﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلطانًا﴾</span></span> وتقدم، وسلطانًا مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله...﴾</span></span> مستأنفة لا محل لها من الإعراب، وما: عطف على ما الأولى، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ليس المقدم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بعلم، وعلم اسم ليس المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما للظالمين من نصير﴾</span></span>: الواو عاطفة، وما نافية، وللظالمين خبر مقدم، ومن حرف جر صلة، ونصير مجرور لفظًا مرفوع محلا مبتدأ مؤخر.</p></div>"
  22,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا تتلى عليهم آياتنا بينات تعرف في وجوه الذين كفروا المنكر﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة تتلى في محل جر بإضافة إذا إليها، وتتلى فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلى﴾</span></span>، وآياتنا نائب فاعل، وبينات حال، وجملة تعرف لا محل لها من الإعراب، لأنها جواب إذا، وفي وجوه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعرف﴾</span></span>، والذين مضاف إليه، وجملة كفروا صلة الذين لا محل لها من الإعراب، والمنكر مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يكادون يسطون بالذين يتلون عليهم آياتنا﴾</span></span>: جملة يكادون حال من الذين، أو حال من <span class="hlt"><span class="qpc-hafs">﴿وجوه﴾</span></span> لأنها يعبر بها عن أصحابها، و<span class="hlt"><span class="qpc-hafs">﴿يكادون﴾</span></span> من أفعال المقاربة، والواو اسمها، وجملة يسطون خبرها، وبالذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسطون﴾</span></span>، وجملة يتلون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلون﴾</span></span>، وآياتنا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل أفأنبئكم بشر من ذلكم النار وعدها الله الذين كفروا﴾</span></span>: قل: فعل أمر، والفاعل مستتر تقديره أنت. والجملة مستأنفة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿أفأنبئكم﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف، أي: أخاطبكم فأنبئكم. وأنبئكم: فعل مضارع، وفاعل مستتر، ومفعول به. وبِشَرٍ: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبئكم﴾</span></span>، ومن ذلكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شر﴾</span></span>. والنار: خبر لمبتدأ محذوف، أو النار: مبتدأ وخبره جملة <span class="hlt"><span class="qpc-hafs">﴿وعدها﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿النار وعدها...﴾</span></span> استئنافية، أو تفسيرية للشر المتقدم كأنه قيل: <span class="hlt"><span class="qpc-hafs">﴿ما الأكثر شرًّا من ذلك؟ فقيل: النار وعدها الله...﴾</span></span>، وعلى كلا الوجهين لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وعدها الله...﴾</span></span> إما خبر ثان للمبتدأ المحذوف، وإما خبر لـ<span class="hlt"><span class="qpc-hafs">﴿النار﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿وعدها الله﴾</span></span>: فعل ماض، ومفعول به ثان مقدم، وفاعل مؤخر. والذين: مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿وعدها﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبئس المصير﴾</span></span>: الواو استئنافية وبئس: فعل ماض جامد للذم، والمصير فاعل، والمخصوص بالذم محذوف، تقديره: هي.</p></div>"
  22,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس ضرب مثل فاستمعوا له﴾</span></span>: كلام مستأنف لا محل له من الإعراب، يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة مبني على الضم، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وضرب فعل ماض مبني لما لم يسمَّ فاعله، ومثل نائب فاعل. فاستمعوا: الفاء الفصيحة، واستمعوا فعل أمر مبني على حذف النون والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استمعوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين تدعون من دون الله لن يخلقوا ذبابا ولو اجتمعوا له﴾</span></span>: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> صلة الذين لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الذين تدعون...﴾</span></span> استئناف بياني لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن يخلقوا ذبابًا﴾</span></span> خبر إن، وذبابًا مفعول به. ولو: الواو عاطفة على محذوف هو حال، أي: انتفى خلقهم الذباب على كل حال، ولو في هذه الحال التي اجتمعوا لها. ولو شرطية، واجتمعوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اجتمعوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يسلبهم الذباب شيئا لا يستنقذوه منه﴾</span></span>: الواو عاطفة، وإن شرطية، ويسلبهم فعل الشرط والهاء مفعول به، والذباب فاعل، وشيئًا مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يستنقذوه﴾</span></span> جواب الشرط: لا نافية، ويستنقذوه فعل مضارع، وواو الجماعة فاعل، والهاء مفعول به، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستنقذوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ضعف الطالب والمطلوب﴾</span></span>: ضعف فعل ماض، والطالب فاعل، والمطلوب معطوف على الطالب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ضعف الطالب والمطلوب﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  22,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما قدروا الله حق قدره﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿قدروا الله﴾</span></span> فعل وفاعل ومفعوله، وحق: نائب عن المفعول المطلق لأنه صفته، والتقدير: ما قدروا الله قدرَه الحقَّ، وقدره: مضاف إليه وهو مضاف، والهاء: ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لقوي عزيز﴾</span></span>: جملة تعليلية، وإن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وقوي خبر إن الأول، وعزيز خبر إن الثاني.</p></div>"
  22,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله يصطفي من الملائكة رسلا ومن الناس﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، والله مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصطفي﴾</span></span> خبر، ومن الملائكة جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسلا﴾</span></span> وتقدم عليه، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصطفي﴾</span></span>، ورسلا مفعول به، ومن الناس عطف على <span class="hlt"><span class="qpc-hafs">﴿من الملائكة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله سميع بصير﴾</span></span>: جملة تعليلية، وإن حرف ناسخ، ولفظ الجلالة اسمها، وسميع خبر إن الأول، وبصير خبرها الثاني.</p></div>"
  22,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعلم ما بين أيديهم وما خلفهم﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span> خبر ثالث لإن، أو مستأنفة لا محل لها من الإعراب، ويعلم فعل مضارع، وفاعله مستتر تقديره هو، وما موصول مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بين أيديهم﴾</span></span> الظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وما خلفهم عطف على <span class="hlt"><span class="qpc-hafs">﴿ما بين أيديهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإلى الله ترجع الأمور﴾</span></span>: الواو عاطفة، وإلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجع﴾</span></span>، وترجع فعل مضارع مبني لما لم يسمَّ فاعله، والأمور نائب فاعل.</p></div>"
  22,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الذين آمنوا اركعوا واسجدوا واعبدوا ربكم وافعلوا الخير لعلكم تفلحون﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وآمنوا فعل وفاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، واركعوا فعل أمر مبني على حذف النون والواو فاعل، واسجدوا عطف على اركعوا، فعل أمر مبني على حذف النون والواو فاعل. واعبدوا: الواو عاطفة، واعبدوا فعل أمر مبني على حذف النون والواو فاعل، وربكم مفعول به، وافعلوا: الواو عاطفة، وافعلوا فعل أمر مبني على حذف النون والواو فاعل، والخير مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لعلكم تفلحون﴾</span></span> استئنافية لا محل لها من الإعراب، ولعلكم: لعل حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تفلحون﴾</span></span> خبرها.</p></div>"
  22,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاهدوا في الله حق جهاده﴾</span></span>: الواو عاطفة، وجاهدوا عطف أيضًا، وجاهدوا فعل أمر مبني على حذف النون والواو فاعل، وفي الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاهدوا﴾</span></span>، ولا بد من حذف مضاف بعد حذف مفعول جاهدوا، أي: جاهدوا أعداءكم في ذات الله ومن أجله، ففي للسببية، و<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span> نائب عن المفعول المطلق. و<span class="hlt"><span class="qpc-hafs">﴿جهاده﴾</span></span>: مضاف إليه وهو مضاف، والهاء: ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو اجتباكم وما جعل عليكم في الدين من حرج﴾</span></span>: هو مبتدأ، وجملة اجتباكم خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو اجتباكم﴾</span></span> تعليلية. وما: الواو عاطفة، وما نافية، وجعل فعل ماض، وفاعله مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، وفي الدين حال، ومن حرف جر صلة، وحرج مجرور لفظًا منصوب محلا لأنه مفعول جعل الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ملة أبيكم إبراهيم﴾</span></span>: نصب <span class="hlt"><span class="qpc-hafs">﴿ملة﴾</span></span> بمضمون ما تقدمها، كأنه قال: وسع دينكم توسعة ملة أبيكم، ثم حذف المضاف وأقيم المضاف إليه مقامه، أو منصوبة على الاختصاص، أي: أخص بالدين ملة أبيكم، أو بتقدير فعل مضمر تقديره: اتبعوا، وأبيكم مضاف إليه، وإبراهيم بدل من أبيكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو سماكم المسلمين من قبل وفي هذا ليكون الرسول شهيدا عليكم وتكونوا شهداء على الناس﴾</span></span>: هو مبتدأ وجملة سماكم خبر، والجملة حال من إبراهيم، وسماكم فعل وفاعل مستتر ومفعول به أول، والمسلمين مفعول به ثان، ومن قبل جار ومجرور متعلقان بمحذوف حال، أي: من قبل هذا الكتاب، وفي هذا عطف على من قبل، أي: وفي هذا القرآن. ليكون: اللام للتعليل أو للعاقبة، ويكون فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سماكم﴾</span></span>، والرسول اسم يكون، وشهيدًا خبر يكون، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿وتكونوا شهداء على الناس﴾</span></span> عطف على نظيرتها، وتكونوا: فعل مضارع ناقص، والواو اسمها، وشهداء خبرها، و<span class="hlt"><span class="qpc-hafs">﴿على الناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهداء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأقيموا الصلاة وآتوا الزكاة واعتصموا بالله هو مولاكم﴾</span></span>: الفاء الفصيحة، وأقيموا الصلاة فعل أمر وفاعل ومفعول به، وما بعده عطف عليه. وآتوا الزكاة فعل أمر وفاعل ومفعول به، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أقيموا الصلاة﴾</span></span>، واعتصموا فعل أمر وفاعل، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أقيموا الصلاة﴾</span></span>، وبالله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعتصموا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو مولاكم﴾</span></span> جملة حالية من الله، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ومولاكم خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنعم المولى ونعم النصير﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ونعم فعل ماض جامد لإنشاء المدح، والمولى فاعل، والمخصوص بالمدح محذوف، أي: هو، ونعم النصير عطف على نعم المولى. نعم فعل ماض جامد لإنشاء المدح، والنصير فاعل، والمخصوص بالمدح محذوف، أي: هو.</p></div>"
