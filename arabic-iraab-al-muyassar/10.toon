quran[109]{c,v,t}:
  10,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الر﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب الحكيم﴾</span></span>: تلك مبتدأ، وآيات الكتاب خبر، والحكيم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span>.</p></div>"
  10,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أكان للناس عجبا أن أوحينا إلى رجل منهم﴾</span></span>: الهمزة للاستفهام الإنكاري المشوب بالتعجب، وكان فعل ماض ناقص، وللناس جار ومجرور متعلقان بمحذوف حال، لأنه تقدم على الصفة، وعجبًا خبر كان مقدم، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span> فعل ماض وفاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن أوحينا﴾</span></span> اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿إلى رجل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لرجل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن أنذر الناس﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنذر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأنذر: فعل أمر، والفاعل مستتر تقديره: أنت، والناس: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبشر الذين آمنوا أن لهم قدم صدق عند ربهم﴾</span></span>: الواو عاطفة، وبشر معطوف على أنذر، والذين مفعول به، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وأن حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها نصب بنزع الخافض، أي: بأن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، وقدم صدق اسمها المؤخر، وعند ربهم الظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قدم صدق﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الكافرون إن هذا لساحر مبين﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الكافرون﴾</span></span> فعل وفاعل، وإن حرف ناسخ، وهذا اسمها، وساحر خبرها، واللام المزحلقة، ومبين صفة لساحر، والجملة مقول القول.</p></div>"
  10,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ربكم الله الذي خلق السماوات والأرض في ستة أيام﴾</span></span>: إن حرف ناسخ، وربكم اسمها، ولفظ الجلالة خبرها، والذي صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، وجملة خلق السماوات والأرض صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في ستة أيام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم استوى على العرش يدبر الأمر﴾</span></span>: ثم حرف عطف وتراخ، واستوى عطف على خلق، وعلى العرش جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استوى﴾</span></span>، وجملة يدبر الأمر خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو حالية، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما من شفيع إلا من بعد إذنه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية لا عمل لها، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿شفيع﴾</span></span> مجرور لفظًا مرفوع محلا على أنه مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿إذنه﴾</span></span> مضاف إليه، والهاء ضمير مبني في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلكم الله ربكم فاعبدوه أفلا تذكرون﴾</span></span>: ذلكم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> بدل، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ذلكم﴾</span></span>، والفاء الفصيحة، واعبدوه فعل أمر وفاعل ومفعول به، والهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف، ولا نافية، وتذكرون فعل مضارع أصله تتذكرون.</p></div>"
  10,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إليه مرجعكم جميعا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومرجعكم مبتدأ مؤخر، وجميعًا نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعد الله حقا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وعد﴾</span></span> مفعول مطلق لفعل محذوف. ولفظ الجلالة مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿حقًّا﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة والتقدير: حق ذلك حقا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه يبدأ الخلق ثم يعيده﴾</span></span>: إن واسمها، وجملة يبدأ خبرها، والخلق مفعول به، ثم يعيده عطف على يبدأ الخلق، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليجزي الذين آمنوا وعملوا الصالحات بالقسط﴾</span></span>: اللام للتعليل، ويجزي مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعيده﴾</span></span>، والذين مفعول يجزي، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وعملوا الصالحات عطف على آمنوا، وبالقسط جار ومجرور متعلقان بيجزي، أي: بسبب قسطهم وعدلهم، أو حال، إما من الفاعل، وإما من المفعول، أي: يجزيهم متلبسًا بالقسط، أي: عادلا، أو متلبسين به.</p><p><span class="hlt"><span class="qpc-hafs">﴿والذين كفروا لهم شراب من حميم وعذاب أليم بما كانوا يكفرون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، والذين مبتدأ، وجملة كفروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وشراب مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من حميم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لشراب، وعذاب عطف على شراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم شراب﴾</span></span> خبر الذين، وأليم صفة لعذاب، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء حرف جر سببية، وما مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> كان واسمها، وجملة يكفرون خبرها، والمصدر المؤول من ما والفعل بعدها مجرور بالباء، أي: بكفرهم، والجار والمجرور متعلقان بمحذوف صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، أو متعلقان بمحذوف خبر لمبتدأ محذوف، أي: ذلك بسبب كفرهم.</p></div>"
  10,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي جعل الشمس ضياء والقمر نورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة جعل صلة الذي لا محل لها من الإعراب، وإن كان الجعل بمعنى التصيير كانت الشمس مفعولا أولا، وضياء مفعولا ثانيًا، وإن كان الجعل بمعنى الخلق كانت الشمس مفعولا به، وضياء حال، و<span class="hlt"><span class="qpc-hafs">﴿القمر نورًا﴾</span></span> عطف عليهما.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقدره منازل لتعلموا عدد السنين والحساب﴾</span></span>: الواو عاطفة، وقدره فعل وفاعل مستتر ومفعول به، ومنازل، أي: في منازل، فهو منصوب على الظرفية، أو التقدير: ذا منازل، و<span class="hlt"><span class="qpc-hafs">﴿قدّر﴾</span></span> على هذا متعدية إلى مفعولين، لأن معناه: جعل وصير، فيكون مفعولا ثانيًا، أو يكون قدر متعديًا إلى واحد بمعنى خلق، وهو الهاء، ومنازل حال، أي: متنقلا، وقيل: الضمير منصوب بنزع الخافض، فحذف حرف الجر، أي: قدر له منازل، ومنازل مفعول به، واللام للتعليل، وتعلموا منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدره﴾</span></span>، وعدد مفعول به، والسنين مضاف إليه، والحساب معطوف على عدد.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما خلق الله ذلك إلا بالحق يفصل الآيات لقوم يعلمون﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿خلق الله ذلك﴾</span></span> فعل وفاعل ومفعول به، وإلا أداة حصر، وبالحق حال، فالاستثناء المفرغ من أعم الأحوال، أي: ما خلق ذلك إلا متلبسًا بالحق والحكمة البالغة، ولم يخلقه عبثًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفصل الآيات﴾</span></span> حال أيضًا، والآيات مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفصل﴾</span></span>، وجملة يعلمون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  10,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في اختلاف الليل والنهار وما خلق الله في السماوات والأرض لآيات لقوم يتقون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في اختلاف﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوف على اختلاف، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر معطوف على اختلاف، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> جار ومجرور متعلقان بخلق، و<span class="hlt"><span class="qpc-hafs">﴿لآيات﴾</span></span> اللام المزحلقة، وآيات اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآيات، وجملة يتقون صفة لقوم.</p></div>"
  10,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين لا يرجون لقاءنا﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة لا يرجون صلة الذين لا محل لها من الإعراب، ولقاءنا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورضوا بالحياة الدنيا واطمأنوا بها﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿لا يرجون لقاءنا﴾</span></span>، فهو داخل في حكم الصلة، أو الواو للحال، وقد مقدرة، وكذلك يقال في <span class="hlt"><span class="qpc-hafs">﴿واطمأنوا بها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم عن آياتنا غافلون﴾</span></span>: الواو عاطفة، والذين عطف على <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> المتقدمة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وعن آياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافلون﴾</span></span>، وغافلون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة صلة الموصول لا محل لها من الإعراب.</p></div>"
  10,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك مأواهم النار بما كانوا يكسبون﴾</span></span>: أولئك مبتدأ، ومأواهم مبتدأ ثان، والنار خبر الثاني، والثاني وخبره خبر أولئك، وأولئك وخبره خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء حرف جر سببية، وما مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة يكسبون خبرها، أي: بسبب كسبهم، والجار والمجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: ذلك بسبب كسبهم.</p></div>"
  10,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات يهديهم ربهم بإيمانهم﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وعملوا عطف على آمنوا، والصالحات مفعول، وجملة يهديهم ربهم خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿تجري من تحتهم الأنهار في جنات النعيم﴾</span></span>: الجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو حال من مفعول يهديهم، أو مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في جنات النعيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ثالث، أو حال ثانية، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>.</p></div>"
  10,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿دعواهم فيها سبحانك اللهم وتحيتهم فيها سلام﴾</span></span>: دعواهم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بدعواهم، أو بمحذوف حال، وسبحانك: نائب مفعول مطلق منصوب بفعل محذوف، والكاف مضاف إليه، والجملة المؤلفة منه خبر دعواهم، و<span class="hlt"><span class="qpc-hafs">﴿اللهم﴾</span></span> منادى مفرد علم، والميم المشددة عوض عن حرف النداء، وتحيتهم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحيتهم﴾</span></span>، أو بمحذوف حال، وسلام خبر تحيتهم، والمصدر يعني التحية مضاف لمفعوله، والفاعل مستتر، أي: تحية الله لهم، أو تحية الملائكة إياهم، أو مضاف لفاعله، أي: ويحيي بعضهم بعضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآخر دعواهم أن الحمد لله رب العالمين﴾</span></span>: الواو عاطفة، وآخر مبتدأ، ودعواهم مضاف إليه، وأن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، والحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، ورب العالمين صفة، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿الحمد لله...﴾</span></span> خبر أن المخففة.</p></div>"
  10,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو يعجل الله للناس الشر استعجالهم بالخير لقضي إليهم أجلهم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> حرف شرط للامتناع، و<span class="hlt"><span class="qpc-hafs">﴿يعجل﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> لفظ الجلالة فاعل مرفوع وعلامة رفعه الضمة، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعجل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الشر﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿استعجالهم﴾</span></span> نائب عن المفعول المطلق، والتقدير: تعجيلا مثل استعجالهم، فحذف المصدر وصفته المضافة وأقام المضاف إليه مقامه، و<span class="hlt"><span class="qpc-hafs">﴿بالخير﴾</span></span> جار ومجرور متعلقان بالمصدر الذي هو استعجالهم، واللام: واقعة في جواب لو، و<span class="hlt"><span class="qpc-hafs">﴿قضى﴾</span></span> فعل ماض بالبناء لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أجلهم﴾</span></span> نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنذر الذين لا يرجون لقاءنا في طغيانهم يعمهون﴾</span></span>: الفاء عاطفة، ونذر عطف على مفهوم النفي، لأن <span class="hlt"><span class="qpc-hafs">﴿لو يعجل﴾</span></span> متضمن معنى النفي للتعجيل، كأنه قيل: ولا نعجل لهم الشر، ولا نقضي إليهم أجلهم فنذر، والفاعل مستتر تقديره: نحن، والذين مفعول به، وجملة لا يرجون لقاءنا صلة الذين لا محل لها من الإعراب، وفي طغيانهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعمهون﴾</span></span>، وجملة يعمهون حال.</p></div>"
  10,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مس الإنسان الضر﴾</span></span>: الواو استئنافية، وإذا ظرف لما يستقبل من الزمن، وجملة مس مضاف إليها، والإنسان مفعول به، والضر فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿دعانا لجنبه أو قاعدا أو قائما﴾</span></span>: جملة دعانا لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، ولجنبه في محل نصب حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿دعانا﴾</span></span> بدليل ما عطف عليه من الحالين الآتيين، <span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وقاعدًا معطوف على محل لجنبه، وكذلك أو قائمًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذا مس الإنسان...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما كشفنا عنه ضره مر كأن لم يدعنا إلى ضر مسه﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، وكشفنا فعل وفاعل، وعنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وجملة مر لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> مخففة من الثقيلة، واسمها ضمير الشأن، وجملة لم يدعنا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى ضر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعنا﴾</span></span>، وجملة مسه صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ضر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك زين للمسرفين ما كانوا يعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: تزيينًا مثلَ ذلك زُيِّن للمسرفين عملُهم، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span> فعل ماض مبني على الفتح وهو مبني لما لم يُسَمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿للمسرفين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> كان فعل ناسخ، وواو الجماعة اسم كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span> خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا يعملون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  10,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أهلكنا القرون من قبلكم﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأهلكنا القرون فعل وفاعل ومفعول، ومن قبلكم جار ومجرور متعلقان بأهلكنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما ظلموا وجاءتهم رسلهم بالبينات﴾</span></span>: لما حينية، متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، أو رابطة، وظلموا فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿وجاءتهم﴾</span></span> الواو للحال بإضمار قد، وقيل: الواو للعطف على ظلموا، و<span class="hlt"><span class="qpc-hafs">﴿جاءتهم رسلهم﴾</span></span> فعل ومفعول به وفاعل، وبالبينات جار ومجرور متعلقان بجاءتهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أهلكنا القرون...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كانوا ليؤمنوا كذلك نجزي القوم المجرمين﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span>، واللام في <span class="hlt"><span class="qpc-hafs">﴿ليؤمنوا﴾</span></span> للجحود، ويؤمنوا منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف خبر كانوا، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: جزاءً مثلَ ذلك نجزي، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿القوم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿المجرمين﴾</span></span> صفة للقوم.</p></div>"
  10,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلناكم خلائف في الأرض من بعدهم﴾</span></span>: ثم حرف عطف، وجعلناكم عطف على أهلكنا، وخلائف مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لخلائف، و<span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلناكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لننظر كيف تعملون﴾</span></span>: اللام للتعليل، وننظر منصوب بأن مضمرة بعدها، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بجعلناكم، وكيف اسم استفهام في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span>، أو كيف في محل نصب على الحال، أي: على أي حالة تعملون الأعمال اللائقة بالاستخلاف.</p></div>"
  10,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا تتلى عليهم آياتنا بينات﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة تتلى مضاف إليها، وتتلى فعل مضارع بالبناء لما لم يسمَّ فاعله، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلى﴾</span></span>، وآياتنا نائب فاعل، وبينات حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين لا يرجون لقاءنا ائت بقرآن غير هذا أو بدله﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، والذين فاعل، وجملة لا يرجون صلة الذين لا محل لها من الإعراب، ولقاءنا مفعول يرجون، وجملة ائت مقول القول، وبقرآن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿غير﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قرآن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿بدله﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ائت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل ما يكون لي أن أبدله من تلقاء نفسي﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span> فعل مضارع ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها اسمها المؤخر، أو <span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span> تامة، والمصدر فاعل، <span class="hlt"><span class="qpc-hafs">﴿من تلقاء نفسي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبدله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نفسي﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أتبع إلا ما يوحى إلي﴾</span></span>: إن نافية، وأتبع فعل مضارع، وفاعله مستتر تقديره: أنا، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوحى إلي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني أخاف إن عصيت ربي عذاب يوم عظيم﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة أخاف خبرها، وإن شرطية، وعصيت فعل ماض في محل جزم فعل الشرط، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مفعول به، وعذاب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مضاف إليه، وعظيم صفة.</p></div>"
  10,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لو شاء الله ما تلوته عليكم ولا أدراكم به﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿شاء الله﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما تلوته عليكم﴾</span></span> جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تلوته﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أدراكم﴾</span></span> فعل ماض، وفاعله مستتر، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدراكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقد لبثت فيكم عمرا من قبله أفلا تعقلون﴾</span></span>: الفاء تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿عمرًا﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span> الهمزة للاستفهام الإنكاري، والفاء عاطفة على مقدر، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> معطوف على المقدر.</p></div>"
  10,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن أظلم ممن افترى على الله كذبا أو كذب بآياته﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم استفهام للنفي مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أظلم﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿ممن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أظلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿افترى﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿افترى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كذبا﴾</span></span> مفعول به للفعل افترى، أي: اختلق كذبا وافتعله، أو مفعول لأجله، أي: افترى لأجل الكذب، أو مصدر في موضع الحال، أي: افترى حال كونه كاذبا وهي حال مؤكدة. و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿كذب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿افترى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بآياته﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا يفلح المجرمون﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿المجرمون﴾</span></span> فاعل.</p></div>"
  10,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله ما لا يضرهم ولا ينفعهم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span>، أي: متجاوزين الله، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يضرهم﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا ينفعهم﴾</span></span> عطف، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون هؤلاء شفعاؤنا عند الله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿شفعاؤنا﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عند الله﴾</span></span> ظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل أتنبئون الله بما لا يعلم في السماوات ولا في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتنبئون﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أو نكرة موصوفة، وعلى كلا التقديرين العائد محذوف، أي: يعلمه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنبئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> جار ومجرور متعلقان بمحذوف حال من العائد المحذوف في <span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحانه وتعالى عما يشركون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سبحانه﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عما يشركون﴾</span></span> متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أو مصدرية.</p></div>"
  10,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان الناس إلا أمة واحدة فاختلفوا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان الناس﴾</span></span>: كان فعل ماض ناقص ناسخ، والناس اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿أمة﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، <span class="hlt"><span class="qpc-hafs">﴿فاختلفوا﴾</span></span> عطف على المعنى، أي: كان الناس جميعًا على الحق فاختلفوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولولا كلمة سبقت من ربك لقضي بينهم فيما فيه يختلفون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span> مبتدأ محذوف الخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لقضي﴾</span></span> اللام جواب لولا، وجملة <span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ونائب الفاعل مستتر تقديره الأمر، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span> أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span> وجملة <span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  10,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون لولا أنزل عليه آية من ربه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف تحضيض، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من ربه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقل إنما الغيب لله فانتظروا إني معكم من المنتظرين﴾</span></span>: الفاء واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿الغيب﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، <span class="hlt"><span class="qpc-hafs">﴿فانتظروا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿انتظروا﴾</span></span> فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المنتظرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿المنتظرين﴾</span></span>.</p></div>"
  10,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا أذقنا الناس رحمة من بعد ضراء مستهم إذا لهم مكر في آياتنا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف لما يستقبل من الزمن خافض لشرطه منصوب بجوابه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذقنا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿أذقنا﴾</span></span> فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ضراء﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿مستهم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ضراء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مكر﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿في آياتنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مكر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إذا لهم مكر﴾</span></span> جواب الشرط لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل الله أسرع مكرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أسرع﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿مكرًا﴾</span></span> تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن رسلنا يكتبون ما تمكرون﴾</span></span>: إن حرف ناسخ، ورسلنا اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكتبون﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمكرون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  10,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي يسيركم في البر والبحر﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة يسيركم صلة الذي لا محل لها من الإعراب، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في البر والبحر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسيركم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا كنتم في الفلك وجرين بهم بريح طيبة وفرحوا بها﴾</span></span>: حتى حرف غاية وجر، وإذا ظرف لما يستقبل من الزمن، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> في محل جر بإضافة الظرف إليها، والتاء اسم كان، وفي الفلك خبرها، و<span class="hlt"><span class="qpc-hafs">﴿جرين﴾</span></span> عطف، والنون للنسوة فاعل <span class="hlt"><span class="qpc-hafs">﴿جرين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بجرين، وبريح طيبة جار ومجرور متعلقان بمحذوف حال، أي: مسوقين، وطيبة صفة، وفرحوا بها عطف على <span class="hlt"><span class="qpc-hafs">﴿وجرين﴾</span></span>، أو جملة حالية من الضمير <span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> مضمرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿جاءتها ريح عاصف وجاءهم الموج من كل مكان﴾</span></span>: جملة جاءتها لا محل لها من الإعراب، لأنها جواب إذا، وريح فاعل جاءتها، وعاصف صفة، وجاءهم الموج عطف على جاءتها، و<span class="hlt"><span class="qpc-hafs">﴿من كل مكان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، أو بمحذوف حال من الموج، أي: منحدرًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وظنوا أنهم أحيط بهم﴾</span></span>: عطف على جاءهم، وأن وما في حيزها سدت مسد مفعولي ظنوا، وجملة أحيط بهم خبر <span class="hlt"><span class="qpc-hafs">﴿أنهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿دعوا الله مخلصين له الدين﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿دعوا الله﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿ظنوا﴾</span></span> بدل اشتمال، أو استئنافية مبنية على سؤال يخطر للذهن، وهو: فماذا صنعوا؟ فقيل: دعوا الله، وهي بذلك لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿دعوا الله﴾</span></span> فعل وفاعل ومفعول، ومخلصين حال، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span>، والدين مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لئن أنجيتنا من هذه لنكونن من الشاكرين﴾</span></span>: اللام موطئة للقسم، وإن شرطية، وأنجيتنا فعل وفاعل ومفعول به، وهي فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿من هذه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنجيتنا﴾</span></span>، ولنكونن جوابه، وجواب الشرط محذوف لتقدم القسم، والقسم وجوابه في محل نصب بقول مقدر، وذلك القول المقدر في محل نصب حال، والتقدير: دعو الله قائلين: لئن أنجيتنا من هذه الأهوال لنكونن من الشاكرين.</p></div>"
  10,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أنجاهم إذا هم يبغون في الأرض بغير الحق﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، وأنجاهم فعل وفاعل مستتر ومفعول به، وإذا فجائية، وهم مبتدأ، وجملة يبغون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبغون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بغير الحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس إنما بغيكم على أنفسكم﴾</span></span>: إنما كافة ومكفوفة، وبغيكم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على أنفسكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span>: منصوب على الظرف الزماني، أي: زمن متاع الحياة، أو منصوب على المصدر الواقع موقع الحال، أي: متمتعين، أو منصوب على أنه مفعول مطلق لفعل محذوف، أي: يتمتعون متاع الحياة، أو منصوب على أنه مفعول به لفعل مقدر يدل عليه المصدر، أي: يبغون متاع الحياة، أو منصوب على أنه مفعول لأجله، أي: لأجل متاع الحياة الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span>: مضاف إليه مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم إلينا مرجعكم فننبئكم بما كنتم تعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف وتراخ، و<span class="hlt"><span class="qpc-hafs">﴿إلينا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومرجعكم مبتدأ مؤخر، فننبئكم: الفاء عاطفة، وننبئكم فعل مضارع وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما كنتم تعملون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننبئكم﴾</span></span>، وجملة كنتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة تعملون خبر كنتم.</p></div>"
  10,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما مثل الحياة الدنيا كماء أنزلناه من السماء﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإنما كافة ومكفوفة، ومثل مبتدأ، والحياة مضاف إليه، والدنيا صفة، <span class="hlt"><span class="qpc-hafs">﴿كماء﴾</span></span> الكاف: اسم بمعنى مِثل مبني على الفتح في محل رفع خبر المبتدأ، وماء: مضاف إليه، وجملة أنزلناه صفة لماء، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاختلط به نبات الأرض مما يأكل الناس والأنعام﴾</span></span>: الفاء عاطفة، واختلط عطف على أنزلناه، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان باختلط، ونبات الأرض فاعل اختلط، و<span class="hlt"><span class="qpc-hafs">﴿مما يأكل الناس﴾</span></span> جار ومجرور متعلقان بمحذوف حال من نبات الأرض، وجملة يأكل الناس صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والأنعام عطف على الناس.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا أخذت الأرض زخرفها وازينت﴾</span></span>: حتى حرف غاية، وإذا ظرف لما يستقبل من الزمن متعلق بالجواب وهو أتاها، وجملة أخذت في محل جر بإضافة الظرف إليها، والأرض فاعل، وزخرفها مفعول به، وازينت عطف على أخذت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وظن أهلها أنهم قادرون عليها﴾</span></span>: الواو عاطفة، وظن عطف أيضًا، وأهلها فاعل ظن، وأن وما في حيزها سدت مسد مفعولي ظن، وقادرون خبر أن، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادرون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتاها أمرنا ليلا أو نهارا﴾</span></span>: أتاها جواب إذا، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وأمرنا فاعل، وليلا ظرف متعلق بأتاها، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ونهارًا معطوف على <span class="hlt"><span class="qpc-hafs">﴿ليلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجعلناها حصيدا كأن لم تغن بالأمس﴾</span></span>: الفاء عاطفة، وجعلناها فعل وفاعل ومفعول به أول، وحصيدًا مفعول به ثان، وكأن مخففة من الثقيلة، واسمها ضمير الشأن، وجملة لم تغن خبرها، وبالأمس جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نفصل الآيات لقوم يتفكرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: تفصيلا مثلَ ذلك نفصل الآيات، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نفصل﴾</span></span> فعل مضارع وفاعله مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿الآيات﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفصل﴾</span></span>، وجملة يتفكرون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  10,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله يدعو إلى دار السلام﴾</span></span>: الواو استئنافية، والله مبتدأ، وجملة يدعو خبر، و<span class="hlt"><span class="qpc-hafs">﴿إلى دار السلام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعو﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويهدي من يشاء إلى صراط مستقيم﴾</span></span>: الواو عاطفة، ويهدي عطف على يدعو، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، وجملة يشاء صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إلى صراط﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span>، ومستقيم صفة.</p></div>"
  10,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للذين أحسنوا الحسنى وزيادة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجملة أحسنوا صلة الذين لا محل لها من الإعراب، والحسنى مبتدأ مؤخر، <span class="hlt"><span class="qpc-hafs">﴿وزيادة﴾</span></span> عطف على الحسنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يرهق وجوههم قتر ولا ذلة﴾</span></span>: الواو مستأنفة، والجملة بعدها استئنافية لا محل لها من الإعراب، أو الواو عاطفة، وجملة يرهق وجوههم معطوفة على الحسنى، ولا بد حينئذ من تقدير <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، فإن شئت نصبت، وإن شئت رفعت، ولا نافية، ويرهق وجوههم فعل مضارع ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قتر﴾</span></span> فاعل، <span class="hlt"><span class="qpc-hafs">﴿ولا ذلة﴾</span></span> عطف على قتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب الجنة هم فيها خالدون﴾</span></span>: أولئك مبتدأ، وأصحاب خبر، والجنة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر، والجملة حالية.</p></div>"
  10,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين كسبوا السيئات جزاء سيئة بمثلها﴾</span></span>: الواو عاطفة، والذين معطوفة نسقًا على الذين الأولى، أي: للذين أحسنوا الحسنى، وللذين كسبوا السيئات جزاء سيئة بمثلها، فيتعادل التقسيم، وهذا أفضل الوجوه، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، والذين مبتدأ، خبره <span class="hlt"><span class="qpc-hafs">﴿جزاء سيئة بمثلها﴾</span></span>، وكسبوا السيئات: الجملة من الفعل والفاعل والمفعول به صلة الموصول لا محل لها من الإعراب، وجزاء مبتدأ ثان، وسيئة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بمثلها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>، أي: مقدر بمثلها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وترهقهم ذلة﴾</span></span>: الواو مستأنفة، والجملة مستأنفة لا محل لها من الإعراب، وقيل: هذه الجملة عطف على كسبوا، وقيل: الواو حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترهقهم ذلة﴾</span></span> حالية، وترهقهم فعل مضارع مرفوع، والهاء مفعول به، وذلة فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما لهم من الله من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأنما أغشيت وجوههم قطعا من الليل مظلما﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وكأنما كافة ومكفوفة، وأغشيت فعل ماض مبني لما لم يسمَّ فاعله، ووجوههم نائب فاعل، وقطعًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من الليل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قطعا﴾</span></span>، ومظلمًا حال من الليل، والعامل فيه إما <span class="hlt"><span class="qpc-hafs">﴿أغشيت﴾</span></span>، وإما أن يكون معنى الفعل في قوله: من الليل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب النار هم فيها خالدون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وأولئك مبتدأ، وأصحاب النار خبر، وهم فيها خالدون جملة اسمية حالية منهم.</p></div>"
  10,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نحشرهم جميعا﴾</span></span>: الظرف متعلق بمحذوف مفهوم من الآية السابقة، أي: نفعل ذلك كله يوم نحشرهم، وجملة نحشرهم مضاف إليها، وجميعًا نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم نقول للذين أشركوا مكانكم أنتم وشركاؤكم﴾</span></span>: ثم حرف عطف وتراخ، و<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span> معطوف على متعلق الظرف، أي: نفعل ذلك كله ثم نقول، أو معطوف على نحشرهم، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span>، وجملة أشركوا صلة الذين لا محل لها من الإعراب، ومكانكم اسم فعل أمر معناه: الزموا، وأنتم ضمير منفصل في محل رفع تأكيد للضمير في مكانكم، وشركاؤكم عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فزيلنا بينهم وقال شركاؤهم ما كنتم إيانا تعبدون﴾</span></span>: الفاء استئنافية، وزيلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بزيلنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿فزيلنا بينهم﴾</span></span> مستأنفة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿قال شركاؤهم﴾</span></span> فعل وفاعل، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وإيانا ضمير منفصل مفعول مقدم لتعبدون، وجملة تعبدون نصب خبر كنتم.</p></div>"
  10,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكفى بالله شهيدا بيننا وبينكم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وكفى فعل ماض، والباء حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل محلاًّ، وشهيدًا: منصوب على التمييز، أو على الحال، فإن كان الاسم جامدًا فالنصب على التمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنا عن عبادتكم لغافلين﴾</span></span>: إن مخففة من الثقيلة، واسمها ضمير محذوف، أي: إننا، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عن عبادتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافلين﴾</span></span>، واللام الفارقة، وهي التي أبعدت إن النافية، وغافلين خبر كنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا...﴾</span></span> في محل رفع خبر إن.</p></div>"
  10,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هنالك تبلو كل نفس ما أسلفت﴾</span></span>: هنالك اسم إشارة في محل نصب على الظرفية المكانية، وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تبلو﴾</span></span>، واللام للبعد، والكاف للخطاب، وتبلو كل نفس مضارع وفاعل، وما اسم موصول مفعول به، وجملة أسلفت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وردوا إلى الله مولاهم الحق﴾</span></span>: الواو عاطفة، وردوا فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الله﴾</span></span> جار ومجرور متعلقان بردوا، ومولاهم صفة، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، والحق صفة، لأنهم كانوا يتولون ما ليس لربوبيته حقيقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وضل عنهم ما كانوا يفترون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وضل﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span> معطوف على ردوا، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بضل، وما اسم موصول فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة كانوا يفترون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة يفترون خبر كانوا.</p></div>"
  10,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من يرزقكم من السماء والأرض﴾</span></span>: قل فعل أمر مبني على السكون، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، وجملة يرزقكم خبر، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرزقكم﴾</span></span>، والأرض عطف على السماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿أمن يملك السمع والأبصار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أمَّن﴾</span></span> أم: منقطعة بمعنى بل للإضراب الانتقالي من استفهام إلى آخر، لأنها ليست مسبوقة بهمزة استفهام ولا تسوية، ومَن اسم استفهام مبتدأ، وجملة يملك خبر، والسمع مفعول به، والأبصار عطف على السمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يخرج الحي من الميت ويخرج الميت من الحي ومن يدبر الأمر﴾</span></span>: الواو عاطفة، ومَن اسم استفهام مبتدأ، <span class="hlt"><span class="qpc-hafs">﴿يخرج الحي﴾</span></span> فعل مضارع، والفاعل مستتر، والحي مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الميت﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span></span> خبر مَن، و<span class="hlt"><span class="qpc-hafs">﴿يخرج الميت﴾</span></span> فعل مضارع، والفاعل مستتر، والميت مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الحي﴾</span></span> جار ومجرور متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span> الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرج الميت من الحي﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> الواو عاطفة، ومَن اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يدبر﴾</span></span> فعل مضارع، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿الأمر﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدبر الأمر﴾</span></span> خبر مَن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسيقولون الله﴾</span></span>: الفاء في جواب شرط مقدر، أي: إن سألتهم فسيقولون، ويقولون فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبر لمبتدأ محذوف، أي: هو الله، أو مبتدأ والخبر محذوف، والتقدير: الله يفعل هذه الأشياء كلها، والجملة من المبتدأ والخبر مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقل أفلا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> الفاء عاطفة، وقل فعل أمر، والفاعل مستتر تقديره أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> الأولى، و<span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span> الهمزة للاستفهام، والفاء عاطفة على مقدر، أي: أتعلمون ذلك فلا تتقون، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span> فعل مضارع وواو الجماعة فاعل.</p></div>"
  10,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذلكم الله ربكم الحق﴾</span></span>: الفاء عاطفة، وذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبر، وربكم بدل من الله، أو صفة، والحق صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ ثان، وربكم خبره، والجملة خبر اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فماذا بعد الحق إلا الضلال فأنى تصرفون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل رفع مبتدأ، أو  ذا موصول خبر لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الاستفهامية، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف متعلق بمحذوف حال، وإلا أداة حصر، والضلال بدل من ذا، والاستفهام بمعنى النفي أيضًا، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنى﴾</span></span> اسم استفهام بمعنى كيف في محل نصب حال من فاعل تصرفون، وتصرفون بالبناء لما لم يسمَّ فاعله فعل مضارع، والواو نائب فاعل.</p></div>"
  10,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك حقت كلمت ربك على الذين فسقوا أنهم لا يؤمنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: حقًا مثلَ ذلك حقت كلمة ربك، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، والإشارة بـ<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> إلى صرفهم عن الحق بعد الإقرار به في قوله: <span class="hlt"><span class="qpc-hafs">﴿فسيقولون الله﴾</span></span>، وقيل: الإشارة إلى الحق. <span class="hlt"><span class="qpc-hafs">﴿وحقت كلمة ربك﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فسقوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وأن وما في حيزها بدل من <span class="hlt"><span class="qpc-hafs">﴿كلمة ربك﴾</span></span>، أي: حق عليهم انتفاء الإيمان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> خبر أن.</p></div>"
  10,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل هل من شركائكم من يبدأ الخلق ثم يعيده﴾</span></span>: هل حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من شركائكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومَن موصول مبتدأ مؤخر، وجملة يبدأ الخلق صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وثم حرف عطف على يبدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل الله يبدأ الخلق ثم يعيده فأنى تؤفكون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة يبدأ الخلق خبره، والجملة الاسمية مقول القول، ثم يعيده عطف على يبدأ، والفاء عاطفة، وأنى اسم استفهام بمعنى كيف في محل نصب على الحال، وتؤفكون فعل مضارع بالبناء لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  10,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل هل من شركائكم من يهدي إلى الحق﴾</span></span>: قل فعل أمر، وهل حرف استفهام، <span class="hlt"><span class="qpc-hafs">﴿من شركائكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومَن مبتدأ مؤخر، ويهدي فعل مضارع يتعدى إلى اثنين، وحذف المفعول به الأول من الأفعال الثلاثة، والتقدير: هل من شركائكم من يهدي غيره إلى الحق؟ <span class="hlt"><span class="qpc-hafs">﴿قل الله يهدي للحق﴾</span></span>: الله مبتدأ، وجملة يهدي للحق خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفمن يهدي إلى الحق أحق أن يتبع﴾</span></span>: الهمزة للاستفهام الإنكاري، ومن مبتدأ، وأحق خبره، وأن حرف مصدري ونصب، ويتبع بالبناء لما لم يسمَّ فاعله، والمصدر المؤول من أن والفعل منصوب بنزع الخافض أو مضاف إليه بعد نزع الخافض، أي: أحق بالاتباع.</p><p><span class="hlt"><span class="qpc-hafs">﴿أمن لا يهدي إلا أن يهدى﴾</span></span>: أم عاطفة، ومن مبتدأ، وجملة لا يهدي صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وإلا أداة حصر، وأنا وما في حيزها نصب بنزع الخافض، والجار والمجرور متعلقان بمحذوف حال، فالاستثناء مفرغ من أعم الأحوال، أي: لا يهدي أو يهتدي في حال من الأحوال إلا في حال إهدائه، أي: إهداء الآخرين إياه، والخبر محذوف تقديره: أحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما لكم كيف تحكمون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما استفهامية مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، وكيف اسم استفهام في محل نصب على الحال، وتحكمون فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحكمون﴾</span></span> حال من ضمير الخطاب في <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>.</p></div>"
  10,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يتبع أكثرهم إلا ظنا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، ويتبع أكثرهم فعل وفاعل، وإلا أداة حصر، وظنًّا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الظن لا يغني من الحق شيئا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والظن اسمها، وجملة لا يغني خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من الحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال مقدمة، وشيئًا نائب عن المفعول المطلق، أي: شيئًا من الإغناء، أو مفعول به بتضمين يغني معنى يدفع.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله عليم بما يفعلون﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وعليم خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span>، وجملة يفعلون لا محل لها من الإعراب، لأنها صلة ما، سواء كانت موصولة، أو مصدرية.</p></div>"
  10,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان هذا القرآن أن يفترى من دون الله﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، وكان فعل ماض ناقص ناسخ، وهذا اسمها، والقرآن بدل من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، وأن وما في حيزها خبر كان، أي: افتراء.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن تصديق الذي بين يديه﴾</span></span>: الواو عاطفة، ولكن مخففة مهملة، وتصديق معطوف على افتراء المؤولة، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، ويديه مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتفصيل الكتاب﴾</span></span>: الواو عاطفة، وتفصيل: عطف على تصديق.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا ريب فيه﴾</span></span>: ولا نافية للجنس، وريب اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب العالمين﴾</span></span>: جار ومجرور متعلقان بمحذوف حال. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ريب فيه﴾</span></span> حالية، وجاز مجيء الحال من المضاف إليه لأنه مفعول في المعنى. والمعنى: وتفصيل الكتاب منتفيًا عنه الريب. وقيل: إنها مستأنفة، لا محل لها من الإعراب. وقيل: إنها اعتراضية بين <span class="hlt"><span class="qpc-hafs">﴿تصديق﴾</span></span> وبين <span class="hlt"><span class="qpc-hafs">﴿من رب العالمين﴾</span></span>، لا محل لها من الإعراب، والتقدير: ولكن تصديق الذين بين يديه من رب العالمين.</p></div>"
  10,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون افتراه﴾</span></span>: أم عاطفة منقطعة فهي بمعنى: بل وهمزة الاستفهام، والتقدير: بل أيقولون افتراه؟ والهمزة للاستفهام الإنكاري، أو <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> متصلة، وحينئذ فلا بد من تقدير جملة ليصح التعادل، والتقدير: أيقرون به أم يقولون: افتراه؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿افتراه﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل فأتوا بسورة مثله﴾</span></span>: الفاء الفصيحة، وائتوا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بسورة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثله﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وادعوا من استطعتم من دون الله إن كنتم صادقين﴾</span></span>: الواو عاطفة، وادعوا عطف على فائتوا، والواو فاعل، ومن اسم موصول مفعول به، وجملة استطعتم صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وإن شرطية، وكنتم فعل الشرط، والتاء اسم كان، وصادقين خبر كان، وجواب الشرط محذوف، أي: فائتوا وادعوا.</p></div>"
  10,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل كذبوا بما لم يحيطوا بعلمه ولما يأتهم تأويله﴾</span></span>: بل حرف إضراب وعطف، وكذبوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، وجملة لم يحيطوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والواو للحال، والجملة في محل نصب على الحال، أي: كذبوا به حال كونهم لم يفهموا ما كذبوا به، ولا بلغته عقولهم، ولما حرف جازم، و<span class="hlt"><span class="qpc-hafs">﴿يأتهم﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿تأويله﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿يأتهم﴾</span></span>، أو الواو للعطف، والجملة معطوفة على لم يحيطوا، فتكون داخلة في حكم الصلة، أي: بل كذبوا بما لم يحيطوا بعلمه وبما لم يأتهم تأويله.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك كذب الذين من قبلهم فانظر كيف كان عاقبة الظالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: تكذيبًا مثلَ ذلك التكذيب كذَّب الذين من قبلهم، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿كذب الذين﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب، فانظر: الفاء عاطفة على محذوف، أي: فأهلكنا فانظر، وكيف اسم استفهام في موضع نصب على أنه خبر كان، ولا يصح أن يعمل فيه الفعل <span class="hlt"><span class="qpc-hafs">﴿فانظر﴾</span></span>، لأن ما قبل الاستفهام لا يعمل فيه، وعاقبة اسمها، والظالمين مضاف إليه.</p></div>"
  10,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومنهم من يؤمن به ومنهم من لا يؤمن به وربك أعلم بالمفسدين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومَن مبتدأ مؤخر، وجملة يؤمن به صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وجملة ومنهم من لا يؤمن عطف على الجملة السابقة، وربك مبتدأ، وأعلم خبر، وبالمفسدين جار ومجرور متعلقان بأعلم.</p></div>"
  10,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كذبوك فقل لي عملي ولكم عملكم﴾</span></span>: الواو عاطفة، وإن شرطية، وكذبوك فعل وفاعل ومفعول به، وهو في محل جزم فعل الشرط، <span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> الفاء رابطة، لأن ما بعدها جملة طلبية، وقل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعملي مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لكم عملكم﴾</span></span> عطف، وجملة لي عملي في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنتم بريئون مما أعمل﴾</span></span>: أنتم مبتدأ، وبريئون خبر، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بريئون﴾</span></span>، وجملة أعمل صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا بريء مما تعملون﴾</span></span>: عطف على ما تقدم.</p></div>"
  10,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومنهم من يستمعون إليك﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومَن مبتدأ مؤخر، ويستمعون صفة لمن إذا كانت نكرة موصوفة، أي: ناس يستمعون، وصلة إذا كانت موصولة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفأنت تسمع الصم﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأنت ضمير في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو كانوا لا يعقلون﴾</span></span>: الواو عاطفة، ولو حرف شرط غير جازم، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة لا يعقلون خبرها.</p></div>"
  10,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومنهم من ينظر إليك﴾</span></span>: الواو عاطفة على ما سبق، <span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، وحمل الضمير هنا على لفظ مَن، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفأنت تهدي العمي ولو كانوا لا يبصرون﴾</span></span>: عطف على ما تقدم، وجواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> في الجملتين محذوف لدلالة قوله: <span class="hlt"><span class="qpc-hafs">﴿أفأنت تسمع الصم﴾</span></span> وقوله: <span class="hlt"><span class="qpc-hafs">﴿أفأنت تهدي العمي﴾</span></span>، وكل منهما معطوف على جملة مقدرة قابلة لها، وكلتاهما في موضع الحال من مفعول الفعل السابق، أي: أفأنت تسمع الصم لو كانوا يعقلون ولو كانوا لا يعقلون، أفأنت تهدي العمي لو كانوا يبصرون ولو كانوا لا يبصرون، أي: لا تسمعهم ولا تهديهم على كل حال.</p></div>"
  10,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يظلم الناس شيئا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> اسمها، وجملة لا يظلم خبرها، والناس مفعول به، وشيئًا نائب عن المفعول المطلق، أي: شيئًا من الظلم، أو مفعول ثانٍ ليظلم، بمعنى: لا ينقص الناس شيئًا من أعمالهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن الناس أنفسهم يظلمون﴾</span></span>: الواو حالية، ولكن حرف استدراك ونصب، والناس اسمها، وأنفسهم مفعول مقدم ليظلمون، وجملة يظلمون خبر لكن.</p></div>"
  10,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يحشرهم كأن لم يلبثوا إلا ساعة من النهار﴾</span></span>: الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتعارفون﴾</span></span>، وجملة يحشرهم مضاف إليها، وكأن مخففة من الثقيلة، واسمها ضمير الشأن، وجملة لم يلبثوا خبر كأن، وجملة لم يلبثوا جملة حالية من الهاء في يحشرهم، وإلا أداة حصر، وساعة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يلبثوا﴾</span></span>، ومن النهار صفة لساعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يتعارفون بينهم﴾</span></span>: الجملة حالية من الواو في يلبثوا، فتكون حالًا متداخلة، أو من الضمير في يحشرهم، فتكون حالًا مترادفة، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتعارفون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد خسر الذين كذبوا بلقاء الله﴾</span></span>: قد حرف تحقيق، وخسر الذين فعل وفاعل، وجملة كذبوا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بلقاء الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد خسر...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كانوا مهتدين﴾</span></span>: الواو عاطفة، وما نافية، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، ومهتدين خبرها، وهي معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قد خسر﴾</span></span>، أو على صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>.</p></div>"
  10,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإما نرينك بعض الذي نعدهم أو نتوفينك﴾</span></span>: إن شرطية، وما صلة، ونرينك فعل مضارع مبني على الفتح في محل جزم فعل الشرط، والفاعل ضمير مستتر تقديره: نحن، والكاف مفعول به، وبعض مفعول ثان، والذي مضاف إليه، وجملة نعدهم صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ونتوفينك عطف على نرينك.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإلينا مرجعهم ثم الله شهيد على ما يفعلون﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿إلينا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومرجعهم مبتدأ مؤخر، والجملة جواب الشرط، ثم حرف عطف، لا للترتيب الزماني، بل لترتيب الأخبار، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وشهيد خبر، و<span class="hlt"><span class="qpc-hafs">﴿على ما يفعلون﴾</span></span> جار ومجرور متعلقان بشهيد، وجملة يفعلون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  10,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكل أمة رسول﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وأمة مضاف إليه، ورسول مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء رسولهم قضي بينهم بالقسط وهم لا يظلمون﴾</span></span>: الفاء عاطفة على صفة رسول، أي: يُبعث إليهم فإذا، وإذا طرف مستقبل، وجملة جاء رسولهم مضاف إليها، وجملة قضي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بقضي، و<span class="hlt"><span class="qpc-hafs">﴿بالقسط﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل قضي، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو حرف عطف، أو حالية، وهم مبتدأ، وجملة لا يظلمون خبر.</p></div>"
  10,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون متى هذا الوعد إن كنتم صادقين﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، ويقولون فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿متى﴾</span></span> استفهام عن الزمان متعلق بمحذوف خبر مقدم، وهذا مبتدأ مؤخر، والوعد بدل، وإن شرطية، وكنتم فعل الشرط، والتاء اسم كان، وصادقين خبرها، والجواب محذوف، أي: فمتى هذا الوعد؟</p></div>"
  10,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لا أملك لنفسي ضرا ولا نفعا إلا ما شاء الله﴾</span></span>: جملة لا أملك مقول القول، ولنفسي جار ومجرور متعلقان بأملك، وضرًّا مفعول به، ولا نفعًا عطف على <span class="hlt"><span class="qpc-hafs">﴿ضرًّا﴾</span></span>، وإلا أداة استثناء أو حصر لوجود النفي، وما اسم موصول مستثنى، قيل: الاستثناء متصل، وقيل: منقطع، وإذا كانت <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> حصرًا فـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿ضرًّا﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿نفعا﴾</span></span>، وجملة شاء الله صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكل أمة أجل﴾</span></span>: تتمة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span> خبر مقدم، وأمة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أجل﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا جاء أجلهم فلا يستأخرون ساعة ولا يستقدمون﴾</span></span>: إذا ظرف مستقبل، وجملة جاء مضاف إليها، وأجلهم فاعل جاء، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، وجملة يستأخرون لا محل لها من الإعراب، لأنها جواب إذا، وساعة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يستأخرون﴾</span></span>، ولا يستقدمون عطف على فلا يستأخرون.</p></div>"
  10,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم إن أتاكم عذابه بياتا أو نهارا﴾</span></span>: قل فعل أمر، وفاعله: أنت، أي: محمد صلى الله عليه وسلم، وجملة أرأيتم مقول القول، وأرأيتم: الهمزة للاستفهام، ورأى فعل ماض مبني على السكون، والتاء فاعل، وأرأيتم هنا بمعنى أخبروني وتتعدى لمفعولين، المفعول الأول لها محذوف، ولا يصح أن تقع جملة الشرط موقعه، وإن شرطية، وأتاكم فعل ماض في محل جزم فعل الشرط، والجواب جملة الاستفهام على تقدير الفاء في الجملة الاسمية، وبياتًا منصوب على الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أتاكم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أو نهارًا﴾</span></span> عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماذا يستعجل منه المجرمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول في محل رفع خبر المبتدأ، والمعنى: ما الذي يستعجل منه المجرمون، ويستعجل فعل مضارع، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجل﴾</span></span>، والمجرمون فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستعجل﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يستعجل﴾</span></span>. والجملة الاستفهامية في محل نصب مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span>.</p></div>"
  10,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أثم إذا ما وقع آمنتم به آلآن وقد كنتم به تستعجلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أثم﴾</span></span> الهمزة للاستفهام الإنكاري، وثم: حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> صلة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span> في محل جر بالإضافة إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنتم به﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿آلآن﴾</span></span> الهمزة للاستفهام الإنكاري، والآن ظرف متعلق بمحذوف يفهم من سياق الكلام، تقديره: آلآن به تؤمنون، <span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span> الواو: حالية، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسم كان، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستعجلون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تستعجلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>.</p></div>"
  10,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم قيل للذين ظلموا ذوقوا عذاب الخلد هل تجزون إلا بما كنتم تكسبون﴾</span></span>: ثم: حرف عطف. و<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>: فعل ماض مبني لما لم يسمَّ فاعله. و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿ذوقوا﴾</span></span> في محل رفع نائب فاعل. وعذاب: مفعول به. والخلد: مضاف إليه. وهل: حرف استفهام. وتجزون: فعل مضارع، ونائب فاعل. وإلا: أداة حصر. و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿تكسبون﴾</span></span> خبر كان.</p></div>"
  10,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويستنبئونك أحق هو قل إي وربي﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ويستنبئونك فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أحق﴾</span></span> الهمزة للاستفهام الإنكاري المشوب بالاستهزاء، وحق خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ مؤخر، والجملة في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يستنبئونك﴾</span></span>، وقيل: الجملة في محل نصب بـ<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يستنبئونك﴾</span></span> متعدية لواحد، وأصل استنبأ أن يتعدى إلى مفعولين، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿إي﴾</span></span> حرف جواب، وربي الواو للقسم، وربي مجرور بواو القسم، والجار والمجرور متعلقان بفعل القسم المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لحق وما أنتم بمعجزين﴾</span></span>: إن حرف ناسخ، والهاء اسمها، واللام المزحلقة، والواو حرف عطف على جواب القسم، أو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمعجزين﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿معجزين﴾</span></span> خبر ما منصوب محلا ومجرور بالباء لفظًا.</p></div>"
  10,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو أن لكل نفس ظلمت ما في الأرض لافتدت به﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية امتناعية، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span> خبر أن المقدم، ونفس مضاف إليه، وجملة ظلمت صفة لنفس، وما اسم موصول في محل نصب اسم أن، وأن وما في حيزها فاعل لفعل محذوف، أي: لو ثبت ذلك، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، واللام واقعة في جواب لو، وافتدت به جملة فعلية لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأسروا الندامة لما رأوا العذاب﴾</span></span>: الواو عاطفة، وأسروا الندامة فعل وفاعل ومفعول به، ولما رابطة، أو حينية، وجملة رأوا مضاف إليها، والواو فاعل، والعذاب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقضي بينهم بالقسط﴾</span></span>: الكلام مستأنف لا محل له من الإعراب، أو معطوف، وقضي فعل ماض بالبناء لما لم يسمَّ فاعله، ونائب الفاعل مستتر، وبينهم ظرف متعلق بقضي، وبالقسط حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يظلمون خبر.</p></div>"
  10,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن لله ما في السماوات والأرض﴾</span></span>: ألا أداة تنبيه، واستفتاح، ولله خبر إن المقدم، وما اسمها المؤخر، وفي السماوات والأرض صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن وعد الله حق﴾</span></span>: ألا تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> الأولى، وإن واسهما، وحق خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم لا يعلمون﴾</span></span>: الواو حالية والجملة بعدها في محل نصب حال، أو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولكن حرف ناسخ، وأكثرهم اسمها، وجملة لا يعلمون خبرها.</p></div>"
  10,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو يحيي ويميت وإليه ترجعون﴾</span></span>: هو مبتدأ، وجملة يحيي خبر، وجملة يميت عطف، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>.</p></div>"
  10,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس﴾</span></span>: يا حرف نداء للمتوسط، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جاءتكم موعظة من ربكم﴾</span></span>: قد حرف تحقيق، وجاءتكم موعظة فعل ومفعول به وفاعل، ومن ربكم صفة لموعظة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبعيض، أو متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿جاءتكم﴾</span></span> فتكون للابتداء.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشفاء لما في الصدور وهدى ورحمة للمؤمنين﴾</span></span>: الواو عاطفة، وشفاء عطف على موعظة، و<span class="hlt"><span class="qpc-hafs">﴿لما في الصدور﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لشفاء، أو اللام حرف صلة، وما اسم موصول مفعول به، وفي الصدور صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وهدى ورحمة معطوفان أيضًا، وللمؤمنين صفة.</p></div>"
  10,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل بفضل الله وبرحمته فبذلك فليفرحوا هو خير مما يجمعون﴾</span></span>: الجار والمجرور متعلقان بمحذوف، وأصل الكلام: ليفرحوا بفضل الله وبرحمته فبذلك، والفاء لإفادة معنى السببية، أي: بفضل الله وبرحمته فليفرحوا، والفاء الأولى جزائية، والثانية للسببية، <span class="hlt"><span class="qpc-hafs">﴿فبذلك﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿بذلك﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بفضل الله﴾</span></span>، وقيل: الفاء الداخلة على <span class="hlt"><span class="qpc-hafs">﴿بذلك﴾</span></span> صلة، و<span class="hlt"><span class="qpc-hafs">﴿بذلك﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿بفضل﴾</span></span>، أما الفاء الداخلة على <span class="hlt"><span class="qpc-hafs">﴿فليفرحوا﴾</span></span> فهي الفصيحة، لأنها داخلة لمعنى الشرط، كأنه قيل: إن فرحوا بشيء فليخصوها بالفرح، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير خبر، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بخير، ويجمعون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  10,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم ما أنزل الله لكم من رزق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> الهمزة للاستفهام، ورأى فعل ماض مبني على السكون، والتاء فاعل، <span class="hlt"><span class="qpc-hafs">﴿ما أنزل الله﴾</span></span> ما اسم موصول مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span>، أو لـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وجملة أنزل صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: أنزله الله، أو ما استفهامية في محل نصب بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وهي حينئذ معلقة لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> عن العمل، أو ما استفهامية في محل رفع بالابتداء، وجملة <span class="hlt"><span class="qpc-hafs">﴿آلله أذن لكم﴾</span></span> خبر، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، ومن رزق حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجعلتم منه حراما وحلالا قل آلله أذن لكم أم على الله تفترون﴾</span></span>: فجعلتم عطف على أنزل، وجعلتم فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلتم﴾</span></span>، وحرامًا مفعول جعلتم، وحلالًا عطف، <span class="hlt"><span class="qpc-hafs">﴿آلله﴾</span></span> الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة أذن خبره، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> منقطعة بمعنى: بل والهمزة، والتقدير: بل أتفترون على الله؟ والاستفهام للإنكار، أو متصلة، والتقدير: أي الأمرين وقع، إذن الله لكم في ذلك أم افتراؤكم عليه؟ ولعل اتصالها أظهر، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>.</p></div>"
  10,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ظن الذين يفترون على الله الكذب يوم القيامة﴾</span></span>: الواو عاطفة، وما استفهامية مبتدأ، وظن خبرها، والذين مضاف إليه، وجملة يفترون صلة الذين لا محل لها من الإعراب، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، والكذب مفعول به، ويوم القيامة ظرف متعلق بالظن، فمفعولا الظن سدت مسدهما أن المقدرة وما بعدها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لذو فضل على الناس ولكن أكثرهم لا يشكرون﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وذو فضل خبرها، وعلى الناس جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولكن﴾</span></span> الواو حالية والجملة بعدها في محل نصب، أو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولكن حرف ناسخ، وأكثرهم اسمها، وجملة لا يشكرون خبرها.</p></div>"
  10,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تكون في شأن وما تتلو منه من قرآن﴾</span></span>: الواو عاطفة، وما نافية، وتكون فعل مضارع ناقص ناسخ، واسم تكون مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿في شأن﴾</span></span> خبر تكون، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> الواو عاطفة، وما نافية، وتتلو فعل مضارع، وفاعله مستتر تقديره: أنت، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلو﴾</span></span>، والضمير يعود إلى القرآن، أو إلى الشأن، فتكون من تعليلية، أي: من أجل الشأن الذي كنت مسترسلًا فيه، ومن حرف صلة، وقرآن مفعول به محلاّ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تعملون من عمل إلا كنا عليكم شهودا إذ تفيضون فيه﴾</span></span>: الواو عاطفة، ولا تعملون عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span> مجرور لفظا مفعول به محلا، أو مفعول مطلق، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم كا، وعليكم جار ومجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿شهودًا﴾</span></span>، أي: شاهدين، وشهودًا خبر كنا، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿شهودًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تفيضون﴾</span></span> في محل جر بإضافة الظرف إليها، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفيضون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يعزب عن ربك من مثقال ذرة في الأرض ولا في السماء﴾</span></span>: الواو حرف عطف، وما نافية، وعن ربك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعزب﴾</span></span>، ومن حرف صلة، ومثقال ذرة فاعل يعزب محلاًّ، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿مثقال ذرة﴾</span></span>، أو صفة، ولا في السماء عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا أصغر من ذلك ولا أكبر إلا في كتاب مبين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولا نافية للجنس، وأصغر اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من ذلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أصغر﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا أكبر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ولا أصغر﴾</span></span>، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في كتاب مبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، ومبين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>.</p></div>"
  10,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن أولياء الله لا خوف عليهم﴾</span></span>: ألا حرف تنبيه، و<span class="hlt"><span class="qpc-hafs">﴿إن أولياء الله لا خوف عليهم﴾</span></span>: إن حرف ناسخ، وأولياء اسمها، ولا نافية، خوف مبتدأ وساغ الابتداء به وهو نكرة لنفيه، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا خوف عليهم﴾</span></span> في محل رفع خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم يحزنون﴾</span></span>: الواو حرف عطف، ولا نافية، وهم مبتدأ، ويحزنون: فعل مضارع مرفوع بثبوت النون وواو الجماعة فاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿يحزنون﴾</span></span> في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  10,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين آمنوا وكانوا يتقون﴾</span></span>: الذين منصوب على أنه صفة <span class="hlt"><span class="qpc-hafs">﴿أولياء الله﴾</span></span>، أو  خبر لمبتدأ محذوف، أي: هم الذين آمنوا، أو مبتدأ، والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿لهم البشرى﴾</span></span> الآتية، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وكانوا يتقون عطف على الصلة، وجملة يتقون خبر كان.</p></div>"
  10,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم البشرى في الحياة الدنيا﴾</span></span>: لهم خبر مقدم، والبشرى مبتدأ مؤخر، وفي الحياة جار ومجرور متعلقان بمحذوف حال من البشرى، والعامل في الحال الاستقرار في <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>، والدنيا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم البشرى﴾</span></span> مستأنفة لا محل لها من الإعراب، أو في محل رفع خبر إذا جعلت <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> في الآية السابقة مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وفي الآخرة﴾</span></span>: الواو عاطفة، وفي الآخرة عطف على <span class="hlt"><span class="qpc-hafs">﴿في الحياة الدنيا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تبديل لكلمات الله﴾</span></span>: لا نافية للجنس، وتبديل اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكلمات﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تبديل...﴾</span></span> استئنافية، لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك هو الفوز العظيم﴾</span></span>: ذلك مبتدأ، وهو مبتدأ ثان، الفوز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر ذلك، والعظيم صفة الفوز. وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك هو...﴾</span></span> استئنافية، لا محل لها من الإعراب.</p></div>"
  10,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يحزنك قولهم إن العزة لله جميعا هو السميع العليم﴾</span></span>: الواو حرف عطف، ولا ناهية، ويحزنك فعل مضارع مجزوم بلا، والكاف مفعول به، وقولهم فاعل، وإن حرف ناسخ، والعزة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> خبر إن، وجميعًا حال من العزة، أو توكيد، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والسميع خبره الأول، والعليم خبره الثاني.</p></div>"
  10,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن لله من في السماوات ومن في الأرض﴾</span></span>: ألا حرف تنبيه، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> خبرها المقدم، ومَن اسمها المؤخر، وفي السماوات صلة مَن  لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من في الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من في السماوات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يتبع الذين يدعون من دون الله شركاء﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿يتبع الذين﴾</span></span> فعل مضارع وفاعل، وجملة يدعون صلة الذين لا محل لها من الإعراب، ومن دون الله حال من شركاء لتقدمه عليه، وشركاء مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يتبع﴾</span></span>، ومفعول يدعون محذوف لفهم المعنى، والتقدير: وما يتبع الذين يدعون من دون الله آلهة شركاء، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية منصوبة بما بعدها، أي: ما يتبع؟ أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة معطوفة على من، كأنه يقول: ولله ما يتبعه الذين يدعون من دون الله شركاء، أي: وله شركاؤهم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الموصولة هذه في محل رفع بالابتداء، والخبر محذوف، تقديره: والذي يتبعه المشركون باطل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يتبعون إلا الظن﴾</span></span>: إن نافية، ويتبعون فعل وفاعل، وإلا أداة حصر، والظن مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن هم إلا يخرصون﴾</span></span>: إن نافية أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وإلا أداة حصر، وجملة يخرصون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  10,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي جعل لكم الليل لتسكنوا فيه والنهار مبصرا﴾</span></span>: هو مبتدأ، والذي خبر، وجملة جعل صلة الموصول لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والليل مفعول به، <span class="hlt"><span class="qpc-hafs">﴿لتسكنوا﴾</span></span> اللام للتعليل، وتسكنوا منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور إما متعلقان بمحذوف مفعول لأجله، أو مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسكنوا﴾</span></span>، والنهار عطف على الليل، ومبصرًا حال، أو مفعول به ثان إذا كانت <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> بمعنى التصيير فتتعدى لمفعولين.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يسمعون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، واللام المزحلقة، وآيات اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآيات، وجملة يسمعون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  10,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا اتخذ الله ولدا سبحانه﴾</span></span>: قالوا فعل وفاعل، واتخذ الله ولدًا فعل وفاعل ومفعول به، والجملة مقول القول، وسبحانه: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو الغني له ما في السماوات وما في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والغني خبره، وله خبر مقدم، وما مبتدأ مؤخر، وفي السماوات صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وما في الأرض عطف على ما في السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن عندكم من سلطان بهذا﴾</span></span>: إن نافية، وعندكم ظرف متعلق بمحذوف خبر مقدم، ومن حرف صلة، وسلطان مبتدأ مؤخر مرفوع محلاًّ مجرور لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتقولون على الله ما لا تعلمون﴾</span></span>: الهمزة للاستفهام الإنكاري، وتقولون فعل مضارع وفاعل، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة لا تعلمون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  10,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إن الذين يفترون على الله الكذب لا يفلحون﴾</span></span>: قل فعل أمر، وفاعله تقديره: أنت، <span class="hlt"><span class="qpc-hafs">﴿إن الذين﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة يفترون صلة الذين لا محل لها من الإعراب، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، والكذب مفعول به، وجملة لا يفلحون خبر إن.</p></div>"
  10,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متاع في الدنيا ثم إلينا مرجعهم ثم نذيقهم العذاب الشديد بما كانوا يكفرون﴾</span></span>: متاع خبر لمبتدأ محذوف، أي: ذاك، أو: هو، <span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> صفة، أو <span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span> مبتدأ، وخبره محذوف، والتقدير: لهم متاع، وثم حرف عطف وتراخ، وإلينا خبر مقدم، ومرجعهم مبتدأ مؤخر، ثم حرف عطف، ونذيقهم فعل وفاعل مستتر ومفعول به أول، والعذاب مفعول به ثان، والشديد صفة، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء حرف جر للسببية، وما مصدرية، أي: بسبب كونهم كافرين، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذيقهم﴾</span></span>.</p></div>"
  10,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتل عليهم نبأ نوح إذ قال لقومه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واتل فعل أمر مبني على حذف حرف العلة، وفاعله: أنت، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتل﴾</span></span>، ونبأ مفعول به، ونوح مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نبأ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال لقومه﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا قوم إن كان كبر عليكم مقامي وتذكيري بآيات الله فعلى الله توكلت﴾</span></span>: يا حرف نداء، وقوم منادى مضاف لياء المتكلم المحذوفة، وإن شرطية، وكان فعل الشرط، واسمها ضمير الشأن المحذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿كبر عليكم مقامي﴾</span></span> خبرها، وتذكيري عطف على <span class="hlt"><span class="qpc-hafs">﴿مقامي﴾</span></span>، وبآيات الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذكيري﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فعلى الله﴾</span></span> الفاء رابطة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأجمعوا أمركم وشركاءكم﴾</span></span>: الفاء الفصيحة، وأجمعوا فعل أمر، والواو فاعل، وأمركم مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وشركاءكم﴾</span></span> الواو للمعية، وشركاءكم مفعول به منصوب بفعل مضمر، أي: وادعوا شركاءكم، أو معطوف على المعنى، أو: مفعول معه، أي: مع شركائكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا يكن أمركم عليكم غمة﴾</span></span>: ثم حرف عطف وتراخ، ولا ناهية، ويكن فعل مضارع ناقص ناسخ مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وأمركم اسم يكن، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة في الأصل وتقدمت، وغمة خبر يكن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم اقضوا إلي ولا تنظرون﴾</span></span>: ثم حرف عطف، واقضوا فعل أمر وفاعل، وإليَّ جار ومجرور متعلقان به، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span> الواو عاطفة، ولا ناهية، وتنظرون فعل مضارع مجزوم بلا.</p></div>"
  10,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن توليتم فما سألتكم من أجر﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن شرطية، وتوليتم فعل وفاعل في محل جزم فعل الشرط، والفاء رابطة، وما نافية، وسألتكم فعل وفاعل، ومن حرف صلة، وأجر مفعول به محلاًّ.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أجري إلا على الله﴾</span></span>: إن نافية، وأجري مبتدأ، وإلا أداة حصر، وعلى الله خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأمرت أن أكون من المسلمين﴾</span></span>: الواو عاطفة، وأمرت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن أكون﴾</span></span> أن وما في حيزها في تأويل مصدر منصوب بنزع الخافض، أي: بأن أكون.</p></div>"
  10,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه فنجيناه ومن معه في الفلك وجعلناهم خلائف﴾</span></span>: الفاء عاطفة، وكذبوه فعل وفاعل ومفعول به، فنجيناه عطف على كذبوه، ومن اسم موصول معطوف على الهاء، والظرف متعلق بمحذوف هو الصلة، أي: استقروا معه في السفينة، وفي الفلك جار ومجرور متعلقان بنجيناه، أو في الاستقرار الذي هو الصلة، أي: والذين استقروا معه في الفلك، و<span class="hlt"><span class="qpc-hafs">﴿جعلناهم خلائف﴾</span></span> فعل وفاعل ومفعولاه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأغرقنا الذين كذبوا بآياتنا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأغرقنا عطف على نجيناه، ونا فاعل، والذين مفعول به، وجملة كذبوا بآياتنا صلة الذين لا محل لها من الإعراب، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فانظركيف كان عاقبة المنذرين﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وانظر فعل أمر، وفاعله مستتر، وكيف اسم استفهام خبر كان مقدم، وعاقبة اسمها، والمنذرين مضاف إليه.</p></div>"
  10,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم بعثنا من بعده رسلا إلى قومهم﴾</span></span>: عطف على قصة نوح، وبعثنا: فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ورسلًا مفعول به، وإلى قومهم جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجاءوهم بالبينات فما كانوا ليؤمنوا بما كذبوا به من قبل﴾</span></span>: الفاء عاطفة، وجاءوهم فعل وفاعل ومفعول به، وبالبينات جار ومجرور متعلقان بجاءوهم، والفاء عاطفة، وما نافية، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، واللام لام الجحود، ويؤمنوا منصوب بأن مضمرة بعدها، واللام ومدخولها متعلقان بمحذوف خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بيؤمنوا، وجملة كذبوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وبه جار ومجرور متعلقان بكذبوا، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وبنيت على الضم لانقطاعها عن الإضافة لفظًا لا معنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نطبع على قلوب المعتدين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: طبعًا مثلَ ذلك الطبع نطبع على قلوب المعتدين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿على قلوب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نطبع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المعتدين﴾</span></span> مضاف إليه.</p></div>"
  10,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم بعثنا من بعدهم موسى وهارون إلى فرعون وملئه بآياتنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> حال، وموسى مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، وهارون معطوف على موسى، وإلى فرعون جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، وملئه عطف على فرعون، وبآياتنا جار ومجرور متعلقان بمحذوف حال، أي: متلبسين بآياتنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستكبروا وكانوا قومًا مجرمين﴾</span></span>: الفاء عاطفة، واستكبروا فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿وكانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وقومًا خبرها، ومجرمين صفة.</p></div>"
  10,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم الحق من عندنا﴾</span></span>: الفاء عاطفة، ولما حينية، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> في محل جر مضاف إليه، أو <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> رابطة، وجملة جاءهم لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الحق﴾</span></span> فاعل، ومن عندنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إن هذا لسحر مبين﴾</span></span>: جملة قالوا لا محل لها من الإعراب، وإن حرف ناسخ، وهذا اسمها، واللام المزحلقة، وسحر خبر إن، ومبين صفة.</p></div>"
  10,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال موسى أتقولون للحق لما جاءكم أسحر هذا ولا يفلح الساحرون﴾</span></span>: قال موسى فعل وفاعل، والهمزة للاستفهام، وتقولون فعل مضارع وفاعل، وللحق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولون﴾</span></span>، ولما حينية، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span> في محل جر مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿أسحر﴾</span></span> الهمزة للاستفهام الإنكاري التوبيخي، وسحر خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ مؤخر، والجملة مقول القول، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span> الواو للحال، ولا نافية، ويفلح الساحرون فعل مضارع وفاعل، والجملة حالية.</p></div>"
  10,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أجئتنا لتلفتنا عما وجدنا عليه آباءنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، والهمزة للاستفهام، وجملة <span class="hlt"><span class="qpc-hafs">﴿أجئتنا﴾</span></span> مقول القول، وهو فعل وفاعل ومفعول به، ولتلفتنا اللام للتعليل، وتلفت فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بجئتنا، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تلفتنا﴾</span></span>، وجملة وجدنا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال تقديره: عاكفين، وآباءنا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتكون لكما الكبرياء في الأرض﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص ناسخ، ولكما جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> المقدم، والكبرياء اسمها المؤخر، وفي الأرض جار ومجرور متعلقان بمحذوف حال، أي: ممتدة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما نحن لكما بمؤمنين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿لكما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بمؤمنين﴾</span></span> الباء حرف جر صلة، ومؤمنين خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> منصوب محلا مجرور بالباء لفظًا.</p></div>"
  10,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون ائتوني بكل ساحر عليم﴾</span></span>: الواو عاطفة، وقال فرعون فعل وفاعل، وائتوني فعل أمر وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بكل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوني﴾</span></span>، وساحر مضاف إليه، وعليم صفة.</p></div>"
  10,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء السحرة قال لهم موسى ألقوا ما أنتم ملقون﴾</span></span>: الفاء عاطفة على محذوف، أي: فأتوا بالسحرة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال لهم موسى﴾</span></span> لا محل لها من الإعراب، وألقوا فعل أمر وفاعل، وما اسم موصول مفعول به، وأنتم مبتدأ، وملقون خبر، والجملة الاسمية صلة الموصول لا محل لها من الإعراب، وجملة ألقوا مقول القول.</p></div>"
  10,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما ألقوا قال موسى ما جئتم به السحر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبتدأ، وجملة جئتم به صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والسحر خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله سيبطله﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة سيبطله خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يصلح عمل المفسدين﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يصلح خبرها، وإن للتعليل، وعمل المفسدين مفعول به.</p></div>"
  10,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويحق الله الحق بكلماته ولو كره المجرمون﴾</span></span>: الواو عاطفة، ويحق الله فعل وفاعل، والحق مفعول به، وبكلماته جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحق﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> وصلية، وكره المجرمون فعل وفاعل.</p></div>"
  10,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما آمن لموسى إلا ذرية من قومه﴾</span></span>: الفاء عاطفة، وما نافية، وآمن فعل ماض، ولموسى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span>، وإلا أداة حصر، وذرية فاعل، ومن قومه صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿على خوف من فرعون وملئهم أن يفتنهم﴾</span></span>: على بمعنى مع، وهي مع مجرورها في محل نصب على الحال، ومن فرعون جار ومجرور متعلقان بخوف، وملئهم عطف على فرعون، وإنما أعاد الضمير إليه جمعًا، لأنه بمعنى آل فرعون، و<span class="hlt"><span class="qpc-hafs">﴿أن يفتنهم﴾</span></span>: أن وما في حيزها بدل اشتمال من فرعون، أي: على خوف من فتنة فرعون، أو مفعول لأجله بعد حذف اللام.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن فرعون لعال في الأرض﴾</span></span>: الواو اعتراضية، وإن حرف ناسخ، وفرعون اسمها، واللام المزحلقة، وعال خبر إن مرفوع وعلامة رفعه الضمة المقدرة على الياء المحذوفة، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عال﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿إن فرعون...﴾</span></span> اعتراضية، لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لمن المسرفين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span> الواو عاطفة، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المسرفين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه لمن المسرفين﴾</span></span> معطوفة على الاعتراضية.</p></div>"
  10,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى يا قوم إن كنتم آمنتم بالله فعليه توكلوا إن كنتم مسلمين﴾</span></span>: يا قوم: يا حرف نداء، وقوم منادى مضاف لياء المتكلم، وإن شرطية، وكنتم في محل جزم فعل الشرط، والتاء اسم كان، وجملة آمنتم خبر كنتم، وبالله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فعليه﴾</span></span> الفاء رابطة لجواب الشرط، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلوا﴾</span></span>، وتوكلوا فعل أمر وفاعل، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، ومسلمين خبرها، وجواب الشرط محذوف.</p></div>"
  10,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا على الله توكلنا﴾</span></span>: الفاء للعطف، وقالوا فعل وفاعل، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلنا﴾</span></span>، وتوكلنا فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا لا تجعلنا فتنة للقوم الظالمين﴾</span></span>: ربنا منادى مضاف، وحرف النداء محذوف، ولا طلبية للدعاء، وتجعلنا فعل مضارع مجزوم بلا، ونا مفعول به أول، وفتنة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿للقوم﴾</span></span> صفة، والظالمين صفة للقوم.</p></div>"
  10,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجنا برحمتك من القوم الكافرين﴾</span></span>: الواو عاطفة، ونج فعل طلب مبني على حذف حرف العلة، ونا مفعول به، وبرحمتك جار ومجرور متعلقان بمحذوف حال، ومن القوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجنا﴾</span></span>، والكافرين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿القوم﴾</span></span>.</p></div>"
  10,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إلى موسى وأخيه أن تبوآ لقومكما بمصر بيوتا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأوحينا فعل وفاعل، وإلى موسى جار ومجرور متعلقان بأوحينا، وأخيه عطف على موسى. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تبوآ﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. ولقومكما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبوآ﴾</span></span>، وباعتبارها مفعولًا ثانيًا، و<span class="hlt"><span class="qpc-hafs">﴿بمصر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بيوتًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿تبوآ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واجعلوا بيوتكم قبلة وأقيموا الصلاة وبشر المؤمنين﴾</span></span>: الواو عاطفة، واجعلوا عطف على تبوآ، وبيوتكم مفعول <span class="hlt"><span class="qpc-hafs">﴿اجعلوا﴾</span></span> الأول، و<span class="hlt"><span class="qpc-hafs">﴿قبلة﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿اجعلوا﴾</span></span> الثاني، و<span class="hlt"><span class="qpc-hafs">﴿أقيموا الصلاة﴾</span></span> فعل أمر وفاعل ومفعول به، وبشر المؤمنين عطف أيضًا.</p></div>"
  10,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى ربنا إنك آتيت فرعون وملأه زينة وأموالا في الحياة الدنيا﴾</span></span>: قال موسى فعل وفاعل، وربنا منادى مضاف حذف منه حرف النداء، وإن حرف ناسخ، والكاف اسمها، وجملة آتيت خبر إن، وفرعون مفعول به، وملأه عطف على فرعون، وزينة مفعول به ثان، وأموالًا عطف على زينة، و<span class="hlt"><span class="qpc-hafs">﴿في الحياة الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لزينة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا ليضلوا عن سبيلك﴾</span></span>: ربنا منادى مضاف، واللام لام الصيرورة والعاقبة، أي: آتيتهم النعم المذكورة ليشكروها ويتبعوا سبيلك، فكان عاقبة أمرهم أنهم كفروها وضلوا عن سبيلك، أو اللام لام العلة، والمعنى: أنك آتيتهم ما آتيتهم لتستدرجهم، وقيل:  اللام للدعاء عليهم بأن يبقوا على ما هم عليه من الضلال، وعن سبيلك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا اطمس على أموالهم واشدد على قلوبهم﴾</span></span>: اطمس فعل دعاء، وفاعله: أنت، وعلى قلوبهم جار ومجرور متعلقان باطمس، <span class="hlt"><span class="qpc-hafs">﴿واشدد على قلوبهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اطمس على أموالهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يؤمنوا حتى يروا العذاب الأليم﴾</span></span>: يؤمنوا: منصوب بأن مضمرة بعد فاء السببية العاطفة، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الدعاء السابق تقديره: <span class="hlt"><span class="qpc-hafs">﴿ليكن منك شد على قلوبهم فعدم إيمان منهم﴾</span></span>. أو بالعطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿ليضلوا﴾</span></span>، وجملة: <span class="hlt"><span class="qpc-hafs">﴿ربنا اطمس على أموالهم واشد على قلوبهم﴾</span></span> اعتراضية لا محل لها من الإعراب، أو أن المصدر المؤول مجزوم باعتباره جوابا للدعاء. وحتى: حرف غاية وجر، ويروا مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور، والجار والمجرور متعلقان باشدد، والواو فاعل، والعذاب مفعول به، والأليم صفة.</p></div>"
  10,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قد أجيبت دعوتكما﴾</span></span>: جملة قد أجيبت مقول القول، ودعوتكما نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستقيما ولا تتبعان سبيل الذين لا يعلمون﴾</span></span>: الفاء الفصيحة، واستقيما فعل أمر، والألف فاعل، ولا تتبعان: الواو عاطفة، ولا ناهية، وتتبعان فعل مضارع مجزوم بلا، وعلامة جزمه حذف النون، وألف الاثنين فاعل، والنون المشددة هي نون التوكيد الثقيلة، وسبيل مفعول به، والذين مضاف إليه، وجملة لا يعلمون صلة الذين لا محل لها من الإعراب.</p></div>"
  10,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاوزنا ببني إسرائيل البحر﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وجاوزنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ببني إسرائيل﴾</span></span> جار ومجرور متعلقان بجاوزنا، والباء للتعدية، أي: جعلناهم مجاوزين البحر، والبحر مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأتبعهم فرعون وجنوده بغيا وعدوا﴾</span></span>: فأتبعهم: الفاء عاطفة، وأتبعهم فعل ومفعول به، وفرعون فاعل، وجنوده عطف على فرعون، وبغيًا مفعول لأجله، وعدوًا معطوف عليه، أو <span class="hlt"><span class="qpc-hafs">﴿بغيا وعدوا﴾</span></span> مصدران في موضع الحال، أي: باغين معتدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا أدركه الغرق قال آمنت أنه لا إله إلا الذي آمنت به بنو إسرائيل﴾</span></span>: حتى ابتدائية لوقوع <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> الفجائية بعدها، وهي غاية للإتباع، أي: استمر إتباعه إياهم إلى وقت إدراك الغرق إياه، وإذا ظرف مستقبل، وأدركه الغرق فعل ومفعول به وفاعل، والجملة في محل جر بالإضافة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span> مقول القول، وأن وما في حيزها في موضع نصب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا إله إلا الذي﴾</span></span>: لا نافية للجنس، وإله اسمها، وإلا أداة حصر، والذي بدل من محل <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، واسمها على الصحيح، أو من الخبر المحذوف، أي: لا إله موجود إلا <span class="hlt"><span class="qpc-hafs">﴿الذي آمنت به بنو إسرائيل﴾</span></span>، وجملة آمنت صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span>، وبنو إسرائيل فاعل آمنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا من المسلمين﴾</span></span>: الواو عاطفة، وأنا مبتدأ، ومن المسلمين خبر.</p></div>"
  10,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿آلآن وقد عصيت قبل وكنت من المفسدين﴾</span></span>: آلآن الهمزة للاستفهام، والآن ظرف متعلق بمحذوف، وتقديره: آلآن آمنت؟ <span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span> الواو للحال، وقد حرف تحقيق، وعصيت فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف مبني على الضم لانقطاعه عن الإضافة لفظًا لا معنى، و<span class="hlt"><span class="qpc-hafs">﴿كنت من المفسدين﴾</span></span> عطف على عصيت، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المفسدين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  10,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاليوم ننجيك ببدنك لتكون لمن خلفك آية﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واليوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ننجيك﴾</span></span>، وببدنك حال من الكاف، أي: مصاحبًا لبدنك، ولتكون اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بننجيك، واسم تكون مستتر تقديره: أنت، وآية خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لمن خلفك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والظرف متعلق بالاستقرار الذي هو صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كثيرا من الناس عن آياتنا لغافلون﴾</span></span>: الواو اعتراضية، وإن حرف ناسخ، وكثيرا اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الناس﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span>، وعن آياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافلون﴾</span></span>، واللام المزحلقة، وغافلون: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن كثيرًا...﴾</span></span> اعتراضية لا محل لها من الإعراب.</p></div>"
  10,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد بوأنا بني إسرائيل مبوأ صدق﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وبوأنا فعل وفاعل، وبني إسرائيل مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿مبوأ﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿بَوَّأ﴾</span></span>، أو نائب مفعول مطلق، لأنه مصدر ميمي، أي: بوأناهم مبوأ صدق.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقناهم من الطيبات فما اختلفوا حتى جاءهم العلم﴾</span></span>: الواو عاطفة، ورزقناهم عطف على بوأنا، وهو فعل وفاعل ومفعول به، ومن الطيبات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقناهم﴾</span></span>، فما: الفاء عاطفة، وما نافية، واختلفوا فعل وفاعل، وحتى حرف غاية وجر، وجاءهم العلم فعل ومفعول به وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك يقضي بينهم يوم القيامة فيما كانوا فيه يختلفون﴾</span></span>: إن حرف ناسخ، وربك اسمها، وجملة يقضي خبرها، وبينهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span> أيضًا، وفيما جار ومجرور متعلقان بمحذوف حال، أي: فاصلًا فيما، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>، وجملة يختلفون خبر كانوا.</p></div>"
  10,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن كنت في شك مما أنزلنا إليك﴾</span></span>: الفاء استئنافية، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، والفعل في محل جزم فعل الشرط، وفي شك خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>، وجملة أنزلنا إليك صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاسأل الذين يقرءون الكتاب من قبلك﴾</span></span>: الفاء رابطة، واسأل فعل أمر، وفاعله مستتر تقديره: أنت، والذين مفعول به، وجملة يقرءون الكتاب صلة الذين لا محل لها من الإعراب، ومن قبلك حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإن كنت في شك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقد جاءك الحق من ربك﴾</span></span>: اللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وجاءك الحق فعل ومفعول به وفاعل، ومن ربك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تكونن من الممترين﴾</span></span>: الفاء عاطفة، ولا ناهية، وتكونن مجزوم بلا محلاًّ، لأنه مبني، واسمها مستتر تقديره: أنت، ومن الممترين خبرها.</p></div>"
  10,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تكونن﴾</span></span>: الواو عاطفة، ولا ناهية، وتكونن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> الناهية، واسم <span class="hlt"><span class="qpc-hafs">﴿تكونن﴾</span></span> ضمير مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿من الذين كذبوا بآيات الله﴾</span></span>: الجار والمجرور متعلقان بمحذوف خبر، وجملة كذبوا صلة الذين لا محل لها من الإعراب، وبآيات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، ولفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتكون من الخاسرين﴾</span></span>: الفاء سببية، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> مضارع ناقص منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق، أي: لا يكن منك كذب فخسران. و<span class="hlt"><span class="qpc-hafs">﴿من الخاسرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>.</p></div>"
  10,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين حقت عليهم كلمت ربك لا يؤمنون﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة حقت صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span> فاعل، وربك مضاف إليه، وجملة لا يؤمنون خبر إن.</p></div>"
  10,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو جاءتهم كل آية حتى يروا العذاب الأليم﴾</span></span>: الواو حالية، ولو شرطية، وجاءتهم كل آية فاعل، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> غاية النفي، ويروا فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بيؤمنون، والواو فاعل، والعذاب مفعول به، والرؤية عينية، ولذلك نصبت مفعولًا واحدًا فقط، والأليم صفة، وجواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> محذوف، أي: فلا ينفعهم إيمانهم حينئذ كما لم ينفع فرعون.</p></div>"
  10,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلولا كانت قرية آمنت﴾</span></span>: الفاء استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولولا تحضيضية، وكانت قرية فعل وفاعل، لأن <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> هنا تامة، وجملة آمنت صفة لقرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنفعها إيمانها إلا قوم يونس﴾</span></span>: الفاء عاطفة، ونفعها معطوف على الصفة عطف المسبب على السبب، وإيمانها فاعل نفعها، والجملة قد تقوم مقام الصفة للنكرة، و<span class="hlt"><span class="qpc-hafs">﴿إلا قوم يونس﴾</span></span> استثناء متصل، ويونس مضاف إليه ممنوع من الصرف للعلمية والعجمية.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما آمنوا كشفنا عنهم عذاب الخزي في الحياة الدنيا ومتعناهم إلى حين﴾</span></span>: لما حينية، أو رابطة، وآمنوا فعل وفاعل، وجملة كشفنا لا محل لها من الإعراب، وعنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وعذاب الخزي مفعول به، وفي الحياة جار ومجرور متعلقان بمحذوف حال، والدنيا صفة، ومتعناهم عطف على <span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وإلى حين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span>.</p></div>"
  10,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو شاء ربك لآمن من في الأرض كلهم جميعا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية، وشاء ربك فعل وفاعل لـ<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span>، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة آمن لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل آمن، وفي الأرض متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وكلهم توكيد لـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجميعًا نصب على الحال من <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفأنت تكره الناس حتى يكونوا مؤمنين﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة، وأنت مبتدأ، والجملة بعده خبر، والهمزة مقدمة على العاطف، أو ثَم جملة محذوفة، وحتى حرف تعليل وجر، ويكونوا منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكره﴾</span></span>، ومؤمنين خبر يكونوا.</p></div>"
  10,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لنفس أن تؤمن إلا بإذن الله﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لنفس﴾</span></span> خبرها المقدم، وأن المصدرية، وما في حيزها اسمها المؤخر، وإلا أداة حصر، وبإذن الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تؤمن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعل الرجس على الذين لا يعقلون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span> معطوفة على مقدر، كأنه قيل: فيأذن لبعضهم في الإيمان، ويجعل مضارع، والرجس مفعوله، وعلى الذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span>، وجملة لا يعقلون صلة الذين لا محل لها من الإعراب.</p></div>"
  10,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل انظروا ماذا في السماوات والأرض﴾</span></span>: قل فعل أمر، وجملة انظروا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> ما استفهامية مبتدأ، وذا اسم موصول خبر، والجملة في محل نصب لتعليق العامل وهو <span class="hlt"><span class="qpc-hafs">﴿انظروا﴾</span></span> بالاستفهام، والجار والمجرور متعلقان بمحذوف هو الصلة للموصول، أي: ما الذي استقر في السماوات والأرض، وجملة الصلة لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> بتمامها استفهام في محل رفع مبتدأ، وفي السماوات خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تغني الآيات والنذر عن قوم لا يؤمنون﴾</span></span>: الواو اعتراضية. وما: نافية، أو اسم استفهام مبني على السكون في محل نصب نائب مفعول مطلق. وتغني: فعل مضارع مرفوع بضمة مقدرة على الياء للثقل. والآيات: فاعل. والنذر: عطف على <span class="hlt"><span class="qpc-hafs">﴿الآيات﴾</span></span>. عن قوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>. ولا: نافية. ويؤمنون: فعل مضارع مرفوع بثبوت النون، والواو فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span>: في محل جر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ما تغني...﴾</span></span> اعتراضي تذييلي للجملة السابقة، لا محل لها من الإعراب.</p></div>"
  10,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهل ينتظرون إلا مثل أيام الذين خلوا من قبلهم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وهل حرف استفهام، وينتظرون فعل مضارع مرفوع بثبوت النون، والواو فاعل، وإلا أداة حصر، ومثل مفعول ينتظرون، وأيام مضاف إليه، والذين مضاف إليه، وجملة خلوا صلة الذين لا محل لها من الإعراب، ومن قبلهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلوا﴾</span></span>، أو بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل فانتظروا﴾</span></span>: قل فعل أمر، والفاء الفصيحة، وانتظروا فعل أمر مبني على حذف النون. والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني معكم من المنتظرين﴾</span></span>: إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المنتظرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، والظرف متعلق بمحذوف حال.</p></div>"
  10,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم ننجي رسلنا والذين آمنوا﴾</span></span>: ثم حرف عطف للترتيب والتراخي، وننجي فعل مضارع، وفاعله مستتر تقديره: نحن، والجملة عطف على كلام محذوف، تقديره: نهلك الأمم، ثم ننجي رسلنا على حكاية الأحوال الماضية، ورسلنا مفعول به، والذين عطف على رسلنا، وجملة آمنوا صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك حقا علينا ننج المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: إنجاءً مثلَ ذلك الإنجاء ننجي المؤمنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿حقا﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة والتقدير: حق ذلك حقا. و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿حقًا علينا﴾</span></span> اعتراضية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ننجي﴾</span></span> فعل مضارع والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> مفعول به.</p></div>"
  10,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل يا أيها الناس إن كنتم في شك من ديني﴾</span></span>: قل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وإن شرطية، وكنتم فعل ماض ناقص ناسخ فعل الشرط، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من ديني﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا أعبد الذين تعبدون من دون الله﴾</span></span>: الفاء رابطة لجواب الشرط، ولا نافية، وأعبد فعل مضارع فاعله: أنا، والذين مفعول أعبد، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أعبد الله الذي يتوفاكم﴾</span></span>: الواو عاطفة، ولكن حرف استدراك لا عمل لها، وأعبد فعل مضارع، وفاعله مستتر تقديره: أنا، ولفظ الجلالة مفعوله، والذي صفة، وجملة يتوفاكم صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأمرت أن أكون من المؤمنين﴾</span></span>: الواو عاطفة، وأمرت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، وأن وما في حيزها في موضع نصب بنزع الخافض، أي: بأن أكون، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمرت﴾</span></span>، واسم أكون مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أكون.</p></div>"
  10,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن أقم وجهك للدين حنيفا﴾</span></span>: الواو عاطفة، وأن وما في حيزها عطف على ما قبلها، كأنه قيل: وقيل لي: وأقم، و<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span> فعل أمر، ووجهك مفعول به، وللدين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، وحنيفًا حال من الدين، أو من الوجه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تكونن من المشركين﴾</span></span>: الواو عاطفة، ولا ناهية، وتكونن فعل مضارع مبني لاتصاله بنون التوكيد في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، واسم تكونن مستتر تقديره: أنت، ومن المشركين خبرها.</p></div>"
  10,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تدع من دون الله ما لا ينفعك ولا يضرك﴾</span></span>: الواو عاطفة، ولا ناهية، وتدع مضارع مجزوم بلا، والفاعل: أنت، ومن دون الله حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة لا ينفعك صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا يضرك﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا ينفعك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن فعلت فإنك إذا من الظالمين﴾</span></span>: الفاء عاطفة، وإن شرطية، وفعلت في محل جزم فعل الشرط، والفاء رابطة، وإن حرف ناسخ، والكاف اسمها، وإذًا حرف جواب وجزاء مهمل، و<span class="hlt"><span class="qpc-hafs">﴿من الظالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  10,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن يمسسك الله بضر فلا كاشف له إلا هو﴾</span></span>: الواو عاطفة، وإن شرطية، ويمسسك فعل الشرط، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، وبضر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمسسك﴾</span></span>، والفاء رابطة، ولا نافية للجنس، وكاشف اسمها مبني على الفتح، وله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كاشف﴾</span></span>، والخبر محذوف، أو <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> هو الخبر، أي: كائن له، وإلا أداة حصر، وهو بدل من الخبر المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يردك بخير فلا راد لفضله﴾</span></span>: الواو عاطفة، وإن شرطية، ويردك فعل الشرط مجزوم، والكاف مفعول به، وبخير جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يردك﴾</span></span>، والفاء رابطة، ولا نافية للجنس، وراد اسمها، ولفضله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راد﴾</span></span>، والخبر محذوف، أو الجار والمجرور هو الخبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿يصيب به من يشاء من عباده﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب، والفاعل: هو، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصيب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول يصيب، وجملة يشاء صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من عباده﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو الغفور الرحيم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والغفور خبر أول، والرحيم خبر ثان، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  10,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل يا أيها الناس﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جاءكم الحق من ربكم﴾</span></span>: قد جاءكم الحق فعل ومفعول به وفاعل، ومن ربكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن اهتدى فإنما يهتدي لنفسه﴾</span></span>: الفاء الفصيحة، ومن شرطية، واهتدى فعل الشرط، أو مَن موصولة مبتدأ، والجملة صلة الموصول لا محل لها من الإعراب، والفاء رابطة، وإنما كافة ومكفوفة، ويهتدي فعل مضارع، والفاعل مستتر تقديره: هو، ولنفسه جار ومجرور متعلقان بيهتدي.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ضل فإنما يضل عليها﴾</span></span>: معطوفة على الجملة السابقة، ولها نفس الإعراب، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنا عليكم بوكيل﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بوكيل﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿وكيل﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  10,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتبع ما يوحى إليك﴾</span></span>: الواو استئنافية، واتبع فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة يوحي صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوحي﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿واصبر حتى يحكم الله﴾</span></span>: الواو عاطفة، واصبر فعل أمر معطوف على اتبع، وحتى حرف غاية وجر، ويحكم منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعله.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو خير الحاكمين﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير الحاكمين خبره، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
