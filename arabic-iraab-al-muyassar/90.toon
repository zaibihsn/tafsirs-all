quran[20]{c,v,t}:
  90,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية أو صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>: فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿البلد﴾</span></span>: بدل مطابق من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مرفوع.</p></div>"
  90,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنت﴾</span></span>: الواو حالية، أو اعتراضية، وأنت مبتدأ مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿حل﴾</span></span>: خبر مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿البلد﴾</span></span>: بدل مطابق من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مجرور، والجملة اعتراضية لا محل لها من الإعراب، أو حالية، والتقدير: لا أقسم بهذا البلد وأنت حالٌّ أي نازل في هذا البلد، وقيل: المعنى لا أقسم به وأنت مُستحَلّ فيه، أي: مُستحَلّ أذاك.</p></div>"
  90,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووالد﴾</span></span>: الواو حرف عطف، ووالد معطوف على القسم السابق مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوف على <span class="hlt"><span class="qpc-hafs">﴿والد﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولد﴾</span></span>: فعل ماض والفاعل مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولَدَ﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  90,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد﴾</span></span>: اللام في جواب القسم، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>: فعل ماض وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿في كبد﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> جواب قسم لا محل لها من الإعراب.</p></div>"
  90,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أيحسب﴾</span></span>: الهمزة للاستفهام الإنكاري، ويحسب فعل مضارع مرفوع، والفاعل مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مخففة من الثقيلة، واسمها ضمير الشأن محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>: أداة نفي.</p><p><span class="hlt"><span class="qpc-hafs">﴿يقدر﴾</span></span>: فعل مضارع منصوب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن يقدر...﴾</span></span> في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقدر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحد﴾</span></span>: فاعل مرفوع، وأن وما في حيزها في محل نصب سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يحسب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحسب...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  90,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>: فعل مضارع مرفوع، والفاعل مستتر تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿أهلكت﴾</span></span>: فعل ماض والتاء فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أهلكت﴾</span></span> مقول قول.</p><p><span class="hlt"><span class="qpc-hafs">﴿مالا﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لبدا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مالا﴾</span></span> منصوب، والجملة حالية في محل نصب، أو استئنافية لا محل لها من الإعراب.</p></div>"
  90,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أيحسب﴾</span></span>: الهمزة للاستفهام الإنكاري، ويحسب فعل مضارع مرفوع، والفاعل مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مخففة من الثقيلة، واسمها ضمير الشأن محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>: حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يره﴾</span></span>: فعل مضارع مجزوم، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يره...﴾</span></span> في محل رفع خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحد﴾</span></span>: فاعل مرفوع، وأن وما في حيزها في محل نصب سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يحسب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحسب...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  90,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عينين﴾</span></span>: مفعول به منصوب وعلامة نصبه الياء، لأنه مثنى.</p></div>"
  90,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولسانًا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿عينين﴾</span></span> منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشفتين﴾</span></span>: عطف على عينين.</p></div>"
  90,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهديناه﴾</span></span>: فعل ماض وفاعل ومفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿النجدين﴾</span></span>: مفعول به ثان منصوب، أو منصوب بنزع الخافض.</p></div>"
  90,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span>: الفاء عاطفة، ولا نافية أو دعائية.</p><p><span class="hlt"><span class="qpc-hafs">﴿اقتحم﴾</span></span>: فعل ماض، والفاعل مستتر، تقديره هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿العقبة﴾</span></span>: مفعول به منصوب.</p></div>"
  90,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو حالية، وما اسم استفهام في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>: فعل ماض، والفاعل مستتر تقديره: هو، والكاف في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span> خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم استفهام مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿العقبة﴾</span></span>: خبر مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما العقبة﴾</span></span> في محل نصب سدت مسد المفعولين الثاني والثالث للفعل <span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span> المعلق بالاستفهام. وجملة <span class="hlt"><span class="qpc-hafs">﴿وما أدراك...﴾</span></span> في محل نصب حال من <span class="hlt"><span class="qpc-hafs">﴿العقبة﴾</span></span> في الآية السابقة.</p></div>"
  90,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فك﴾</span></span>: خبر لمبتدأ مضمر، أي: هي فك رقبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿رقبة﴾</span></span>: مضاف إليه مجرور. والجملة الاسمية مستأنفة بيانيًا لا محل لها من الإعراب.</p></div>"
  90,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿إطعام﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فك رقبة﴾</span></span> مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: اسم مجرور، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿إطعام﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذي﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مسغبة﴾</span></span>: مضاف إليه مجرور.</p></div>"
  90,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يتيمًا﴾</span></span>: مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿إطعام﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿يتيمًا﴾</span></span> منصوب بالألف.</p><p><span class="hlt"><span class="qpc-hafs">﴿مقربة﴾</span></span>: مضاف إليه مجرور وعلامة الجر الكسرة.</p></div>"
  90,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿مسكينًا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿يتيمًا﴾</span></span> منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مسكينًا﴾</span></span> منصوب بالألف.</p><p><span class="hlt"><span class="qpc-hafs">﴿متربة﴾</span></span>: مضاف إليه.</p></div>"
  90,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف يفيد التراخي في الرتبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماض ناقص، واسمها مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>: اسم موصول مبني على الفتح في محل جر، والجار والمجرور متعلقان بمحذوف خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>: فعل ماض والضمير فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتواصوا﴾</span></span>: الواو حرف عطف، وتواصوا فعل ماض والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تواصوا﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> داخلة في حيز الصلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالصبر﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تواصوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتواصوا﴾</span></span>: الواو حرف عطف، وتواصوا فعل ماض والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تواصوا﴾</span></span> معطوفة أيضًا على <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> داخلة في حيز الصلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالمرحمة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تواصوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان من الذين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فلا اقتحم﴾</span></span>.</p></div>"
  90,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>: اسم إشارة مبني في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span>: خبر مرفوع وعلامة الرفع الضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الميمنة﴾</span></span>: مضاف إليه مجرور بالكسرة، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  90,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، والذين مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>: في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span>: خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿المشأمة﴾</span></span>: مضاف إليه مجرور، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>.</p></div>"
  90,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿نار﴾</span></span>: مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿مؤصدة﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نار﴾</span></span>، والجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، أو استئنافية لا محل لها من الإعراب.</p></div>"
