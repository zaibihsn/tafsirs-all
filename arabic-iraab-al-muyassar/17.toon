quran[111]{c,v,t}:
  17,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الذي أسرى بعبده ليلا من المسجد الحرام إلى المسجد الأقصى الذي باركنا حوله﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسرى﴾</span></span> صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بعبده﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسرى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليلًا﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أسرى﴾</span></span> أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿من المسجد﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مبتدئًا، و<span class="hlt"><span class="qpc-hafs">﴿إلى المسجد الأقصى﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضًا، أي: منتهيًا إلى المسجد، والأقصى نعت للمسجد، والذي نعت ثان، وباركنا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿باركنا﴾</span></span> صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿حوله﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿باركنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنريه من آياتنا﴾</span></span>: اللام للتعليل، ونريه فعل مضارع منصوب بأن مضمرة، والفاعل مستتر تقديره: نحن، والهاء مفعول به، والجار والمجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: وذلك لنريه، و<span class="hlt"><span class="qpc-hafs">﴿من آياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نريه﴾</span></span>، ومن للتبعيض.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو السميع البصير﴾</span></span>: إن حرف ناسخ، والهاء اسمها، والسميع خبر إن، والبصير خبر ثان، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والسميع خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والبصير خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو السميع البصير﴾</span></span> خبر إن.</p></div>"
  17,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتينا موسى الكتاب وجعلناه هدى لبني إسرائيل﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو عاطفة، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿سبحان الذي أسرى﴾</span></span>، وآتينا فعل وفاعل، وموسى مفعول به أول، والكتاب مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span> فعل وفاعل، والهاء مفعول به أول، وهدى مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿لبني﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هدى﴾</span></span>، وإسرائيل مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا تتخذوا من دوني وكيلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية مؤولة مع مدخولها بمصدر منصوب بنزع الخافض، أي: بأن لا تتخذوا، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كتبنا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تتخذوا﴾</span></span> صلة أن المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، وتتخذوا مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span> مفعول تتخذوا الأول، و<span class="hlt"><span class="qpc-hafs">﴿من دوني﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثاني لـ<span class="hlt"><span class="qpc-hafs">﴿تتخذوا﴾</span></span>.</p></div>"
  17,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذرية من حملنا مع نوح﴾</span></span>: ذرية نصبت على الاختصاص، وقيل: على النداء، وقيل: بدل من <span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span>، وقيل: مفعول ثان لتتخذوا، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span>، ونوح مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان عبدا شكورا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وكان فعل ماض ناقص ناسخ، واسمها ضمير مستتر تقديره: هو، وعبدًا خبرها، وشكورًا صفة.</p></div>"
  17,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقضينا إلى بني إسرائيل في الكتاب﴾</span></span>: الواو عاطفة، وقضينا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى بني إسرائيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الكتاب﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتفسدن في الأرض مرتين﴾</span></span>: اللام جواب للقسم المحذوف، أو أجرى القضاء المبتوت مجرى القسم، كأنه قيل: وأقسمنا لتفسدن، وتفسدن فعل مضارع مرفوع وعلامة رفعه ثبوت النون المحذوفة لتوالي النونات، وواو الجماعة المحذوفة لالتقاء الساكنين هي الفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفسدن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مرتين﴾</span></span> نائب مفعول مطلق، لأنه عدده، منصوب وعلامة النصب الياء لأنه مثنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلن علوا كبيرا﴾</span></span>: الواو عطف، و<span class="hlt"><span class="qpc-hafs">﴿لتعلن﴾</span></span> عطف على لتفسدن وهو فعل مضارع مرفوع وعلامة رفعه ثبوت النون المحذوفة لتوالي النونات، وواو الجماعة المحذوفة لالتقاء الساكنين هي الفاعل، و<span class="hlt"><span class="qpc-hafs">﴿علوًّا﴾</span></span> مفعول مطلق منصوب، وكبيرًا صفة.</p></div>"
  17,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء وعد أولاهما بعثنا عليكم عبادا لنا أولي بأس شديد﴾</span></span>: الفاء عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> مضاف إليها الظرف، و<span class="hlt"><span class="qpc-hafs">﴿وعد﴾</span></span> فاعل، وأولاهما مضاف إليه، ولا بد من تقدير مضاف محذوف، أي: وعد عقاب أولاهما، وجملة <span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، وعبادًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أولي﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عبادًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بأس﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿شديد﴾</span></span> صفة لبأس.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجاسوا خلال الديار﴾</span></span>: الفاء عاطفة، وجاسوا عطف على <span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلال﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿جاسوا﴾</span></span>، والديار مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان وعدا مفعولا﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، واسمها ضمير يعود على الوعد بالعقاب، و<span class="hlt"><span class="qpc-hafs">﴿وعدًا﴾</span></span> خبر كان، ومفعولًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وعدًا﴾</span></span>، والجملة في محل نصب حال، أو الواو اعتراضية، والجملة اعتراضية بين المتعاطفين لا محل لها من الإعراب، وقيل: الواو عاطفة على <span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، وقيل: عاطفة على <span class="hlt"><span class="qpc-hafs">﴿فجاسوا﴾</span></span>.</p></div>"
  17,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم رددنا لكم الكرة عليهم﴾</span></span>: ثم حرف عطف للتراخي، و<span class="hlt"><span class="qpc-hafs">﴿رددنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رددنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكرة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الكرة﴾</span></span>، أو متعلقان بمحذوف حال منها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأمددناكم بأموال وبنين وجعلناكم أكثر نفيرا﴾</span></span>: الواو عاطفة، وأمددناكم عطف على <span class="hlt"><span class="qpc-hafs">﴿رددنا﴾</span></span>، وهو فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بأموال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمددناكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بنين﴾</span></span> عطف على أموال، و<span class="hlt"><span class="qpc-hafs">﴿جعلناكم﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span> مفعول به ثان، ونفيرًا تمييز.</p></div>"
  17,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن أحسنتم أحسنتم لأنفسكم وإن أسأتم فلها﴾</span></span>: إن شرطية، وأحسنتم فعل وفاعل، وهو في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿أحسنتم﴾</span></span> جوابه، و<span class="hlt"><span class="qpc-hafs">﴿إن أسأتم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿إن أحسنتم﴾</span></span>، والفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: فإساءتكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء وعد الآخرة ليسوءوا وجوهكم﴾</span></span>: الفاء عاطفة، وإذا ظرف مستقبل، <span class="hlt"><span class="qpc-hafs">﴿جاء وعد﴾</span></span> فعل وفاعل، والآخرة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ليسوءوا﴾</span></span> اللام للتعليل، ويسوءوا مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بجواب إذا المحذوف، أي: بعثناهم ليسوءوا، ووجوهكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليدخلوا المسجد كما دخلوه أول مرة﴾</span></span>: الواو عاطفة، وليدخلوا عطف على ليسوءوا، أي: فهو متعلق بمحذوف هو: بعثناهم، والمسجد منصوب على السعة، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: دخولًا مثل دخلوهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مجرور بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿أول مرة﴾</span></span> نصب على الظرفية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليتبروا ما علوا تتبيرا﴾</span></span>: الواو عاطفة، وليتبروا عطف على ليسوءوا، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يتبروا﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية ظرفية، ومفعول <span class="hlt"><span class="qpc-hafs">﴿يتبروا﴾</span></span> محذوف، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتبروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تتبيرًا﴾</span></span> مفعول مطلق.</p></div>"
  17,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عسى ربكم أن يرحمكم وإن عدتم عدنا وجعلنا جهنم للكافرين حصيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿عسى﴾</span></span> فعل ماض من أفعال الرجاء، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> اسمها، وأن مع مدخولها في محل نصب خبر، والواو حرف عطف، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿عدتم﴾</span></span> فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عدتم﴾</span></span> في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عدنا﴾</span></span> فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عدنا﴾</span></span> في محل جزم جواب الشرط، وجعلنا عطف على عدنا، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجهنم مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿للكافرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حصيرًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حصيرًا﴾</span></span> مفعول به ثان، أو <span class="hlt"><span class="qpc-hafs">﴿للكافرين﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿حصيرا﴾</span></span>.</p></div>"
  17,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا القرآن يهدي للتي هي أقوم﴾</span></span>: إن حرف ناسخ، وهذا اسمها، والقرآن بدل من اسم الإشارة، ويهدي فعل وفاعل مستتر، والمفعول به محذوف، أي: يهدي الناس، والجملة خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿للتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وأقوم خبر، والجملة الاسمية صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويبشر المؤمنين الذين يعملون الصالحات أن لهم أجرا كبيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ويبشر﴾</span></span> عطف على يهدي، والمؤمنين مفعول به، والذين صفة <span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span>، وجملة يعملون صلة الذين لا محل لها من الإعراب، والصالحات مفعول به، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن المقدم، وأجرًا اسمها المؤخر، وأن وما في حيزها نصب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبشر﴾</span></span>، وكبيرًا صفة.</p></div>"
  17,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن الذين لا يؤمنون بالآخرة أعتدنا لهم عذابا أليما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وأن الذين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن لهم أجرًا كبيرًا﴾</span></span>، أو عطف على <span class="hlt"><span class="qpc-hafs">﴿يبشر﴾</span></span> بإضمار، أي: ويخبر بأن الذين لا يؤمنون معذبون، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span> خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span>، وعذابًا مفعول به، وأليمًا صفة.</p></div>"
  17,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويدع الإنسان بالشر دعاءه بالخير﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يدع الإنسان﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالشر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو بـ<span class="hlt"><span class="qpc-hafs">﴿يدع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿دعاءه﴾</span></span> مفعول مطلق، أو منصوب بنزع الخافض. و<span class="hlt"><span class="qpc-hafs">﴿بالخير﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضًا، أو متعلقان بالدعاء، لأنه مصدر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الإنسان عجولا﴾</span></span>: الواو عاطفة، أو حالية، وكان فعل ماض ناقص ناسخ، والإنسان اسمها، وعجولا خبرها.</p></div>"
  17,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا الليل والنهار آيتين فمحونا آية الليل﴾</span></span>: الواو استئنافية، وجعلنا فعل وفاعل، والليل مفعول به، والنهار عطف على الليل، وآيتين مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجعلنا الليل والنهار آيتين﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فمحونا﴾</span></span> الفاء عاطفة، ومحونا عطف على جعلنا، وآية الليل مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا آية النهار مبصرة لتبتغوا فضلا من ربكم﴾</span></span>: الواو عاطفة، وجعلنا فعل وفاعل، وآية النهار مفعول به أول، ومبصرة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿لتبتغوا﴾</span></span> اللام للتعليل، وتبتغوا مضارع منصوب بأن مضمرة بعد لام التعليل، والواو فاعل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span>، وفضلًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من ربكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبتغوا﴾</span></span>، وصفة لقوله: <span class="hlt"><span class="qpc-hafs">﴿فضلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلموا عدد السنين والحساب وكل شيء فصلناه تفصيلا﴾</span></span>: الواو عاطفة، ولتعلموا عطف على ولتبتغوا، وعدد السنين مفعول به، والحساب عطف على عدد، <span class="hlt"><span class="qpc-hafs">﴿وكل شيء﴾</span></span> نصب على الاشتغال، و<span class="hlt"><span class="qpc-hafs">﴿فصلناه﴾</span></span> فعل وفاعل ومفعول به، وتفصيلًا مفعول مطلق.</p></div>"
  17,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكل إنسان ألزمناه طائره في عنقه﴾</span></span>: الواو عاطفة، وكل إنسان نصب على الاشتغال، وألزمناه فعل وفاعل ومفعول به، وطائره مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿في عنقه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: كائنًا.</p><p>ِ<span class="hlt"><span class="qpc-hafs">﴿ونخرج له يوم القيامة كتابا يلقاه منشورا﴾</span></span>: الواو عاطفة، ونخرج فعل مضارع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نخرج﴾</span></span>، وكتابًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلقاه﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كتابًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منشورًا﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿كتابًا﴾</span></span>، أو حال.</p></div>"
  17,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اقرأ كتابك كفى بنفسك اليوم عليك حسيبا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿اقرأ كتابك﴾</span></span> في موضع نصب مقول قول محذوف، أي: يقال له، واقرأ فعل أمر، وفاعله مستتر تقديره: أنت، وكتابك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كفى﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بنفسك﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿نفسك﴾</span></span> فاعل مرفوع محلًّا مجرور بالباء لفظًا، واليوم ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حسيبًا﴾</span></span>، وحسيبًا تمييز، وقيل: حال، لأنه مشتق.</p></div>"
  17,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من اهتدى فإنما يهتدي لنفسه﴾</span></span>: من شرطية مبتدأ، واهتدى فعل ماض في محل جزم فعل الشرط، <span class="hlt"><span class="qpc-hafs">﴿فإنما﴾</span></span> الفاء رابطة، وإنما كافة ومكفوفة، ويهتدي فعل مضارع مرفوع، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهتدي﴾</span></span>، والجملة المقترنة بالفاء في محل جزم جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ضل فإنما يضل عليها﴾</span></span>: عطف على الجملة السابقة، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بمحذوف منصوب على الحال، أي: واقعًا ضلاله عليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تزر وازرة وزر أخرى﴾</span></span>: الواو عاطفة، ولا نافية، وتزر فعل مضارع وفاعل، ووزر مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿تزر﴾</span></span>، وأخرى مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا معذبين حتى نبعث رسولا﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومعذبين خبرها، <span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، ونبعث فعل مضارع منصوب بأن مضمرة بعد <span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بمحذوف خبر كان، ورسولًا مفعول به.</p></div>"
  17,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا أردنا أن نهلك قرية أمرنا مترفيها ففسقوا فيها﴾</span></span>: الواو استئنافية، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة أردنا مضاف إليها الظرف، والمصدر المؤول من أن وما في حيزها مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أردنا﴾</span></span>، وقرية مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿نهلك﴾</span></span>، وجملة أمرنا لا محل لها من الإعراب، لأنها جواب إذا، ومترفيها مفعول به، <span class="hlt"><span class="qpc-hafs">﴿ففسقوا﴾</span></span> الفاء عاطفة، وفسقوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فسقوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فحق عليها القول فدمرناها تدميرا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span>، والقول فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فدمرناها﴾</span></span> فعل وفاعل ومفعول به، وتدميرًا مفعول مطلق.</p></div>"
  17,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا من القرون من بعد نوح﴾</span></span>: كم خبرية في محل نصب مفعول أهلكنا، و<span class="hlt"><span class="qpc-hafs">﴿من القرون﴾</span></span> جار ومجرور متعلقان بمحذوف منصوب تمييز لـ<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعد نوح﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span> فـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> للابتداء.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكفى بربك بذنوب عباده خبيرا بصيرا﴾</span></span>: الباء صلة، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> فاعل مرفوع محلًّا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿بذنوب عباده﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبيرًا بصيرًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خبيرا بصيرا﴾</span></span> تمييزان منصوبان.</p></div>"
  17,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كان يريد العاجلة عجلنا له فيها ما نشاء لمن نريد﴾</span></span>: من شرطية مبتدأ، وكان فعل ماض ناقص ناسخ في محل جزم فعل الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد العاجلة﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿عجلنا﴾</span></span> فعل وفاعل، وهو في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة نشاء صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> الجار والمجرور بدل من <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> بإعادة العامل، وجملة <span class="hlt"><span class="qpc-hafs">﴿نريد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ومفعول نريد محذوف، أي: لمن نريد تعجيله، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلنا له جهنم يصلاها مذموما مدحورا﴾</span></span>: ثم حرف عطف للتراخي، وجعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعلنا الثاني، وجهنم مفعول جعلنا الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصلاها﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>، ومذمومًا حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿يصلاها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مدحورًا﴾</span></span> حال أيضا.</p></div>"
  17,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن أراد الآخرة وسعى لها سعيها﴾</span></span>: الواو عاطفة، والجملة معطوفة على سابقتها، و<span class="hlt"><span class="qpc-hafs">﴿سعى لها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سعيها﴾</span></span> مفعول مطلق، وقيل: مفعول به لأن المعنى: وعمل لها عملها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو مؤمن﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ومؤمن خبر، والجملة نصب على الحال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿سعى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك كان سعيهم مشكورا﴾</span></span>: الفاء رابطة لجواب مَن، وأولئك اسم إشارة مبتدأ، وكان فعل ماض ناقص ناسخ، وسعيهم اسمها، ومشكورا خبرها، والجملة خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك كان...﴾</span></span> إلخ في محل جزم جواب الشرط.</p></div>"
  17,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا نمد هؤلاء وهؤلاء من عطاء ربك﴾</span></span>: كلًّا مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span>، وفاعل <span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span> مستتر تقديره: نحن، وهؤلاء بدل من <span class="hlt"><span class="qpc-hafs">﴿كلًّا﴾</span></span>، وهؤلاء عطف على هؤلاء الأولى، و<span class="hlt"><span class="qpc-hafs">﴿من عطاء ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان عطاء ربك محظورا﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وكان فعل ماض ناقص ناسخ، وعطاء اسمها، ومحظورا خبرها.</p></div>"
  17,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿انظر كيف فضلنا بعضهم على بعض﴾</span></span>: انظر فعل أمر، والفاعل مستتر، وكيف اسم استفهام في محل نصب على الحال، وفضلنا فعل وفاعل، وبعضهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وللآخرة أكبر درجات وأكبر تفضيلا﴾</span></span>: الواو للحال، واللام للابتداء، والآخرة مبتدأ، وأكبر خبر، ودرجات تمييز نصب بالكسرة، لأنه جمع مؤنث سالم، وأكبر عطف على أكبر الأولى، وتفضيلًا تمييز.</p></div>"
  17,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا تجعل مع الله إلها آخر فتقعد مذموما مخذولا﴾</span></span>: لا ناهية، وتجعل فعل مضارع مجزوم بلا الناهية، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف مفعول تجعل الثاني، وإلهًا مفعول تجعل الأول، وآخر صفة، <span class="hlt"><span class="qpc-hafs">﴿فتقعد﴾</span></span> الفاء فاء السببية، وتقعد فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق، أي: لا يكن منك جَعْلٌ فقعودٌ. والفاعل مستتر تقديره: أنت، ومذمومًا حال، ومخذولًا حال ثانية.</p></div>"
  17,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقضى ربك ألا تعبدوا إلا إياه وبالوالدين إحسانا﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، وقضى ربك فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ألّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span> مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وعلامة نصبه حذف النون، والواو فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية وما دخلت عليه منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضى﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعبدوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، لتضمن <span class="hlt"><span class="qpc-hafs">﴿قضى﴾</span></span> معنى قال، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> وعلامة جزمه حذف النون، والواو فاعل. و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿إياه﴾</span></span> مفعول، و<span class="hlt"><span class="qpc-hafs">﴿بالوالدين﴾</span></span> جار ومجرور متعلقان بفعل محذوف تقديره: وأحسنوا، و<span class="hlt"><span class="qpc-hafs">﴿إحسانًا﴾</span></span> مفعول مطلق لفعل محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿إما يبلغن عندك الكبر أحدهما أو كلاهما﴾</span></span>: إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> للتأكيد، ويبلغن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عندك﴾</span></span> ظرف متعلق بمحذوف حال، وأحدهما فاعل <span class="hlt"><span class="qpc-hafs">﴿يبلغن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿كلاهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أحدهما﴾</span></span> وعلامة رفعه الألف، لأنه ملحق بالمثنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تقل لهما أف ولا تنهرهما وقل لهما قولا كريما﴾</span></span>: الفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تقل﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أف﴾</span></span> اسم فعل مضارع بمعنى التضجر، وفاعله مستتر تقديره: أنا، والجملة مقول القول، <span class="hlt"><span class="qpc-hafs">﴿ولا تنهرهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تقل لهما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قولًا﴾</span></span> مفعول به، أو مفعول مطلق منصوب بالفتحة، و<span class="hlt"><span class="qpc-hafs">﴿كريمًا﴾</span></span> صفة.</p></div>"
  17,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واخفض لهما جناح الذل من الرحمة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿واخفض لهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وقل لهما﴾</span></span>، وجناح الذل مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الرحمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخفض﴾</span></span>، أو متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب ارحمهما كما ربياني صغيرا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> منادى مضاف لياء المتكلم محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿ارحمهما﴾</span></span> فعل دعاء، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: ارحمهما رحمة مثل تربيتهما لي، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ربياني﴾</span></span> فعل ماض، وألف الاثنين فاعل، والنون للوقاية، والياء مفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل مضاف إليه، وصغيرًا حال من الياء.</p></div>"
  17,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربكم أعلم بما في نفوسكم﴾</span></span>: ربكم مبتدأ، وأعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في نفوسكم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تكونوا صالحين فإنه كان للأوابين غفورا﴾</span></span>: الجملة حالية، وإن شرطية، وتكونوا فعل مضارع ناقص ناسخ وهو فعل الشرط، والواو اسمها، وصالحين خبرها، والفاء رابطة للجواب، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبرها، وللأوابين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفورًا﴾</span></span>، وغفورًا خبر كان.</p></div>"
  17,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآت ذا القربى حقه والمسكين وابن السبيل ولا تبذر تبذيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿آت﴾</span></span> فعل أمر، وفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ذا القربى﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿حقه﴾</span></span> مفعول به ثان، والمسكين وابن السبيل عطف على <span class="hlt"><span class="qpc-hafs">﴿ذا القربى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، وتبذر فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وتبذيرًا مفعول مطلق.</p></div>"
  17,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المبذرين كانوا إخوان الشياطين﴾</span></span>: إن حرف ناسخ، والمبذرين اسمها، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وإخوان الشياطين خبر كان، وجملة كانوا خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الشيطان لربه كفورا﴾</span></span>: الواو عاطفة، أو حالية، وكان فعل ماض ناقص ناسخ، والشيطان اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لربه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفورًا﴾</span></span>، وكفورًا خبر كان، ولا بد من تقدير مضاف، أي: لنعم ربه وآلائه.</p></div>"
  17,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإما﴾</span></span> إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> صلة، وتعرضن فعل الشرط وهو في محل جزم، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعرضن﴾</span></span>، وابتغاء رحمة مفعول من أجله، أو جواب الشرط وقد تقدم عليه، أي: فقل لهم قولًا كريمًا لينًا، وعِدْهم وعدًا جميلًا تطييبًا لقلوبهم ابتغاء رحمة من ربك، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترجوها﴾</span></span> حال من رحمة، أو صفة ثانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span></span>: الفاء رابطة، وقل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قولًا﴾</span></span> مفعول به، أو مفعول مطلق منصوب بالفتحة. وميسورًا صفة.</p></div>"
  17,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span></span>: الواو عاطفة، ولا ناهية، وتجعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر تقديره: أنت، ويدك مفعول تجعل الأول، ومغلولة مفعول تجعل الثاني، و<span class="hlt"><span class="qpc-hafs">﴿إلى عنقك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مغلولة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولا تبسطها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تجعل﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> نائب عن المفعول المطلق. و<span class="hlt"><span class="qpc-hafs">﴿البسط﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتقعد ملوما محسورا﴾</span></span>: الفاء فاء السببية، وتقعد مضارع منصوب بأن مضمرة بعد الفاء المسبوقة بالنهي، والمصدر المؤول معطوف على مصدر مفهوم من الكلام السابق أي: لا يكن منك بسط فقعودٌ. وفاعل <span class="hlt"><span class="qpc-hafs">﴿تقعد﴾</span></span> مستتر تقديره: أنت، وملومًا محسورًا حالان، أو خبران لـ<span class="hlt"><span class="qpc-hafs">﴿تقعد﴾</span></span> إذا ضمنت معنى: تصير.</p></div>"
  17,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</span></span>: إن حرف ناسخ، وربك اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبسط﴾</span></span> خبرها، والرزق مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبسط﴾</span></span>، وجملة يشاء صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ويقدر عطف على يبسط.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان بعباده خبيرا بصيرا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وكان فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بعباده﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبيرًا بصيرًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خبيرًا بصيرًا﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجملة كان خبر إن.</p></div>"
  17,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقتلوا أولادكم خشية إملاق﴾</span></span>: لا ناهية، وتقتلوا مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وأولادكم مفعول به، وخشية مفعول لأجله، وإملاق مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿نحن نرزقهم وإياكم﴾</span></span>: نحن مبتدأ، وجملة نرزقهم خبر، وإياكم عطف على الهاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن قتلهم كان خطئا كبيرا﴾</span></span>: إن حرف ناسخ، وقتلهم اسمها، وكان فعل ماض ناقص ناسخ، وخطئًا خبر كان، واسمها مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر إن، وكبيرًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خطئًا﴾</span></span>.</p></div>"
  17,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقربوا الزنا إنه كان فاحشة وساء سبيلا﴾</span></span>: الواو عاطفة، ولا ناهية، وتقربوا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والواو فاعل، والزنا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> تعليلية لا محل لها من الإعراب، وإن حرف ناسخ، والهاء اسمها، وكان فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، وفاحشة خبرها، وجملة كان خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل ماض للذم، والفاعل مستتر، وسبيلًا تمييز، والمخصوص بالذم محذوف، أي: هو.</p></div>"
  17,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقتلوا النفس التي حرم الله إلا بالحق﴾</span></span>: الواو عاطفة، ولا تقتلوا عطف على ما تقدم، والنفس مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> صفة، وجملة حرم الله صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقتلوا﴾</span></span>، والباء للسببية، أو بمحذوف حال من فاعل تقتلوا، أي: متلبسين بالحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن قتل مظلوما﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ومن شرطية مبتدأ، وقتل فعل ماض مبني لما لم يسمَّ فاعله في محل جزم فعل الشرط، ونائب الفاعل مستتر تقديره: هو، ومظلومًا حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقد جعلنا لوليه سلطانا﴾</span></span>: الفاء رابطة، وقد حرف تحقيق، وجعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لوليه﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعلنا الثاني، وسلطانًا مفعول جعلنا الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span></span>: الفاء عاطفة، ولا ناهية، ويسرف مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وفاعله مستتر يعود على الولي، و<span class="hlt"><span class="qpc-hafs">﴿في القتل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان منصورا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، وكان فعل ماض ناقص ناسخ، واسمها مستتر، و<span class="hlt"><span class="qpc-hafs">﴿منصورًا﴾</span></span> خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه...﴾</span></span> تعليلية.</p></div>"
  17,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</span></span>: الواو عاطفة، ولا تقربوا عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿مال اليتيم﴾</span></span> مفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالتي﴾</span></span> جار ومجرور متعلقان بمحذوف مستثنى، أي: لا تقربوه بحال من الأحوال إلا بالخصلة أو الطريقة التي هي أحسن، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وأحسن خبر، والجملة لا محل لها من الإعراب، لأنها صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى يبلغ أشده﴾</span></span>: حتى حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿يبلغ﴾</span></span> منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بتقربوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأوفوا بالعهد﴾</span></span>: أوفوا فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالعهد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوفوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن العهد كان مسئولا﴾</span></span>: إن حرف ناسخ، والعهد اسمها، وجملة كان خبرها، وكان فعل ماض ناقص ناسخ، واسمها مستتر، ومسئولًا خبرها، وحذف الجار والمجرور تخفيفًا، أي: عنه.</p></div>"
  17,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوفوا الكيل إذا كلتم وزنوا بالقسطاس المستقيم﴾</span></span>: الواو عاطفة، وأوفوا فعل أمر، والواو فاعل، والكيل مفعول أوفوا، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿كلتم﴾</span></span> مضاف إليه، وجوابه محذوف دل عليه قوله: أوفوا الكيل، و<span class="hlt"><span class="qpc-hafs">﴿زنوا بالقسطاس المستقيم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أوفوا الكيل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك خير وأحسن تأويلا﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، وأحسن عطف على خير، و<span class="hlt"><span class="qpc-hafs">﴿تأويلًا﴾</span></span> تمييز.</p></div>"
  17,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span></span>: لا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تقف﴾</span></span> مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> وعلامة جزمه حذف حرف العلة وهو الواو، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ليس المقدم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وقيل: متعلقان بما تعلق به <span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> وهو الاستقرار، و<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span> اسم ليس المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن السمع والبصر والفؤاد كل أولئك كان عنه مسئولا﴾</span></span>: إن حرف ناسخ، والسمع اسمها، والبصر والفؤاد عطف على السمع، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، وأولئك مضاف إليه، وكان فعل ماض ناقص ناسخ، واسمها مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسئولًا﴾</span></span>، ومسئولًا خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كل أولئك﴾</span></span> خبر إن.</p></div>"
  17,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تمش في الأرض مرحا﴾</span></span>: لا ناهية، وتمش مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمش﴾</span></span>، ومرحًا حال، أي: كونك ذا مرح، وقيل: مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك لن تخرق الأرض ولن تبلغ الجبال طولا﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن تخرق الأرض﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لن تبلغ الجبال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لن تخرق﴾</span></span>، وطولًا تمييز محول عن الفاعل، أي: ولن يبلغ طولك الجبال، وقيل: <span class="hlt"><span class="qpc-hafs">﴿طولا﴾</span></span> مصدر في موقع الحال، أو مفعول له، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك﴾</span></span> تعليلية لا محل لها من الإعراب.</p></div>"
  17,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كل ذلك كان سيئه عند ربك مكروها﴾</span></span>: كل مبتدأ، وذلك مضاف إليه، وكان فعل ماض ناقص ناسخ، <span class="hlt"><span class="qpc-hafs">﴿سيئه﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عند ربك﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مكروهًا﴾</span></span>، ومكروهًا خبر كان.</p></div>"
  17,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك مما أوحى إليك ربك من الحكمة﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> خبر، وجملة أوحى صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وربك فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من الحكمة﴾</span></span> جار ومجرور متعلقان بمحذوف حال من عائد الموصول المحذوف، أي: من الذي أوحاه إليك كونه من الحكمة، أو حال من الموصول <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجعل مع الله إلها آخر﴾</span></span>: الواو عاطفة، ولا تجعل عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجعل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span> مفعول أول، وآخر صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتلقى في جهنم ملوما مدحورا﴾</span></span>: الفاء فاء السببية، ونائب الفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿في جهنم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تلقى﴾</span></span>، وملومًا ومدحورًا حالان.</p></div>"
  17,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفأصفاكم ربكم بالبنين﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿أصفاكم﴾</span></span> فعل ماض، والكاف مفعوله، وهو معطوف على محذوف يقدر بحسب المقام، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالبنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أصفاكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتخذ من الملائكة إناثا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span> فعل وفاعل مستتر وهو عطف على أصفاكم، و<span class="hlt"><span class="qpc-hafs">﴿من الملائكة﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول اتخذ الثاني، وإناثًا مفعول أول، وقيل: الواو واو الحال، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذ من الملائكة إناثًا﴾</span></span> حالية، وقد مقدرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنكم لتقولون قولا عظيما﴾</span></span>: إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وجملة تقولون خبرها، و<span class="hlt"><span class="qpc-hafs">﴿قولًا﴾</span></span> مفعول به، أو مفعول مطلق منصوب بالفتحة. وعظيمًا صفة.</p></div>"
  17,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صرفنا في هذا القرآن ليذكروا﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وصرفنا فعل وفاعل، ومفعوله محذوف، أي: أمثالًا ومواعظ وحكمًا، و<span class="hlt"><span class="qpc-hafs">﴿في هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، والقرآن بدل، واللام للتعليل، ويذكروا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بصرفنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يزيدهم إلا نفورا﴾</span></span>: الواو للحال، وما نافية، ويزيدهم فعل مضارع، والفاعل مستتر تقديره: هو، وإلا أداة حصر، ونفورًا مفعول <span class="hlt"><span class="qpc-hafs">﴿يزيدهم﴾</span></span> الثاني.</p></div>"
  17,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لو كان معه آلهة كما يقولون﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف متعلق بمحذوف خبر كان المقدم، وآلهة اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿كما يقولون﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: كونًا مثلَ قولهم، وما مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا لابتغوا إلى ذي العرش سبيلا﴾</span></span>: إذًا حرف جواب وجزاء مهملة، واللام واقعة في جواب لو، وجملة <span class="hlt"><span class="qpc-hafs">﴿ابتغوا﴾</span></span> جواب عن مقالة المشركين لا محل لها من الإعراب، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى ذي العرش﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابتغوا﴾</span></span>، أو بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿سبيلًا﴾</span></span>، وسبيلًا مفعول ابتغوا.</p></div>"
  17,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحانه وتعالى عما يقولون علوا كبيرا﴾</span></span>: سبحانه: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span> فعل ماض عطف على ما تضمنه المصدر، والتقدير: تنزه وتعالى، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان به، وجملة يقولون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وعلوًّا مفعول مطلق، لأنه مصدر واقع موقع التعالي، وكبيرًا صفة.</p></div>"
  17,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تسبح له السماوات السبع والأرض ومن فيهن﴾</span></span>: تسبح فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسبح﴾</span></span>، والسماوات فاعل، والسبع صفة، والأرض عطف على السماوات، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> عطف على السماوات والأرض، و<span class="hlt"><span class="qpc-hafs">﴿فيهن﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن من شيء إلا يسبح بحمده﴾</span></span>: الواو عاطفة، وإن نافية، ومن حرف جر صلة، وشيء مجرور لفظًا مرفوع محلًّا، وإلا أداة حصر، ويسبح فعل مضارع، والفاعل مستتر تقديره: هو، والجملة خبر شيء، و<span class="hlt"><span class="qpc-hafs">﴿بحمده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا بحمده.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن لا تفقهون تسبيحهم﴾</span></span>: الواو حالية، ولكن حرف استدراك مهمل، ولا نافية، وتفقهون فعل مضارع وفاعل، وتسبيحهم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان حليما غفورا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، وكان فعل ماض ناقص ناسخ، واسمها مستتر، وحليمًا خبر أول لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وغفورًا خبر ثان لها.</p></div>"
  17,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قرأت القرآن جعلنا بينك وبين الذين لا يؤمنون بالآخرة حجابا مستورا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿قرأت القرآن﴾</span></span> فعل وفاعل ومفعول به، والجملة في محل جر بإضافة الظرف إليها، وجعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينك﴾</span></span> ظرف متعلق بمحذوف مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿بين الذين لا يؤمنون﴾</span></span> عطف على الظرف الأول، وجملة لا يؤمنون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بالآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وحجابًا مفعول جعلنا الأول، ومستورًا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حجابًا﴾</span></span>.</p></div>"
  17,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا على قلوبهم أكنة أن يفقهوه وفي آذانهم وقرا﴾</span></span>: جعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على قلوبهم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعلنا الثاني، وأكنة مفعول جعلنا الأول، و<span class="hlt"><span class="qpc-hafs">﴿أن يفقهوه﴾</span></span> في موضع النصب مفعول من أجله، أي: كراهة أن يفقهوه، أو منصوبًا بنزع الخافض، أي: من أن يفقهوه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكنة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في آذانهم وقرا﴾</span></span> عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿على قلوبهم أكنة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا ذكرت ربك في القرآن وحده ولوا على أدبارهم نفورا﴾</span></span>: الواو عاطفة، إذا ظرف مستقبل، و<span class="hlt"><span class="qpc-hafs">﴿ذكرت﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذكرت﴾</span></span> مضاف إليه، وربك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في القرآن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذكرت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وحده﴾</span></span> حال، وجملة: <span class="hlt"><span class="qpc-hafs">﴿ولوا﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على أدبارهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ونفورًا نائب عن المفعول المطلق، لأنه في معنى ولَّوا، أو حال، أي: نافرين، وقيل: مفعول من أجله.</p></div>"
  17,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن أعلم بما يستمعون به إذ يستمعون إليك﴾</span></span>: نحن مبتدأ، وأعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة يستمعون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستمعون﴾</span></span>، والباء سببية، وقيل: <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال كما نقول: يستمعون بالهزء، أي: هازئين، وقيل: الباء بمعنى اللام، وإذ ظرف لما مضى متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿يستمعون﴾</span></span> الأولى، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستمعون إليك﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذ هم نجوى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف معطوف على <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿إذ يستمعون﴾</span></span> فهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿يستمعون﴾</span></span> الأولى، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ونجوى خبر على حذف مضاف، وقيل: لا حاجة لتقدير مضاف قبل الخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم نجوى﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ يقول الظالمون إن تتبعون إلا رجلا مسحورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> السابقة في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿وإذ هم نجوى﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿يقول الظالمون﴾</span></span> فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول الظالمون﴾</span></span>  في محل جر مضاف إليه، وإن نافية، وتتبعون فعل مضارع مرفوع، والواو فاعل، وإلا أداة حصر، ورجلًا مفعول به، ومسحورًا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رجلًا﴾</span></span>.</p></div>"
  17,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿انظر كيف ضربوا لك الأمثال فضلوا فلا يستطيعون سبيلا﴾</span></span>: انظر فعل أمر، وفاعله مستتر تقديره: أنت، وكيف اسم استفهام في محل نصب حال، وضربوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضربوا﴾</span></span>، والأمثال مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فضلوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ضربوا﴾</span></span>، والفاء حرف عطف، ولا نافية، ويستطيعون سبيلًا فعل وفاعل ومفعول به.</p></div>"
  17,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا أئذا كنا عظاما ورفاتا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، والهمزة للاستفهام الإنكاري، وإذا ظرف مستقبل متعلق بمحذوف تقديره: أنبعث، أو نحشر إذا كنا عظامًا ورفاتًا، والجواب هو الفعل الذي تعلقت به، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وعظامًا خبرها، ورفاتًا عطف على <span class="hlt"><span class="qpc-hafs">﴿عظامًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئنا لمبعوثون خلقا جديدا﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومبعوثون خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿خلقا﴾</span></span> حال، أي: مخلوقين، أو نائب عن المفعول المطلق من معنى الفعل لا من لفظه، أي: نبعث بعثا جديدا، و<span class="hlt"><span class="qpc-hafs">﴿جديدا﴾</span></span> صفة.</p></div>"
  17,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل كونوا حجارة أو حديدا﴾</span></span>: قل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿كونوا﴾</span></span> فعل أمر ناقص ناسخ، والواو اسمها، وحجارة خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كونوا حجارة﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وحديدًا عطف على حجارة.</p></div>"
  17,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو خلقا مما يكبر في صدوركم﴾</span></span>: أو حرف عطف، وخلقًا معطوف على حجارة، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خلقًا﴾</span></span>، وجملة يكبر صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في صدوركم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكبر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسيقولون من يعيدنا﴾</span></span>: الفاء عاطفة، والسين حرف استقبال، ويقولون فعل مضارع وفاعل، ومن اسم استفهام في محل رفع مبتدأ، وجملة يعيدنا خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل الذي فطركم أول مرة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، والذي فطركم مبتدأ خبره محذوف، تقديره: يعيدكم، أو خبر لمبتدأ محذوف، أي: هو الذي فطركم، وجملة فطركم صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أول مرة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فطركم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسينغضون إليك رءوسهم ويقولون متى هو﴾</span></span>: الفاء عاطفة، والسين للاستقبال، وينغضون فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينغضون﴾</span></span>، ورءوسهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ينغضون﴾</span></span>، ومتى اسم استفهام متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل عسى أن يكون قريبا﴾</span></span>: عسى من أفعال الرجاء، واسمها ضمير مستتر تقديره: هو، وأن وبما بعدها في محل نصب خبر عسى، واسم يكون مستتر تقديره هو، وقريبًا خبرها.</p></div>"
  17,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يدعوكم فتستجيبون بحمده﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره اذكر أو اذكروا، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعوكم﴾</span></span> في محل جر مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿فتستجيبون﴾</span></span> عطف على يدعوكم، و<span class="hlt"><span class="qpc-hafs">﴿بحمده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حامدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتظنون إن لبثتم إلا قليلا﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿تظنون﴾</span></span> فعل مضارع مرفوع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لبثتم﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿قليلًا﴾</span></span> نائب ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثتم﴾</span></span>، أي: زمنًا قليلا، أو نائب عن المفعول المطلق لأنه صفته، أي: لبثًا قليلًا.</p></div>"
  17,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل لعبادي يقولوا التي هي أحسن﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، والفاعل مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿لعبادي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يقولوا﴾</span></span> فعل مضارع مجزوم بلام أمر مقدرة، وجاز حذف اللام لدلالة <span class="hlt"><span class="qpc-hafs">﴿قُل﴾</span></span> على الأمر، وواو الجماعة فاعل.</p><p>أو: <span class="hlt"><span class="qpc-hafs">﴿يقولوا﴾</span></span> فعل مضارع مجزوم على أنه جواب الأمر <span class="hlt"><span class="qpc-hafs">﴿قُل﴾</span></span>، ومقول القول محذوف، والتقدير: قل لعبادي قولوا التي هي أحسن يقولوا التي هي أحسن.</p><p>أو: <span class="hlt"><span class="qpc-hafs">﴿يقولوا﴾</span></span> فعل مضارع صُرِف عن الأمر إلى الخبر، ومعناه <span class="hlt"><span class="qpc-hafs">﴿قولوا﴾</span></span>، وبُنِي لوقوعه موقع المبني فحذفت نونه.</p><p>و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يقولوا﴾</span></span>، أو صفة لمفعول محذوف، أي: يقولوا الكلمةَ التي هي أحسن، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الشيطان ينزغ بينهم﴾</span></span>: الجملة تعليلية لقوله: <span class="hlt"><span class="qpc-hafs">﴿يقولوا التي هي أحسن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الشيطان﴾</span></span> اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينزغ بينهم﴾</span></span> في محل رفع خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الشيطان كان للإنسان عدوا مبينا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الشيطان﴾</span></span> اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿للإنسان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿مبينًا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان للإنسان عدوا مبينا﴾</span></span> في محل رفع خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الشيطان كان للإنسان عدوا مبينا﴾</span></span> تعليل لجملة <span class="hlt"><span class="qpc-hafs">﴿ينزغ بينهم﴾</span></span>.</p></div>"
  17,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربكم أعلم بكم إن يشأ يرحمكم﴾</span></span>: ربكم مبتدأ، وأعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يشأ﴾</span></span> فعل الشرط مجزوم، ويرحمكم جواب الشرط مجزوم أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو إن يشأ يعذبكم﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلناك عليهم وكيلا﴾</span></span>: الواو عاطفة، وما نافية، وأرسلناك فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span>، ووكيلًا حال من الكاف.</p></div>"
  17,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربك أعلم بمن في السماوات والأرض﴾</span></span>: الواو عاطفة، وربك مبتدأ، وأعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿بمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولقد فضلنا بعض النبيين على بعض وآتينا داود زبورا﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وفضلنا فعل وفاعل، وبعض النبيين مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضلنا﴾</span></span>، وآتينا فعل وفاعل وهو عطف على <span class="hlt"><span class="qpc-hafs">﴿فضلنا﴾</span></span>، وداود مفعول به أول، وزبورًا مفعول به ثان.</p></div>"
  17,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل ادعوا الذين زعمتم من دونه﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿ادعوا الذين﴾</span></span> مقول القول، وادعوا فعل أمر وفاعل، والذين مفعول به، وجملة زعمتم صلة الذين لا محل لها من الإعراب، ومفعولا <span class="hlt"><span class="qpc-hafs">﴿زعمتم﴾</span></span> محذوفان للعلم بهما، والتقدير: زعمتموهم آلهة، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يملكون كشف الضر عنكم ولا تحويلا﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولا نافية، ويملكون كشف الضر فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عنكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشف﴾</span></span>، والواو حرف عطف، ولا نافية، وتحويلًا معطوف على كشف الضر.</p></div>"
  17,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك الذين يدعون يبتغون إلى ربهم الوسيلة﴾</span></span>: أولئك مبتدأ، والذين يدعون بدل منه، وجملة يبتغون خبر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الوسيلة﴾</span></span>، والوسيلة مفعول به، أو <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> خبر، وجملة يبتغون حال من فاعل يدعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيهم أقرب ويرجون رحمته ويخافون عذابه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أيهم﴾</span></span> بدل من فاعل يبتغون، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> موصولة، وأقرب خبر مبتدأ محذوف، وقيل: <span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> استفهامية مبتدأ، وأقرب خبر، والمعنى: ينظرون أيهم أقرب فيتوسلون به، على إضمار فعل التعليق، و<span class="hlt"><span class="qpc-hafs">﴿أيهم أقرب﴾</span></span> في موضع نصب على إسقاط حرف الجر، ويرجون رحمته عطف على يبتغون، ويرجون فعل مضارع وفاعل، ورحمته مفعول به، ويخافون عذابه عطف على يرجون رحمته.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن عذاب ربك كان محذورا﴾</span></span>: تعليل للخوف، وإن حرف ناسخ، وعذاب اسمها، وجملة كان خبرها، وكان فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، ومحذورًا خبر كان.</p></div>"
  17,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن من قرية إلا نحن مهلكوها قبل يوم القيامة أو معذبوها عذابا شديدا﴾</span></span>: الواو استئنافية، وإن نافية، ومن حرف جر صلة، وقرية مبتدأ مجرور لفظًا مرفوع محلًّا، وإلا أداة حصر، ونحن مبتدأ، ومهلكوها خبر، والجملة الاسمية خبر قرية، و<span class="hlt"><span class="qpc-hafs">﴿قبل يوم القيامة﴾</span></span> الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مهلكوها﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن من قرية...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ومعذبوها عطف على <span class="hlt"><span class="qpc-hafs">﴿مهلكوها﴾</span></span>، وعذابا نائب عن المفعول المطلق، لأنه اسم مصدر، وشديدًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان ذلك في الكتاب مسطورا﴾</span></span>: كان فعل ماض ناقص ناسخ، وذلك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في الكتاب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسطورًا﴾</span></span>، ومسطورًا خبر كان.</p></div>"
  17,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما منعنا أن نرسل بالآيات إلا أن كذب بها الأولون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، منعنا فعل ماض ومفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿أن نرسل﴾</span></span> في تأويل مصدر مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالآيات﴾</span></span> الباء حرف جر صلة، أو أصلية للملابسة، والمفعول محذوف، والجار والمجرور متعلقان بمحذوف حال، والمعنى: وما منعنا أن نرسل نبيًّا حالة كونه متلبسًا بالآيات، وإلا أداة حصر، وأن الثانية وما في حيزها في محل رفع فاعل منع، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذب﴾</span></span>، والأولون فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآتينا ثمود الناقة مبصرة فظلموا بها﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وآتينا فعل وفاعل، وثمود مفعول به أول، والناقة مفعول به ثان، ومبصرة حال، <span class="hlt"><span class="qpc-hafs">﴿فظلموا﴾</span></span> الفاء عاطفة، وظلموا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما نرسل بالآيات إلا تخويفا﴾</span></span>: الواو للحال، وما نافية، ونرسل فعل مضارع، وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿بالآيات﴾</span></span> الباء حرف جر صلة، أو أصلية للملابسة، وإلا أداة حصر، وتخويفًا مفعول لأجله، أو مصدر في موضع نصب على الحال، إما من الفاعل، أي: مخوفين بها، أو من المفعول، أي: مخوفًا بها.</p></div>"
  17,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قلنا لك إن ربك أحاط بالناس﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span> في محل جر مضاف إليه، وإن حرف ناسخ، وربك اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحاط بالناس﴾</span></span> خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما جعلنا الرؤيا التي أريناك إلا فتنة للناس﴾</span></span>: الواو عاطفة، وما نافية، وجعلنا الرؤيا فعل وفاعل ومفعول به، وأريناك صلة الموصول لا محل لها من الإعراب، وإلا أداة حصر، وفتنة مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والشجرة الملعونة في القرآن﴾</span></span>: عطف على الرؤيا، و<span class="hlt"><span class="qpc-hafs">﴿الملعونة﴾</span></span> نعت لها، و<span class="hlt"><span class="qpc-hafs">﴿في القرآن﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونخوفهم فما يزيدهم إلا طغيانا كبيرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ونخوفهم فعل مضارع، وفاعل مستتر، ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span> الفاء عاطفة، وما نافية، ويزيدهم فعل ومفعول به، والفاعل مستتر تقديره: تخويفنا، وإلا أداة حصر، وطغيانًا مفعول به ثان، وكبيرًا نعت.</p></div>"
  17,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، <span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span> في محل جر مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿للملائكة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span>، اسجدوا فعل أمر مبني على حذف النون، والواو فاعل، والجملة الفعلية في محل نصب مقول القول، <span class="hlt"><span class="qpc-hafs">﴿لآدم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسجدوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فسجدوا﴾</span></span> الفاء عاطفة، وسجدوا فعل وفاعل، إلا أداة استثناء، إبليس مستثنى بـ<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> متصل على اعتبار إبليس في الأصل من الملائكة، وقيل: منقطع، لأنه ليس منهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال أأسجد لمن خلقت طينا﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسجد﴾</span></span>، وجملة خلقت صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وطينًا حال من الموصول، والعامل فيها <span class="hlt"><span class="qpc-hafs">﴿أأسجد﴾</span></span>، أو من عائد هذا الموصول، أي: خلقته طينًا، فالعامل فيها خلقته، كأنه قال: متأصلًا من طين، وقيل: منصوب بنزع الخافض، أي: من طين، وقيل: تمييز.</p></div>"
  17,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أرأيتك هذا الذي كرمت علي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أرأيتك﴾</span></span> الهمزة للاستفهام، ورأى فعل ماض مبني على السكون، والتاء فاعل، والكاف لتأكيد الخطاب لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مفعول أول، والموصول صفة، أو بدل منه، والمفعول الثاني محذوف لدلالة الصلة عليه، أي: أخبرني عن هذا الذي كرمته علي بأن أمرتني بالسجود له لم كرمته علي.</p><p><span class="hlt"><span class="qpc-hafs">﴿لئن أخرتن إلى يوم القيامة لأحتنكن ذريته إلا قليلا﴾</span></span>: اللام موطئة للقسم، وإن شرطية، وأخرتني فعل وفاعل ومفعول به، والنون للوقاية، وهو فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم القيامة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرتني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لأحتنكن﴾</span></span> اللام واقعة في جواب القسم، وأحتنكن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: أنا، وذريته مفعول به، وإلا أداة استثناء، وقليلًا مستثنى من <span class="hlt"><span class="qpc-hafs">﴿ذريته﴾</span></span> منصوب، وجواب الشرط محذوف لدلالة جواب القسم عليه.</p></div>"
  17,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال اذهب فمن تبعك منهم﴾</span></span>: اذهب فعل أمر وفاعل مستتر، والجملة مقول القول، <span class="hlt"><span class="qpc-hafs">﴿فمن﴾</span></span> الفاء استئنافية، ومن شرطية مبتدأ، وتبعك فعل ماض، والفاعل مستتر، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿تبعك﴾</span></span> في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن جهنم جزاؤكم جزاء موفورا﴾</span></span>: الفاء رابطة لجواب الشرط، وإن حرف ناسخ، وجهنم اسمها، وجزاؤكم خبرها، وجزاء مفعول مطلق لفعل دل عليه جزاؤكم، أي: تجزون جزاء، أو انتصب بالمصدر، وقيل: هو حال موطئة، وقيل: تمييز، وموفورًا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمن تبعك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  17,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستفزز من استطعت منهم بصوتك وأجلب عليهم بخيلك ورجلك﴾</span></span>: الواو عاطفة، واستفزز أمر ثان للشيطان، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول مفعول استفزز، وجملة استطعت صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ومفعول استطعت محذوف تقديره: من استطعت أن تستفزه، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بصوتك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استفزز﴾</span></span>، وأجلب أمر ثالث، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بخيلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أجلب﴾</span></span>، ورجلك عطف على بخيلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشاركهم في الأموال والأولاد وعدهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وشاركهم في﴾</span></span> أمر رابع، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الأموال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شاركهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عدهم﴾</span></span> أمر خامس، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يعدهم الشيطان إلا غرورا﴾</span></span>: الواو للحال أو اعتراضية، وما نافية، ويعدهم الشيطان فعل مضارع ومفعول به مقدم وفاعل مؤخر، وإلا أداة حصر، وغرورًا صفة لمصدر محذوف، أي: إلا وعدًا غرورًا، وقيل: مفعول من أجله، أي: ما يعدهم ويمنيهم إلا لأجل الغرور، والجملة في محل نصب حال، أو اعتراضية لا محل لها من الإعراب.</p></div>"
  17,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن عبادي ليس لك عليهم سلطان وكفى بربك وكيلا﴾</span></span>: جملة تعليلية للأمر بالوعد، أي: إنما نأمرك بذلك لأننا نعلم أنه ليس لك سلطان على عبادنا الصالحين، وإن حرف ناسخ، وعبادي اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لسلطان، وسلطان اسم ليس مؤخر، وكفى فعل ماض، والباء صلة في الفاعل، ووكيلًا تمييز.</p></div>"
  17,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربكم الذي يزجي لكم الفلك في البحر﴾</span></span>: الجملة تعليل لبيان قدرته تعالى، وربكم مبتدأ، والذي خبره، وجملة يزجي صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يزجي﴾</span></span>، والفلك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في البحر﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتبتغوا من فضله﴾</span></span>: اللام للتعليل، وتبتغوا مضارع منصوب بأن مضمرة بعد لام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبتغوا﴾</span></span>، أي: تبتغوا الربح من فضله.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان بكم رحيما﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رحيمًا﴾</span></span>، ورحيمًا خبر كان.</p></div>"
  17,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مسكم الضر في البحر ضل من تدعون إلا إياه﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة مسكم مضاف إليه، والكاف مفعول به، والضر فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في البحر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حالة كونكم في البحر، وجملة ضل لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>، وجملة تدعون صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إلا إياه﴾</span></span> استثناء متصل، وقيل: منقطع، أي: ضل من تدعونه من الآلهة عن إغاثتكم، ولكن الله وحده هو الذي ترجونه وحده.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما نجاكم إلى البر أعرضتم وكان الإنسان كفورا﴾</span></span>: لما أداة شرط غير جازمة، ونجاكم فعل ماض ومفعول به، وهو فعل الشرط، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿إلى البر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجاكم﴾</span></span>، وأعرضتم جواب الشرط، وكان فعل ماض ناقص ناسخ، والإنسان اسمها، وكفورا خبرها.</p></div>"
  17,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفأمنتم أن يخسف بكم جانب البر﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف تقديره: أنجوتم فأمنتم فحملتكم نجاتكم على الإعراض؟ وأمنتم فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن يخسف﴾</span></span> في تأويل مصدر منصوب بنزع الخافض، أي: من أن يخسف، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مصحوبًا بكم، فالباء للمصاحبة، أو الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخسف﴾</span></span>، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿جانب البر﴾</span></span> مفعول يخسف.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو يرسل عليكم حاصبا﴾</span></span>: أو حرف عطف، ويرسل عطف على يخسف، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>، وحاصبًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا تجدوا لكم وكيلا﴾</span></span>: ثم حرف عطف للتراخي، ولا نافية، وتجدوا عطف على يرسل أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span> وتقدمت عليه، ووكيلًا مفعول به.</p></div>"
  17,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم أمنتم أن يعيدكم فيه تارة أخرى﴾</span></span>: أم حرف عطف، وأمنتم فعل وفاعل، والمصدر المؤول من أن والفعل في <span class="hlt"><span class="qpc-hafs">﴿أن يعيدكم﴾</span></span> منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تارة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span> أيضًا، وأخرى صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيرسل عليكم قاصفا من الريح فيغرقكم بما كفرتم﴾</span></span>: الفاء عاطفة، ويرسل عطف على أن يعيدكم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>، وقاصفًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الريح﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، والفاء حرف عطف، ويغرقكم عطف على يرسل، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغرقكم﴾</span></span>، وما مصدرية، أي: بسبب كفركم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا تجدوا لكم علينا به تبيعا﴾</span></span>: ثم حرف عطف، ولا تجدوا عطف على يغرقكم، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿تبيعًا﴾</span></span> وتقدمت عليه، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبيعًا﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبيعا﴾</span></span>.</p></div>"
  17,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد كرمنا بني آدم وحملناهم في البر والبحر﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وكرمنا فعل وفاعل، وبني آدم مفعول به، وحملناهم فعل وفاعل ومفعول به، عطف على كرمنا، <span class="hlt"><span class="qpc-hafs">﴿في البر والبحر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملناهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقناهم من الطيبات وفضلناهم على كثير ممن خلقنا تفضيلا﴾</span></span>: الواو عاطفة، ورزقناهم فعل وفاعل ومفعول به، عطف على كرمنا، و<span class="hlt"><span class="qpc-hafs">﴿من الطيبات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقناهم﴾</span></span>، وفضلناهم عطف على كرمنا، و<span class="hlt"><span class="qpc-hafs">﴿على كثير﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضلناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ممن خلقنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كثير﴾</span></span>، وجملة خلقنا صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وتفضيلًا مفعول مطلق.</p></div>"
  17,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم ندعو كل أناس بإمامهم﴾</span></span>: الظرف متعلق بمحذوف تقديره: اذكر، وندعو فعل مضارع، والفاعل مستتر تقديره: نحن، وكل أناس مفعول به، وجملة ندعو مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بإمامهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ندعو﴾</span></span>، أو متعلقان بمحذوف حال، أي: موسومين ومعروفين بإمامهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن أوتي كتابه بيمينه﴾</span></span>: الفاء عاطفة، ومن شرطية، أو موصولة في محل رفع مبتدأ، وأوتي فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، وكتابه مفعول به ثان، وبيمينه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك يقرءون كتابهم﴾</span></span>: الفاء رابطة، وأولئك مبتدأ، وجملة يقرءون خبر، وكتابهم مفعول به، وجملة أولئك جواب الشرط، أو خبر الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يظلمون فتيلا﴾</span></span>: الواو حرف عطف، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فتيلا﴾</span></span> نائب عن المفعول المطلق، أي: ظلمًا قدر الفتيل.</p></div>"
  17,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن كان في هذه أعمى﴾</span></span>: الواو عاطفة، ومن شرطية، أو موصولة، وكان فعل ماض ناقص ناسخ، واسمها ضمير مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، أو على ضمير الشأن، وأعمى خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو في الآخرة أعمى وأضل سبيلا﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرة﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأعمى خبر، وأضل عطف على أعمى، وسبيلًا تمييز.</p></div>"
  17,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كادوا ليفتنونك عن الذي أوحينا إليك لتفتري علينا غيره﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن مخففة من الثقيلة مهملة، وكادوا فعل ماض ناقص من أفعال المقاربة، والواو اسمها، واللام الفارقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفتنونك﴾</span></span> خبر كادوا، و<span class="hlt"><span class="qpc-hafs">﴿عن الذي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفتنونك﴾</span></span>، وجملة أوحينا صلة الذي لا محل لها من الإعراب، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿لتفتري﴾</span></span> اللام لام التعليل، وتفتري مضارع منصوب بأن مضمرة بعد لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفتري﴾</span></span>، والفاعل مستتر تقديره: أنت، وغيره مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا لاتخذوك خليلا﴾</span></span>: الواو عاطفة، وإذًا حرف جزاء وجواب يقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> الشرطية، أي: ولو اتبعت مرادهم، واللام واقعة في جواب الشرط المقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، والكاف مفعول به أول، وخليلًا مفعول به ثان.</p></div>"
  17,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا أن ثبتناك لقد كدت تركن إليهم شيئا قليلا﴾</span></span>: لولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ محذوف الخبر، واللام جواب لولا، وقد حرف تحقيق، وكدت فعل ماض من أفعال المقاربة، والتاء اسمها، وجملة تركن خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تركن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شيئا﴾</span></span> نائب عن المفعول المطلق، لأنه بمعنى الركون، أي: شيئًا قليلًا من الركون.</p></div>"
  17,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذا لأذقناك ضعف الحياة وضعف الممات ثم لا تجد لك علينا نصيرا﴾</span></span>: إذًا حرف جواب وجزاء يقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> الشرطية، أي: ولو اتبعت مرادهم،  واللام واقعة في جواب الشرط المقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وأذقناك فعل وفاعل ومفعول به، وضعف مفعول ثان، والحياة مضاف إليه، ولا بد من تقدير محذوف، أي: ضعف عذاب الحياة، وضعف عذاب الممات، وثم حرف عطف وتراخ، ولا نافية، وتجد فعل مضارع، وفاعله مستتر تقديره: أنت، ولك جار ومجرور متعلقان بتجد، وعلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نصيرًا﴾</span></span>، ونصيرًا مفعول به.</p></div>"
  17,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كادوا ليستفزونك من الأرض ليخرجوك منها﴾</span></span>: الواو عاطفة، وإن مخففة من الثقيلة مهملة، وكادوا من أفعال المقاربة، والواو اسمها، واللام الفارقة، وجملة يستفزونك خبر كادوا، و<span class="hlt"><span class="qpc-hafs">﴿من الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستفزونك﴾</span></span>، وليخرجوك اللام حرف جر، ويخرجوك فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور، الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستفزونك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجوك﴾</span></span>، والضمير يعود إلى الأرض.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا لا يلبثون خلافك إلا قليلا﴾</span></span>:الواو عاطفة، وإذًا حرف جواب وجزاء مهمل، ولا نافية، ويلبثون فعل مضارع مرفوع، وخلافك ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يلبثون﴾</span></span>، وإلا أداة حصر، وقليلًا صفة لظرف محذوف، أي: زمانًا قليلًا، أو صفة لمصدر محذوف، أي: لبثًا قليلًا.</p></div>"
  17,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سنة من قد أرسلنا قبلك من رسلنا﴾</span></span>: سنة نصبت على المصدرية،  أو نصبت بفعل محذوف، أي: اتبع سنة، وقيل: على نزع الخافض، أي: كسنة من قد أرسلنا، ومن اسم موصول في محل جر مضاف إليه، وأرسلنا فعل وفاعل، وقبلك ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿من رسلنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجد لسنتنا تحويلا﴾</span></span>: الواو عاطفة، ولا نافية، وتجد فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿لسنتنا﴾</span></span> جار ومجرور متعلقان بمحذوف منصوب مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجد﴾</span></span>، وتحويلا مفعول أول.</p></div>"
  17,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أقم الصلاة لدلوك الشمس إلى غسق الليل﴾</span></span>: أقم الصلاة فعل أمر وفاعل مستتر تقديره: أنت، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لدلوك﴾</span></span> اللام حرف جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى غسق الليل﴾</span></span> جار ومجرور متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span> أيضًا لانتهاء غاية إقامة الصلاة، أو متعلق بمحذوف حال من الصلاة، أي: أقمها ممتدة إلى غسق الليل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقرآن الفجر إن قرآن الفجر كان مشهودا﴾</span></span>: الواو عاطفة، وقرآن عطف على الصلاة، أو نصب على الإغراء، وإن حرف ناسخ، وقرآن اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان مشهودًا﴾</span></span> خبرها، وكان فعل ماض ناقص ناسخ، ومشهودًا خبر كان، واسم كان مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن قرآن...﴾</span></span> إلخ تعليل للأمر.</p></div>"
  17,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الليل فتهجد به نافلة لك﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من الليل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تهجد﴾</span></span>، أو بمحذوف، أي: قم قومة من الليل، وقيل: متعلقان بفعل دل عليه معنى الكلام تقديره: واسهر من الليل بالقرآن، والفاء عاطفة، وتهجد فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تهجد﴾</span></span>، ونافلة حال، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لنافلة، وقيل: متعلقان بمحذوف مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿عسى أن يبعثك ربك مقاما محمودا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿عسى﴾</span></span> من أفعال الرجاء، واسمه مستتر، و<span class="hlt"><span class="qpc-hafs">﴿أن يبعثك﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> فاعل يبعثك، و<span class="hlt"><span class="qpc-hafs">﴿مقامًا﴾</span></span> نصب على الظرف، أي: يبعثك في مقام، أو نائب عن المفعول المطلق، لأن <span class="hlt"><span class="qpc-hafs">﴿يبعثك﴾</span></span> معناها: يقيمك، أو حال، أي: يبعثك ذا مقام، و<span class="hlt"><span class="qpc-hafs">﴿محمودًا﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿مقامًا﴾</span></span>.</p></div>"
  17,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب أدخلني مدخل صدق وأخرجني مخرج صدق﴾</span></span>: رب منادى محذوف منه حرف النداء، وأدخلني فعل دعاء، وفاعل مستتر، والياء مفعول به. و<span class="hlt"><span class="qpc-hafs">﴿مدخل﴾</span></span> نائب مفعول مطلق لأنه مصدر ميمي. و<span class="hlt"><span class="qpc-hafs">﴿صدق﴾</span></span> مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿أخرجني مخرج صدق﴾</span></span> عطف على الجملة المماثلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿واجعل لي من لدنك سلطانا نصيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿واجعل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أدخلني﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿أخرجني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span>، وسلطانًا مفعول أول لـ<span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span>، ونصيرًا صفة، و<span class="hlt"><span class="qpc-hafs">﴿من لدنك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلطانًا﴾</span></span>، أو متعلقان بما تعلق به الأول.</p></div>"
  17,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل جاء الحق وزهق الباطل﴾</span></span>: جملة جاء الحق مقول القول، وزهق الباطل عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الباطل كان زهوقا﴾</span></span>: إن حرف ناسخ، والباطل اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبرها، وكان فعل ماض ناقص ناسخ، واسمها مستتر، وزهوقًا خبر كان.</p></div>"
  17,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وننزل من القرآن ما هو شفاء ورحمة للمؤمنين﴾</span></span>: الواو عاطفة، وننزل فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿من القرآن﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وشفاء خبر، والجملة صلة الموصول لا محل لها من الإعراب، ورحمة عطف على شفاء، و<span class="hlt"><span class="qpc-hafs">﴿للمؤمنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شفاء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يزيد الظالمين إلا خسارا﴾</span></span>: الواو حالية، ولا نافية، ويزيد الظالمين فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، وخسارًا مفعول به ثان.</p></div>"
  17,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا أنعمنا على الإنسان أعرض ونأى بجانبه﴾</span></span>: الواو حرف عطف، وإذا ظرف مستقبل، و<span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿على الإنسان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ونأى عطف على أعرض، و<span class="hlt"><span class="qpc-hafs">﴿بجانبه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نأى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مسه الشر كان يئوسا﴾</span></span>: عطف على ما تقدم، وجملة مسه الشر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> لا محل لها من الإعراب، واسم كان مستتر تقديره: هو، ويئوسًا خبر كان.</p></div>"
  17,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل كل يعمل على شاكلته﴾</span></span>: كل مبتدأ، وجملة يعمل خبر، و<span class="hlt"><span class="qpc-hafs">﴿على شاكلته﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعمل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فربكم أعلم بمن هو أهدى سبيلا﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وربكم مبتدأ، وأعلم خبره، و<span class="hlt"><span class="qpc-hafs">﴿بمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأهدى خبر، والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وسبيلًا تمييز.</p></div>"
  17,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسألونك عن الروح﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ويسألونك فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن الروح﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسألونك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل الروح من أمر ربي﴾</span></span>: الروح مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من أمر ربي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أوتيتم من العلم إلا قليلا﴾</span></span>: الواو عاطفة، أو حالية، وما نافية، وأوتيتم فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿من العلم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتيتم﴾</span></span>، وإلا أداة حصر، وقليلًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أوتيتم﴾</span></span>، أي: شيئًا قليلًا.</p></div>"
  17,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن شئنا لنذهبن بالذي أوحينا إليك﴾</span></span>: الواو عاطفة، واللام موطئة للقسم، وإن شرطية، وشئنا فعل ماض وفاعل في محل جزم فعل الشرط، واللام واقعة في جواب القسم، وجواب الشرط محذوف، أي: ذهبنا به، و<span class="hlt"><span class="qpc-hafs">﴿بالذي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذهبن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span> صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا تجد لك به علينا وكيلا﴾</span></span>: ثم حرف عطف، ولا نافية، وتجد فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span>، ووكيلًا مفعول به.</p></div>"
  17,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا رحمة من ربك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> منصوب على الاستثناء المتصل، أو أن الاستثناء منقطع فتكون <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> بمعنى لكن، أو أن <span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، والتقدير: حفظناه عليك للرحمة، أو مفعول مطلق، أي: ولكن رحمناك رحمة. و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لرحمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن فضله كان عليك كبيرا﴾</span></span>: إن حرف ناسخ، وفضله اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كبيرًا﴾</span></span>، وكبيرًا خبر كان.</p></div>"
  17,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لئن اجتمعت الإنس والجن على أن يأتوا بمثل هذا القرآن﴾</span></span>: اللام موطئة للقسم، وإن شرطية، واجتمعت فعل ماض في محل جزم فعل الشرط، والإنس فاعل، والجن عطف على الإنس، و<span class="hlt"><span class="qpc-hafs">﴿أن يأتوا﴾</span></span> أن وما في حيزها في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بمحذوف حال، أي: متظاهرين ومتعاونين، و<span class="hlt"><span class="qpc-hafs">﴿بمثل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مضاف إليه، والقرآن بدل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا يأتون بمثله﴾</span></span>: لا نافية، وجملة يأتون جواب القسم، ويأتون فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بمثله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو كان بعضهم لبعض ظهيرا﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> وصلية، وكان فعل ماض ناقص ناسخ، وبعضهم اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿لبعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span>، وظهيرًا خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لو كان...﴾</span></span> إلخ حالية.</p></div>"
  17,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صرفنا للناس في هذا القرآن من كل مثل﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وصرفنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، والقرآن بدل، و<span class="hlt"><span class="qpc-hafs">﴿من كل مثل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول به المحذوف، أي: من كل معنى هو كالمثل في غرابته وحسنه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأبى أكثر الناس إلا كفورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأبى﴾</span></span> عطف على صرفنا، و<span class="hlt"><span class="qpc-hafs">﴿أكثر الناس﴾</span></span> فاعل، وإلا أداة حصر، وكفورًا مفعول به.</p></div>"
  17,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لن نؤمن لك حتى تفجر لنا من الأرض ينبوعا﴾</span></span>: الواو عاطفة، وقالوا فعل وفاعل، ولن حرف نفي ونصب واستقبال، نؤمن نصب بها، وفاعل <span class="hlt"><span class="qpc-hafs">﴿نؤمن﴾</span></span> مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤمن﴾</span></span>، وحتى حرف غاية وجر، وتفجر فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤمن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفجر﴾</span></span>، وينبوعًا مفعول به.</p></div>"
  17,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو تكون لك جنة من نخيل وعنب فتفجر الأنهار خلالها تفجيرا﴾</span></span>: أو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> عطف على تفجر، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون المقدم، وجنة اسمها المؤخر، <span class="hlt"><span class="qpc-hafs">﴿فتفجر﴾</span></span> الفاء عطف، وتفجر عطف على تكون، وفاعله ضمير مستتر تقديره: أنت، والأنهار مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿خلالها﴾</span></span> ظرف متعلق بمحذوف حال، أي: كائنة خلالها، وتفجيرًا مفعول مطلق.</p></div>"
  17,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو تسقط السماء كما زعمت علينا كسفا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وتسقط عطف على ما تقدم، والسماء مفعول به، والكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، أو الكاف في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسقط﴾</span></span>، وكسفًا حال من السماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو تأتي بالله والملائكة قبيلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأتي﴾</span></span>، والملائكة عطف على <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، وقبيلًا حال من <span class="hlt"><span class="qpc-hafs">﴿الله والملائكة﴾</span></span> أو من أحدهما.</p></div>"
  17,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو يكون لك بيت من زخرف﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر يكون المقدم، وبيت اسم يكون المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من زخرف﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لبيت.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو ترقى في السماء﴾</span></span>: أو حرف عطف، وترقى عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿في السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترقى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولن نؤمن لرقيك حتى تنزل علينا كتابا نقرؤه﴾</span></span>: الواو عاطفة، ولن حرف نفي ونصب واستقبال، ونؤمن منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، وفاعله ضمير مستتر تقديره: نحن، ولرقيك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤمن﴾</span></span>، وحتى حرف غاية وجر، وتنزل فعل مضارع منصوب بأن مضمرة، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزل﴾</span></span>، وكتابًا مفعول به، وجملة نقرؤه نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كتابًا﴾</span></span>، أو حال مقدرة من <span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل سبحان ربي هل كنت إلا بشرا رسولا﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، وسبحان: نائب مفعول مطلق منصوب بفعل محذوف، وربي: مضاف إليه، والجملة مقول القول، وهل حرف استفهام معناه النفي والإنكار، وكنت فعل ماض ناقص، والتاء اسمها، وإلا أداة حصر، وبشرًا خبر <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span>، ورسولًا نعت، أو بشرا حال، ورسولا خبر <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span>.</p></div>"
  17,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما منع الناس أن يؤمنوا إذ جاءهم الهدى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، ومنع فعل ماض، والناس مفعول به مقدم، وأن وما في حيزها في محل نصب مفعول به ثان لمنع، وإذ ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءهم الهدى﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا أن قالوا أبعث الله بشرا رسولا﴾</span></span>: إلا أداة حصر، وأن وما في حيزها في محل رفع فاعل منع، والهمزة للاستفهام الإنكاري، وبعث الله فعل وفاعل، وبشرًا حال من رسولًا، لأنه كان نعتًا له، وتقدم عليه، ورسولًا مفعول به.</p></div>"
  17,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لو كان في الأرض ملائكة يمشون مطمئنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، ولو شرطية، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، وملائكة اسمها المؤخر، وجملة يمشون صفة لملائكة، ومطمئنين حال، وقيل: <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> تامة، وملائكة فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنزلنا عليهم من السماء ملكا رسولا﴾</span></span>: اللام واقعة في جواب لو، ونزلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلنا﴾</span></span> أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿ملكًا﴾</span></span> مفعول به، ورسولًا نعت.</p></div>"
  17,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل كفى بالله شهيدا بيني وبينكم﴾</span></span>: كفى فعل ماض، والباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مجرور بالباء لفظًا وهو فاعل كفى محلًّا، و<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span> تمييز، و<span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينكم﴾</span></span> عطف على الظرف الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان بعباده خبيرا بصيرا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، وخبيرًا بصيرًا خبران لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  17,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يهد الله﴾</span></span>: الواو استئنافية، ومن اسم شرط جازم في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يهد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يهد﴾</span></span> فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو المهتد﴾</span></span>: الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والمهتدي خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو المهتد﴾</span></span> في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يهد الله...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يضلل فلن تجد لهم أولياء من دونه﴾</span></span>: الواو عاطفة، والجملة معطوفة على سابقتها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أولياء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونحشرهم يوم القيامة على وجوههم عميا وبكما وصما﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ونحشرهم فعل وفاعل مستتر ومفعول به، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نحشرهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على وجوههم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الهاء في <span class="hlt"><span class="qpc-hafs">﴿نحشرهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عميًا﴾</span></span> وما عطف عليه أحوال أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿مأواهم جهنم كلما خبت زدناهم سعيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مأواهم جهنم﴾</span></span> جملة مستأنفة لا محل لها من الإعراب، وهي مؤلفة من مبتدأ وخبر، و<span class="hlt"><span class="qpc-hafs">﴿كلما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كلَّ﴾</span></span> نائب ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿زدناهم﴾</span></span> متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية زمانية، وجملة <span class="hlt"><span class="qpc-hafs">﴿خبت﴾</span></span> لا محل لها من الإعراب لأنها صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع مدخولها في تأويل مصدر مجرور بالإضافة والتقدير: كلَّ خبوٍ، وهو على حذف مضاف، أي: كلَّ وقتِ خبوٍ. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة بمعنى <span class="hlt"><span class="qpc-hafs">﴿وقت﴾</span></span> والعائد محذوف والتقدير: كلَّ وقتٍ خبت فيه، فتكون جملة <span class="hlt"><span class="qpc-hafs">﴿خبت﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿زدناهم﴾</span></span> فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل والهاء مفعول به أول، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿سعيرًا﴾</span></span> مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿زدناهم﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿كلما خبت زدناهم سعيرا﴾</span></span> حال من جهنم في محل نصب أو استئنافية لا محل لها من الإعراب.</p></div>"
  17,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك جزاؤهم بأنهم كفروا بآياتنا﴾</span></span>: ذلك اسم إشارة مبتدأ، وجزاؤهم خبره، و<span class="hlt"><span class="qpc-hafs">﴿بأنهم﴾</span></span> أن وما في حيزها في محل جر بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جزاؤهم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿جزاؤهم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بأنهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة كفروا خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا أئذا كنا عظاما ورفاتا﴾</span></span>: الهمزة للاستفهام الإنكاري، وإذا ظرف مستقبل، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وعظامًا خبرها، ورفاتًا عطف على <span class="hlt"><span class="qpc-hafs">﴿عظامًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئنا لمبعوثون خلقا جديدا﴾</span></span>: الهمزة للاستفهام الإنكاري والاستبعاد، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومبعوثون خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿خلقًا﴾</span></span> حال، أي: مخلوقين، أو نائب عن المفعول المطلق من معنى الفعل لا من لفظه، أي: نبعث بعثًا جديدًا، و<span class="hlt"><span class="qpc-hafs">﴿جديدًا﴾</span></span> صفة.</p></div>"
  17,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا أن الله الذي خلق السماوات والأرض قادر على أن يخلق مثلهم﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو عاطفة على محذوف، وأن وما في حيزها سدت مسد مفعولي يروا، والذي صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span> صلة الذي لا محل لها من الإعراب، وقادر خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿على أن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادر﴾</span></span>، ومثلهم صفة للمفعول المحذوف، أي: خلقًا مثلهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لهم أجلا لا ريب فيه﴾</span></span>: الواو عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل لهم﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أو لم يروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعل الثاني، وأجلًا مفعول جعل الأول، و<span class="hlt"><span class="qpc-hafs">﴿لا ريب فيه﴾</span></span> الجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أجلًا﴾</span></span>، ولا نافية للجنس، وريب اسمها المبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأبى الظالمون إلا كفورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأبى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والظالمون فاعل، وإلا أداة حصر، وكفورًا مفعول به.</p></div>"
  17,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لو أنتم تملكون خزائن رحمة ربي﴾</span></span>: لو شرطية. أنتم: في محل رفع فاعل للفعل المحذوف يدل عليه ما بعده. وجملة الفعل المحذوف في محل نصب مقول القول. وتملكون: فعل وفاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿تملكون﴾</span></span> تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿خزائن﴾</span></span> مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿قل...﴾</span></span> استئنافية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا لأمسكتم خشية الإنفاق﴾</span></span>: إذًا حرف جواب وجزاء مهمل، <span class="hlt"><span class="qpc-hafs">﴿لأمسكتم﴾</span></span> اللام واقعة في جواب لو، والجملة لا محل لها من الإعراب، وخشية الإنفاق مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الإنسان قتورا﴾</span></span>: الواو حالية، وكان فعل ماض ناقص ناسخ، والإنسان اسمها، وقتورا خبرها، والجملة منصوبة على الحال.</p></div>"
  17,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى تسع آيات بينات﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وآتينا فعل وفاعل، وموسى مفعول به أول، وتسع آيات مفعول به ثان، وبينات صفة مجرورة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاسأل بني إسرائيل إذ جاءهم﴾</span></span>: الفاء الفصيحة، وبني إسرائيل مفعول به، وإذ ظرف لما مضى متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتينا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> في محل جر مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿فقال له﴾</span></span> عطف على مقدر، أي: إذ جاءهم وبلغهم الرسالة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال له فرعون إني لأظنك يا موسى مسحورا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقال له فرعون﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وإني﴾</span></span> إن حرف ناسخ، والياء اسمها، واللام المزحلقة، وأظنك فعل مضارع، والفاعل مستتر تقديره: أنا، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يا موسى﴾</span></span> يا حرف نداء، وموسى منادى مفرد علم في محل نصب، ومسحورًا مفعول به ثان.</p></div>"
  17,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لقد علمت ما أنزل هؤلاء إلا رب السماوات والأرض بصائر﴾</span></span>: قال فعل ماض، وفاعله مستتر، واللام جواب للقسم المحذوف، وعلمت فعل وفاعل، وما نافية، وأنزل فعل ماض، وهؤلاء مفعول به، أي: الآيات التي جئت بها، وإلا أداة حصر، ورب السماوات والأرض فاعل، وبصائر حال من <span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإني لأظنك يا فرعون مثبورا﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء اسمها، واللام المزحلقة، وجملة أظنك خبر إن، ويا فرعون نداء، ومثبورًا مفعول ثان لأظنك.</p></div>"
  17,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأراد أن يستفزهم من الأرض﴾</span></span>: الفاء عاطفة، وأراد فعل ماض، والفاعل مستتر، أي: فرعون، والمصدر المؤول من أن وما في حيزها مفعول أراد، و<span class="hlt"><span class="qpc-hafs">﴿من الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستفزهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأغرقناه ومن معه جميعا﴾</span></span>: الفاء عاطفة، وأغرقناه فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> الواو واو المعية، ومن مفعول معه، أو معطوف على الهاء، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف مكان صلة مَن لا محل لها من الإعراب، وجميعًا حال.</p></div>"
  17,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقلنا من بعده لبني إسرائيل﴾</span></span>: الواو عاطفة، وقلنا عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿لبني إسرائيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿اسكنوا الأرض فإذا جاء وعد الآخرة جئنا بكم لفيفا﴾</span></span>: جملة اسكنوا مقول القول، والأرض مفعول به على السعة، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا ظرف مستقبل، وجاء وعد الآخرة فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿جئنا﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئنا﴾</span></span>، ولفيفًا حال.</p></div>"
  17,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبالحق أنزلناه وبالحق نزل﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وبالحق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> والباء سببية، أو جار ومجرور متعلقان بمحذوف حال من مفعول أنزلناه، أي: متلبسا بالحق، أو من فاعله، أي: متلبسين بالحق، والباء للملابسة، و<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span> والباء سببية، أو جار ومجرور متعلقان بمحذوف حال من فاعل نزل، والباء للملابسة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلناك إلا مبشرا ونذيرا﴾</span></span>: الواو عاطفة، وما نافية، وأرسلناك فعل وفاعل ومفعول به، وإلا أداة حصر، ومبشرًا حال، ونذيرًا معطوف عليه.</p></div>"
  17,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقرآنا فرقناه لتقرأه على الناس على مكث ونزلناه تنزيلا﴾</span></span>: الواو عاطفة، وقرآنًا منصوب بفعل محذوف يدل عليه ما بعده، وجملة الفعل المحذوف معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>. وفرقناه: فعل ماض، وفاعل، ومفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿فرقناه﴾</span></span> تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لتقرأه﴾</span></span> اللام للتعليل، وتقرأه مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فرقناه﴾</span></span>، وفرقناه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على الناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقرأه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على مكث﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل، أي: متريثًا متمهلًا، ونزلناه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿تنزيلا﴾</span></span> مفعول مطلق.</p></div>"
  17,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل آمنوا به أو لا تؤمنوا﴾</span></span>: جملة آمنوا مقول القول، أو لا تؤمنوا، أو حرف عطف، ولا ناهية، وتؤمنوا مجزوم بلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين أوتوا العلم من قبله إذا يتلى عليهم يخرون للأذقان سجدا﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة أوتوا العلم صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿العلم﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أوتوا﴾</span></span>، والأول نائب الفاعل وهو الواو في <span class="hlt"><span class="qpc-hafs">﴿أوتوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والجملة تعليلة، وإذا ظرف مستقبل متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يخرون﴾</span></span>، وجملة يتلى مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلى﴾</span></span>، وجملة يخرون لا محل لها من الإعراب، لأنها جواب إذا، وللأذقان جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرون﴾</span></span>، وسجدًا حال.</p></div>"
  17,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون سبحان ربنا إن كان وعد ربنا لمفعولا﴾</span></span>: الواو عاطفة، ويقولون عطف على يخرون، وسبحان: نائب مفعول مطلق منصوب بفعل محذوف، وربنا: مضاف إليه، وإن مخففة من الثقيلة مهملة، ووعد ربنا اسم كان، واللام الفارقة، ومفعولًا خبرها.</p></div>"
  17,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويخرون للأذقان يبكون﴾</span></span>: الجملة معطوفة على سابقتها، وجملة يبكون حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويزيدهم خشوعا﴾</span></span>: الواو عاطفة على يبكون، ويزيدهم فعل مضارع والفاعل مستتر، والهاء مفعول به أول، وخشوعًا مفعول به ثان.</p></div>"
  17,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل ادعوا الله أو ادعوا الرحمن﴾</span></span>: جملة ادعوا الله مقول القول، ولفظ الجلالة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> عاطفة، وادعوا معطوف على ادعوا الأولى، والرحمن مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيا ما تدعوا فله الأسماء الحسنى﴾</span></span>: أيًّا شرطية مفعول مقدم منصوب، وما صلة مؤكدة، وتدعوا فعل الشرط مجزوم وعلامة جزمه حذف النون، والواو فاعل، والفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الأسماء﴾</span></span> مبتدأ مؤخر، والحسنى صفة، وقيل: ما شرطية، وجمع بين أداتي الشرط للتأكيد.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجهر بصلاتك ولا تخافت بها وابتغ بين ذلك سبيلا﴾</span></span>: الواو عاطفة، ولا ناهية، وتجهر مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر تقديره: أنت، ولا تخافت عطف على ولا تجهر، وابتغ فعل أمر مبني على حذف حرف العلة، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سبيلًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مضاف إليه، وسبيلًا مفعول ابتغ.</p></div>"
  17,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل الحمد لله الذي لم يتخذ ولدا﴾</span></span>: جملة الحمد لله مقول القول، والحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والذي صفة، وجملة لم يتخذ ولدًا صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم يكن له شريك في الملك﴾</span></span>: عطف على لم يتخذ، ولم حرف نفي وقلب وجزم، ويكن فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿يكن﴾</span></span> المقدم، وشريك اسمها المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم يكن له ولي من الذل وكبره تكبيرا﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الذل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ولي﴾</span></span>، وكبره فعل أمر وفاعل مستتر ومفعول به، وهو عطف على قل، وتكبيرًا مفعول مطلق للتأكيد.</p></div>"
