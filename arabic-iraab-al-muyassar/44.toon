quran[59]{c,v,t}:
  44,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  44,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والكتاب المبين﴾</span></span>: الواو واو القسم، و<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، و<span class="hlt"><span class="qpc-hafs">﴿المبين﴾</span></span> نعت للكتاب.</p></div>"
  44,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أنزلناه في ليلة مباركة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والجملة خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿في ليلة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مباركة﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ليلة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا أنزلناه﴾</span></span> جواب القسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا كنا منذرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿منذرين﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبر إن. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا كنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب القسم أيضًا، أو لأنها مستأنفة، أو لأنها اعتراضية بين الصفة وهي قوله: <span class="hlt"><span class="qpc-hafs">﴿فيها يفرق كل أمر﴾</span></span> وبين الموصوف <span class="hlt"><span class="qpc-hafs">﴿ليلة﴾</span></span>.</p></div>"
  44,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيها يفرق كل أمر حكيم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ليلة﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفرق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يفرق﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿كل أمر﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿حكيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أمر﴾</span></span>.</p></div>"
  44,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أمرا﴾</span></span> حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> أو من مفعوله، أي: أنزلناه آمرين، أو مأمورا به، أو مفعول لأجله وناصبه إما أنزلناه وإما منذرين وإما يُفْرَق، أو أن <span class="hlt"><span class="qpc-hafs">﴿أمرا﴾</span></span> مفعول مطلق لفعل محذوف والتقدير: أمرنا أمرًا من عندنا، أو نائب مفعول مطلق لأنه في معنى مصدر يُفْرَق، أي: فرقًا، أو مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿منذرين﴾</span></span> ويكون المفعول الأول محذوفا أي: منذرين الناس أمرا.</p><p><span class="hlt"><span class="qpc-hafs">﴿من عندنا﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أمرا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا كنا مرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مرسلين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا مرسلين﴾</span></span> خبر إن.</p></div>"
  44,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رحمة من ربك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، والعامل فيه إما <span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>، وإما <span class="hlt"><span class="qpc-hafs">﴿أمرًا﴾</span></span>، وإما <span class="hlt"><span class="qpc-hafs">﴿يفرق﴾</span></span>، وإما <span class="hlt"><span class="qpc-hafs">﴿منذرين﴾</span></span>، أو مصدر منصوب بفعل مقدر، أي: رحمنا رحمة، أو مفعول بـ<span class="hlt"><span class="qpc-hafs">﴿مرسلين﴾</span></span>، أو حال من ضمير <span class="hlt"><span class="qpc-hafs">﴿مرسلين﴾</span></span>، أي: ذوي رحمة، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿أمرًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، أو متعلقان بنفس الرحمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو السميع العليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿السميع العليم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿السميع العليم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>.</p></div>"
  44,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض وما بينهما إن كنتم موقنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات والأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف صلة الموصول، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ في محل جزم فعل الشرط، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿موقنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>، وجواب الشرط محذوف تقديره: فأيقنوا بأن محمدًا رسوله.</p></div>"
  44,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. جملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر أيضًا لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> في الآية السادسة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يحيي ويميت ربكم ورب آبائكم الأولين﴾</span></span>: يحيي: فعل مضارع مرفوع بضمة مقدرة على الياء للثقل، والفاعل مستتر. ويميت: عطف على يحيي. و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> خبر رابع، أو خبر لمبتدأ محذوف. و<span class="hlt"><span class="qpc-hafs">﴿رب آبائكم الأولين﴾</span></span> عطف على ما تقدم.</p></div>"
  44,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل هم في شك يلعبون﴾</span></span>: بل حرف إضراب عن محذوف، كأنه قال: فليسوا بموقنين بل هم في شك بحسب ضمائرهم، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿يلعبون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلعبون﴾</span></span> حال.</p></div>"
  44,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فارتقب يوم تأتي السماء بدخان مبين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ارتقب﴾</span></span> فعل أمر، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿ارتقب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تأتي﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتي السماء﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿بدخان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأتي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿دخان﴾</span></span>.</p></div>"
  44,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يغشى الناس هذا عذاب أليم﴾</span></span>: الجملة في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿دخان﴾</span></span> أيضًا، ويغشى فعل مضارع مرفوع، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿أليم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، والجملة مقول قول محذوف، وجملة القول في محل نصب على الحال، أي: قائلين لربك.</p></div>"
  44,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربنا اكشف عنا العذاب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف، و<span class="hlt"><span class="qpc-hafs">﴿اكشف﴾</span></span> فعل دعاء مبني على السكون، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اكشف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿العذاب﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا مؤمنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مؤمنون﴾</span></span> خبرها، والجملة تعليلية للدعاء.</p></div>"
  44,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أنى لهم الذكرى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أنى﴾</span></span> اسم استفهام بمعنى كيف في محل نصب على الظرفية في محل رفع خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الذكرى﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد جاءهم رسول مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span> فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة.</p></div>"
  44,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم تولوا عنه وقالوا معلم مجنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span> فعل ماض، والواو فاعل، والعطف على محذوف، أي: فلم يذكروا ثم تولوا، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿معلم﴾</span></span> خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿مجنون﴾</span></span> خبر ثان.</p></div>"
  44,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كاشفو العذاب قليلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كاشفو العذاب﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿قليلًا﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كاشفو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنكم عائدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عائدون﴾</span></span> خبرها.</p></div>"
  44,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم نبطش البطشة الكبرى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف متعلق بمحذوف دل عليه <span class="hlt"><span class="qpc-hafs">﴿إنا منتقمون﴾</span></span>، أي: ننتقم، وقيل: بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم تأتي﴾</span></span>، وقيل: منصوب بإضمار: اذكر، وقيل: بـ<span class="hlt"><span class="qpc-hafs">﴿منتقمون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نبطش﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿البطشة﴾</span></span> مفعول مطلق، و<span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا منتقمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿منتقمون﴾</span></span> خبرها.</p></div>"
  44,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد فتنا قبلهم قوم فرعون وجاءهم رسول كريم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿فتنا﴾</span></span> فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قوم فرعون﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وجاءهم﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> فعل ماض ومفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كريم﴾</span></span> صفة.</p></div>"
  44,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أن أدوا إلي عباد الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن مجيء الرسل لا يكون إلا بدعوة وهي تتضمن القول، و<span class="hlt"><span class="qpc-hafs">﴿أدوا﴾</span></span> فعل أمر، وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدوا﴾</span></span> تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر منصوب بنزع الخافض، أي: بأن أدوا. والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿أدوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدوا﴾</span></span> في محل رفع خبر أن المخففة. و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> منادى مضاف محذوف منه حرف النداء، وقيل: <span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مفعول به، ولفظ الجلالة: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أمين﴾</span></span> صفة.</p></div>"
  44,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن لا تعلوا على الله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تعلوا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وعلامة جزمه حذف النون. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر منصوب بنزع الخافض، أي: بأن لا تعلوا، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿أدوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعلوا﴾</span></span> في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المخففة. و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني آتيكم بسلطان مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿آتيكم﴾</span></span> فعل مضارع مرفوع، والكاف مفعول به، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيكم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿بسلطان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتيكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة، والجملة تعليلية للنهي لا محل لها من الإعراب.</p></div>"
  44,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإني عذت بربي وربكم أن ترجمون﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span> فعل ماض، والتاء فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿بربي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بربي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ترجمون﴾</span></span> فعل مضارع منصوب بأن وعلامة نصبه حذف النون، والواو فاعل، والنون نون الوقاية، والياء المحذوفة مفعول به، وأن وما بعدها في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عُذت﴾</span></span>، أي: من أن ترجمون، وياء المتكلم المحذوفة مفعول ترجمون.</p></div>"
  44,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن لم تؤمنوا لي فاعتزلون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تؤمنوا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وهو فعل الشرط، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿اعتزلون﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿اعتزلون﴾</span></span> في محل جزم جواب الشرط.</p></div>"
  44,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فدعا ربه أن هؤلاء قوم مجرمون﴾</span></span>: الفاء حرف عطف، والكلام معطوف على مقدر تقديره: فلم يتركوه، و<span class="hlt"><span class="qpc-hafs">﴿دعا﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، وهؤلاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> خبر أن، ومجرمون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> ومدخولها في محل نصب بنزع الخافض، أي: بأن هؤلاء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دعا﴾</span></span>.</p></div>"
  44,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأسر بعبادي ليلا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿بعبادي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليلًا﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span> أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنكم متبعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿متبعون﴾</span></span> خبرها، والجملة تعليل للأمر بالإسراء.</p></div>"
  44,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واترك البحر رهوا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اترك﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، والبحر مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿رهوًا﴾</span></span> حال، أو مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اترك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم جند مغرقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مغرقون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>، والجملة تعليل للأمر بالترك.</p></div>"
  44,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كم تركوا من جنات وعيون﴾</span></span>: الكلام مرتبط بمقدر، والتقدير: فاطمأن موسى بذلك فتم إغراقهم، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> خبرية في محل نصب مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تركوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تركوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة و<span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span> تمييز <span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> منصوب محلا، و<span class="hlt"><span class="qpc-hafs">﴿عيون﴾</span></span> معطوف على لفظ <span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span> مجرور.</p></div>"
  44,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وزروع ومقام كريم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿جنات وعيون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كريم﴾</span></span> صفة مجرورة.</p></div>"
  44,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونعمة كانوا فيها فاكهين﴾</span></span>: عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاكهين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فاكهين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span>.</p></div>"
  44,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك وأورثناها قوما آخرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر لمبتدأ محذوف، والتقدير: الأمر مثل ذلك، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أورثناها﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿كم تركوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿آخرين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>.</p></div>"
  44,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما بكت عليهم السماء والأرض﴾</span></span>: الفاء عاطفة، والكلام معطوف على جملة أغرقوا المقدرة، و<span class="hlt"><span class="qpc-hafs">﴿بكت﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بكت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كانوا منظرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿منظرين﴾</span></span> خبرها.</p></div>"
  44,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد نجينا بني إسرائيل﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿نجينا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بني إسرائيل﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من العذاب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المهين﴾</span></span> صفة للعذاب.</p></div>"
  44,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من فرعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من فرعون﴾</span></span> بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿من العذاب﴾</span></span> بإعادة الجار، وقيل: متعلقان بمحذوف حال من العذاب، أي: كائنًا، أو صادرًا من فرعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان عاليا من المسرفين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، وجملة كان خبرها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿عاليًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من المسرفين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> وما بعدها لا محل لها من الإعراب، لأنها تعليلية.</p></div>"
  44,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد اخترناهم﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿اخترناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿على علم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿على العالمين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخترناهم﴾</span></span>.</p></div>"
  44,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناهم من الآيات﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول، و<span class="hlt"><span class="qpc-hafs">﴿من الآيات﴾</span></span> جار ومجرور متعلقان بمحذوف حال مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما فيه بلاء مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿بلاء﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بلاء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فيه بلاء﴾</span></span> صلة الموصول.</p></div>"
  44,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هؤلاء ليقولون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، والجملة خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن هؤلاء...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  44,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هي إلا موتتنا الأولى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿موتتنا﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأولى﴾</span></span> نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما نحن بمنشرين﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمنشرين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿منشرين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  44,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتوا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span> فعل أمر مبني على حذف النون، والواو ضمير متصل في محل رفع فاعل، والجملة في محل جزم جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿بآبائنا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿صادقين﴾</span></span>: خبرها، وجواب الشرط محذوف، أي: فافعلوا ذلك.</p></div>"
  44,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أهم خير﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم قوم تبع والذين من قبلهم أهلكناهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿قوم تبع﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿قوم تبع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أهلكناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أهلكناهم﴾</span></span> حال من المعطوف والمعطوف عليه، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا مجرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا مجرمين﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مجرمين﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا مجرمين﴾</span></span> تعليلية لا محل لها من الإعراب، لأنها تعليل لإهلاكهم.</p></div>"
  44,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما خلقنا السماوات والأرض﴾</span></span>: الواو استئنافية. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿خلقنا السماوات﴾</span></span> فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما بينهما لاعبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات والأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لاعبين﴾</span></span> حال من الفاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿وما خلقنا السماوات...﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  44,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما خلقناهما إلا بالحق﴾</span></span>: الجملة بدل اشتمال من جملة <span class="hlt"><span class="qpc-hafs">﴿وما خلقنا السماوات والأرض وما بينهما لاعبين﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿خلقناهما﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم لا يعلمون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> حرف ناسخ للاستدراك، و<span class="hlt"><span class="qpc-hafs">﴿أكثرهم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبرها.</p></div>"
  44,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن يوم الفصل ميقاتهم أجمعين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿الفصل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ميقاتهم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿أجمعين﴾</span></span> تأكيد للضمير، أي: للناس جميعًا.</p></div>"
  44,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم لا يغني مولى عن مولى شيئا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم الفصل﴾</span></span>، أو ظرف لما دل عليه الفصل، أي: يفصل بينهم يوم لا يغني، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿مولى﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عن مولى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به، أو نائب عن المفعول المطلق، أي: إغناء قليلا أو كثيرا، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يغني﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم ينصرون﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span> خبر.</p></div>"
  44,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من رحم الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> في محل رفع بدل من الواو في <span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span>، أو منصوب على الاستثناء، أي: ولكن من رحم الله لا ينالهم ما يحتاجون فيه إلى من ينفعهم من المخلوقين، أو الاستثناء متصل تقديره: لا يغني قريب عن قريب إلا المؤمنين، وجملة <span class="hlt"><span class="qpc-hafs">﴿رحم الله﴾</span></span> فعل وفاعل صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو العزيز الرحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الرحيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الرحيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  44,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن شجرة الزقوم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿الزقوم﴾</span></span> مضاف إليه.</p></div>"
  44,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طعام الأثيم﴾</span></span>: خبر المبتدأ في الآية السابقة.</p></div>"
  44,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كالمهل يغلي في البطون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كالمهل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المهل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يغلي﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغلي﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿الزقوم﴾</span></span>، أو من <span class="hlt"><span class="qpc-hafs">﴿طعام الأثيم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في البطون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغلي﴾</span></span>.</p></div>"
  44,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كغلي الحميم﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: تغلي غليانًا مثل غليان الحميم، و<span class="hlt"><span class="qpc-hafs">﴿غلي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الحميم﴾</span></span> مضاف إليه.</p></div>"
  44,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خذوه﴾</span></span>: فعل أمر مبني على حذف النون، والواو فاعله، والهاء مفعوله، والجملة مقول قول محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاعتلوه﴾</span></span>: فعل أمر عطف على <span class="hlt"><span class="qpc-hafs">﴿خذوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى سواء الجحيم﴾</span></span>: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعتلوه﴾</span></span>.</p></div>"
  44,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم صبوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿صبوا﴾</span></span> فعل أمر، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوق رأسه من عذاب الحميم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فوق رأسه﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿صبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الحميم﴾</span></span> مجرور لفظا منصوب محلا مفعول به.</p></div>"
  44,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذق إنك أنت العزيز الكريم﴾</span></span>: الجملة مقول قول محذوف، أي: ويقال له: ذق، و<span class="hlt"><span class="qpc-hafs">﴿ذق﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الكريم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الكريم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك أنت العزيز الكريم﴾</span></span> تعليلية.</p></div>"
  44,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا ما كنتم به تمترون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> خبرها، وكنتم فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمترون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تمترون﴾</span></span> فعل مضارع والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمترون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  44,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في مقام أمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿المتقين﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في مقام﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿أمين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مقام﴾</span></span>.</p></div>"
  44,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في جنات وعيون﴾</span></span>: الجار والمجرور بدل من <span class="hlt"><span class="qpc-hafs">﴿في مقام﴾</span></span> بإعادة الجار.</p></div>"
  44,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يلبسون من سندس وإستبرق متقابلين﴾</span></span>: الجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من سندس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span>.</p></div>"
  44,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك وزوجناهم بحور عين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: الأمر كذلك، وهذه الجملة اعتراضية بين المعطوف والمعطوف عليه، لا محل لها من الإعراب، جيء بها للتقرير، و<span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span> فعل ماض وفاعل ومفعول به، عطف على <span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بحور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حور﴾</span></span>.</p></div>"
  44,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدعون فيها بكل فاكهة آمنين﴾</span></span>: الجملة حال من الهاء في <span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بكل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آمنين﴾</span></span> حال، أي: لا يخافون من مغبة أكلها.</p></div>"
  44,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يذوقون فيها الموت إلا الموتة الأولى﴾</span></span>: الجملة حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿آمنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يذوقون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الموت﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿الموتة﴾</span></span> مستثنى من <span class="hlt"><span class="qpc-hafs">﴿الموت﴾</span></span> على أنه استثناء منقطع، و<span class="hlt"><span class="qpc-hafs">﴿الأولى﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ووقاهم عذاب الجحيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿وقاهم﴾</span></span> فعل ماض، والفاعل مستتر يعود على الله، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الجحيم﴾</span></span> مفعول به ثان.</p></div>"
  44,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فضلا﴾</span></span>: نائب مفعول مطلق، أي: تفضَّل فَضْلا وهو اسم مصدر، أو: مفعول من أجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فضلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: ضمير فصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span>: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span>: نعت للفوز، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span> خبره، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p></div>"
  44,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما يسرناه بلسانك﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿يسرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بلسانك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرناه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلهم يتذكرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿يتذكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتذكرون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span>.</p></div>"
  44,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فارتقب إنهم مرتقبون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ارتقب﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، ومفعوله محذوف تقديره: هلاكهم، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مرتقبون﴾</span></span> خبرها، ومفعول <span class="hlt"><span class="qpc-hafs">﴿مرتقبون﴾</span></span> محذوف أيضًا تقديره: هلاكك، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم مرتقبون﴾</span></span> تعليلية للأمر بالانتظار.</p></div>"
