quran[98]{c,v,t}:
  19,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كهيعص‌﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  19,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذكر رحمة ربك عبده زكريا﴾</span></span>: ذكر خبر لمبتدأ محذوف، ورحمة ربك مضاف إليه من إضافة المصدر لمفعوله، وعبده مفعول به لرحمة، وزكريا بدل من عبده، أو عطف بيان له.</p></div>"
  19,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ نادى ربه نداء خفيا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span> فعل ماض، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مفعول به، والهاء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿نداء﴾</span></span> مفعول مطلق، و<span class="hlt"><span class="qpc-hafs">﴿خفيًّا﴾</span></span> صفة.</p></div>"
  19,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إني وهن العظم مني واشتعل الرأس شيبا﴾</span></span>: رب منادى مضاف لياء المتكلم المحذوفة، وإن حرف ناسخ،  والياء ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهن العظم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿مني﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واشتعل عطف على وهن، والرأس فاعل، وشيبًا تمييز محول عن الفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم أكن بدعائك رب شقيا﴾</span></span>: الواو عاطفة، ولم حرف نفي وقلب وجزم، وأكن فعل مضارع ناقص مجزوم بلم، واسمها مستتر تقديره: أنا، وشقيًّا خبر أكن منصوب، وبدعائك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شقيًّا﴾</span></span>، ورب منادى مضاف إلى ياء المتكلم المحذوفة.</p></div>"
  19,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإني خفت الموالي من ورائي وكانت امرأتي عاقرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإني﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿إني وهن﴾</span></span>، والياء اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿خفت﴾</span></span> خبرها، والموالي مفعول به، <span class="hlt"><span class="qpc-hafs">﴿من ورائي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الموالي﴾</span></span>، أو بمحذوف هو حال من الموالي، والياء في محل جر مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وكانت امرأتي عاقرًا﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص، والتاء للتأنيث، وامرأة اسم كان مرفوع، والياء ضمير مبني في محل جر مضاف إليه، وعاقرا خبر كان منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهب لي من لدنك وليا﴾</span></span>: الفاء الفصيحة، وهب فعل دعاء، ولي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من لدنك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ووليًّا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>.</p></div>"
  19,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب واجعله رب رضيا﴾</span></span>: جملة يرثني صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وليًّا﴾</span></span>، ويرث عطف على يرثني، و<span class="hlt"><span class="qpc-hafs">﴿من آل يعقوب﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرث﴾</span></span>، والمفعول محذوف، والمراد إرث النبوة والعلم، والياء في <span class="hlt"><span class="qpc-hafs">﴿يرثني﴾</span></span> منصوبة بنزع الخافض، واجعله فعل دعاء وفاعل مستتر، ورب منادى مضاف لياء المتكلم المحذوفة، ورضيًّا مفعول به ثان لاجعله.</p></div>"
  19,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا زكريا إنا نبشرك بغلام اسمه يحيى﴾</span></span>: يا حرف نداء، وزكريا منادى علم مبني على الضم، وإنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، وجملة نبشرك خبر إن، والكاف مفعول به، وبغلام جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبشرك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اسمه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يحيى﴾</span></span> خبره، والجملة الاسمية صفة لغلام.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span></span>: الجملة صفة ثانية لغلام، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول نجعل الثاني، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وسميًّا مفعول نجعل الأول.</p></div>"
  19,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب أنى يكون لي غلام وكانت امرأتي عاقرا وقد بلغت من الكبر عتيا﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، وأنى اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بالاستقرار في خبر يكون، ولي جار ومجرور متعلقان بمحذوف خبر يكون المقدم، وغلام اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿وكانت امرأتي عاقرًا﴾</span></span>: الواو للحال، وكان فعل ماض ناقص، والتاء للتأنيث، وامرأة اسم كان مرفوع، والياء ضمير مبني في محل جر مضاف إليه، وعاقرا خبر كان منصوب، والجملة حالية، وقد بلغت من الكبر جملة حالية أيضًا، ومن الكبر جار ومجرور متعلقان ببلغت، أو بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿عتيًّا﴾</span></span>، لأنه كان صفة له، وتقدم عليه، وعتيًّا مفعول بلغت.</p></div>"
  19,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كذلك قال ربك هو علي هين وقد خلقتك من قبل ولم تك شيئا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر لمبتدأ محذوف، أي: الأمر كذلك، أو في محل نصب بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، والإشارة إلى مبهم يدل عليه: <span class="hlt"><span class="qpc-hafs">﴿هو علي هين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قال ربك﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وقد: الواو حالية، وقد حرف تحقيق، وخلقتك فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقتك﴾</span></span>، والواو حالية، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تك﴾</span></span> فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، واسم <span class="hlt"><span class="qpc-hafs">﴿تك﴾</span></span> مستتر، وشيئًا خبر تك، وجملة ولم تك شيئًا حال متداخلة.</p></div>"
  19,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب اجعل لي آية﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، واجعل فعل دعاء، ولي جار ومجرور متعلقان بمحذوف مفعول به ثان، وآية مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال آيتك ألا تكلم الناس ثلاث ليال سويا﴾</span></span>: آيتك مبتدأ، وأن وما في حيزها خبر، والناس مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ثلاث ليال﴾</span></span> نصب على الظرف، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تكلم﴾</span></span>، وسويًّا حال من فاعل تكلم، وقيل: سويًّا نصب على الصفة لـ<span class="hlt"><span class="qpc-hafs">﴿ثلاث﴾</span></span> بمعنى أنها كاملات.</p></div>"
  19,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخرج على قومه من المحراب فأوحى إليهم أن سبحوا بكرة وعشيا﴾</span></span>: الفاء استئنافية. وخرج: فعل وفاعل مستتر. و<span class="hlt"><span class="qpc-hafs">﴿على قومه﴾</span></span>: جار ومجرور متعلقان بمحذوف حال. و<span class="hlt"><span class="qpc-hafs">﴿من المحراب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خرج﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿فأوحى﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿خرج﴾</span></span>. وإليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، والمصدر المؤول من أن والفعل مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿سبحوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. وسبحوا: فعل أمر، والواو: فاعل، وبكرة: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سبح﴾</span></span>، وعشيًّا عطف على <span class="hlt"><span class="qpc-hafs">﴿بكرة﴾</span></span>.</p></div>"
  19,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا يحيى خذ الكتاب بقوة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> أداة نداء، و<span class="hlt"><span class="qpc-hafs">﴿يحيى﴾</span></span> منادى مفرد علم، و<span class="hlt"><span class="qpc-hafs">﴿خذ الكتاب﴾</span></span> فعل أمر وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بقوة﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل خذ، والباء للملابسة، أي: حال كونك متلبسًا بقوة واجتهاد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وآتيناه فعل وفاعل ومفعول به أول، والحكم مفعول به ثان، وصبيًّا حال من الهاء.</p></div>"
  19,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحنانا من لدنا وزكاة وكان تقيا﴾</span></span>: الواو عاطفة، وحنانًا عطف على الحكم، أي: وآتيناه حنانًا، وقيل: مفعول مطلق لفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حنانًا﴾</span></span>، وزكاة عطف على <span class="hlt"><span class="qpc-hafs">﴿حنانًا﴾</span></span>، وكان تقيًا عطف على آتيناه، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، وتقيًّا خبر كان منصوب.</p></div>"
  19,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبرا بوالديه ولم يكن جبارا عصيا﴾</span></span>: الواو عاطفة، وبرًّا عطف على <span class="hlt"><span class="qpc-hafs">﴿تقيًّا﴾</span></span>، وبوالديه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿برًّا﴾</span></span>، ولم يكن عطف على: وكان تقيًّا، واسم يكن مستتر تقديره: هو، وجبارًا خبرها، وعصيًّا نعت.</p></div>"
  19,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</span></span>: الواو استئنافية، وسلام مبتدأ، وساغ الابتداء به مع أنه نكرة لتضمنه الدعاء، وعليه جار ومجرور متعلقان بمحذوف خبر، ويوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>، وجملة ولد مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وسلام عليه يوم ولد﴾</span></span> مستأنفة لا محل لها من الإعراب، وما بعده عطف عليه، و<span class="hlt"><span class="qpc-hafs">﴿حيًّا﴾</span></span> حال.</p></div>"
  19,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب مريم إذ انتبذت﴾</span></span>: الواو استئنافية، واذكر فعل أمر وفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان باذكر، ومريم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بمضاف محذوف والتقدير: واذكر خبر مريم أو نبأ مريم، فالظرف متعلق بذلك الخبر أو النبأ. أو <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل اشتمال من مريم، والمعنى: اذكر وقت انتباذها، وجملة <span class="hlt"><span class="qpc-hafs">﴿انتبذت﴾</span></span> في محل جر مضاف إليه، ومن أهلها حال، ومكانًا ظرف متعلق بانتبذت، أي: في مكان، أو مفعول به على أن معنى انتبذت: أتت، وشرقيًّا نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب مريم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  19,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتخذت من دونهم حجابا فأرسلنا إليها روحنا فتمثل لها بشرا سويا﴾</span></span>: الفاء عاطفة، واتخذت فعل ماض وفاعل مستتر، ومن دونهم جار ومجرور متعلقان بمحذوف مفعول به ثان، وحجابًا مفعول به أول، <span class="hlt"><span class="qpc-hafs">﴿فأرسلنا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فاتخذت﴾</span></span>، وإليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وروحنا مفعول به، فتمثل عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمثل﴾</span></span>، وبشرًا حال، وسويًّا نعت، وسوغ وقوع الحال جامدة وصفها.</p></div>"
  19,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span></span>: إن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة أعوذ خبر إن، والجملة مقول القول، وبالرحمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، ومنك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span> أيضًا، وإن حرف شرط جازم وكنت فعل ماض ناقص، والتاء ضمير مبني في محل رفع اسم كان، وتقيًّا خبر كان منصوب، وجواب الشرط محذوف.</p></div>"
  19,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</span></span>: إنما كافة ومكفوفة، وأنا مبتدأ، ورسول خبر، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مضاف إليه، واللام للتعليل، وأهب فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان برسول أو بفعل محذوف تقديره: أرسلني، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهب﴾</span></span>، وغلامًا مفعول به، وزكيًّا صفة.</p></div>"
  19,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت أنى يكون لي غلام ولم يمسسني بشر ولم أك بغيا﴾</span></span>: أنى اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بالاستقرار في خبر يكون. <span class="hlt"><span class="qpc-hafs">﴿ولم يمسسني﴾</span></span>: الواو حالية، ولم حرف نفي وقلب وجزم، ويمسسني مضارع مجزوم بلم، والياء مفعول به، وبشر فاعل. <span class="hlt"><span class="qpc-hafs">﴿ولم أك بغيًّا﴾</span></span>: لم حرف نفي وقلب وجزم، وأك مضارع مجزوم، وعلامة جزمه السكون على النون المحذوفة للتخفيف، واسم أك مستتر، وبغيًّا خبرها.</p></div>"
  19,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كذلك قال ربك هو علي هين﴾</span></span>: كذلك جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، وقال ربك فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وعلي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هين﴾</span></span>، وهين خبر هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجعله آية للناس ورحمة منا وكان أمرا مقضيا﴾</span></span>: لنجعله تعليل معلله محذوف، أي: فعلنا ذلك. أو هو معطوف على مضمر، أي: لنبين به قدرتنا ولنجعله آية. وآية مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجعله﴾</span></span>، وللناس جار ومجرور متعلقان بمحذوف صفة لآية، ورحمة منا عطف على آية. <span class="hlt"><span class="qpc-hafs">﴿وكان أمرًا مقضيًّا﴾</span></span> كان فعل ماض ناقص، واسمها ضمير مستتر، وأمرا خبر كان منصوب، ومقضيًّا صفة.</p></div>"
  19,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فحملته فانتبذت به مكانا قصيا﴾</span></span>: الفاء عاطفة على محذوف، تقديره: فنفخ جبريل في جيب درعها فحملته، فانتبذت عطف على فحملته، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف في موضع نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿مكانًا﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿انتبذ﴾</span></span>، أو مفعول به، وقصيًّا صفة.</p></div>"
  19,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأجاءها المخاض إلى جذع النخلة﴾</span></span>: الفاء عاطفة، وأجاءها فعل ماض، ومفعول به مقدم، والمخاض فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿إلى جذع﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والنخلة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span></span>: يا حرف نداء، والمنادى محذوف، أو حرف تنبيه، وليت حرف ناسخ، والياء ضمير مبني في محل نصب اسم ليت، وجملة مت خبر ليت، وهي فعل وفاعل، والظرف منصوب وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مت﴾</span></span>، وهذا مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وكنت﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص، والتاء ضمير مبني في محل رفع اسم كان، ونسيًا خبر كان منصوب، ومنسيًّا نعت، أو تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿نسيًا﴾</span></span>، لأنه بمعناه.</p></div>"
  19,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فناداها من تحتها ألا تحزني﴾</span></span>: الفاء: عاطفة، وناداها: فعل، ومفعول به، وفاعل مستتر يعود على المَلَك أو عيسى. و<span class="hlt"><span class="qpc-hafs">﴿من تحتها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناداها﴾</span></span>، أو بمحذوف حال من الفاعل. وأن تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. ولا ناهية، وتحزني مجزوم بلا. وقيل: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وتحزني منصوب بها، ولا نافية، وأن وما بعدها نصب بنزع الخافض المتعلق بالنداء. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تحزني﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span></span>: قد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جعل ربك﴾</span></span> فعل وفاعل، وتحتك ظرف متعلق بمحذوف هو المفعول الثاني لجعل، وسريًّا هو المفعول الأول.</p></div>"
  19,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</span></span>: الواو عاطفة، وهزي فعل أمر مبني على حذف حرف العلة، والياء هي الفاعل، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هزي﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿بجذع النخلة﴾</span></span>: الباء صلة وجذع النخلة مفعول، وتساقط مجزوم في جواب الطلب، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تساقط﴾</span></span>، ورطبًا مفعول به، وجنيًّا صفة.</p></div>"
  19,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكلي واشربي وقري عينا﴾</span></span>: الفاء الفصيحة، وكلي فعل أمر، والياء فاعل، وما بعده عطف عليه، وعينًا تمييز محول عن الفاعل، إذ الأصل: لتقر عينك.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإما ترين من البشر أحدا﴾</span></span>: الفاء عاطفة، وإن شرطية أدغمت نونها بـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وما صلة، وترين فعل الشرط، ونون التوكيد، و<span class="hlt"><span class="qpc-hafs">﴿من البشر﴾</span></span> جار ومجرور متعلقان بمحذوف حال لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أحدًا﴾</span></span>، وأحدًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</span></span>: الفاء رابطة لجواب الشرط، وقولي فعل أمر مبني على حذف النون، والياء فاعل، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة نذرت خبر إن، والجملة مقول القول، وللرحمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذرت﴾</span></span>، وصومًا مفعول به. <span class="hlt"><span class="qpc-hafs">﴿فلن﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولن حرف نفي ونصب واستقبال، وأكلم منصوب بلن، واليوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أكلم﴾</span></span>، وإنسيًّا مفعول به.</p></div>"
  19,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتت به قومها تحمله قالوا يا مريم لقد جئت شيئا فريا﴾</span></span>: الفاء استئنافية، وأتت فعل وفاعل مستتر، والتاء للتأنيث، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مصحوبة به، وقيل: متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتت﴾</span></span>، وقومها مفعول به، وجملة تحمله حال ثانية، إما من ضمير مريم، وإما من ضمير عيسى في: به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأتت...﴾</span></span> مستأنفة لا محل لها من الإعراب، قالوا فعل وفاعل، ويا حرف نداء، ومريم منادى، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وجئت فعل وفاعل، وشيئًا مفعول به، أي: فعلت شيئًا، وفريًّا نعت، وقيل: منصوب على المصدرية، أي: نوعًا من المجيء غريبًا.</p></div>"
  19,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أخت هارون ما كان أبوك امرأ سوء وما كانت أمك بغيا﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أخت هارون﴾</span></span> منادى مضاف. <span class="hlt"><span class="qpc-hafs">﴿ما كان أبوك امرأ سوء﴾</span></span>: ما نافية، وكان فعل ناسخ، وأبو اسم كان مرفوع بالواو، لأنه من الأسماء الخمسة، والكاف ضمير مبني في محل جر مضاف إليه، وامرأ خبر كان منصوب، وسوء مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وما كانت أمك بغيًّا﴾</span></span> عطف على الجملة التي سبقتها.</p></div>"
  19,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأشارت إليه قالوا كيف نكلم من كان في المهد صبيا﴾</span></span>: الفاء عاطفة، وأشارت فعل وفاعل مستتر، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشارت﴾</span></span>، قالوا فعل وفاعل، وكيف اسم استفهام في محل نصب حال، ونكلم فعل مضارع وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مبني في محل نصب مفعول به، وجملة كان صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، واسم كان مستتر، و<span class="hlt"><span class="qpc-hafs">﴿في المهد﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وصبيًّا خبر كان.</p></div>"
  19,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿إني عبد الله﴾</span></span> مقول القول، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وعبد الله خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتاني الكتاب﴾</span></span> حالية، والكتاب مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿جعلني نبيًّا﴾</span></span> فعل ماض، وفاعل مستتر، ومفعولاه.</p></div>"
  19,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلني مباركا أين ما كنت﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وجعلني مباركًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وجعلني نبيًّا﴾</span></span>، وأينما اسم شرط جازم في محل نصب على الظرفية المكانية متعلق بالجواب المحذوف، وكان تامة، والتاء فاعلها، وقيل: ناقصة، وأينما متعلق بمحذوف خبرها المقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأوصاني بالصلاة والزكاة ما دمت حيا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما دمت﴾</span></span> ما مصدرية ظرفية، ودمت فعل ماض ناقص، والتاء اسمها، وحيًّا خبرها. والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل منصوب على الظرفية، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أوصاني﴾</span></span>.</p></div>"
  19,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبرا بوالدتي ولم يجعلني جبارا شقيا﴾</span></span>: مفعول به ثان لفعل محذوف تقديره <span class="hlt"><span class="qpc-hafs">﴿جعلني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بوالدتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿برًّا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولم يجعلني﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وجعلني﴾</span></span>، وجبارًا مفعول به ثان، وشقيًّا صفة.</p></div>"
  19,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</span></span>: السلام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، ويوم ظرف متعلق بمعنى الاستقرار المتعلق به الجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿عليَّ﴾</span></span>، وجملة ولدت مضاف إليه، ويوم أبعث عطف على يوم ولدت، وكذلك يوم أبعث، وحيًّا حال.</p></div>"
  19,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</span></span>: ذلك اسم إشارة، مبتدأ، وعيسى خبره، و<span class="hlt"><span class="qpc-hafs">﴿ابن﴾</span></span> بدل، و<span class="hlt"><span class="qpc-hafs">﴿مريم﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿قول﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة، أي: أقول قولَ الحق، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> نعت للقول إن أريد به عيسى، أو صفة للحق نفسه، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمترون﴾</span></span>، وجملة فيه يمترون صلة الموصول لا محل لها من الإعراب.</p></div>"
  19,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما كان لله أن يتخذ من ولد سبحانه﴾</span></span>: ما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يتخذ﴾</span></span> اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> صلة، وولد مجرور بمن لفظًا مفعول به منصوب محلًّا، وسبحانه: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا قضى أمرا﴾</span></span>: إذا ظرف مستقبل، وجملة قضى في محل جر بالإضافة، وأمرًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنما يقول له كن فيكون﴾</span></span>: الفاء رابطة لجواب إذا، وجملة إنما يقول لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، وكن فعل أمر تام، والجملة مقول القول، والفاء استئنافية، ويكون فعل مضارع تام مرفوع بالضمة، والفاعل هو، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  19,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن الله ربي وربكم فاعبدوه هذا صراط مستقيم﴾</span></span>: الواو استئنافية، وإن حرف ناسخ، ولفظ الجلالة اسم إن منصوب، وربي خبر إن، وربكم عطف على ربي، فاعبدوه: الفاء الفصيحة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن الله...﴾</span></span> مستأنفة لا محل لها من الإعراب، واعبدوه: فعل أمر، وفاعل، ومفعول به، وهذا مبتدأ، وصراط خبر، ومستقيم صفة لصراط، والجملة لا محل لها من الإعراب، لأنها تعليلية.</p></div>"
  19,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واختلف الأحزاب فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بينهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الأحزاب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فويل للذين كفروا من مشهد يوم عظيم﴾</span></span>: الفاء عاطفة، وويل مبتدأ، وللذين جار ومجرور متعلقان بمحذوف خبر ويل، وجملة كفروا صلة الذين لا محل لها من الإعراب، ومن مشهد جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>.</p></div>"
  19,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أسمع بهم وأبصر يوم يأتوننا لكن الظالمون اليوم في ضلال مبين﴾</span></span>: أسمع فعل ماض أتى على صيغة الأمر للتعجب، والباء حرف صلة، والجملة لا محل لها من الإعراب، لأنها استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف زمان منصوب بالفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أسمع وأبصر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتوننا﴾</span></span> في محل جر مضاف إليه، ولكن مخففة مهملة، والظالمون مبتدأ، واليوم ظرف زمان منصوب بالفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ضلال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، ومبين صفة.</p></div>"
  19,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنذرهم يوم الحسرة إذ قضي الأمر وهم في غفلة وهم لا يؤمنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أنذرهم﴾</span></span> فعل أمر، والفاعل مستتر تقديره أنت، والهاء مفعول، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿يوم الحسرة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>، أو ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿الحسرة﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في غفلة﴾</span></span> خبر، <span class="hlt"><span class="qpc-hafs">﴿وهم لا يؤمنون﴾</span></span> جملة حالية أيضا.</p></div>"
  19,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا نحن نرث الأرض ومن عليها وإلينا يرجعون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، ونحن تأكيد لاسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿نرث الأرض﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> عطف على الأرض، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وإلينا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، والواو عاطفة، ويرجعون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  19,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب إبراهيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واذكر فعل أمر، و فاعله مستتر تقديره أنت، وفي الكتاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وإبراهيم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان صديقا نبيا﴾</span></span>: إن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة كان خبرها، واسم كان مستتر تقديره: هو، وصديقًا خبر كان الأول منصوب، ونبيًّا خبر كان الثاني. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه كان صديقا نبيا﴾</span></span> في محل نصب حال من إبراهيم، وقيل: إنها اعتراضية بين المبدل منه والبدل، فإن قوله تعالى في الآية التالية: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم زمان وقع بدلا من <span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span>، وقيل: إنها استئنافية، وعلى كونها اعتراضية أو استئنافية فلا محل لها من الإعراب.</p></div>"
  19,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لأبيه يا أبت﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿صديقًا نبيًّا﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بمضاف محذوف والتقدير: واذكر خبر إبراهيم أو نبأ إبراهيم حين قال لأبيه، فالظرف متعلق بذلك الخبر أو النبأ، وعلى اعتبار <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> بدلا أو ظرفا لمضاف محذوف تكون جملة <span class="hlt"><span class="qpc-hafs">﴿إنه كان صديقًا نبيًّا﴾</span></span> اعتراضية. وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿لأبيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، وأبت منادى مضاف لياء المتكلم المعوض عنها بالتاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم تعبد ما لا يسمع ولا يبصر ولا يغني عنك شيئا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لِمَ﴾</span></span> أصلها اللام الجارة وما الاستفهامية، وهي متعلقة مع مجرورها بـ<span class="hlt"><span class="qpc-hafs">﴿تعبد﴾</span></span>، وفاعل تعبد ضمير مستتر تقديره أنت، وما اسم موصول مفعول به، وجملة لا يسمع صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وما بعدها معطوف عليها، وشيئًا مفعول به، أو نائب عن المفعول المطلق.</p></div>"
  19,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أبت إني قد جاءني من العلم ما لم يأتك فاتبعني أهدك صراطا سويا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا أبت﴾</span></span>: يا حرف نداء، وأبت منادى مضاف لياء المتكلم المعوض عنها بالتاء، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد جاءني﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿من العلم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءني﴾</span></span>، ومن للتبعيض، وما اسم موصول فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يأتك﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، فاتبعني الفاء الفصيحة، واتبعني فعل أمر، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أهدك﴾</span></span> فعل مضارع مجزوم في جواب الطلب، والكاف مفعول به، وصراطًا مفعول به ثان، أو منصوب بنزع الخافض، وسويًّا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صراطًا﴾</span></span>.</p></div>"
  19,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أبت لا تعبد الشيطان إن الشيطان كان للرحمن عصيا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا أبت﴾</span></span>: يا حرف نداء، وأبت منادى مضاف لياء المتكلم المعوض عنها بالتاء، ولا ناهية، وتعبد فعل مضارع مجزوم بلا الناهية، والفاعل مستتر تقديره أنت، والشيطان مفعول به، وإن حرف ناسخ، والشيطان اسم إن منصوب، وجملة كان خبر إن، واسم كان مستتر، وللرحمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عصيًّا﴾</span></span>، وعصيًّا خبر كان منصوب.</p></div>"
  19,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أبت إني أخاف أن يمسك عذاب من الرحمن فتكون للشيطان وليا﴾</span></span>: يا حرف نداء، وأبت منادى مضاف لياء المتكلم المعوض عنها بالتاء، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة أخاف خبر إن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يمسك﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، وعذاب فاعل يمسك، و<span class="hlt"><span class="qpc-hafs">﴿من الرحمن﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لعذاب، <span class="hlt"><span class="qpc-hafs">﴿فتكون﴾</span></span> عطف على أن يمسك، واسم <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿للشيطان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وليًّا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وليًّا﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> منصوب.</p></div>"
  19,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أراغب أنت عن آلهتي يا إبراهيم﴾</span></span>: الهمزة للاستفهام، وراغب مبتدأ، وأنت فاعل سد مسد الخبر، أو: راغب خبر مقدم، وأنت مبتدأ مؤخر، ويا حرف نداء، وإبراهيم منادى مفرد علم مبني على الضم.</p><p><span class="hlt"><span class="qpc-hafs">﴿لئن لم تنته لأرجمنك واهجرني مليا﴾</span></span>: اللام موطئة للقسم، وإن شرطية، ولم حرف نفي وقلب وجزم، وتنته فعل مضارع مجزوم بلم، ولأرجمنك اللام واقعة في جواب القسم، وأرجمنك فعل مضارع مبني على الفتح، والفاعل مستتر تقديره أنا، والكاف مفعول به، واهجرني الواو عاطفة، واهجرني معطوف على محذوف، والتقدير: فاحذرني واهجرني، و<span class="hlt"><span class="qpc-hafs">﴿مليًّا﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿اهجرني﴾</span></span>، وقيل: هو حال من فاعل اهجرني.</p></div>"
  19,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال سلام عليك سأستغفر لك ربي إنه كان بي حفيا﴾</span></span>: سلام مبتدأ، وعليك خبر. <span class="hlt"><span class="qpc-hafs">﴿سأستغفر﴾</span></span>: السين للاستقبال، وأستغفر فعل مضارع، وفاعله مستتر تقديره أنا، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أستغفر﴾</span></span>، وربي مفعول به، وجملة إنه تعليلية لا محل لها من الإعراب، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة كان خبر إن، واسم كان مستتر تقديره: هو، وحفيًّا خبر إن، وبي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حفيًّا﴾</span></span>.</p></div>"
  19,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأعتزلكم وما تدعون من دون الله﴾</span></span>: الواو عاطفة، وأعتزلكم فعل ماض، والفاعل مستتر، والكاف مفعول به، وما الواو حرف عطف، وموصولة أو مصدرية، ومنصوبة عطفًا على الكاف، أو مفعول معه، وجملة تدعون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ولفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأدعو ربي عسى ألا أكون بدعاء ربي شقيا﴾</span></span>: الواو عاطفة، وأدعو عطف على أعتزلكم، وفاعله مستتر تقديره: أنا، وربي مفعول به، وعسى فعل ماض من أفعال الرجاء، واسمها مستتر، وأن وما في حيزها خبر عسى، وأكون فعل مضارع ناقص منصوب بأن، واسم أكون مستتر تقديره أنا، وبدعاء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شقيًّا﴾</span></span>، وربي مضاف إليه، وشقيًّا خبر أكون منصوب.</p></div>"
  19,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما اعتزلهم وما يعبدون من دون الله وهبنا له إسحاق ويعقوب وكلا جعلنا نبيا﴾</span></span>: لما ظرفية حينية أو رابطة، واعتزلهم فعل ماض، وفاعل مستتر، ومفعول به. <span class="hlt"><span class="qpc-hafs">﴿وما يعبدون﴾</span></span>: الواو حرف عطف، وما معطوف على الهاء، وهي موصولة أو مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> الجار والمجرور متعلقان بمحذوف حال، ولفظ الجلالة مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب لما، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وإسحق مفعول وهبنا، ويعقوب عطف على إسحق، وكلًّا مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، ونبيًّا هو المفعول الثاني.</p></div>"
  19,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا لهم من رحمتنا وجعلنا لهم لسان صدق عليا﴾</span></span>: الواو عاطفة، ووهبنا عطف على وهبنا الأولى، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، ومن رحمتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span> أيضًا، وجعلنا عطف على وهبنا، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف في موضع المفعول الثاني لجعلنا، ولسان صدق هو المفعول الأول، وعليًّا صفة للسان.</p></div>"
  19,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب موسى إنه كان مخلصا﴾</span></span>: الواو استئنافية، واذكر فعل أمر، وفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وموسى مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب موسى﴾</span></span> مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، والهاء ضمير منصوب مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان...﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان رسولا نبيا﴾</span></span>: عطف على كان الأولى.</p></div>"
  19,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وناديناه من جانب الطور الأيمن وقربناه نجيا﴾</span></span>: الواو عاطفة، وناديناه عطف على ما سبق، وهو فعل وفاعل ومفعول به، ومن جانب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نادينا﴾</span></span>، والطور مضاف إليه، والأيمن صفة لجانب، وقربناه عطف على ناديناه، و<span class="hlt"><span class="qpc-hafs">﴿نجيًّا﴾</span></span> حال من أحد الضميرين في ناديناه أو قربناه.</p></div>"
  19,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا له من رحمتنا أخاه هارون نبيا﴾</span></span>: الواو عاطفة، ووهبنا عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، ومن رحمتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span> أيضًا، ومن للتبعيض، أي: بعض رحمتنا، أو: للتعليل، أي: من أجل رحمتنا، وأخاه مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وهارون بدل، ونبيًّا حال.</p></div>"
  19,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب إسماعيل﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واذكر فعل أمر، والفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وإسماعيل مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان صادق الوعد﴾</span></span>: إن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان صادق الوعد﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه كان...﴾</span></span> تعليلة، وكان فعل ماض ناقص، واسمها مستتر، وصادق خبر كان منصوب، والوعد مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان رسولا نبيا﴾</span></span>: عطف على كان الأولى.</p></div>"
  19,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكان يأمر أهله بالصلاة والزكاة وكان عند ربه مرضيا﴾</span></span>: جملة يأمر خبر كان، وأهله مفعول به، وبالصلاة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأمر﴾</span></span>، وكان فعل ماض ناقص، واسمها مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿عند ربه﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مرضيًّا﴾</span></span>، ومرضيًّا خبر كان منصوب.</p></div>"
  19,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب إدريس﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واذكر فعل أمر، وفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وإدريس مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان صديقا نبيا﴾</span></span>: إن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة كان خبر إن.</p></div>"
  19,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ورفعناه مكانا عليا﴾</span></span>: رفعناه فعل وفاعل ومفعول به، ومكانًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رفعناه﴾</span></span>، وعليًّا صفة.</p></div>"
  19,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك الذين أنعم الله عليهم من النبيين من ذرية آدم﴾</span></span>: أولئك مبتدأ، والذين خبر، أو بدل من اسم الإشارة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنعم الله عليهم﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من النبيين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من ذرية آدم﴾</span></span> بدل بإعادة الجار، والجار والمجرور متعلقان بحال من الضمير في عليهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وممن حملنا مع نوح ومن ذرية إبراهيم وإسرائيل وممن هدينا واجتبينا﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا تتلى عليهم آيات الرحمن خروا سجدا وبكيا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿إذا تتلى...﴾</span></span> وجوابها استئنافية لا محل لها من الإعراب إذا أعربت <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> خبرًا، أما إذا أعربتها بدلًا فجملة <span class="hlt"><span class="qpc-hafs">﴿إذا تتلى﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿خروا﴾</span></span> لا محل لها من الإعراب، لأنها جواب إذا، والواو في خروا فاعل، وسجدًا حال من الفاعل، وبكيًّا عطف على <span class="hlt"><span class="qpc-hafs">﴿سجدًا﴾</span></span>.</p></div>"
  19,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخلف من بعدهم خلف أضاعوا الصلاة واتبعوا الشهوات فسوف يلقون غيا﴾</span></span>: الفاء عاطفة وخلف فعل ماض، ومن بعدهم حال، وخلف فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أضاعوا الصلاة﴾</span></span> صفة لخلف، <span class="hlt"><span class="qpc-hafs">﴿واتبعوا الشهوات﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أضاعوا الصلاة﴾</span></span>، والفاء الفصيحة، وسوف حرف استقبال، ويلقون فعل مضارع وفاعل، وغيًّا مفعول به.</p></div>"
  19,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من تاب وآمن وعمل صالحا فأولئك يدخلون الجنة ولا يظلمون شيئا﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مستثنى منصوب، وجملة تاب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وآمن عطف على تاب، وعمل عطف أيضًا، وصالحًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. فأولئك الفاء الفصيحة، وأولئك مبتدأ، وجملة يدخلون خبر، والجنة مفعول به على السعة، ولا يظلمون عطف على يدخلون، وشيئًا نائب عن المفعول المطلق، أو مفعول ثان بتضمين يظلمون معنى ينقصون.</p></div>"
  19,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن التي وعد الرحمن عباده بالغيب﴾</span></span>: جنات بدل من الجنة، وعدن مضاف إليه، والتي صفة لجنات عدن، وجملة وعد صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، والرحمن فاعل وعد، وعباده مفعول به، وبالغيب حال من عباده، أو حال من ضمير الجنة، وهو الضمير العائد على الموصول، أي: وعدها، وهم غائبون عنها لا يرونها.</p></div>"
  19,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يسمعون فيها لغوا إلا سلاما ولهم رزقهم فيها بكرة وعشيا﴾</span></span>: الجملة حال من جنات عدن، ولا نافية، ويسمعون فعل مضارع، والواو فاعل، وفيها جار ومجرور متعلقان بمحذوف حال، أي: حالة كونهم في ا لجنة، ولغوًا مفعول به، وإلا أداة حصر، وسلامًا بدل من <span class="hlt"><span class="qpc-hafs">﴿لغوًا﴾</span></span>، أو مستثنى منقطع، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ورزقهم مبتدأ مؤخر، وفيها جار ومجرور متعلقان بمحذوف حال، وبكرة ظرف متعلق بمعنى الاستقرار المستكن في الخبر المقدم، وعشيًّا عطف على بكرة.</p></div>"
  19,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك الجنة التي نورث من عبادنا من كان تقيا﴾</span></span>: اسم الإشارة مبتدأ، والجنة خبر، والتي صفة للجنة، وجملة نورث صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مفعول نورث، وجملة كان صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، واسم كان مستتر تقديره: هو، وتقيًّا خبر كان.</p></div>"
  19,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما نتنزل إلا بأمر ربك﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، ونتنزل فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿إلا بأمر ربك﴾</span></span> استثناء من أعم الأحوال، فإلا أداة حصر، وبأمر جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان ربك نسيا﴾</span></span>: الواو حرف عطف، وما نافية، وكان فعل ماض ناقص، وربك اسم كان مرفوع، ونسيا خبر كان منصوب.</p></div>"
  19,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض وما بينهما﴾</span></span>: رب السماوات والأرض خبر لمبتدأ محذوف، أي: هو رب السماوات والأرض، أو بدل من ربك.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاعبده واصطبر لعبادته هل تعلم له سميا﴾</span></span>: الفاء الفصيحة، واصطبر عطف على <span class="hlt"><span class="qpc-hafs">﴿اعبده﴾</span></span>، ولعبادته جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصطبر﴾</span></span>، وهل حرف استفهام معناه النفي، وتعلم فعل مضارع، وفاعله مستتر تقديره: أنت، وسميًّا مفعول به.</p></div>"
  19,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقول الإنسان أئذا ما مت لسوف أخرج حيا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ويقول الإنسان فعل مضارع وفاعل، وأل فيه للجنس، والهمزة للاستفهام بمعنى النفي، وإذا ظرف لما يستقبل من الزمن، متعلق بفعل محذوف دل عليه قوله: لسوف أخرج، لأن اللام تمنع من تعليقه بـ<span class="hlt"><span class="qpc-hafs">﴿أخرج﴾</span></span> المذكورة، لأن ما بعدها لا يعمل فيما قبلها، وما صلة، واللام لام الابتداء، وسوف حرف استقبال، وأخرج فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره: أنا، وحيًّا حال.</p></div>"
  19,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولا يذكر الإنسان أنا خلقناه من قبل ولم يك شيئا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أوَلا﴾</span></span> الهمزة للاستفهام، والواو عاطفة، ولا نافية، ويذكر فعل مضارع معطوف على يقول، والإنسان فاعل، وأنا: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم أن، وجملة خلقناه خبر أن، وأن وما بعدها في تأويل مصدر مفعول يذكر، ومن قبل الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذكر﴾</span></span>، ولم حرف نفي وقلب وجزم، ويك فعل مضارع مجزوم بلم، وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، واسمها ضمير مستتر تقديره: هو، وشيئًا خبر يك منصوب، والمضاف إليه محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿قبل الحالة التي هو فيها﴾</span></span>، وقدر بعضهم: <span class="hlt"><span class="qpc-hafs">﴿قبل بعثه﴾</span></span>.</p></div>"
  19,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فوربك لنحشرنهم والشياطين﴾</span></span>: الفاء عاطفة، والواو للقسم، وربك مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف، تقديره: أقسم، واللام واقعة في جواب القسم، ونحشرنهم فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل ضمير مستتر تقديره: نحن، والهاء مفعول به، والشياطين عطف على الهاء، أو الواو بمعنى مع، والشياطين مفعول معه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لنحضرنهم حول جهنم جثيا﴾</span></span>: ثم حرف عطف للتراخي، ولنحضرنهم عطف على لنحشرنهم، وحول ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نحضرنهم﴾</span></span>، وجهنم مضاف إليه، وجثيًّا حال.</p></div>"
  19,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم لننزعن من كل شيعة أيهم أشد على الرحمن عتيا﴾</span></span>: ثم لننزعن عطف على لنحضرنهم، ومن كل شيعة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننزعن﴾</span></span>، وأيهم اسم موصول بمعنى الذي، وحذف صدر صلتها، وهو مبني في محل نصب مفعول به لنزعن، وأشد خبر لمبتدأ محذوف، والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> لا محل لها من الإعراب، وعتيًّا تمييز، وعلى الرحمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>، أو بمحذوف حال.</p></div>"
  19,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم لنحن أعلم بالذين هم أولى بها صليا﴾</span></span>: ثم حرف عطف للترتيب والتراخي، واللام للابتداء، ونحن مبتدأ، وأعلم خبر، وبالذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وأولى خبر، والجملة صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أولى﴾</span></span>، وصليًّا تمييز، وقيل: صليًّا جمع صالٍ فانتصب على الحال.</p></div>"
  19,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن منكم إلا واردها كان على ربك حتما مقضيا﴾</span></span>: الواو عاطفة، وإن نافية، ومنكم صفة لمبتدأ محذوف تقديره: أحد، أي: ما منكم أحد، وإلا أداة حصر، وواردها خبر، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، أي: الورود، وحتمًا خبر كان منصوب، ومقضيًّا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حتمًا﴾</span></span>.</p></div>"
  19,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم ننجي الذين اتقوا ونذر الظالمين فيها جثيا﴾</span></span>: ثم ننجي عطف على ماتقدم، وفاعل ننجي مستتر تقديره نحن، والذين اسم موصول في محل نصب مفعول به، واتقوا صلة الذين لا محل لها من الإعراب، ونذر عطف على ننجي، والفاعل مستتر تقديره نحن، والظالمين مفعول به، وفيها جار ومجرور متعلقان بنذر أو بـ<span class="hlt"><span class="qpc-hafs">﴿جثيًّا﴾</span></span>، وقيل: متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿جثيًّا﴾</span></span>، لأنه في الأصل صفة لنكرة قدم عليها فنصب على الحال، وجثيًّا حال، أو مفعول ثان لنذر، أي: نتركهم فيها جثيًّا.</p></div>"
  19,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا تتلى عليهم آياتنا بينات قال الذين كفروا﴾</span></span>: الواو استئنافية، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة تتلى في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلى﴾</span></span>، وآياتنا نائب فاعل، وبينات حال من آياتنا، وجملة قال الذين كفروا لا محل لها من الإعراب، لأنها جواب.</p><p><span class="hlt"><span class="qpc-hafs">﴿للذين آمنوا أي الفريقين خير مقاما وأحسن نديا﴾</span></span>: للذين آمنوا جار ومجرور متعلقان بقال، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وأي استفهامية مبتدأ، وخير خبر، ومقامًا تمييز، وأحسن عطف على خير، ونديًّا تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذا تتلى عليهم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  19,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا قبلهم من قرن هم أحسن أثاثا ورئيا﴾</span></span>: كم خبرية في محل نصب مفعول أهلكنا، وأهلكنا فعل وفاعل، ومن قرن تمييز غير صريح لـ<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وأحسن خبر، والجملة في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قرن﴾</span></span>، وأثاثًا تمييز، ورئيًا عطف عليه.</p></div>"
  19,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من كان في الضلالة فليمدد له الرحمن مدا﴾</span></span>: من اسم شرط جازم مبتدأ، وكان فعل الشرط، وهو فعل ماض ناقص، واسمها مستتر يعود على من، وفي الضلالة جار ومجرور متعلقان بمحذوف خبر كان، والفاء رابطة للجواب، واللام لام الأمر، ويمدد فعل مضارع مجزوم بلام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمدد﴾</span></span>، والرحمن فاعل، ومدًّا مفعول مطلق منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا رأوا ما يوعدون إما العذاب وإما الساعة﴾</span></span>: حتى حرف غاية وجر، والجار والمجرور متعلقان بالجواب، وهو: فسيعلمون، وقيل: حرف ابتداء، وجملة رأوا مضاف إليه، وما مفعول به، وجملة يوعدون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وإما حرف شرط وتفصيل، والعذاب والساعة بدل من ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسيعلمون من هو شر مكانا وأضعف جندا﴾</span></span>: الفاء واقعة في جواب إذا، وسيعلمون فعل مضارع مرفوع، والواو فاعل، ومن موصولة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وشر خبر، والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وقيل: من استفهامية في محل رفع بالابتداء، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، وشر خبر المبتدأ الثاني، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> وخبره خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، والجملة متعلقة برأوا، وهي في محل نصب مفعول يعلمون.</p></div>"
  19,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويزيد الله الذين اهتدوا هدى﴾</span></span>: الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو عاطفة، تعطف الجملة على جملة الشرط المحكية بالقول، أي: وقل يزيد الله، ويزيد الله الذين اهتدوا فعل مضارع وفاعل ومفعول به، وجملة اهتدوا صلة الذين لا محل لها من الإعراب، وهدى تمييز أو مفعول به ثان ليزيد.</p><p><span class="hlt"><span class="qpc-hafs">﴿والباقيات الصالحات خير عند ربك ثوابا وخير مردا﴾</span></span>: الواو عاطفة، والباقيات مبتدأ، والصالحات صفة، وخير خبر الباقيات، وعند ربك الظرف متعلق بخير، وثوابًا تمييز، وخير مردًّا عطف على خير ثوابًا.</p></div>"
  19,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيت الذي كفر بآياتنا وقال لأوتين مالا وولدا﴾</span></span>: الهمزة للاستفهام، والفاء للتعقيب، ورأيت هنا بمعنى أخبرني، والذي هو مفعولها الأول، وجملة كفر بآياتنا صلة الذي لا محل لها من الإعراب، وقال عطف على كفر، لأوتين اللام جواب لقسم مقدر، ونائب الفاعل مضمر تقديره: أنا، ومالًا مفعول به ثان لأوتين، وولدًا عطف على <span class="hlt"><span class="qpc-hafs">﴿مالًا﴾</span></span>.</p></div>"
  19,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أطلع الغيب أم اتخذ عند الرحمن عهدا﴾</span></span>: الهمزة للاستفهام، واطلع فعل ماض، وفاعله هو يعود على الكافر، وأم حرف عطف معادل للهمزة، واتخذ فعل ماض، وفاعله مستتر يعود عليه، وعند الرحمن مفعول به ثان لاتخذ، وعهدًا مفعول به أول.</p></div>"
  19,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا سنكتب ما يقول ونمد له من العذاب مدا﴾</span></span>: كلا حرف ردع وزجر، وسنكتب فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، وما مفعول به، وجملة يقول صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ونمد عطف على نكتب، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span>، ومن العذاب حال، لأنه كان صفةً لـ<span class="hlt"><span class="qpc-hafs">﴿مدًّا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مدًّا﴾</span></span> مفعول مطلق، أو مفعول به إن كان بمعنى المدد.</p></div>"
  19,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونرثه ما يقول ويأتينا فردا﴾</span></span>: الواو عاطفة، ونرثه عطف على نمد، والفاعل نحن، والهاء منصوب بنزع الخافض، وما مفعول به، والتقدير: ونرث منه ما يقوله، أو الهاء هي المفعول به، وما بدل اشتمال من الهاء، والمعنى: نرث ما عنده من المال، والأهل، والولد، وجملة يقول صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ويأتينا عطف على ما تقدم، والفاعل مستتر تقديره: هو، ونا ضمير فصل فاعل، وفردًا حال.</p></div>"
  19,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتخذوا من دون الله آلهة ليكونوا لهم عزا﴾</span></span>: الواو استئنافية، واتخذوا فعل وفاعل، وحذف المفعول الأول، وهي الأوثان المفهومة من سياق الحديث، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وآلهة هي المفعول الثاني، ليكونوا اللام لام التعليل، ويكونوا فعل مضارع ناقص منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وعزًّا خبر يكونوا.</p></div>"
  19,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا سيكفرون بعبادتهم ويكونون عليهم ضدا﴾</span></span>: كلا حرف ردع وزجر، سيكفرون فعل مضارع مرفوع، وبعبادتهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفرون﴾</span></span>، من إضافة المصدر إلى مفعوله، ويكونون عطف على يكفرون، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وضدًّا خبر يكونون.</p></div>"
  19,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أنا أرسلنا الشياطين على الكافرين تؤزهم أزا﴾</span></span>: ألم الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وتر فعل مضارع مجزوم بلم، وفاعله أنت، وأن وما في حيزها سدت مسد مفعولي تر، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، وجملة أرسلنا خبر إن، والشياطين مفعول به، وجملة تؤزهم حالية، و<span class="hlt"><span class="qpc-hafs">﴿أزًّا﴾</span></span> مفعول مطلق منصوب.</p></div>"
  19,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا تعجل عليهم إنما نعد لهم عدا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعجل﴾</span></span>، وإنما كافة ومكفوفة، وجملة نعد لهم حالية، وعدًّا مفعول مطلق منصوب.</p></div>"
  19,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم نحشر المتقين إلى الرحمن وفدا﴾</span></span>: الظرف منتصب بفعل محذوف، تقديره: اذكر، وقيل: نصب يوم بمضمر، أي: يوم نحشر، ونسوق، نفعل بالفريقين ما لا يحيط به الوصف، وقيل: العامل فيه قوله فيما بعد: <span class="hlt"><span class="qpc-hafs">﴿لا يملكون﴾</span></span>، وجملة نحشر مضاف إليه، وفاعل نحشر ضمير مستتر تقديره: نحن، والمتقين مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى الرحمن﴾</span></span> جار ومجرور متعلقان بنحشر، ووفدًا حال.</p></div>"
  19,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونسوق المجرمين إلى جهنم وردا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نسوق المجرمين﴾</span></span> فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى جهنم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسوق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وردا﴾</span></span> حال منصوبة بالفتحة.</p></div>"
  19,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يملكون الشفاعة إلا من اتخذ عند الرحمن عهدا﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، لا نافية، ويملكون فعل مضارع مرفوع، والواو فاعل تعود على الناس كلهم، والشفاعة مفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول محله الرفع على البدل من الواو، أو النصب على الاستثناء المتصل، وجملة اتخذ صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وعند الرحمن ظرف متعلق بمحذوف هو المفعول الثاني لاتخذ، وعهدًا هو المفعول الأول، وقيل: الاستثناء منقطع.</p></div>"
  19,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا اتخذ الرحمن ولدا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿اتخذ الرحمن ولدًا﴾</span></span> مقول القول، واتخذ الرحمن ولدًا فعل وفاعل ومفعول به.</p></div>"
  19,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد جئتم شيئا إدا﴾</span></span>: اللام لام القسم، وقد حرف تحقيق، وجئتم فعل وفاعل، وشيئًا مفعول به، وإدًّا صفة.</p></div>"
  19,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تكاد السماوات يتفطرن منه وتنشق الأرض وتخر الجبال هدا﴾</span></span>: تكاد من أفعال المقاربة العاملة عمل كان، والسماوات اسمها، وجملة يتفطرن خبرها، والنون فاعل، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتفطرن﴾</span></span>، وتنشق الأرض فعل مضارع وفاعل، وتخر الجبال فعل مضارع وفاعل، وهدًّا مصدر في موضع الحال، أي: مهدودة، أو نائب عن المفعول المطلق، لأنه بمعنى المصدر، أومفعول لأجله، أي: لأن تهد.</p></div>"
  19,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أن دعوا للرحمن ولدا﴾</span></span>: أن وما في حيزها مصدر بدل من الهاء في منه، أو منصوب بنزع الخافض، والجار والمجرور في محل نصب مفعول لأجله، حيث علل الهد بدعاء الولد للرحمن، أو فاعل <span class="hlt"><span class="qpc-hafs">﴿هدًّا﴾</span></span>، ودعوا فعل ماض مبني على الفتح المقدر على الألف المحذوفة لالتقاء الساكنين، وللرحمن جار ومجرور متعلقان بدعوا، وولدًا مفعول دعوا الثاني، والأول محذوف تقديره: معبودهم.</p></div>"
  19,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ينبغي للرحمن أن يتخذ ولدا﴾</span></span>: الواو حالية أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿للرحمن﴾</span></span> جار ومجرور متعلقان به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿يتخذ﴾</span></span> فعل مضارع منصوب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يتخذ﴾</span></span> فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، وولدًا مفعول به.</p></div>"
  19,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كل من في السماوات والأرض إلا آتي الرحمن عبدا﴾</span></span>: إن نافية، وكل مبتدأ، ومن مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وقيل: من نكرة موصوفة بالجار والمجرور، لأنها وقعت بعد كل نكرة، وإلا أداة حصر، وآتي الرحمن خبر، وعبدًا حال من الضمير المستتر في آتي.</p></div>"
  19,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد أحصاهم وعدهم عدا﴾</span></span>: اللام واقعة في جواب قسم مقدر. و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أحصاهم﴾</span></span> فعل وفاعل مستتر ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿عدهم﴾</span></span> عطف على أحصاهم. و<span class="hlt"><span class="qpc-hafs">﴿عدًّا﴾</span></span> مفعول مطلق.</p></div>"
  19,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكلهم آتيه يوم القيامة فردا﴾</span></span>: الواو عاطفة، وكلهم مبتدأ، وآتيه خبر، ويوم القيامة ظرف متعلق بآتيه، وفردًا حال.</p></div>"
  19,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</span></span>: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وجملة عملوا الصالحات عطف على آمنوا، وجملة سيجعل خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول يجعل الثاني، والرحمن فاعل، وودًّا مفعول يجعل الأول.</p></div>"
  19,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما يسرناه بلسانك لتبشر به المتقين وتنذر به قوما لدا﴾</span></span>: الفاء الفصيحة، وإنما كافة ومكفوفة، ويسرناه فعل ماض، وفاعل، ومفعول به، وبلسانك جار ومجرور متعلقان بمحذوف حال، أي: جاريًا، لتبشر اللام للتعليل، وتبشر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبشر﴾</span></span>، والمتقين مفعول به، وتنذر معطوف، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنذر﴾</span></span>، وقومًا مفعول به، ولدًّا صفة.</p></div>"
  19,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا قبلهم من قرن﴾</span></span>: كم خبرية مفعول مقدم لأهلكنا، وقبلهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، ومن قرن تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل تحس منهم من أحد أو تسمع لهم ركزا﴾</span></span>: هل حرف للاستفهام، وتحس فعل مضارع، وفاعله مستتر تقديره: أنت، ومنهم حال، لأنه كان صفة لأحد، ومن حرف صلة، وأحد مجرور بمن لفظًا، مفعول به منصوب محلًّا، أو حرف عطف، وتسمع عطف على تحس، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، وركزًا مفعول به.</p></div>"
