quran[69]{c,v,t}:
  29,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  29,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أحسب الناس أن يتركوا أن يقولوا آمنا وهم لا يفتنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أحسب﴾</span></span> الهمزة للاستفهام، وحسب فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span> فاعل، وأن وما في حيزها سدت مسد مفعولي حسب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يقولوا﴾</span></span> مجرور بلام مقدرة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتركوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span> مقول القول، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفتنون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة حالية.</p></div>"
  29,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد فتنا الذين من قبلهم فليعلمن الله الذين صدقوا وليعلمن الكاذبين﴾</span></span>: الواو عاطفة، واللام جواب للقسم المقدر، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿فتنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مفعوله، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف هو صلة الذين، وجملة الصلة لا محل لها من الإعراب. والفاء عاطفة، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿يعلمن﴾</span></span> فعل مضارع مبني على الفتح، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مفعوله، وجملة <span class="hlt"><span class="qpc-hafs">﴿صدقوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وليعلمن الكاذبين﴾</span></span> عطف على ما تقدم.</p></div>"
  29,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم حسب الذين يعملون السيئات أن يسبقونا﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أحسب ...، والاستفهام للإنكار، و<span class="hlt"><span class="qpc-hafs">﴿حسب﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون السيئات﴾</span></span> صلة الموصول لا محل لها من الإعراب. وأن وما في حيزها سدت مسد مفعولي حسب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ساء ما يحكمون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل ماض جامد لإنشاء الذم مبني على الفتح، والفاعل مستتر وجوبا تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نكرة موصوفة في محل نصب تمييز لفاعل <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والمخصوص بالذم محذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> في محل نصب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والتقدير: ساء حكمًا يحكمونه.</p><p>أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول بمعنى الذي في محل رفع فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والمخصوص بالذم محذوف، أي: حكمهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب. والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وما دخلت عليه مخصوص بالذم، والتقدير: ساء حكمًا حكمهم.</p></div>"
  29,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كان يرجو لقاء الله فإن أجل الله لآت وهو السميع العليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص في محل جزم فعل الشرط، واسم كان مستتر يعود على من، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرجو﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿لقاء﴾</span></span> مفعول به، والفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿إن أجل﴾</span></span>: إن حرف ناسخ، وأجل اسمها، ولفظ الجلالة مضاف إليه، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آت﴾</span></span> خبر إن، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿السميع العليم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وفعل الشرط وجوابه في محل رفع خبر من.</p></div>"
  29,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن جاهد فإنما يجاهد لنفسه إن الله لغني عن العالمين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جاهد﴾</span></span> فعل ماض في محل جزم فعل الشرط، والفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿يجاهد﴾</span></span> فعل مضارع، وفاعله ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجاهد﴾</span></span>، وإن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿غني﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿عن العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غني﴾</span></span>، والجملة تعليلية.</p></div>"
  29,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات لنكفرن عنهم سيئاتهم﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة آمنوا صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على آمنوا، واللام واقعة في جواب قسم مقدر، ونكفرن فعل مضارع مبني على الفتح، والفاعل مستتر، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نكفرن﴾</span></span>، وسيئاتهم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجزينهم أحسن الذي كانوا يعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولنجزينهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لنكفرن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، وجملة كانوا صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span> خبر كانوا.</p></div>"
  29,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووصينا الإنسان بوالديه حسنا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿وصينا﴾</span></span> فعل وفاعل، والإنسان مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بوالديه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وصينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حسنا﴾</span></span> نائب عن المفعول المطلق وقد ناب عن المصدر، على تقدير حذف مضاف، أي: إيصاء ذا حسن، وجملة <span class="hlt"><span class="qpc-hafs">﴿ووصينا الإنسان...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن جاهداك لتشرك بي ما ليس لك به علم فلا تطعهما﴾</span></span>: الواو عاطفة، وإن شرطية، وجاهداك فعل ماض في محل جزم فعل الشرط، الألف فاعل، والكاف مفعول به، ولتشرك اللام لام التعليل، وتشرك فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والفاعل مستتر، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاهداك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشرك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تشرك﴾</span></span>، وليس فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿عِلْم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عِلْم﴾</span></span> اسم ليس مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس لك به علم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span> الفاء رابطة لجواب الشرط، لأن الجواب جملة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تطعهما﴾</span></span> فعل مضارع مجزوم بلا، والفاعل مستتر، والهاء ضمير مبني في محل نصب مفعول به، والميم والألف حرفان دالان على التثنية، والجملة المقترنة بالفاء في محل جزم جواب إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلي مرجعكم فأنبئكم بما كنتم تعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إليَّ﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مرجعكم﴾</span></span> مبتدأ مؤخر، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أنبئكم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف ضمير مبني في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبئكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر كنتم.</p></div>"
  29,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات لندخلنهم في الصالحين﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة آمنوا صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على آمنوا، واللام واقعة في جواب قسم مقدر، وندخلن فعل مضارع مبني على الفتح، وفاعله مستتر، تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الصالحين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ندخلنهم﴾</span></span>.</p></div>"
  29,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يقول آمنا بالله﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿من الناس﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول ...﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا أوذي في الله جعل فتنة الناس كعذاب الله﴾</span></span>: الفاء حرف عطف، وإذا ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿في الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوذي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوذي﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> لا محل لها من الإعراب، لأنها جواب إذا، و<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span> مفعول جعل الأول، والناس مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿كعذاب﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مضاف إليه، ولفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن جاء نصر من ربك ليقولن إنا كنا معكم﴾</span></span>: الواو عاطفة، واللام موطئة للقسم، وإن حرف شرط جازم، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض في محل جزم فعل الشرط، ونصر فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، أو بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نصر﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ليقولن﴾</span></span>: اللام واقعة في جواب القسم، ويقولن: فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا كنا معكم﴾</span></span> مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span> ظرف متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أوليس الله بأعلم بما في صدور العالمين﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على محذوف يقتضيه السياق، و<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> فعل ماض ناقص، ولفظ الجلالة اسمها، والباء حرف صلة، وأعلم مجرور لفظًا، منصوب محلًّا على أنه خبر ليس، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في صدور العالمين﴾</span></span> الجار والمجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وجملة الصلة لا محل لها من الإعراب. والعالمين مضاف إليه.</p></div>"
  29,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وليعلمن الله الذين آمنوا وليعلمن المنافقين﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿يعلمن﴾</span></span> فعل مضارع مبني على الفتح، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وليعلمن المنافقين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وليعلمن الله الذين آمنوا﴾</span></span>.</p></div>"
  29,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا للذين آمنوا اتبعوا سبيلنا ولنحمل خطاياكم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة  الموصول لا محل لها من الإعراب.و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span> مقول القول، واتبعوا: فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿سبيلنا﴾</span></span> مفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لنحمل﴾</span></span> الواو عاطفة، واللام لام الأمر، ونحمل فعل مضارع مجزوم بلام الأمر، وخطاياكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما هم بحاملين من خطاياهم من شيء إنهم لكاذبون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بحاملين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿حاملين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿من خطاياهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لشيء، وتقدم عليه، ومن حرف صلة، وشيء مجرور لفظًا، منصوب محلًّا، لأنه مفعول حاملين، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم لكاذبون﴾</span></span> تعليل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿كاذبون﴾</span></span> خبرها.</p></div>"
  29,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وليحملن أثقالهم وأثقالا مع أثقالهم﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿يحملن﴾</span></span> فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أثقالهم﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأثقالًا﴾</span></span> عطف على أثقالهم، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أثقالًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أثقالهم﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليسألن يوم القيامة عما كانوا يفترون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يسألن﴾</span></span> عطف على يحملن، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يسألن﴾</span></span>، والقيامة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسألن﴾</span></span> أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span> خبر كان.</p></div>"
  29,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا نوحا إلى قومه فلبث فيهم ألف سنة إلا خمسين عاما﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿نوحًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى قومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا نوحا﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فلبث﴾</span></span>: الفاء عاطفة، ولبث فعل ماض، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ألف سنة﴾</span></span> نصب على الظرف، وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span> أيضًا، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿خمسين﴾</span></span> منصوب على الاستثناء، و<span class="hlt"><span class="qpc-hafs">﴿عامًا﴾</span></span> تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم الطوفان وهم ظالمون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذهم الطوفان﴾</span></span> فعل: ومفعول به مقدم، وفاعل مؤخر، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وظالمون خبر.</p></div>"
  29,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأنجيناه وأصحاب السفينة وجعلناها آية للعالمين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنجيناه﴾</span></span> فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأصحاب﴾</span></span> عطف على الهاء، أو مفعول معه، والسفينة مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وجعلناها﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿جعلناها﴾</span></span> فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿للعالمين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآية.</p></div>"
  29,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإبراهيم إذ قال لقومه﴾</span></span>: الواو استئنافية، وإبراهيم منصوب بفعل محذوف، تقديره: اذكر، والجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر،  وجملة قال لقومه في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لقومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله واتقوه ذلكم خير لكم إن كنتم تعلمون﴾</span></span>: الجملة مقول قول إبراهيم لقومه، و<span class="hlt"><span class="qpc-hafs">﴿اعبدوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، ولفظ الجلالة مفعول به، <span class="hlt"><span class="qpc-hafs">﴿واتقوه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اذكروا الله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذلكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض في محل جزم فعل الشرط، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span> خبرها، وجواب الشرط محذوف دل عليه ما قبله، أي: فاعبدوا الله واتقوه.</p></div>"
  29,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما تعبدون من دون الله أوثانا وتخلقون إفكا﴾</span></span>: إنما كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أوثانًا﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وتخلقون إفكًا﴾</span></span> عطف على ما قبله.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين تعبدون من دون الله لا يملكون لكم رزقا﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة تعبدون صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يملكون﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>، ورزقًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يملكون﴾</span></span>، لأنه بمعنى المرزوق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فابتغوا عند الله الرزق واعبدوه واشكروا له إليه ترجعون﴾</span></span>: الفاء الفصيحة، وابتغوا: فعل أمر، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عند الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابتغوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الرزق﴾</span></span> مفعول ابتغوا، <span class="hlt"><span class="qpc-hafs">﴿واعبدوه واشكروا له﴾</span></span> عطف على ابتغوا، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  29,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن تكذبوا فقد كذب أمم من قبلكم﴾</span></span>: عطف على ما تقدم، وإن شرطية، وتكذبوا فعل الشرط، وعلامة جزمه حذف النون، والواو فاعل، <span class="hlt"><span class="qpc-hafs">﴿فقد﴾</span></span> الفاء رابطة للجواب، لاقترانه بقد، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كذب أمم﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لأمم، وقيل: جواب الشرط محذوف، أي: فلا يضرني تكذيبكم، فقد كذب أمم من قبلكم أنبياءهم ورسلهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما على الرسول إلا البلاغ المبين﴾</span></span>: الواو حالية، أو استئنافية، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿على الرسول﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿البلاغ﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿المبين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بلاغ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما على الرسول...﴾</span></span> في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  29,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا كيف يبدئ الله الخلق ثم يعيده إن ذلك على الله يسير﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على محذوف يقتضيه السياق، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وجزم وقلب، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبدئ الله الخلق﴾</span></span> في محل نصب مفعول يروا، <span class="hlt"><span class="qpc-hafs">﴿ثم يعيده﴾</span></span> كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، وذلك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسير﴾</span></span>، ويسير خبر إن.</p></div>"
  29,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل سيروا في الأرض فانظروا كيف بدأ الخلق﴾</span></span>: سيروا: فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سيروا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فانظروا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿سيروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام مبني في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿بدأ الخلق﴾</span></span> فعل، وفاعل مستتر، ومفعول به، والجملة في محل نصب مفعول انظروا المعلقة بسبب الاستفهام.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم الله ينشئ النشأة الآخرة إن الله على كل شيء قدير﴾</span></span>: ثم حرف عطف، والله مبتدأ، وجملة ينشئ خبر، و<span class="hlt"><span class="qpc-hafs">﴿النشأة الآخرة﴾</span></span> نصب على المصدرية، وإن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدير﴾</span></span>، وقدير خبر إن.</p></div>"
  29,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعذب من يشاء ويرحم من يشاء وإليه تقلبون﴾</span></span>: الجملة حالية، أو خبر ثان لإن، أو مستأنفة لا محل لها من الإعراب، ويعذب فعل مضارع، وفاعله مستتر، تقديره: هو يعود على الله، ومن: اسم موصول في محل نصب مفعول به. وجملة يشاء صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ويرحم من يشاء﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يعذب من يشاء﴾</span></span>، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقلبون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تقلبون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  29,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنتم بمعجزين في الأرض ولا في السماء وما لكم من دون الله من ولي ولا نصير﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمعجزين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿معجزين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومفعول معجزين محذوف للعلم به، أي: الله تعالى، <span class="hlt"><span class="qpc-hafs">﴿ولا في السماء﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من ولي﴾</span></span>: من حرف صلة، وولي مجرور لفظًا، مرفوع محلًّا على أنه مبتدأ مؤخر، <span class="hlt"><span class="qpc-hafs">﴿ولا نصير﴾</span></span> عطف على من ولي.</p></div>"
  29,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين كفروا بآيات الله ولقائه أولئك يئسوا من رحمتي﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بآيات الله﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>، ولفظ الجلالة مضاف إليه، ولقائه عطف على آيات، وأولئك مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يئسوا من رحمتي﴾</span></span> خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك يئسوا﴾</span></span> خبر الذين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأولئك لهم عذاب أليم﴾</span></span>: الواو عاطفة، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، وأليم صفة لعذاب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم عذاب أليم﴾</span></span> خبر أولئك.</p></div>"
  29,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما كان جواب قومه إلا أن قالوا اقتلوه أو حرقوه﴾</span></span>: الفاء عاطفة، وما نافية، وكان فعل ماض ناقص، وجواب خبرها المقدم، وإلا أداة حصر، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن قالوا﴾</span></span> اسم كان المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿اقتلوه﴾</span></span> فعل أمر، وفاعل، ومفعول به، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿حرقوه﴾</span></span> عطف على اقتلوه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنجاه الله من النار إن في ذلك لآيات لقوم يؤمنون﴾</span></span>: الفاء الفصيحة، أي: فقذفوه في النار فأنجاه الله. و<span class="hlt"><span class="qpc-hafs">﴿أنجاه الله﴾</span></span> فعل، ومفعول به مقدم، وفاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من النار﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنجاه﴾</span></span>، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وآيات اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآيات، وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span> صفة لقوم.</p></div>"
  29,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال إنما اتخذتم من دون الله أوثانا مودة بينكم في الحياة الدنيا﴾</span></span>: الواو عاطفة، وقال فعل ماض، والفاعل مستتر، وإنما كافة ومكفوفة، واتخذتم فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> الجار والمجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذتم﴾</span></span>، ولفظ الجلالة مضاف إليه، وأوثانًا مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مودة﴾</span></span> مفعول لأجله، أو منصوبة بفعل محذوف، تقديره: أعني، و<span class="hlt"><span class="qpc-hafs">﴿بينِكم﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿في الحياة الدنيا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتخذتم﴾</span></span>، أو بمحذوف حال، والدنيا مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم يوم القيامة يكفر بعضكم ببعض ويلعن بعضكم بعضا﴾</span></span>: ثم حرف عطف للتراخي، ويوم القيامة: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يكفر﴾</span></span>، والقيامة: مضاف إليه، ويكفر: فعل مضارع، وبعضكم: فاعل، وببعض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفر﴾</span></span> أيضًا، <span class="hlt"><span class="qpc-hafs">﴿ويلعن بعضكم بعضًا﴾</span></span>: فعل مضارع، وفاعل، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومأواكم النار وما لكم من ناصرين﴾</span></span>: مأواكم: مبتدأ، والنار: خبر. <span class="hlt"><span class="qpc-hafs">﴿وما لكم﴾</span></span>: الواو عاطفة، وما نافية، ولكم جار ومجرور متعلقان بخبر مقدم، ومن: حرف صلة، وناصرين مبتدأ مؤخر، وهو مجرور لفظًا.</p></div>"
  29,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فآمن له لوط وقال إني مهاجر إلى ربي إنه هو العزيز الحكيم﴾</span></span>: الفاء عاطفة، وآمن فعل ماض، ولوط فاعله، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span>، وقال عطف على <span class="hlt"><span class="qpc-hafs">﴿فآمن﴾</span></span>، وفاعله مستتر يعود على إبراهيم، وقال: الواو عاطفة،وقال فعل ماض، والفاعل ضمير مستتر، وإن حرف ناسخ، والياء اسمها، ومهاجر خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهاجر﴾</span></span>، وإن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، أو مبتدأ، والعزيز خبر إن، أو خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن، والحكيم خبر ثان.</p></div>"
  29,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا له إسحاق ويعقوب وجعلنا في ذريته النبوة والكتاب﴾</span></span>: الواو عاطفة، ووهبنا فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وإسحاق مفعول به، ويعقوب عطف عليه، و<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في ذريته﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان، والنبوة هي المفعول الأول، والكتاب عطف على النبوة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناه أجره في الدنيا وإنه في الآخرة لمن الصالحين﴾</span></span>: الواو عاطفة، وآتيناه فعل، وفاعل، ومفعول به، وأجره مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، وإن حرف ناسخ، والهاء اسمها، وفي الآخرة: جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، ومن الصالحين: جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  29,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولوطا إذ قال لقومه إنكم لتأتون الفاحشة ما سبقكم بها من أحد من العالمين﴾</span></span>: عطف على إبراهيم، أو منصوب بفعل محذوف، تقديره: اذكر، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿لوطا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لقومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنكم لتأتون﴾</span></span> مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، واللام المزحلقة، وجملة تأتون خبرها، والواو فاعل، والفاحشة مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما سبقكم﴾</span></span> مستأنفة لا محل لها من الإعراب، وقيل: حالية، أي: أتأتون الفاحشة مبتدعين لها، غير مسبوقين بها، وما نافية، وسبقكم فعل ماض، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقكم﴾</span></span>، ومن حرف صلة، وأحد مجرور لفظًا، مرفوع محلًّا على أنه فاعل سبقكم، و<span class="hlt"><span class="qpc-hafs">﴿من العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لأحد.</p></div>"
  29,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئنكم لتأتون الرجال وتقطعون السبيل وتأتون في ناديكم المنكر﴾</span></span>: الهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، واللام المزحلقة، وجملة تأتون خبر إن، والرجال مفعول به، وتقطعون السبيل عطف على تأتون الرجال، وتأتون عطف أيضًا، وفي ناديكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأتون﴾</span></span>، والمنكر مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما كان جواب قومه إلا أن قالوا ائتنا بعذاب الله إن كنت من الصادقين﴾</span></span>: الفاء عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿جواب﴾</span></span>: خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، وأن وما في حيزها اسم كان المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ائتنا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ائتنا﴾</span></span> فعل أمر، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعذاب الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتنا﴾</span></span>، وإن شرطية، وكنت فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، ومن الصادقين: جار ومجرور متعلقان بمحذوف خبر إن، وجواب إن محذوف، دل عليه ما قبله، أي: فائتنا بعذاب الله.</p></div>"
  29,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب انصرني على القوم المفسدين﴾</span></span>: رب منادى مضاف لياء المتكلم المحذوفة، وحرف النداء محذوف، وانصرني: فعل دعاء، والفاعل مستتر، والنون للوقاية، والياء مفعول به، وعلى القوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انصرني﴾</span></span>، والمفسدين صفة للقوم.</p></div>"
  29,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جاءت رسلنا إبراهيم بالبشرى قالوا إنا مهلكو أهل هذه القرية﴾</span></span>: الواو عاطفة على محذوف، ولما ظرفية حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿جاءت رسلنا إبراهيم﴾</span></span> فعل، وفاعل، ومفعول به، وبالبشرى: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مهلكو﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿أهل هذه﴾</span></span> مضافين، والقرية بدل من هذه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أهلها كانوا ظالمين﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها تعليل، وإن حرف ناسخ، وأهلها اسم إن، وجملة كانوا خبرها، وظالمين خبر كان.</p></div>"
  29,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</span></span>: إن حرف ناسخ، وفيها: جار ومجرور متعلقان بمحذوف خبر إن المقدم، و<span class="hlt"><span class="qpc-hafs">﴿لوطًا﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل، وفاعل، ونحن مبتدأ، وأعلم خبر، وبمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وفيها جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لننجينه وأهله إلا امرأته كانت من الغابرين﴾</span></span>: اللام واقعة في جواب قسم مقدر، وننجينه فعل مضارع مبني على الفتح، وفاعله مستتر، تقديره: نحن، والهاء: مفعول به، وأهله عطف على الهاء، أو مفعول معه، وإلا أداة استثناء، وامرأته مستثنى، وجملة كانت حالية، وكانت فعل ماض ناقص، واسمها مستتر، ومن الغابرين: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>.</p></div>"
  29,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما أن جاءت رسلنا لوطا سيء بهم وضاق بهم ذرعا﴾</span></span>: الواو: استئنافية، ولما: ظرفية حينية، وأن: صلة، وجاءت: فعل ماض، ورسلنا: فاعل، ولوطًا: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيء بهم﴾</span></span> لا محل لها من الإعراب لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لَمّا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سيء﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل ضمير مستتر تقديره هو يعود على لوط، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سيء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ضاق بهم﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿سيء بهم﴾</span></span>، وذرعًا: تمييز محول عن الفاعل، أي: ضاق ذرعُه بهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لا تخف ولا تحزن إنا منجوك وأهلك إلا امرأتك كانت من الغابرين﴾</span></span>: الواو: عاطفة، وقالوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقالوا لا تخف﴾</span></span> معطوفة عل جملة <span class="hlt"><span class="qpc-hafs">﴿سيء بهم﴾</span></span>، وإنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿منجوك﴾</span></span> خبرها، والكاف في <span class="hlt"><span class="qpc-hafs">﴿منجوك﴾</span></span> في موضع جر بالإضافة، وأهلك مفعول به منصوب بفعل محذوف، أي: وننجي أهلك، وإلا: أداة استثناء، وامرأتك: مستثنى، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت من الغابرين﴾</span></span> حالية، وكانت: فعل ماض ناقص، واسمها مستتر، ومن الغابرين: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>.</p></div>"
  29,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا منزلون على أهل هذه القرية رجزا من السماء بما كانوا يفسقون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومنزلون خبرها، و<span class="hlt"><span class="qpc-hafs">﴿على أهل هذه القرية﴾</span></span> الجار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منزلون﴾</span></span>، وهذه: مضاف إليه، والقرية بدل مجرور، ورجزًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿منزلون﴾</span></span>، لأنه اسم فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجزًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء سببية، وما مصدرية، أي: بسبب فسقهم، والمصدر المؤول مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منزلون﴾</span></span>، وكانوا فعل ماض ناقص، وواو الجماعة اسمها، وجملة يفسقون خبرها.</p></div>"
  29,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد تركنا منها آية بينة لقوم يعقلون﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وتركنا فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، أو هو المفعول الثاني لها، وآية مفعولها الأول، وبينة صفة، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بينة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعقلون﴾</span></span> صفة لقوم.</p></div>"
  29,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإلى مدين أخاهم شعيبا فقال يا قوم اعبدوا الله وارجوا اليوم الآخر﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إلى مدين﴾</span></span> جار ومجرور متعلقان بمحذوف، أي: وأرسلنا إلى مدين شعيبًا، و<span class="hlt"><span class="qpc-hafs">﴿أخاهم﴾</span></span> مفعول به، وشعيبًا بدل، أو عطف بيان، والفاء عاطفة، وقال فعل ماض، وفاعله مستتر، تقديره: هو، ويا حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> فعل أمر، وفاعل، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ارجوا﴾</span></span> عطف على اعبدوا، واليوم: مفعول به، والآخر: صفة لليوم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span></span>: الواو عاطفة، ولا ناهية، وتعثوا فعل مضارع مجزوم بلا الناهية، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعثوا﴾</span></span>، ومفسدين حال.</p></div>"
  29,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه فأخذتهم الرجفة فأصبحوا في دارهم جاثمين﴾</span></span>: الفاء عاطفة، وكذبوه فعل ماض، وفاعل، ومفعول به، فأخذتهم الفاء عاطفة، وأخذتهم فعل ماض، ومفعول به مقدم، والرجفة فاعل مؤخر، <span class="hlt"><span class="qpc-hafs">﴿فأصبحوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فأخذتهم﴾</span></span>، والواو اسم أصبح، و<span class="hlt"><span class="qpc-hafs">﴿في دارهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاثمين﴾</span></span>، وجاثمين خبر أصبحوا.</p></div>"
  29,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعادا وثمود وقد تبين لكم من مساكنهم﴾</span></span>: الواو عاطفة، وعادًا مفعول به لفعل محذوف معطوف على ما قبله، أي: وأهلكنا عادًا، وثمود عطف على <span class="hlt"><span class="qpc-hafs">﴿عادًا﴾</span></span>، والواو عاطفة، وقد حرف تحقيق، وتبين فعل ماض، وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من مساكنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم فصدهم عن السبيل وكانوا مستبصرين﴾</span></span>: الواو عاطفة، وزين فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span>، والشيطان فاعل، وأعمالهم مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فصدهم﴾</span></span> عطف على زين، و<span class="hlt"><span class="qpc-hafs">﴿عن السبيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صدهم﴾</span></span>، والواو حالية، وكانوا فعل ماض ناقص، والواو اسمها، ومستبصرين خبرها.</p></div>"
  29,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقارون وفرعون وهامان ولقد جاءهم موسى بالبينات فاستكبروا في الأرض وما كانوا سابقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وقارون وفرعون وهامان﴾</span></span> معطوف على عاد، والواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> فعل، ومفعول به مقدم، وموسى فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاستكبروا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكبروا﴾</span></span>، والواو حالية، وما نافية. <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وسابقين خبرها.</p></div>"
  29,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكلا أخذنا بذنبه فمنهم من أرسلنا عليه حاصبا﴾</span></span>: الفاء الفصيحة، وكلًّا: مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span>، وأخذنا: فعل، وفاعل. <span class="hlt"><span class="qpc-hafs">﴿فمنهم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن مبتدأ مؤخر، وهي نكرة موصوفة، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> صفة، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حاصبًا﴾</span></span> مفعول أرسلنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومنهم من أخذته الصيحة ومنهم من خسفنا به الأرض ومنهم من أغرقنا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخذته الصيحة﴾</span></span> صفة، <span class="hlt"><span class="qpc-hafs">﴿ومنهم من خسفنا به الأرض ومنهم من أغرقنا﴾</span></span> الجملتان معطوفتان على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان الله ليظلمهم ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان الله﴾</span></span> كان فعل ماض ناقص، ولفظ الجلالة اسمها، واللام لام الجحود، و<span class="hlt"><span class="qpc-hafs">﴿يظلمهم﴾</span></span> منصوب بأن مضمرة وجوبًا بعد لام الجحود، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف خبر كان، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> مخففة مهملة. <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنفسهم﴾</span></span> مفعول مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span> خبر كانوا.</p></div>"
  29,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مثل الذين اتخذوا من دون الله أولياء كمثل العنكبوت اتخذت بيتا وإن أوهن البيوت لبيت العنكبوت﴾</span></span>: مثل مبتدأ، والذين مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وهي فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> الجار والمجرور متعلقان بمحذوف حال، وأولياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كمثل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿مَثل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العنكبوت﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذت بيتًا﴾</span></span> حالية، <span class="hlt"><span class="qpc-hafs">﴿وإن أوهن البيوت﴾</span></span>: الواو حالية، وإن اسمها، و<span class="hlt"><span class="qpc-hafs">﴿البيوت﴾</span></span> مضاف إليه، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿بيت﴾</span></span> خبر إن، والعنكبوت: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لو كانوا يعلمون﴾</span></span>: لو شرطية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> خبرها، وجواب لو محذوف تقديره: لما عبدوها.</p></div>"
  29,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يعلم ما يدعون من دونه من شيء وهو العزيز الحكيم﴾</span></span>: الجملة تعليل لما قبلها، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يعلم خبرها، وما اسم موصول مفعول يعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، وقيل: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، وشيء مجرور لفظا منصوب محلا على أنه مفعول يدعون، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يدعون﴾</span></span> في محل نصب مفعول يعلم، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر أول، والحكيم خبر ثان.</p></div>"
  29,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك الأمثال نضربها للناس وما يعقلها إلا العالمون﴾</span></span>: الواو عاطفة، وتلك مبتدأ، والأمثال بدل، وجملة <span class="hlt"><span class="qpc-hafs">﴿نضربها للناس﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نضربها﴾</span></span>، أو الأمثال خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نضربها﴾</span></span> حال، أو خبر ثان، والواو حالية، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿يعقلها﴾</span></span> فعل مضارع، ومفعول به، وإلا أداة حصر، والعالمون فاعل يعقلها.</p></div>"
  29,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الله السماوات والأرض بالحق إن في ذلك لآية للمؤمنين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿خلق الله السماوات﴾</span></span> فعل، وفاعل، ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿والأرض﴾</span></span> عطف على السماوات، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والباء للملابسة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وآية اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿للمؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآية.</p></div>"
  29,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اتل ما أوحي إليك من الكتاب وأقم الصلاة﴾</span></span>: اتل: فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره: أنت، أي: يا محمد، وما: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span> صلة الموصول لا محل لها من الإعراب. وإليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الكتاب﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، وأقم: فعل أمر معطوف على اتل، والفاعل: مستتر تقديره أنت أيضًا، والصلاة: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الصلاة تنهى عن الفحشاء والمنكر ولذكر الله أكبر والله يعلم ما تصنعون﴾</span></span>: إن حرف ناسخ، والصلاة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنهى عن الفحشاء والمنكر﴾</span></span>: خبرها، والواو: استئنافية، واللام لام الابتداء، و<span class="hlt"><span class="qpc-hafs">﴿ذكر الله﴾</span></span>: مبتدأ، ولفظ الجلالة: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أكبر﴾</span></span>: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولذكر الله أكبر﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿والله﴾</span></span>: الواو عاطفة، ولفظ الجلالة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>: فعل وفاعله ضمير مستتر تقديره هو والجملة في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تصنعون﴾</span></span>: صلة الموصول لا محل لها من الإعراب.</p></div>"
  29,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجادلوا أهل الكتاب إلا بالتي هي أحسن إلا الذين ظلموا منهم﴾</span></span>: <span class="hlt">«لا»</span>: ناهية، وتجادلوا: فعل مضارع مجزوم بلا الناهية، والواو: فاعل، وأهل: مفعول به، والكتاب: مضاف إليه، وإلا: أداة حصر، وبالتي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجادلوا﴾</span></span>، وموصوف الموصول محذوف، أي: بالمجادلة التي، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>: مبتدأ، وأحسن: خبر، والجملة: صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب. وإلا: أداة استثناء، والذين: مستثنى، وظلموا: فعل وفاعل، ومنهم: جار ومجرور متعلقان بحال من فاعل ظلموا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقولوا آمنا بالذي أنزل إلينا وأنزل إليكم وإلهنا وإلهكم واحد ونحن له مسلمون﴾</span></span>: الواو عاطفة، وقولوا: فعل أمر وفاعل، وآمنا: فعل وفاعل وهي جملة مقول القول، وبالذي: جار ومجرور متعلقان بآمنا، وجملة أنزل: صلة الموصول لا محل لها من الإعراب. وإلينا: جار ومجرور متعلقان بأنزل، وأنزل إليكم: عطف على أنزل إلينا، ففي الكلام حذف الموصول الاسمي أي: والذي أنزل إليكم، وإلهنا: الواو عاطفة، وإلهنا مبتدأ، وإلهكم: عطف على إلهنا، وواحد: خبر، ونحن: مبتدأ، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسلمون﴾</span></span>، ومسلمون: خبر نحن.</p></div>"
  29,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك أنزلنا إليك الكتاب﴾</span></span>: الواو استئنافية، كذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: مثل ذلك الإنزال أنزلنا، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وأنزلنا: فعل وفاعل، وإليك: جار ومجرور متعلقان بأنزلنا، والكتاب: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكذلك أنزلنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالذين آتيناهم الكتاب يؤمنون به﴾</span></span>: الفاء تفريعية، والذين: مبتدأ، وآتيناهم: فعل وفاعل ومفعول به وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span> صلة الموصول لا محل لها من الإعراب. والكتاب: مفعول به ثان، ويؤمنون فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وجملة يؤمنون به: خبر الذين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن هؤلاء من يؤمن به﴾</span></span>: الواو عاطفة، ومن هؤلاء: خبر مقدم، ومن: مبتدأ مؤخر، وجملة يؤمن به: صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يجحد بآياتنا إلا الكافرون﴾</span></span>: الواو حالية، وما: نافية، ويجحد: فعل مضارع مرفوع، وبآياتنا: جار ومجرور متعلقان به، وإلا: أداة حصر، والكافرون: فاعل يجحد.</p></div>"
  29,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت تتلو من قبله من كتاب ولا تخطه بيمينك إذا لارتاب المبطلون﴾</span></span>: الواو استئنافية، وما: نافية، وكنت: كان فعل ماض ناقص، والتاء اسمها، وتتلو فعل مضارع مرفوع، وفاعله مستتر تقديره أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتلو﴾</span></span> خبر كان، ومن قبله: جار ومجرور متعلقان بتتلو، أو متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>، ومن: حرف جر صلة، وكتاب: مجرور بمن لفظًا، منصوب محلا على أنه مفعول تتلو، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما كنت...﴾</span></span> مستأنفة لا محل لها من الإعراب، والواو: حرف عطف، ولا: نافية، وتخطه: فعل مضارع معطوف على تتلو، وبيمينك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخطه﴾</span></span>، وإذًا: حرف جواب وجزاء مهمل، ولارتاب: اللام: واقعة في جواب شرط مقدر، أي: لو كان شيء من ذلك لارتاب المبطلون، وارتاب: فعل ماض، والمبطلون: فاعل.</p></div>"
  29,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل هو آيات بينات في صدور الذين أوتوا العلم﴾</span></span>: بل: حرف إضراب، وهو: مبتدأ، وآيات: خبر، وبينات: صفة لآيات، وفي صدور: جار ومجرور متعلقان بمحذوف خبر ثان لهو، والذين: مضاف إليه، وجملة أوتوا العلم: صلة الموصول لا محل لها من الإعراب. والعلم: مفعول به ثان لأوتوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يجحد بآياتنا إلا الظالمون﴾</span></span>: الواو حالية، وما: نافية، ويجحد: فعل مضارع مرفوع، وبآياتنا: جار ومجرور متعلقان به، وإلا: أداة حصر، والظالمون: فاعل يجحد.</p></div>"
  29,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لولا أنزل عليه آيات من ربه﴾</span></span>: الواو استئنافية، وقالوا: فعل ماض، والواو: فاعل، ولولا: حرف تحضيض بمنزلة هلا، وأنزل: فعل ماض مبني لما لم يسمَّ فاعله، وعليه: جار ومجرور متعلقان بأنزل، وآيات: نائب فاعل، ومن ربه: جار ومجرور صفة لآيات أو متعلقان بأنزل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقالوا لولا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل إنما الآيات عند الله وإنما أنا نذير مبين﴾</span></span>: قل: فعل أمر، إنما: كافة ومكفوفة، والآيات: مبتدأ، وعند الله: ظرف متعلق بمحذوف هو الخبر، <span class="hlt"><span class="qpc-hafs">﴿وإنما﴾</span></span>: الواو عاطفة أو حالية، وإنما: كافة ومكفوفة، وأنا: مبتدأ، ونذير: خبر، ومبين: صفة.</p></div>"
  29,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يكفهم أنا أنزلنا عليك الكتاب يتلى عليهم﴾</span></span>: الهمزة للاستفهام، والواو: عاطفة على محذوف مقدر يقتضيه المقام، ولم: حرف نفي وقلب وجزم، ويكفهم: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والهاء: مفعول به، والميم علامة الجمع، وأنّ وما بعدها: فاعل يكفهم، وأنا: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أنزلنا عليك الكتاب: خبر أن، وجملة يتلى عليهم: حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لرحمة وذكرى لقوم يؤمنون﴾</span></span>: إن حرف توكيد ونصب، وفي ذلك: خبرها المقدم، واللام: المزحلقة، ورحمة: اسمها المؤخر، وذكرى: عطف على رحمة، ولقوم: جار ومجرور متعلقان بصفة لذكرى، وجملة يؤمنون: صفة لقوم.</p></div>"
  29,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل كفى بالله بيني وبينكم شهيدا يعلم ما في السماوات والأرض﴾</span></span>: قل: فعل أمر، كفى: فعل ماض، والباء: حرف جر صلة، واسم الجلالة مجرور بالباء لفظًا فاعل كفى المرفوع محلا، وبيني: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>، وبينكم: معطوف على <span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span>، وشهيدًا: تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span> حال، وما: مفعول يعلم، وفي السماوات: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. والأرض: عطف على السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا بالباطل وكفروا بالله أولئك هم الخاسرون﴾</span></span>: الواو استئنافية، والذين: مبتدأ، وجملة آمنوا: صلة الموصول لا محل لها من الإعراب. وبالباطل: جار ومجرور متعلقان بآمنوا، وكفروا بالله: عطف على آمنوا بالباطل، وأولئك: مبتدأ، وهم: ضمير فصل لا محل له من الإعراب، والخاسرون: خبر أولئك، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، والخاسرون: خبر المبتدأ الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم الخاسرون﴾</span></span> خبر أولئك. وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك هم الخاسرون﴾</span></span> خبر الذين، وجملة <span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا بالباطل...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  29,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويستعجلونك بالعذاب ولولا أجل مسمى لجاءهم العذاب﴾</span></span>: الواو استئنافية، ويستعجلونك: فعل مضارع مرفوع بثبوت النون، والواو: فاعل، والكاف: مفعول به، وبالعذاب: جار ومجرور متعلقان بيستعجلونك، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويستعجلونك...﴾</span></span> مستأنفة لا محل لها من الإعراب، والواو استئنافية، ولولا: حرف امتناع لوجود، وأجل: مبتدأ، ومسمى: صفة، والخبر محذوف، واللام: رابطة للجواب، وجاءهم العذاب: فعل ومفعول به وفاعل، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولولا أجل...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليأتينهم بغتة وهم لا يشعرون﴾</span></span>: الواو عاطفة، واللام: واقعة في جواب قسم مقدر، ويأتينهم: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره هو، وهم: مفعول به، وبغتة: مصدر في موضع الحال، والواو حالية، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يشعرون﴾</span></span>: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهم لا يشعرون﴾</span></span>: حالية.</p></div>"
  29,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يستعجلونك بالعذاب﴾</span></span>: يستعجلونك: فعل مضارع مرفوع بثبوت النون، والواو: فاعل، والكاف: مفعول به، وبالعذاب: جار ومجرور متعلقان بيستعجلونك، وكرر جملة <span class="hlt"><span class="qpc-hafs">﴿يستعجلونك بالعذاب﴾</span></span> للتعجب من حماقاتهم، لأن من هُدِّد بشيء التمس أسباب الوقاية منه، أما هؤلاء فيستعجلونه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن جهنم لمحيطة بالكافرين﴾</span></span>: الواو حالية، وإن حرف ناسخ، وجهنم اسمها، واللام المزحلقة، ومحيطة: خبر إن، وبالكافرين: جار ومجرور متعلقان بمحيطة.</p></div>"
  29,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يغشاهم العذاب من فوقهم ومن تحت أرجلهم﴾</span></span>: يوم: ظرف متعلق بمحيطة، و<span class="hlt"><span class="qpc-hafs">﴿يغشاهم العذاب﴾</span></span> فعل ومفعول به وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغشاهم العذاب﴾</span></span> في محل جر بإضافة الظرف إليها، ومن فوقهم: حال، ومن تحت أرجلهم: عطف على من فوقهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقول ذوقوا ما كنتم تعملون﴾</span></span>: الواو عاطفة، ويقول: فعل مضارع، وفاعله مستتر تقديره هو، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿يغشاهم..﴾</span></span>، وجملة ذوقوا: مقول القول، وهو فعل أمر وفاعل، وما: مفعول به، وجملة كنتم: صلة الموصول لا محل لها من الإعراب. وجملة تعملون: خبر كنتم.</p></div>"
  29,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا عبادي الذين آمنوا إن أرضي واسعة فإياي فاعبدون﴾</span></span>: يا: حرف نداء، وعبادي: منادي مضاف لياء المتكلم، والذين: صفة لعبادي، وجملة  <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿أرضي﴾</span></span> اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿واسعة﴾</span></span> خبر إن، <span class="hlt"><span class="qpc-hafs">﴿فإياي﴾</span></span> الفاء واقعة في جواب شرط مقدر، وإياي ضمير منفصل في محل نصب مفعول به لفعل مقدَّر يفسِّره الفعل المذكور تقديره: اعبدوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿إياي اعبدوا﴾</span></span> في محل جزم جواب الشرط المقدَّر، والمعنى: إنْ ضاق بكم مكان فإياي اعبدوا لأن أرضي واسعة ولن تضيق بكم. <span class="hlt"><span class="qpc-hafs">﴿فاعبدونِ﴾</span></span> الفاء صلة للتزيين، واعبدونِ: فعل أمر مبني على حذف النون، وواو الجماعة فاعل، والنون للوقاية، وياء المتكلم المحذوفة مفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿اعبدونِ﴾</span></span> تفسيرية لا محل لها من الإعراب.</p></div>"
  29,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كل نفس ذائقة الموت ثم إلينا ترجعون﴾</span></span>: كل نفس: مبتدأ ومضاف إليه، وذائقة: خبر، والموت: مضاف إليه. وثم: حرف عطف، وإلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  29,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات لنبوئنهم من الجنة غرفا﴾</span></span>: الواو: استئنافية، والذين: مبتدأ، وجملة آمنوا: صلة الموصول لا محل لها من الإعراب. والواو: عاطفة، وجملة عملوا الصالحات: عطف على جملة آمنوا، واللام: واقعة في جواب قسم مقدر، ونبوئنهم: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل: مستتر تقديره نحن، وهم: مفعول به، وجملة القسم: خبر الذين، ومن الجنة: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿غرفا﴾</span></span>، وغرفًا: مفعول به ثان. و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> أن تنصب <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> بفعل محذوف دل عليه الفعل المذكور بعده وهو <span class="hlt"><span class="qpc-hafs">﴿لنبوئنهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها الأنهار خالدين فيها نعم أجر العاملين﴾</span></span>: تجري: فعل مضارع، من تحتها: جار ومجرور متعلقان بتجري، الأنهار: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها الأنهار﴾</span></span>: صفة لغرفًا، وخالدين: حال، وفيها: جار ومجرور متعلقان بخالدين، ونعم: فعل ماض جامد، وأجر: فاعل نعم، والعاملين: مضاف إليه، والمخصوص بالمدح محذوف، أي: الجنة.</p></div>"
  29,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين صبروا وعلى ربهم يتوكلون﴾</span></span>: الذين: نعت للعاملين، وجملة صبروا: صلة الموصول لا محل لها من الإعراب. وعلى ربهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتوكلون﴾</span></span>، ويتوكلون: فعل مضارع مرفوع بثبوت النون، والواو: فاعله.</p></div>"
  29,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكأين من دابة لا تحمل رزقها﴾</span></span>: الواو استئنافية، وكأين: بمعنى كم الخبرية، وهي في محل رفع مبتدأ، ومن دابة: جار ومجرور، ودابة تمييز كأين، وجملة لا تحمل رزقها: صفة لدابة.</p><p>وقوله: <span class="hlt"><span class="qpc-hafs">﴿الله يرزقها وإياكم﴾</span></span>: لفظ الجلالة مبتدأ، وجملة يرزقها: خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿الله يرزقها﴾</span></span> خبر المبتدأ الأول <span class="hlt"><span class="qpc-hafs">﴿كأين﴾</span></span>، والواو عاطفة، وإياكم: ضمير نصب منفصل معطوف على الها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكأين من دابة...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو السميع العليم﴾</span></span>: الواو استئنافية، وهو: مبتدأ، والسميع: خبر أول، والعليم: خبر ثان، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  29,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم من خلق السماوات والأرض وسخر الشمس والقمر ليقولن الله فأنى يؤفكون﴾</span></span>: الواو استئنافية، واللام موطئة للقسم، وإن شرطية، وسألتهم فعل ماض، والتاء فاعل، وهم: مفعول به، وقوله: <span class="hlt"><span class="qpc-hafs">﴿سألتهم﴾</span></span> في محل جزم فعل الشرط، ومن: اسم استفهام في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span>: خبر مَن، والجملة في محل نصب مفعول ثان لسألتهم، و<span class="hlt"><span class="qpc-hafs">﴿سخر الشمس والقمر﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span>، واللام واقعة في جواب القسم، ويقولن: فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين: فاعل، والنون المشددة: نون التوكيد الثقيلة، والله: خبر لمبتدأ محذوف تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم...﴾</span></span> مستأنفة لا محل لها من الإعراب، والفاء الفصيحة، وأنى: اسم استفهام في محل نصب حال، ويؤفكون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  29,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله يبسط الرزق لمن يشاء من عباده ويقدر له إن الله بكل شيء عليم﴾</span></span>: لفظ الجلالة مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبسط الرزق﴾</span></span> في محل رفع خبر، ولمن: اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبسط﴾</span></span>، وجملة يشاء: صلة الموصول لا محل لها من الإعراب. ومن عباده: جار ومجرور متعلقان بمحذوف حال من العائد المحذوف، ويقدر: فعل مضارع معطوف على يبسط، وله: جار ومجرور متعلقان بيقدر، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وبكل: جار ومجرور متعلقان بعليم، وشيء: مضاف إليه، وعليم: خبر إن.</p></div>"
  29,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم من نزل من السماء ماء فأحيا به الأرض من بعد موتها ليقولن الله﴾</span></span>: الواو عاطفة، واللام موطئة للقسم، وإن شرطية، وسألتهم فعل ماض، والتاء فاعل، وهم: مفعول به، وقوله: <span class="hlt"><span class="qpc-hafs">﴿سألتهم﴾</span></span> في محل جزم فعل الشرط، ومَن: اسم استفهام في محل رفع مبتدأ، ونزل: فعل ماض، ومن السماء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، وماء: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نزل من السماء ماء﴾</span></span>: خبر مَن، وجملة <span class="hlt"><span class="qpc-hafs">﴿من نزَّل ...﴾</span></span> في محل نصب مفعول ثان لسألتهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأحيا به الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نزل من السماء ماء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعد موتها﴾</span></span> جار ومجرور ومضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحيا﴾</span></span>، واللام واقعة في جواب القسم، ويقولن: فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين فاعل، والنون المشددة: نون التوكيد الثقيلة، ولفظ الجلالة خبر لمبتدأ محذوف تقديره: هو. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم﴾</span></span> السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل الحمد لله بل أكثرهم لا يعقلون﴾</span></span>: قل: فعل أمر، الحمد: مبتدأ، ولله: خبر، والجملة مقول القول، وبل: حرف إضراب، وأكثرهم: مبتدأ، وجملة لا يعقلون: خبر.</p></div>"
  29,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما هذه الحياة الدنيا إلا لهو ولعب﴾</span></span>: الواو استئنافية، وما نافية، وهذه: مبتدأ، والحياة: بدل، والدنيا: نعت للحياة، وإلا: أداة حصر، ولهو: خبر هذه، ولعب: عطف على لهو، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما هذه الحياة...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الدار الآخرة لهي الحيوان لو كانوا يعلمون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والدار اسمها، والآخرة: نعت للدار، واللام المزحلقة، وهي: مبتدأ، والحيوان: خبر، والجملة من المبتدأ والخبر في محل رفع خبر إن، ولو: شرطية، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يعلمون خبر كان، وجواب لو محذوف تقديره: ما آثروا الحياة الدنيا.</p></div>"
  29,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا ركبوا في الفلك دعوا الله مخلصين له الدين﴾</span></span>: الفاء استئنافية، وإذا: ظرف مستقبل متضمن معنى الشرط، وركبوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ركبوا﴾</span></span> في محل جر بإضافة الظرف إليها، وفي الفلك: جار ومجرور متعلقان بركبوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعوا الله﴾</span></span>: لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومخلصين: حال، وله: جار ومجرور متعلقان بمخلصين، والدين: مفعول به لمخلصين، لأن <span class="hlt"><span class="qpc-hafs">﴿مخلصين﴾</span></span> اسم فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإذا ركبوا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما نجاهم إلى البر إذا هم يشركون﴾</span></span>: الفاء: عاطفة، ولما: ظرف بمعنى حين متضمن معنى الشرط، ونجاهم: فعل وفاعل مستتر ومفعول به، وإلى البر: جار ومجرور متعلقان بنجاهم، وإذا: فجائية، وهي مع مدخولها جملة لا محل لها من الإعراب، لأنها جواب لما، وهم: مبتدأ، وجملة يشركون: خبر <span class="hlt">«هم»</span>.</p></div>"
  29,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليكفروا بما آتيناهم وليتمتعوا فسوف يعلمون﴾</span></span>: اللام: لام التعليل أو لام العاقبة، ويكفروا: فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span>، أو اللام لام الأمر، والمضارع بعدها مجزوم، وواو الجماعة فاعل، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وليتمتعوا: عطف على ليكفروا، فهي مثلها، والفاء: الفصيحة، وسوف: حرف استقبال، ويعلمون: فعل مضارع وفاعل.</p></div>"
  29,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا أنا جعلنا حرما آمنا ويتخطف الناس من حولهم﴾</span></span>: الهمزة: للاستفهام الإنكاري التقريري، والواو: عاطفة على محذوف، أي: لقد جعلناهم آمنين قارين في مكة ولم يعلموا ذلك، ولم: حرف نفي وقلب وجزم، ويروا: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو: فاعل، وأنا: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة جعلنا: خبرها، ومفعول جعلنا الأول محذوف، أي: جعلنا بلدهم مكة، وحرمًا: مفعول به ثان، وأن وما بعدها: سدت مسد مفعولي يروا، وآمنًا: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حرما﴾</span></span>، والواو: حالية، ويتخطف: فعل مضارع مبني لما لم يسمَّ فاعله، والناس: نائب فاعل، ومن حولهم: حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفبالباطل يؤمنون وبنعمة الله يكفرون﴾</span></span>: الهمزة: للاستفهام الإنكاري، والفاء: عاطفة على محذوف، وبالباطل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بنعمة الله يكفرون﴾</span></span>: معطوف على ما قبله.</p></div>"
  29,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن أظلم ممن افترى على الله كذبا أو كذب بالحق لما جاءه﴾</span></span>: الواو استئنافية، ومن: اسم استفهام متضمن معنى النفي في محل رفع مبتدأ، وأظلم: خبر، وممن: جار ومجرور متعلقان بأظلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿افترى على الله﴾</span></span>: صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿كذبا﴾</span></span> مفعول به للفعل افترى، أي: اختلق كذبا وافتعله، أو مفعول لأجله، أي: افترى لأجل الكذب، أو مصدر في موضع الحال، أي: افترى حال كونه كاذبا وهي حال مؤكدة. وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن أظلم...﴾</span></span> مستأنفة لا محل لها من الإعراب، وأو: حرف عطف، وكذب: عطف على افترى، وبالحق: جار ومجرور متعلقان بكذب، ولما: ظرفية حينية، وجاءه: فعل وفاعل مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أليس في جهنم مثوى للكافرين﴾</span></span>: الهمزة للاستفهام التقريري، وليس: فعل ماض ناقص، وفي جهنم: خبر ليس المقدم، ومثوى: اسمها المؤخر، وللكافرين: جار ومجرور متعلقان بنعت لمثوى.</p></div>"
  29,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين جاهدوا فينا لنهدينهم سبلنا وإن الله لمع المحسنين﴾</span></span>: الواو استئنافية، والذين مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاهدوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. ومفعول جاهدوا محذوف، وفينا: جار ومجرور متعلقان بجاهدوا، واللام: واقعة في جواب قسم مقدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لنهدينهم﴾</span></span>: خبر الذين، سبلنا: مفعول به ثان، أو منصوب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿والذين جاهدوا...﴾</span></span> مستأنفة لا محل لها من الإعراب، وإن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، ومع المحسنين: ظرف متعلق بمحذوف خبر إن.</p></div>"
