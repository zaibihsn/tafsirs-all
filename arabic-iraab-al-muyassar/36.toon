quran[83]{c,v,t}:
  36,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يس﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  36,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والقرآن الحكيم﴾</span></span>: الواو: حرف قسم وجر، والقرآن: مقسم به وهو اسم مجرور بواو القسم، والجار والمجرور متعلقان بمحذوف تقديره: أقسم، والحكيم: صفة مجرورة.</p></div>"
  36,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك لمن المرسلين﴾</span></span>: إنك: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ والكاف اسمها، واللام المزحلقة، ومن المرسلين: جار ومجرور متعلقان بمحذوف خبر إن، والجملة جواب القسم.</p></div>"
  36,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿على صراط مستقيم﴾</span></span>: على صراط: جار ومجرور متعلقان بمحذوف خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو متعلقان بمحذوف حال من اسم إن أو من الضمير المستكن في خبرها، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>، ومستقيم: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صراط﴾</span></span>.</p></div>"
  36,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيل العزيز الرحيم﴾</span></span>: تنزيلَ: مفعول مطلق لفعل محذوف، أي: نزّل الله ذلك تنزيل العزيز الرحيم، أو منصوب على المدح بفعل محذوف تقديره أعني أو أمدح، والعزيز: مضاف إليه، والرحيم: نعت مجرور.</p></div>"
  36,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لتنذر قوما ما أنذر آباؤهم﴾</span></span>: اللام: للتعليل، وتنذر: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل المضارع مجرور باللام، ولام التعليل ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span> أو بمعنى قوله: <span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span>، أي: إنك مرسلٌ لتنذر. وقومًا: مفعول به، وما: نافية، وأُنذر: فعل ماض مبني لما لم يُسَمَّ فاعله، وآباؤهم: نائب فاعل، والضمير المتصل في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنذر آباؤهم﴾</span></span> في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في قوله: <span class="hlt"><span class="qpc-hafs">﴿ما أنذر آباؤهم﴾</span></span> موصولة في محل نصب مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تنذر﴾</span></span> وجملة <span class="hlt"><span class="qpc-hafs">﴿أُنذِر آباؤهم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الموصولة لا محل لها من الإعراب، أي: لتنذر قومًا الذي أُنذِره آباؤهم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة في محل نصب مفعول ثان وجملة <span class="hlt"><span class="qpc-hafs">﴿أُنذِر آباؤهم﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، أي: لتنذر قوما عذابًا أُنذِره آباؤهم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: لتنذر قومًا إنذارَ آبائهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم غافلون﴾</span></span>: الفاء: تعليلية لتعليل النفي إذا جعلت <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، أي: لم يُنذَروا فهم لأجل ذلك غافلون، أو لتعليل إنذاره عليه الصلاة والسلام أو إرساله بغفلتهم المحوجة إليه، وهم: مبتدأ، وغافلون: خبر.</p></div>"
  36,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد حق القول على أكثرهم فهم لا يؤمنون﴾</span></span>: لقد: اللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، وحق: فعل ماض، والقول: فاعل، وعلى أكثرهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span> والضمير المتصل مضاف إليه، والفاء: تعليلية، وهم: مبتدأ، ولا: نافية، ويؤمنون: فعل مضارع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> خبر.</p></div>"
  36,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا جعلنا في أعناقهم أغلالا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإنّا: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن، وجعلنا: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وفي أعناقهم: جار ومجرور متعلقان بمحذوف مفعول جعلنا الثاني، وأغلالا: مفعول جعلنا الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا في أعناقهم أغلالا﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهي إلى الأذقان﴾</span></span>: الفاء للتفريع، وهي: ضمير يعود على الأغلال في محل رفع مبتدأ، وإلى الأذقان: جار ومجرور متعلقان بمحذوف خبر، أي: <span class="hlt"><span class="qpc-hafs">﴿فهي واصلةٌ إلى الأذقان﴾</span></span>، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم مقمحون﴾</span></span>: الفاء تفريعية، وهم: مبتدأ، ومقمحون: خبر، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿هي إلى الأذقان﴾</span></span>.</p></div>"
  36,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا من بين أيديهم سدا ومن خلفهم سدا﴾</span></span>: الواو: عاطفة، وجعلنا: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، ومن بين: جار ومجرور متعلقان بمحذوف مفعول جعلنا الثاني، وأيديهم: مضاف إليه والضمير المتصل مضاف إليه، وسدًّا: مفعول جعلنا الأول، ومن خلفهم سدًّا: عطف على <span class="hlt"><span class="qpc-hafs">﴿من بين أيديهم سدًّا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا من بين أيديهم...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا في أعناقهم أغلالا...﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأغشيناهم﴾</span></span>: الفاء تفريعية، وأغشيناهم: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والميم علامة الجمع، والجملة الفعلية معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم لا يبصرون﴾</span></span>: الفاء تفريعية، وهم: مبتدأ، ولا: نافية، ويبصرون: فعل مضارع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يبصرون﴾</span></span> في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة الاسمية معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أغشيناهم﴾</span></span>.</p></div>"
  36,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسواء عليهم أأنذرتهم أم لم تنذرهم لا يؤمنون﴾</span></span>: الواو: استئنافية، أو عاطفة، وسواء: خبر مقدم، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أأنذرتهم﴾</span></span>: الهمزة للتسوية، وأنذرتهم: فعل ماض وفاعل ومفعول به، والهمزة مع الفعل بعدها في تأويل مصدر مبتدأ مؤخر، أي: سواء إنذارك إياهم وعدمه. و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف معادل للهمزة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تنذرهم﴾</span></span> فعل مضارع مجزوم بلم والفاعل مستتر تقديره أنت، والهاء مفعول به، والميم علامة الجمع، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تنذرهم﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أنذرتهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> استئناف مؤكد لما قبله لا محل لها من الإعراب، أو حال مؤكدة له، أو بدل منه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وسواء عليهم...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو معطوفة على ما قبلها.</p></div>"
  36,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما تنذر من اتبع الذكر وخشي الرحمن بالغيب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span>: كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿تنذر﴾</span></span>: فعل مضارع، وفاعله مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿اتبع﴾</span></span> فعل ماض، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿الذكر﴾</span></span> مفعول اتبع، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبع الذكر﴾</span></span> صلة الاسم الموصول <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿خشي﴾</span></span>: فعل ماض، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span> مفعول خشي، وجملة <span class="hlt"><span class="qpc-hafs">﴿خشي الرحمن﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿اتبع الذكر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالغيب﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل خشي، أي: خشي الرحمن غائبا عن أعين الناس في خلواته أو غائبا عن عذابه، أو الجار والمجرور متعلقان بمحذوف حال من مفعول خشي، أي: خشي عقاب الرحمن حال كون العقاب غائبا عنه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فبشره بمغفرة وأجر كريم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فبشره﴾</span></span>: الفاء لترتيب البشارة على ما قبلها من اتباع الذكر والخشية، و<span class="hlt"><span class="qpc-hafs">﴿بشره﴾</span></span>: فعل أمر، والفاعل مستتر تقديره أنت، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بمغفرة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشره﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وأجر﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿مغفرة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كريم﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span>.</p></div>"
  36,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا نحن نحي الموتى ونكتب ما قدموا وآثارهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>: مبتدأ، ونحيي: فعل مضارع، وفاعله مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿الموتى﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحيي الموتى﴾</span></span> خبر نحن، والجملة الاسمية <span class="hlt"><span class="qpc-hafs">﴿نحن نحيي الموتى﴾</span></span> خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل والجملة الفعلية <span class="hlt"><span class="qpc-hafs">﴿نحيي الموتى﴾</span></span> خبر إن، <span class="hlt"><span class="qpc-hafs">﴿ونكتب﴾</span></span>: الواو: عاطفة، ونكتب: فعل مضارع، وفاعله مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قدموا﴾</span></span>: فعل ماض وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدموا﴾</span></span> صلة الاسم الموصول <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وآثارهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿آثارهم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> منصوب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ونكتب ما قدموا﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نحيي الموتى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكل شيء أحصيناه في إمام مبين﴾</span></span>: الواو: عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>: مفعول به منصوب بفعل محذوف يدل عليه ما بعده تقديره: أحصينا، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أحصيناه﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحصيناه﴾</span></span> تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿في إمام﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحصيناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span>: صفة مجرورة.</p></div>"
  36,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واضرب لهم مثلا أصحاب القرية إذ جاءها المرسلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>: فعل أمر بمعنى اجعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثلا﴾</span></span>: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span>: مفعول به أول، أو <span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span> بمعنى اذكر، و<span class="hlt"><span class="qpc-hafs">﴿مثلا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span> بدل على حذف مضاف، أي: مثَلَ أصحاب، و<span class="hlt"><span class="qpc-hafs">﴿القرية﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: اسم مبني على السكون في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿أصحاب القرية﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جاءها﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿المرسلون﴾</span></span>: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءها المرسلون﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  36,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ أرسلنا إليهم اثنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> التي في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اثنين﴾</span></span>: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> في محل جر بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوهما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فكذبوهما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذبوهما﴾</span></span> فعل ماض وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذبوهما﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فعززنا بثالث﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فعززنا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span> فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بثالث﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span> معطوفة على سابقتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا إنا إليكم مرسلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا إليكم مرسلون﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span>.</p></div>"
  36,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ما أنتم إلا بشر مثلنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بشر﴾</span></span>: خبر أنتم، و<span class="hlt"><span class="qpc-hafs">﴿مثلنا﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بشر﴾</span></span>، وضمير المتكلمين <span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنتم...﴾</span></span> مقول القول في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنزل الرحمن من شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>: مجرور لفظًا بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> منصوب محلا على أنه مفعول أنزل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنزل﴾</span></span> معطوفة على مقول القول في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أنتم إلا تكذبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span>: فعل مضارع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن أنتم إلا تكذبون﴾</span></span> مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا يعلم إنا إليكم لمرسلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>: فعل مضارع، وفاعل يعلم مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لمرسلون﴾</span></span>: اللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا إليكم لمرسلون﴾</span></span> سدت مسد مفعولي يعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span> خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿ربنا يعلم...﴾</span></span> مقول القول في محل نصب.</p></div>"
  36,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما علينا إلا البلاغ المبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿البلاغ﴾</span></span>: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿المبين﴾</span></span>: صفة، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿ربنا يعلم...﴾</span></span>.</p></div>"
  36,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا تطيرنا بكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، تطيرنا: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطيرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تطيرنا﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لئن لم تنتهوا لنرجمنكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لئن﴾</span></span>: اللام موطئة للقسم و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>: حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تنتهوا﴾</span></span>: فعل مضارع مجزوم بلم، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لنرجمنكم﴾</span></span>: اللام واقعة في جواب القسم، و<span class="hlt"><span class="qpc-hafs">﴿نرجمنكم﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، والفاعل مستتر تقديره نحن، والكاف مفعول به، والميم علامة الجمع، وجملة <span class="hlt"><span class="qpc-hafs">﴿لنرجمنكم﴾</span></span> لا محل لها من الإعراب، لأنها جواب القسم، وجواب الشرط محذوف دل عليه جواب القسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليمسنكم منا عذاب أليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وليمسنكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يمسنكم﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، والكاف مفعول به، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أليم﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليمسنكم﴾</span></span> معطوفة على جواب القسم.</p></div>"
  36,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا طائركم معكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿طائركم﴾</span></span>: مبتدأ، والضمير المتصل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span>: ظرف متعلق بمحذوف خبر المبتدأ، والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿طائركم معكم...﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئن ذكرتم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أئن﴾</span></span>: الهمزة للاستفهام الإنكاري و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿ذكرتم﴾</span></span>: فعل ماض مبني لما لم يُسَمَّ فاعله في محل جزم فعل الشرط، والتاء نائب فاعل، والميم علامة الجمع، وجواب الشرط محذوف والتقدير: أئن ذكرتم تطيَّرتم أو توعدتم بالرجم والتعذيب، وجملة الشرط مستأنفة في حيز القول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أنتم قوم مسرفون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>: خبر، و<span class="hlt"><span class="qpc-hafs">﴿مسرفون﴾</span></span>: صفة، والجملة مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء من أقصى المدينة رجل يسعى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وجاء﴾</span></span>: الواو عاطفة أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿من أقصى﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المدينة﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>: فاعل جاء، و<span class="hlt"><span class="qpc-hafs">﴿يسعى﴾</span></span>: فعل مضارع وفاعله مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسعى﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجاء من أقصى...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم اتبعوا المرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض وفاعله مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى منصوب بفتحة مقدرة لأنه مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span>: فعل أمر وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>: مفعول اتبعوا، وجملة النداء <span class="hlt"><span class="qpc-hafs">﴿يا قوم...﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا المرسلين﴾</span></span> جواب النداء.</p></div>"
  36,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اتبعوا من لا يسألكم أجرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span>: فعل أمر وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل نصب مفعول اتبعوا، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿يسألكم﴾</span></span>: فعل مضارع، والفاعل مستتر تقديره هو، والكاف مفعول به أول، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿أجرًا﴾</span></span>: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يسألكم أجرا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا من لا يسألكم﴾</span></span> بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا المرسلين﴾</span></span> أو تأكيد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم مهتدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو عاطفة أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مهتدون﴾</span></span>: خبر، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿لا يسألكم أجرا﴾</span></span> لا محل لها من الإعراب، أو في محل نصب على الحال.</p></div>"
  36,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما لي لا أعبد الذي فطرني﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ وهو استفهام إنكاري، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الاستفهامية، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿أعبد﴾</span></span>: فعل مضارع، والفاعل مستتر تقديره أنا، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>: اسم موصول في محل نصب مفعول أعبد، و<span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span>: فعل ماض، والفاعل مستتر تقديره هو يعود على الاسم الموصول، وياء المتكلم مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span> صلة الذي لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا أعبد...﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لي لا أعبد...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإليه ترجعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإليه﴾</span></span>: الواو عاطفة أو حالية، والجار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>: فعل مضارع مبني لما لم يُسَمَّ فاعله، وواو الجماعة نائب فاعل، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span> لا محل لها من الإعراب، أو حالية.</p></div>"
  36,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأتخذ من دونه آلهة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أأتخذ﴾</span></span>: الهمزة للاستفهام الإنكاري أو بمعنى النفي، و<span class="hlt"><span class="qpc-hafs">﴿أتخذ﴾</span></span>: فعل مضارع، وفاعله مستتر تقديره أنا، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span>: جار ومجرور متعلقان بمفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أتخذ﴾</span></span> والهاء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span>: مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يردن الرحمن بضر لا تغن عني شفاعتهم شيئا ولا ينقذون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يردنِ﴾</span></span>: فعل الشرط مضارع مجزوم بالسكون، والنون للوقاية، والياء المحذوفة لاتباع خط المصحف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بضر﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يردن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية لا عمل لها، و<span class="hlt"><span class="qpc-hafs">﴿تغن﴾</span></span>: فعل مضارع مجزوم في جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عني﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شفاعتهم﴾</span></span>: فاعل مرفوع، والضمير المتصل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span>: نائب عن المفعول المطلق، أو مفعول به، وقوله: <span class="hlt"><span class="qpc-hafs">﴿لا تغن عني شفاعتهم شيئا﴾</span></span> جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ولا ينقذون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تغن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ينقذون﴾</span></span>: فعل مضارع مجزوم، وواو الجماعة فاعل، والنون للوقاية، وياء المتكلم المحذوفة مفعول به، وجملة الشرط صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> أو استئنافية لا محل لها من الإعراب.</p></div>"
  36,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني إذا لفي ضلال مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، وياء المتكلم اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span>: حرف جواب لا عمل له، و<span class="hlt"><span class="qpc-hafs">﴿لفي ضلال﴾</span></span>: اللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ضلال﴾</span></span>، والجملة مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني آمنت بربكم فاسمعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، وياء المتكلم اسمها، و<span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span>: فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بربكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span> والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنت بربكم﴾</span></span> خبر إن، <span class="hlt"><span class="qpc-hafs">﴿فاسمعونِ﴾</span></span>: الفاء تفريعية، و<span class="hlt"><span class="qpc-hafs">﴿اسمعون﴾</span></span> فعل أمر مبني على حذف النون، وواو الجماعة فاعل، والنون للوقاية، والياء المحذوفة مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿اسمعون﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني آمنت...﴾</span></span> مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قيل ادخل الجنة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>: فعل ماض مبني لما لم يُسَمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿ادخل﴾</span></span>: فعل أمر والفاعل مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span>: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ادخل الجنة﴾</span></span> مقول القول في محل رفع نائب فاعل، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا ليت قومي يعلمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف تنبيه، أو حرف نداء والمنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span>: حرف ناسخ يفيد التمني، و<span class="hlt"><span class="qpc-hafs">﴿قومي﴾</span></span>: اسم ليت منصوب بفتحة مقدرة، وياء المتكلم مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>: فعل مضارع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> خبر ليت، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا ليت قومي يعلمون﴾</span></span> مقول القول في محل نصب، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال يا ليت...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  36,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بما غفر لي ربي وجعلني من المكرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، أي: يعلمون بالذي غفره لي ربي من الذنوب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية والفعل <span class="hlt"><span class="qpc-hafs">﴿غفر﴾</span></span> مجرور بالباء، أي: يعلمون بغفران ربي لي، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿غفر﴾</span></span>: فعل ماض. و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفر﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span>: فاعل مرفوع بضمة مقدرة على ما قبل ياء المتكلم، وياء المتكلم مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿غفر لي ربي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وجعلني﴾</span></span>: الواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿وجعلني﴾</span></span> فعل ماض، والفاعل مستتر تقديره هو، والنون للوقاية، وياء المتكلم مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿من المكرمين﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلني من المكرمين﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿غفر لي ربي﴾</span></span>.</p></div>"
  36,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنزلنا على قومه من بعده من جند من السماء﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، وجند مجرور لفظًا منصوب محلًّا على أنه مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا منزلين﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومنزلين خبرها.</p></div>"
  36,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كانت إلا صيحة واحدة﴾</span></span>: إن نافية، وكانت فعل ماض ناقص ناسخ، واسمها ضمير مستتر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span> خبر كانت منصوب، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، والتقدير: ما كانت الصيحة إلا صيحة واحدة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا هم خامدون﴾</span></span>: الفاء عاطفة، وإذا فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خامدون﴾</span></span> خبر.</p></div>"
  36,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا حسرة على العباد﴾</span></span>: يا حرف نداء، وحسرة منادى شبيه بالمضاف منصوب، أو منادى نكرة مقصودة، وإنما نصبت لأنها وصفت بالجار والمجرور، أو المنادى محذوف، وحسرة مصدر، أي: أتحسر حسرة، ويكون النداء هنا مجازيا، أي: يا حسرة احضري فهذا أوانك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما يأتيهم من رسول إلا كانوا به يستهزئون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يأتيهم﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، ومن حرف جر صلة، ورسول مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا مرفوع محلا على أنه فاعل، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> كان فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والجملة في محل نصب خبر كانوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> في محل نصب على الحال من الفاعل في <span class="hlt"><span class="qpc-hafs">﴿يأتيهم﴾</span></span> أو من المفعول.</p></div>"
  36,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم يروا كم أهلكنا قبلهم من القرون﴾</span></span>: الهمزة للاستفهام التقريري، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو فاعل، والرؤية قلبية علمية، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> خبرية في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، وأهلكنا فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والجملة في محل نصب مفعول <span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> استفهامية، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من القرون﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنهم إليهم لا يرجعون﴾</span></span>: أن حرف ناسخ، وهم اسمها، وأن وما في حيزها بدل من معنى <span class="hlt"><span class="qpc-hafs">﴿كم أهلكنا﴾</span></span>، والتقدير: ألم يروا كثرة إهلاكنا القرون من قبلهم كونهم غير راجعين إليهم، أو المصدر المؤول معمول لفعل محذوف دل عليه السياق، والمعنى: وقضينا وحكمنا أنهم إليهم لا يرجعون، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span> خبر إن.</p></div>"
  36,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كل لما جميع لدينا محضرون﴾</span></span>: الواو عاطفة، وإن نافية، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حرف بمعنى إلا، و<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لدينا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر ثان، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>.</p></div>"
  36,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآية لهم الأرض الميتة أحييناها﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span> حالية، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخرجنا منها حبا فمنه يأكلون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حبًّا﴾</span></span> مفعول به، والفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمنه يأكلون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  36,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا فيها جنات من نخيل وأعناب وفجرنا فيها من العيون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span> فعل وفاعل، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، أو متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، وجنات مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من نخيل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أعناب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نخيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span> عطف، وهو فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من العيون﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول <span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span> المحذوف، أي: ينابيع كائنة من العيون، فـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبعيض.</p></div>"
  36,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليأكلوا من ثمره وما عملته أيديهم﴾</span></span>: تعليل لما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿ليأكلوا﴾</span></span> اللام لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿يأكلوا﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد اللام، وعلامة النصب حذف النون، والواو فاعل، والمصدر المؤول من أن والفعل مجرور بلام التعليل، والجار والمجرور من اللام والمصدر متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من ثمره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبني في محل جر عطفا على <span class="hlt"><span class="qpc-hafs">﴿ثمره﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿عملته﴾</span></span> فعل ماض والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أيديهم﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملته﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة عطف على <span class="hlt"><span class="qpc-hafs">﴿من ثمره﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملته أيديهم﴾</span></span> صفة، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: ومن عمل أيديهم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا يشكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف يقتضيه السياق، أي: أيرون هذه النعم ويستمتعون بها فلا يشكرونها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يشكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والمفعول به محذوف.</p></div>"
  36,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الذي خلق الأزواج كلها مما تنبت الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، والجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿الأزواج﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كلها﴾</span></span> تأكيد، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنبت الأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿تنبت﴾</span></span>: فعل مضارع. و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أنفسهم ومما لا يعلمون﴾</span></span>: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿مما تنبت الأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ومن أنفسهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ومما لا يعلمون﴾</span></span> عطف على ما سبق.</p></div>"
  36,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآية لهم الليل نسلخ منه النهار﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسلخ﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسلخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا هم مظلمون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مظلمون﴾</span></span> خبر.</p></div>"
  36,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والشمس تجري لمستقر لها﴾</span></span>: الشمس مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span> خبر، وهي فعل مضارع، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿لمستقر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك تقدير العزيز العليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، والإشارة إلى جريها، و<span class="hlt"><span class="qpc-hafs">﴿تقدير﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span>.</p></div>"
  36,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والقمر قدرناه منازل حتى عاد كالعرجون القديم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿القمر﴾</span></span> مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده، فهو منصوب على الاشتغال. و<span class="hlt"><span class="qpc-hafs">﴿قدرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به. وهي جملة <span class="hlt"><span class="qpc-hafs">﴿قدرناه﴾</span></span> تفسيرية لا محل لها من الإعرب. و<span class="hlt"><span class="qpc-hafs">﴿منازل﴾</span></span> حال بتقدير حذف مضاف، أي: ذا منازل، أو مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿قدرناه﴾</span></span>، أي: صيرناه منازل، أو ظرف، أي: قدرنا سيره في منازل، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، أي: القمر، أو <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> فعل ناقص، والاسم مستتر، وكالعرجون الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> تامة، والكاف اسم بمعنى مثل مبني على الفتح في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿العرجون﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿القديم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿العرجون﴾</span></span>.</p></div>"
  36,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا الشمس ينبغي لها أن تدرك القمر﴾</span></span>: لا نافية، و<span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها فاعل <span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القمر﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا الليل سابق النهار﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿سابق﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكل في فلك يسبحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في فلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span> خبر.</p></div>"
  36,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآية لهم أنا حملنا ذريتهم في الفلك المشحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وأن وما في حيزها مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ذريتهم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الفلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المشحون﴾</span></span> صفة.</p></div>"
  36,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخلقنا لهم من مثله ما يركبون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من مثله﴾</span></span> جار ومجرور متعلقان بمحذوف حال من المفعول المؤخر وهو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يركبون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. والضمير في <span class="hlt"><span class="qpc-hafs">﴿مثله﴾</span></span> يعود على الفلك.</p></div>"
  36,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن نشأ نغرقهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿نشأ﴾</span></span> فعل الشرط، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿نغرقهم﴾</span></span> فعل مضارع جواب الشرط، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا صريخ لهم﴾</span></span>: الفاء عاطفة، أو استئنافية، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿صريخ﴾</span></span> اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا صريخ لهم﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم ينقذون﴾</span></span>: الواو عاطفة، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينقذون﴾</span></span> خبر، وينقذون فعل مضارع مرفوع بثبوت النون مبني لما لم يسم فاعله، والواو نائب فاعل.</p></div>"
  36,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا رحمة منا ومتاعا إلى حين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، أو مفعول مطلق لفعل محذوف، أو منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿متاعًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى حين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p></div>"
  36,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم اتقوا ما بين أيديكم وما خلفكم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتقوا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿اتقوا﴾</span></span> فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أيديكم﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ما خلفكم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما بين أيديكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلكم ترحمون﴾</span></span>: لعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترحمون﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿ترحمون﴾</span></span> فعل مضارع مرفوع بثبوت النون مبني لما لم يسم فاعله، والواو نائب فاعل، وجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> محذوف، والتقدير: أعرضوا وأشاحوا.</p></div>"
  36,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين﴾</span></span>: الواو عاطفة، وما نافية، وتأتيهم فعل مضارع ومفعول به، ومن حرف جر صلة، وآية مجرور لفظًا مرفوع محلًّا على أنه فاعل، ومن آيات ربهم صفة، ومعنى <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> التبعيض، وإلا أداة حصر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا عنها معرضين﴾</span></span> في محل نصب حال، وكان فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بمعرضين، ومعرضين خبرها.</p></div>"
  36,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم أنفقوا مما رزقكم الله﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بالإضافة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنفقوا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنفقوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقكم الله﴾</span></span> فعل ماض، ومفعول به مقدم، ولفظ الجلالة: فاعل مؤخر. وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقكم الله﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين كفروا للذين آمنوا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل وفاعل، وهي صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنطعم من لو يشاء الله أطعمه﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿نطعم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يشاء الله﴾</span></span> فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أطعمه﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لو يشاء الله أطعمه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أنتم إلا في ضلال مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة.</p></div>"
  36,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون متى هذا الوعد﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿متى﴾</span></span> اسم استفهام في محل نصب على الظرفية، والظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿الوعد﴾</span></span> بدل من اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنتم صادقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، وكان فعل ماض ناقص، والتاء اسمها، وصادقين خبرها، وجواب الشرط محذوف لدلالة ما قبله عليه، أي: فمتى هذا الوعد؟</p></div>"
  36,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما ينظرون إلا صيحة واحدة تأخذهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿ينظرون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأخذهم﴾</span></span> صفة ثانية، أو جملة حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم يخصمون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير منفصل مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخصمون﴾</span></span> خبر، والجملة نصب على الحال.</p></div>"
  36,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا يستطيعون توصية ولا إلى أهلهم يرجعون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يستطيعون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿توصية﴾</span></span> مفعول به، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿إلى أهلهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿فلا يستطيعون﴾</span></span> .</p></div>"
  36,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونفخ في الصور فإذا هم من الأجداث إلى ربهم ينسلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> الفجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الأجداث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  36,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا ويلنا من بعثنا من مرقدنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف تنبيه، أو حرف نداء، والمنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ويلنا﴾</span></span> منادى مضاف منصوب، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام في محل رفع مبتدأ. وجملة <span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span> خبر، وهي فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من مرقدنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذا ما وعد الرحمن وصدق المرسلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعد الرحمن﴾</span></span> فعل وفاعل، والمفعول محذوف، أي: وعدنا، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي مع مدخولها خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مرقدنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما وعد﴾</span></span> في تأويل مصدر مبتدأ محذوف الخبر، والتقدير: وعد الرحمن حق، أو خبر لمبتدأ محذوف، والتقدير: هذا وعد الرحمن، و<span class="hlt"><span class="qpc-hafs">﴿صدق المرسلون﴾</span></span> فعل وفاعل.</p></div>"
  36,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كانت إلا صيحة واحدة فإذا هم جميع لدينا محضرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> فعل ماض ناقص ناسخ، واسمها مستتر تقديره: الصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> الفجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لدينا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر ثان، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>.</p></div>"
  36,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاليوم لا تظلم نفس شيئا ولا تجزون إلا ما كنتم تعملون﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تظلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تظلم﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نفس﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> نائب عن المفعول المطلق، وجملة <span class="hlt"><span class="qpc-hafs">﴿فاليوم لا تظلم...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا تجزون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تظلم﴾</span></span> على طريق الالتفات، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ناقص ناسخ، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  36,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن أصحاب الجنة اليوم في شغل فاكهون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿في شغل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن الثاني، و<span class="hlt"><span class="qpc-hafs">﴿فاكهون﴾</span></span> خبرها الأول. أو <span class="hlt"><span class="qpc-hafs">﴿في شغل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن الأول، و<span class="hlt"><span class="qpc-hafs">﴿فاكهون﴾</span></span> خبرها الثاني. أو <span class="hlt"><span class="qpc-hafs">﴿في شغل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاكهون﴾</span></span>، أو في محل نصب على الحال.</p></div>"
  36,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هم وأزواجهم في ظلال على الأرائك متكئون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أزواجهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في ظلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿على الأرائك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متكئون﴾</span></span> خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿وفي ظلال﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿متكئون﴾</span></span> خبر.</p></div>"
  36,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم فيها فاكهة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿فاكهة﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولهم ما يدعون﴾</span></span>: الواو عاطفة. و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: موصولة في محل رفع مبتدأ مؤخر. و<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم ما يدعون﴾</span></span> معطوفة على الجملة السابقة. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما يدعون﴾</span></span> مبتدأ مؤخر. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صفة ما.</p></div>"
  36,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>: خبر لمبتدأ محذوف، والتقدير: هو سلام.</p><p><span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>: مفعول مطلق منصوب بالفتحة لفعل محذوف، وهو مع عامله صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>، أي: سلام يقال لهم قولا.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قولًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رحيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>.</p><p>أو:</p><p><span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>: مفعول مطلق، وهو مصدر مؤكِّد لمضمون الجملة عامله مقدر، وهو مع عامله جملة معترضة.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رحيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>.</p><p>والجملة الاسمية استئناف بياني فلا محل لها من الإعراب.</p></div>"
  36,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وامتازوا اليوم أيها المجرمون﴾</span></span>: الجملة مقول لقول محذوف، أي: ويقول لهم الله، و<span class="hlt"><span class="qpc-hafs">﴿امتازوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿امتازوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، و<span class="hlt"><span class="qpc-hafs">﴿المجرمون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p></div>"
  36,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم أعهد إليكم يا بني آدم﴾</span></span>: جملة منتظمة في سلك المقول لهم، والهمزة للاستفهام المتضمن هذه المعاني، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿أعهد﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وفاعله ضمير مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعهد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿بني﴾</span></span> منادى مضاف، و<span class="hlt"><span class="qpc-hafs">﴿آدم﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن لا تعبدوا الشيطان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية. و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: ناهية. و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> الناهية، والواو فاعل. و<span class="hlt"><span class="qpc-hafs">﴿الشيطان﴾</span></span>: مفعول به. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي ومدخولها في تأويل مصدر منصوب بنزع الخافض، أي: ألم أعهد إليكم بترك عبادة الشيطان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعبدوا الشيطان﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لكم عدو مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عدوّ﴾</span></span>، أو بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿عدو﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة، والجملة تعليلية للنهي لا محل لها من الإعراب.</p></div>"
  36,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن اعبدوني هذا صراط مستقيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن اعبدوني﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن لا تعبدوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اعبدوني﴾</span></span> فعل أمر، والواو فاعل، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿صراط﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿مستقيم﴾</span></span> صفة، والجملة تعليلية للأمر.</p></div>"
  36,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أضل منكم جبلا كثيرا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جبلًّا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلم تكونوا تعقلون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تكونوا﴾</span></span> فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> خبرها.</p></div>"
  36,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذه جهنم التي كنتم توعدون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جهنم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب. والتاء اسم كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> خبرها.</p></div>"
  36,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اصلوها اليوم بما كنتم تكفرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اصلوها﴾</span></span> فعل أمر، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿اصلوها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصلوها﴾</span></span>، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: بسبب كفركم، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ناقص ناسخ، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكفرون﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم تكفرون﴾</span></span> لا محل لها من الإعراب.</p></div>"
  36,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اليوم نختم على أفواههم﴾</span></span>: اليوم ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نختم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نختم﴾</span></span> فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿على أفواههم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نختم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتكلمنا أيديهم وتشهد أرجلهم بما كانوا يكسبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿تكلمنا﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿أيديهم﴾</span></span> فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿تشهد أرجلهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تكلمنا أيديهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكلمنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أو موصولة، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكسبون﴾</span></span> خبرها.</p></div>"
  36,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نشاء لطمسنا على أعينهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> فعل مضارع، والفاعل مستتر، والمفعول به محذوف، أي: لو نشاء طمسها، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿طمسنا﴾</span></span> لا محل لها من الإعراب، وهي فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على أعينهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طمسنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستبقوا الصراط﴾</span></span>: الفاء عاطفة، واستبقوا فعل وفاعل، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿لطمسنا﴾</span></span>، والصراط منصوب على نزع الخافض، والأصل: فاستبقوا إلى الصراط، أو مفعول به، وتضمين فاستبقوا معنى: ابتدروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنى يبصرون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنى﴾</span></span> اسم استفهام بمعنى كيف في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿يبصرون﴾</span></span> فعل مضارع وفاعل، والاستفهام هنا معناه النفي، أي: لا يبصرون.</p></div>"
  36,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نشاء لمسخناهم على مكانتهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: نحن، ومفعول <span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> محذوف، أي: لو نشاء مسخهم، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿مسخناهم﴾</span></span> لا محل لها من الإعراب، وهي فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على مكانتهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: لمسخناهم على حالتهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما استطاعوا مضيا ولا يرجعون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿استطاعوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿مضيًّا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا يرجعون﴾</span></span> عطف.</p></div>"
  36,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن نعمره ننكسه في الخلق أفلا يعقلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم، و<span class="hlt"><span class="qpc-hafs">﴿نعمره﴾</span></span> فعل الشرط، والفاعل مستتر تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ننكسه﴾</span></span> جواب الشرط، والفاعل مستتر تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الخلق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننكسه﴾</span></span>، أو بمحذوف حال، والهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف يقتضيه السياق، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يعقلون﴾</span></span> فعل مضارع مرفوع والواو فاعل.</p></div>"
  36,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما علمناه الشعر وما ينبغي له﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿علمناه﴾</span></span> فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الشعر﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف، و<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> فعل مضارع معطوف على <span class="hlt"><span class="qpc-hafs">﴿علمناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا ذكر وقرآن مبين﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قرآن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة.</p></div>"
  36,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لينذر من كان حيا ويحق القول على الكافرين﴾</span></span>: اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿ينذر﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف تدل عليه قرينة الكلام، أي: أنزل عليه لينذر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> صلة الموصول لا محل لها من الإعراب. واسم كان ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿حيًّا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿يحق﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على الكافرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحق﴾</span></span>.</p></div>"
  36,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا أنا خلقنا لهم مما عملت أيدينا أنعاما﴾</span></span>: الهمزة للاستفهام التقريري، وأصلها: وألم يروا، وتقدم الاستفهام للصدارة، أو الواو عاطفة على محذوف يقتضيه السياق، والتقدير: ألم يتفكروا ولم يروا، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو فاعل، والرؤية علمية، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> خبرها، وهي فعل وفاعل، وأن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، أي: لأجلهم وانتفاعهم، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملت﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي: عملته، و<span class="hlt"><span class="qpc-hafs">﴿أيدينا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أنعامًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم لها مالكون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مالكون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مالكون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  36,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وذللناها لهم فمنها ركوبهم ومنها يأكلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذللناها﴾</span></span> فعل ماض وفاعل ومفعول، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذللناها﴾</span></span>، والفاء للتفريع، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ركوبهم﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  36,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولهم فيها منافع ومشارب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿منافع﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿مشارب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿منافع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا يشكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يشكرون﴾</span></span> فعل مضارع، والواو فاعل.</p></div>"
  36,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتخذوا من دون الله آلهة﴾</span></span>: الواو عاطفة على مقدر يستدعيه السياق، أي: ما فعلوا الشكر، و<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span> فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> مفعوله الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلهم ينصرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span> خبرها، والواو نائب فاعل، وجملة الرجاء حالية، أي: حال كونهم راجين النصر من آلهتهم.</p></div>"
  36,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يستطيعون نصرهم وهم لهم جند محضرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يستطيعون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿نصرهم﴾</span></span> مفعول به، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>.</p></div>"
  36,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا يحزنك قولهم إنا نعلم ما يسرون وما يعلنون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿يحزنك﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قولهم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعلم﴾</span></span> خبرها، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة مفعول به، أي: الذي يسرونه، أو مصدرية، أي: إسرارهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسرون﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما يعلنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما يسرون﴾</span></span>.</p></div>"
  36,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم ير الإنسان أنا خلقناه من نطفة فإذا هو خصيم مبين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والهمزة للاستفهام الإنكاري التعجبي، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿ير﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه حذف حرف العلة، و<span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span> خبرها، وأن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿ير﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من نطفة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span>، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خصيم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿إذا هو خصيم مبين﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿لم ير الإنسان﴾</span></span> داخلة معها في حيز الإنكار والتعجب.</p></div>"
  36,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضرب لنا مثلا ونسي خلقه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿نسي﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلقه﴾</span></span> مفعول به، أو الواو للحال بتقدير: قد، أي: وقد نسي خلقه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال من يحي العظام وهي رميم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي العظام﴾</span></span> خبر، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿رميم﴾</span></span> خبر، والجملة في موضع نصب على الحال.</p></div>"
  36,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل يحييها الذي أنشأها أول مرة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يحييها﴾</span></span> فعل مضارع ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحييها﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنشأها﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أول مرة﴾</span></span> نصب على الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو بكل خلق عليم﴾</span></span>: الواو استئنافية أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بكل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو بكل...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو في محل نصب حال.</p></div>"
  36,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل لكم من الشجر الأخضر نارا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> بدل من الذي الآنفة الذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿من الشجر الأخضر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿نارًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا أنتم منه توقدون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توقدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿توقدون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>.</p></div>"
  36,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أوليس الذي خلق السماوات والأرض بقادر على أن يخلق مثلهم﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو للعطف على مقدر يقتضيه المقام، و<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق...﴾</span></span> صلة الموصول لا محل لها من الإعراب. والباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿قادر﴾</span></span> مجرور لفظًا منصوب محلا على أنه خبر ليس، و<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span> حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادر﴾</span></span>، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿مثلهم﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلى﴾</span></span>: حرف جواب لإبطال النفي، أي: بلى هو قادر على ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو الخلاق العليم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الخلاق﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span> خبر ثان.</p></div>"
  36,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما أمره إذا أراد شيئا أن يقول له كن فيكون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿أمره﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span> مضاف إليه، وهي فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، وأن وما في حيزها خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿أمره﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كن﴾</span></span> مقول القول، وهو فعل أمر تام، وفاعله مستتر تقديره: أنت، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، والفعل وفاعله جملة في محل رفع خبر لمبتدأ محذوف، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿أمره﴾</span></span>.</p></div>"
  36,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبحان الذي بيده ملكوت كل شيء﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بيده﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ملكوت كل شيء﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿بيده ملكوت كل شيء﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإليه ترجعون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
