quran[15]{c,v,t}:
  91,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والشمس﴾</span></span>: الواو حرف قسم وجر، والشمس مقسم به مجرور، والجار والمجرور متعلقان بفعل القسم المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وضحاها﴾</span></span>: الواو عاطفة، وضحاها عطف على الشمس مجرور بكسرة مقدرة، والضمير في محل جر مضاف إليه.</p></div>"
  91,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والقمر﴾</span></span>: عطف أيضًا على الشمس مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: ظرف لما يستقبل من الزمان في محل نصب متعلق بفعل القسم المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿تلاها﴾</span></span>: فعل ماض وفاعل مستتر، والضمير مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تلاها﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  91,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنهار﴾</span></span>: عطف أيضًا على <span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: ظرف لما يستقبل من الزمان في محل نصب متعلق بفعل القسم المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿جلاها﴾</span></span>: فعل ماض وفاعل مستتر، والضمير مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿جلاها﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  91,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والليل﴾</span></span>: عطف أيضًا على <span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: ظرف لما يستقبل من الزمان في محل نصب متعلق بفعل القسم المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿يغشاها﴾</span></span>: فعل مضارع وفاعل مستتر، والضمير مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغشاها﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  91,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسماء﴾</span></span>: عطف أيضا على <span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوفة على <span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> مجرور، والتقدير: <span class="hlt"><span class="qpc-hafs">﴿والسماء والذي بناها﴾</span></span>. أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر، والمصدر المؤول معطوف على <span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> مجرور، والتقدير: <span class="hlt"><span class="qpc-hafs">﴿والسماء وبنائها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بناها﴾</span></span>: فعل ماض والفاعل مستتر، والضمير في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿بناها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  91,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض﴾</span></span>: عطف أيضًا على <span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوفة على <span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> مجرور. أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر، والمصدر المؤول معطوف على <span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿طحاها﴾</span></span>: فعل ماض والفاعل مستتر، والضمير في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿طحاها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  91,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونفس﴾</span></span>: عطف أيضًا على <span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوفة على <span class="hlt"><span class="qpc-hafs">﴿نفس﴾</span></span> مجرور. أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر، والمصدر المؤول معطوف على <span class="hlt"><span class="qpc-hafs">﴿نفس﴾</span></span> مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿سواها﴾</span></span>: فعل ماض والفاعل مستتر، والضمير في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿سواها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  91,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألهمها﴾</span></span>: الفاء عاطفة، وألهمها فعل ماض، وفاعل مستتر، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجورها﴾</span></span>: مفعول به ثان، والضمير مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتقواها﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فجورها﴾</span></span> منصوب بفتحة مقدرة، والضمير في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألهمها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿سواها﴾</span></span>.</p></div>"
  91,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>: حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلح﴾</span></span>: فعل ماض.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿زكاها﴾</span></span>: فعل ماض، والفاعل مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿زكاها﴾</span></span> صلة الموصول لا محل لها من الإعراب، والجملة جواب القسم، وقيل: الجواب محذوف، تقديره: لتبعثن، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد أفلح﴾</span></span> تابعة لقوله: <span class="hlt"><span class="qpc-hafs">﴿فألهمها﴾</span></span>.</p></div>"
  91,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span>: الواو عاطفة، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿خاب﴾</span></span>: فعل ماض.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿دساها﴾</span></span>: فعل ماض، والفاعل مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وقيل: يعود على الله تعالى، أي: هلك من أشقاه الله عز وجل، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿دساها﴾</span></span> صلة الموصول لا محل لها من الإعراب، والجملة عطف على سابقتها.</p></div>"
  91,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وكذبت فعل ماض، والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثمود﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿بطغواها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  91,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿طغواها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿انبعث﴾</span></span>: فعل ماض مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿أشقاها﴾</span></span>: فاعل مرفوع بضمة مقدرة، والضمير في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿انبعث﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  91,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span>: الفاء عاطفة، وقال فعل ماض مبني على الفتح.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ناقة﴾</span></span>: منصوب على التحذير على حذف مضاف، أي: ذروا عقرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ناقة الله﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسقياها﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿ناقة الله﴾</span></span> منصوب بفتحة مقدرة، والضمير في محل جر مضاف إليه، أي: وشربها، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقال لهم﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  91,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>: الفاء عاطفة، وكذبوه فعل، وفاعل، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قال لهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فعقروها﴾</span></span>: فعل وفاعل ومفعول به، وهي عطف على <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فدمدم﴾</span></span>: فعل ماض معطوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دمدم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span>: فاعل مرفوع، والضمير في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿بذنبهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دمدم﴾</span></span> أيضًا، والباء للسببية، أي: بسبب ذنبهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسواها﴾</span></span>: فعل وفاعل ومفعول به، عطف على <span class="hlt"><span class="qpc-hafs">﴿دمدم﴾</span></span>.</p></div>"
  91,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، أو حالية، أو استئنافية، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يخاف﴾</span></span>: فعل مضارع والفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿عقباها﴾</span></span>: مفعول به منصوب بفتحة مقدرة، والضمير في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا يخاف...﴾</span></span> معطوفة، أو في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p></div>"
