quran[88]{c,v,t}:
  28,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طسم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  28,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب المبين﴾</span></span>: تلك: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿آيات الكتاب المبين﴾</span></span>: خبر، ومضاف إليه، وصفة.</p></div>"
  28,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نتلو عليك من نبأ موسى وفرعون بالحق لقوم يؤمنون﴾</span></span>: نتلو: فعل مضارع مرفوع، وفاعل مستتر تقديره: نحن، وعليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتلو﴾</span></span>، ومن نبأ: جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: شيئًا محكيًّا من قصة موسى وفرعون. وفيه حذف الموصوف، وإقامة الصفة مقامه، وبالحق: جار ومجرور متعلقان بمحذوف حال من فاعل نتلو، أي: حال كوننا متلبسين بالحق والصدق، أو من المفعول، أي: حال كونه متلبسًا بالحق والصدق، ولقوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتلو﴾</span></span>، فهو بمثابة التعليل له، أي: لأجل قوم، وجملة يؤمنون: صفة لقوم.</p></div>"
  28,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن فرعون علا في الأرض وجعل أهلها شيعا﴾</span></span>: كلام مستأنف لا محل له من الإعراب. وإن: حرف ناسخ. وفرعون اسمها، وجملة علا: خبرها، وفاعل علا ضمير مستتر، وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وجعل أهلها﴾</span></span>: فعل وفاعل مستتر ومفعول به أول، وشيعًا: مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿يستضعف طائفة منهم يذبح أبناءهم ويستحيي نساءهم إنه كان من المفسدين﴾</span></span>: جملة يستضعف: حالية من فاعل جعل، وفاعل يستضعف مستتر، وطائفة: مفعول به، ومنهم: جار ومجرور متعلقان بمحذوف صفة لطائفة، ويذبح: بدل اشتمال من يستضعف، وأبناءهم: مفعول يذبح، <span class="hlt"><span class="qpc-hafs">﴿ويستحيي نساءهم﴾</span></span>: عطف على يذبح أبناءهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> تعليل، وإن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، واسم كان مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المفسدين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  28,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونريد أن نمن على الذين استضعفوا في الأرض﴾</span></span>: الواو عاطفة، أو حالية. وأن وما في حيزها مفعول نريد، وعلى الذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمن﴾</span></span>، وجملة استضعفوا: صلة الموصول لا محل لها من الإعراب. وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استضعفوا﴾</span></span>، أو بمحذوف حال، أي: حالة كونهم على الأرض. وجملة <span class="hlt"><span class="qpc-hafs">﴿نريد﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿إن فرعون﴾</span></span>، أو حالية من يستضعف، أي: يستضعفهم فرعون، ونحن نريد أن نمن عليهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونجعلهم أئمة ونجعلهم الوارثين﴾</span></span>: الواو عاطفة، ونجعلهم: عطف على نمن، والهاء مفعول به أول، وأئمة: مفعول به ثان، ونجعلهم الوارثين: عطف على نجعلهم أئمة.</p></div>"
  28,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونمكن لهم في الأرض ونري فرعون وهامان وجنودهما منهم ما كانوا يحذرون﴾</span></span>: الواو عاطفة، ونمكن: عطف على نجعل، وفاعله مستتر، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمكن﴾</span></span>، وفي الأرض: جار ومجرور متعلقان بمحذوف حال، ونري: عطف أيضًا، وفرعون: مفعول به، وهامان: عطف على فرعون، وجنودهما: عطف على فرعون وهامان، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نري﴾</span></span>، وما: مفعول به ثان لنري، وجملة كانوا: صلة الموصول لا محل لها من الإعراب. وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يحذرون: خبر كان.</p></div>"
  28,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إلى أم موسى أن أرضعيه﴾</span></span>: الواو عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿نريد...﴾</span></span>، أو الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب. وأوحينا: فعل وفاعل، وإلى أم موسى: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرضعيه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأرضعيه: فعل أمر وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا خفت عليه فألقيه في اليم﴾</span></span>: الفاء رابطة، وخفت: فعل وفاعل، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خفت﴾</span></span>، فألقيه: الفاء رابطة، وألقيه فعل أمر مبني على حذف النون، والياء فاعل، والهاء مفعول به، وفي اليم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تخافي ولا تحزني إنا رادوه إليك وجاعلوه من المرسلين﴾</span></span>: الواو عاطفة، ولا: ناهية، وتخافي: فعل مضارع مجزوم بلا، ولا تحزني: عطف على لا تخافي، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا رادوه﴾</span></span>: تعليل للأمر، والنهي، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ورادوه خبرها، وإليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رادوه﴾</span></span>، وجاعلوه: عطف على رادوه، وقد أضيف اسم الفاعل إلى مفعوله الأول، ومن المرسلين: جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  28,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالتقطه آل فرعون ليكون لهم عدوا وحزنا﴾</span></span>: الفاء الفصيحة، والتقطه: فعل ماض، ومفعول به مقدم، وآل: فاعل مؤخر، وفرعون: مضاف إليه، وليكون: اللام للعاقبة، وقيل: للتعليل، ويكون: فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿التقطه﴾</span></span>، واسم يكون مستتر تقديره: هو، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span>، وعدوًّا: خبر يكون، وحزنًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن فرعون وهامان وجنودهما كانوا خاطئين﴾</span></span>: إن حرف ناسخ، وفرعون اسمها، <span class="hlt"><span class="qpc-hafs">﴿وهامان وجنودهما﴾</span></span>: عطف على فرعون، وجملة كانوا: خبر إن، وكان فعل ماض ناقص، وواو الجماعة اسمها، وخاطئين: خبرها.</p></div>"
  28,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالت امرأت فرعون قرت عين لي ولك﴾</span></span>: الواو عاطفة، وقالت: عطف على <span class="hlt"><span class="qpc-hafs">﴿فالتقطه آل فرعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿امرأة فرعون﴾</span></span>: فاعل، ومضاف إليه، وقرة عين: خبر لمبتدأ محذوف، أي: هو قرة عين، ولي: جار ومجرور متعلقان بمحذوف صفتان لقرة، ولك: عطف على <span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تقتلوه عسى أن ينفعنا أو نتخذه ولدا وهم لا يشعرون﴾</span></span>: لا ناهية، وتقتلوه: فعل مضارع مجزوم بلا، والواو فاعل، والهاء مفعول به، وعسى: فعل ماض من أفعال الرجاء، واسمها مستتر تقديره: هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن ينفعنا﴾</span></span> خبر عسى منصوب، أو نتخذه: عطف على ينفعنا، والهاء مفعول به أول، وولدًا: مفعول به ثان، وهم: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون: خبر، والجملة حال من <span class="hlt"><span class="qpc-hafs">﴿آل فرعون﴾</span></span>.</p></div>"
  28,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأصبح فؤاد أم موسى فارغا﴾</span></span>: الواو استئنافية، وأصبح: فعل ماض ناقص، وفؤاد: اسمها، وأم موسى: مضاف إليه، وفارغًا: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأصبح فؤاد...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كادت لتبدي به لولا أن ربطنا على قلبها لتكون من المؤمنين﴾</span></span>: إن مخففة من الثقيلة مهملة، وكادت: فعل ماض من أفعال المقاربة، واسمها مستتر، واللام الفارقة، وجملة تبدي: خبر كاد، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبدي﴾</span></span>، ولولا: حرف امتناع لوجود، وأن: مصدرية، وهي مع مدخولها في تأويل مصدر مبتدأ محذوف الخبر، أي: لولا ربطنا على قلبها حاصل، وعلى قلبها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ربطنا﴾</span></span>، وجواب لولا محذوف، أي: لأبدت به، ولتكون: اللام للتعليل، وتكون فعل مضارع ناقص منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ربطنا﴾</span></span> أيضًا، ومن المؤمنين: جار ومجرور متعلقان بمحذوف خبر تكون.</p></div>"
  28,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالت لأخته قصيه فبصرت به عن جنب وهم لا يشعرون﴾</span></span>: الواو عاطفة، وقالت: فعل ماض، وفاعل مستتر تقديره: هي، أي: أم موسى، ولأخته: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالت﴾</span></span>، وقصيه: فعل أمر مبني على حذف النون، والياء فاعل، والهاء مفعول به، فبصرت: الفاء عاطفة على محذوف، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصرت﴾</span></span>، وعن جنب: جار ومجرور متعلقان بمحذوف حال من فاعل بصرت، أي: بصرت به مستخفية كائنة عن جنب، أو من الضمير في به، أي: بعيدًا، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون: خبر.</p></div>"
  28,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحرمنا عليه المراضع من قبل فقالت هل أدلكم على أهل بيت يكفلونه لكم وهم له ناصحون﴾</span></span>: الواو استئنافية، وحرمنا: فعل وفاعل، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>، والمراضع: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿وحرمنا عليه المراضع﴾</span></span> مستأنفة لا محل لها من الإعراب، ومن قبل: جار ومجرور متعلقان بمحذوف حال، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>، فقالت: الفاء الفصيحة، وهل: حرف استفهام، وأدلكم: فعل مضارع، والفاعل مستتر تقديره: أنا، والكاف مفعول به، وعلى أهل بيت: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدلكم﴾</span></span>، وجملة يكفلونه: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أهل بيت﴾</span></span>، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفلونه﴾</span></span>، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناصحون﴾</span></span>، وناصحون: خبر.</p></div>"
  28,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فرددناه إلى أمه كي تقر عينها ولا تحزن﴾</span></span>: الفاء عاطفة، ورددناه فعل وفاعل ومفعول به، وإلى أمه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رددناه﴾</span></span>، وكي: حرف مصدري ونصب، وتقر: فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، والمصدر المؤول من كي والفعل في محل جر باللام المحذوفة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رددناه﴾</span></span>، ولا تحزن: عطف على تقر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلم أن وعد الله حق ولكن أكثرهم لا يعلمون﴾</span></span>: الواو عاطفة، واللام للتعليل، وتعلم: فعل مضارع منصوب بأن مضمرة بعد اللام، وأن وما بعدها سدت مسد مفعولي تعلم، وأن حرف ناسخ، ووعد اسمها، وحق: خبرها، والواو حالية، ولكن أكثرهم: لكن حرف ناسخ، وأكثر اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مضاف إليه، وجملة لا يعلمون: خبرها.</p></div>"
  28,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما بلغ أشده واستوى آتيناه حكما وعلما وكذلك نجزي المحسنين﴾</span></span>: الواو استئنافية، ولما: حينية، أو رابطة، وبلغ: فعل ماض، وفاعله مستتر تقديره: هو، وأشده: مفعول به، واستوى: عطف على بلغ، وجملة آتيناه: لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وآتيناه: فعل ماض وفاعل ومفعول به أول، وحكمًا: مفعول به ثان، وعلمًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿حكمًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولما بلغ...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: وجزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به.</p></div>"
  28,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ودخل المدينة على حين غفلة من أهلها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ودخل المدينة﴾</span></span>: عطف على محذوف، ودخل المدينة: فعل وفاعل مستتر، ومفعول على السعة، وعلى حين غفلة: جار ومجرور متعلقان بمحذوف حال من المدينة، أومن فاعل دخل، أي: مختلسًا، ومن أهلها: جار ومجرور متعلقان بمحذوف صفة لغفلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوجد فيها رجلين يقتتلان هذا من شيعته وهذا من عدوه﴾</span></span>: فوجد: عطف على دخل، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span>، ورجلين: مفعول به، وجملة يقتتلان: صفة لرجلين، وهذا: مبتدأ، ومن شيعته: جار ومجرور متعلقان بمحذوف خبر، والجملة صفة ثانية لرجلين، وقيل حال، <span class="hlt"><span class="qpc-hafs">﴿وهذا من عدوه﴾</span></span>: عطف عليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستغاثه الذي من شيعته على الذي من عدوه﴾</span></span>: الفاء عاطفة، واستغاثه: فعل ماض ومفعول به، والذي: فاعل، ومن شيعته: جار ومجرور متعلقان بمحذوف صلة وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوكزه موسى فقضى عليه قال هذا من عمل الشيطان إنه عدو مضل مبين﴾</span></span>: فوكزه: عطف أيضًا، وموسى: فاعل، فقضى عليه: عطف على فوكزه، وقال: فعل ماض، والجملة مستأنفة لا محل لها من الإعراب، وهذا: مبتدأ، ومن عمل الشيطان: خبر، والجملة مقول القول، وجملة إنه عدو: تعليل، وإن حرف ناسخ، والهاء اسمها، وعدو خبرها، ومضل: صفة، ومبين: صفة ثانية.</p></div>"
  28,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إني ظلمت نفسي فاغفر لي فغفر له إنه هو الغفور الرحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: منادى مضاف إلى ياء المتكلم المحذوفة، وإن حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلمت نفسي﴾</span></span>: خبر إن، فاغفر لي: الفاء عاطفة، واغفر فعل دعاء، ولي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span>، فغفر له: عطف، وإن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: ضمير فصل، والغفور: خبر، والرحيم: خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، والغفور الرحيم: خبران له، والجملة خبر إن.</p></div>"
  28,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب بما أنعمت علي فلن أكون ظهيرا للمجرمين﴾</span></span>: بما: الباء حرف قسم وجر، وجواب القسم محذوف، تقديره: أقسم بإنعامك علي بالمغفرة لأتوبن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول مجرور بباء القسم، والفاء عاطفة على الجواب المحذوف، ولن: حرف نفي ونصب واستقبال، وأكون: فعل مضارع ناقص، واسمها مستتر تقديره: أنا، وظهيرًا: خبرها، وللمجرمين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span>، وقيل: الباء ومدخولها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعصمني﴾</span></span> المقدر، والفاء في <span class="hlt"><span class="qpc-hafs">﴿فلن أكون﴾</span></span>، هي الفصيحة، لأنها جواب شرط مقدر.</p></div>"
  28,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأصبح في المدينة خائفا يترقب﴾</span></span>: الفاء عاطفة، وأصبح: فعل ماض ناقص، اسمها مستتر، تقديره: هو، وفي المدينة: جار ومجرور متعلقان بمحذوف حال، وخائفًا: خبر أصبح، أو في المدينة: جار ومجرور متعلقان بمحذوف خبر أصبح، وخائفًا: حال، أو أن الفعل <span class="hlt"><span class="qpc-hafs">﴿أصبح﴾</span></span> تام وفاعله مستتر، وفي المدينة جار ومجرور متعلقان به، وخائفًا حال، وجملة يترقب: حال ثانية، أو خبر ثان، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿خائفًا﴾</span></span>، مفعول يترقب محذوف، أي: يترقب المكروه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا الذي استنصره بالأمس يستصرخه﴾</span></span>: الفاء عاطفة، وإذا: فجائية، والذي: مبتدأ، وجملة استنصره: صلة الموصول لا محل لها من الإعراب. وبالأمس: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استنصر﴾</span></span>، وجملة يستصرخه: خبر الذي، ومتعلق يستصرخه محذوف، أي: على قبطي آخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال له موسى إنك لغوي مبين﴾</span></span>: قال: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان به، وموسى: فاعل، وإنك: إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وغوي مبين: خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  28,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أن أراد أن يبطش بالذي هو عدو لهما﴾</span></span>: الفاء عاطفة، ولما: حينية، أو رابطة، وأن: صلة، وأراد: فعل ماض، وأن وما بعده في تأويل مصدر مفعول أراد، وبالذي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبطش﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، وعدو: خبر، ولهما: جار ومجرور متعلقان بمحذوف صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو عدو لهما﴾</span></span> صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا موسى أتريد أن تقتلني كما قتلت نفسا بالأمس﴾</span></span>: قال: فعل ماض، وفاعله مستتر، أتريد: الهمزة للاستفهام، وتريد فعل مضارع مرفوع، وأن وما في حيزها مفعول تريد، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمفعول مطلق محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، والتقدير: تقتلني قتلا مثلَ قتلك نفسًا بالأمس، و<span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span> فعل وفاعل، ونفسًا مفعول به، وبالأمس: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span> صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تريد إلا أن تكون جبارا في الأرض وما تريد أن تكون من المصلحين﴾</span></span>: إن نافية، وتريد: فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت، وإلا: أداة حصر، وأن وما بعدها في تأويل مصدر مفعول تريد، وجبارًا: خبر تكون، وفي الأرض: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جبارًا﴾</span></span>، وما نافية، وتريد: فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت، وأن وما بعدها في تأويل مصدر مفعول تريد، و<span class="hlt"><span class="qpc-hafs">﴿من المصلحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون.</p></div>"
  28,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء رجل من أقصى المدينة يسعى﴾</span></span>: الواو عاطفة على محذوف، وجاء رجل: فعل وفاعل، ومن أقصى المدينة: الجار والمجرور متعلقان بمحذوف صفة لرجل، وجملة يسعى: صفة ثانية، أو حال، أو من أقصى المدينة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وجملة يسعى: صفة فقط.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا موسى إن الملأ يأتمرون بك ليقتلوك فاخرج إني لك من الناصحين﴾</span></span>: إن الملأ: إن حرف ناسخ، والملأ اسمها، وجملة يأتمرون: خبر إن، وبك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتمرون﴾</span></span>، وليقتلوك: اللام تعليلية، ويقتلوك فعل مضارع منصوب بأن مضمرة بعدها، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتمرون﴾</span></span>، فاخرج: الفاء الفصيحة، أي: إن سمعت نصيحتي فاخرج، وإني: إن حرف ناسخ، والياء اسمها، ولك: جار ومجرور متعلقان بمحذوف حال، وقيل: متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الناصحين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الناصحين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  28,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخرج منها خائفا يترقب قال رب نجني من القوم الظالمين﴾</span></span>: الفاء عاطفة على محذوف، ومنها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خرج﴾</span></span>، وخائفًا: حال، وجملة يترقب: حال ثانية، ومفعول يترقب محذوف، أي: الشر، أو لحوقهم به، وقيل: يترقب غوث الله، ورب: منادى، ونجني: فعل دعاء، والياء مفعول به، ومن القوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجني﴾</span></span>، والظالمين: صفة.</p></div>"
  28,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما توجه تلقاء مدين قال عسى ربي أن يهديني سواء السبيل﴾</span></span>: الواو استئنافية، ولما ظرف بمعنى حين متضمن معنى الشرط، وتوجه: فعل ماض، وفاعله مستتر، تقديره: هو، وتلقاء مدين: ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿توجه﴾</span></span>، ومدين: مضاف إليه، ومنعت من الصرف للعلمية والتأنيث، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال...﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وعسى: فعل ماض جامد من أفعال الرجاء، وربي: اسمها، وأن وما في حيزها خبرها، وسواء السبيل: مفعول ثان، أو منصوب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولما توجه...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  28,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما ورد ماء مدين وجد عليه أمة من الناس يسقون﴾</span></span>: وجد: فعل ماض، وفاعله مستتر تقديره: هو، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span>، وأمة: مفعول به، ومن الناس: جار ومجرور متعلقان بمحذوف صفة لأمة، وجملة يسقون: صفة ثانية، أو حال، ومفعول يسقون محذوف للعلم به، أي: مواشيهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ووجد من دونهم امرأتين تذودان﴾</span></span>: الواو عاطفة، ووجد: عطف على وجد الأولى، ومن دونهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span> أيضًا، وامرأتين مفعول به أول، وجملة تذودان صفة لامرأتين.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال ما خطبكما قالتا لا نسقي حتى يصدر الرعاء وأبونا شيخ كبير﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، وخطبكما: خبر، والجملة مقول القول، قالتا: فعل ماض، والتاء تاء التأنيث الساكنة، وحركت بالفتح لمناسبة ألف التثنية، والألف فاعل، وجملة لا نسقي: مقول قولهما، وحتى: حرف غاية وجر، ويصدر: فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسقي﴾</span></span>، والرعاء: فاعل، والواو حالية، وأبونا: مبتدأ، وشيخ: خبر، وكبير: صفة.</p></div>"
  28,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسقى لهما ثم تولى إلى الظل﴾</span></span>: الفاء عاطفة على محذوف مقدر، وسقى: فعل ماض، ولهما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سقى﴾</span></span>، والمفعول به محذوف، أي: غنمهما لأجلهما، ثم حرف عطف، وتولى فعل ماض، وإلى الظل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تولى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال رب إني لما أنزلت إلي من خير فقير﴾</span></span>: رب منادى، وإن حرف ناسخ، والياء اسمها، ولما: اللام حرف جر، وما: نكرة بمعنى شيء، أو اسم موصول، أي: لأي شيء، أو للذي أنزلت، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فقير﴾</span></span>، وأنزلت: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلت﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، أو صلة الموصول لا محل لها من الإعراب. وإلي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلت﴾</span></span>، ومن خير حال، وفقير: خبر إن.</p></div>"
  28,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فجاءته إحداهما تمشي على استحياء﴾</span></span>: الفاء عاطفة على محذوف، وإحداهما: فاعل، وجملة تمشي: حال من الفاعل، وعلى استحياء: جار ومجرور متعلقان بمحذوف حال من الفاعل المضمر في تمشي، أي: مستحيية.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت إن أبي يدعوك ليجزيك أجر ما سقيت لنا﴾</span></span>: إن حرف ناسخ، وأبي اسمها، وجملة يدعوك: خبرها، وليجزيك: اللام للتعليل، ويجزيك: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعوك﴾</span></span>، والكاف مفعول به أول، وأجر: مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مضاف إليه، أي: أجر سقايتك، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سقيت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءه وقص عليه القصص قال لا تخف نجوت من القوم الظالمين﴾</span></span>: الفاء عاطفة على محذوف، قص: فعل ماض، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قص﴾</span></span>، والقصص: مفعول به، وجملة قال: لا محل لها من الإعراب، ولا ناهية، وتخف: فعل مضارع مجزوم بلا، ونجوت: فعل وفاعل، ومن القوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجوت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الظالمين﴾</span></span> صفة.</p></div>"
  28,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت إحداهما يا أبت استأجره﴾</span></span>: قالت إحداهما فعل، وفاعل، ويا حرف نداء، وأبت منادى مضاف لياء المتكلم المعوض عنها بالتاء، واستأجره فعل أمر، وفاعل، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن خير من استأجرت القوي الأمين﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها تعليل للأمر قبلها، وإن حرف ناسخ، وخير اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مضاف إليه، وجملة استأجرت: صلة الموصول لا محل لها من الإعراب. والقوي: خبر أول، والأمين: خبر ثان.</p></div>"
  28,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إني أريد أن أنكحك إحدى ابنتي هاتين﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة أريد: خبرها، والجملة مقول القول، وأن أنكحك: في تأويل مصدر مفعول أريد، وفاعل أنكحك ضمير مستتر، تقديره: أنا، والكاف مفعول به أول، وإحدى: مفعول به ثان، وابنتي: مضاف إليه، وهاتين: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ابنتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿على أن تأجرني ثماني حجج﴾</span></span>: على: حرف جر دخل على أن وما يليها، والجار والمجرور متعلقان بمحذوف في موضع الحال من الفاعل، أو من المفعول، أي: مشروطًا علي، أو عليك ذلك، وتأجرني: فعل مضارع، ومفعول تأجرني الثاني محذوف، أي: نفسك، وثماني: ظرف لتأجرني، وقيل: ثماني مفعولًا ثانيًا لتأجرني، وقد احتاج إلى تقدير مضاف، أي: رعى ثماني حجج، وحجج: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن أتممت عشرا فمن عندك﴾</span></span>: الفاء عاطفة، وإن شرطية، وأتممت: فعل ماض في محل جزم فعل الشرط، وعشرًا: مفعول به، والفاء رابطة للجواب، لأنه جملة اسمية، ومن عندك: جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: فالتمام من عندك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أريد أن أشق عليك ستجدني إن شاء الله من الصالحين﴾</span></span>: الواو عاطفة، وما نافية، وأريد: فعل مضارع، وفاعل مستتر تقديره: أنا، وأن وما في حيزها مفعول أريد، وعليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشق﴾</span></span>، وستجدني: فعل مضارع مرفوع، والفاعل مستتر تقديره: أنت، والنون للوقاية، والياء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن شاء الله﴾</span></span>: اعتراضية لا محل لها من الإعراب، وجواب الشرط محذوف دل عليه ما قبله، ومن الصالحين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجدني﴾</span></span>.</p></div>"
  28,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ذلك بيني وبينك أيما الأجلين قضيت فلا عدوان علي والله على ما نقول وكيل﴾</span></span>: ذلك: مبتدأ، وبيني وبينك: خبره، وأيما الأجلين: أي اسم شرط جازم في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿قضيت﴾</span></span>، وما صلة، وقيل: إن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة بمعنى شيء، والأجلين بدل منها، وقضيت فعل وفاعل، والفاء رابطة للجواب، ولا نافية للجنس، وعدوان: اسمها المبني على الفتح، وعلي: جار ومجرور متعلقان بمحذوف خبر لا. والله: مبتدأ. و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيل﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span> صلة الموصول لا محل لها من الإعراب. ووكيل: خبر الله.</p></div>"
  28,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما قضى موسى الأجل وسار بأهله آنس من جانب الطور نارا﴾</span></span>: الفاء عاطفة على محذوف، ولما حينية، أو رابطة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قضى موسى الأجل﴾</span></span> لا محل لها من الإعراب، وسار: عطف على قضى، وبأهله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سار﴾</span></span>، وجملة آنس لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿من جانب الطور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آنس﴾</span></span>، أو حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نارًا﴾</span></span>، وتقدم عليها، ونارًا: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال لأهله امكثوا إني آنست نارا﴾</span></span>: لأهله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة امكثوا: مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span> تعليل للأمر بالمكث، وإن حرف ناسخ، والياء اسمها، وجملة آنست خبرها، ونارًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلي آتيكم منها بخبر أو جذوة من النار لعلكم تصطلون﴾</span></span>: لعل حرف ناسخ للترجي، والياء اسمها، وجملة آتيكم خبرها، والكاف مفعول به، ومنها جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لخبر، وبخبر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتيكم﴾</span></span>، وأو حرف عطف، وجذوة عطف على خبر، ومن النار نعت لجذوة، وجملة الرجاء حال أيضًا، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة تصطلون خبرها.</p></div>"
  28,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أتاها نودي من شاطئ الواد الأيمن في البقعة المباركة من الشجرة﴾</span></span>: الفاء عاطفة على محذوف، وجملة نودي لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومن شاطئ: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نودي﴾</span></span>، والواد مضاف إليه مجرور بكسرة مقدرة على الياء المحذوفة، والأيمن صفة لشاطئ، أو صفة للوادي، وفي البقعة: جار ومجرور متعلقان بمحذوف حال من الشاطئ، والمباركة صفة للبقعة، ومن الشجرة جار ومجرور متعلقان بمحذوف بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿من شاطئ الوادي﴾</span></span> بدل الاشتمال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن يا موسى إني أنا الله رب العالمين﴾</span></span>: أن: تفسيرية، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا موسى...﴾</span></span> تفسيرية لا محل لها من الإعراب، وإني: إن حرف ناسخ، والياء اسمها، وأنا ضمير فصل، أو مبتدأ، والله خبر إن، أو خبر أنا، والجملة خبر إن، ورب العالمين نعت للفظ الجلالة، أو بدل منه.</p></div>"
  28,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن ألق عصاك فلما رآها تهتز كأنها جان ولى مدبرا ولم يعقب﴾</span></span>: الواو عاطفة. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿أن ألق...﴾</span></span> معطوفة على سابقتها. وألق: فعل أمر، وفاعله مستتر، تقديره: أنت. وعصاك: مفعول به. فلما: الفاء عاطفة على مقدر يقتضيه السياق، و<span class="hlt"><span class="qpc-hafs">﴿رآها﴾</span></span> فعل وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تهتز﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأنها جان﴾</span></span> حال من فاعل تهتز، وكأن حرف ناسخ، والهاء اسمها، وجان خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولّى﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وفاعل ولى مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿مدبرًا﴾</span></span> حال، والواو عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يعقب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ولّى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا موسى أقبل ولا تخف إنك من الآمنين﴾</span></span>: أقبل فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لا تخف﴾</span></span>: لا ناهية، وتخف فعل مضارع مجزوم بلا، وإن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الآمنين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، والجملة تعليلية.</p></div>"
  28,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اسلك يدك في جيبك تخرج بيضاء من غير سوء﴾</span></span>: اسلك يدك فعل أمر، وفاعل مستتر، ومفعول به، وفي جيبك جار ومجرور متعلقان باسلك، وتخرج فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر، تقديره: هي، وبيضاء حال، ومن غير سوء جار ومجرور متعلقان ببيضاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿واضمم إليك جناحك من الرهب﴾</span></span>: الواو عاطفة، واضمم فعل أمر، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضمم﴾</span></span>، وجناحك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الرهب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضمم﴾</span></span> بمثابة التعليل له، أي: من أجل الرهب، وقيل: بـ<span class="hlt"><span class="qpc-hafs">﴿ولّى﴾</span></span>، أي: هرب من الفزع، وقيل: بـ<span class="hlt"><span class="qpc-hafs">﴿مدبرًا﴾</span></span>، وقيل: بمحذوف، أي: يسكن من الرهب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فذانك برهانان من ربك إلى فرعون وملئه إنهم كانوا قوما فاسقين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ذانك﴾</span></span> اسم إشارة مبتدأ مرفوع بالألف، وبرهانان خبر، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿برهانان﴾</span></span>، أي: مرسلان من ربك، و<span class="hlt"><span class="qpc-hafs">﴿إلى فرعون﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿برهانان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ملئه﴾</span></span> عطف على فرعون، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span> تعليل لإرسال البرهانين، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة كانوا خبرها، وكان فعل ماض ناقص، وواو الجماعة اسمها، وقومًا خبرها، وفاسقين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>.</p></div>"
  28,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إني قتلت منهم نفسا فأخاف أن يقتلون﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، وإن حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span> خبرها، ومنهم جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة وتقدمت، و<span class="hlt"><span class="qpc-hafs">﴿نفسًا﴾</span></span> مفعول به. <span class="hlt"><span class="qpc-hafs">﴿فأخاف﴾</span></span>: الفاء عاطفة، وأخاف فعل مضارع مرفوع، وفاعله مستتر تقديره: أنا، وأن وما في حيزها مفعول أخاف، ويقتلون: منصوب بأن، وعلامة نصبه حذف النون، والواو فاعل، والنون للوقاية، وياء المتكلم المحذوفة مفعول به.</p></div>"
  28,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأخي هارون هو أفصح مني لسانا فأرسله معي ردءا يصدقني إني أخاف أن يكذبون﴾</span></span>: الواو عاطفة، وأخي مبتدأ، وهارون بدل، أو عطف بيان، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأفصح خبر، والجملة خبر أخي، ومني: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفصح﴾</span></span>، ولسانًا: تمييز، فأرسله: الفاء الفصيحة، وأرسله: فعل دعاء، وفاعله أنت، والهاء مفعول به، ومعي: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسله﴾</span></span>، والياء في محل جر مضاف إليه، وردءًا: حال، ويصدقني: فعل مضارع مرفوع، والنون للوقاية، والياء مفعول به، والجملة مستأنفة لا محل لها من الإعراب، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ردءًا﴾</span></span>، أو حال من مفعول أرسله، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني أخاف﴾</span></span> تعليل، وإن حرف ناسخ، والياء اسمها، وجملة أخاف خبر إن، وأن وما في حيزها مفعول أخاف.</p></div>"
  28,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال سنشد عضدك بأخيك ونجعل لكما سلطانا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿سنشد﴾</span></span> مقول القول، وفاعل نشد نحن، وعضدك مفعول به، وبأخيك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نشد﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ونجعل﴾</span></span> عطف على سنشد، و<span class="hlt"><span class="qpc-hafs">﴿لكما﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>، وسلطانًا مفعول نجعل الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يصلون إليكما بآياتنا أنتما ومن اتبعكما الغالبون﴾</span></span>: الفاء عاطفة، ولا نافية، ويصلون فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليكما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بمحذوف، أي: اذهبا بآياتنا، أو بـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿يصلون﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿سلطانًا﴾</span></span>، أي: نسلطكما بآياتنا، أو بمحذوف حال، وأنتما مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول معطوف على أنتما، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعكما﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. والغالبون: خبر أنتما.</p></div>"
  28,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم موسى بآياتنا بينات قالوا ما هذا إلا سحر مفترى﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرفية حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم موسى﴾</span></span> فعل ومفعول وفاعل، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، أو بمحذوف حال، وبينات حال، وجملة قالوا جواب لما، وما نافية، وهذا مبتدأ، وإلا أداة حصر، وسحر خبر، ومفترى صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما سمعنا بهذا في آبائنا الأولين﴾</span></span>: الواو عاطفة، وما نافية، وسمعنا: فعل وفاعل، وبهذا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سمعنا﴾</span></span>، وفي آبائنا: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، والأولين: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿آبائنا﴾</span></span>.</p></div>"
  28,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى ربي أعلم بمن جاء بالهدى من عنده﴾</span></span>: ربي مبتدأ، وأعلم خبره، وبمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء بالهدى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من عنده﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن تكون له عاقبة الدار إنه لا يفلح الظالمون﴾</span></span>: الواو عاطفة، ومَن: عطف على مَن الأولى، وتكون: فعل مضارع ناقص، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عاقبة الدار﴾</span></span> اسمها المؤخر، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح الظالمون﴾</span></span> خبرها.</p></div>"
  28,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون يا أيها الملأ ما علمت لكم من إله غيري﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل ماض وفاعل مرفوع، ويا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة بني على الضم في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والملأ صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿علمت﴾</span></span> فعل وفاعل، ولكم: جار ومجرور متعلقان بمحذوف حال، ومن حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مجرور لفظًا بمن، منصوب محلًّا، لأنه مفعول به، وغيري صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين فاجعل لي صرحا﴾</span></span>: الفاء الفصيحة، وأوقد فعل أمر، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوقد﴾</span></span>، ويا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿هامان﴾</span></span> منادى مفرد علم، و<span class="hlt"><span class="qpc-hafs">﴿على الطين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوقد﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاجعل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أوقد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span>، وصرحًا: مفعول أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلي أطلع إلى إله موسى وإني لأظنه من الكاذبين﴾</span></span>: لعل حرف ناسخ للترجي، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أطلع﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى إله موسى﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أطلع﴾</span></span>، وإني الواو عاطفة، وإن حرف ناسخ، والياء اسمها، واللام المزحلقة، وجملة أظنه خبرها، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  28,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستكبر هو وجنوده في الأرض بغير الحق﴾</span></span>: الواو عاطفة، واستكبر فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> فاعل استكبر لأن استتار الضمير في الغائب جائز الظهور، أو توكيد للفاعل المستتر، وجنوده عطف على هو، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بغير الحق﴾</span></span> الجار والمجرور متعلقان بمحذوف حال من فاعل استكبر، أي: متلبسين بغير الحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿وظنوا أنهم إلينا لا يرجعون﴾</span></span>: الواو عاطفة، وظنوا عطف على استكبر، وأن وما يليها سدت مسد مفعولي ظنوا، وإلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، ولا نافية، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرجعون﴾</span></span> خبر أن.</p></div>"
  28,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذناه وجنوده فنبذناهم في اليم فانظر كيف كان عاقبة الظالمين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذناه﴾</span></span> فعل وفاعل ومفعول به، وجنوده: عطف على الهاء في أخذناه، أو مفعول معه، فنبذناهم: عطف على فأخذناه، وفي اليم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبذناهم﴾</span></span>، فانظر: الفاء الفصيحة، وانظر فعل أمر، وكيف خبر مقدم لكان، وعاقبة الظالمين: اسمها المؤخر، ومضاف إليه.</p></div>"
  28,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلناهم أئمة يدعون إلى النار ويوم القيامة لا ينصرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿جعلناهم﴾</span></span> فعل وفاعل ومفعول به أول، وأئمة مفعول به ثان، وجملة يدعون صفة لأئمة، و<span class="hlt"><span class="qpc-hafs">﴿إلى النار﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ويوم القيامة﴾</span></span>: الواو عاطفة، ويوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span>، ولا نافية، وينصرون فعل مضارع مبني لما لم يسمَّ فاعله، والواو ضمير مبني في محل رفع نائب فاعل.</p></div>"
  28,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة﴾</span></span>: الواو عاطفة، وأتبعناهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والدنيا بدل من <span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span>، ولعنة مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويوم القيامة هم من المقبوحين﴾</span></span>: الواو عاطفة، ويوم ظرف زمان منصوب متعلق بفعل محذوف يدل عليه السياق، وتقديره: قُبحوا، ويصح تعليقه باسم المفعول <span class="hlt"><span class="qpc-hafs">﴿المقبوحين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المقبوحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  28,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب من بعد ما أهلكنا القرون الأولى﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وآتينا: فعل وفاعل، وموسى: مفعول به أول، الكتاب: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى...﴾</span></span> مستأنفة لا محل لها من الإعراب، ومن بعد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتينا﴾</span></span>، وما مصدرية، وأهلكنا: فعل وفاعل، والقرون: مفعول به، والأولى: صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿بصائر للناس وهدى ورحمة لعلهم يتذكرون﴾</span></span>: بصائر: حال من الكتاب، على تقدير مضاف، أي: ذا بصائر، أو على المبالغة، أو مفعول لأجله، وللناس: جار ومجرور متعلقان بمحذوف نعت لبصائر، <span class="hlt"><span class="qpc-hafs">﴿وهدى ورحمة﴾</span></span> عطف على بصائر، ولعلهم يتذكرون: لعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يتذكرون خبرها.</p></div>"
  28,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت بجانب الغربي إذ قضينا إلى موسى الأمر وما كنت من الشاهدين﴾</span></span>: الواو عاطفة، أو استئنافية، وما نافية، وكنتَ: كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بجانب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، والغربي: مضاف إليه مجرور بالكسرة، وإذ: ظرف لما مضى متعلق بالخبر المحذوف الذي تعلق به الجار والمجرور، وقضينا: فعل وفاعل، وجملة قضينا مجرورة بإضافة الظرف إليها، والأمر: مفعول به، والواو: حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما كنت...﴾</span></span> معطوفة، مستأنفة لا محل لها من الإعراب، وما: نافية، وكنت: كان فعل ماض ناقص، والتاء اسمها، ومن الشاهدين: جار ومجرور متعلقان بمحذوف خبر كنت.</p></div>"
  28,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكنا أنشأنا قرونا فتطاول عليهم العمر﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أنشأنا خبرها، ونا فاعل، وقرونًا مفعول به، فتطاول عطف على أنشأنا، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطاول﴾</span></span>، والعمر فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت ثاويا في أهل مدين تتلو عليهم آياتنا ولكنا كنا مرسلين﴾</span></span>: الواو عاطفة، وما نافية، وكنت: كان فعل ماض ناقص، والتاء اسمها، وثاويًا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿في أهل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ثاويًا﴾</span></span>، ومدين: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتلو﴾</span></span> في موضع نصب خبر ثان لكنت، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿ثاويًا﴾</span></span>، ولكنا الواو حالية، أو عاطفة، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة كنا خبرها، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومرسلين خبرها.</p></div>"
  28,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت بجانب الطور إذ نادينا ولكن رحمة من ربك﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بجانب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كنت، والطور مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى متعلق بخبر <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> المحذوف الذي تعلق به الجار والمجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿نادينا﴾</span></span> في محل جر بإضافة الظرف إليها، <span class="hlt"><span class="qpc-hafs">﴿ولكن﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> حرف استدراك مهمل، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتنذر قوما ما أتاهم من نذير من قبلك لعلهم يتذكرون﴾</span></span>: لتنذر اللام للتعليل، وتنذر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلناك﴾</span></span> المحذوفة، وقومًا: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أتاهم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، وما نافية، وأتاهم فعل ماض، ومفعول به، ومن حرف جر صلة، ونذير مجرور لفظًا، مرفوع محلًّا على أنه فاعل، ومن قبلك: جار ومجرور متعلقان بمحذوف صفة لنذير، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يتذكرون خبرها.</p></div>"
  28,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا أن تصيبهم مصيبة بما قدمت أيديهم﴾</span></span>: الواو عاطفة، ولولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ خبره محذوف، وجوابها محذوف، تقديره: لما أرسلنا رسولًا، ومصيبة فاعل، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تصيبهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمت﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيقولوا ربنا لولا أرسلت إلينا رسولا فنتبع آياتك ونكون من المؤمنين﴾</span></span>: الفاء عاطفة، ويقولوا عطف على أن تصيبهم، وربنا منادى مضاف، ولولا تحضيضية بمعنى هلا، و<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span> فعل وفاعل، وإلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span>، ورسولًا مفعول به، فنتبع الفاء فاء السببية، ونتبع فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من أن والفعل معطوف على مصدر مأخوذ من الكلام السابق أي: هلا ثمة إرسال فاتباع الآيات. وفاعل نتبع مستتر، تقديره: نحن، وآياتك: مفعول به، ونكون: عطف على نتبع، واسم نكون ضمير مستتر، تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  28,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم الحق من عندنا قالوا لولا أوتي مثل ما أوتي موسى﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم الحق﴾</span></span>: فعل ماض، ومفعول به مقدم، وفاعل مؤخر، ومن عندنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب لما، ولولا حرف تحضيض، و<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> فعل ماض، ونائب الفاعل مستتر، تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> صلة الموصول لا محل لها من الإعراب. وموسى: نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم يكفروا بما أوتي موسى من قبل﴾</span></span>: الهمزة للاستفهام، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، ويكفروا: فعل مضارع مجزوم بلم، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي موسى﴾</span></span> صلة الموصول لا محل لها من الإعراب. ومن قبل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا سحران تظاهرا وقالوا إنا بكل كافرون﴾</span></span>: جملة استئنافية لا محل لها من الإعراب. وسحران: خبر لمبتدأ محذوف، أي: هما ساحران. والجملة من المبتدأ والخبر في محل نصب مقول القول. وجملة تظاهرا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سحران﴾</span></span>، وقالوا: الواو عاطفة، وقالوا: فعل ماض، والواو ضمير مبني في محل رفع فاعل، وإنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وبكل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وكافرون خبر إن، والجملة مقول القول.</p></div>"
  28,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل فأتوا بكتاب من عند الله هو أهدى منهما أتبعه إن كنتم صادقين﴾</span></span>: قل فعل أمر، وفاعله مستتر، تقديره: أنت، والفاء واقعة في جواب شرط مقدر، وفعل الأمر مبني على حذف النون، والواو في محل رفع فاعل، وبكتاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فأتوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عند﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، وأهدى: خبر، ومنهما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهدى﴾</span></span>، والجملة صفة ثانية لكتاب، و<span class="hlt"><span class="qpc-hafs">﴿أتبعه﴾</span></span>: فعل مضارع مجزوم، لأنه جواب الأمر، والفاعل مستتر، والهاء مفعول به، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، وصادقين خبرها، وجواب الشرط محذوف، دل عليه ما قبله، أي: فأتوا.</p></div>"
  28,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن لم يستجيبوا لك فاعلم أنما يتبعون أهواءهم﴾</span></span>: الفاء عاطفة، وإن شرطية، ولم حرف نفي وقلب وجزم، ويستجيبوا فعل مضارع مجزوم بلم، والواو فاعل، ولك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستجيبوا﴾</span></span>، والفاء رابطة لجواب الشرط، واعلم فعل أمر، وأنما كافة ومكفوفة، ويتبعون: فعل مضارع مرفوع، والواو في محل رفع فاعل، وأهواءهم مفعول به، وأنما وما في حيزها سدت مسد مفعولي اعلم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أضل ممن اتبع هواه بغير هدى من الله إن الله لا يهدي القوم الظالمين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام معناه النفي والإنكار في محل رفع مبتدأ، وأضل خبره، وممن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبع هواه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بغير هدى﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿هدى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله﴾</span></span> تعليل لما تقدم، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهدي القوم الظالمين﴾</span></span> خبرها.</p></div>"
  28,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد وصلنا لهم القول لعلهم يتذكرون﴾</span></span>: الواو استئنافية، أو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، ووصلنا فعل ماض، مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير متصل في محل رفع فاعل، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وصلنا﴾</span></span>، والقول: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد وصلنا...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو معطوفة، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتذكرون﴾</span></span> خبر لعل.</p></div>"
  28,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين آتيناهم الكتاب من قبله هم به يؤمنون﴾</span></span>: الذين اسم موصول مبتدأ، وجملة آتيناهم صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span>: فعل وفاعل ومفعول به أول، والكتاب مفعول به ثان، ومن قبله: جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وجملة يؤمنون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم به يؤمنون﴾</span></span> خبر الذين.</p></div>"
  28,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا يتلى عليهم قالوا آمنا به﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة يتلى في محل جر بإضافة الظرف إليها، ويتلى: فعل مضارع مبني لما لم يسمَّ فاعله، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلى﴾</span></span>، ونائب الفاعل مستتر تقديره هو، يعود على القرآن، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه الحق من ربنا إنا كنا من قبله مسلمين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والهاء اسمها، والحق خبر إن، ومن ربنا: جار ومجرور متعلقان بمحذوف حال. <span class="hlt"><span class="qpc-hafs">﴿إنا كنا ...﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبرها، ومن قبله: جار ومجرور متعلقان بمحذوف حال، ومسلمين خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  28,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك يؤتون أجرهم مرتين بما صبروا﴾</span></span>: أولئك مبتدأ، وجملة يؤتون خبر، ويؤتون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وأجرهم مفعول به ثان، ومرتين: نائب مفعول مطلق منصوب بالياء، وقد ناب عن المصدر لأنه عدده، و<span class="hlt"><span class="qpc-hafs">﴿بما صبروا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤتون﴾</span></span>، والباء حرف جر للسببية، وما مصدرية، أي: بسبب صبرهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويدرءون بالحسنة السيئة ومما رزقناهم ينفقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ويدرءون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يؤتون﴾</span></span>، والواو في <span class="hlt"><span class="qpc-hafs">﴿يدرءون﴾</span></span> في محل رفع فاعل، وبالحسنة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدرءون﴾</span></span>، والسيئة مفعول به، ومما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفقون﴾</span></span>، وجملة رزقناهم صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ينفقون﴾</span></span> عطف على يدرءون.</p></div>"
  28,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا سمعوا اللغو أعرضوا عنه وقالوا لنا أعمالنا ولكم أعمالكم﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة سمعوا مجرورة بإضافة الظرف إليها، واللغو مفعول به، وجملة أعرضوا لا محل لها من الإعراب، وعنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرضوا﴾</span></span>، وقالوا: عطف على أعرضوا، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، وأعمالنا: مبتدأ مؤخر. <span class="hlt"><span class="qpc-hafs">﴿ولكم أعمالكم﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلام عليكم لا نبتغي الجاهلين﴾</span></span>: سلام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا نبتغي الجاهلين﴾</span></span> حالية، ولا نافية، ونبتغي فعل مضارع والفاعل مستتر، تقديره: نحن، والجاهلين مفعول به.</p></div>"
  28,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك لا تهدي من أحببت ولكن الله يهدي من يشاء وهو أعلم بالمهتدين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تهدي﴾</span></span> خبرها، والفاعل مستتر، تقديره: أنت، ومَن مفعول به، وجملة أحببت صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ولكن الله﴾</span></span>: الواو عاطفة، أو حالية، ولكن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأعلم خبر، وبالمهتدين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>.</p></div>"
  28,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا إن نتبع الهدى معك نتخطف من أرضنا﴾</span></span>: الواو حرف عطف، وقالوا: فعل ماض، والواو في محل رفع فاعل، وإن شرطية، ونتبع فعل الشرط مجزوم، وفاعله مستتر، تقديره: نحن، والهدى مفعول به، ومعك ظرف متعلق بمحذوف حال، ونتخطف جواب الشرط، وهو فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، تقديره: نحن، ومن أرضنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتخطف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم نمكن لهم حرما آمنا يجبى إليه ثمرات كل شيء رزقا من لدنا ولكن أكثرهم لا يعلمون﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على محذوف يقتضيه السياق، ولم حرف نفي وقلب وجزم، ونمكن فعل مضارع مجزوم بلم، والفاعل مستتر، تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمكن﴾</span></span>، وحرمًا مفعول به، وآمنًا: صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجبى﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿حرمًا﴾</span></span>، وإليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجبى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ثمرات﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كل شيء﴾</span></span>: كل مضاف إليه، وشيء مضاف إليه أيضا، ورزقًا: نائب عن المفعول المطلق لقوله يجبى، لأن معنى الجباية والرزق بمعنى واحد، وقيل: مفعول لأجله، وقيل: حال من الثمرات لتخصصها بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، وأكثرهم اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبرها.</p></div>"
  28,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا من قرية بطرت معيشتها﴾</span></span>: الواو استئنافية، وكم خبرية مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قرية﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span> وهو تمييز كم الخبرية، وجملة <span class="hlt"><span class="qpc-hafs">﴿بطرت﴾</span></span> صفة لقرية، ومعيشتها: مفعول به على تضمين بطرت معنى فعل متعد، أي: كفرت معيشتها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتلك مساكنهم لم تسكن من بعدهم إلا قليلا وكنا نحن الوارثين﴾</span></span>: فتلك الفاء عاطفة، وتلك مبتدأ، ومساكنهم خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تسكن﴾</span></span> خبر ثان، أو حال، والعامل فيها معنى الإشارة، وإلا أداة حصر، وقليلًا ظرف، أي: إلا وقتًا قليلًا، فالاستثناء من الظرف، أو نائب عن المفعول المطلق، أي: لم تسكن من ضروب السكن إلا سكنًا قليلا، فالاستثناء من المصدر، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ونحن ضمير فصل، أو توكيد لاسم كان، والوارثين خبر كان.</p></div>"
  28,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان ربك مهلك القرى حتى يبعث في أمها رسولا يتلو عليهم آياتنا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان ربك﴾</span></span> كان فعل ماض ناقص، وربك اسمها، ومهلك خبرها، والقرى مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف تعليل وجر، ويبعث: فعل مضارع منصوب بأن مضمرة بعد حتى، والفاعل مستتر يعود على الله، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهلك﴾</span></span>، وفي أمها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبعث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتلو﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلو﴾</span></span>، وآياتنا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا مهلكي القرى إلا وأهلها ظالمون﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مهلكي﴾</span></span> خبرها، والقرى مضاف إليه، وإلا أداة حصر، والواو حالية، وأهلها مبتدأ، وظالمون خبر، والجملة حالية، والاستثناء مفرغ من أعم الأحوال أي: وما كنا مهلكين لأهل القرى بعد ما بعثنا في أمها رسولًا يدعوهم إلى الحق ويرشدهم إليه في حال من الأحوال إلا حال كونهم ظالمين بتكذيب رسولنا والكفر بآياتنا.</p></div>"
  28,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أوتيتم من شيء فمتاع الحياة الدنيا وزينتها﴾</span></span>: الواو عاطفة، أو استئنافية، والجملة بعدها معطوفة، أو مستأنفة لا محل لها من الإعراب، وما اسم شرط جازم في محل رفع مبتدأ، وأوتيتم: فعل ماض مبني لما لم يسمَّ فاعله، وهو في محل جزم فعل الشرط، والتاء نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span> جار ومجرور متعلقان بمحذوف  حال مبينة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والفاء رابطة للجواب، ومتاع خبر لمبتدأ محذوف، والحياة مضاف إليه، والدنيا صفة، وزينتها: عطف على متاع، والجملة في محل جزم جواب الشرط، والفعل والجواب خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما عند الله خير وأبقى أفلا تعقلون﴾</span></span>: الواو حالية، وما اسم موصول مبتدأ، وعند: ظرف متعلق بمحذوف صلة وجملة الصلة لا محل لها من الإعراب. ولفظ الجلالة مضاف إليه، وخير خبر، وأبقى عطف على خير، والهمزة للاستفهام، والفاء عاطفة على محذوف يقتضيه السياق، ولا نافية، وتعقلون فعل مضارع مرفوع، والواو في محل رفع فاعل.</p></div>"
  28,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفمن وعدناه وعدا حسنا فهو لاقيه كمن متعناه متاع الحياة الدنيا ثم هو يوم القيامة من المحضرين﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعدناه﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿وعدناه﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿وعدًا﴾</span></span> مفعول مطلق، وحسنًا صفة، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ولاقيه: خبر، <span class="hlt"><span class="qpc-hafs">﴿كمن﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿متعناه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span> نائب عن المفعول المطلق، لأنه اسم مصدر، و<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span> صفة للحياة، وثم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> الظرف متعلق بالمحضرين، والقيامة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من المحضرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>.</p></div>"
  28,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول أين شركائي الذين كنتم تزعمون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يناديهم﴾</span></span> في محل جر مضاف إليه، والفاعل مستتر، والهاء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: عطف على يناديهم. و<span class="hlt"><span class="qpc-hafs">﴿أين﴾</span></span> اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بمحذوف خبر مقدم، وشركائي مبتدأ مؤخر، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الذين لا محل لها من الإعراب. وكان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تزعمون﴾</span></span> خبرها، ومفعولا تزعمون محذوفان، تقديرهما: <span class="hlt"><span class="qpc-hafs">﴿تزعمونهم شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أين شركائي﴾</span></span> مقول القول.</p></div>"
  28,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين حق عليهم القول ربنا هؤلاء الذين أغوينا أغويناهم كما غوينا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿حق عليهم ...﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> فاعل، وربنا: منادى مضاف محذوف منه حرف النداء، وهؤلاء: مبتدأ، والذين: اسم موصول في محل رفع خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أغوينا﴾</span></span> فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغوينا﴾</span></span> صلة الموصول لا محل لها من الإعراب والعائد محذوف، أي: هؤلاء الذين أغويناهم. و<span class="hlt"><span class="qpc-hafs">﴿أغويناهم﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر محذوف ذلك المصدر لمطاوع الفعل المذكور، وتقدير الكلام: أغويناهم فغَوَوا غَيًّا مثلَ غَيِّنا، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿غوينا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿غوينا﴾</span></span> صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية وما دخلت عليه مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغويناهم كما غوينا﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبرأنا إليك ما كانوا إيانا يعبدون﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿تبرأنا﴾</span></span> فعل ماض، وفاعل، وإليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبرأنا﴾</span></span>، وما نافية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وإيانا: مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span> خبر كانوا.</p></div>"
  28,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل ادعوا شركاءكم فدعوهم فلم يستجيبوا لهم﴾</span></span>: الواو عاطفة، وقيل فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، تقديره: هذا القول، وادعوا فعل أمر، وفاعله، وشركاءكم: مفعول به، فدعوهم: الفاء عاطفة، ودعوهم فعل ماض وفاعل ومفعول به، والفاء عاطفة، ويستجيبوا: فعل مضارع مجزوم بلم، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستجيبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورأوا العذاب لو أنهم كانوا يهتدون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿رأوا العذاب﴾</span></span> فعل ماض، وفاعل، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وأن وما بعدها فاعل لفعل محذوف، أي: لو ثبت كونهم مهتدين في الدنيا لما رأوا العذاب في الآخرة. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة كانوا خبرها، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يهتدون خبرها.</p></div>"
  28,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول ماذا أجبتم المرسلين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول أين شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يناديهم﴾</span></span> في محل جر مضاف إليه، والفاعل مستتر، والهاء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: عطف على يناديهم، وماذا اسم استفهام في محل نصب على نزع الخافض، وأجبتم فعل ماض، والتاء في محل رفع فاعل، والمرسلين مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أجبتم﴾</span></span>.</p></div>"
  28,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعميت عليهم الأنباء يومئذ فهم لا يتساءلون﴾</span></span>: الفاء عاطفة، وعميت فعل ماض، والأنباء فاعل، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عميت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عميت﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ يناديهم فيقول ماذا أجبتم المرسلين. <span class="hlt"><span class="qpc-hafs">﴿فهم﴾</span></span>: الفاء عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يتساءلون﴾</span></span>: خبر.</p></div>"
  28,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما من تاب وآمن وعمل صالحا فعسى أن يكون من المفلحين﴾</span></span>: الفاء استئنافية، وأما: حرف شرط وتفصيل، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تاب﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>: فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿صالحًا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. والفاء رابطة، وعسى فعل ماض جامد من أفعال الرجاء، واسمها مستتر، تقديره: هو، وأن وما في حيزها خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من المفلحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر يكون، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأما من تاب...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  28,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربك يخلق ما يشاء ويختار ما كان لهم الخيرة سبحان الله وتعالى عما يشركون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخلق﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ويختار﴾</span></span> عطف على يخلق، وجملة <span class="hlt"><span class="qpc-hafs">﴿وربك يخلق...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿الخيرة﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، ولفظ الجلالة مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وتعالى﴾</span></span>: الواو عاطفة، وتعالى فعل ماض، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  28,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربك يعلم ما تكن صدورهم وما يعلنون﴾</span></span>: الواو عاطفة، ورب مبتدأ، والكاف مضاف إليه، وجملة يعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تُكِنُّ﴾</span></span> صلة الموصول لا محل لها من الإعراب. وصدورهم فاعل، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الأولى، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلنون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  28,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والله خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿له الحمد في الأولى والآخرة وله الحكم وإليه ترجعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والحمد مبتدأ مؤخر، والجملة خبر ثالث، و<span class="hlt"><span class="qpc-hafs">﴿في الأولى﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span> عطف على الأولى، <span class="hlt"><span class="qpc-hafs">﴿وله الحكم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿له الحمد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون فعل مضارع مبني لما لم يسمَّ فاعله مرفوع، والواو نائب فاعل.</p></div>"
  28,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم إن جعل الله عليكم الليل سرمدا إلى يوم القيامة﴾</span></span>: قل فعل أمر، والفاعل مستتر، والهمزة للاستفهام، ورأيتم فعل وفاعل، والمفعول الأول لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> ضمير مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span>، وقد تنازع الفعلان <span class="hlt"><span class="qpc-hafs">﴿رأيتم﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span>، وأعمل <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> لقربه منه، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿جعل الله عليكم﴾</span></span> فعل ماض في محل جزم فعل الشرط، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مفعول جعل الأول، و<span class="hlt"><span class="qpc-hafs">﴿سرمدًا﴾</span></span> مفعوله الثاني، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سرمدًا﴾</span></span>، والقيامة مضاف إليه، وجواب الشرط محذوف يدل عليه ما قبله.</p><p><span class="hlt"><span class="qpc-hafs">﴿من إله غير الله يأتيكم بضياء أفلا تسمعون﴾</span></span>: الجملة الاستفهامية في محل نصب مفعول أرأيتم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> خبر، وغير: صفة إله، ولفظ الجلالة: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتيكم﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بضياء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيكم﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف مقدر، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿تسمعون﴾</span></span> فعل مضارع، والواو فاعل.</p></div>"
  28,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم إن جعل الله عليكم النهار سرمدا إلى يوم القيامة﴾</span></span>: قل فعل أمر، والفاعل مستتر، والهمزة للاستفهام، ورأيتم فعل وفاعل، والمفعول الأول لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> ضمير مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span>، وقد تنازع الفعلان <span class="hlt"><span class="qpc-hafs">﴿رأيتم﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span>، وأعمل <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> لقربه منه، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿جعل الله عليكم﴾</span></span> فعل ماض في محل جزم فعل الشرط، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span> مفعول جعل الأول، و<span class="hlt"><span class="qpc-hafs">﴿سرمدًا﴾</span></span> مفعوله الثاني، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سرمدًا﴾</span></span>، والقيامة: مضاف إليه، وجواب الشرط محذوف يدل عليه ما قبله.</p><p><span class="hlt"><span class="qpc-hafs">﴿من إله غير الله يأتيكم بليل تسكنون فيه أفلا تبصرون﴾</span></span>: الجملة الاستفهامية في محل نصب مفعول <span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> خبر، وغير: صفة إله، ولفظ الجلالة: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتيكم﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بليل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تسكنون﴾</span></span>: فعل مضارع والواو في محل رفع فاعل، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسكنون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تسكنون﴾</span></span> صفة لليل، <span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف مقدر، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span> فعل مضارع، والواو فاعل.</p></div>"
  28,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا فيه ولتبتغوا من فضله ولعلكم تشكرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من رحمته﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿جعل لكم﴾</span></span> مؤول بمصدر بتقدير <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مبتدأ مؤخر، وجعل فعل ماض، وفاعله مستتر، تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعل الثاني، والليل مفعول جعل الأول، والنهار عطف على الليل، ولتسكنوا اللام للتعليل، وتسكنوا فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والواو فاعل، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسكنوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لتبتغوا من فضله﴾</span></span> عطف على لتسكنوا. <span class="hlt"><span class="qpc-hafs">﴿ولعلكم﴾</span></span>: الواو عاطفة، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تشكرون﴾</span></span> خبرها.</p></div>"
  28,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول أين شركائي الذين كنتم تزعمون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يناديهم﴾</span></span> في محل جر مضاف إليه، والفاعل مستتر، والهاء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: عطف على يناديهم. و<span class="hlt"><span class="qpc-hafs">﴿أين﴾</span></span> اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بمحذوف خبر مقدم، وشركائي مبتدأ مؤخر، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: صلة الذين لا محل لها من الإعراب. وكان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تزعمون﴾</span></span> خبرها، ومفعولا تزعمون محذوفان، تقديرهما: <span class="hlt"><span class="qpc-hafs">﴿تزعمونهم شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أين شركائي﴾</span></span> مقول القول.</p></div>"
  28,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونزعنا من كل أمة شهيدا فقلنا هاتوا برهانكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نزعنا﴾</span></span>: فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من كل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزعنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أمة﴾</span></span> مضاف إليه، وشهيدًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فقلنا﴾</span></span> عطف على نزعنا، وجملة هاتوا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿هاتوا﴾</span></span> فعل أمر، والواو في محل رفع فاعل، وبرهانكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فعلموا أن الحق لله وضل عنهم ما كانوا يفترون﴾</span></span>: الفاء عاطفة، وعلموا فعل ماض، والواو في محل رفع فاعل، وأن وما في حيزها سدت مسد مفعولي علموا، وأن حرف ناسخ، والحق اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن، وضل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span> خبرها.</p></div>"
  28,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن قارون كان من قوم موسى﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، وقارون اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر إن، واسم كان مستتر، يعود على قارون، و<span class="hlt"><span class="qpc-hafs">﴿من قوم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فبغى عليهم وآتيناه من الكنوز ما إن مفاتحه لتنوء بالعصبة أولي القوة﴾</span></span>: الفاء عاطفة، وبغى فعل ماض، وفاعله مستتر، يعود على قارون، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بغى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آتيناه﴾</span></span> فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الكنوز﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتيناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿آتيناه﴾</span></span>، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿مفاتحه﴾</span></span> اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿لتنوء﴾</span></span> اللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تنوء﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: هي، والجملة خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن مفاتحه لتنوء بالعصبة﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بالعصبة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنوء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أولي﴾</span></span> صفة للعصبة، و<span class="hlt"><span class="qpc-hafs">﴿القوة﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال له قومه لا تفرح إن الله لا يحب الفرحين﴾</span></span>: الظرف متعلق بمحذوف تقديره: فأظهر التفاخر والفرح بما أوتي من الكنوز، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وقومه: فاعل، والهاء: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تفرح﴾</span></span>: مقول القول، ولا ناهية، وتفرح فعل مضارع مجزوم بلا، وفاعل تفرح مستتر، تقديره: أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله ...﴾</span></span> تعليل للنهي، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يحب الفرحين﴾</span></span> خبرها.</p></div>"
  28,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وابتغ فيما آتاك الله الدار الآخرة ولا تنس نصيبك من الدنيا﴾</span></span>: الواو عاطفة، وابتغ فعل أمر مبني على حذف حرف العلة، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أو موصولة، والجار والمجرور متعلقان بمحذوف حال، أي: متقلبًا فيما آتاك، ومعنى <span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> هنا السببية، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتاك الله﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آتاك الله﴾</span></span>: فعل ماض، ومفعول به مقدم، ولفظ الجلالة فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿الدار﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿ابتغ﴾</span></span>، والآخرة صفة للدار، و<span class="hlt"><span class="qpc-hafs">﴿لا تنس﴾</span></span> لا ناهية، وتنس فعل مضارع مجزوم بلا، وفاعله مستتر، تقديره: أنت، ونصيبك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف على أنه حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأحسن كما أحسن الله إليك ولا تبغ الفساد في الأرض إن الله لا يحب المفسدين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> فعل أمر، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمفعول مطلق محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، والتقدير: أحسنْ إحسانًا مثل إحسان الله إليك، و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> فعل ماض، ولفظ الجلالة فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا تبغ الفساد﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الفساد﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿تبغ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله ...﴾</span></span> تعليل للنهي المتقدم، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يحب المفسدين خبرها.</p></div>"
  28,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إنما أوتيته على علم عندي﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب، وإنما: كافة ومكفوفة، وأوتيته: فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، والهاء مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿على علم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من نائب الفاعل في أوتيته، وعندي: ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، أي: إنما أوتيته حال كوني متصفًا بالعلم الذي عندي. والياء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم يعلم أن الله قد أهلك من قبله من القرون من هو أشد منه قوة وأكثر جمعا﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على مقدر دخلت عليه الهمزة، ولم حرف نفي وقلب وجزم، ويعلم فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وفاعله ضمير مستتر، وأن وما في حيزها سدت مسد مفعولي يعلم، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد أهلك﴾</span></span> خبرها، وفاعل أهلك ضمير مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من قبله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من القرون﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿مَن هو أشد﴾</span></span> مقدمة عليه، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أهلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأشد خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو أشد﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿قوة﴾</span></span> تمييز، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وأكثر جمعًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أشد منه قوة﴾</span></span> .</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يسأل عن ذنوبهم المجرمون﴾</span></span>: الواو عاطفة، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يسأل﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عن ذنوبهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسأل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المجرمون﴾</span></span> نائب فاعل.</p></div>"
  28,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخرج على قومه في زينته﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿على قومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خرج﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في زينته﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين يريدون الحياة الدنيا يا ليت لنا مثل ما أوتي قارون إنه لذو حظ عظيم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والحياة: مفعول به، والدنيا: صفة للحياة، ويا: حرف نداء، والمنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span> حرف ناسخ للتمني، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ليت، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، وقارون نائب فاعل، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذو﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿حظ﴾</span></span> مضاف إليه، وعظيم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حظ﴾</span></span>.</p></div>"
  28,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين أوتوا العلم ويلكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتوا العلم﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ويلكم﴾</span></span> مفعول لفعل محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثواب الله خير لمن آمن وعمل صالحا ولا يلقاها إلا الصابرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثواب﴾</span></span> مبتدأ، ولفظ الجلالة مضاف إليه، وخير خبر، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وعمل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿صالحا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. والواو عاطفة، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يلقاها﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الصابرون﴾</span></span> نائب فاعل مؤخر، وهو المفعول الأول.</p></div>"
  28,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخسفنا به وبداره الأرض﴾</span></span>: الفاء هي الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿خسفنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خسفنا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وبداره﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما كان له من فئة ينصرونه من دون الله وما كان من المنتصرين﴾</span></span>: الفاء عاطفة، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿فئة﴾</span></span> مجرور لفظًا بمن، مرفوع محلًّا على أنه اسم كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرونه﴾</span></span> صفة لفئة، و<span class="hlt"><span class="qpc-hafs">﴿من دون﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فئة، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، واسمها مستتر، تقديره هو، يعود على قارون، و<span class="hlt"><span class="qpc-hafs">﴿من المنتصرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  28,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأصبح الذين تمنوا مكانه بالأمس يقولون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أصبح﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿مكانه﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالأمس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمنوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> خبر أصبح، أو أصبح تامة، والذين فاعل، وجملة يقولون في محل نصب على أنها حال، أي: قائلين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويكأن الله يبسط الرزق لمن يشاء من عباده ويقدر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وي﴾</span></span> اسم فعل مضارع معناه: أتعجب، وكأن حرف مشبه بالفعل من أخوات إن، وهو هنا للخبر واليقين، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبسط الرزق﴾</span></span> خبر كأن، والرزق: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبسط﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من عباده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿ويقدر﴾</span></span> عطف على يبسط.</p><p><span class="hlt"><span class="qpc-hafs">﴿لولا أن من الله علينا لخسف بنا﴾</span></span>: لولا حرف امتناع لوجود، متضمن معنى الشرط، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها مرفوع بالابتداء، والخبر محذوف وجوبًا، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، واللام واقعة في جواب لولا، وجملة <span class="hlt"><span class="qpc-hafs">﴿خسف بنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومفعول <span class="hlt"><span class="qpc-hafs">﴿خسف﴾</span></span> محذوف، أي: الأرض.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويكأنه لا يفلح الكافرون﴾</span></span>: وي اسم فعل مضارع معناه: أتعجب، وكأن حرف مشبه بالفعل من أخوات إن، وهو هنا للخبر واليقين، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿الكافرون﴾</span></span> فاعل يفلح.</p></div>"
  28,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك الدار الآخرة نجعلها للذين لا يريدون علوا في الأرض ولا فسادا والعاقبة للمتقين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿تلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الدار﴾</span></span> بدل من اسم الإشارة، و<span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span> صفة للدار، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجعلها﴾</span></span> خبر تلك، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجعلها﴾</span></span>، على أنه مفعوله الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يريدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿علوًّا﴾</span></span> مفعول يريدون، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علوًّا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا فسادًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿علوًّا﴾</span></span>، والعاقبة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  28,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من جاء بالحسنة فله خير منها﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، وجاء فعل ماض في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿بالحسنة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، والفاء رابطة لجواب الشرط، لأنه جملة اسمية، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، والجملة في محل جزم جواب الشرط، والفعل والجواب معًا خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن جاء بالسيئة فلا يجزى الذين عملوا السيئات إلا ما كانوا يعملون﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿يجزى﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا السيئات﴾</span></span> صلة الموصول لا محل لها من الإعراب. وإلا أداة حصر، وما مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يجزى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span> خبر كانوا.</p></div>"
  28,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذي فرض عليك القرآن لرادك إلى معاد﴾</span></span>: إن حرف ناسخ، والذي اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿فرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿رادك﴾</span></span> خبر إن، والكاف في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿إلى معاد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل ربي أعلم من جاء بالهدى ومن هو في ضلال مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مبتدأ، والياء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بالهدى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> الأولى، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفته.</p></div>"
  28,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت ترجو أن يلقى إليك الكتاب إلا رحمة من ربك﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span>: كان فعل ماض ناسخ، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترجو﴾</span></span> خبرها، وأن وما في حيزها مفعول ترجو، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر بمعنى لكن للاستدراك، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لرحمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تكونن ظهيرا للكافرين﴾</span></span>: الفاء الفصيحة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تكونن﴾</span></span> فعل مضارع ناقص مبني على الفتح في محل جزم، واسمه ضمير مستتر، والنون نون التوكيد الثقيلة، و<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span> خبر تكونن، و<span class="hlt"><span class="qpc-hafs">﴿للكافرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span>.</p></div>"
  28,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يصدنك عن آيات الله بعد إذ أنزلت إليك﴾</span></span>: عطف على ما تقدم، ولا ناهية، ويصدنك فعل مضارع مجزوم بلا الناهية، وعلامة جزمه حذف النون، وحذفت الواو، لالتقاء الساكنين، وبقيت الضمة دليلًا عليها، وأصله: يصدونّك، و<span class="hlt"><span class="qpc-hafs">﴿عن آيات الله﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصدنك﴾</span></span>، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يصدنك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل جر مضاف إليه، أي: بعد وقتِ إنزالها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلت﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وادع إلى ربك ولا تكونن من المشركين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ادع﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادع﴾</span></span>، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تكونن﴾</span></span> فعل مضارع ناقص مبني على الفتح في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، واسمها مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من المشركين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  28,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تدع مع الله إلها آخر﴾</span></span>: الواو عاطفة، ولا ناهية، وتدع فعل مضارع مجزوم بلا، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تدع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span> مفعول به، وآخر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. جملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> في محل نصب حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿كل شيء هالك إلا وجهه له الحكم وإليه ترجعون﴾</span></span>: كل مبتدأ، وشيء مضاف إليه، وهالك خبر المبتدأ، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿وجهه﴾</span></span> مستثنى، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والحكم مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب الفاعل.</p></div>"
