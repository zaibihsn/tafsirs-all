quran[62]{c,v,t}:
  53,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنجم إذا هوى﴾</span></span>: الواو واو القسم، والنجم مقسم به مجرور بالكسرة، والجار والمجرور متعلقان بفعل محذوف تقديره أقسم، وإذا ظرف للزمان المستقبل مجرد من معنى الشرط في محل نصب متعلق بالفعل المقدر، أي أقسم بالنجم وقت هويه، فالظرف مستعار للحال، وجملة القسم لا محل لها من الإعراب، لأنها ابتدائية، وهوى فعل ماض والفاعل مستتر تقديره هو، والجملة في محل جر مضاف إليه.</p></div>"
  53,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما ضل صاحبكم وما غوى﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها جواب القسم، وضل صاحبكم فعل وفاعل، وما غوى عطف على ما ضل.</p></div>"
  53,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ينطق عن الهوى﴾</span></span>: الواو عاطفة، وما نافية، وينطق فعل مضارع، وفاعله هو، وعن الهوى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينطق﴾</span></span>، فعن للمجاوزة على بابها، وقيل: إنها بمعنى الباء، والجار والمجرور متعلقان بمحذوف حال.</p></div>"
  53,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا وحي يوحى﴾</span></span>: إن نافية، وهو مبتدأ، وإلا أداة حصر، ووحي خبر هو، وجملة يوحى صفة لوحي.</p></div>"
  53,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿علمه شديد القوى﴾</span></span>: الجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿وحي﴾</span></span>، وعلمه فعل ومفعول به، وشديد القوى فاعل علمه.</p></div>"
  53,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذو مرة فاستوى﴾</span></span>: ذو مرة صفة لشديد القوى، والفاء عاطفة، واستوى فعل وفاعل مقدر.</p></div>"
  53,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو بالأفق الأعلى﴾</span></span>: الواو حالية، وهو مبتدأ، وبالأفق خبر، والأعلى صفة للأفق، والجملة في موضع الحال.</p></div>"
  53,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم دنا فتدلى﴾</span></span>: ثم حرف عطف للتراخي، ودنا فعل، وفاعله مقدر تقديره هو. فتدلى عطف على دنا.</p></div>"
  53,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكان قاب قوسين أو أدنى﴾</span></span>: الفاء عاطفة، وكان فعل ماض ناقص، واسمها المستتر، وقاب قوسين خبرها، وأو حرف عطف، أو للإجابة، وأدنى عطف على قاب.</p></div>"
  53,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوحى﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span> فعل ماض، والفاعل مستتر تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> يعود على الله تعالى، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحى إلى عبده ما أوحى﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى عبده﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة في محل نصب مفعول به، أو: مصدرية، وهي مع مدخولها في تأويل مصدر منصوب على أنه مفعول به، أو مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>: فعل ماض، والفاعل مستتر تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> يعود على جبريل عليه السلام، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  53,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما كذب الفؤاد ما رأى﴾</span></span>: ما نافية، وكذب الفؤاد فعل وفاعل، وما موصولة مفعول به، لأن كذب فعل يتعدى إلى مفعول، وقيل: لا يتعدى، فيكون نصب ما على إسقاط الخافض، أي: فيما رآه، وقيل: إن كذب قد يتعدى إلى اثنين. أو ما مصدرية، وهي مع مدخولها في موضع نصب، لأنه مفعول كذب.</p></div>"
  53,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفتمارونه﴾</span></span>: الهمزة للاستفهام الإنكاري، وتمارونه: فعل وفاعل ومفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿تمارونه﴾</span></span> معطوفة على جملة استئنافية مقدرة أي: أتنكرون قوله فتمارونه.</p><p><span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>: حرف جر مبني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مجرور، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمارونه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span>: فعل مضارع والفاعل مستتر. وجملة <span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، تؤول مع ما بعدها بمصدر مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمارونه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب.</p></div>"
  53,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span>: الواو للحال، واللام جواب للقسم المحذوف، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>: فعل ماض، والفاعل مستتر، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿نزلة﴾</span></span>: ظرف زمان، أي: مرة أخرى، لأن مصدر النزلة بمثابة المرة منها، أو: حال نصبت نصب المصدر الواقع موقع الحال، أي: رآه نازلا نزلة أخرى، أو نائب عن المفعول المطلق، لأنه صفة المصدر أي: رؤية نزلة أخرى.</p><p><span class="hlt"><span class="qpc-hafs">﴿أخرى﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿نزلة﴾</span></span> منصوب بالفتحة المقدرة على الألف.</p></div>"
  53,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عند سدرة المنتهى﴾</span></span>: الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>، أو حال من الفاعل، أو المفعول، أو منهما معًا، وسدرة مضاف إليه، والمنتهى مضاف إليه.</p></div>"
  53,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عندها جنة المأوى﴾</span></span>: الظرف متعلق بمحذوف خبر مقدم، وجنة المأوى مبتدأ مؤخر، والجملة حال من سدرة المنتهى.</p></div>"
  53,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ يغشى السدرة ما يغشى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغشى السدرة﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿السدرة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغشى﴾</span></span> الثانية صلة الموصول لا محل لها من الإعراب.</p></div>"
  53,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما زاغ البصر وما طغى﴾</span></span>: ما نافية، وزاغ البصر فعل ماض وفاعل، وما طغى عطف على ما زاغ.</p></div>"
  53,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد رأى من آيات ربه الكبرى﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، ورأى فعل ماضٍ، وفاعله مستتر، ومن آيات ربه حال مقدمة على المفعول، والكبرى مفعول رأى، أو <span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿آيات ربه﴾</span></span>، ويكون المرئي محذوفًا.</p></div>"
  53,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيتم اللات والعزى﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء حرف عطف لترتيب الرؤية، ورأيتم فعل وفاعل واللات مفعوله، والعزى معطوف على اللات.</p></div>"
  53,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومناة الثالثة الأخرى﴾</span></span>: مناة معطوف على اللات، والثالثة الأخرى صفتان، الأولى صفة للتين قبلها، والثانية صفة ذم للثالثة. والمفعول الثاني محذوف تقديره: كيف هي عاجزة؟ والجملة لا محل لها من الإعراب عطفًا على استئناف مقدر، أي: أعرفتم عظمة الله وقدرته فرأيتم اللات .. كيف هي عاجزة؟</p></div>"
  53,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألكم الذكر وله الأنثى﴾</span></span>: الهمزة للاستفهام الإنكاري أيضًا، ولكم خبر مقدم، والذكر مبتدأ مؤخر، وله الأنثى معطوفة لا محل لها من الإعراب.</p></div>"
  53,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك إذا قسمة ضيزى﴾</span></span>: تلك اسم إشارة مبتدأ، وإذًا بمعنى الجواب والجزاء، وقسمة خبر، وضيزى صفة لقسمة، والجملة استئناف بياني لا محل لها من الإعراب.</p></div>"
  53,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هي إلا أسماء سميتموها أنتم وآباؤكم ما أنزل الله بها من سلطان﴾</span></span>: إن نافية، وهي مبتدأ، وإلا أداة حصر، وأسماء خبر هي، وسميتموها فعل وفاعل ومفعول به ثانٍ، والأول محذوف تقديره: أصنامًا، وأنتم تأكيد للفاعل ليصح عطف <span class="hlt"><span class="qpc-hafs">﴿وآباؤكم﴾</span></span> عليه، وجملة سميتموها صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أسماء﴾</span></span>، وكذلك جملة ما أنزل، وما نافية، وأنزل الله فعل وفاعل، وبها حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>، ومن حرف جر صلة، وسلطان مجرور لفظًا منصوب محلا على أنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يتبعون إلا الظن وما تهوى الأنفس﴾</span></span>: إن نافية، ويتبعون فعل مضارع مرفوع بثبوت النون، والواو فاعل، وإلا أداة حصر، والظن مفعول يتبعون، والواو حرف عطف، وما موصول معطوف على الظن، ولك أن تجعلها مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم من ربهم الهدى﴾</span></span>: الواو حالية، أو اعتراضية، واللام: جواب للقسم المحذوف، وقد: حرف تحقيق. وجاءهم: فعل ماضٍ، ومفعول به مقدم. ومن ربهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>. والهدى: فاعل جاءهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم...﴾</span></span>: إما حالية من فاعل يتبعون، أو اعتراضية لا محل لها من الإعراب، لأن قوله: <span class="hlt"><span class="qpc-hafs">﴿أم للإنسان...﴾</span></span> متصل بقوله: <span class="hlt"><span class="qpc-hafs">﴿وما تهوى الأنفس﴾</span></span>.</p></div>"
  53,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم للإنسان ما تمنى﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿للإنسان﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمنى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  53,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلله الآخرة والأولى﴾</span></span>: الفاء عاطفة على مقدر مفهوم من معنى أم، أي: ليس الأمر كذلك، ولله خبر مقدم، والآخرة مبتدأ مؤخر، والأولى عطف على الآخرة.</p></div>"
  53,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم﴾</span></span>: الواو عاطفة، وكم خبرية في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ملك﴾</span></span>: في محل نصب تمييز كم الخبرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لملك.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: لا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>: فعل مضارع.</p><p><span class="hlt"><span class="qpc-hafs">﴿شفاعتهم﴾</span></span>: فاعل مرفوع، والضمير مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تغني شفاعتهم﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span>: مفعول تغني، أو نائب عن المفعول المطلق، أي شيئًا من الإغناء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن يأذن الله﴾</span></span>: أن وما في حيزها في تأويل مصدر مجرور بالإضافة لبعد، والله: لفظ الجلالة فاعل <span class="hlt"><span class="qpc-hafs">﴿يأذن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span>: اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مبني في محل جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span>: فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويرضى﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يرضى﴾</span></span> فعل مضارع، والفاعل مستتر.</p></div>"
  53,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين لا يؤمنون بالآخرة﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> صلة الموصول لا محل لها من الإعراب. وبالآخرة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليسمون الملائكة﴾</span></span>: اللام المزحلقة، ويسمون الملائكة فعل مضارع وفاعل ومفعول به، والجملة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿تسمية﴾</span></span>: مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأنثى﴾</span></span>: مضاف إليه.</p></div>"
  53,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما لهم به من علم﴾</span></span>: الواو حالية، وما نافية، ولهم خبر مقدم، ومن حرف جر صلة، وعلم مبتدأ مؤخر، والجملة في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يتبعون إلا الظن﴾</span></span>: إن نافية، ويتبعون فعل مضارع مرفوع بثبوت النون والواو فاعل، وإلا أداة حصر، والظن مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الظن لا يغني من الحق شيئا﴾</span></span>: الواو للحال، وإن حرف ناسخ، والظن اسمها، وجملة لا يغني خبرها، ومن الحق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span>، وشيئًا مفعول به، أو نائب عن المفعول المطلق.</p></div>"
  53,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأعرض عن من تولى عن ذكرنا﴾</span></span>: الفاء الفصيحة، وأعرض فعل أمر، وعمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تولى عن ذكرنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. وعن ذكرنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تولى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم يرد إلا الحياة الدنيا﴾</span></span>: الواو عاطفة، ولم حرف نفي وقلب وجزم، ويرد فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وإلا أداة حصر، والحياة مفعول به، والدنيا صفة.</p></div>"
  53,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك مبلغهم من العلم﴾</span></span>: ذلك: اسم إشارة مبتدأ. مبلغهم: خبر. ومن العلم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مبلغهم﴾</span></span>. والجملة اعتراضية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك هو أعلم بمن ضل عن سبيله وهو أعلم بمن اهتدى﴾</span></span>: إن حرف ناسخ، ورب اسمها، والكاف مضاف إليه، وهو مبتدأ، وأعلم خبر، وبمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ضل عن سبيله﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة هو أعلم خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو أعلم بمن اهتدى﴾</span></span> عطف على الجملة السابقة.</p></div>"
  53,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولله ما في السماوات وما في الأرض﴾</span></span>: الواو استئنافية، ولله اللام حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بمحذوف خبر مقدم، وما مبتدأ مؤخر، وفي السماوات: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ما في الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما في السماوات﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولله ما...﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  53,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يجتنبون كبائر الإثم والفواحش إلا اللمم﴾</span></span>: الذين في موضع نصب على أنه بدل من الذين، أو هو في موضع رفع على أنه خبر مبتدأ مضمر، أي: هم الذين يجتنبون، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجتنبون﴾</span></span> صلة الذين لا محل لها من الإعراب. وكبائر: مفعول يجتنبون. والإثم: مضاف إليه. والفواحش: عطف على <span class="hlt"><span class="qpc-hafs">﴿كبائر﴾</span></span>. وإلا: أداة استثناء، واللمم: مستثنى بإلا، وهو استثناء منقطع، وقيل: إنه استثناء متصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك واسع المغفرة﴾</span></span>: إن حرف ناسخ، ورب اسمها، والكاف مضاف إليه، وواسع المغفرة خبرها، والجملة تعليلية لاستثناء اللمم لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو أعلم بكم إذ أنشأكم من الأرض وإذ أنتم أجنة في بطون أمهاتكم﴾</span></span>: هو مبتدأ، وأعلم خبر، وبكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنشأكم﴾</span></span> في محل جر بإضافة الظرف إليها، ومن الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأكم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وإذ﴾</span></span> عطف على إذ الأولى، وأنتم مبتدأ، وأجنة خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنتم أجنة﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿في بطون أمهاتكم﴾</span></span> صفة لأجنة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تزكوا أنفسكم هو أعلم بمن اتقى﴾</span></span>: الفاء الفصيحة، ولا ناهية، وتزكوا فعل مضارع مجزوم بلا الناهية، وعلامة جزمه حذف النون، والواو فاعل، وأنفسكم مفعول به، وهو مبتدأ، وأعلم خبر، وبمن اتقى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة اتقى صلة الموصول لا محل لها من الإعراب.</p></div>"
  53,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيت الذي تولى﴾</span></span>: الهمزة للاستفهام التقريري، والفاء عاطفة على محذوف مقدَّر، ورأيت فعل وفاعل بمعنى: أخبرني، والذي مفعول رأيت الأول، وجملة تولى صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿أفرأيت...﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  53,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأعطى قليلا وأكدى﴾</span></span>: الواو عاطفة، وأعطى معطوف على تولى، وقليلًا صفة لمصدر محذوف، ولك أن تجعله مفعولًا به، وأكدى عطف على أعطى.</p></div>"
  53,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أعنده علم الغيب فهو يرى﴾</span></span>: الهمزة للاستفهام الإنكاري، وعنده ظرف متعلق بمحذوف خبر مقدم، وعلم الغيب مبتدأ مؤخر، والجملة في موضع نصب على أنها مفعول ثانٍ لرأيت، والفاء عاطفة، وهو مبتدأ، وجملة يرى خبره، والجملة عطف على جملة: أعنده علم الغيب، فهي داخلة في حيز الاستفهام.</p></div>"
  53,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لم ينبأ بما في صحف موسى﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل ألم ينبأ؟ و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، وينبأ فعل مضارع مجزوم بلم، ونائب الفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿ينبأ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في صحف﴾</span></span> الجار والمجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. وموسى: مضاف إليه.</p></div>"
  53,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإبراهيم الذي وفى﴾</span></span>: إبراهيم عطف على موسى، والذي صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وفّى﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  53,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا تزر وازرة وزر أخرى﴾</span></span>: أن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تزر...﴾</span></span> خبرها، ووازرة فاعل تزر، ووزر أخرى مفعول تزر، وأن وما في حيزها بدل من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في صحف موسى، فهي في محل جر، أو خبر لمبتدأ محذوف، أي: هو ألا تزر، فهي في محل رفع.</p></div>"
  53,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن ليس للإنسان إلا ما سعى﴾</span></span>: أن عطف على ألا تزر، فهي مخففة مثلها، وجملة ليس خبرها، وللإنسان خبر مقدم لليس، وإلا أداة حصر، وما مصدرية، وسعى فعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما سعى﴾</span></span> اسم ليس.</p></div>"
  53,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن سعيه سوف يرى﴾</span></span>: عطف على ما تقدم، وسعيه اسم أن، وجملة سوف يرى خبر أن.</p></div>"
  53,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم يجزاه الجزاء الأوفى﴾</span></span>: ثم حرف عطف، ويجزاه فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، تقديره: هو، والهاء نصب بنزع الخافض، أو هو مفعول ثانٍ، يقال: جزيته سعيه، وبسعيه، والجزاء مفعول مطلق، والأوفى صفة، والضمير المرفوع يعود على الإنسان، والمنصوب يعود على الجزاء، والجملة في محل رفع عطفًا على خبر إن.</p></div>"
  53,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن إلى ربك المنتهى﴾</span></span>: عطف على ما تقدم، وإلى ربك خبر أن المتقدم، والمنتهى اسم أن المؤخر.</p></div>"
  53,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنه هو أضحك وأبكى﴾</span></span>: عطف أيضًا، وأن حرف ناسخ، والهاء اسمها، وهو مبتدأ، وجملة أضحك خبر، والجملة خبر أن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> تأكيد لاسم أن، وقيل: هو ضمير فصل، وجملة أضحك خبر أن.</p></div>"
  53,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنه هو أمات وأحيا﴾</span></span>: عطف على الآية السابقة، وأن حرف ناسخ، والهاء اسمها، وهو مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمات﴾</span></span> خبر، والجملة خبر أن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> تأكيد لاسم أن، وقيل: هو ضمير فصل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمات﴾</span></span> خبر أن.</p></div>"
  53,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنه خلق الزوجين الذكر والأنثى﴾</span></span>: عطف على الآية السابقة، وجملة خلق خبر أن، والزوجين مفعول به، والذكر بدل من الزوجين، والأنثى عطف على الذكر.</p></div>"
  53,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من نطفة إذا تمنى﴾</span></span>: من نطفة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، وإذا ظرف لما يستقبل من الزمن، خافض لشرطه، منصوب بجوابه، وجملة تمنى في محل جر بإضافة الظرف إليها.</p></div>"
  53,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن عليه النشأة الأخرى﴾</span></span>: الآية معطوفة على ما قبلها، وعليه خبر أن المقدم، والنشأة اسمها المؤخر، والأخرى صفة للنشأة.</p></div>"
  53,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنه هو أغنى وأقنى﴾</span></span>: عطف على الآية السابقة، وأن حرف ناسخ، والهاء اسمها، وهو مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span> خبر، والجملة خبر أن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> تأكيد لاسم أن، وقيل: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span> خبر أن.</p></div>"
  53,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنه هو رب الشعرى﴾</span></span>: أن حرف ناسخ، والهاء اسمها، وهو ضمير في محل رفع مبتدأ، رب خبر مرفوع بالضمة، الشعرى: مضاف إليه مجرور بالكسرة المقدرة، والجملة في محل رفع خبر أن، والمصدر المؤول عطف على نظيره السابق.</p></div>"
  53,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنه أهلك عادا الأولى﴾</span></span>: أن حرف ناسخ، والهاء اسمها، وجملة أهلك خبرها، وعادًا مفعول أهلك، والأولى صفة.</p></div>"
  53,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وثمود فما أبقى﴾</span></span>: عطف على عاد، والفاء عاطفة، وما أبقى معطوف على أهلك، وقيل: وثمودًا منصوب بفعل مضمر، أي: وأهلك ثمودًا، ولا يصح أن يكون مفعولًا مقدمًا لأبقى، لأن لما النافية الصدر، فلا يعمل ما بعدها فيما قبلها.</p></div>"
  53,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقوم نوح﴾</span></span>: عطف على ثمود.</p><p><span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span>: جار ومجرور متعلقان بمحذوف على الحال، وقد بُنيت قبل على الضم لانقطاعها عن الإضافة لفظًا لا معنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا هم أظلم وأطغى﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وكان فعل ماض ناقص، وواو الجماعة اسمها، وهم ضمير فصل لا محل له من الإعراب، أو تأكيد للضمير في كانوا، وأظلم خبر كانوا، وأطغى عطف على أظلم.</p></div>"
  53,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والمؤتفكة أهوى﴾</span></span>: الواو عاطفة، والمؤتفكة مفعول مقدم لأهوى، والجملة معطوفة. أو المؤتفكة اسم معطوف على ما قبله.</p></div>"
  53,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فغشاها ما غشى﴾</span></span>: الفاء حرف عطف، وغشاها فعل وفاعل مستتر، وما موصول مفعول ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿غشى﴾</span></span>، وجملة غشى صلة. أو يكون غشى المشدد بمعنى المجرد، فيتعدى لواحد، ويكون الفاعل <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p></div>"
  53,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربك تتمارى﴾</span></span>: الفاء الفصيحة، والباء ظرفية، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتمارى﴾</span></span>، وتتمارى فعل مضارع مرفوع بالضمة المقدرة والفاعل مستتر تقديره أنت، والجملة في محل جزم جواب الشرط المقدر، أي: إن كانت قدرة الله متمثلة فيما ذكر فبأي آلاء ربك تتمارى؟</p></div>"
  53,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا نذير من النذر الأولى﴾</span></span>: اسم الإشارة مبتدأ، ونذير خبر، ومن النذر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿نذير﴾</span></span>، والنذر إما جمع لاسم الفاعل إذا اعتبرنا نذيرًا اسم فاعل غير قياسي، أو للمصدر إذا اعتبرنا نذيرًا مصدرًا غير قياسي، لأنه من أنذر، وقياس اسم الفاعل منه منذر، وقياس المصدر منه منذر، والأولى نعت للنذر.</p></div>"
  53,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أزفت الآزفة﴾</span></span>: فعل وفاعل، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  53,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليس لها من دون الله كاشفة﴾</span></span>: الجملة حال من الآزفة، وليس فعل ماضٍ ناقص، ولها خبر مقدم، ومن دون الله حال، وكاشفة اسم ليس، وتحتمل أن تكون وصفًا أو مصدرًا، فإذا كانت وصفًا فالتاء فيها للتأنيث، لأنها عندئذ صفة لمحذوف، أي: نفس كاشفة، أو: حال كاشفة.</p></div>"
  53,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفمن هذا الحديث تعجبون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ومن هذا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعجبون﴾</span></span>، والحديث بدل من اسم الإشارة، وتعجبون فعل مضارع مرفوع بثبوت النون والواو فاعل.</p></div>"
  53,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتضحكون ولا تبكون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿تعجبون﴾</span></span>.</p></div>"
  53,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنتم سامدون﴾</span></span>: الواو للحال، أو للاستئناف، وأنتم مبتدأ، وسامدون خبر، والجملة إما حالية في محل نصب، وإما مستأنفة لا محل لها من الإعراب.</p></div>"
  53,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاسجدوا لله واعبدوا﴾</span></span>: الفاء الفصيحة، واسجدوا فعل أمر مبني على حذف النون، ولله اللام حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسجدوا﴾</span></span>، واعبدوا فعل أمر معطوف على <span class="hlt"><span class="qpc-hafs">﴿فاسجدوا﴾</span></span>، والمفعول به محذوف.</p></div>"
