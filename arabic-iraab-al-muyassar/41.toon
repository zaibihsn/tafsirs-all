quran[54]{c,v,t}:
  41,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  41,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيل من الرحمن الرحيم﴾</span></span>: تنزيل: خبر لمبتدأ محذوف، أي: هو تنزيل، ومن الرحمن: جار ومجرور متعلقان بصفة لـ<span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>، والرحيم: صفة. أو <span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>: مبتدأ، وقوله: <span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span> في الآية التالية: خبره، وساغ الابتداء بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span> لأنه تخصص بالصفة.</p></div>"
  41,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كتاب فصلت آياته قرآنا عربيا لقوم يعلمون﴾</span></span>: كتاب: بدل من تنزيل، أو خبر بعد خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فصلت﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>، وفصلت: فعل ماض مبني لما لم يسمَّ فاعله، والتاء للتأنيث، وآياته: نائب فاعل، وقرآنًا: حال من كتاب، وعربيًّا: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قرآنا﴾</span></span>، ولقوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فصلت﴾</span></span> أو متعلقان بمحذوف بنعت ثان لـ<span class="hlt"><span class="qpc-hafs">﴿قرآنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  41,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بشيرا ونذيرا فأعرض أكثرهم فهم لا يسمعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بشيرا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قرآنًا﴾</span></span> أو حال من <span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>، ونذيرا: معطوف على <span class="hlt"><span class="qpc-hafs">﴿بشيرًا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿فأعرض﴾</span></span>: الفاء عاطفة، وأعرض: فعل ماض، وأكثرهم: فاعل، والهاء مضاف إليه والميم علامة الجمع، فهم: الفاء عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يسمعون﴾</span></span>: خبر هم.</p></div>"
  41,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا قلوبنا في أكنة مما تدعونا إليه وفي آذاننا وقر﴾</span></span>: الواو عاطفة أو استئنافية، وقالوا: فعل ماض وفاعل، وقلوبنا: مبتدأ، وفي أكنة: جار ومجرور متعلقان بمحذوف خبر، ومما: جار ومجرور متعلقان بمحذوف والتقدير: في أكنة تمنعنا مما تدعونا إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعونا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقالوا قلوبنا...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أعرض أكثرهم﴾</span></span> في الآية السابقة، أو مستأنفة لا محل لها من الإعراب، وفي آذاننا: جار ومجرور متعلقان بمحذوف خبر مقدم، ووقر: مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن بيننا وبينك حجاب فاعمل إننا عاملون﴾</span></span>: الواو: حرف عطف، ومن بيننا: جار ومجرور متعلقان بمحذوف خبر مقدم، وبينك: معطوف على بيننا، وحجاب: مبتدأ مؤخر، فاعمل: الفاء الفصيحة، واعمل: فعل أمر، والفاعل مستتر، وإننا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وعاملون: خبرها.</p></div>"
  41,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إنما أنا بشر مثلكم يوحى إلي أنما إلهكم إله واحد﴾</span></span>: قل: فعل أمر، والفاعل مستتر، إنما: كافة ومكفوفة، وأنا: مبتدأ، وبشر: خبر، ومثلكم: نعت، والكاف: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span>: نعت ثان لبشر، ويوحى: فعل مضارع مبني لما لم يسمَّ فاعله، وإلي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span>، وأنما: كافة ومكفوفة، وإلهكم: مبتدأ، وإله: خبر، وواحد: نعت، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أنما إلهكم ...﴾</span></span> نائب فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستقيموا إليه واستغفروه وويل للمشركين﴾</span></span>: الفاء الفصيحة، واستقيموا: فعل أمر، وفاعل، واستغفروه: عطف على فاستقيموا، والهاء: مفعول به، وويل: الواو عاطفة، وويل: مبتدأ ساغ الابتداء به لما فيه من معنى الدعاء، وللمشركين: جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  41,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين لا يؤتون الزكاة﴾</span></span>: الذين: نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤتون الزكاة﴾</span></span> صلة الموصول لا محل لها من الإعراب، ولا نافية، ويؤتون: فعل مضارع، والواو: فاعل، والزكاة: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم بالآخرة هم كافرون﴾</span></span>: الواو عاطفة، وهم: مبتدأ، وبالآخرة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وهم الثانية: تأكيد للأولى، وكافرون: خبر هم.</p></div>"
  41,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات لهم أجر غير ممنون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والذين اسمها، وجملة آمنوا: صلة الموصول لا محل لها من الإعراب. وآمن: فعل ماض، والواو: فاعل، وعملوا: عطف على آمنوا، والصالحات: مفعول به منصوب بالكسرة، ولهم: جار ومجرور متعلقان بمحذوف خبر مقدم، وأجر: مبتدأ مؤخر، وغير: نعت، وممنون: مضاف إليه، والجملة الاسمية خبر إن.</p></div>"
  41,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أئنكم لتكفرون بالذي خلق الأرض في يومين﴾</span></span>: الهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكفرون﴾</span></span>: خبر إن، وبالذي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكفرون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق الأرض﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وفي يومين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتجعلون له أندادا ذلك رب العالمين﴾</span></span>: الواو: عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تجعلون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿تكفرون﴾</span></span>، وله: جار ومجرور متعلقان بمحذوف مفعول تجعلون الثاني، وأندادًا: مفعوله الأول، وذلك: مبتدأ، والإشارة إلى الذي باعتبار اتصافه بما دلت عليه الصلة، ورب: خبره، والعالمين: مضاف إليه.</p></div>"
  41,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعل فيها رواسي من فوقها وبارك فيها﴾</span></span>: الواو:عاطفة، والجملة معطوفة على خلق الأرض، وفيها: جار ومجرور متعلقان بمحذوف مفعول ثان، ورواسي: مفعول جعل الأول، ويصح تعليق الجار والمجرور بجعل، على أنه بمعنى خلق، فهو ينصب مفعولًا واحدًا، ومن فوقها: جار ومجرور متعلقان بمحذوف نعت لرواسي.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقدر فيها أقواتها في أربعة أيام سواء للسائلين﴾</span></span>: الواو عاطفة، وقدر: فعل ماض، والفاعل مستتر، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدر﴾</span></span>، وأقواتها: مفعول به، والهاء: مضاف إليه، وفي أربعة أيام: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدر﴾</span></span>، وأيام: مضاف إليه، وسواء: حال من <span class="hlt"><span class="qpc-hafs">﴿أيام﴾</span></span>، أي: كاملة لا نقص فيها ولا زيادة، وللسائلين: جار ومجرور متعلقان بالفعل المحذوف. أو تعراب <span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>: حال من الضمير في أقواتها.</p></div>"
  41,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم استوى إلى السماء وهي دخان﴾</span></span>: ثم: حرف عطف، واستوى: فعل ماض، وفاعله مستتر تقديره هو، وإلى السماء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استوى﴾</span></span>، والواو: للحال، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>: مبتدأ، ودخان: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال لها وللأرض ائتيا طوعا أو كرها قالتا أتينا طائعين﴾</span></span>: الفاء: عاطفة، وقال: فعل ماض، وفاعله مستتر يعود على الله تعالى، ولها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وللأرض: عطف على <span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span>، وائتيا: فعل أمر مبني على حذف النون، وألف الاثنين: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿طوعًا وكرهًا﴾</span></span>: مصدران في موضع الحال، أي طائعتين أو كارهتين.</p></div>"
  41,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقضاهن سبع سماوات في يومين وأوحى في كل سماء أمرها﴾</span></span>: الفاء عاطفة، وقضاهن: فعل ماض وفاعل مستتر ومفعول به، وسبع: مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿قضاهن﴾</span></span>، لأنه ضُمِّن معنى صير، وسماوات: مضاف إليه، وفي يومين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضاهن﴾</span></span>، وأوحى: الواو عاطفة، وأوحى: فعل ماض، والفاعل مستتر، وفي كل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وسماء: مضاف إليه، وأمرها: مفعول به، والهاء: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وزينا السماء الدنيا بمصابيح وحفظا ذلك تقدير العزيز العليم﴾</span></span>: الواو عاطفة، وزينا: فعل وفاعل، والسماء: مفعول به، والدنيا: نعت، وبمصابيح: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span>، وحفظًا: مفعول مطلق لفعل محذوف، أي: وحفظناها حفظًا، أو أن يكون مفعولًا لأجله على المعنى، كأنه قال: <span class="hlt"><span class="qpc-hafs">﴿وخلقنا المصابيح زينة وحفظًا﴾</span></span>، وذلك: مبتدأ، وتقدير: مضاف إليه، والعزيز: مضاف إليه، والعليم: نعت للعزيز مجرور.</p></div>"
  41,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن أعرضوا فقل أنذرتكم صاعقة مثل صاعقة عاد وثمود﴾</span></span>: الفاء عاطفة، وإن شرطية، وأعرضوا: فعل ماض، والواو فاعل، والفعل في محل جزم فعل الشرط، فقل: الفاء رابطة، وقل: فعل أمر، وفاعله مستتر تقديره أنت، وأنذرتكم: فعل ماض، وفاعل، ومفعول به، وصاعقة: مفعول به ثان، ومثل: نعت لصاعقة، وصاعقة: مضاف إليه وهو مضاف، وعاد: مضاف إليه، وثمود: معطوف على <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> مجرور بالفتحة لأنه ممنوع من الصرف.</p></div>"
  41,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ جاءتهم الرسل من بين أيديهم ومن خلفهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿صاعقة عاد وثمود﴾</span></span> على أن معنى الصاعقة العذاب، أو هي في محل نصب حال منها، أو <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> بعدها، والجملة مستأنفة استئنافا بيانيا، كأنها وقعت إجابة لسؤال تقديره: ما شأنهم؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءتهم الرسل﴾</span></span>: في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿من بين﴾</span></span>: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءتهم﴾</span></span>، وأيديهم: مضاف إليه، أو متعلقان بمحذوف حال من الرسل، أي حال كون الرسل من بين أيدي عاد وثمود، و<span class="hlt"><span class="qpc-hafs">﴿من خلفهم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿من بين أيديهم﴾</span></span>، والهاء: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا تعبدوا إلا الله﴾</span></span>: في <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> ثلاثة أوجه:</p><p>أحدها: أنها مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وأصله: أنه لا تعبدوا، أي: بأن الشأن والحديث قولنا لكم: لا تعبدوا إلا الله. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعبدوا..﴾</span></span> في محل رفع خبر أن المخففة، وأن وما في حيزها في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بمحذوف حال من الرسل، وتقديره: قائلين، ولا ناهية، وتعبدوا: فعل مضارع مجزوم بلا، وإلا: أداة حصر، ولفظ الجلالة: مفعول به.</p><p>والوجه الثاني: أنها حرف مصدري ناصب، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span> فعل مضارع منصوب بأن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية وما في حيزها منصوب بنزع الخافض، والجار والمجرور متعلقان بمحذوف حال من الرسل، وتقديره: قائلين، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعبدوا...﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p>والوجه الثالث: أنها، لأن مجيء الرسل يحتمل القول، والجملة بعدها تفسيرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لو شاء ربنا لأنزل ملائكة فإنا بما أرسلتم به كافرون﴾</span></span>: قالوا: فعل ماض وفاعل، ولو: حرف شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿شاء ربنا﴾</span></span>: فعل وفاعل، والمفعول به محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿إنزال ملائكة بالرسالة إلى الإنس لأنزل إليهم بها ملائكة﴾</span></span>، واللام: واقعة في جواب لو، وأنزل: فعل ماض مبني على الفتح، والفاعل مستتر، وملائكة: مفعول به، والفاء الفصيحة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء: حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلتم به﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وأرسلتم: فعل ماض مبني لما لم يسمَّ فاعله، والتاء: نائب فاعل، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>، وكافرون: خبر إن.</p></div>"
  41,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما عاد فاستكبروا في الأرض بغير الحق﴾</span></span>: الفاء استئنافية، وأما: حرف شرط وتفصيل، وعاد: مبتدأ، والفاء: رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وجملة استكبروا: خبر عاد، وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكبروا﴾</span></span>، وبغير: جار ومجرور متعلقان بمحذوف حال، والحق: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأما عاد...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا من أشد منا قوة﴾</span></span>: قالوا: عطف على <span class="hlt"><span class="qpc-hafs">﴿فاستكبروا﴾</span></span>، ومن: اسم استفهام مبتدأ، وأشد: خبر، والجملة مقول القول، ومنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>، وقوة: تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا أن الله الذي خلقهم هو أشد منهم قوة﴾</span></span>: الهمزة للاستفهام، والواو: حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يروا﴾</span></span>: معطوفة على مقدر يقتضيه السياق، أي: أغفلوا وضلوا ولم يروا، وأن وما في حيزها سدت مسد مفعولي يروا، لأنها بمعنى العلم، وأن حرف ناسخ، ولفظ الجلالة اسمها والذي: نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقهم﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وهو: مبتدأ، وأشد: خبر، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>، وقوة: تمييز، والجملة خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكانوا بآياتنا يجحدون﴾</span></span>: الواو عاطفة، وكانوا: فعل ماض ناقص، والواو: اسم كان، وبآياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>.</p></div>"
  41,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأرسلنا عليهم ريحا صرصرا في أيام نحسات لنذيقهم عذاب الخزي في الحياة الدنيا﴾</span></span>: الفاء عاطفة، وأرسلنا: فعل وفاعل، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وريحًا: مفعول به، وصرصرًا: نعت، وفي أيام: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ونحسات: نعت لأيام، ولنذيقهم: اللام للتعليل، ونذيقهم: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والهاء مفعول به، والمصدر المؤول مجرور بلام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وعذاب: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نذيقهم﴾</span></span>، والخزي: مضاف إليه، وفي الحياة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذيقهم﴾</span></span>، والدنيا: نعت للحياة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولعذاب الآخرة أخزى وهم لا ينصرون﴾</span></span>: الواو استئنافية، واللام للابتداء، وعذاب: مبتدأ، والآخرة: مضاف إليه، وأخزى: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولعذاب الآخرة أخزى﴾</span></span> مستأنفة لا محل لها من الإعراب، والواو عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ينصرون﴾</span></span>: خبر، ولا نافية، وينصرون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  41,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما ثمود فهديناهم فاستحبوا العمى على الهدى﴾</span></span>: الواو عاطفة، وأما: حرف شرط وتفصيل، وثمود: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فهديناهم﴾</span></span>: الفاء: واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وهدينا: فعل ماض، وفاعله، والهاء: مفعول به، والجملة في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿فاستحبوا﴾</span></span>: الفاء عاطفة، واستحبوا: عطف على <span class="hlt"><span class="qpc-hafs">﴿هديناهم﴾</span></span>، والعمى: مفعول به، وعلى الهدى: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استحب﴾</span></span>، لأنه متضمن معنى آثروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذتهم صاعقة العذاب الهون بما كانوا يكسبون﴾</span></span>: الفاء عاطفة، وأخذتهم: فعل ماض، ومفعول به مقدم، وصاعقة: فاعل مؤخر، والعذاب: مضاف إليه، والهون: نعت للعذاب، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء: حرف جر، وما: اسم موصول مبني في محل جر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: مصدرية، وهي وما بعدها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذتهم﴾</span></span>، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يكسبون: خبرها والعائد محذوف، أي: بالذي كانوا يكسبونه من شركهم وتكذيبهم نبيهم.</p></div>"
  41,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجينا الذين آمنوا وكانوا يتقون﴾</span></span>: الواو: حرف عطف، ونجينا: فعل وفاعل، والذين: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وكانوا: عطف على <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يتقون: خبرها.</p></div>"
  41,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يحشر أعداء الله إلى النار فهم يوزعون﴾</span></span>: الواو استئنافية، ويوم: مفعول لفعل محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿اذكر يوم﴾</span></span>، ويحشر: فعل مضارع مبني لما لم يسمَّ فاعله، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحشر﴾</span></span> في محل جر مضاف إليه، وأعداء: نائب فاعل، ولفظ الجلالة: مضاف إليه، وإلى النار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحشر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويوم يحشر...﴾</span></span> مستأنفة لا محل لها من الإعراب، والفاء عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوزعون﴾</span></span>: خبر.</p></div>"
  41,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا ما جاءوها شهد عليهم سمعهم وأبصارهم وجلودهم﴾</span></span>: حتى: حرف غاية، وإذا: ظرف لما يستقبل من الزمن متضمن معنى الشرط متعلق بجوابه، وهو شهد، وما: صلة لتأكيد الشهادة، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاؤوها﴾</span></span>: في محل جر بإضافة الظرف إليها، وجملة شهد: لا محل لها من الإعراب، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهد﴾</span></span>، وسمعهم: فاعل، <span class="hlt"><span class="qpc-hafs">﴿وأبصارهم وجلودهم﴾</span></span>: معطوفان على <span class="hlt"><span class="qpc-hafs">﴿سمعهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بما كانوا يعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء: حرف جر، وما: اسم موصول مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهد﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: مصدرية، وهي وما دخلت عليه في تأويل مصدر مجرور بالباء، والجار والمجرو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span>: خبر كان، ويعملون: فعل مضارع، والواو: فاعل.</p></div>"
  41,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لجلودهم لم شهدتم علينا﴾</span></span>: الواو عاطفة، وقالوا: فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لجلودهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿لِمَ﴾</span></span>: اللام: حرف جر، وما: اسم استفهام مجرور باللام، ولذلك حذفت ألفها، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهدتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهدتم﴾</span></span>، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أنطقنا الله الذي أنطق كل شيء﴾</span></span>: قالوا: فعل وفاعل، وأنطقنا الله: فعل ماض، ومفعول به، وفاعل، والجملة مقول القول، والذي: صفة لله، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنطق كل شيء﴾</span></span>: صلة الذي لا محل لها من الإعراب. وأنطق: فعل ماض، والفاعل مستتر، وكل: مفعول به، وشيء: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو خلقكم أول مرة وإليه ترجعون﴾</span></span>: الواو عاطفة، وهو: مبتدأ وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span>: خبر، وأول: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span>، ومرة: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  41,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنتم تستترون أن يشهد عليكم سمعكم ولا أبصاركم ولا جلودكم﴾</span></span>: الواو استئنافية، وما: نافية، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تستترون﴾</span></span>: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما كنتم...﴾</span></span> مستأنفة لا محل لها من الإعراب. وأن وما في حيزها نصب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستترون﴾</span></span>، أي من أن يشهد عليكم، لأن تستترون لا يتعدى بنفسه، وقيل: هو مفعول لأجله بتقدير مضاف، أي: مخافة أن يشهد عليكم سمعكم. وعليكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشهد﴾</span></span>، وسمعكم: فاعل، والكاف: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولا أبصاركم، ولا جلودكم﴾</span></span>: الواو عاطفة، ولا: صلة لتوكيد النفي، وأبصاركم: معطوف على سمعكم مرفوع، والكاف: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولا جلودكم﴾</span></span>: عطف على سمعكم أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن ظننتم أن الله لا يعلم كثيرا مما تعملون﴾</span></span>: الواو عاطفة، ولكن: حرف استدراك مهمل، وظننتم: فعل وفاعل، وأن وما في حيزها سدت مسد مفعولي ظننتم، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلم﴾</span></span>: خبرها، وكثيرًا: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span>: من حرف جر، وما: اسم موصول، والجار والمجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span>، وجملة تعلمون صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي تعلمونه، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مجرور بمن، والجار والمجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span>.</p></div>"
  41,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وذلكم ظنكم الذي ظننتم بربكم أرداكم فأصبحتم من الخاسرين﴾</span></span>: الواو عاطفة، وذلكم: مبتدأ، وظنكم: خبر، والذي: اسم موصول في محل رفع بدل أو عطف بيان أو نعت ظنكم، و<span class="hlt"><span class="qpc-hafs">﴿ظننتم﴾</span></span>: فعل ماض، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظننتم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وبربكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظننتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أرداكم﴾</span></span>: فعل، وفاعل، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرداكم﴾</span></span>: خبر ثان، أو أن تعرب ظنكم بدلًا من ذلكم، أو ظنكم خبر، وجملة أرداكم حال بإضمار <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> قبلها، <span class="hlt"><span class="qpc-hafs">﴿فأصبحتم﴾</span></span>: الفاء عاطفة، وأصبح فعل ماض ناقص، والتاء اسمها، ومن الخاسرين: جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  41,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن يصبروا فالنار مثوى لهم﴾</span></span>: الفاء استئنافية، وإن شرطية، ويصبروا: فعل الشرط، ويصبروا: فعل مضارع، والواو فاعل، والفاء رابطة، والنار مبتدأ، ومثوى: خبر، ولهم: جار ومجرور متعلقان بمحذوف نعت لمثوى، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإن يصبروا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يستعتبوا فما هم من المعتبين﴾</span></span>: الواو: عاطفة، وإن: شرطية، ويستعتبوا: فعل وفاعل، والفاء: رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، وهم: ضمير مبني في محل رفع اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿من المعتبين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر ما، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية غير عاملة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير مبني في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المعتبين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿فما هم من المعتبين﴾</span></span> جواب الشرط في محل جزم.</p></div>"
  41,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيضنا لهم قرناء فزينوا لهم ما بين أيديهم وما خلفهم﴾</span></span>: الواو عاطفة، وقيضنا: فعل وفاعل، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيضنا﴾</span></span>، وقرناء: مفعول به، فزينوا: الفاء عاطفة، وزينوا: فعل وفاعل، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زينوا﴾</span></span>، وما: اسم موصول في محل نصب مفعول به، وبين: ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. وأيديهم: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿وما خلفهم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿ما بين أيديهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وحق عليهم القول في أمم قد خلت من قبلهم من الجن والإنس إنهم كانوا خاسرين﴾</span></span>: الواو عاطفة، وحق فعل ماض، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span>، والقول: فاعل، وفي أمم: جار ومجرور متعلقان بمحذوف حال من الضمير في عليهم، أي: كائنين في جملة أمم أو مندرجين. و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، وخلت: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد خلت﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أمم﴾</span></span>، ومن قبلهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلت﴾</span></span>، ومن الجن: جار ومجرور متعلقان بمحذوف نعت ثان لأمم، أو حال من الضمير في خلت، والإنس: معطوف على الجن. <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: خبرها، وكان فعل ماض ناقص، وواو الجماعة اسمها، وخاسرين: خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> وما بعدها تعليلية.</p></div>"
  41,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا لا تسمعوا لهذا القرآن والغوا فيه لعلكم تغلبون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span>: فعل وفاعل، وكفروا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب، ولا ناهية، وتسمعوا: فعل مضارع مجزوم بلا، والواو فاعل، والجملة مقول القول، ولهذا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسمعوا﴾</span></span>، والقرآن: بدل، والغوا: فعل أمر وفاعل، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الغوا﴾</span></span>، ولعل حرف ناسخ يفيد الترجي، و<span class="hlt"><span class="qpc-hafs">﴿الكاف﴾</span></span> اسمها، وتغلبون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تغلبون﴾</span></span> خبر لعل.</p></div>"
  41,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلنذيقن الذين كفروا عذابا شديدا﴾</span></span>: الفاء الفصيحة، واللام: واقعة في جواب قسم مقدر، ونذيقن: فعل مضارع مبني على الفتح واجب التأكيد، والفاعل مستتر تقديره نحن، والذين: مفعول به، وكفروا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وعذابًا: مفعول به، وشديدًا: نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجزينهم أسوأ الذي كانوا يعملون﴾</span></span>: ولنجزينهم: مثل لنذيقن، والضمير في محل نصب مفعول به أول، وأسوأ: مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span>، والذي: اسم موصول في محل جر مضاف إليه، وكانوا: فعل ماض ناقص، والواو: اسم كان، ويعملون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  41,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك جزاء أعداء الله النار﴾</span></span>: ذلك: مبتدأ، وجزاء: خبر، وأعداء: مضاف إليه وهو مضاف، ولفظ الجلالة: مضاف إليه، والنار: بدل، أو عطف بيان من جزاء، والراجح إعراب النار خبرًا لمبتدأ محذوف تقديره: هي، أو مبتدأ خبره <span class="hlt"><span class="qpc-hafs">﴿لهم فيها دار الخلد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم فيها دار الخلد جزاء بما كانوا بآياتنا يجحدون﴾</span></span>: لهم: جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها: جار ومجرور متعلقان بمحذوف حال، ودار: مبتدأ مؤخر، والخلد: مضاف إليه، والجملة إما خبر النار بناء على إعرابها مبتدأ، أو في محل نصب حال، أو مستأنفة مستقلة مقررة لما قبلها لا محل لها من الإعراب، وجزاء: مفعول لأجله، أي: لأجل الجزاء، أو مفعول مطلق لفعل محذوف، أي: يجزون جزاء، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، وما: اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>، وجملة كانوا صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>، وكانوا: فعل ماض ناقص ناسخ، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وبآياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>، ويجحدون: فعل مضارع، والواو: فاعل.</p></div>"
  41,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا ربنا أرنا اللذين أضلانا من الجن والإنس﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span>: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وربنا: منادى مضاف محذوف منه حرف النداء، وأرنا: فعل دعاء مبني على حذف حرف العلة، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير مبني في محل نصب مفعول به أول، واللذين: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿أضلانا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، ومن الجن: جار ومجرور متعلقان بمحذوف حال من الفاعل، والإنس: معطوف على الجن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿نجعلهما تحت أقدامنا ليكونا من الأسفلين﴾</span></span>: نجعلهما: فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر تقديره نحن، والهاء مفعول به أول، وتحت: ظرف متعلق بمحذوف مفعول ثان، وأقدامنا: مضاف إليه وهو مضاف، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ليكونا﴾</span></span>: اللام للتعليل، ويكونا: فعل مضارع ناقص ناسخ منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ مجرور باللام، واللام ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>، وألف الاثنين اسم يكون، ومن الأسفلين: جار ومجرور متعلقان بمحذوف خبر يكون.</p></div>"
  41,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين قالوا ربنا الله ثم استقاموا تتنزل عليهم الملائكة﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والذين اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، ورب: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، ولفظ الجلالة: خبر، والجملة مقول القول، وثم: حرف عطف، واستقاموا: فعل ماض وفاعل، وتتنزل: فعل مضارع، والملائكة: فاعل مرفوع، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتنزل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتنزل عليهم الملائكة﴾</span></span>: خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا تخافوا ولا تحزنوا وأبشروا بالجنة التي كنتم توعدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ألّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، وتخافوا: فعل مضارع مجزوم بحذف النون، وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تخافوا﴾</span></span> تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، وتخافوا: فعل مضارع منصوب بأن وعلامة نصبه حذف النون، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية وما بعدها منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتنزل﴾</span></span> والتقدير: تتنزل بأن لا تخافوا، أي: بانتفاء الخوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تخافوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ولا تحزنوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تخافوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وأبشروا﴾</span></span>: الواو عاطفة، وأبشروا: فعل أمر مبني على حذف النون، والواو فاعل، وبالجنة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبشروا﴾</span></span>، والتي: اسم موصول في محل جر نعت للجنة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وكان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span>: خبر كان، وتوعدون: فعل مضارع مبني لما لم يُسَمَّ فاعله، وواو الجماعة نائب فاعل.</p></div>"
  41,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن أولياؤكم في الحياة الدنيا وفي الآخرة﴾</span></span>: نحن: مبتدأ، وأولياؤكم: خبر، وفي الحياة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أولياؤكم﴾</span></span>، ويصح تعليقه بمحذوف حال، والدنيا: نعت للحياة، <span class="hlt"><span class="qpc-hafs">﴿وفي الآخر﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿في الحياة الدنيا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكم فيها ما تشتهي أنفسكم ولكم فيها ما تدعون﴾</span></span>: الواو عاطفة، ولكم: جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها: جار ومجرور متعلقان بمحذوف حال، وما: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تشتهي أنفسكم﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف وهو مفعول تشتهي، أي: الذي تشتهيه أنفسكم، <span class="hlt"><span class="qpc-hafs">﴿ولكم فيها ما تدعون﴾</span></span>: عطف على الجملة السابقة، ولكم: جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها: جار ومجرور متعلقان بمحذوف حال، وما: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف وهو مفعول تدعون، أي: الذي تدعونه.</p></div>"
  41,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نزلا من غفور رحيم﴾</span></span>: نزلا: حال من <span class="hlt"><span class="qpc-hafs">﴿ما تدعون﴾</span></span> أو من العائد المحذوف على أن المراد بالنُّزُل ما يُعَدُّ للنازل من طعام ونحوه، و<span class="hlt"><span class="qpc-hafs">﴿من غفور﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نزلا﴾</span></span>، ورحيم: صفة.</p></div>"
  41,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن أحسن قولا ممن دعا إلى الله وعمل صالحا وقال إنني من المسلمين﴾</span></span>: الواو عاطفة، ومن: اسم استفهام مبتدأ، وأحسن خبر، وقولًا: تمييز، وممن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span>، ودعا: فعل ماض، والفاعل مستتر، وإلى الله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دعا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعا إلى الله﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وعمل صالحًا﴾</span></span>: الواو عاطفة، وعمل: فعل، وفاعل مستتر، وصالحًا: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا، وقال: عطف على ما قبله، و<span class="hlt"><span class="qpc-hafs">﴿إنني﴾</span></span>: إن حرف ناسخ، والياء اسمها، ومن المسلمين: جار ومجرور متعلقان بمحذوف خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنني﴾</span></span> في موضع نصب، لأنها مقول القول.</p></div>"
  41,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تستوي الحسنة ولا السيئة ادفع بالتي هي أحسن﴾</span></span>: الواو استئنافية، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿تستوي الحسنة﴾</span></span>: فعل مضارع وفاعل، <span class="hlt"><span class="qpc-hafs">﴿ولا السيئة﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿الحسنة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا تستوي...﴾</span></span> مستأنفة لا محل لها من الإعراب، وادفع: فعل أمر، والفاعل مستتر، وبالتي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادفع﴾</span></span>، والتي صفة لموصوف محذوف، أي بالخصلة، وهي: مبتدأ، وأحسن: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا الذي بينك وبينه عداوة كأنه ولي حميم﴾</span></span>: الفاء الفصيحة، وإذا الفجائية، والذي: اسم موصول مبني على السكون في محل رفع مبتدأ، وبينك: ظرف مكان منصوب متعلق بمحذوف خبر مقدم، والكاف: مضاف إليه، وبينه: معطوف على بينك، عداوة: مبتدأ مؤخر مرفوع، كأنه ولي: كأن حرف ناسخ، والهاء اسمها، وولي خبرها، وحميم صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأنه ولي﴾</span></span>: في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>.</p></div>"
  41,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يلقاها إلا الذين صبروا﴾</span></span>: الواو: حرف عطف، وما نافية، ويلقاها: فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به ثان، وإلا: أداة حصر، والذين: نائب فاعل يلقاها، وصبروا: فعل ماض، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿صبروا﴾</span></span>: لا محل لها من الإعراب، لأنها صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يلقاها إلا ذو حظ عظيم﴾</span></span>: الواو: حرف عطف، وما نافية، ويلقاها: فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به ثان، وإلا: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ذو﴾</span></span> نائب فاعل <span class="hlt"><span class="qpc-hafs">﴿يلقاها﴾</span></span>، وحظ: مضاف إليه، وعظيم: نعت لحظ.</p></div>"
  41,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإما ينزغنك من الشيطان نزغ فاستعذ بالله إنه هو السميع العليم﴾</span></span>: الواو عاطفة، وإن: شرطية أدغمت نونها في <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الصلة، وينزغنك: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة في محل جزم فعل الشرط، والكاف: مفعول به مقدم، ومن الشيطان: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لنزغ، ونزغ: فاعل مؤخر، <span class="hlt"><span class="qpc-hafs">﴿فاستعذ﴾</span></span>: الفاء رابطة، واستعذ فعل أمر، والفاعل مستتر تقديره أنت، وبالله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استعذ﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿إنه هو السميع العليم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: ضمير فصل، أو مبتدأ، والسميع العليم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو السميع العليم﴾</span></span> خبر إن.</p></div>"
  41,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته الليل والنهار والشمس والقمر﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿من آياته﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، والليل: مبتدأ مؤخر، وما بعده عطف عليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن آياته...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تسجدوا للشمس ولا للقمر واسجدوا لله الذي خلقهن إن كنتم إياه تعبدون﴾</span></span>: لا: ناهية، وتسجدوا: فعل مضارع مجزوم بلا، وللشمس: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسجدوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا للقمر﴾</span></span>: الواو عاطفة، ولا: صلة لتوكيد النفي، و<span class="hlt"><span class="qpc-hafs">﴿للقمر﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسجدوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿واسجدوا لله﴾</span></span>: الواو عاطفة، واسجدوا: فعل أمر، والواو فاعل، ولله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسجدوا﴾</span></span>، والذي: نعت لله، وخلقهن: فعل، وفاعل مستتر، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقهن﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وإن: شرطية، وكنتم: فعل ماض ناقص، وهو في محل جزم فعل الشرط، والتاء: اسمها، وإياه: مفعول مقدم لتعبدون، وتعبدون: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>: خبر كنتم، وجواب الشرط: محذوف تقديره: فاسجدوا له.</p></div>"
  41,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن استكبروا فالذين عند ربك يسبحون له بالليل والنهار وهم لا يسأمون﴾</span></span>: الفاء: عاطفة، وإن شرطية، واستكبروا: فعل ماض، وفاعله، وهو في محل جزم فعل الشرط، فالذين: الفاء: تعليل لجواب الشرط المحذوف، وتقديره: فدعهم وشأنهم، والذين: مبتدأ، وعند: ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. وربك: مضاف إليه، ويسبحون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span>: خبر الذين، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span>، وبالليل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span> أيضًا، والنهار: معطوف على الليل مجرور. <span class="hlt"><span class="qpc-hafs">﴿وهم لا يسأمون﴾</span></span>: الواو: عاطفة، أو: حالية، وهم: مبتدأ، ولا نافية، ويسأمون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يسأمون﴾</span></span>: خبر.</p></div>"
  41,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته أنك ترى الأرض خاشعة فإذا أنزلنا عليها الماء اهتزت وربت﴾</span></span>: الواو: عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من آياته﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، وأن وما في حيزها: مبتدأ مؤخر، وأنك: أن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ترى الأرض﴾</span></span>: فعل، وفاعل مستتر، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترى الأرض﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، وخاشعة: حال، أو الرؤية علمية، و<span class="hlt"><span class="qpc-hafs">﴿خاشعة﴾</span></span>: مفعول به ثان، فإذا: الفاء: عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>: في محل جر بإضافة الظرف إليها، وعليها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، والماء: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿اهتزت﴾</span></span>: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿اهتزت﴾</span></span>: لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وربت﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿اهتزت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذي أحياها لمحيي الموتى إنه على كل شيء قدير﴾</span></span>: إن حرف ناسخ، والذي اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أحياها﴾</span></span>: فعل، وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحياها﴾</span></span>: صلة الموصول لا محل لها من الإعراب، واللام المزحلقة، ومحيي: خبر إن، والموتى: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وعلى كل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدير﴾</span></span>، وشيء: مضاف إليه، وقدير: خبر إن.</p></div>"
  41,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يلحدون في آياتنا لا يخفون علينا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والذين اسمها، و<span class="hlt"><span class="qpc-hafs">﴿يلحدون﴾</span></span>: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلحدون﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وفي آياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلحدون﴾</span></span>، ولا: نافية، ويخفون: فعل، وفاعل، وعلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يخفون علينا﴾</span></span>: خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفمن يلقى في النار خير أم من يأتي آمنا يوم القيامة﴾</span></span>: الهمزة للاستفهام، والفاء: عاطفة على مقدر يقتضيه السياق، ومن: اسم موصول مبتدأ، ويلقى: فعل، وفاعل مستتر، وفي النار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلقى في النار﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. وخير: خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وأم: حرف عطف، ومَن: عطف على من الأولى، و<span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span>: فعل، وفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وآمنا: حال، ويوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span>، والقيامة: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿اعملوا ما شئتم إنه بما تعملون بصير﴾</span></span>: اعملوا: فعل أمر، والواو: فاعل، وما: اسم موصول في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿شئتم﴾</span></span>: فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿شئتم﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وإن حرف ناسخ، والهاء اسمها، وجملة إنه: تعليل للأمر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء: حرف جر جار، وما: اسم موصول مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصير﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span>: صلة الموصول لا محل لها من الإعراب، أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: مصدرية، فهي وما دخلت عليه في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصير﴾</span></span>، وبصير: خبر إن.</p></div>"
  41,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين كفروا بالذكر لما جاءهم﴾</span></span>: الجملة بدل من الجملة السابقة، وإن حرف ناسخ، والذين اسمها، وكفروا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وبالذكر: جار ومجرور متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿كفر﴾</span></span>، ولما: حينية، أو: رابطة، وجاءهم: فعل، وفاعل مستتر، ومفعول به، وفي خبر إن وجوه، أظهرها: أنه محذوف، تقديره: <span class="hlt"><span class="qpc-hafs">﴿لا يخفون علينا﴾</span></span>، ويؤيد هذا الوجه كون <span class="hlt"><span class="qpc-hafs">﴿إن الذين﴾</span></span> الثانية بدلًا من <span class="hlt"><span class="qpc-hafs">﴿إن الذين﴾</span></span> الأولى، فيسري عليها ما يسري على الأولى، والقاعدة: أن المحكوم به على البدل محكوم به على المبدل منه، وهناك أوجه أخرى، تتمثل فيما يلي:</p><p>١ - إنه محذوف لفهم المعنى، وتقديره: معذبون، أو: مهلكون، وهو وجه سديد أيضًا.</p><p>٢ - إنه محذوف، تقديره نجازيهم.</p><p>٣ - إنه موجود مذكور، وهو قوله فيما بعد: <span class="hlt"><span class="qpc-hafs">﴿أولئك ينادون﴾</span></span>.</p><p>٤ - إنه موجود مذكور، وهو قوله: <span class="hlt"><span class="qpc-hafs">﴿لا يأتيه الباطل﴾</span></span> والعائد محذوف، أي: لا يأتيه الباطل منهم، نحو: <span class="hlt"><span class="qpc-hafs">﴿السمن منوان بدرهم﴾</span></span>، أي: منوان منه، وتكون أل عوضًا من الضمير، تقديره: إن الذين كفروا بالذكر لا يأتيه باطلهم.</p><p>٥ - إن الخبر قوله: <span class="hlt"><span class="qpc-hafs">﴿ما يقال لك﴾</span></span>، والعائد: محذوف، تقديره: إن الذين كفروا بالذكر ما يقال لك في شأنهم إلا ما قد قيل للرسل من قبلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لكتاب عزيز﴾</span></span>: الواو حالية، وإنه: الواو حالية، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وكتاب: خبرها، وعزيز: نعت، والجملة: في محل نصب على الحال من الذكر.</p></div>"
  41,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يأتيه الباطل من بين يديه ولا من خلفه تنزيل من حكيم حميد﴾</span></span>: الجملة: نعت ثان للكتاب، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يأتيه الباطل﴾</span></span>: فعل، ومفعول به مقدم، وفاعل مؤخر، ومن بين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيه﴾</span></span>، ويديه: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولا من خلفه﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿من بين يديه﴾</span></span>، وتنزيل: خبر لمبتدأ محذوف أي: هو، ومن حكيم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>، وحميد: نعت لحكيم.</p></div>"
  41,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما يقال لك إلا ما قد قيل للرسل من قبلك﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، ويقال: فعل مضارع مبني لما لم يسمَّ فاعله، ولك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقال﴾</span></span>، وإلا: أداة حصر، وما: اسم موصول في محل رفع نائب فاعل، وقد: حرف تحقيق، وقيل: فعل ماض مبني لما لم يسم َّ فاعله، ونائب الفاعل ضمير مستتر، تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿للرسل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، والجملة لا محل لها من الإعراب، لأنها صلة الموصول، ومن قبلك: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك لذو مغفرة وذو عقاب أليم﴾</span></span>: إن حرف ناسخ، ورب اسمها، والكاف مضاف إليه، واللام المزحلقة، وذو: خبرها، ومغفرة: مضاف إليه، وذو عقاب: عطف على <span class="hlt"><span class="qpc-hafs">﴿ذو مغفرة﴾</span></span>، وأليم: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عقاب﴾</span></span>.</p></div>"
  41,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو جعلناه قرآنا أعجميا لقالوا لولا فصلت آياته أأعجمي وعربي﴾</span></span>: كلام مستأنف لا محل له من الإعراب، ولو: شرطية، وجعلناه: فعل، وفاعل، ومفعول به، وقرآنًا: مفعول به ثان، وأعجميًا: نعت، واللام: واقعة في جواب الشرط، وجملة قالوا: لا محل لها من الإعراب، ولولا: حرف تحضيض، أي: هلا، وفصلت: فعل ماض مبني لما لم يسمَّ فاعله، وآياته: نائب فاعل، أأعجمي: الهمزة للاستفهام الإنكاري، وأعجمي: خبر لمبتدأ محذوف، أي: أهو، أو أأعجمي: مبتدأ، والخبر محذوف، تقديره: أأعجمي، وعربي يستويان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل هو للذين آمنوا هدى وشفاء﴾</span></span>: قل: فعل أمر، وفاعل مستتر، تقديره: أنت، أي: قل في الرد عليهم، وهو مبتدأ، وللذين: جار ومجرور متعلقان بمحذوف حال، لأنه كان نعتًا، وتقدم، وآمنوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وهدى: خبر هو، وشفاء: معطوف على <span class="hlt"><span class="qpc-hafs">﴿هدى﴾</span></span> مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿والذين لا يؤمنون في آذانهم وقر وهو عليهم عمى أولئك ينادون من مكان بعيد﴾</span></span>: الواو عاطفة، والذين: مبتدأ، ولا: نافية، ويؤمنون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span>: صلة الموصول لا محل لها من الإعراب، والعائد: محذوف، أي: به، وفي آذانهم: جار ومجرور متعلقان بمحذوف خبر مقدم، ووقر: مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿في آذانهم وقر﴾</span></span> خبر الذين، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، وعليهم: جار ومجرور متعلقان بمحذوف حال من عمى، ولا يتعلق بالمصدر لتقدمه عليه، وعمى: مبتدأ مؤخر، وأولئك: مبتدأ، وينادون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينادون﴾</span></span>: خبر، ومن مكان: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينادون﴾</span></span>، وبعيد: نعت لمكان.</p></div>"
  41,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب فاختلف فيه﴾</span></span>: الواو استئنافية، واللام: جواب للقسم المحذوف، وقد: حرف تحقيق، وآتينا: فعل وفاعل، وموسى: مفعول به أول، والكتاب: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا...﴾</span></span> مستأنفة لا محل لها من الإعراب. والفاء: عاطفة، واختلف: فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، وفيه: متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اختلف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولولا كلمة سبقت﴾</span></span>: الواو عاطفة، ولولا: حرف امتناع لوجود، وكلمة: مبتدأ محذوف الخبر، وسبقت: فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>: نعت لكلمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span>: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>. واللام: واقعة في جواب لولا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقضي﴾</span></span>: اللام: واقعة في جواب الشرط، وقضي: فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، يعود على المصدر المفهوم من قضي، أي القضاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قضي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم﴾</span></span>: الواو حالية، إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها. واللام المزحلقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿مريب﴾</span></span>: نعت ثان.</p></div>"
  41,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من عمل صالحا فلنفسه﴾</span></span>: من: اسم شرط جازم مبتدأ، وعمل: فعل ماض في محل جزم فعل الشرط، وصالحًا: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. والفاء: رابطة لجواب الشرط، ولنفسه: جار ومجرور متعلقان بفعل محذوف تقديره: نفع، أو: عمل. أو متعلقان بمحذوف خبر لمبتدأ محذوف، أي: فالعمل الصالح لنفسه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أساء فعليها﴾</span></span>: الواو عاطفة، من: اسم شرط جازم مبتدأ، وأساء: فعل ماض في محل جزم فعل الشرط، فعليها: جار ومجرور متعلقان بفعل محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما ربك بظلام للعبيد﴾</span></span>: الواو: استئنافية، وما: نافية حجازية تعمل عمل ليس، وربك: اسم <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والكاف ضمير في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بظلام﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿ظلام﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وللعبيد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظلام﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما ربك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  41,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إليه يرد علم الساعة﴾</span></span>: إليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، ويرد: فعل مضارع مبني لما لم يُسَمَّ فاعله، وعلم: نائب فاعل، والساعة: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تخرج من ثمرات من أكمامها وما تحمل من أنثى ولا تضع إلا بعلمه﴾</span></span>: الواو: عاطفة، وما: نافية، وتخرج: فعل مضارع مرفوع، ومِن: حرف صلة، وثمرات: مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا مرفوع محلا فاعل تخرج، ومن أكمامها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span> وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة في محل جر عطف على الساعة، أي: علم الساعة، وعلم التي تخرج، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> الأولى للاستغراق و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> الثانية لابتداء الغاية. والواو: حرف عطف، وما: نافية، وتحمل: فعل مضارع مرفوع، ومن: حرف صلة، وأنثى: فاعل مجرور لفظًا مرفوع محلا، والواو: عاطفة، ولا: لتأكيد النفي، وتضع: فعل مضارع مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿تضع﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿تحمل﴾</span></span>، وإلا: أداة حصر، وبعلمه: استثناء مفرغ من أعم الأحوال، أي: إلا مقرونًا بعلمه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم أين شركائي قالوا آذناك ما منا من شهيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف والتقدير: واذكر يوم يناديهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يناديهم﴾</span></span> في محل جر مضاف إليه، وأين: اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بمحذوف خبر مقدم، وشركائي: مبتدأ مؤخر، وقالوا: فعل وفاعل، وآذناك: فعل ماض، وفاعل، ومفعول به، وما: نافية، ومنا: خبر مقدم، ومن: حرف صلة، وشهيد: مجرور لفظًا في محل رفع مبتدأ مؤخر.</p></div>"
  41,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضل عنهم ما كانوا يدعون من قبل﴾</span></span>: الواو: عاطفة، وضل: فعل ماض، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>، وما: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وكان: فعل ماض ناقص، والواو: اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> خبر كانوا، ومن قبل: حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وظنوا ما لهم من محيص﴾</span></span>: الواو: عاطفة، وظنوا: فعل ماض، وفاعل، وما: نافية، ولهم: جار ومجرور متعلقان بمحذوف خبر مقدم، ومن: حرف جر صلة، ومحيص: مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا، والنفي معلق للظن عن العمل لفظًا مع بقائه محلا، وجملة النفي سدت مسد المفعولين لآذناك، لأنها بمعنى أعلمناك، كما سدت جملة النفي السابقة مسد المفعول الثاني لآذناك.</p></div>"
  41,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يسأم الإنسان من دعاء الخير﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وهو للشروع في وصف الإنسان في حالتي شدته ورخائه، ولا: نافية، ويسأم: الإنسان فعل مضارع وفاعل، ومن دعاء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسأم﴾</span></span>، والخير: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن مسه الشر فيئوس قنوط﴾</span></span>: الواو عاطفة، وإن شرطية جازمة، ومسه: فعل ماض في محل جزم فعل الشرط، والهاء مفعول به، والشر: فاعل، والفاء رابطة للجواب، ويئوس: خبر لمبتدأ محذوف، أي: فهو يؤوس، وقنوط: خبر ثان.</p></div>"
  41,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن أذقناه رحمة منا من بعد ضراء مسته ليقولن هذا لي﴾</span></span>: الواو: عاطفة، واللام موطئة للقسم، وإن شرطية جازمة، وأذقناه: فعل ماض وفاعل ومفعول به، والجملة في محل جزم فعل الشرط، ورحمة: مفعول به ثان، ومنا: جار ومجرور متعلقان بمحذوف صفة، ومن بعد: جار ومجرور متعلقان بمحذوف صفة لرحمة، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذقناه﴾</span></span>، وضراء: مضاف إليه وجُرَّ بالفتحة، لأنه ممنوع من الصرف لألف التأنيث الممدودة، واللام جواب القسم، وجواب الشرط محذوف لسد جواب القسم مسده، وهذا: مبتدأ، ولي: خبر، واللام للاستحقاق، أي: أستحقه بعملي.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أظن الساعة قائمة ولئن رجعت إلى ربي إن لي عنده للحسنى﴾</span></span>: الواو: عاطفة، وما: نافية، وأظن فعل مضارع، والفاعل مستتر، والساعة: مفعول أظن الأول، وقائمة: مفعولها الثاني، والواو: عاطفة، واللام موطئة للقسم، وإن: شرطية، ورجعت: في محل جزم فعل الشرط، وإلى ربي: الجار والاسم المجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجعت﴾</span></span>، وإن وما في حيزها جواب القسم، ولي: خبر إن، وعنده: حال، واللام المزحلقة، والحسنى: اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن لي عنده للحسنى﴾</span></span> لا محل لها من الإعراب، لأنها جواب القسم لسبقه الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلننبئن الذين كفروا بما عملوا ولنذيقنهم من عذاب غليظ﴾</span></span>: الفاء: الفصيحة، لأنها جواب لقول الكافر: <span class="hlt"><span class="qpc-hafs">﴿ولئن رجعت﴾</span></span>، واللام موطئة للقسم، وننبئن: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والذين: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة في محل جر، أي: بالذي عملوا، أو مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما عملوا﴾</span></span> مجرور بالباء، أي: بعملهم، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننبئن﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولنذيقنهم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿لننبئن﴾</span></span>، ومن عذاب: جار ومجرور متعلقان بمحذوف صفة للمفعول الثاني المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> للتبعيض، أي: لنذيقنهم عذابا كائنا من عذاب غليظ، وغليظ: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>.</p></div>"
  41,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا أنعمنا على الإنسان أعرض﴾</span></span>: الواو: عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span> في محل جر بإضافة الظرف إليها، وعلى الإنسان: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونأى بجانبه﴾</span></span>: عطف على أعرض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نأى﴾</span></span>، لأن الباء للتعدية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مسه الشر فذو دعاء عريض﴾</span></span>: الواو: عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿مسه الشر﴾</span></span> في محل جر بإضافة الظرف إليها، فذو: الفاء رابطة، وذو: خبر لمبتدأ محذوف، أي: هو، ودعاء: مضاف إليه، وعريض: نعت لدعاء.</p></div>"
  41,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم إن كان من عند الله ثم كفرتم به من أضل ممن هو في شقاق بعيد﴾</span></span>: قل: فعل أمر وفاعل مستتر، وأرأيتم: الهمزة للاستفهام، وفعل وفاعل، ومفعول رأى الأول محذوف، تقديره: أرأيتم أنفسكم، والثاني هو الجملة الاستفهامية، وإن: شرطية، وكان: فعل الشرط، واسمها مستتر تقديره: هو، أي القرآن. ومن عند خبر، ولفظ الجلالة: مضاف إليه، ثم كفرتم: عطف على <span class="hlt"><span class="qpc-hafs">﴿كان من عند الله﴾</span></span>، وجواب الشرط محذوف، تقديره: <span class="hlt"><span class="qpc-hafs">﴿فأنتم أضل من غيركم﴾</span></span>، أو: <span class="hlt"><span class="qpc-hafs">﴿لا أحد أضل منكم﴾</span></span>، وجملة الشرط اعتراضية بين المفعولين الأول والثاني لا محل لها من الإعراب، ومن: اسم استفهام مبتدأ، وأضل: خبر، وممن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span>، وهو: مبتدأ، وفي شقاق بعيد: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو في شقاق بعيد﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  41,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سنريهم آياتنا في الآفاق وفي أنفسهم﴾</span></span>: السين للاستقبال، ونريهم: فعل مضارع، والفاعل مستتر تقديره نحن، والهاء مفعول به أول، وآياتنا: مفعول به ثان، ونا: مضاف إليه، والرؤية هنا بصرية، فلذلك عديت إلى اثنين فقط، وفي الآفاق: جار ومجرور متعلقان بمحذوف حال من آياتنا. و<span class="hlt"><span class="qpc-hafs">﴿في أنفسهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿في الآفاق﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى يتبين لهم أنه الحق﴾</span></span>: حتى: حرف غاية وجر، ويتبين: فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بقوله: سنريهم، وأنّ وما في حيزها فاعل يتبين.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم يكف بربك أنه على كل شيء شهيد﴾</span></span>: الهمزة: للاستفهام الإنكاري التوبيخي، والواو: حرف عطف على مقدر يقتضيه السياق، ولم: حرف نفي وجزم وقلب، ويكفِ: فعل مضارع مجزوم بلم وعلامة جزمه حذف حرف العلة، و<span class="hlt"><span class="qpc-hafs">﴿بربك﴾</span></span> الباء: حرف جر صلة، وربك: فاعل <span class="hlt"><span class="qpc-hafs">﴿يكْفِ﴾</span></span> مرفوع محلا مجرور بالباء لفظًا، والمفعول به محذوف، والتقدير: أولم يكفك ربك، و<span class="hlt"><span class="qpc-hafs">﴿أنه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ والهاء اسمها، وعلى كل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهيد﴾</span></span>، وشيء: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿شهيد﴾</span></span> خبر أن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أنه على كل شيء شهيد﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مرفوع محلا  مجرور لفظًا كمتبوعه.</p></div>"
  41,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إنهم في مرية من لقاء ربهم﴾</span></span>: ألا: استفتاحية للتنبيه، إنهم: إن للتوكيد والنصب، وهم اسمها، وفي مرية: جار ومجرور متعلقان بمحذوف خبر إن. من لقاء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرية﴾</span></span>، وربهم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إنه بكل شيء محيط﴾</span></span>: ألا: استفتاحية للتنبيه، إنه: إن للتوكيد والنصب، والهاء اسمها، بكل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿محيط﴾</span></span>، شيء: مضاف إليه، ومحيط: خبر إن مرفوع، وجملتا <span class="hlt"><span class="qpc-hafs">﴿إنهم في مرية﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿إنه بكل شيء محيط﴾</span></span> مستأنفتان لا محل لهما من الإعراب.</p></div>"
