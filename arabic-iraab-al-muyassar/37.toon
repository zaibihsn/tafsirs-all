quran[182]{c,v,t}:
  37,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والصافات صفا﴾</span></span>: الواو حرف قسم وجر، و<span class="hlt"><span class="qpc-hafs">﴿الصافات﴾</span></span> مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، و<span class="hlt"><span class="qpc-hafs">﴿صفًا﴾</span></span> مفعول مطلق مؤكد.</p></div>"
  37,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالزاجرات زجرا﴾</span></span>: الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿الزاجرات﴾</span></span> عطف على الصافات، و<span class="hlt"><span class="qpc-hafs">﴿زجرا﴾</span></span> مفعول مطلق.</p></div>"
  37,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالتاليات ذكرا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿التاليات﴾</span></span> معطوفة على المقسم به في الآيات السابقة، و<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span> نائب عن المفعول المطلق، لأنها في معنى التاليات، أو مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿التاليات﴾</span></span>.</p></div>"
  37,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن إلهكم لواحد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿إلهكم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿واحد﴾</span></span> خبرها، والجملة لا محل لها من الإعراب، لأنها جواب القسم.</p></div>"
  37,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض وما بينهما ورب المشارق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب السماوات﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿واحد﴾</span></span>، أو خبر ثان، أو خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿رب المشارق﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿رب السماوات﴾</span></span>.</p></div>"
  37,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا زينا السماء الدنيا بزينة الكواكب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span> صفة، و<span class="hlt"><span class="qpc-hafs">﴿بزينة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكواكب﴾</span></span> عطف بيان، أو بدل لـ<span class="hlt"><span class="qpc-hafs">﴿زينة﴾</span></span>.</p></div>"
  37,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحفظا من كل شيطان مارد﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿حفظا﴾</span></span> مفعول مطلق لفعل محذوف و التقدير: حفظناها حفظًا، و<span class="hlt"><span class="qpc-hafs">﴿من كل شيطان﴾</span></span> جار ومجرور متعلقان بالفعل المحذوف، <span class="hlt"><span class="qpc-hafs">﴿مارد﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شيطان﴾</span></span>.</p></div>"
  37,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يسمعون إلى الملأ الأعلى ويقذفون من كل جانب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span> فعل مضارع مرفوع، وعلامة رفعه ثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الملأ الأعلى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأعلى﴾</span></span> صفة للملأ، و<span class="hlt"><span class="qpc-hafs">﴿يقذفون﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقذفون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من كل جانب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقذفون﴾</span></span>.</p></div>"
  37,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿دحورا ولهم عذاب واصب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿دحورًا﴾</span></span> مفعول من أجله، أي: يقذفون للدحور، أو حال، أي: مدحورين، أو نائب عن المفعول المطلق، لأنه بمعنى المصدر، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿واصب﴾</span></span> نعت لعذاب.</p></div>"
  37,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من خطف الخطفة فأتبعه شهاب ثاقب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر واستثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> في محل رفع بدل من الواو في <span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>، أو في محل نصب على الاستثناء، و<span class="hlt"><span class="qpc-hafs">﴿خطف﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿الخطفة﴾</span></span> نائب عن المفعول المطلق منصوب، <span class="hlt"><span class="qpc-hafs">﴿فأتبعه﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أتبعه﴾</span></span> فعل ماض، والهاء مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿شهاب﴾</span></span> فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ثاقب﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿شهاب﴾</span></span>.</p></div>"
  37,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستفتهم أهم أشد خلقا أم من خلقنا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿استفتهم﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل مستتر وجوبًا، تقديره: أنت، والهاء مفعول به، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿خلقًا﴾</span></span> تمييز، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، وهي متصلة، <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> فعل و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وهي صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا خلقناهم من طين لازب﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقناهم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿من طين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناهم﴾</span></span>، ولازب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿طين﴾</span></span>.</p></div>"
  37,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل عجبت ويسخرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف للإضراب الانتقالي، و<span class="hlt"><span class="qpc-hafs">﴿عجبت﴾</span></span> فعل ماض، والتاء فاعل، والمتعلق محذوف، أي: من قدرة الله على هذه الخلائق العظيمة، <span class="hlt"><span class="qpc-hafs">﴿ويسخرون﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿يسخرون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسخرون﴾</span></span> خبر لمبتدأ محذوف، أي: وهم يسخرون، والجملة منصوبة على الحال.</p></div>"
  37,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا ذكروا لا يذكرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذكروا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿ذكروا﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يذكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يذكرون﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  37,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا رأوا آية يستسخرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿رأوا آية﴾</span></span> فعل، وفاعل، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأوا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿يستسخرون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستسخرون﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  37,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا إن هذا إلا سحر مبين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿سحر﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت، والجملة مقول القول.</p></div>"
  37,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئذا متنا وكنا ترابا وعظاما أئنا لمبعوثون﴾</span></span>: الجملة مقول قول محذوف أيضًا، أي: وقالوا منكرين للبعث، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿متنا﴾</span></span> في محل جر بإضافة الظرف إليها، وهي فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عظامًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span>، والهمزة للاستفهام الإنكاري أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿مبعوثون﴾</span></span> خبرها.</p></div>"
  37,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أوآباؤنا الأولون﴾</span></span>: الهمزة للاستفهام، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> معطوف على محل إن واسمها، أو على الضمير في <span class="hlt"><span class="qpc-hafs">﴿مبعوثون﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> مبتدأ محذوف الخبر، والتقدير: أوآباؤنا يبعثون أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿الأولون﴾</span></span> صفة.</p></div>"
  37,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل نعم وأنتم داخرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> حرف جواب، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿داخرون﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأنتم داخرون﴾</span></span> منصوبة على الحال، والعامل فيها <span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> بالنظر لمعناها، أي: نعم تبعثون داخرين.</p></div>"
  37,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما هي زجرة واحدة فإذا هم ينظرون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿زجرة﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينظرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينظرون﴾</span></span> خبر، وهي فعل مضارع، والواو فاعل.</p></div>"
  37,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا يا ويلنا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف تنبيه، أو المنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ويلنا﴾</span></span> منادى مضاف منصوب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وقالوا يا ويلنا﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذا يوم الدين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يوم الدين﴾</span></span> خبر.</p></div>"
  37,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا يوم الفصل الذي كنتم به تكذبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يوم الفصل﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب، أو الجملة من تتمة مقولهم، وقوله: <span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> التفات من التكلم إلى الخطاب.</p></div>"
  37,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿احشروا الذين ظلموا وأزواجهم وما كانوا يعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿احشروا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مفعول به. وظلموا: فعل ماض، والواو فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أزواجهم﴾</span></span> عطف على الموصول، أو مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوف أيضًا، أو مفعول معه، وكانوا كان فعل ناقص ناسخ، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span> خبرها، وهي فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من دون الله فاهدوهم إلى صراط الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اهدوهم﴾</span></span> فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى صراط الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اهدوهم﴾</span></span>.</p></div>"
  37,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقفوهم إنهم مسئولون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قفوهم﴾</span></span> عطف على ما تقدم، وهو فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مسئولون﴾</span></span> خبرها، والجملة تعليل للأمر.</p></div>"
  37,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لكم لا تناصرون﴾</span></span>: الجملة مقول قول محذوف، أي: ويقال توبيخًا لهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تناصرون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تناصرون﴾</span></span> حالية.</p></div>"
  37,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل هم اليوم مستسلمون﴾</span></span>: بل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مستسلمون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مستسلمون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  37,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿أقبل﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بعضهم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأقبل بعضهم على بعض﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  37,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنكم كنتم تأتوننا عن اليمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنكم﴾</span></span> إن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، وجملة تأتوننا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿تأتوننا﴾</span></span> فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿تأتوننا﴾</span></span>.</p></div>"
  37,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بل لم تكونوا مؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب إبطالي، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تكونوا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو اسمها، ومؤمنين خبرها.</p></div>"
  37,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لنا عليكم من سلطان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> مجرور لفظًا اسم كان محلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل كنتم قوما طاغين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب إبطالي أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿طاغين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>.</p></div>"
  37,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فحق علينا قول ربنا إنا لذائقون﴾</span></span>: الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قول ربنا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذائقون﴾</span></span> خبرها، والجملة الاسمية تعليل لما تقدم، ومفعول <span class="hlt"><span class="qpc-hafs">﴿ذائقون﴾</span></span> محذوف، أي: العذاب، والفاعل مستتر تقديره: نحن.</p></div>"
  37,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأغويناكم إنا كنا غاوين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أغويناكم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> كان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿غاوين﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبر إن.</p></div>"
  37,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم يومئذ في العذاب مشتركون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة والتقدير: يوم إذ يتساءلون، و<span class="hlt"><span class="qpc-hafs">﴿في العذاب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نفعل بالمجرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span> فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالمجرمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span>.</p></div>"
  37,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا إذا قيل لهم لا إله إلا الله يستكبرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وقيل فعل ماض مبني لما لم يسم فاعله، ونائب الفاعل مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> اسمها المبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> بدل من محل <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> واسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا الله﴾</span></span> مقول قول محذوف، أي: قولوا: لا إله إلا الله، و<span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>، وجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> محذوف دل عليه ما قبله.</p></div>"
  37,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون أئنا لتاركوا آلهتنا لشاعر مجنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span>، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تاركو﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لشاعر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تاركو﴾</span></span>، أي: لأجل شاعر، و<span class="hlt"><span class="qpc-hafs">﴿مجنون﴾</span></span> صفة.</p></div>"
  37,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل جاء بالحق وصدق المرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب إبطالي، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿صدق﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿صدق المرسلين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاء بالحق﴾</span></span>.</p></div>"
  37,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنكم لذائقو العذاب الأليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذائقو﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، والعذاب مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الأليم﴾</span></span> صفة.</p></div>"
  37,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تجزون إلا ما كنتم تعملون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان، وهو على حذف مضاف، أي: جزاء ما، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  37,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن، لأن الاستثناء منقطع، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مستثنى من الواو في <span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك لهم رزق معلوم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿معلوم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span>، ونائب الفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم رزق معلوم﴾</span></span> خبر المبتدأ الأول <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>.</p></div>"
  37,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فواكه وهم مكرمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فواكه﴾</span></span> بدل، أو عطف بيان لـ<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span>، والواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مكرمون﴾</span></span> خبر.</p></div>"
  37,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في جنات النعيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿في جنات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكرمون﴾</span></span>، أو متعلقان بمحذوف خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> في الآية السابقة، أو متعلقان بمحذوف حال.</p></div>"
  37,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿على سرر متقابلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿على سرر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span> حال، أو <span class="hlt"><span class="qpc-hafs">﴿على سرر﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضا.</p></div>"
  37,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يطاف عليهم بكأس من معين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يطاف﴾</span></span> فعل مضارع مبني لما لم يسمّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكأس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يطاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من معين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، والجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مكرمون﴾</span></span>، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span>، أو جملة مستأنفة لا محل لها من الإعراب.</p></div>"
  37,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بيضاء لذة للشاربين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بيضاء﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لذة﴾</span></span> صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للشاربين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لذة﴾</span></span>.</p></div>"
  37,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا فيها غول﴾</span></span>: الجملة صفة رابعة لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿غول﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم عنها ينزفون﴾</span></span>: الواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينزفون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ينزفون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينزفون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  37,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعندهم قاصرات الطرف عين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿عندهم﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿الطرف﴾</span></span> مضاف إليه مرفوع المحل على اعتبار أن <span class="hlt"><span class="qpc-hafs">﴿قاصرات﴾</span></span> صفة مشبهة، أو منصوب المحل على اعتبار أن <span class="hlt"><span class="qpc-hafs">﴿قاصرات﴾</span></span> اسم فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span>.</p></div>"
  37,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأنهن بيض مكنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> حرف للتشبيه والنصب، و<span class="hlt"><span class="qpc-hafs">﴿هن﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بيض﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مكنون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بيض﴾</span></span>، والجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات﴾</span></span>.</p></div>"
  37,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقبل بعضهم على بعض يتساءلون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أقبل بعضهم﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿أقبل بعضهم﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يطاف عليهم﴾</span></span>.</p></div>"
  37,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قائل منهم إني كان لي قرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال قائل﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قائل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span> إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> مقدم، و<span class="hlt"><span class="qpc-hafs">﴿قرين﴾</span></span> اسمها مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر إن، وجملة إن واسمها وخبرها مقول القول.</p></div>"
  37,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يقول أئنك لمن المصدقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر تقديره: هو، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المصدقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، والجملة مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قرين﴾</span></span>.</p></div>"
  37,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئذا متنا وكنا ترابا وعظاما﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿متنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿متنا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عظامًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئنا لمدينون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿مدينون﴾</span></span> خبر إن.</p></div>"
  37,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هل أنتم مطلعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض ناقص، والفاعل ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مطلعون﴾</span></span> خبر.</p></div>"
  37,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاطلع فرآه في سواء الجحيم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اطلع﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، <span class="hlt"><span class="qpc-hafs">﴿فرآه﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span> فعل ماض، والفاعل مستتر، والهاء مفعول به، أي: رأى قرينه، و<span class="hlt"><span class="qpc-hafs">﴿في سواء الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>، أو متعلقان بمحذوف حال، أي: مرتطمًا في وسط جهنم.</p></div>"
  37,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال تالله إن كدت لتردين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿تالله﴾</span></span> التاء حرف قسم وجر، ولفظ الجلالة مجرور، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة، و<span class="hlt"><span class="qpc-hafs">﴿كدت﴾</span></span> من أفعال المقاربة، والتاء اسمها، واللام هي الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿تردين﴾</span></span> فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره: أنت، والنون للوقاية، والياء المحذوفة تخفيفا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لتردين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كدت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن كدت﴾</span></span> جواب القسم لا محل لها من الإعراب.</p></div>"
  37,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا نعمة ربي لكنت من المحضرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مضاف إليه، وخبر المبتدأ محذوف وجوبًا، والتقدير: موجودة، <span class="hlt"><span class="qpc-hafs">﴿لكنت﴾</span></span> اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المحضرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، أي: من الذين أحضروا العذاب.</p></div>"
  37,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفما نحن بميتين﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف تقديره: أنحن مخلدون منعمون فما نحن بميتين؟ و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بميتين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿ميتين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  37,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا موتتنا الأولى وما نحن بمعذبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، والاستثناء منقطع و<span class="hlt"><span class="qpc-hafs">﴿موتتنا﴾</span></span> مستثنى بـ<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> منصوب، أو أن الاستثناء مفرغ و<span class="hlt"><span class="qpc-hafs">﴿موتتنا﴾</span></span> مفعول مطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿الأولى﴾</span></span> صفة، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمعذبين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿معذبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  37,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لهو الفوز العظيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span>.</p></div>"
  37,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لمثل هذا فليعمل العاملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لمثل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعمل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مضاف إليه، والفاء الفصيحة، واللام لام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿يعمل﴾</span></span> فعل مضارع مجزوم بلام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿العاملون﴾</span></span> فاعل.</p></div>"
  37,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أذلك خير نزلا أم شجرة الزقوم﴾</span></span>: الجملة مقول قول محذوف، والهمزة للاستفهام الإنكاري التوبيخي، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿نزلًا﴾</span></span> تمييز لـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وقيل: حال، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿شجرة الزقوم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p></div>"
  37,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا جعلناها فتنة للظالمين﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿جعلناها﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿للظالمين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span>.</p></div>"
  37,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنها شجرة تخرج في أصل الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في أصل الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>.</p></div>"
  37,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طلعها كأنه رؤوس الشياطين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿طلعها﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> حرف تشبيه ونصب، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿رؤوس﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الشياطين﴾</span></span> مضاف إليه.</p></div>"
  37,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم لآكلون منها فمالئون منها البطون﴾</span></span>: الفاء عطف، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فمالئون﴾</span></span> الفاء عاطفة للترتيب مع التعقيب، و<span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿البطون﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span>.</p></div>"
  37,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إن لهم عليها لشوبا من حميم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿شوبًا﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من حميم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شوبًا﴾</span></span>.</p></div>"
  37,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إن مرجعهم لإلى الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿مرجعهم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿إلى الجحيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  37,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم ألفوا آباءهم ضالين﴾</span></span>: الجملة تعليل لما سبق من ابتلائهم بأفانين العذاب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وألفوا فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿آباءهم﴾</span></span> مفعول أول، و<span class="hlt"><span class="qpc-hafs">﴿ضالين﴾</span></span> مفعول ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألفوا﴾</span></span> إن.</p></div>"
  37,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهم على آثارهم يهرعون﴾</span></span>: الفاء تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على آثارهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهرعون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يهرعون﴾</span></span> خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  37,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد ضل قبلهم أكثر الأولين﴾</span></span>: اللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span> فعل ماض مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿أكثر الأولين﴾</span></span> فاعل.</p></div>"
  37,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا فيهم منذرين﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منذرين﴾</span></span> مفعول به.</p></div>"
  37,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانظر كيف كان عاقبة المنذرين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> المقدم، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿عاقبة﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿المنذرين﴾</span></span> مفعول به.</p></div>"
  37,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مستثنى منصوب، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عباد﴾</span></span>.</p></div>"
  37,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد نادانا نوح﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿نادانا نوح﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿نوح﴾</span></span> فاعل مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلنعم المجيبون﴾</span></span>: الفاء عاطفة، واللام جواب قسم محذوف، وجواب كل من القسمين محذوف، لدلالة السياق عليه، و<span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> فعل ماض جامد لإنشاء المدح، و<span class="hlt"><span class="qpc-hafs">﴿المجيبون﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span>، والمخصوص بالمدح محذوف تقديره: نحن.</p></div>"
  37,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجيناه وأهله من الكرب العظيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أهله﴾</span></span> عطف على الهاء، أو مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿من الكرب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> نعت للكرب.</p></div>"
  37,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا ذريته هم الباقين﴾</span></span>: الواو عاطفة، وجعلنا عطف على نجيناه، وذريته مفعول به، وهم ضمير فصل لا محل له من الإعراب، والباقين مفعول جعلنا الثاني.</p></div>"
  37,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليه، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على نوح في العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ. و<span class="hlt"><span class="qpc-hafs">﴿على نوح﴾</span></span> جار ومجرور متعلقان بمحذوف خبر. و<span class="hlt"><span class="qpc-hafs">﴿في العالمين﴾</span></span> جار ومجرور متعلقان بالخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿سلام على نوح في العالمين﴾</span></span> تفسيرية لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، لا محل لها من الإعراب.</p></div>"
  37,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عبادنا﴾</span></span>.</p></div>"
  37,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أغرقنا الآخرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للتراخي، و<span class="hlt"><span class="qpc-hafs">﴿أغرقنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الآخرين﴾</span></span> مفعول به.</p></div>"
  37,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن من شيعته لإبراهيم﴾</span></span>: الواو عاطفة، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿من شيعته﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span> اسمها المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن من شيعته...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  37,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ جاء ربه بقلب سليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، يعود على إبراهيم، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بقلب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وسليم صفة.</p></div>"
  37,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لأبيه وقومه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> في الآية السابقة، أو ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سليم﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لأبيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماذا تعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ماذا تعبدون﴾</span></span> مقول القول.</p></div>"
  37,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئفكا آلهة دون الله تريدون﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، و<span class="hlt"><span class="qpc-hafs">﴿إفكًا﴾</span></span> مفعول من أجله، أي: أتريدون آلهة دون الله إفكًا، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿دون الله﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿إفكا﴾</span></span> مفعول به بـ<span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> بدل منه، أو<span class="hlt"><span class="qpc-hafs">﴿إفكا﴾</span></span> حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span>، أي: أتريدون آلهة آفكين، أو: ذوي إفك، و<span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span> فعل مضارع مرفوع والواو فاعل.</p></div>"
  37,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما ظنكم برب العالمين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام للإنكار والتوبيخ في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ظنكم﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿برب العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظنكم﴾</span></span>.</p></div>"
  37,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنظر نظرة في النجوم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نظر﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿نظرة﴾</span></span> نائب عن المفعول المطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿في النجوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نظر﴾</span></span>، قيل: الكلام على حذف مضاف، أي: في علم النجوم.</p></div>"
  37,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقال إني سقيم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿سقيم﴾</span></span> خبرها، وإن وما في حيزها في محل نصب مقول القول.</p></div>"
  37,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتولوا عنه مدبرين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مدبرين﴾</span></span> حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>.</p></div>"
  37,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فراغ إلى آلهتهم فقال ألا تأكلون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿إلى آلهتهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span>، والهمزة للاستفهام، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة الاستفهام مقول القول.</p></div>"
  37,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لكم لا تنطقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تنطقون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تنطقون﴾</span></span> في محل نصب على الحال، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لكم﴾</span></span> مقول قول محذوف، والتقدير: فلم ينطقوا فقال: ما لكم لا تنطقون.</p></div>"
  37,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فراغ عليهم ضربا باليمين﴾</span></span>: الفاء عاطفة على محذوف تقديره: فلم يجيبوا فراغ، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ضربًا﴾</span></span> مصدر واقع موقع الحال، أي: فراغ عليهم ضاربًا، أو مفعول مطلق لفعل مقدر، أي: يضرب ضربًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿يضرب ضربًا﴾</span></span> في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿باليمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضربًا﴾</span></span> أو بعامله.</p></div>"
  37,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقبلوا إليه يزفون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿يزفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يزفون﴾</span></span> في محل نصب على الحال من فاعل <span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span>.</p></div>"
  37,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أتعبدون ما تنحتون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، والهمزة للاستفهام الإنكاري التوبيخي، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنحتون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: نحتكم، أو نكرة موصوفة، أي: منحوتكم، وقيل: استفهامية للتوبيخ، أي: وأي شيء تعملون؟</p></div>"
  37,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله خلقكم﴾</span></span>: الواو حالية، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> خبر، وهي فعل ماض، والفاعل مستتر، والكاف مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿والله خلقكم﴾</span></span> في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تعملون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أو مصدرية، وقيل: هي استفهامية للتوبيخ، أي: وأي شيء تعملون؟ وقيل: هي نافية، أي: العمل في الحقيقة ليس لكم فأنتم لا تعملون شيئًا، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ابنوا له بنيانا فألقوه في الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span> فعل أمر، والواو فاعل، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بنيانًا﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فألقوه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span>، وهو فعل أمر، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوه﴾</span></span>.</p></div>"
  37,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأرادوا به كيدا فجعلناهم الأسفلين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كيدًا﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فجعلناهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فأرادوا﴾</span></span>، وهو فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿الأسفلين﴾</span></span> مفعول به ثان.</p></div>"
  37,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال إني ذاهب إلى ربي سيهدين﴾</span></span>: الواو عاطفة على محذوف تقديره: فخرج من النار سالمًا، وقال...، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ذاهب﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذاهب﴾</span></span>، والسين حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يهدين﴾</span></span> فعل مضارع مرفوع بضمة مقدرة على الياء، والنون للوقاية، وياء الضمير المحذوفة لرعاية الفواصل مفعول به، أي: سيهديني.</p></div>"
  37,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب هب لي من الصالحين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span> فعل دعاء مبني على السكون، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الصالحين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: ولدًا من الصالحين.</p></div>"
  37,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبشرناه بغلام حليم﴾</span></span>: الفاء عاطفة على محذوف تقديره: فاستجبنا له، و<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بغلام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حليم﴾</span></span> صفة.</p></div>"
  37,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما بلغ معه السعي﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿بلغ﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿السعي﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا بني إني أرى في المنام﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿بني﴾</span></span> منادى مضاف لياء المتكلم، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، وأرى فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في المنام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أني أذبحك فانظر ماذا ترى﴾</span></span>: أن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أذبحك﴾</span></span> فعل مضارع، والفاعل مستتر، والكاف مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذبحك﴾</span></span> خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿أني أذبحك﴾</span></span> سدت مسد مفعول <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فانظر﴾</span></span> الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> فعل أمر مبني على السكون، وفاعله مستتر وجوبًا تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> استفهامية منصوبة بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> موصولة خبر، أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> بمعنى الذي، فهي معمول لـ<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span> فعل مضارع مرفوع. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلما بلغ معه...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا أبت افعل ما تؤمر ستجدني إن شاء الله من الصابرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أبت﴾</span></span> منادى مضاف إلى ياء المتكلم المعوض عنها بالتاء، والتاء في محل جر، لأن المعوض عنه كذلك، و<span class="hlt"><span class="qpc-hafs">﴿افعل﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول <span class="hlt"><span class="qpc-hafs">﴿افعل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تؤمر﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف تقديره: ما تؤمر به، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: أمرك، على إضافة المصدر للمفعول، والسين حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿تجدني﴾</span></span> فعل مضارع مرفوع، والنون للوقاية، والفاعل ضمير مستتر تقديره: أنت، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الصابرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  37,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أسلما وتله للجبين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حينية أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿أسلما﴾</span></span> فعل ماض، والألف فاعل، <span class="hlt"><span class="qpc-hafs">﴿وتله﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تله﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، أي: إبراهيم، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للجبين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> محذوف تقديره: ظهر صبرهما، أو: أجزلنا لهما أجرهما.</p></div>"
  37,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وناديناه أن يا إبراهيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ناديناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، لأن النداء فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span> منادى مفرد علم مبني على الضم.</p></div>"
  37,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد صدقت الرؤيا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿صدقت﴾</span></span> فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الرؤيا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي المحسنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لهو البلاء المبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿البلاء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهو البلاء المبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿البلاء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المبين﴾</span></span> نعت للبلاء.</p></div>"
  37,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفديناه بذبح عظيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿فديناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ناديناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بذبح﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فديناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عظيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذبح﴾</span></span>.</p></div>"
  37,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليه، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على إبراهيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على إبراهيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سلام على إبراهيم﴾</span></span> مقول قول محذوف، أي: يقال له هذا في الآخرين.</p></div>"
  37,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نجزي المحسنين﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به.</p></div>"
  37,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> صفة، والجملة تعليلية لا محل لها من الإعراب.</p></div>"
  37,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبشرناه بإسحاق نبيا من الصالحين﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بإسحاق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نبيا﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿إسحاق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الصالحين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نبيا﴾</span></span>، أو حال ثانية.</p></div>"
  37,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وباركنا عليه وعلى إسحاق﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿باركنا﴾</span></span> عطف على ما تقدم، وهو فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿باركنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على إسحاق﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ذريتهما محسن وظالم لنفسه مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من ذريتهما﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿محسن﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿محسن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span>.</p></div>"
  37,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد مننا على موسى وهارون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، أو الواو عاطفة على ما سبق، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على موسى وهارون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>.</p></div>"
  37,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجيناهما وقومهما من الكرب العظيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نجيناهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>، وهو فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قومهما﴾</span></span> مفعول معه، أو معطوف على الضمير في <span class="hlt"><span class="qpc-hafs">﴿نجيناهما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الكرب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناهما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الكرب﴾</span></span>.</p></div>"
  37,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونصرناهم فكانوا هم الغالبين﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿نصرناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فكانوا﴾</span></span> الفاء عاطفة، وكان فعل ماض ناقص، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل لا محل له من الإعراب، وقيل: تأكيد للواو، أو بدل منها، و<span class="hlt"><span class="qpc-hafs">﴿الغالبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"
  37,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناهما الكتاب المستبين﴾</span></span>: عطف على ما تقدم، <span class="hlt"><span class="qpc-hafs">﴿آتيناهما﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿المستبين﴾</span></span> نعت للكتاب.</p></div>"
  37,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهديناهما الصراط المستقيم﴾</span></span>: عطف على ما تقدم، <span class="hlt"><span class="qpc-hafs">﴿وهديناهما﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿الصراط﴾</span></span> مفعول به ثان، أو منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿المستقيم﴾</span></span> نعت للصراط.</p></div>"
  37,119,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليهما في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليهما، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,120,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على موسى وهارون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على موسى وهارون﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  37,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي المحسنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,122,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهما من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> نعت.</p></div>"
  37,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن إلياس لمن المرسلين﴾</span></span>: الواو عاطفة أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿إلياس﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن إلياس...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  37,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لقومه ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وقيل: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لقومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والجملة مقول القول.</p></div>"
  37,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتدعون بعلا﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بعلًا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتذرون أحسن الخالقين﴾</span></span>: الواو عاطفة، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span>، أو الواو حالية، والجملة في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿تذرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أحسن الخالقين﴾</span></span> مفعول به.</p></div>"
  37,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله ربكم ورب آبائكم الأولين﴾</span></span>: لفظ الجلالة بدل من <span class="hlt"><span class="qpc-hafs">﴿أحسن الخالقين﴾</span></span> منصوب، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ورب آبائكم الأولين﴾</span></span> عطف.</p></div>"
  37,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذبوه﴾</span></span> فعل ماض، والواو فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم لمحضرون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر إن.</p></div>"
  37,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> استثناء متصل من فاعل <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليه، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,130,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على إل ياسين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على إل ياسين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سلام على إل ياسين﴾</span></span> مقول قول محذوف، أي: يقال له هذا في الآخرين.</p></div>"
  37,131,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي المحسنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,132,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> صفة، والجملة تعليلية لا محل لها من الإعراب.</p></div>"
  37,133,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن لوطا لمن المرسلين﴾</span></span>: الواو عاطفة أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لوطا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن لوطا...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  37,134,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ نجيناه وأهله أجمعين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، و<span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿أهله﴾</span></span> عطف على الهاء، و<span class="hlt"><span class="qpc-hafs">﴿أجمعين﴾</span></span> تأكيد.</p></div>"
  37,135,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿عجوزًا﴾</span></span> مستثنى منصوب، و<span class="hlt"><span class="qpc-hafs">﴿في الغابرين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p></div>"
  37,136,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم دمرنا الآخرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿دمرنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الآخرين﴾</span></span> مفعول به.</p></div>"
  37,137,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنكم لتمرون عليهم مصبحين﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تمرون﴾</span></span> فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مصبحين﴾</span></span> حال.</p></div>"
  37,138,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبالليل﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿بالليل﴾</span></span> جار ومجرور متعلقان بمحذوف عطف على <span class="hlt"><span class="qpc-hafs">﴿مصبحين﴾</span></span>، فهو حال أخرى، والباء للملابسة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تعقلون﴾</span></span>: الهمزة داخلة على مقدر عطف عليه قوله: فلا تعقلون، والتقدير: تشاهدون ذلك فلا تعقلون، أي: تعتبرون به، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,139,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن يونس لمن المرسلين﴾</span></span>: الواو عاطفة، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿يونس﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن يونس...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  37,140,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ أبق إلى الفلك المشحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>، أي: هو من المرسلين حتى في هذه الحالة، و<span class="hlt"><span class="qpc-hafs">﴿أبق﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أبق﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿إلى الفلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المشحون﴾</span></span> نعت.</p></div>"
  37,141,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فساهم فكان من المدحضين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ساهم﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، <span class="hlt"><span class="qpc-hafs">﴿فكان﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فساهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المدحضين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  37,142,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالتقمه الحوت وهو مليم﴾</span></span>: الفاء عاطفة على محذوف يدرك من سياق الكلام، أي: فألقوه في البحر فالتقمه الحوت، وقيل: فألقى نفسه في الماء. و<span class="hlt"><span class="qpc-hafs">﴿التقمه﴾</span></span> فعل ماض، والهاء مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الحوت﴾</span></span> فاعل مؤخر، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مليم﴾</span></span> خبر، والجملة في محل نصب حال.</p></div>"
  37,143,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلولا أنه كان من المسبحين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، واسم <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المسبحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، وأن وما في حيزها مبتدأ، والخبر محذوف وجوبًا.</p></div>"
  37,144,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للبث في بطنه إلى يوم يبعثون﴾</span></span>: اللام واقعة في جواب لولا، و<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span> فعل ماض، والفاعل ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿في بطنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، أو بمحذوف حال، أي: مستقرًا، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  37,145,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنبذناه بالعراء﴾</span></span>: الفاء عاطفة على محذوف، أي: أمرنا الحوت بنبذه فنبذناه، و<span class="hlt"><span class="qpc-hafs">﴿نبذناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو سقيم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿سقيم﴾</span></span> خبر.</p></div>"
  37,146,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنبتنا عليه شجرة من يقطين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فنبذناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من يقطين﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span>.</p></div>"
  37,147,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأرسلناه إلى مائة ألف أو يزيدون﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أرسلناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى مائة ألف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يزيدون﴾</span></span> فعل مضارع مرفوع.</p></div>"
  37,148,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فآمنوا فمتعناهم إلى حين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> فعل ماض مبني على الضم، والواو فاعل، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى حين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span>.</p></div>"
  37,149,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستفتهم ألربك البنات ولهم البنون﴾</span></span>: الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿استفتهم﴾</span></span> فعل أمر، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿لربك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿البنات﴾</span></span> مبتدأ مؤخر، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿البنون﴾</span></span> مبتدأ مؤخر.</p></div>"
  37,150,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم خلقنا الملائكة إناثا وهم شاهدون﴾</span></span>: أم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الملائكة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إناثًا﴾</span></span> حال، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿شاهدون﴾</span></span> خبر، والجملة نصب على الحال.</p></div>"
  37,151,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إنهم من إفكهم ليقولون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> أداة تنبيه، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من إفكهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>، ويقولون فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,152,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولد الله وإنهم لكاذبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولد﴾</span></span> فعل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، والجملة مقول قولهم، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿كاذبون﴾</span></span> خبرها.</p></div>"
  37,153,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أصطفى البنات على البنين﴾</span></span>: الهمزة المفتوحة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿اصطفى﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، يعود على الله، و<span class="hlt"><span class="qpc-hafs">﴿البنات﴾</span></span> مفعول به منصوب بالكسرة، و<span class="hlt"><span class="qpc-hafs">﴿على البنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصطفى﴾</span></span>.</p></div>"
  37,154,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والتقدير: ما ثبت واستقر لكم، وهو استفهام إنكاري، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كيف تحكمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب على الحال، وهو استفهام إنكار وتعجيب من حكمهم، و<span class="hlt"><span class="qpc-hafs">﴿تحكمون﴾</span></span> فعل مضارع، وواو الجماعة فاعل، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  37,155,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تذكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف مفهوم من السياق، أي: أعميتم عن الحقائق وضللتم عن الشواهد، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,156,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لكم سلطان مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف للإضراب الانتقالي، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>.</p></div>"
  37,157,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتوا بكتابكم إن كنتم صادقين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكتابكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿صادقين﴾</span></span> خبرها، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  37,158,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلوا بينه وبين الجنة نسبا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينه﴾</span></span> ظرف متعلق بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بين الجنة﴾</span></span> عطف، و<span class="hlt"><span class="qpc-hafs">﴿نسبًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span> الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجعلوا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولقد علمت الجنة إنهم لمحضرون﴾</span></span>: الواو حالية، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿علمت﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبرها، وإن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿علمت﴾</span></span>.</p></div>"
  37,159,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>: نائب مفعول مطلق منصوب بفعل محذوف. ولفظ الجلالة: مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span>: فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿سبحان الله...﴾</span></span> اعتراضية، لا محل لها من الإعراب.</p></div>"
  37,160,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مستثنى من الواو في <span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,161,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنكم وما تعبدون﴾</span></span>: الفاء تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ والكاف اسمها، والواو واو المعية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> معطوفة على اسم إن، وخبر إن جملة <span class="hlt"><span class="qpc-hafs">﴿ما أنتم﴾</span></span> في الآية التالية.</p></div>"
  37,162,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أنتم عليه بفاتنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاتنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بفاتنين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿فاتنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنتم...﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> في الآية السابقة.</p></div>"
  37,163,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من هو صال الجحيم﴾</span></span>: إلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مفعول فاتنين، والاستثناء مفرغ، أو مفعول فاتنين محذوف، أي أحدًا، فتكون إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مستثنى من المفعول المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وصال خبر مرفوع بالضمة المقدرة على الياء المحذوفة لالتقاء الساكنين، والجحيم مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو صال الجحيم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  37,164,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما منا إلا له مقام معلوم﴾</span></span>: الواو استئنافية، وما نافية، ومنا خبر مقدم، والمبتدأ محذوف، أقيمت صفته مقامه، والتقدير: وما منا أحد إلا له مقام معلوم، أو منا صفة لمحذوف هو المبتدأ، والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿إلا له مقام معلوم﴾</span></span> وإلا أداة حصر، وله خبر مقدم، ومقام مبتدأ مؤخر، ومعلوم صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما منا إلا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  37,165,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لنحن الصافون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الصافون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الصافون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، ومفعول <span class="hlt"><span class="qpc-hafs">﴿الصافون﴾</span></span> محذوف، أي: نصف أقدامنا.</p></div>"
  37,166,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لنحن المسبحون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المسبحون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿المسبحون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,167,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كانوا ليقولون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"
  37,168,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لو أن عندنا ذكرا من الأولين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿عندنا﴾</span></span> ظرف متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المقدم، و<span class="hlt"><span class="qpc-hafs">﴿ذكرا﴾</span></span> اسم أن، وأن وما في حيزها فاعل لفعل محذوف، أي: ثبت، و<span class="hlt"><span class="qpc-hafs">﴿من الأولين﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>.</p></div>"
  37,169,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لكنا عباد الله المخلصين﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> خبرها، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,170,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكفروا به فسوف يعلمون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,171,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد سبقت كلمتنا لعبادنا المرسلين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿كلمتنا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لعبادنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عبادنا﴾</span></span>.</p></div>"
  37,172,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم لهم المنصورون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المنصورون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿المنصورون﴾</span></span> خبر إن.</p></div>"
  37,173,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن جندنا لهم الغالبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿جندنا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الغالبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الغالبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,174,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتول عنهم حتى حين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span> اسم مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>.</p></div>"
  37,175,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأبصرهم فسوف يبصرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبصرهم﴾</span></span> فعل أمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، والفاء رابطة لجواب الطلب، و<span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يبصرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والمفعول به محذوف، أي: ما يحيق بهم جزاء كفرهم.</p></div>"
  37,176,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف يقدر بحسب المقام، و<span class="hlt"><span class="qpc-hafs">﴿بعذابنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يستعجلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,177,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا نزل بساحتهم فساء صباح المنذرين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، أي: العذاب، و<span class="hlt"><span class="qpc-hafs">﴿بساحتهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، والفاء رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل جامد لإنشاء الذم، و<span class="hlt"><span class="qpc-hafs">﴿صباح المنذرين﴾</span></span> فاعل، والمخصوص بالذم محذوف تقديره: صباحهم، وقيل: ضمير <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> يعود على المخصوص، والتمييز محذوف، و<span class="hlt"><span class="qpc-hafs">﴿صباح المنذرين﴾</span></span> مخصوص بالذم وليس فاعلا.</p></div>"
  37,178,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتول عنهم حتى حين﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span> اسم مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>.</p></div>"
  37,179,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأبصر فسوف يبصرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبصر﴾</span></span> فعل أمر، والفاعل مستتر، والمفعول به مستتر أيضا، والفاء رابطة لجواب الطلب، و<span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يبصرون﴾</span></span> فعل مضارع، والواو فاعل، والمفعول به محذوف، أي: ما يحيق بهم جزاء كفرهم.</p></div>"
  37,180,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان ربك رب العزة عما يصفون﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، وربك: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿رب العزة﴾</span></span> بدل، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  37,181,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسلام على المرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  37,182,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والحمد لله رب العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الحمد﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿رب العالمين﴾</span></span> بدل، أو صفة.</p></div>"
