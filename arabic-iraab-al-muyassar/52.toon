quran[49]{c,v,t}:
  52,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والطور﴾</span></span>: الواو واو القسم، والطور مقسم به مجرور بالواو، وعلامة جره الكسرة، متعلق بمحذوف تقديره أقسم، والجملة لا محل لها من الإعراب، لأنها ابتدائية.</p></div>"
  52,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكتاب مسطور﴾</span></span>: معطوف بالواو مجرور بالكسرة، ومسطور نعت مجرور بالكسرة.</p></div>"
  52,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في رق منشور﴾</span></span>: في رق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسطور﴾</span></span>، أو نعت آخر لكتاب، ومنشور نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رق﴾</span></span> مجرور بالكسرة.</p></div>"
  52,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والبيت المعمور﴾</span></span>: الواو عاطفة، والبيت معطوف بالواو مجرور بالكسرة، والمعمور نعت مجرور بالكسرة.</p></div>"
  52,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسقف المرفوع﴾</span></span>: الواو عاطفة، والسقف معطوف بالواو مجرور بالكسرة، والمرفوع: نعت مجرور.</p></div>"
  52,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والبحر المسجور﴾</span></span>: الواو عاطفة، والبحر معطوف بالواو مجرور بالكسرة، والمسجور نعت مجرور بالكسرة.</p></div>"
  52,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن عذاب ربك لواقع﴾</span></span>: إن حرف ناسخ، وعذاب اسمها، وربك مضاف إليه، واللام لام القسم عوض عن المزحلقة تفيد التوكيد، وواقع خبر إن، والجملة جواب القسم.</p></div>"
  52,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما له من دافع﴾</span></span>: ما نافية. وله: جار ومجرور متعلقان بمحذوف خبر مقدم. ومن: حرف جر صلة. ودافع: مجرور لفظًا مرفوع محلا على أنه مبتدأ مؤخر. وهذه الجملة خبر ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>، أي: واقع غير مدفوع، أو اعتراضية بين الظرف في قوله: <span class="hlt"><span class="qpc-hafs">﴿يوم تمور السماء﴾</span></span>، وبين متعلقه وهو قوله: <span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>، فلا محل لها من الإعراب.</p></div>"
  52,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم تمور السماء مورا﴾</span></span>: الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>، أي: يقع العذاب في ذلك اليوم. وجملة <span class="hlt"><span class="qpc-hafs">﴿ما له من دافع﴾</span></span> اعتراضية بين الظرف ومتعلقه. وقيل: الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿دافع﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿تمور السماء﴾</span></span> في محل جر بإضافة الظرف إليها، ومورًا مفعول مطلق منصوب بالفتحة.</p></div>"
  52,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتسير الجبال سيرا﴾</span></span>: الجملة عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿تمور السماء مورًا﴾</span></span>، والواو عاطفة، وتسير فعل مضارع والجبال فاعل مرفوع وسيرًا مفعول مطلق منصوب بالفتحة.</p></div>"
  52,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فويل يومئذ للمكذبين﴾</span></span>: الفاء الفصيحة، والتقدير: إذا كان ما ذكر فويل لمن يكذب الله ورسوله. و<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span> مبتدأ ساغ الابتداء به لتضمنه معنى الدعاء، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span> أو بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: فويل لهم يوم إذ يقع ذلك، وللمكذبين: جار ومجرور متعلقان بمحذوف خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>.</p></div>"
  52,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين هم في خوض يلعبون﴾</span></span>: الذين نعت للمكذبين، وهم مبتدأ، وفي خوض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلعبون﴾</span></span>، وجملة يلعبون خبر هم، والجملة لا محل لها من الإعراب، لأنها صلة الذين.</p></div>"
  52,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يدعون إلى نار جهنم دعا﴾</span></span>: الظرف بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم تمور السماء مورًا﴾</span></span> أو من <span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> قبله، وجملة يدعون في محل جر بإضافة الظرف إليها، ويدعون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وإلى نار جهنم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، ودعًّا مفعول مطلق.</p></div>"
  52,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذه النار التي كنتم بها تكذبون﴾</span></span>: الجملة منصوبة بقول محذوف، أي: يقال لهم ذلك، وهذه مبتدأ، والنار خبر، والتي صفة، وجملة كنتم صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب. وكان فعل ماض ناسخ، والتاء اسمها، وبها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span>، وجملة تكذبون خبر كان.</p></div>"
  52,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفسحر هذا﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف تقديره: كنتم تقولون للوحي: هذا سحر، أفسحر هذا؟ وسحر خبر مقدم، وهذا مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم أنتم لا تبصرون﴾</span></span>: أم: متصلة، وقيل: منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أأنتم لا تبصرون؟ وأنتم مبتدأ، وجملة لا تبصرون خبر.</p></div>"
  52,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اصلوها فاصبروا أو لا تصبروا سواء عليكم﴾</span></span>: فعل أمر وفاعل ومفعول به، والفاء عاطفة، واصبروا فعل أمر وفاعل، وأو حرف عطف، ولا ناهية، وتصبروا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وسواء خبر لمبتدأ محذوف، أي: صبركم، وتركه سواء، وعليكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>، وقيل: مبتدأ خبره محذوف، أي: سواء عليكم الأمران.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما تجزون ما كنتم تعملون﴾</span></span>: إنما كافة ومكفوفة، وتجزون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وما اسم موصول مفعول به ثانٍ، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم تعملون﴾</span></span> صلة الموصول لا محل لها من الإعراب، وكان فعل ماض ناقص، والتاء اسمها، وجملة تعملون خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنما تجزون...﴾</span></span> تعليلية للاستواء.</p></div>"
  52,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في جنات ونعيم﴾</span></span>: إن حرف ناسخ، والمتقين اسمها، وفي جنات جار ومجرور متعلقان بمحذوف خبر إن، ونعيم عطف على جنات، والكلام مستأنف لا محل له من الإعراب.</p></div>"
  52,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاكهين بما آتاهم ربهم ووقاهم ربهم عذاب الجحيم﴾</span></span>: فاكهين: حال، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاكهين﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتاهم﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما دخلت عليه في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاكهين﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتاهم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آتاهم﴾</span></span> فعل ماض، والهاء مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span> فاعل مؤخر. <span class="hlt"><span class="qpc-hafs">﴿ووقاهم﴾</span></span> الواو عاطفة ووقاهم: فعل ماض، والفاعل مستتر، والضمير الظاهر في محل نصب مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿وقاهم﴾</span></span> عطف على جملة الصلة، أي: فاكهين بإيتاء ربهم وبوقايتهم له عذاب الجحيم. أو أن الواو حالية، والجملة في محل نصب على الحال، مع تقدير: قد، عند من يشترط اقترانها بالماضي الواقع حالًا.</p></div>"
  52,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>: فعل أمر، والواو فاعل، والجملة مقول قول محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿واشربوا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اشربوا﴾</span></span> فعل أمر، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿هنيئا﴾</span></span>: حال من المفعول به المقدر، أي: مُهَنَّأً، أو: نائب عن المفعول المطلق، لأنه صفة للمصدر، أي: أكلا هنيئا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا أو اشربوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span>: فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر كان.</p></div>"
  52,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متكئين على سرر مصفوفة وزوجناهم بحور عين﴾</span></span>: متكئين حال من الضمير المستكن في قوله: <span class="hlt"><span class="qpc-hafs">﴿في جنات﴾</span></span>، أي: كائنون في جنات حال كونهم متكئين، أو من فاعل <span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، أو من مفعول <span class="hlt"><span class="qpc-hafs">﴿آتاهم﴾</span></span>، أو من مفعول <span class="hlt"><span class="qpc-hafs">﴿وقاهم﴾</span></span>، وعلى سرر جار ومجرور متعلقان بمتكئين، ومصفوفة نعت لسرر، والواو حرف عطف، وزوجناهم فعل وفاعل ومفعول به، وبحور جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span>، وعين نعت لحور.</p></div>"
  52,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا واتبعتهم ذريتهم بإيمان ألحقنا بهم ذريتهم﴾</span></span>: الواو استئنافية، والذين مبتدأ والخبر جملة ألحقنا بهم ذريتهم. وقيل: منصوب بفعل محذوف على تقدير: وأكرمنا الذين آمنوا. وقيل: <span class="hlt"><span class="qpc-hafs">﴿الذين آمنوا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿حور عين﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب. واتبعتهم ذريتهم عطف على <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، وبإيمان حال من ذريتهم، وجملة ألحقنا بهم ذريتهم خبر الذين، وجملة <span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما ألتناهم من عملهم من شيء كل امرئ بما كسب رهين﴾</span></span>: الواو حرف عطف وألتناهم فعل وفاعل ومفعول به، ومن عملهم حال، ومن حرف جر صلة، وشيء مجرور لفظًا منصوب محلًّا، لأنه مفعول ثانٍ، وكل مبتدأ، وامرئ مضاف إليه، وبما الباء حرف جر، وما موصولة، أو مصدرية، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رهين﴾</span></span>، ورهين خبر كل.</p></div>"
  52,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأمددناهم بفاكهة ولحم مما يشتهون﴾</span></span>: الواو عاطفة، وأمددناهم عطف على ما تقدم، وبفاكهة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمددناهم﴾</span></span>، ولحم عطف على فاكهة، ومما صفة، وجملة يشتهون صلة الموصول لا محل لها من الإعراب.</p></div>"
  52,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يتنازعون فيها كأسا لا لغو فيها ولا تأثيم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وقيل: نصب على الحال من مفعول أمددناهم، ويتنازعون فعل مضارع وفاعل، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتنازعون﴾</span></span>، وكأسًا مفعول به، ولا نافية للجنس أُهملت لتكررها، ولغو مبتدأ خبره <span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> ولا تأثيم عطف عليه وسوغ الابتداء به تقدم النفي عليه.</p></div>"
  52,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويطوف عليهم غلمان لهم كأنهم لؤلؤ مكنون﴾</span></span>: الواو حرف عطف، ويطوف فعل مضارع مرفوع، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يطو ف﴾</span></span>، وغلمان فاعل يطوف، ولهم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿غلمان﴾</span></span>، وكأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، ولؤلؤ خبرها، ومكنون صفة لؤلؤ، وجملة كأنهم صفة ثانية.</p></div>"
  52,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span></span>: الواو حرف عطف، وأقبل بعضهم فعل وفاعل، وعلى بعض جار ومجرور متعلقان بأقبل، وجملة يتساءلون حال.</p></div>"
  52,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا كنا قبل في أهلنا مشفقين﴾</span></span>: قالوا فعل وفاعل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة كنا خبرها، وجملة إنا كنا مقول القول، وقبل ظرف مبني على الضم لانقطاعه عن الإضافة لفظًا لا معنى، والظرف متعلق بمحذوف حال، ومشفقين خبر كان.</p></div>"
  52,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن الله علينا ووقانا عذاب السموم﴾</span></span>: الفاء حرف عطف، ومن الله فعل وفاعل، وعلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مَنَّ﴾</span></span>، ووقانا عطف على مَنَّ، وعذاب السموم مفعول به ثانٍ.</p></div>"
  52,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كنا من قبل ندعوه إنه هو البر الرحيم﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومن قبل حال، وجملة ندعوه خبر كنا، وجملة كنا خبر إن، وإن حرف ناسخ، والهاء اسمها، وهو ضمير فصل، والبر الرحيم خبران لإنه، وجملة إنه تعليلية لا محل لها من الإعراب.</p></div>"
  52,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذكر فما أنت بنعمت ربك بكاهن ولا مجنون﴾</span></span>: الفاء الفصيحة، وذكر فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء تعليلية للأمر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بنعمة﴾</span></span> جار ومجرور متعلقان بمضمون الجملة المنفية، والباء للسببية، أي: ما أنت بكاهن ولا مجنون بسبب نعمة ربك عليك، وقيل: الجار والمجرور متعلقان بمحذوف حال والعامل فيها <span class="hlt"><span class="qpc-hafs">﴿بكاهن﴾</span></span> أو <span class="hlt"><span class="qpc-hafs">﴿مجنون﴾</span></span> والباء للملابسة، والتقدير: ما أنت كاهنًا ولا مجنونًا حال كونك متلبسًا بنعمة ربك، وعلى هذا فهي حال لازمة، وقيل: الباء للقسم، و<span class="hlt"><span class="qpc-hafs">﴿نعمة ربك﴾</span></span> مقسَم به متوسط بين اسم <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية وخبرها فيتعلق الجار والمجرور بفعل محذوف تقديره: أقسم، وجواب القسم محذوف، أي: بنعمةِ ربك ما أنت بكاهن ولا مجنون. و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مضاف إليه، والكاف ضمير في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بكاهن﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿كاهن﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وقوله تعالى <span class="hlt"><span class="qpc-hafs">﴿ولا مجنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿كاهن﴾</span></span>.</p></div>"
  52,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون شاعر نتربص به ريب المنون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أيقولون شاعر؟ و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿شاعر﴾</span></span> خبر لمبتدأ محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿نتربص به﴾</span></span> صفة لشاعر، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتربص﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ريب المنون﴾</span></span> مفعول به.</p></div>"
  52,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل تربصوا فإني معكم من المتربصين﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، وتربصوا فعل أمر مبني على حذف النون، والواو فاعل، والفاء تعليل للأمر المقصود به التهديد، وإن حرف ناسخ، والياء اسمها، ومعكم ظرف متعلق بمحذوف حال، ومن المتربصين خبر إن، وجملة تربصوا مقول القول.</p></div>"
  52,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم تأمرهم أحلامهم بهذا﴾</span></span>: أم حرف عطف بمعنى بل، وتأمرهم فعل مضارع، ومفعول به مقدم، وأحلامهم فاعل، وبهذا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأمرهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم هم قوم طاغون﴾</span></span>: أم عاطفة، وهم مبتدأ وقوم خبر، وطاغون نعت.</p></div>"
  52,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون تقوله بل لا يؤمنون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أيقولون تقوله؟ والهمزة للاستفهام الإنكاري، أو <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> متصلة، وحينئذ فلا بد من تقدير جملة ليصح التعادل، والتقدير: أيقرون به أم يقولون: تقوّله، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوّله﴾</span></span> مقول القول. و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع بثبوت النون والواو فاعل، تقوله فعل ماض ومفعول به، والفاعل مستتر تقديره: هو.</p></div>"
  52,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فليأتوا بحديث مثله﴾</span></span>: الفاء الفصيحة واللام لام الأمر، ويأتوا فعل مضارع مجزوم بلام الأمر، والواو فاعل، وبحديث جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتوا﴾</span></span>، ومثله صفة لحديث.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كانوا صادقين﴾</span></span>: إن شرطية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وصادقين خبرها، وجواب إن محذوف دل عليه ما قبله.</p></div>"
  52,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم خلقوا من غير شيء﴾</span></span>: عطف على ما تقدم، ومن غير شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقوا﴾</span></span>، وأم هم الخالقون مبتدأ وخبر.</p></div>"
  52,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم خلقوا السماوات والأرض﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿خلقوا﴾</span></span> فعل ماض وفاعله، والسماوات مفعول به منصوب بالكسرة، والأرض معطوف بالواو منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل لا يوقنون﴾</span></span>: بل: حرف للإضراب الانتقالي، ولا نافية ويوقنون مضارع مرفوع بثبوت النون والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يوقنون﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  52,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم عندهم خزائن ربك﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والظرف متعلق بمحذوف خبر مقدم، وخزائن مبتدأ مؤخر، وهم مبتدأ، والمسيطرون خبر.</p></div>"
  52,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لهم سلم يستمعون فيه فليأت مستمعهم بسلطان مبين﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وسلم مبتدأ مؤخر، وجملة يستمعون نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سلم﴾</span></span>، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستمعون﴾</span></span>، فليأت: الفاء الفصيحة، لأنها جواب شرط مقدر تقديره: إن ادعوا ذلك فليأت، واللام لام الأمر، ويأت فعل مضارع مجزوم بلام الأمر، ومستمعهم فاعل، وبسلطان جار ومجرور متعلقان بيأت، ومبين صفة.</p></div>"
  52,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم له البنات ولكم البنون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿البنات﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لكم البنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿له البنات﴾</span></span>.</p></div>"
  52,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم تسألهم أجرا فهم من مغرم مثقلون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، وتسألهم فعل مضارع، وفاعل مستتر تقديره: أنت، ومفعول به أول، وأجرًا مفعول به ثانٍ، والفاء حرف عطف، وهم مبتدأ، ومن مغرم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مثقلون﴾</span></span>، ومثقلون خبر.</p></div>"
  52,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم عندهم الغيب فهم يكتبون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والظرف متعلق بمحذوف خبر مقدم، والغيب مبتدأ مؤخر، والفاء عاطفة، وهم مبتدأ، وجملة يكتبون خبر.</p></div>"
  52,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يريدون كيدا فالذين كفروا هم المكيدون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، ويريدون فعل مضارع مرفوع، والواو فاعل، وكيدًا مفعول به، والفاء عاطفة، والذين مبتدأ، وهو من وضع الظاهر موضع المضمر، وقد تقدمت الإشارة إليه، وجملة كفروا صلة الموصول لا محل لها من الإعراب، وهم مبتدأ، والمكيدون خبره، والجملة الاسمية خبر الذين.</p></div>"
  52,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لهم إله غير الله سبحان الله عما يشركون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وإله مبتدأ مؤخر، وغير الله نعت لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>، وسبحان نائب مفعول مطلق منصوب بفعل محذوف، واسم الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span> لا محل لها من الإعراب، لأن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة أو مصدرية.</p></div>"
  52,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن يروا كسفا من السماء ساقطا يقولوا سحاب مركوم﴾</span></span>: الواو عاطفة، ويروا فعل الشرط مجزوم، وعلامة جزمه حذف النون، والواو فاعل، وكسفًا مفعول به، ومن السماء صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كسفًا﴾</span></span>، وساقطا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كسفًا﴾</span></span>، وجملة الجواب لا محل لها من الإعراب، ويقولوا جواب الشرط، وسحاب خبر لمبتدأ محذوف، ومركوم صفة لسحاب.</p></div>"
  52,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذرهم حتى يلاقوا يومهم الذي فيه يصعقون﴾</span></span>: الفاء الفصيحة، وذرهم فعل أمر وفاعل مستتر ومفعول به، وحتى حرف غاية وجر، ويلاقوا فعل مضارع مجزوم بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بذرهم، ويومهم مفعول به، والذي نعت ليومهم، وفيه جار ومجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿يصعقون﴾</span></span>، وجملة يصعقون لا محل لها من الإعراب، لأنها صلة الذي.</p></div>"
  52,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم لا يغني عنهم كيدهم شيئا ولا هم ينصرون﴾</span></span>: يوم بدل من يومهم، وجملة لا يغني في محل جر بإضافة الظرف إليها، وعنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span>، وكيدهم فاعل يغني، وشيئًا مفعول به، أو نائب عن المفعول المطلق، الواو حرف عطف، ولا نافية، وهم مبتدأ، وجملة ينصرون خبر.</p></div>"
  52,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن للذين ظلموا عذابا دون ذلك ولكن أكثرهم لا يعلمون﴾</span></span>: الواو استئنافية، وإن حرف ناسخ، وللذين خبرها المقدم، وجملة كفروا صلة الموصول لا محل لها من الإعراب. وعذابًا اسم إن المؤخر، ودون ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عذابًا﴾</span></span>، وذلك اسم إشارة مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن للذين...﴾</span></span> مستأنفة لا محل لها من الإعراب، ولكن الواو عاطفة، أو حالية، ولكن حرف ناسخ للاستدراك، وأكثرهم اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر لكن.</p></div>"
  52,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واصبر لحكم ربك فإنك بأعيننا﴾</span></span>: الواو عاطفة، واصبر فعل أمر مبني على السكون، والفاعل مستتر تقديره: أنت، ولحكم ربك: جار ومجرور متعلقان باصبر، والفاء تعليلية، وإن حرف ناسخ، والكاف اسمها، وبأعيننا جار ومجرور متعلقان بمحذوف خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبح بحمد ربك حين تقوم﴾</span></span>: الواو عاطفة، وسبح عطف على واصبر، وبحمد ربك: جار ومجرور متعلقان بمحذوف حال، أي متلبسًا بحمد ربك، وحين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سبح﴾</span></span>، وجملة تقوم في محل جر بإضافة الظرف إليها.</p></div>"
  52,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الليل فسبحه وإدبار النجوم﴾</span></span>: الواو عاطفة، ومن الليل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحه﴾</span></span>، وسبحه فعل أمر وفاعل مستتر ومفعول به، وإدبار النجوم مصدر ناب عن الظرف.</p></div>"
