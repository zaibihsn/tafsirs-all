quran[135]{c,v,t}:
  20,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طه﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  20,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أنزلنا عليك القرآن لتشقى﴾</span></span>: ما نافية، وأنزلنا فعل وفاعل، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، والقرآن مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لتشقى﴾</span></span> اللام للتعليل، وتشقى فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>.</p></div>"
  20,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا تذكرة لمن يخشى﴾</span></span>: إلا أداة حصر، وتذكرة مفعول لأجه، والاستثناء منقطع، وقيل: تذكرة مصدر في موضع الحال.</p></div>"
  20,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيلا﴾</span></span>: مفعول مطلق لفعل محذوف وجوبا، تقديره: نزلناه تنزيلًا، وقيل: بدل من تذكرة إذا جعل حالا، وقيل: منصوب على المدح والاختصاص، وقيل: منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿يخشى﴾</span></span> مفعولًا به، أي: أنزله الله تذكرة لمن يخشى تنزيل الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿ممن﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلق الأرض﴾</span></span>: فعل ماض والفاعل مستتر، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿والسماوات﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> منصوب. وجملة خلق الأرض والسماوات صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿العلا﴾</span></span>: صفة.</p></div>"
  20,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الرحمن على العرش استوى﴾</span></span>: الرحمن خبر لمبتدأ محذوف تقديره: هو، أو مبتدأ، وعلى العرش جار ومجرور متعلقان باستوى، وجملة استوى خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ا لمقدرة، أو خبر الرحمن.</p></div>"
  20,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿له ما في السماوات وما في الأرض وما بينهما وما تحت الثرى﴾</span></span>: له خبر مقدم، وما مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما في الأرض﴾</span></span> عطف على ما في السماوات، وما بينهما عطف كذلك، وما عطف على ما، وتحت الثرى ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p></div>"
  20,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن تجهر بالقول فإنه يعلم السر وأخفى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن شرطية، وتجهر فعل الشرط، وفاعله مستتر تقديره: أنت، وبالقول جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجهر﴾</span></span>، فإنه: الفاء رابطة لأن الجواب جملة اسمية، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة يعلم السر خبر إن، وأخفى اسم تفضيل  عطف على السر، أي: أخفى منه، وقيل: فعل ماض، أي: وأخفى الله من عباده غيبه.</p></div>"
  20,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿له الأسماء الحسنى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، والأسماء مبتدأ مؤخر، والحسنى صفة للأسماء، والجملة خبر ثان.</p></div>"
  20,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهل أتاك حديث موسى﴾</span></span>: الواو للاستئناف، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأتاك فعل ومفعول به، وحديث موسى فاعل، والاستفهام للتقرير.</p></div>"
  20,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ رأى نارا فقال لأهله امكثوا إني آنست نارا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿حديث﴾</span></span> في الآية السابقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأى﴾</span></span> في محل جر مضاف إليه، ونارًا مفعول به، فقال عطف على رأى، ولأهله جار ومجرور متعلقان بقال، وجملة امكثوا مقول القول، وجملة إني تعليل للأمر بالمكوث، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة آنست خبر إن، ونارًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلي آتيكم منها بقبس أو أجد على النار هدى﴾</span></span>: لعل حرف ناسخ، والياء ضمير مبني في محل نصب اسم لعل، وجملة آتيكم خبر لعل، ومنها جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة للقبس، <span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وأجد معطوف على آتيكم، وفاعل أجد مستتر تقديره: أنا، وعلى النار جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أجد﴾</span></span>، وهدى مفعول به.</p></div>"
  20,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أتاها نودي يا موسى﴾</span></span>: الفاء عاطفة على محذوف، والتقدير: فيمَّمَ شطر النار، ولما ظرفية حينية، أو رابطة، وأتاها فعل، وفاعل مستتر، ومفعول به، وجملة نودي لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ويا موسى حرف نداء ومنادى.</p></div>"
  20,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني أنا ربك فاخلع نعليك إنك بالواد المقدس طوى﴾</span></span>: إن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وأنا تأكيد للضمير، أو مبتدأ، وربك خبر إن منصوب والكاف ضمير مبني في محل جر مضاف إليه، أو خبر أنا، والجملة خبر إن، والأول أولى، فاخلع الفاء الفصيحة، واخلع فعل أمر، وفاعل مستتر، ونعليك مفعول به، وجملة إنك تعليل للخلع، وإن حرف ناسخ، والكاف ضمير مبني في محل نصب اسم إن، وبالوادي جار ومجرور متعلقان بمحذوف خبر إن، والمقدس صفة، وطوى بدل أو عطف بيان.</p></div>"
  20,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنا اخترتك فاستمع لما يوحى﴾</span></span>: الواو عاطفة، وأنا مبتدأ، وجملة اخترتك من الفعل والفاعل والمفعول به خبر، فاستمع: الفاء عاطفة، واستمع فعل أمر، والفاعل مستتر تقديره: أنت، ولما جار ومجرور متعلقان باستمع، وجملة يوحى صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ويوحى بالبناء لما لم يسمَّ فاعله.</p></div>"
  20,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنني أنا الله لا إله إلا أنا فاعبدني وأقم الصلاة لذكري﴾</span></span>: الجملة بدل من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿لما يوحى﴾</span></span>، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وأنا تأكيد للضمير، أو مبتدأ، والله خبر إن، أو خبر أنا، والجملة خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا أنا﴾</span></span> خبر ثان، فاعبدني: الفاء الفصيحة، واعبدني فعل أمر، وفاعل مستتر، والنون للوقاية، والياء مفعول، وأقم الصلاة عطف على اعبدني، ولذكرى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، وهو مصدر مضاف لمفعوله، أي: لتذكرني فيها، وقيل: المصدر مضاف للفاعل، أي: لذكري إياك.</p></div>"
  20,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها لتجزى كل نفس بما تسعى﴾</span></span>: إن: حرف ناسخ، والساعة: اسم إن منصوب، آتية: خبر إن مرفوع، وأكاد: فعل مضارع ناقص من أفعال المقاربة، واسمها مستتر تقديره: أنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخفيها﴾</span></span>: خبر أكاد، ولتجزى: اللام للتعليل، وتجزى فعل مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخفيها﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿آتية﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أكاد أخفيها﴾</span></span>: اعتراضية بينهما لا محل لها من الإعراب، وقيل: إن جملة <span class="hlt"><span class="qpc-hafs">﴿أكاد أخفيها﴾</span></span> في محل رفع خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وقيل: إنها في محل نصب حال من <span class="hlt"><span class="qpc-hafs">﴿الساعة﴾</span></span>. وكل: نائب فاعل، ونفس: مضاف إليه، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span>، وجملة تسعى صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وقيل: ما مصدرية، أي: بجزاء سعيها، على حذف مضاف.</p></div>"
  20,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا يصدنك عنها من لا يؤمن بها واتبع هواه فتردى﴾</span></span>: الفاء الفصيحة، ولا ناهية، ويصدنك فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، وهو في محل جزم بلا الناهية، والكاف مفعول به، وعنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصدنك﴾</span></span>، ومَن فاعل، وجملة لا يؤمن صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، واتبع هواه فعل، وفاعل مستتر، ومفعول به، فتردى: الفاء فاء السببية، وتردى فعل مضارع منصوب بأن مضمرة بعد الفاء بفتحة مقدرة على الألف، والمصدر المؤول من أن والفعل معطوف على مصدر مُتَصَيَّد من الكلام السابق، أي: لا يكن صَدٌّ فَتَرَدٍّ.</p></div>"
  20,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تلك بيمينك يا موسى﴾</span></span>: الواو عاطفة، وما اسم استفهام للتقرير مبتدأ، وتلك خبره، وبـ<span class="hlt"><span class="qpc-hafs">﴿يمينك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وهي تشبه قوله تعالى: <span class="hlt"><span class="qpc-hafs">﴿وهذا بعلي شيخا﴾</span></span>، والعامل في الحال المقدرة اسم الإشارة، ويا موسى نداء.</p></div>"
  20,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</span></span>: هي مبتدأ، وعصاي خبره، وجملة أتوكأ عليها حالية، وقيل: مستأنفة لا محل لها من الإعراب، وأهش بها على غنمي عطف على أتوكأ عليها، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهش﴾</span></span>، وكذلك على غنمي.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span></span>: الواو عاطفة، ولي خبر مقدم، وفيها حال، ومآرب مبتدأ مؤخر، وأخرى صفة لمآرب.</p></div>"
  20,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ألقها يا موسى﴾</span></span>: جملة ألقها مقول القول، ويا موسى نداء.</p></div>"
  20,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقاها فإذا هي حية تسعى﴾</span></span>: ألقاها فعل وفاعل ومفعول به، والفاء عاطفة، وإذا للمفاجأة، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وحية خبر، وجملة تسعى حال، أو خبر ثان.</p></div>"
  20,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال خذها ولا تخف سنعيدها سيرتها الأولى﴾</span></span>: جملة خذها مقول القول، والواو حرف عطف، ولا ناهية، وتخف فعل مضارع مجزوم بلا الناهية، والسين حرف استقبال، ونعيدها فعل مضارع، والفاعل مستتر تقديره: نحن، وسيرتها منصوب بنزع الخافض، أي: إلى سيرتها، وقيل: هي ظرف، وقيل: بدل اشتمال من ضمير المفعول، وقيل: نصبت  بفعل مضمر، أي: تسير سيرتها الأولى، والأولى صفة.</p></div>"
  20,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واضمم يدك إلى جناحك تخرج بيضاء من غير سوء آية أخرى﴾</span></span>: الواو عاطفة، واضمم عطف على ألقها، ويدك مفعول به، والفاعل مستتر تقديره: أنت، وإلى جناحك جار ومجرور متعلقان باضمم، وتخرج جزم في جواب الطلب، وبيضاء حال، ومن غير سوء جار ومجرور متعلقان ببيضاء لما فيها من معنى الفعل، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>، وآية حال ثانية من فاعل تخرج أيضًا، وقيل: نصبت بإضمار، نحو: خذ أو دونك، وأخرى صفة لآية.</p></div>"
  20,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنريك من آياتنا الكبرى﴾</span></span>: اللام للتعليل، ونريك فعل مضارع منصوب بأن مضمرة بعد اللام، وهو تعليل لمحذوف متعلق به، أي: أمرناك بما ذكرنا لنريك بها، أي: بيدك، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بفعل محذوف تقديره: جعلناها، و<span class="hlt"><span class="qpc-hafs">﴿من آياتنا﴾</span></span> جار ومجرور متعلقان بمحذوف على أنه حال من <span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span> على هذا مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نريك﴾</span></span>، أو صفة للمفعول الثاني على الأصح، والتقدير: لنريك الآية الكبرى من آياتنا، أي: حال كونها من آياتنا.</p></div>"
  20,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهب إلى فرعون إنه طغى﴾</span></span>: اذهب فعل أمر، والفاعل مستتر تقديره: أنت، وإلى فرعون جار ومجرور متعلقان باذهب، وإن حرف ناسخ، والهاء اسمها، وجملة طغى خبرها، وجملة إنه طغى تعليلية لا محل لها من الإعراب.</p></div>"
  20,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب اشرح لي صدري﴾</span></span>: قال فعل ماض، وفاعله مستتر تقديره: هو، ورب منادى مضاف لياء المتكلم المحذوفة، واشرح فعل دعاء، ولي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اشرح﴾</span></span>، وصدري مفعول به.</p></div>"
  20,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسر لي أمري﴾</span></span>: الواو عاطفة، ويسِّر فعل دعاء مبني على السكون، والفاعل مستتر تقديره أنت، وأمري مفعول به، والياء مضاف إليه.</p></div>"
  20,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واحلل عقدة من لساني﴾</span></span>: الواو عاطفة، واحلل فعل دعاء مبني على السكون، والفاعل مستتر تقديره أنت، وعقدة مفعول به، ومن لساني جار ومجرور متعلقان بمحذوف صفة لعقدة، كأنه قيل: عقدة من عقد لساني.</p></div>"
  20,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يفقهوا قولي﴾</span></span>: يفقهوا فعل مضارع مجزوم في جواب الطلب، والواو فاعل، وقولي مفعول به.</p></div>"
  20,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واجعل لي وزيرا من أهلي﴾</span></span>: الواو عاطفة، واجعل فعل دعاء، وفاعله مستتر تقديره: أنت، ولي جار ومجرور متعلقان بمحذوف مفعول ثان، ووزيرًا مفعول به أول، ومن أهلي جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span>.</p></div>"
  20,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هارون أخي﴾</span></span>: هارون بدل من <span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span>، وأخي بدل من هارون، أو وزيرًا مفعول ثان، وهارون مفعول أول، ولي جار ومجرور متعلقان بمحذوف حال، أو بنفس الجعل، ومن أهلي صفة، أو <span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span> هو المفعول الأول، ومن أهلي هو الثاني.</p></div>"
  20,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اشدد به أزري﴾</span></span>: اشدد فعل دعاء، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اشدد﴾</span></span>، وأزري مفعول به.</p></div>"
  20,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأشركه في أمري﴾</span></span>: الواو عاطفة، وأشركه عطف على اشدد، والهاء مفعول به، وفي أمري جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشركه﴾</span></span>.</p></div>"
  20,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كي نسبحك كثيرا﴾</span></span>: كي حرف مصدري ونصب واستقبال، ونسبحك فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، وفاعل نسبحك ضمير مستتر تقديره: نحن، وكثيرًا صفة لمصدر محذوف فهو نائب مفعول مطلق، أي: نسبحك تسبيحًا كثيرًا، أو صفة لظرف زمان محذوف، أي: نسبحك وقتًا كثيرًا.</p></div>"
  20,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونذكرك كثيرا﴾</span></span>: الواو عاطفة، ونذكرك فعل مضارع معطوف على نسبحك منصوب، وفاعل نذكرك ضمير مستتر تقديره: نحن، وكثيرًا صفة لمصدر محذوف فهو نائب مفعول مطلق، أي: نذكرك ذكرًا كثيرًا، أو صفة لظرف زمان محذوف، أي: نذكرك وقتًا كثيرًا.</p></div>"
  20,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك كنت بنا بصيرا﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وجملة كنت خبر إن، والتاء اسم كان، وبنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصيرًا﴾</span></span>، وبصيرًا خبر كان منصوب.</p></div>"
  20,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قد أوتيت سؤلك يا موسى﴾</span></span>: جملة قد أوتيت مقول القول، وأوتيت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، وسؤلك مفعول به ثان لأوتيت.</p></div>"
  20,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد مننا عليك مرة أخرى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، ومننا فعل وفاعل، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مرة﴾</span></span> ظرف، أو نائب عن المفعول المطلق، لأنه عدده، وأخرى صفة لمرة.</p></div>"
  20,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ أوحينا إلى أمك ما يوحى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span> في محل جر مضاف إليه، وإلى أمك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مفعول مطلق، أو موصولة فهي مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أن اقذفيه في التابوت﴾</span></span>: أن تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. واقذفيه فعل أمر، وفاعل، ومفعول به، وفي التابوت جار ومجرور متعلقان باقذفيه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاقذفيه في اليم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿اقذفيه في التابوت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليلقه اليم بالساحل﴾</span></span>: الفاء عاطفة، واللام لام الأمر، ويلقه فعل مضارع مجزوم بلام الأمر، وعلامة جزمه حذف حرف العلة، والهاء مفعول به، واليم فاعل، وهذا أمر معناه الخبر، وبالساحل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقه﴾</span></span>، أو بمحذوف حال، أي: متلبسًا به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأخذه عدو لي وعدو له﴾</span></span>: يأخذه جواب الطلب، والهاء مفعول، وعدو فاعل، ولي صفة، <span class="hlt"><span class="qpc-hafs">﴿وعدو له﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عدو لي﴾</span></span> .</p><p><span class="hlt"><span class="qpc-hafs">﴿وألقيت عليك محبة مني ولتصنع على عيني﴾</span></span>: الواو حرف عطف، وألقيت فعل وفاعل، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيت﴾</span></span>، ومحبة مفعول به، ومني صفة لمحبة، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيت﴾</span></span>، ولتصنع: عطف على محذوف، أي: ليحبك الناس، ولتصنع: اللام للتعليل، وتصنع فعل مضارع مبني لما لم يسمَّ فاعله، منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمضمر تقديره: ولتصنع فعلتُ ذلك، و<span class="hlt"><span class="qpc-hafs">﴿على عيني﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  20,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ تمشي أختك فتقول هل أدلكم على من يكفله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيت﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿تصنع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمشي﴾</span></span> في محل جر مضاف إليه، وأختك فاعل، فتقول: عطف على تمشي، وهل حرف استفهام، وأدلكم فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدلكم﴾</span></span>، وجملة يكفله صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرجعناك إلى أمك كي تقر عينها ولا تحزن﴾</span></span>: الفاء عاطفة على محذوف تقديره: فأجيبت إلى طلبها، ورجعناك فعل، وفاعل، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى أمك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجعناك﴾</span></span>، وكي حرف ناصب، وتَقَر منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، وعينها فاعل، ولا تحزن عطف على <span class="hlt"><span class="qpc-hafs">﴿كي تقر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقتلت نفسا فنجيناك من الغم وفتناك فتونا﴾</span></span>: الواو استئنافية، وقتلت فعل وفاعل، ونفسًا مفعول قتل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقتلت نفسا﴾</span></span> مستأنفة لا محل لها من الإعراب، فنجيناك: الفاء عاطفة، ونجيناك فعل، وفاعل، ومفعول به، ومن الغم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناك﴾</span></span>، وفتناك فعل، وفاعل، ومفعول به، وفتونًا مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلبثت سنين في أهل مدين ثم جئت على قدر يا موسى﴾</span></span>: الفاء عاطفة، ولبثت فعل وفاعل، وسنين ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، وفي أهل مدين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، ومدين مضاف إليه، ممنوع من الصرف للعملية والتأنيث، ثم حرف عطف، وجئت فعل وفاعل، وعلى قدر جار ومجرور متعلقان بمحذوف حال.</p></div>"
  20,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واصطنعتك لنفسي﴾</span></span>: فعل ماض، وفاعل، ومفعول به، ولنفسي جار ومجرور متعلقان بالفعل.</p></div>"
  20,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهب أنت وأخوك بآياتي ولا تنيا في ذكري﴾</span></span>: اذهب فعل أمر، وفاعله مستتر تقديره: أنت، وأنت ضمير منفصل تأكيد للضمير المستتر، وأخوك عطف على الضمير المرفوع، وعلامة رفعه الواو، والكاف مضاف إليه، وبآياتي  الباء للمصاحبة وبآياتي جار ومجرور متعلقان بمحذوف حال، أي: مصحوبين بآياتي، والواو حرف عطف، ولا ناهية، وتنيا فعل مضارع مجزوم بلا الناهية، والألف فاعل، وفي ذكري جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنيا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> على حقيقتها من الظرفية، وقيل: <span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> هنا بمعنى عن، أي: عن عبادتي.</p></div>"
  20,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهبا إلى فرعون إنه طغى﴾</span></span>: اذهبا فعل وفاعل، وإلى فرعون جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذهبا﴾</span></span>، وإن حرف ناسخ، والهاء اسمها، وجملة طغى خبرها.</p></div>"
  20,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقولا له قولا لينا لعله يتذكر أو يخشى﴾</span></span>: الفاء عاطفة، وقولا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>، وقولًا مفعول به، أو مفعول مطلق منصوب بالفتحة. ولينًا صفة، ولعل حرف ناسخ، والهاء اسمها، وجملة يتذكر خبرها، أو حرف عطف، ويخشى عطف على يتذكر.</p></div>"
  20,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالا ربنا إننا نخاف أن يفرط علينا أو أن يطغى﴾</span></span>: قالا فعل ماض وفاعل، وربنا منادى مضاف، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نخاف خبر إن، وأن وما في حيزها مفعول نخاف، وعلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفرط﴾</span></span>، أو حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أن يطغى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن يفرط﴾</span></span>.</p></div>"
  20,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا تخافا إنني معكما أسمع وأرى﴾</span></span>: لا ناهية، وتخافا فعل مضارع مجزوم بلا، والألف فاعل، وجملة لا تخافا مقول القول، وجملة إنني معكما تعليلية، وإن حرف ناسخ، والياء اسمها، والظرف متعلق بمحذوف خبرها، وجملة أسمع خبر ثان، أو حالية، وأرى عطف على أسمع.</p></div>"
  20,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتياه فقولا إنا رسولا ربك﴾</span></span>: فأتياه: الفاء هي الفصيحة، وأتياه فعل أمر، وفاعل، ومفعول به، فقولا عطف على فأتياه، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ورسولا خبرها، وربك مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأرسل معنا بني إسرائيل ولا تعذبهم﴾</span></span>: الفاء هي الفصيحة، وأرسل فعل أمر، والفاعل مستتر تقديره: أنت، ومعنا ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>، وبني إسرائيل مفعول به، ولا تعذبهم: لا ناهية، وتعذبهم مجزوم بلا، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جئناك بآية من ربك﴾</span></span>: قد حرف تحقيق، وجئناك فعل ماض، وفاعل، ومفعول به، وبآية جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئناك﴾</span></span>، ومن ربك صفة لآية، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد جئناك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿والسلام على من اتبع الهدى﴾</span></span>: الواو استئنافية، والسلام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على من اتبع الهدى﴾</span></span> الجار والمجرور متعلقان بمحذوف خبر، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  20,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا قد أوحي إلينا أن العذاب على من كذب وتولى﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة قد أوحي خبرها، وإلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، وأن وما في حيزها في تأويل مصدر نائب فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، وأن حرف ناسخ، والعذاب اسم أن، و<span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن، وجملة كذب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وتولى عطف على كذب.</p></div>"
  20,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فمن ربكما يا موسى﴾</span></span>: الفاء عاطفة على مقدر، أي: فأتياه وقالا جميع ما ذكر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، وربكما خبر، والجملة مقول القول.</p></div>"
  20,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ربنا الذي أعطى كل شيء خلقه ثم هدى﴾</span></span>: ربنا مبتدأ، والذي خبره، وجملة أعطى صلة الذي لا محل لها من الإعراب، وكل شيء مفعول به أول، وخلقه مفعول به ثان، وقيل: خلقه أول مفعولي أعطى، وكل شيء ثانيهما، ثم هدى عطف على أعطى.</p></div>"
  20,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فما بال القرون الأولى﴾</span></span>: الفاء عاطفة، وما استفهام مبتدأ، وبال خبر، والقرون مضاف إليه، والأولى صفة.</p></div>"
  20,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال علمها عند ربي في كتاب لا يضل ربي ولا ينسى﴾</span></span>: علمها مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عند ربي﴾</span></span> الظرف متعلق بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿في كتاب﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان بمحذوف الخبر، و<span class="hlt"><span class="qpc-hafs">﴿عند ربي﴾</span></span> ظرف متعلق بمحذوف حال، أو هما متعلقان بمحذوفان خبران، أو هما متعلقان بمحذوف خبر واحد، وجملة لا يضل مستأنفة لا محل لها من الإعراب، وقيل: صفة لكتاب، والعائد محذوف تقديره: في كتاب لا يضله ربي، أو: لا يضل حفظه ربي، وربي فاعل يضل، ولا ينسى، عطف على لا يضل.</p></div>"
  20,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل لكم الأرض مهدا وسلك لكم فيها سبلا﴾</span></span>: الذي خبر لمبتدأ محذوف، أي: هو، وجملة جعل صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مهدًا﴾</span></span> ثم تقدم عليه، والأرض مفعول به أول، ومهدًا مفعول به ثان، وسلك فعل ماض، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سبلًا﴾</span></span>، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سلك﴾</span></span>، وسبلًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنزل من السماء ماء فأخرجنا به أزواجا من نبات شتى﴾</span></span>: الواو عاطفة، وأنزل عطف على ما تقدم، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وماء مفعول به، فأخرجنا: الفاء عاطفة، وأخرجنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span>، وأزواجًا مفعول به، ومن نبات جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span>، وشتى صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span>، أو حال منه، لأنه وصف، وقيل: صفة للنبات.</p></div>"
  20,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلوا وارعوا أنعامكم إن في ذلك لآيات لأولي النهى﴾</span></span>: كلوا فعل أمر وفاعل، والجملة معمولة لحال محذوفة، أي: قائلين، وارعوا عطف على كلوا، وأنعامكم مفعول به لارعوا، وإن حرف ناسخ، وفي ذلك خبر إن المقدم، ولآيات اللام المزحلقة، وآيات اسم إن المؤخر، ولأولي النهى صفة لآيات، والنهى مضاف إليه.</p></div>"
  20,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم ومنها نخرجكم تارة أخرى﴾</span></span>: منها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span>، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نعيدكم﴾</span></span>، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجكم﴾</span></span>، وتارة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجكم﴾</span></span>، وأخرى صفة لتارة.</p></div>"
  20,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أريناه آياتنا كلها فكذب وأبى﴾</span></span>: اللام جواب لقسم محذوف، وقد حرف تحقيق، وأريناه فعل ماض، ونا ضمير متصل في محل رفع فاعل، والهاء مفعول به أول، وآياتنا مفعول به ثان، وكلها تأكيد لآياتنا، فكذب وأبى عطف على أريناه.</p></div>"
  20,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أجئتنا لتخرجنا من أرضنا بسحرك يا موسى﴾</span></span>: قال فعل ماض، وفاعله مستتر تقديره: هو، أي: فرعون، وجملة أجئتنا مقول القول، والهمزة للاستفهام الإنكاري، وجئتنا فعل، وفاعل، ومفعول به، ولتخرجنا اللام للتعليل، وتخرج فعل مضارع منصوب بأن مضمرة بعد لام التعليل، ونا مفعول به، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بجئتنا، و<span class="hlt"><span class="qpc-hafs">﴿من أرضنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرجنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بسحرك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرجنا﴾</span></span>.</p></div>"
  20,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلنأتينك بسحر مثله فاجعل بيننا وبينك موعدا لا نخلفه نحن ولا أنت مكانا سوى﴾</span></span>: الفاء الفصيحة، واللام جواب قسم محذوف تقديره: والله لنأتينك، وبسحر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نأتينك﴾</span></span>، أو بمحذوف حال، ومثله صفة لسحر، فاجعل: الفاء عاطفة، واجعل فعل أمر، وفاعله أنت، وبيننا ظرف متعلق بمحذوف مفعول به ثان، وبينك معطف، وموعدًا مصدر ميمي مفعول به أول، وجملة لا نخلفه صفة لـ<span class="hlt"><span class="qpc-hafs">﴿موعدًا﴾</span></span>، ونحن تأكيد للضمير في نخلفه، والواو عاطفة، ولا نافية، وأنت عطف على الضمير في نخلفه، ومكانًا بدل من <span class="hlt"><span class="qpc-hafs">﴿موعدًا﴾</span></span> بتقدير مضاف إليه، أي: مكان موعد، أو منصوب بنزع الخافض، أي: في مكان، أو منصوب بالمصدر، وهو موعد. وسوى صفة، أي: وسطًا.</p></div>"
  20,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال موعدكم يوم الزينة وأن يحشر الناس ضحى﴾</span></span>: موعدكم مبتدأ، ويوم الزينة الظرف متعلق بمحذوف خبر، وأن وما بعدها عطف على يوم الزينة، إما على اليوم فيكون محل المصدر الرفع، وإما على الزينة، فيكون محله الجر، والناس نائب فاعل، وضحى ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحشر﴾</span></span>.</p></div>"
  20,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتولى فرعون فجمع كيده ثم أتى﴾</span></span>: الفاء عاطفة، وتولى فعل ماض، وفرعون فاعل، فجمع عطف على فتولى، وكيده مفعول به، على تقدير مضاف محذوف، أي: ذوي كيده، وهم السحرة، ثم حرف عطف، وأتى عطف على جمع.</p></div>"
  20,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لهم موسى ويلكم لا تفتروا على الله كذبا﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان به، وموسى فاعل، وويلكم مفعول لفعل محذوف على سبيل الردع، أي: ألزمكم الله ويلكم، ولا ناهية، وتفتروا فعل مضارع مجزوم بلا، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفتروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كذبا﴾</span></span> مفعول به للفعل <span class="hlt"><span class="qpc-hafs">﴿لا تفتروا﴾</span></span>، أي: لا تختلقوا كذبا، أو مفعول لأجله، أي: لا تفتروا لأجل الكذب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيسحتكم بعذاب وقد خاب من افترى﴾</span></span>: الفاء: فاء السببية، و<span class="hlt"><span class="qpc-hafs">﴿يسحتكم﴾</span></span> مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل معطوف على مصدر مُتصيَّد من الكلام السابق، أي: لا يكن افتراءٌ فسحتٌ. و<span class="hlt"><span class="qpc-hafs">﴿بعذاب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسحتكم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span> الواو حالية، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿خاب﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل، وجملة افترى صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتنازعوا أمرهم بينهم وأسروا النجوى﴾</span></span>: الفاء عاطفة، وتنازعوا فعل ماض مبني على الضم لاتصاله بواو لجماعة، والواو فاعل، وأمرهم مفعول به، أو منصوب بنزع الخافض، وبينهم ظرف متعلق بمحذوف حال، وأسروا عطف على تنازعوا، والنجوى مفعول به.</p></div>"
  20,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إن هذان لساحران يريدان أن يخرجاكم من أرضكم بسحرهما ويذهبا بطريقتكم المثلى﴾</span></span>: إن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وهذان اسم إشارة للمثنى في محل رفع مبتدأ، واللام الفارقة، وساحران خبر <span class="hlt"><span class="qpc-hafs">﴿هذان﴾</span></span>، وجملة يريدان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ساحران﴾</span></span>، وأن وما في حيزها مفعول يريدان، ومن أرضكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجاكم﴾</span></span>، وبسحرهما جار ومجرور متعلقان بمحذوف حال، أي: متلبسين بسحرهما، ويذهبا عطف على يخرجاكم، وبطريقتكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذهبا﴾</span></span>، والمثلى صفة لطريقتكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذان...﴾</span></span> في محل رفع خبر إن المخففة.</p></div>"
  20,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأجمعوا كيدكم ثم ائتوا صفا﴾</span></span>: الفاء الفصيحة، وأجمعوا: فعل أمر مبني على حذف النون، والواو فاعل، وكيدكم: مفعول به إذا اعتُبرتْ <span class="hlt"><span class="qpc-hafs">﴿أجمعوا﴾</span></span> متعدية، أو منصوب بنزع الخافض إذا اعتُبرتْ لازمة، <span class="hlt"><span class="qpc-hafs">﴿ثم ائتوا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أجمعوا﴾</span></span>، وصفًّا: حال أي: ائتوا مصطفين، وقيل: هو مفعول به أي: ائتوا قوما صفا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد أفلح اليوم من استعلى﴾</span></span>: الواو اعتراضية، أو استئنافية. وقد: حرف تحقيق. وأفلح: فعل ماض. واليوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أفلح﴾</span></span>. ومن: فاعل أفلح. وجملة <span class="hlt"><span class="qpc-hafs">﴿استعلى﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وقد أفلح...﴾</span></span>: اعتراضية، أو استئنافية، وعلى كلا الوجهين لا محل لها من الإعراب.</p></div>"
  20,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا موسى إما أن تلقي وإما أن نكون أول من ألقى﴾</span></span>: إما حرف شرط وتفصيل، وأن وما بعدها في تأويل مصدر منصوب بفعل محذوف، تقديره: اختر أحد الأمرين، أو مرفوع بأنه خبر مبتدأ محذوف تقديره: الأمر إلقاؤك، أو مبتدأ والخبر محذوف، والتقدير: إلقاؤك أول، <span class="hlt"><span class="qpc-hafs">﴿وإما أن نكون﴾</span></span> عطف على ما تقدم، واسم نكون مضمر تقديره: نحن، وأول خبرها، ومن مضاف إليه، وجملة ألقى صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. أو أن وما في حيزها في محل نصب بفعل مضمر، أي: اختر إلقاءك أولًا، أو إلقاءنا.</p></div>"
  20,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال بل ألقوا فإذا حبالهم وعصيهم يخيل إليه من سحرهم أنها تسعى﴾</span></span>: بل حرف إضراب وعطف، وألقوا فعل أمر مبني على حذف النون، والواو فاعل، فإذا الفاء عاطفة على محذوف تقديره: فألقوا، وإذا للمفاجأة، والجملة ابتدائية، وحبالهم مبتدأ، وعصيهم عطف عليه، وجملة يخيل إليه خبر حبالهم، ومن سحرهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخيل﴾</span></span>، وأنها: أن حرف ناسخ، والهاء اسمها، وجملة تسعى خبر أن، وأن وما بعدها في تأويل مصدر نائب فاعل ليخيل، أي: يخيل إليه سعيها.</p></div>"
  20,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوجس في نفسه خيفة موسى﴾</span></span>: الفاء عاطفة، وأوجس فعل ماض، وفي نفسه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوجس﴾</span></span>، وخيفة مفعول به، وموسى فاعل.</p></div>"
  20,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قلنا لا تخف إنك أنت الأعلى﴾</span></span>: قلنا: فعل وفاعل، وجملة لا تخف مقول القول، ولا ناهية، وتخف فعل مضارع مجزوم بلا الناهية، والفاعل مستتر تقديره: أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك...﴾</span></span> مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، والكاف اسمها، وأنت تأكيد، أو ضمير فصل، أو مبتدأ، والأعلى خبر إن، أو خبر أنت، والجملة خبر إن.</p></div>"
  20,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وألق ما في يمينك تلقف ما صنعوا﴾</span></span>: الواو عاطفة، وألق الواو عاطفة، وألق فعل أمر مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، وما مفعول به، وفي يمينك جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وتلقف جواب الطلب مجزوم وعلامة جزمه السكون، وفاعل تلقف ضمير مستتر تقديره: هي، وما مفعول به، وجملة صنعوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما صنعوا كيد ساحر ولا يفلح الساحر حيث أتى﴾</span></span>: تعليل لقوله تلقف، وإن حرف ناسخ، وما اسم موصول مبني في محل نصب اسم إن، وجملة صنعوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وكيد ساحر خبر إن، وما إما موصولة أو موصوفة أو مصدرية أي إن الذي صنعوه أو إن شيئًا صنعوه أو إن صنعهم، والإعراب واحد، ولا الواو عاطفة، ولا نافية، ويفلح الساحر فعل مضارع وفاعل، وحيث ظرف مكان مبني على الضم متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يفلح﴾</span></span>، وجملة أتى مضاف إليه.</p></div>"
  20,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقي السحرة سجدا قالوا آمنا برب هارون وموسى﴾</span></span>: الفاء عاطفة، وألقي فعل ماض مبني لما لم يسمَّ فاعله، والسحرة نائب فاعل، وسجدًا حال من السحرة، قالوا فعل وفاعل، وجملة آمنا مقول القول، وهو فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿برب﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هارون﴾</span></span> مضاف إليه، وموسى معطوف مجرور.</p></div>"
  20,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال آمنتم له قبل أن آذن لكم﴾</span></span>: جملة آمنتم مقول القول، وآمنتم: الهمزة للاستفهام والتقريع والتوبيخ، حذفت الهمزة الأولى، وسهلت الثانية، وهو فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span> أيضًا، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن آذن لكم﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لكبيركم الذي علمكم السحر﴾</span></span>: إن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وكبيرهم خبرها، والذي صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿علمكم السحر﴾</span></span> صلة الذي لا محل لها من الإعراب، والسحر مفعول به ثان لعلمكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلأقطعن أيديكم وأرجلكم من خلاف﴾</span></span>: الفاء الفصيحة، واللام واقعة في جواب القسم، وأقطعن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: أنا، وأيديكم مفعول به، وأرجلكم عطف على أيديكم، ومن خلاف جار ومجرور متعلقان بمحذوف حال بمعنى مختلفة، ومِن حرف لابتداء الغاية المكانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولأصلبنكم في جذوع النخل﴾</span></span>: الواو حرف عطف، ولأصلبنكم عطف على لأقطعن، وفي الظرفية، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أصلبنكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلمن أينا أشد عذابا وأبقى﴾</span></span>: الواو عاطفة، ولتعلمن عطف على لأصلبنكم، و<span class="hlt"><span class="qpc-hafs">﴿أينا﴾</span></span> استفهامية مبتدأ، وأشد خبر، الجملة في محل نصب سدت مسد مفعولي تعلمن، أو أي موصولة، وهي المفعول به لتعلمن، وحذف صدر صلتها، وأشد خبر لمبتدأ محذوف تقديره: هو، وجملة أشد صلة الموصول لا محل لها من الإعراب، وأبقى عطف على أشد.</p></div>"
  20,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لن نؤثرك على ما جاءنا من البينات والذي فطرنا﴾</span></span>: لن حرف نفي ونصب واستقبال، ونؤثرك مضارع منصوب بلن، والكاف مفعول به، والفاعل مستتر تقديره: نحن، والجملة مقول قولهم، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤثرك﴾</span></span>، وجملة جاءنا صلة، ومن البينات جار ومجرور متعلقان بمحذوف حال، والذي عطف على ما، أو الواو للقسم، والذي مجرور بواو القسم، أي: مقسم به، وهو الله تعالى، وفطرنا صلة، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، وجواب القسم محذوف تقديره: لا نؤثرك على الذي جاءنا من الحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاقض ما أنت قاض إنما تقضي هذه الحياة الدنيا﴾</span></span>: الفاء الفصيحة، واقض فعل أمر مبني على حذف حرف العلة، وفاعله ضمير مستتر تقديره: أنت، وما مفعول به، وأنت مبتدأ، وقاض خبر مرفوع، وعلامة رفعه الضمة المقدرة للثقل على الياء المحذوفة لالتقاء الساكنين، وجملة أنت قاض صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: قاضيه، وإنما كافة ومكفوفة، وتقضي فعل مضارع، والفاعل مستتر تقديره أنت، ومفعول تقضي محذوف تقديره: مأربك، وهذه ظرف، والحياة بدل، والدنيا صفة، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقضي﴾</span></span>، وقيل: ما موصولة أو مصدرية، وهي اسم إن، والخبر هو الظرف، أو هذه الحياة الدنيا مفعول به على السعة.</p></div>"
  20,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا آمنا بربنا ليغفر لنا خطايانا وما أكرهتنا عليه من السحر والله خير وأبقى﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة آمنا خبرها، وبربنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، واللام للتعليل، ويغفر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بآمنا، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span>، وما عطف على خطايانا، وقيل: الواو ابتدائية، وما مبتدأ، وجملة أكرهتنا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والخبر محذوف، أي: مرفوع عنا، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكرهتنا﴾</span></span>، ومن السحر حال، والله مبتدأ، وخير خبر، وأبقى عطف على خير.</p></div>"
  20,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من يأت ربه مجرما فإن له جهنم لا يموت فيها ولا يحيا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويأت فعل الشرط وعلامة جزمه حذف حرف العلة، وفاعل يأت مستتر تقديره: هو، وربه مفعول به، والهاء مضاف إليه، ومجرمًا حال من فاعل يأت، فإن الفاء رابطة لجواب الشرط، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، وجهنم اسمها المتأخر، وجملة لا يموت فيها حالية من الهاء في له، أو من جهنم، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يموت﴾</span></span>، ولا يحيا عطف على لا يموت.</p></div>"
  20,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يأته مؤمنا قد عمل الصالحات فأولئك لهم الدرجات العلا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويأت فعل الشرط، وعلامة جزمه حذف حرف العلة، وفاعل يأت مستتر تقديره: هو، والهاء مفعول به، ومؤمنًا حال من فاعل يأت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد عمل الصالحات﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مؤمنًا﴾</span></span>، فأولئك الفاء رابطة، وأولئك اسم إشارة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والدرجات مبتدأ مؤخر، والجملة الاسمية خبر أولئك، وجملة فأولئك في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من، والعلى صفة للدرجات.</p></div>"
  20,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن تجري من تحتها الأنهار خالدين فيها وذلك جزاء من تزكى﴾</span></span>: جنات عدن بدل من الدرجات العلى، أو خبر لمبتدأ محذوف، وجملة تجري من تحتها الأنهار صفة لجنات، وخالدين فيها حال من <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وفيها جار ومجرور متعلقان بخالدين، وذلك مبتدأ، وجزاء خبر، ومن مضاف إليه، وجملة تزكى صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أوحينا إلى موسى أن أسر بعبادي﴾</span></span>: الواو عاطفة، أو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق. وأوحينا فعل وفاعل، وإلى موسى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأسر فعل أمر مبني على حذف حرف العلة، والفاعل مستتر. وبعبادي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أوحينا...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاضرب لهم طريقا في البحر يبسا لا تخاف دركا ولا تخشى﴾</span></span>: فاضرب عطف على أسر، أي: اجعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، قائم مقام المفعول الثاني، وطريقًا مفعول به أول، وفي البحر جار ومجرور متعلقان بمحذوف صفة، ويبسًا صفة ثانية، وهو وصف لما يؤول إليه، أو مصدر وصف به مبالغة، وجملة لا تخاف حالية من فاعل اضرب، أي: اضرب غير خائف، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿طريقًا﴾</span></span>، والعائد محذوف، أي: لا تخاف فيه، أو هي جملة مستأنفة لا محل لها من الإعراب، ولا نافية، وتخاف فعل مضارع مرفوع، وفاعله أنت، ودركًا مفعول به، وجملة ولا تخشى عطف على لا تخاف.</p></div>"
  20,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتبعهم فرعون بجنوده فغشيهم من اليم ما غشيهم﴾</span></span>: الفاء عاطفة، وأتبعهم فعل ماض متعد لاثنين حذف ثانيهما، والتقدير: فأتبعهم فرعون عقابه، والهاء هي المفعول الأول، وقيل: الباء صلة في المفعول الثاني، والتقدير: فأتبعهم فرعون جنوده، وقيل: هو بمعنى تبع، يتعدى لواحد، و<span class="hlt"><span class="qpc-hafs">﴿بجنوده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، فغشيهم: الفاء عاطفة، وغشيهم فعل ماض، والهاء مفعول، وما فاعل، وجملة غشيهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأضل فرعون قومه وما هدى﴾</span></span>: الواو عاطفة، وأضل فعل ماض، وفرعون فاعل، وقومه مفعول به، وجملة وما هدى عطف على أضل.</p></div>"
  20,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا بني إسرائيل قد أنجيناكم من عدوكم﴾</span></span>: يا حرف نداء، وبني إسرائيل منادى مضاف، وقد حرف تحقيق، وأنجيناكم فعل ماض، وفاعل، ومفعول به، ومن عدوكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنجيناكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وواعدناكم جانب الطور الأيمن ونزلنا عليكم المن والسلوى﴾</span></span>: الواو عاطفة، وواعدناكم عطف على أنجيناكم، وواعدناكم فعل، وفاعل، ومفعول به أول، وجانب الطور مفعول به ثان، على تقدير مضاف محذوف، أي: إتيان جانب، والأيمن صفة لجانب، ونزلنا عطف على ما قبله، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلنا﴾</span></span>، والمن مفعول به، والسلوى عطف على المن.</p></div>"
  20,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلوا من طيبات ما رزقناكم ولا تطغوا فيه فيحل عليكم غضبي﴾</span></span>: كلوا فعل أمر مبني على حذف النون، والواو فاعل، ومن طيبات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وما مضاف إليه، وجملة رزقناكم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ولا تطغوا: الواو عاطفة، ولا ناهية، وتطغوا فعل مضارع مجزوم بلا الناهية، والواو فاعل، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطغوا﴾</span></span>، فيحل: الفاء السببية، و<span class="hlt"><span class="qpc-hafs">﴿يحل﴾</span></span> فعل مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل معطوف على مصدر متصيَّد من الكلام السابق، أي: لا يكن طغيان فحلول غضبي. و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحل﴾</span></span>، وغضبي فاعل، وقيل: هو معطوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يحلل عليه غضبي فقد هوى﴾</span></span>: الواو عاطفة، ومن شرطية مبتدأ، ويحلل فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحلل﴾</span></span>، وغضبي فاعل يحلل، والفاء: رابطة لجواب الشرط، وقد حرف تحقيق، وهوى فعل ماض، أي: هلك، والجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر مَن.</p></div>"
  20,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإني لغفار لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، واللام المزحلقة، وغفار خبر إن مرفوع، ولمن جار ومجرور متعلقان بغفار، وجملة تاب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وآمن وعمل عطف، وصالحًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا، ثم اهتدى عطف.</p></div>"
  20,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى﴾</span></span>: ما اسم استفهام مبتدأ، وأعجل فعل ماض، وفاعل مستتر تقديره: هو، يعود على ما، والكاف مفعول به، والجملة خبر ما، وعن قومك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعجلك﴾</span></span>.</p></div>"
  20,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هم أولاء على أثري وعجلت إليك رب لترضى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وأولاء خبر، وعلى أثري جار ومجرور متعلقان بمحذوف خبر ثان، أو حال، وعجلت فعل وفاعل، والواو حالية بتقدير: قد، أو عاطفة، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجلت﴾</span></span>، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وحرف النداء محذوف، ولترضى اللام للتعليل، وترضى فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجلت﴾</span></span> أيضًا.</p></div>"
  20,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فإنا قد فتنا قومك من بعدك وأضلهم السامري﴾</span></span>: قال فعل ماض، وفاعله مستتر يعود على الله، والفاء الفصيحة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة قد فتنا خبرها، وهي فعل وفاعل، وقومك مفعول به، وأضلهم السامري فعل، ومفعول به مقدم، وفاعل مؤخر.</p></div>"
  20,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فرجع موسى إلى قومه غضبان أسفا﴾</span></span>: الفاء للتعقيب، ورجع فعل ماض، وموسى فاعل، وإلى قومه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجع﴾</span></span>، وغضبان أسفًا حالان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم ألم يعدكم ربكم وعدا حسنا﴾</span></span>: يا حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، ألم الهمزة للاستفهام، ويعدكم فعل مضارع مجزوم بلم، والكاف مفعول به، وربكم فاعل، ووعدًا مفعول مطلق، وحسنًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفطال عليكم العهد أم أردتم أن يحل عليكم غضب من ربكم فأخلفتم موعدي﴾</span></span>: الهمزة للاستفهام، والفاء حرف عطف على محذوف، وطال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طال﴾</span></span>، والعهد فاعل، وأم حرف عطف معادل للهمزة، وأردتم فعل وفاعل، وأن وما في حيزها مفعول أردتم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحل﴾</span></span>، وغضب فاعل يحل، ومن ربكم جار ومجرور متعلقان بمحذوف صفة لغضب، فأخلفتم الفاء حرف عطف، وأخلفتم عطف على أردتم، وموعدي مفعول أخلفتم.</p></div>"
  20,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ما أخلفنا موعدك بملكنا﴾</span></span>: قالوا فعل وفاعل، وما نافية، وأخلفنا فعل وفاعل، وموعدك مفعول به، وبملكنا جار ومجرور متعلقان بمحذوف جار ومجرور متعلقان بمحذوف حال، أي: حال كوننا مالكين أمرنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكنا حملنا أوزارا من زينة القوم﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وحملنا فعل ماض بالبناء لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، وأوزارًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من زينة القوم﴾</span></span> الجار والمجرور متعلقان بمحذوف صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> خبر لكن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقذفناها فكذلك ألقى السامري﴾</span></span>: الفاء عاطفة، وقذفناها فعل، وفاعل، ومفعول به، وهو معطوف على محذوف،  فكذلك الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة بمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وألقى السامري فعل وفاعل.</p></div>"
  20,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخرج لهم عجلا جسدا له خوار﴾</span></span>: الفاء عاطفة، وأخرج فعل ماض، وفاعله مستتر تقديره: هو يعود على السامري، والعطف على فأضلهم السامري، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرج﴾</span></span>، وعجلًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿جسدًا﴾</span></span> فيه ثلاثةُ أوجه، أحدها: أنه نعت . الثاني: أنه عطفُ بيان . الثالث: أنه بدلٌ وهو الراجح، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وخوار مبتدأ مؤخر، والجملة من المبتدأ والخبر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عجلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا هذا إلهكم وإله موسى فنسي﴾</span></span>: الفاء حرف عطف، وقالوا فعل وفاعل، وهذا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلهكم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿إله موسى﴾</span></span> عطف على إلهكم، فنسي الفاء حرف عطف، ونسي فعل ماض، وفاعله مستتر تقديره: هو، يعود على موسى، وقيل: الضمير يعود على السامري.</p></div>"
  20,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلا يرون ألا يرجع إليهم قولا ولا يملك لهم ضرا ولا نفعا﴾</span></span>: الهمزة للاستفهام، والفاء حرف عطف، ولا نافية، ويرون فعل مضارع بثبوت النون، والواو فاعل، وأن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، أي: أنه، ولا نافية، ويرجع فعل مضارع، وفاعل يرجع مضمر تقديره: هو، يعود على العجل، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجع﴾</span></span>، وقولًا مفعول به، والجملة الفعلية في محل رفع خبر أن المخففة، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ألا يرجع﴾</span></span> سد مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أفلا يرون﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  20,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد قال لهم هارون من قبل﴾</span></span>: الواو حرف عطف، واللام واقعة في جواب القسم، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿قال لهم هارون﴾</span></span> فعل ماض وفاعل، ومن قبل جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا قوم إنما فتنتم به وإن ربكم الرحمن فاتبعوني وأطيعوا أمري﴾</span></span>: يا حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، وإنما كافة ومكفوفة، وفتنتم فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، والميم علامة جمع الذكور، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فتنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إن ربكم الرحمن﴾</span></span> إن حرف ناسخ، وربكم اسمها منصوب، والرحمن خبرها مرفوع، والفاء الفصيحة، واتبعوني فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء مفعول به، وأطيعوا أمري عطف على اتبعوني.</p></div>"
  20,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لن نبرح عليه عاكفين حتى يرجع إلينا موسى﴾</span></span>: لن حرف نفي ونصب واستقبال، ونبرح فعل مضارع ناقص منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، واسمها ضمير مستتر تقديره: نحن، وعليه جار ومجرور متعلقان بعاكفين، وعاكفين خبر نبرح، حتى حرف غاية وجر، ويرجع فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاكفين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجع﴾</span></span>.</p></div>"
  20,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا هارون ما منعك إذ رأيتهم ضلوا﴾</span></span>: ما اسم استفهام في محل رفع مبتدأ، وجملة منعك خبر، وإذ ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿منعك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأيتهم﴾</span></span> في محل جر مضاف إليه، ورأيتهم فعل، وفاعل، ومفعول به، وجملة ضلوا حالية، أو مفعول به ثان لرأيتهم إذا اعتبرت قلبية.</p></div>"
  20,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا تتبعن أفعصيت أمري﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ألّا﴾</span></span> أن: حرف مصدري ونصب، ولا: حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿تتبعن﴾</span></span> فعل مضارع منصوب بأن، والنون للوقاية، وياء المتكلم المحذوفة مفعول، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ألّا تتبعن﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span> في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿أفعصيت﴾</span></span> الهمزة للاستفهام، والفاء عاطفة على مقدر، وعصيت فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أمري﴾</span></span> مفعول به.</p></div>"
  20,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا ابن أم لا تأخذ بلحيتي ولا برأسي﴾</span></span>: يا ابن أم يا حرف نداء، وابن منادى مضاف منصوب، وأم مضاف إليه مجرورة بكسرة مقدرة على ما قبل الألف المحذوفة للتخفيف، والألف المحذوفة المنقلبة عن الياء مضاف إليه، وقيل: هما اسمان مبنيان لتركبهما تركب الأعداد والظروف، ولا ناهية، وتأخذ فعل مضارع مجزوم بلا الناهية، والفاعل مستتر تقديره: أنت، وبلحيتي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأخذ﴾</span></span>، ولا برأسي عطف على بلحيتي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني خشيت أن تقول فرقت بين بني إسرائيل ولم ترقب قولي﴾</span></span>: إن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة خشيت خبر إن، وأن وما في حيزها مفعول خشيت، وجملة فرقت مقول القول، وبين ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فرقت﴾</span></span>، وبني إسرائيل مضاف إليه، ولم ترقب قولي عطف على فرقت، والضمير في قولي واقع على موسى، أو عطف على خشيت، والضمير في قولي واقع على هارون.</p></div>"
  20,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فما خطبك يا سامري﴾</span></span>: قال فعل ماض، وفاعله مستتر تقديره: هو، يعود على موسى، والفاء عاطفة، أو استئنافية، وما استفهامية مبتدأ، وخطبك خبر، ويا حرف نداء، وسامري منادى مفرد علم، وجملة <span class="hlt"><span class="qpc-hafs">﴿فما خطبك يا سامري﴾</span></span> معطوفة على مقول القول، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  20,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال بصرت بما لم يبصروا به فقبضت قبضة من أثر الرسول﴾</span></span>: جملة بصرت مقول القول، وفاعل قال هو، أي: السامري، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصرت﴾</span></span>، وجملة لم يبصروا به صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، فقبضت عطف على بصرت، وقبضة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من أثر﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لقبضة، وأثر مضاف، والرسول مضاف إليه على تقدير محذوفين، أي: من أثر حافر فرس الرسول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنبذتها وكذلك سولت لي نفسي﴾</span></span>: فنبذتها عطف على قبضت، وكذلك الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: مثل ذلك التسويل سولت لي نفسي، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وسولت لي نفسي فعل وفاعل.</p></div>"
  20,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فاذهب فإن لك في الحياة أن تقول لا مساس﴾</span></span>: قال فعل ماض، وفاعله يعود على موسى، فاذهب الفاء عاطفة، واذهب فعل أمر فاعله أنت، فإن: الفاء عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، وفي الحياة جار ومجرور متعلقان بمحذوف حال، وأن وما بعدها اسم إن، ولا نافية للجنس، ومساس اسم لا، والخبر محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن لك موعدا لن تخلفه﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، وموعدًا اسمها المؤخر، ولن حرف نفي ونصب واستقبال، وتخلفه منصوب بلن، ونائب الفاعل مستتر تقديره: أنت، والهاء مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وانظر إلى إلهك الذي ظلت عليه عاكفا لنحرقنه ثم لننسفنه في اليم نسفا﴾</span></span>: الواو عاطفة، وانظر فعل أمر، وفاعله مستتر تقديره: أنت، وإلى إلهك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span>، والذي صفة، وجملة ظلت صلة الذي لا محل لها من الإعراب، وظلت فعل ماض ناقص، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاكفًا﴾</span></span>، وعاكفًا خبر ظلت، ولنحرقنه اللام واقعة في جواب القسم، ونحرقنه فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، والفاعل مستتر تقديره: نحن، والهاء مفعول به، ثم حرف عطف، لننسفنه اللام واقعة في جواب القسم، وننسفنه فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، وفي اليم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننسفنه﴾</span></span>، ونسفًا مفعول مطلق.</p></div>"
  20,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما إلهكم الله الذي﴾</span></span>: إنما كافة ومكفوفة، وإلهكم مبتدأ، والله خبره، والجملة مستأنفة لا محل لها من الإعراب، والذي نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة لا إله إلا هو صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسع كل شيء علما﴾</span></span>: وسع فعل ماض، وفاعله مستتر تقديره: هو، وكل شيء مضاف إليه وعلمًا تمييز من فاعل وسع.</p></div>"
  20,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نقص عليك من أنباء ما قد سبق وقد آتيناك من لدنا ذكرا﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف لـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، أي: نقص عليك قصصا مثل ذلك القصص، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ونقص فعل مضارع فاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، ومن أنباء جار ومجرور متعلقان بمحذوف مفعول به لنقص، وما مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد سبق﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span> الواو عاطفة، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿آتيناك﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>، وذكرًا مفعول به ثان.</p></div>"
  20,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من أعرض عنه فإنه يحمل يوم القيامة وزرا﴾</span></span>: من شرطية في محل رفع مبتدأ، وأعرض فعل ماض في محل جزم فعل الشرط، وفاعله ضمير مستتر تقديره: هو، وعنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>، والفاء رابطة، وإن حرف ناسخ، والهاء اسمها، وجملة يحمل خبرها، والفاعل مستتر تقديره: هو، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحمل﴾</span></span>، ووزرًا مفعول به، وجملة من أعرض في محل نصب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>.</p></div>"
  20,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خالدين فيه وساء لهم يوم القيامة حملا﴾</span></span>: خالدين حال، وفيه جار ومجرور متعلقان بخالدين، والضمير يعود للوزر، وساء: الواو حالية، أو عاطفة، وساء فعل ماض من أفعال الذم، وفاعله مستتر مميز بنكرة، وهي <span class="hlt"><span class="qpc-hafs">﴿حملًا﴾</span></span>، والمخصوص بالذم محذوف تقديره: وزرهم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بقول مقدر، أي: يقال لهم هذا الكلام، وقيل: هي كاللام في <span class="hlt"><span class="qpc-hafs">﴿هيت لك﴾</span></span>، أي: لمجرد البيان، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، وحملًا تمييز.</p></div>"
  20,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم ينفخ في الصور ونحشر المجرمين يومئذ زرقا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف بدل من يوم القيامة، وجملة ينفخ مضاف إليه، وينفخ فعل مضارع بالبناء لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: نحن، والمجرمين مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: ونحشر المجرمين يوم إذ ينفخ في الصور، وزرقًا حال من المجرمين.</p></div>"
  20,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يتخافتون بينهم إن لبثتم إلا عشرا﴾</span></span>: الجملة حال من المجرمين، أو مستأنفة لا محل لها من الإعراب، ويتخافتون فعل مضارع مرفوع بثبوت النون، لأنه من الأفعال الخمسة، والواو فاعل، وبينهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتخافتون﴾</span></span>، وإن لبثتم جملة منصوبة بقول دل عليه يتخافتون، والقول نصب على الحال، أي: قائلين في السر، وإن نافية، ولبثتم فعل وفاعل، وإلا أداة حصر، وعشرًا ظرف زمان .</p></div>"
  20,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة إن لبثتم إلا يوما﴾</span></span>: نحن مبتدأ، وأعلم خبر، وبما جار ومجرور متعلقان بأعلم، وجملة يقولون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وإذ ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> في محل جر مضاف إليه، وأمثلهم فاعل، وطريقة تمييز، وإن نافية، ولبثتم فعل وفاعل، وإلا أداة حصر، ويومًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثتم﴾</span></span>.</p></div>"
  20,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسألونك عن الجبال فقل ينسفها ربي نسفا﴾</span></span>: الواو للاستئناف، ويسألونك فعل مضارع مرفوع بثبوت النون، والواو فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن الجبال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسألونك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويسألونك عن الجبال﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> الفاء عاطفة، وقل فعل أمر، وفاعله مستتر تقديره: أنت، وجملة ينسفها مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به مقدم، وربي فاعل مؤخر، ونسفًا مفعول مطلق.</p></div>"
  20,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيذرها قاعا صفصفا﴾</span></span>: الفاء عاطفة، ويذرها فعل مضارع، والفاعل مستتر تقديره: هو، أي: الله تعالى، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وقاعًا حال من الضمير المنصوب، أو مفعول به ثان، لتضمين يذر معنى التصيير، وصفصفًا حال ثانية، أو بدل من المفعول الثاني، وقيل: صفة له.</p></div>"
  20,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا ترى فيها عوجا ولا أمتا﴾</span></span>: الجملة حال ثالثة، أو حال أولى، ولا نافية، وترى فعل مضارع، وفاعله مستتر تقديره: أنت، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>، وعوجًا مفعول به، ولا أمتًا عطف.</p></div>"
  20,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ يتبعون الداعي لا عوج له﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتبعون﴾</span></span>، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> المتقدم، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، و<span class="hlt"><span class="qpc-hafs">﴿يتبعون الداعي﴾</span></span> فعل مضارع وفاعل ومفعول به، ولا نافية للجنس، وعوج اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لا، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا عوج له﴾</span></span> حال من الداعي، أو صفة لمصدر محذوف، أي: يتبعونه اتباعًا لا عوج له، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</span></span>: الواو عاطفة، وخشعت الأصوات فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿للرحمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خشعت﴾</span></span>، والفاء عاطفة، ولا نافية، وتسمع فعل مضارع، وفاعله مستتر تقديره: هو، وإلا أداة حصر، وهمسًا مفعول به.</p></div>"
  20,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ لا تنفع الشفاعة إلا من أذن له الرحمن ورضي له قولا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف متعلق بالفعل المنفي <span class="hlt"><span class="qpc-hafs">﴿تنفع﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، ولا نافية، وتنفع الشفاعة فعل مضارع وفاعل، وإلا أداة حصر، ومن مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿تنفع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذن له الرحمن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿رضي له قولًا﴾</span></span> عطف على أذن له، وقيل: النصب على المفعولية.</p></div>"
  20,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعلم ما بين أيديهم وما خلفهم ولا يحيطون به علما﴾</span></span>: يعلم فعل مضارع مرفوع، وفاعله مستتر تقديره: هو، وما مفعول به، وبين ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، وأيديهم مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلم ما...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما خلفهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما بين أيديهم﴾</span></span>، ولا يحيطون الواو عاطفة، أو حالية، ويحيطون فعل مضارع مرفوع بثبوت النون، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحيطون﴾</span></span>، وعلمًا مفعول به.</p></div>"
  20,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعنت الوجوه للحي القيوم وقد خاب من حمل ظلما﴾</span></span>: الواو استئنافية، وعنت الوجوه فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعنت الوجوه﴾</span></span> مستأنفة لا محل لها من الإعراب، وللحي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عنت﴾</span></span>، والقيوم صفة، والواو حالية، وجملة وقد خاب حالية، ومن فاعل خاب، وجملة حمل ظلمًا صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن فلا يخاف ظلما ولا هضما﴾</span></span>: الواو عاطفة على وقد خاب، ومن شرطية مبتدأ، ويعمل فعل الشرط، ومن الصالحات جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: أعمالًا، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ومؤمن خبر، والفاء رابطة لجواب الشرط، ولا نافية، ويخاف فعل مضارع، وفاعله مستتر تقديره: هو، وظلمًا مفعول به، ولا هضمًا عطف على <span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span>، وجملة لا يخاف خبر لمبتدأ محذوف، والتقدير: فهو لا يخاف، وجملة فهو لا يخاف في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من.</p></div>"
  20,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك أنزلناه قرآنا عربيا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف لـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>، أي: مثل ذلك الإنزال أنزلناه، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قرآنًا﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿عربيًّا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وصرفنا فيه من الوعيد لعلهم يتقون أو يحدث لهم ذكرا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الوعيد﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول محذوف، أي: صرفنا وعيدًا من الوعيد، ولعل حرف ناسخ يفيد الترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يتقون خبرها، وأو حرف عطف، ويحدث عطف على يتقون، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحدث﴾</span></span>، وذكرًا مفعول به، وفاعل يحدث هو، أي: القرآن.</p></div>"
  20,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتعالى الله الملك الحق ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه وقل رب زدني علما﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿تعالى الله﴾</span></span> فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿الملك الحق﴾</span></span> صفتان لله، وجملة <span class="hlt"><span class="qpc-hafs">﴿فتعالى الله﴾</span></span> مستأنفة لا محل لها من الإعراب، ولا تعجل الواو عاطفة، ولا ناهية، وتعجل فعل مضارع مجزوم بلا الناهية، وبالقرآن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعجل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعجل﴾</span></span>، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يقضى﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقضى﴾</span></span>، ويقضى فعل مضارع مبني لما لم يسمَّ فاعله، ووحيه نائب فاعل، وقل عطف على لا تعجل، ورب منادى مضاف لياء المتكلم المحذوفة، وزدني فعل دعاء، والنون للوقاية، والياء مفعول به أول، وعلمًا مفعول به ثان، أو تمييز.</p></div>"
  20,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي ولم نجد له عزما﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وعهدنا فعل وفاعل، وإلى آدم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عهدنا﴾</span></span>، ومن قبل جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد عهدنا...﴾</span></span> مستأنفة لا محل لها من الإعراب، فنسي عطف على عهد، أي: نسي ما أمرناه به، ولم نجد: الواو عاطفة، ولم حرف نفي وقلب وجزم، والفاعل مستتر تقديره: نحن، وعزمًا مفعول به.</p></div>"
  20,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس أبى﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف والتقدير: واذكر إذ قلنا، قلنا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span> في محل جر بالإضافة، للملائكة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span>، اسجدوا فعل أمر مبني على حذف النون، والواو فاعل، والجملة الفعلية في محل نصب مقول القول، لآدم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسجدوا﴾</span></span>، فسجدوا الفاء عاطفة، وسجدوا فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، إبليس مستثنى بـ<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> متصل إن كان إبليس في الأصل من الملائكة، وقيل: منقطع، لأنه ليس منهم، أبى فعل ماض مبني على الفتح المقدر على الألف، والجملة الفعلية في محل نصب على الحال، أي: حال كونه رافضًا للأمر مستكبرًا له كافرًا به.</p></div>"
  20,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقلنا يا آدم إن هذا عدو لك ولزوجك﴾</span></span>: الفاء عاطفة، وقلنا فعل وفاعل، ويا آدم نداء، وجملة إن مقول القول، وهذا اسم إن، وعدو خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لعدو ولزوجك عطف على لك.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span></span>: الفاء عاطفة، ولا ناهية، ويخرجنكما فعل مضارع مبني على الفتح في محل جزم بلا، والكاف مفعول به، والفاعل مستتر وهو إبليس، والميم والألف للتثنية، فتشقى: الفاء فاء السببية، وتشقى فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والفاعل مستتر تقديره: أنت، والمصدر المؤول من أن والفعل معطوف على مصدر متصيَّد من الكلام السابق، أي: لا يكن إخراج منه لكما فشقاء لك.</p><p>.</p></div>"
  20,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن لك ألا تجوع فيها ولا تعرى﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، وأن وما في حيزها اسمها المؤخر، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجوع﴾</span></span> ولا تعرى عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تجوع﴾</span></span>.</p></div>"
  20,119,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنك لا تظمأ فيها ولا تضحى﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تظمأ فيها﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، وتظمأ: فعل مضارع، والفاعل مستتر، وفيها: جار ومجرور متعلقان بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿ولا تضحى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تظمأ﴾</span></span>.</p></div>"
  20,120,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فوسوس إليه الشيطان قال يا آدم هل أدلك على شجرة الخلد وملك لا يبلى﴾</span></span>: فوسوس الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿وسوس﴾</span></span> فعل ماض، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وسوس﴾</span></span>، والشيطان فاعل، <span class="hlt"><span class="qpc-hafs">﴿قال يا آدم﴾</span></span> فعل ماض و أسلوب نداء، وهل حرف استفهام، وأدلك فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على شجرة الخلد﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدلك﴾</span></span>، وملك عطف على شجرة، وجملة لا يبلى صفة لملك.</p></div>"
  20,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأكلا منها فبدت لهما سوآتهما وطفقا يخصفان عليهما من ورق الجنة وعصى آدم ربه فغوى﴾</span></span>: فأكلا فعل ماض، والألف فاعل، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكلا﴾</span></span> فبدت عطف على أكلا، و<span class="hlt"><span class="qpc-hafs">﴿لهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بدت﴾</span></span>، وسوءاتهما فاعل، وطفقا فعل ماض من أفعال الشروع، والألف اسمها، وجملة يخصفان خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عليهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخصفان﴾</span></span>، ومن ورق الجنة جار ومجرور متعلقان بمحذوف صفة لموصوف محذوف هو المفعول به، أي: ورقًا من ورق الجنة. <span class="hlt"><span class="qpc-hafs">﴿وعصى آدم ربه﴾</span></span> فعل وفاعل ومفعول به، فغوى عطف على عصى.</p></div>"
  20,122,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم اجتباه ربه فتاب عليه وهدى﴾</span></span>: ثم حرف عطف، واجتباه فعل ومفعول به، وربه فاعل، فتاب عليه عطف على اجتباه، وهدى عطف على تاب.</p></div>"
  20,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال اهبطا منها جميعا بعضكم لبعض عدو﴾</span></span>: اهبطا فعل أمر مبني على حذف النون، والألف فاعل، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اهبطا﴾</span></span>، وجميعًا حال، وبعضكم مبتدأ، ولبعض جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لعدو، وعدو خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿بعضكم لبعض عدو﴾</span></span> في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإما يأتينكم مني هدى فمن اتبع هداي فلا يضل ولا يشقى﴾</span></span>: الفاء عاطفة، وإن شرطية، وما حرف صلة، ويأتينكم فعل مضارع مبني على الفتح في محل جزم فعل الشرط، والكاف مفعول به، ومني جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتينكم﴾</span></span>، وهدى فاعل يأتينكم، فمن اتبع: الفاء رابطة، ومن شرطية مبتدأ، واتبع فعل ماض في محل جزم فعل الشرط، وهداي مفعول به، والفاء رابطة للجواب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يضل﴾</span></span> في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من، وجملة <span class="hlt"><span class="qpc-hafs">﴿من اتبع﴾</span></span> في محل جزم جواب إن.</p></div>"
  20,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن أعرض عن ذكري فإن له معيشة ضنكا﴾</span></span>: الواو عاطفة على جواب الشرط المتقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، وأعرض فعل ماض في محل جزم فعل الشرط، وفاعله ضمير مستتر تقديره: هو، وعن ذكري جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>، فإن الفاء رابطة للجواب، لأنه جملة اسمية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبرها المقدم، ومعيشة اسمها المؤخر، وضنكًا صفة، والجملة الاسمية في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونحشره يوم القيامة أعمى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ونحشره﴾</span></span> الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ونحشر فعل مضارع مرفوع، والفاعل مستتر تقديره: نحن، والهاء مفعول به، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نحشره﴾</span></span>، وأعمى حال من الهاء في نحشره.</p></div>"
  20,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب لم حشرتني أعمى وقد كنت بصيرا﴾</span></span>: رب منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿لِمَ﴾</span></span> اللام حرف جر، وما الاستفهامية في محل جر باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حشرتني﴾</span></span>، وحشرتني فعل، وفاعل، ومفعول به، وأعمى حال، والواو للحال، وقد حرف تحقيق، وكان فعل ماض ناقص، والتاء اسمها، وبصيرًا خبر كان.</p></div>"
  20,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كذلك أتتك آياتنا فنسيتها وكذلك اليوم تنسى﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: أتتك إتيانًا مثل ذلك الإتيان، أو في محل رفع خبر لمبتدأ محذوف، أي: الأمر كذلك، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أتتك آياتنا﴾</span></span> فعل ومفعول به مقدم وفاعل مؤخر، فنسيتها: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نسيتها﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، واليوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تنسى﴾</span></span>.</p></div>"
  20,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك نجزي من أسرف ولم يؤمن بآيات ربه ولعذاب الآخرة أشد وأبقى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: جزاءً مثلَ ذلك نجزي، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسرف﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿ولم يؤمن﴾</span></span> عطف على أسرف، فهو داخل في حيز الصلة، و<span class="hlt"><span class="qpc-hafs">﴿بآيات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولعذاب﴾</span></span>: الواو حالية، أو عاطفة، واللام للابتداء، وعذاب مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span> خبر، <span class="hlt"><span class="qpc-hafs">﴿وأبقى﴾</span></span> عطف على أشد.</p></div>"
  20,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يهد لهم كم أهلكنا قبلهم من القرون يمشون في مساكنهم﴾</span></span>: الهمزة للاستفهام، وهي داخلة، على محذوف عطف عليه بالفاء، والتقدير: أغفلوا فلم يتبين لهم، وفاعل يهد المصدر المفهوم من أهلكنا، أي: أفلم يتبين لهم إهلاكنا، أو ضمير عائد على الله تعالى، أي: يبين الله، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهد﴾</span></span>، وكم خبرية مفعول مقدم لأهلكنا، ومن القرون جار ومجرور متعلقان بمحذوف نعت لتمييز كم الخبرية، أي: كم قرن من القرون، وجملة يمشون في مساكنهم حال من مفعول أهلكنا، أو من الضمير في لهم، وفي مساكنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمشون﴾</span></span>، والضمير يعود على المهلَكين.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لأولي النهى﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآيات اسمها المؤخر، ولأولي جار ومجرور متعلقان بمحذوف صفة لآيات، والنهى مضاف إليه.</p></div>"
  20,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولولا حرف امتناع لوجود، وكلمة مبتدأ محذوف الخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سبقت من ربك﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span>، ومن ربك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿لكان﴾</span></span> اللام واقعة في جواب لولا، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، يعود على الإهلاك، ولزامًا خبرها، وأجل مسمى عطف على كلمة، أو على الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، أي: لكان الإهلاك العاجل وأجل مسمى لازمين لهم كما كانا لازمين لعاد وثمود.</p></div>"
  20,130,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر على ما يقولون وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</span></span>: الفاء الفصيحة، واصبر فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>، وجملة يقولون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>  لا محل لها من الإعراب، وسبح عطف على اصبر، وبحمد ربك في موضع نصب على الحال، أي: وأنت حامد لربك على أن وفقك للتسبيح، وأعانك عليه، وقبل ظرف متعلق بسبح، وطلوع الشمس مضاف، وقبل غروبها عطف على قبل طلوع الشمس.</p></div>"
  20,131,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تمدن عينيك إلى ما متعنا به أزواجا منهم زهرة الحياة الدنيا لنفتنهم فيه﴾</span></span>: الواو عاطفة، ولا ناهية، وتمدن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، وهو في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وفاعله ضمير مستتر تقديره: أنت، وعينيك مفعول به، وإلى ما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمدن﴾</span></span>، وجملة متعنا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، والهاء هي العائد، وأزواجًا مفعول متعنا، ومنهم جار ومجرور متعلقان بمحذوف صفة، أو نصب على الحال من هاء الضمير، ومنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿زهرة الحياة الدنيا﴾</span></span> فيها أقوال:</p><p>١ -  مفعول ثان إذا أعربنا <span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span> هو المفعول الأول، لأن معنى <span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>: أعطينا.</p><p>٢ -  منصوبة على الحال من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الموصولة.</p><p>٣ - منصوبة على البدلية من <span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span> على المبالغة.</p><p>٤ - منصوبة بفعل مضمر دل عليه <span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، تقديره: جعلنا لهم زهرة.</p><p>٥ - منصوبة على الذم، أي: أذم زهرة الحياة الدنيا.</p><p>٦ - منصوبة على الاختصاص.</p><p>٧ - منصوبة على البدلية من محل <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>.</p><p>٨ - منصوبة على الحال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>.</p><p>٩ - منصوبة على التمييز لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> أو للهاء في <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>.</p><p>و<span class="hlt"><span class="qpc-hafs">﴿لنفتنهم﴾</span></span> اللام للتعليل، ونفتنهم مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، والهاء مفعول به، وفيه متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفتنهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزق ربك خير وأبقى﴾</span></span>: الواو للحال، ورزق مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، وأبقى عطف على خير.</p></div>"
  20,132,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأمر أهلك بالصلاة واصطبر عليها لا نسألك رزقا﴾</span></span>: الواو استئنافية، أو عاطفة، وفعل الأمر مبني على السكون، وفاعله مستتر تقديره: أنت، وأهلك مفعول به، وبالصلاة جار ومجرور متعلقان بفعل الأمر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأمر أهلك بالصلاة﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب، واصطبر فعل أمر، وفاعله مستتر، وتقديره: أنت، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصطبر﴾</span></span>، وجملة لا نسألك استئنافية، ونسألك فعل مضارع، وفاعل مستتر، ومفعول به، ورزقًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿نحن نرزقك والعاقبة للتقوى﴾</span></span>: نحن مبتدأ، وجملة نرزقك خبر، والعاقبة مبتدأ، وللتقوى جار ومجرور متعلقان بمحذوف خبر، وهاتان الجملتان مستأنفتان أيضًا لا محل لهما من الإعراب.</p></div>"
  20,133,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لولا يأتينا بآية من ربه أولم تأتهم بينة ما في الصحف الأولى﴾</span></span>: لولا حرف تحضيض، أي: هلا، ويأتينا فعل، وفاعل مستتر، ومفعول به، وبآياته جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتينا﴾</span></span>، ومن ربه جار ومجرور متعلقان بمحذوف صفة لآية، أولم الهمزة للاستفهام، والواو عاطفة على مقدر يقتضيه السياق، والتقدير: ألم تأتهم البينات تترى، ولم تأتهم بصورة خاصة بينة ما في الصحف الأولى، وبينة فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿تأتهم﴾</span></span>، وما موصول مضاف إليه، وفي الصحف جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، والأولى صفة للصحف.</p></div>"
  20,134,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو أنا أهلكناهم بعذاب من قبله لقالوا ربنا لولا أرسلت إلينا رسولا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وأن حرف ناسخ مصدري، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير في محل نصب اسم أن، وأهلكناهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أنّا﴾</span></span> وما بعدها فاعل لفعل محذوف تقديره ثبت، والجملة مستأنفة لا محل لها من الإعراب، وبعذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكناهم﴾</span></span>، ومن قبله صفة لعذاب، لقالوا: جواب لو، والجملة لا محل لها من الإعراب، وربنا منادى مضاف محذوف منه حرف النداء، ولولا حرف تحضيض، وأرسلت فعل وفاعل، وإلينا جار ومجرور متعلقان  بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span>، ورسولًا مفعول به، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنتبع آياتك من قبل أن نذل ونخزى﴾</span></span>: فنتبع الفاء هي السببية، ونتبع منصوب أن مضمرة في جواب التحضيض، والمصدر المؤول من أن والفعل معطوف على مصدر متصيَّد من الكلام السابق أي: لولا إرسال منك فاتباع منا. والفاعل مستتر تقديره: نحن، وآياتك مفعول به منصوب بالكسرة، لأنه جمع مؤنث سالم، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتبع﴾</span></span>، وأن وما بعدها في تأويل مصدر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿نخزى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نذل﴾</span></span>.</p></div>"
  20,135,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل كل متربص فتربصوا فستعلمون من أصحاب الصراط السوي ومن اهتدى﴾</span></span>: كل مبتدأ، ومتربص خبر، والجملة مقول القول، والفاء الفصيحة، وتربصوا فعل أمر، فستعلمون الفاء استئنافية، والسين حرف استقبال، وتعلمون فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب الصراط السوي﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فستعلمون مَن...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من اهتدى﴾</span></span> عطف على من أصحاب، وجملة <span class="hlt"><span class="qpc-hafs">﴿من أصحاب﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span> المعلقة عن العمل، أو <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> موصولة مفعول <span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span>، وأصحاب الصراط خبر لمبتدأ محذوف، أي: هم أصحاب.</p></div>"
