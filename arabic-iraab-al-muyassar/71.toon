quran[28]{c,v,t}:
  71,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل رفع فاعل، وجملة أرسلنا خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿نوحًا﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى قومه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مصدرية مؤولة مع مدخولها بمصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، والمعنى: أرسلناه بأن قلنا له: أنذر. أو مفسّرة، لأن الإرسال فيه معنى القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنذر﴾</span></span>: فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿قومك﴾</span></span>: مفعول به، والكاف مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنذر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: حرفي مصدري ونصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأتيهم﴾</span></span>: فعل مضارع منصوب، والهاء مفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يأتيهم﴾</span></span> مجرور بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿أليم﴾</span></span>: نعت مرفوع.</p></div>"
  71,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماضٍ، وفاعله مستتر، تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف نداء.</p><p><span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>: منادى مضاف منصوب بالفتحة المقدرة على ما قبل ياء المتكلم المحذوفة، وياء المتكلم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذير﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نذير﴾</span></span>: خبر إن مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span>: نعت مرفوع.</p></div>"
  71,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر منصوب بنزع الخافض، أي: بأن اعبدوا. والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذير﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿اعبدوا﴾</span></span>: فعل أمر مبني على حذف النون، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتقوه﴾</span></span>: معطوف على اعبدوا، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span>: عطف أيضا، وياء المتكلم المحذوفة مفعول به، وحذفت ياء المتكلم تخفيفا لتناسب الفواصل.</p></div>"
  71,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span>: فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ذنوبكم﴾</span></span>: جار ومجرور في موضع نصب مفعول يغفر، لأن من للتبعيض، أي: بعض ذنوبكم، والكاف مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويؤخركم﴾</span></span>: عطف على يغفر، والفاعل مستتر، والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى أجل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤخركم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مسمى﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿أجل﴾</span></span> مجرور بالكسرة المقدرة على الألف للتعذر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أجل﴾</span></span>: اسم إن منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة مضاف إليه، والجملة تعليلية.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: ظرف لما يستقبل من الزمن خافض لشرطه، متعلق بجوابه.</p><p><span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>: فعل ماض، والفاعل مستتر، وجملة جاء في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يؤخر﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله، وجملة لا يؤخر لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>: شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span>: فعل مضارع مرفوع بثبوت النون، والواو ضمير مبني في محل رفع فاعل، وجملة تعلمون خبر كان، وجواب لو محذوف كما حذف مفعول تعلمون، أي: لو كنتم تعلمون ذلك لآمنتم.</p></div>"
  71,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض، والفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربّ﴾</span></span>: منادى مضاف منصوب بالفتحة المقدرة على ما قبل ياء المتكلم المحذوفة، وياء المتكلم مضاف إليه، وحذف حرف النداء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿دعوت﴾</span></span>: فعل ماض، والتاء ضمير مبني في محل رفع فاعل، وجملة دعوت خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿قومي﴾</span></span>: مفعول به، والياء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليلا﴾</span></span>: ظرف منصوب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿دعوت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونهارًا﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿ليلا﴾</span></span>، والجملة مقول القول.</p></div>"
  71,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلم﴾</span></span>: الفاء عاطفة، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يزدهم﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والهاء مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿دعائي﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرارًا﴾</span></span>: مفعول به ثانٍ، والاستثناء مفرغ.</p></div>"
  71,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإني﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿كلما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كلَّ﴾</span></span> نائب ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span> متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية زمانية، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعوتهم﴾</span></span> لا محل لها من الإعراب لأنها صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع مدخولها في تأويل مصدر مجرور بالإضافة والتقدير: كلَّ دعوة، وهو على حذف مضاف، أي: كلَّ وقتِ دعوة. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة بمعنى <span class="hlt"><span class="qpc-hafs">﴿وقت﴾</span></span> والعائد محذوف والتقدير: كلَّ وقتٍ دَعَوْتهم فيه لتغفر لهم، فتكون جملة <span class="hlt"><span class="qpc-hafs">﴿دعوتهم﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿دعوتهم﴾</span></span>: فعل ماض، والتاء فاعل، والهاء مفعول به، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتغفر﴾</span></span>: اللام للتعليل، وتغفر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل المضارع بعدها في تأويل مصدر مجرور بلام التعليل، ولام التعليل ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دعوتهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغفر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span>: فعل ماضٍ، والواو ضمير مبني في محل رفع فاعل، وجملة جعلوا لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وهو كلما.</p><p><span class="hlt"><span class="qpc-hafs">﴿أصابعهم﴾</span></span>: مفعول جعلوا الأول، والهاء مضاف إليه، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿في آذانهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span> على معنى وضعوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿واستغشوا﴾</span></span>: عطف على جعلوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثيابهم﴾</span></span>: مفعول به، والهاء مضاف إليه، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأصروا واستكبروا﴾</span></span>: معطوفان أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿استكبارا﴾</span></span>: مفعول مطلق. وجملة الشرط والجواب في محل رفع خبر إن.</p></div>"
  71,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: ثم حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿دعوتهم﴾</span></span>: فعل ماض، والتاء فاعل، والهاء مفعول به، وجملة دعوتهم خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿جهارًا﴾</span></span>: نائب عن المفعول المطلق، لأنه نوع المصدر أو صفته، وقد يكون مصدرًا في موضع الحال، أي: مجاهرًا، أو ذا جهار.</p></div>"
  71,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: ثم حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿أعلنت﴾</span></span>: فعل ماض، والتاء فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلنت﴾</span></span>. وجملة أعلنت في محل رفع خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأسررت﴾</span></span>: عطف على أعلنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسررت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إسرارًا﴾</span></span>: مفعول مطلق.</p></div>"
  71,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقلت﴾</span></span>: الفاء عاطفة، وقلت فعل ماض والتاء فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿استغفروا﴾</span></span>: فعل أمر مبني على حذف النون، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span>: لفظ رب مفعول به، والكاف مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماض ناقص، واسمها مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿غفارا﴾</span></span>: خبر كان منصوب، وجملة كان خبر إن، وجملة استغفروا مقول القول، وجملة إنه كان غفارًا لا محل لها من الإعراب، لأنها تعليل للاستغفار.</p></div>"
  71,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>: يرسل فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر يعود على الله تعالى.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مدرارا﴾</span></span>: حال من السماء.</p></div>"
  71,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويمددكم﴾</span></span>: عطف على يرسل، ويمدد فعل مضارع مجزوم عطف على يرسل، والفاعل مستتر، والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بأموال﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمددكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبنين﴾</span></span>: عطف على أموال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعل﴾</span></span>: فعل مضارع مجزوم عطف على <span class="hlt"><span class="qpc-hafs">﴿ويمددكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعل لكم أنهارًا﴾</span></span>: عطف على الجملة السابقة.</p></div>"
  71,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم استفهام، في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترجون﴾</span></span>: فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة لا ترجون حال من الكاف في لكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: اللام حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بمحذوف حال، لأن اللام للتبيين، ولو تأخرت لكانت صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الوقار﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقارا﴾</span></span>: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿ترجون﴾</span></span>.</p></div>"
  71,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span>: الواو للحال، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span>: فعل ماضٍ، والفاعل مستتر، والكاف مفعول به، والجملة حالية من فاعل ترجون.</p><p><span class="hlt"><span class="qpc-hafs">﴿أطوارًا﴾</span></span>: حال مؤولة بالمشتق، أي: متنقلين من حال إلى حال.</p></div>"
  71,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم﴾</span></span>: الهمزة للاستفهام الإنكاري، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿تروا﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف النون، والواو فاعل، والرؤية علمية، أي: لم تعتبروا، وتتفكروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span>: اسم استفهام في محل نصب على الحال، والعامل فيها خلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>: فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة فاعل مرفوع، والجملة سدّت مسد مفعولي تروا المعلقة عن العمل بالاستفهام.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبع﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿سماوات﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿طباقًا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سبع﴾</span></span>، أو منصوب بفعل محذوف، أي: طبقت طباقًا، فيكون مصدر طابقت مطابقة وطباقًا.</p></div>"
  71,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعل﴾</span></span>: الواو عاطفة، وجعل فعل ماضٍ والفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿القمر﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيهن﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نورًا﴾</span></span>: مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل الشمس سراجًا﴾</span></span>: عطف على الجملة السابقة.</p></div>"
  71,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله﴾</span></span>: الواو عاطفة، والله مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنبتكم﴾</span></span>: فعل ماض، والفاعل مستتر، والكاف مفعول به، وجملة أنبتكم خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿من الأرض﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نباتا﴾</span></span>: نائب عن المفعول المطلق، لأنه اسم مصدر.</p></div>"
  71,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span>: فعل مضارع مرفوع، والفاعل مستتر، والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويخرجكم﴾</span></span>: الواو عاطفة، ويخرجكم فعل مضارع معطوف على <span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span> مرفوع، والفاعل مستتر، والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إخراجا﴾</span></span>: مفعول مطلق.</p></div>"
  71,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله﴾</span></span>: الواو حرف عطف، والله مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>: جعل فعل ماضٍ والفاعل مستتر، وجملة جعل خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span>: مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿بساطًا﴾</span></span>: مفعول به ثانٍ.</p></div>"
  71,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لتسلكوا﴾</span></span>: اللام لام التعليل، وتسلكوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعل المضارع بعدها في تأويل مصدر مجرور بلام التعليل، ولام التعليل ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿سبلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبلا﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجاجا﴾</span></span>: نعت.</p></div>"
  71,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿نوح﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: منادى منصوب مضاف إلى ياء المتكلم المحذوفة، والياء المحذوفة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿عصوني﴾</span></span>: فعل ماضٍ مبني على الضم المقدر على الألف المحذوفة لالتقاء الساكنين، والواو فاعل، والنون للوقاية، والياء مفعول به، وجملة عصوني خبر إن، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتبعوا﴾</span></span>: عطف على عصوني.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>: حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يزده﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماله﴾</span></span>: فاعل، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وولده﴾</span></span>: عطف على ماله.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿خسارًا﴾</span></span>: مفعول به ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿يزده﴾</span></span>.</p></div>"
  71,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومكروا﴾</span></span>: الواو عاطفة، ومكروا فعل ماضٍ والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿مكرا﴾</span></span>: مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿كبارا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مكرا﴾</span></span>.</p></div>"
  71,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا﴾</span></span>: الواو عاطفة، وقالوا فعل ماضٍ والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: ناهية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذرن﴾</span></span>: فعل مضارع مجزوم بلا، وعلامة جزمه حذف النون، والواو المحذوفة لالتقاء الساكنين فاعل، والنون المشددة نون التوكيد الثقيلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿آلهتكم﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تذرن﴾</span></span>: عطف على لا تذرن الأولى.</p><p><span class="hlt"><span class="qpc-hafs">﴿ودًّا﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، ولا صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿سواعا﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿ودًّا﴾</span></span> منصوب بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يغوث﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿ودا﴾</span></span> أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويعوق﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿ودا﴾</span></span> أيضا، والكلمتان <span class="hlt"><span class="qpc-hafs">﴿يغوث ويعوق﴾</span></span> ممنوعتان من الصرف للعلمية ووزن الفعل إن كانا عربيين، وللعلمية والعجمة إن كانا أعجميين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونسرا﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿ودا﴾</span></span> أيضًا.</p></div>"
  71,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span>: الواو عاطفة، وقد حرف تحقيق، وجملة قد أضلوا مقول قول محذوف معطوف على قال السابقة، أي: قال إنهم عصوني، وقال: قد أضلّوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿أضلوا﴾</span></span>: فعل والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة على القول المحذوف، ولا طلبية للدعاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿تزد﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الظالمين﴾</span></span>: مفعول به منصوب بالياء لأنه جمع مذكر سالم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ضلالا﴾</span></span>: مفعول به.</p></div>"
  71,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span>: من حرف جر، وما صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿خطيئاتهم﴾</span></span>: مجرور بمن التعليلية، والهاء مضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغرقوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أغرقوا﴾</span></span>: فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب الفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأدخلوا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أغرقوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نارا﴾</span></span>: مفعول به ثانٍ على السعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلم﴾</span></span>: الفاء عاطفة، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يجدوا﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة الجزم حذف النون، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿من دون﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنصارا﴾</span></span>: مفعول <span class="hlt"><span class="qpc-hafs">﴿يجدوا﴾</span></span> الأول.</p></div>"
  71,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال﴾</span></span>: الواو عاطفة، وقال فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿نوح﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: منادى منصوب مضاف إلي ياء المتكلم المحذوفة، والياء المحذوفة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: طلبية للدعاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذر﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿على الأرض﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من الكافرين﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ديارا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ديارا﴾</span></span>: مفعول تذر.</p></div>"
  71,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك﴾</span></span>: إن حرف ناسخ، والكاف اسمها، والجملة تعليلية.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذرهم﴾</span></span>: فعل الشرط مجزوم، والفاعل مستتر، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يضلوا﴾</span></span>: جواب الشرط مجزوم وعلامة الجزم حذف النون، والواو فاعل، وفعل الشرط وجوابه خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿عبادك﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يلدوا﴾</span></span>: فعل مضارع معطوف على <span class="hlt"><span class="qpc-hafs">﴿يضلوا﴾</span></span> مجزوم، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاجرا﴾</span></span>: مفعول يضلوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كفارا﴾</span></span>: نعت.</p></div>"
  71,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: منادى منصوب مضاف إلي ياء المتكلم المحذوفة، والياء المحذوفة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span>: فعل دعاء، والفاعل أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولوالدي﴾</span></span>: الواو عاطفة، ولوالدي معطوف على <span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> مجرور بالياء، وياء المتكلم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولمن﴾</span></span>: عطف أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿دخل﴾</span></span>: فعل ماض، والفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿بيتي﴾</span></span>: مفعول به منصوب بالفتحة المقدرة على ما قبل ياء المتكلم، وياء المتكلم مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿دخل بيتي﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿مؤمنا﴾</span></span>: حال منصوبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وللمؤمنين﴾</span></span>: عطف أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿والمؤمنات﴾</span></span>: عطف أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، ولا طلبية دعائية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تزد﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الظالمين﴾</span></span>: مفعول به أول منصوب بالياء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبارا﴾</span></span>: مفعول به ثانٍ.</p></div>"
