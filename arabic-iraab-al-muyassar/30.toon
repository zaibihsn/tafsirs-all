quran[60]{c,v,t}:
  30,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  30,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿غلبت الروم﴾</span></span>: غلبت: فعل ماض مبني لما لم يسمَّ فاعله، والروم: نائب فاعل.</p></div>"
  30,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في أدنى الأرض وهم من بعد غلبهم سيغلبون﴾</span></span>: في أدنى: جار ومجرور متعلقان بغلبت، والواو: عاطفة، وهم: مبتدأ، ومن بعد: جار ومجرور متعلقان بقوله سيغلبون، وغلبهم: مضاف إليه، وقد أضيف إلى مفعوله، وجملة سيغلبون: خبر المبتدأ.</p></div>"
  30,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في بضع سنين لله الأمر من قبل ومن بعد﴾</span></span>: في بضع سنين: جار ومجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿سيغلبون﴾</span></span>، ولله: خبر مقدم، والأمر: مبتدأ مؤخر، ومن قبل: جار ومجرور متعلقان بمحذوف حال، ومن: حرف جر، وقبل وبعد: ظرفان بنيا على الضم لقطعهما عن الإضافة لفظًا لا معنى، ثم جرا بمن، وبقيا على ضمهما.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويومئذ يفرح المؤمنون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يفرح﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة والتقدير: ويوم إذ يغلب الروم على فارس يفرح المؤمنون. و<span class="hlt"><span class="qpc-hafs">﴿يفرح﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنون﴾</span></span> فاعل.</p></div>"
  30,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بنصر الله ينصر من يشاء وهو العزيز الرحيم﴾</span></span>: بنصر: جار ومجرور متعلقان بيفرح، ولفظ الجلالة مضاف إليه، وينصر: فعل مضارع والفاعل ضمير مستتر، ومن: اسم موصول مفعول لينصر، وجملة يشاء: صلة الموصول لا محل لها من الإعراب. والواو عاطفة، وهو: مبتدأ، والعزيز: خبر أول، والرحيم: خبر ثان.</p></div>"
  30,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعد الله لا يخلف الله وعده ولكن أكثر الناس لا يعلمون﴾</span></span>: وعد: مفعول مطلق عامله مقدر، والتقدير: وعدهم الله ذلك وعدًا، ولا: نافية، و<span class="hlt"><span class="qpc-hafs">﴿يخلف الله وعده﴾</span></span>: فعل وفاعل ومفعول به، والضمير مضاف إليه، والواو: حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكنَّ أكثر﴾</span></span>: لكن حرف ناسخ، وأكثر اسمها، والناس: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span>: خبر لكِنَّ.</p></div>"
  30,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعلمون ظاهرا من الحياة الدنيا وهم عن الآخرة هم غافلون﴾</span></span>: يعلمون ظاهرا: فعل وفاعل ومفعول به، من الحياة الدنيا: جار ومجرور ونعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> مستأنفة لا محل لها من الإعراب، وهم: مبتدأ، وعن الآخرة: جار ومجرور متعلقان بغافلون، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الثانية: تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الأولى، وغافلون: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الأولى. أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الثانية مبتدأ و<span class="hlt"><span class="qpc-hafs">﴿غافلون﴾</span></span> خبرا لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الثانية، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم غافلون﴾</span></span> خبرا لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الأولى.</p></div>"
  30,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يتفكروا في أنفسهم ما خلق الله السماوات والأرض وما بينهما إلا بالحق وأجل مسمى﴾</span></span>: الهمزة: للاستفهام الإنكاري، والواو: عاطفة على مقدر يقتضيه السياق، ولم: حرف نفي وقلب وجزم، ويتفكروا: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وواو الجماعة: فاعل، وفي أنفسهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتفكروا﴾</span></span>. وما: نافية، وخلق الله السماوات: فعل وفاعل ومفعول به، والواو عاطفة، وما: اسم موصول مفعول به. بينهما: ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والضمير مضاف إليه، وإلا: أداة حصر، وبالحق: جار ومجرور متعلقان بحال محذوف من فاعل خلق، وأجل: عطف على الحق، ومسمى: نعت لأجل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كثيرا من الناس بلقاء ربهم لكافرون﴾</span></span>: الواو حالية، وإن حرف ناسخ، وكثيرا اسمها، ومن الناس: جار ومجرور متعلقان بنعت لكثيرًا، وبلقاء: جار ومجرور متعلقان بكافرون، وربهم: مضاف إليه، واللام: المزحلقة، وكافرون: خبر إن.</p></div>"
  30,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يسيروا في الأرض فينظروا كيف كان عاقبة الذين من قبلهم﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو: عاطفة على مقدر يقتضيه السياق، أي: أقعدوا في أماكنهم ولم يسيروا. ولم: حرف نفي وقلب وجزم، ويسيروا: فعل مضارع مجزوم بلم، والواو: فاعل، وفي الأرض: جار ومجرور متعلقان بيسيروا، فينظروا: الفاء عاطفة على يسيروا، أو الفاء سببية، وينظروا: فعل مضارع منصوب بأن مضمرة بعد الفاء، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ معطوف على مصدر مأخوذ من الكلام السابق تقديره: أولم يكن سير فنظر؟ وكيف: اسم استفهام في محل نصب خبر مقدم لكان، وعاقبة: اسمها، والذين: مضاف إليه، ومن قبلهم: جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب. والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانوا أشد منهم قوة وأثاروا الأرض وعمروها أكثر مما عمروها﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وأشد: خبرها، ومنهم: جار ومجرور متعلقان بأشد، وقوة: تمييز، وأثاروا الأرض: فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أثاروا﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿كانوا...﴾</span></span>. وعمروها: فعل وفاعل ومفعول به والواو عطفت الجملة على ما قبلها، وأكثر: نعت لمصدر محذوف، أي: عمارة أكثر، ومما: جار ومجرور متعلقان بأكثر، وما: مصدرية مؤولة مع ما بعدها بمصدر مجرور بمن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجاءتهم رسلهم بالبينات فما كان الله ليظلمهم ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو حالية، وجاءتهم رسلهم: فعل ومفعول به وفاعل، وبالبينات: جار ومجرور متعلقان بجاءتهم، والفاء: عاطفة، وما: نافية، كان الله: كان فعل ماض ناقص، ولفظ الجلالة اسمها، واللام: لام الجحود، ويظلمهم: فعل مضارع منصوب بأن مضمرة بعد لام الجحود، والجار والمجرور متعلقان بخبر كان المقدر، ولكن: الواو حالية، ولكن: حرف استدراك مهمل، وكانوا: فعل ماض ناقص، والواو: اسمها، وأنفسهم: مفعول مقدم ليظلمون، ويظلمون: فعل وفاعل والجملة خبر كانوا.</p></div>"
  30,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم كان عاقبة الذين أساءوا السوءى﴾</span></span>: ثم عاطفة، وكان: فعل ماض ناقص، وعاقبة: خبر كان المقدم، والذين: مضاف إليه، وجملة أساءوا: صلة الموصول لا محل لها من الإعراب. والسوأى: اسم كان.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن كذبوا بآيات الله وكانوا بها يستهزئون﴾</span></span>: أن حرف مصدري ونصب، وكذبوا: فعل ماض منصوب بأن، والواو فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن كذبوا﴾</span></span> منصوب بإسقاط الخافض، بآيات الله: جار ومجرور متعلقان بكذبوا، ولفظ الجلالة مضاف إليه، وكانوا: فعل ماض ناقص، وواو الجماعة اسمها، وبها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، وجملة يستهزئون: خبر كان.</p></div>"
  30,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله يبدأ الخلق ثم يعيده ثم إليه ترجعون﴾</span></span>: لفظ الجلالة: مبتدأ، ويبدأ الخلق: فعل وفاعل مستتر تقديره هو ومفعول به والجملة خبر المبتدأ، وثم حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعيده﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿يبدأ...﴾</span></span>.</p></div>"
  30,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم الساعة يبلس المجرمون﴾</span></span>: يوم ظرف متعلق بيبلس، وتقوم الساعة: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوم...﴾</span></span> في محل جر بإضافة الظرف إليها، ويبلس المجرمون: فعل وفاعل.</p></div>"
  30,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولم يكن لهم من شركائهم شفعاء وكانوا بشركائهم كافرين﴾</span></span>: الواو عاطفة، ولم: حرف نفي وقلب وجزم، ويكن: فعل مضارع ناقص مجزوم بلم، ولهم: خبر يكن المقدم، ومن شركائهم: جار ومجرور متعلقان بحال من شفعاء، وشفعاء: اسم يكن، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسمها، وبشركائهم: جار ومجرور متعلقان بكافرين، وكافرين: خبر كانوا.</p></div>"
  30,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم الساعة يومئذ يتفرقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتفرقون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span> في محل جر بإضافة الظرف إليها، ويومئذ: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتفرقون﴾</span></span> وهو تأكيد للظرف السابق أو بدل منه، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة، والتقدير: يوم إذ تقوم الساعة. ويتفرقون: فعل وفاعل.</p></div>"
  30,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما الذين آمنوا وعملوا الصالحات فهم في روضة يحبرون﴾</span></span>: الفاء تفريعية، وأما: حرف شرط وتفصيل، والذين: مبتدأ، وآمنوا: فعل وفاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. والواو عاطفة، وعملوا الصالحات: فعل وفاعل ومفعول به والجملة عطف على جملة الصلة قبلها لا محل لها من الإعراب. والفاء: في جواب الشرط، وهم: مبتدأ، وفي روضة: جار ومجرور متعلقان بيحبرون، وجملة يحبرون: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر الذين.</p></div>"
  30,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما الذين كفروا وكذبوا بآياتنا ولقاء الآخرة فأولئك في العذاب محضرون﴾</span></span>: الواو عاطفة، وأما: حرف شرط وتفصيل، والذين: مبتدأ، وكفروا: فعل وفاعل والجملة صلة الموصول لا محل لها من الإعراب. والواو عاطفة، وكذبوا: فعل وفاعل، بآياتنا: جار ومجرور متعلقان بكذبوا، والواو عاطفة، ولقاء: عطفت على آيات، والآخرة: مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span> عطف على جملة الصلة لا محل لها من الإعراب. والفاء: في جواب الشرط، وأولئك: مبتدأ، وفي العذاب: جار ومجرور، ومحضرون: خبر أولئك، والجملة خبر الذين.</p></div>"
  30,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبحان الله حين تمسون وحين تصبحون﴾</span></span>: الفاء الفصيحة، وسبحان: نائب مفعول مطلق منصوب بفعل محذوف، ولفظ الجلالة مضاف إليه، وحين: ظرف متعلق بسبحان، وتمسون: فعل مضارع مرفوع، والواو: فاعل، لأنها تامة، وجملة تمسون في محل جر بإضافة الظرف إليها، وحين تصبحون: عطف على حين تمسون.</p></div>"
  30,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وله الحمد في السماوات والأرض وعشيا وحين تظهرون﴾</span></span>: الواو: اعتراضية، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، والحمد: مبتدأ مؤخر، وفي السماوات: جار ومجرور متعلقان بحال من الحمد، والأرض: عطف على السماوات، وعشيا: عطف على <span class="hlt"><span class="qpc-hafs">﴿حين تمسون﴾</span></span>، وكذلك قوله: <span class="hlt"><span class="qpc-hafs">﴿وحين تظهرون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وله الحمد في السماوات والأرض﴾</span></span>: اعتراضية بين المعطوف والمعطوف عليه، لا محل لها من الإعراب.</p></div>"
  30,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يخرج الحي من الميت ويخرج الميت من الحي﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حالية، ويخرج: فعل مضارع، وفاعله ضمير مستتر تقديره هو، والحي: مفعول به، ومن الميت: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span>، ويخرج الميت من الحي: عطف على ما سبق.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويحيي الأرض بعد موتها وكذلك تخرجون﴾</span></span>: الواو عاطفة، ويحيي الأرض: فعل مضارع وفاعل مستتر ومفعول به، وبعد موتها: الظرف متعلق بيحيي ومضاف إليه، وكذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: ومثل ذلك الإخراج تخرجون، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وتخرجون: فعل مضارع مبني لما لم يسمَّ فاعله، وواو الجماعة نائب فاعل.</p></div>"
  30,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته أن خلقكم من تراب ثم إذا أنتم بشر تنتشرون﴾</span></span>: الواو عاطفة، ومن آياته: جار ومجرور متعلقان بمحذوف خبر مقدم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن خلقكم﴾</span></span> مبتدأ مؤخر، ومن تراب: جار ومجرور متعلقان بخلقكم، وثم: حرف عطف للتراخي، وإذا: فجائية، وأنتم: مبتدأ، وبشر: خبر، وجملة تنتشرون: حال.</p></div>"
  30,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته أن خلق لكم من أنفسكم أزواجا لتسكنوا إليها﴾</span></span>: الواو عاطفة، ومن آياته: خبر مقدم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن خلق﴾</span></span> مبتدأ مؤخر، ولكم: جار ومجرور متعلقان بخلق، ومن أنفسكم: جار ومجرور متعلقان بخلق، أو الجار والمجرور متعلقان بحال من <span class="hlt"><span class="qpc-hafs">﴿أزواجا﴾</span></span>، وأزواجًا: مفعول خلق، واللام: للتعليل، وتسكنوا: فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بخلق، وإليها: جار ومجرور متعلقان بتسكنوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل بينكم مودة ورحمة﴾</span></span>: الواو عاطفة، وجعل عطف على خلق، وبينكم: ظرف في موضع المفعول الثاني لجعل، ومودة: هو المفعول الأول، ورحمة: عطف على مودة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يتفكرون﴾</span></span>: إن: حرف توكيد ونصب، وفي ذلك: جار ومجرور خبر إن المقدم، واللام: المزحلقة، وآيات: اسمها المؤخر، ولقوم: جار ومجرور متعلقان بصفة لآيات، وجملة يتفكرون: صفة لقوم.</p></div>"
  30,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته خلق السماوات والأرض واختلاف ألسنتكم وألوانكم﴾</span></span>: الواو عاطفة، ومن آياته: خبر مقدم، وخلق: مبتدأ مؤخر، السماوات: مضاف إليه، والواو عاطفة، والأرض: عطف على السماوات، واختلاف: معطوفة على خلْق، وألسنتكم: مضاف إليه، والواو عاطفة، وألوانكم: معطوفة على ألسنتكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات للعالمين﴾</span></span>: إن حرف توكيد ونصب، وفي ذلك: جار ومجرور خبر إن المقدم، واللام: المزحلقة، وآيات: اسمها المؤخر، وللعالمين: جار ومجرور متعلقان بصفة لآيات.</p></div>"
  30,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته منامكم بالليل والنهار وابتغاؤكم من فضله﴾</span></span>: الواو عاطفة، ومن آياته: خبر مقدم، ومنامكم: مبتدأ مؤخر، وبالليل: جار ومجرور متعلقان بمنامكم، والنهار: معطوفة على الليل، وابتغاؤكم: عطف على منامكم، ومن فضله: جار ومجرور متعلقان بابتغاؤكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يسمعون﴾</span></span>: إن حرف توكيد ونصب، وفي ذلك: جار ومجرور خبر إن المقدم، واللام: المزحلقة، وآيات: اسمها المؤخر، ولقوم: جار ومجرور متعلقان بصفة لآيات، وجملة يسمعون: صفة لقوم.</p></div>"
  30,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته يريكم البرق خوفا وطمعا﴾</span></span>: الواو عاطفة، من آياته: جار ومجرور متعلقان بمحذوف خبر مقدم، ويريكم: فعل مضارع، وفاعل مستتر، يعود على الله، والكاف: مفعول به أول، والبرق: مفعول به ثان، والمصدر المؤول من أن المصدرية المحذوفة و<span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿خوفًا وطمعًا﴾</span></span> منصوبان على المصدرية، أي: لتخافوا خوفًا ولتطمعوا طمعًا، أو حالان من الكاف في <span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span>، أي: حال كونكم خائفين وطامعين، أو من البرق، والتقدير: يريكم البرق ذا خوف وذا طمع، أو جعل البرق في نفسه خوفا وطمعا على المبالغة، أو مفعولان لأجلهما.</p><p><span class="hlt"><span class="qpc-hafs">﴿وينزل من السماء ماء فيحيي به الأرض بعد موتها﴾</span></span>: الواو عاطفة، وينزل عطف على يريكم، ومن السماء: جار ومجرور متعلقان بينزل، وماء: مفعول به، فيحيي: عطف على ينزل، وبه: جار ومجرور متعلقان بيحيي، والأرض: مفعول به، وبعد موتها: الظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يعقلون﴾</span></span>: إن حرف توكيد ونصب، وفي ذلك: جار ومجرور خبر إن المقدم، واللام: المزحلقة، وآيات: اسمها المؤخر، ولقوم: جار ومجرور متعلقان بصفة لآيات، وجملة يعقلون: صفة لقوم.</p></div>"
  30,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته أن تقوم السماء والأرض بأمره﴾</span></span>: الواو عاطفة على ما تقدم، ومن آياته: خبر مقدم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن تقوم﴾</span></span> مبتدأ مؤخر، والسماء: فاعل تقوم، والأرض: عطف على السماء، وبأمره: جار ومجرور متعلقان بتقوم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم إذا دعاكم دعوة من الأرض إذا أنتم تخرجون﴾</span></span>: ثم حرف عطف للترتيب مع التراخي، وإذا: ظرف مستقبل متضمن معنى الشرط، ودعاكم: فعل ماض وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعاكم﴾</span></span> في محل جر بإضافة الظرف إليها. ودعوة: نائب مفعول مطلق لإنه اسم مصدر، منصوب وعلامة النصب الفتحة. ومن الأرض: جار ومجرور متعلقان بدعاكم، وإذا الفجائية تقوم مقام الفاء في جواب الشرط، وأنتم: مبتدأ، وجملة تخرجون: خبر.</p></div>"
  30,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وله من في السماوات والأرض كل له قانتون﴾</span></span>: الواو عاطفة، وله: جار ومجرور في محل رفع خبر مقدم، ومن: مبتدأ مؤخر، وفي السماوات: جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والأرض: عطف على السماوات. وكل: مبتدأ، وله: جار ومجرور متعلقان بقانتون، وقانتون: خبر كل.</p></div>"
  30,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي يبدأ الخلق ثم يعيده وهو أهون عليه﴾</span></span>: الواو عاطفة، وهو: مبتدأ، والذي: خبر، و<span class="hlt"><span class="qpc-hafs">﴿يبدأ الخلق﴾</span></span>: فعل وفاعل ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبدأ﴾</span></span> صلة الموصول لا محل لها من الإعراب. وثم: حرف عطف. يعيده: فعل مضارع، والفاعل مستتر، والهاء: مفعول به. <span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span>: الواو حالية أو عاطفة، وهو: مبتدأ. وأهون: خبره. وعليه: جار ومجرور متعلقان بأهون.</p><p><span class="hlt"><span class="qpc-hafs">﴿وله المثل الأعلى في السماوات والأرض وهو العزيز الحكيم﴾</span></span>: الواو عاطفة، وله: خبر مقدم، والمثل: مبتدأ مؤخر، والأعلى: صفة، وفي السماوات: جار ومجرور متعلقان بحال، والأرض: عطف على السماوات، وهو: مبتدأ، والعزيز: خبر أول، والحكيم: خبر ثان.</p></div>"
  30,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ضرب لكم مثلا من أنفسكم﴾</span></span>: ضرب: فعل ماض وفاعله مستتر تقديره هو، ولكم: في محل نصب مفعول ثان، ومثلا: هو المفعول الأول، ومن أنفسكم: جار ومجرور متعلقان بصفة لمثلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل لكم من ما ملكت أيمانكم من شركاء في ما رزقناكم﴾</span></span>: هل: حرف استفهام، ولكم: خبر مقدم، ومما: جار ومجرور متعلقان بحال من شركاء، وجملة ملكت: صلة الموصول لا محل لها من الإعراب. وأيمانكم: فاعل ملكت، ومن: حرف جر صلة، وشركاء: مبتدأ مؤخر، وفيما رزقناكم: جار ومجرور متعلقان بشركاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنتم فيه سواء تخافونهم كخيفتكم أنفسكم كذلك نفصل الآيات لقوم يعقلون﴾</span></span>: الفاء: واقعة في جواب الاستفهام، وأنتم: مبتدأ، وفيه: جار ومجرور متعلقان بسواء، وسواء: خبر، وجملة تخافونهم: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> أو في موضع حال من ضمير الفاعل في سواء، وكخيفتكم: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: خيفة مثل خيفتكم، و<span class="hlt"><span class="qpc-hafs">﴿خيفتكم﴾</span></span> مضاف إليه، وأنفسكم: مفعول به للمصدر <span class="hlt"><span class="qpc-hafs">﴿خيفتكم﴾</span></span>. كذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ونفصل: فعل مضارع وفاعله مستتر تقديره نحن، والآيات: مفعول به، ولقوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفصِّل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعقلون﴾</span></span> صفة لقوم.</p></div>"
  30,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل اتبع الذين ظلموا أهواءهم بغير علم﴾</span></span>: بل: حرف إضراب وعطف، واتبع: عطف على طريق الالتفات، والذين: فاعل اتبع، وظلموا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> صلة الذين لا محل لها من الإعراب. وأهواءهم: مفعول به، وبغير: جار ومجرور متعلقان بحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن يهدي من أضل الله﴾</span></span>: الفاء الفصيحة، ومن: اسم استفهام في محل رفع مبتدأ، وجملة يهدي: خبر، ومن: مفعول يهدي، وجملة <span class="hlt"><span class="qpc-hafs">﴿أضل الله﴾</span></span>: صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي: أضله الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما لهم من ناصرين﴾</span></span>: الواو: حرف عطف، وما: نافية، ولهم: جار ومجرور متعلقان بخبر مقدم، ومن: حرف جر صلة، وناصرين: مجرور لفظًا مرفوع محلا مبتدأ مؤخر.</p></div>"
  30,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقم وجهك للدين حنيفا﴾</span></span>: الفاء الفصيحة، وأقم: فعل أمر وفاعله مستتر تقديره أنت، ووجهك: مفعول به، وللدين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، وحنيفًا: حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span> أو من مفعوله أو من الدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿فطرت الله التي فطر الناس عليها﴾</span></span>: فطرة: مفعول به لفعل محذوف تقديره: الزموا فطرة الله، والتي: صفة للفطرة، وفطر الناس: فعل ماض وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فطر الناس﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وعليها: جار ومجرور متعلقان بفطر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تبديل لخلق الله﴾</span></span>: لا: نافية للجنس، وتبديل: اسمها المبني على الفتح، ولخلق الله: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك الدين القيم﴾</span></span>: ذلك: مبتدأ: والدين: خبره، والقيم: صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس لا يعلمون﴾</span></span>: الواو: حالية أو استئنافية، ولكن حرف ناسخ، وأكثر اسمها، لا: نافية، يعلمون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر لكن، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر...﴾</span></span> في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  30,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿منيبين إليه واتقوه وأقيموا الصلاة ولا تكونوا من المشركين﴾</span></span>: منيبين: حال من فاعل الزموا المضمر، واتقوه: عطف على الزموا المضمرة، وكذلك قوله: وأقيموا الصلاة، ولا: ناهية، وتكونوا: فعل مضارع ناقص مجزوم بلا الناهية، وواو الجماعة اسمها، ومن المشركين: خبرها.</p></div>"
  30,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من الذين فرقوا دينهم وكانوا شيعا﴾</span></span>: من الذين: جار ومجرور بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿من المشركين﴾</span></span> بإعادة العامل، وفرقوا: فعل ماض وواو الجماعة فاعل، ودينهم: مفعول به والهاء مضاف إليه والميم علامة الجمع. وجملة <span class="hlt"><span class="qpc-hafs">﴿فرقوا دينهم﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وكانوا شيعا: كان فعل ماض ناقص، وواو الجماعة اسمها، وشيعا خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿كل حزب بما لديهم فرحون﴾</span></span>: كل حزب: مبتدأ، وبما: جار ومجرور متعلقان بفرحون، ولديهم: الظرف متعلق بمحذوف صلة للموصول، وجملة الصلة لا محل لها من الإعراب. وفرحون: خبر كل.</p></div>"
  30,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مس الناس ضر دعوا ربهم منيبين إليه﴾</span></span>: الواو استئنافية، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿مس﴾</span></span>: في محل جر بإضافة الظرف إليها، والناس: مفعول به مقدم، وضر: فاعل مؤخر، دعوا ربهم: فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعوا ربهم﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومنيبين: حال من فاعل دعوا، وإليه: جار ومجرور متعلقان بمنيبين، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذا مس الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم إذا أذاقهم منه رحمة إذا فريق منهم بربهم يشركون﴾</span></span>: ثم حرف عطف للترتيب والتراخي، وإذا: شرطية، وأذاقهم: فعل وفاعل مستتر ومفعول به أول، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذاقهم﴾</span></span> في محل جر بإضافة الظرف إليها، ومنه: جار ومجرور متعلقان بحال من رحمة، ورحمة: مفعول به ثان، وإذا: الفجائية تقوم مقام الفاء في جواب الشرط، وفريق: مبتدأ، ومنهم: صفة، وبربهم: جار ومجرور متعلقان بيشركون، ويشركون: فعل وفاعل، وجملة يشركون: في محل رفع خبر.</p></div>"
  30,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليكفروا بما آتيناهم﴾</span></span>: اللام للتعليل أو للعاقبة والصيرورة، ويكفروا: فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن المضمرة والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span>، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span>: صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتمتعوا فسوف تعلمون﴾</span></span>: الفاء عاطفة، وتمتعوا: فعل أمر، والفاء: واقعة في جواب الأمر، وسوف: حرف استقبال، وتعلمون: فعل مضارع مرفوع والواو فاعل.</p></div>"
  30,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم أنزلنا عليهم سلطانا فهو يتكلم بما كانوا به يشركون﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والاستفهام للإنكار والتوبيخ، وأنزلنا: فعل وفاعل، وعليهم: جار ومجرور متعلقان بأنزلنا، وسلطانا: مفعول به، والفاء: حرف عطف، وهو: مبتدأ، وجملة يتكلم: فعل وفاعل في محل رفع خبر، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتكلم﴾</span></span>، وجملة كانوا: صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسمها، وبه: جار ومجرور متعلقان بيشركون، وجملة يشركون: خبر كان.</p></div>"
  30,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا أذقنا الناس رحمة فرحوا بها﴾</span></span>: الواو عاطفة، وإذا: ظرف متضمن معنى الشرط، وأذقنا: فعل وفاعل، والناس: مفعول به أول، ورحمة: مفعول به ثان، وجملة أذقنا: في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿فرحوا بها﴾</span></span>: لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن تصبهم سيئة بما قدمت أيديهم إذا هم يقنطون﴾</span></span>: الواو عاطفة، وتصبهم: فعل الشرط، وسيئة: فاعل، والباء: سببية، وما: اسم موصول في محل جر بالباء، والجار والمجرور متعلقان بتصبهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمت أيديهم﴾</span></span> صلة الموصول لا محل لها من الإعراب، وإذا: الفجائية وقد نابت عن الفاء في ربط الجواب بالشرط، وهم: مبتدأ، وجملة يقنطون: خبر، وجملة إذا هم يقنطون: في محل جزم جواب الشرط.</p></div>"
  30,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا أن الله يبسط الرزق لمن يشاء ويقدر﴾</span></span>: الهمزة للاستفهام الإنكاري المفيد للتقرير، والواو: عاطفة على محذوف يقتضيه السياق، ولم: حرف نفي وقلب وجزم، ويروا: فعل مضارع مجزوم بلم، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبسط الرزق﴾</span></span>: خبرها، ولمن: جار ومجرور متعلقان بيبسط، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. ويقدر: عطف على يبسط، وأنّ وما في حيزها: سدت مسد مفعولي يروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يؤمنون﴾</span></span>: إن حرف توكيد ونصب، وفي ذلك: جار ومجرور خبر إن المقدم، واللام: المزحلقة، وآيات: اسمها المؤخر، ولقوم: جار ومجرور متعلقان بصفة لآيات، وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>: صفة لقوم.</p></div>"
  30,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فآت ذا القربى حقه والمسكين وابن السبيل﴾</span></span>: الفاء الفصيحة لأنها أفصحت عن مقدر، أي: إن عرفتَ أن السيئة أصابتهم بما قدمت أيديهم فآت. وآت: فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره أنت، وذا القربى: مفعول به أول، وحقه: مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك خير للذين يريدون وجه الله وأولئك هم المفلحون﴾</span></span>: ذلك: مبتدأ، وخير: خبر، وللذين: جار ومجرور متعلقان بخير، ويريدون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. ووجه الله: مفعول به، والواو عاطفة، وأولئك: مبتدأ، وهم: مبتدأ ثان، والمفلحون: خبر <span class="hlt">«هم»</span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم المفلحون﴾</span></span>: خبر أولئك.</p></div>"
  30,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما آتيتم من ربا ليربو في أموال الناس فلا يربو عند الله﴾</span></span>: الواو عاطفة، وما: شرطية في محل نصب مفعول به مقدم لآتيتم، وآتيتم: فعل وفاعل، ومن ربا: جار ومجرور متعلقان بحال، وليربوا: اللام للتعليل، ويربو: فعل مضارع منصوب بأن مضمرة بعد اللام، وأن المضمرة والفعل المضارع في تأويل مصدر مجرور بلام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتيتم﴾</span></span>، وفي أموال الناس: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يربو﴾</span></span>، والفاء: رابطة لجواب الشرط، ولا: نافية، ويربو: فعل مضارع مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا يربو﴾</span></span>: في محل جزم جواب الشرط، وعند الله: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يربو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما آتيتم من زكاة تريدون وجه الله فأولئك هم المضعفون﴾</span></span>: الواو عاطفة، وما: شرطية في محل نصب مفعول به مقدم لآتيتم، وآتيتم: فعل وفاعل، ومن زكاة: جار ومجرور متعلق بحال، وتريدون: فعل وفاعل، ووجه الله: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span> في محل نصب حال من فاعل آتيتم، والفاء: رابطة لجواب الشرط، وأولئك: مبتدأ، وهم المضعفون: مبتدأ وخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم المضعفون﴾</span></span> في محل رفع خبر أولئك.</p></div>"
  30,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله الذي خلقكم ثم رزقكم ثم يميتكم ثم يحييكم﴾</span></span>: الله: مبتدأ، والذي خلقكم: خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> صلة الموصول لا محل لها من الإعراب. وما بعده عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل من شركائكم من يفعل من ذلكم من شيء﴾</span></span>: هل حرف استفهام، ومن شركائكم: جار ومجرور متعلقان بخبر مقدم، ومن يفعل: مبتدأ مؤخر، ومن ذلكم: جار ومجرور متعلقان بمحذوف حال من شيء، ومِن: حرف جر صلة، وشيء: مجرور بمن لفظا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span> منصوب محلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحانه وتعالى عما يشركون﴾</span></span>: سبحانه: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه، وتعالى: فعل ماض، وعما: جار ومجرور متعلقان بتعالى، وما: مصدرية، أو: موصولة.</p></div>"
  30,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ظهر الفساد في البر والبحر بما كسبت أيدي الناس﴾</span></span>: ظهر الفساد: فعل وفاعل، وفي البر: جار ومجرور متعلقان بظهر أو بمحذوف حال من الفساد، ولعله أرجح، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظهر الفساد...﴾</span></span> مستأنفة لا محل لها من الإعراب. وبما: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولية، أي: بسبب الذي كسبوه، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما كسبوا﴾</span></span> مجرور بالباء، أي: بسبب كسبهم، والجار والمجرور متعلقان بظهر، وأيدي الناس: فاعل كسبت.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليذيقهم بعض الذي عملوا لعلهم يرجعون﴾</span></span>: اللام: لام التعليل، ويذيقهم: فعل مضارع منصوب بأن مضمرة، وأن المضمرة والفعل المضارع في تأويل مصدر مجرور بلام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهر﴾</span></span> أو بمحذوف والتقدير: عاقبهم بذلك ليذيقهم. وقيل: اللام في <span class="hlt"><span class="qpc-hafs">﴿ليذيقهم﴾</span></span> ليست للتعليل بل للصيرورة. وهم: مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿يذيق﴾</span></span>، وبعض الذي عملوا: مفعوله الثاني، ولعلهم: لعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يرجعون: خبرها.</p></div>"
  30,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل سيروا في الأرض فانظروا كيف كان عاقبة الذين من قبل﴾</span></span>: قل: فعل أمر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيروا في الأرض﴾</span></span> مقول القول في محل نصب، فانظروا: عطف على سيروا، وكيف: اسم استفهام في محل نصب خبر كان المقدم، وكان فعل ماض ناقص، وعاقبة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كيف كان ...﴾</span></span> في محل نصب مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿انظروا﴾</span></span>، ومن قبل: جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان أكثرهم مشركين﴾</span></span>: كان فعل ماض ناقص، وأكثرهم اسمها، والضمير مضاف إليه، ومشركين: خبر كان.</p></div>"
  30,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقم وجهك للدين القيم﴾</span></span>: الفاء الفصيحة، وأقم: فعل أمر، وفاعله مستتر تقديره أنت، ووجهك: مفعول به، وللدين: جار ومجرور متعلقان بأقم، والقيم: صفة للدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿من قبل أن يأتي يوم لا مرد له من الله يومئذ يصدعون﴾</span></span>: من قبل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما بعدها مضاف إليه، ويوم: فاعل يأتي، ولا: نافية للجنس، ومرد: اسمها، وله: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا مرد له...﴾</span></span> صفة ليوم، ومن الله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يصدعون﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة والتقدير: يوم إذ يأتي ذلك اليوم، ويصدعون: فعل مضارع، وواو الجماعة فاعل.</p></div>"
  30,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كفر فعليه كفره﴾</span></span>: من: اسم شرط جازم في محل رفع مبتدأ، وكفر: فعل ماض في محل جزم فعل الشرط، والفاء: رابطة للجواب، وعليه: خبر مقدم، وكفره: مبتدأ مؤخر، والجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر مَن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن عمل صالحا فلأنفسهم يمهدون﴾</span></span>: الواو عاطفة، من: اسم شرط جازم في محل رفع مبتدأ، وعمل: فعل ماض في محل جزم فعل الشرط، وصالحا: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. والفاء: رابطة لجواب الشرط، ولأنفسهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمهدون﴾</span></span>، ويمهدون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمهدون﴾</span></span> في محل رفع خبر لمبتدأ محذوف تقديره هم،  والجملة الاسمية في محل جزم جواب الشرط.</p></div>"
  30,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليجزي الذين آمنوا وعملوا الصالحات من فضله﴾</span></span>: اللام: للتعليل، ويجزي: فعل مضارع منصوب بأن مضمرة بعد اللام، وأن المضمرة والفعل المضارع في تأويل مصدر مجرور بلام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمهدون﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿يصدعون﴾</span></span> أو بمحذوف خبر لمبتدأ محذوف، أي: ذلك كائن ليجزي. والذين: مفعول يجزي، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، ومن فضله: جار ومجرور متعلقان بيجزي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا يحب الكافرين﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة لا يحب: خبرها، والكافرين: مفعول به، والجملة لا محل لها من الإعراب لأنها تعليلية.</p></div>"
  30,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن آياته أن يرسل الرياح مبشرات﴾</span></span>: الواو استئنافية، ومن آياته: جار ومجرور متعلقان بخبر مقدم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يرسل﴾</span></span> مبتدأ مؤخر، والرياح: مفعول به، ومبشرات: حال من الرياح.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليذيقكم من رحمته ولتجري الفلك بأمره ولتبتغوا من فضله ولعلكم تشكرون﴾</span></span>: الواو عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليذيقكم﴾</span></span> عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿مبشرات﴾</span></span> والتقدير: ليبشركم وليذيقكم. ومن رحمته: جار ومجرور متعلقان بيذيقكم، ولتجري الفلك: اللام للعاقبة أو الصيرورة وتجري الفلك: فعل وفاعل، وبأمره: جار ومجرور متعلقان بتجري أو متعلقان بحال من الفلك. ولتبتغوا من فضله: عطف أيضا، ولعلكم تشكرون: لعل حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة تشكرون: خبرها.</p></div>"
  30,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا من قبلك رسلا إلى قومهم فجاءوهم بالبينات﴾</span></span>: الواو استئنافية، واللام واقعة في جواب قسم مقدر، وقد: حرف تحقيق، وأرسلنا: فعل وفاعل، ومن قبلك: جار ومجرور متعلقان بحال من رسلا، ورسلا: مفعول به، وإلى قومهم: جار ومجرور متعلقان بأرسلنا، والفاء عاطفة، وجاءوهم: فعل وفاعل ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا...﴾</span></span> مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءوهم﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وبالبينات: جار ومجرور متعلقان بجاءوهم أو بمحذوف حال من فاعل جاءوهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فانتقمنا من الذين أجرموا﴾</span></span>: الفاء: عاطفة على محذوف تقديره: فكذبوهم فانتقمنا، ومن الذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انتقمنا﴾</span></span>، وجملة أجرموا: صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان حقا علينا نصر المؤمنين﴾</span></span>: الواو استئنافية، وكان: فعل ماض ناقص، وحقا: خبرها المقدم، وعلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقا﴾</span></span> أو بمحذوف صفة له، ونصر المؤمنين: اسم كان المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكان حقا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  30,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله الذي يرسل الرياح فتثير سحابا فيبسطه في السماء كيف يشاء﴾</span></span>: الله: مبتدأ، والذي: خبره، ويرسل الرياح: فعل وفاعل ومفعول والجملة صلة الموصول، فتثير: عطف على يرسل، وسحابًا: مفعول به، والفاء: عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبسطه﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿تثير﴾</span></span>، وفي السماء: جار ومجرور متعلقان بيبسطه، وكيف: أداة شرط وتعليق في محل نصب حال، وجوابها محذوف، أي: كيف يشاء يبسطه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعله كسفا﴾</span></span>: الواو عاطفة، ويجعله: عطف على يبسطه، والهاء: مفعول <span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span> الأول، وكسفا: مفعول <span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span> الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿فترى الودق يخرج من خلاله﴾</span></span>: فترى: عطف على الجملة السابقة، وفاعل <span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span> مستتر تقديره أنت، والودق: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span> حالية، ومن خلاله: جار ومجرور متعلقان بيخرج.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا أصاب به من يشاء من عباده إذا هم يستبشرون﴾</span></span>: الفاء عاطفة، وإذا: ظرف مستقبل متضمن معنى الشرط، وجملة أصاب: في محل جر بإضافة الظرف إليها، وبه: جار ومجرور متعلقان بأصاب، ومن: مفعول أصاب، يشاء: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف والتقدير: يشاؤه. ومن عباده: جار ومجرور متعلقان بحال من الاسم الموصول أو من العائد <span class="hlt"><span class="qpc-hafs">﴿الهاء المحذوفة﴾</span></span>، وإذا: فجائية واقعة في جواب إذا الأولى، وهم: مبتدأ، وجملة يستبشرون: خبر.</p></div>"
  30,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كانوا من قبل أن ينزل عليهم من قبله لمبلسين﴾</span></span>: الواو حالية أو عاطفة، وإن: مخففة من الثقيلة مهملة، وكان فعل ماض ناقص، وواو الجماعة اسمها، ومن قبل: جار ومجرور متعلقان بمبلسين أو بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله منصوب بأن، ونائب الفاعل مستتر تقديره هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن ينزل﴾</span></span> مضاف إليه، وعليهم: جار ومجرور متعلقان بيُنَزَّل، و<span class="hlt"><span class="qpc-hafs">﴿من قبله﴾</span></span> الثانية تكرير وتوكيد لـ<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> الأولى، واللام الفارقة، ومبلسين: خبر كان.</p></div>"
  30,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانظر إلى آثار رحمت الله كيف يحي الأرض بعد موتها﴾</span></span>: الفاء الفصيحة، أي: إذا أردت أن تعرف ما يترتب على إنزال المطر فانظر. وانظر: فعل أمر، وفاعله مستتر تقديره أنت، وإلى آثار: جار ومجرور متعلقان بانظر، ورحمة: مضاف إليه، واسم الجلالة: مضاف إليه، وكيف: اسم استفهام في محل نصب على الحال، وهي معلقة لـ<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> عن العمل، ويحيي: فعل وفاعل، والأرض: مفعول به، وبعد موتها: ظرف متعلق بيحيي، وجملة <span class="hlt"><span class="qpc-hafs">﴿كيف يحيي...﴾</span></span> بدل من آثار، فهي في حيز النصب بنزع الخافض.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ذلك لمحي الموتى وهو على كل شيء قدير﴾</span></span>: إن حرف ناسخ، وذلك اسمها، واللام: المزحلقة، ومحيي الموتى: خبرها، وهو: مبتدأ، وعلى كل شيء: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بقدير، وقدير: خبر هو.</p></div>"
  30,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن أرسلنا ريحا فرأوه مصفرا لظلوا من بعده يكفرون﴾</span></span>: الواو عاطفة، واللام: موطئة للقسم دخلت على حرف الشرط، وأرسلنا: فعل وفاعل في محل جزم فعل الشرط، وريحا: مفعول أرسلنا، فرأوه: فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأوه﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ومصفرا: حال، ولظلوا: اللام واقعة في جواب القسم، وظلوا: فعل ماض ناقص، والواو: اسمها، والجملة لا محل لها من الإعراب، لأنها جواب القسم وقد أغنت عن جواب الشرط، ومن بعده: جار ومجرور متعلقان بيكفرون أو متعلقان بحال، وجملة يكفرون: خبر ظلوا.</p></div>"
  30,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنك لا تسمع الموتى ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</span></span>: الفاء تعليلية، والجملة تعليل لمحذوف، أي: لا تحزن على عدم إيمانهم فإنك لا تُسمِع الموتى...إلخ. وإن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تسمع الموتى﴾</span></span>: خبرها، ولا تسمع الصم الدعاء: عطف على الجملة السابقة، والصم: مفعول تُسمِع الأول، والدعاء: مفعول تُسمِع الثاني، وإذا: ظرف مستقبل متعلق بتُسمِع، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولوا﴾</span></span> في محل جر بإضافة الظرف إليها، وولوا: فعل ماض وواو الجماعة فاعل، ومدبرين: حال من واو الجماعة.</p></div>"
  30,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت بهاد العمي عن ضلالتهم﴾</span></span>: الواو عاطفة، وما: نافية عاملة عمل ليس، وأنت: اسم ما، والباء: حرف جر صلة، وهادي: مجرور لفظا منصوب محلا لأنه خبر ما، والعمي: مضاف إليه، وعن ضلالتهم: جار ومجرور متعلقان بهادي على تضمين هادي معنى صارف، أو متعلقان بالعمي.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تسمع إلا من يؤمن بآياتنا فهم مسلمون﴾</span></span>: إن نافية، وتسمع: فعل مضارع مرفوع وفاعله مستتر تقديره أنت، وإلا: أداة حصر، ومَن: مفعول به، وجملة يؤمن: صلة مَن لا محل لها من الإعراب. وبآياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>. فهم: الفاء عاطفة، وهم: مبتدأ، ومسلمون: خبر.</p></div>"
  30,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله الذي خلقكم من ضعف﴾</span></span>: لفظ الجلالة مبتدأ، والذي: خبر، وجملة خلقكم: صلة الموصول لا محل لها من الإعراب. ومن ضعف: جار ومجرور متعلقان بخلقكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعل من بعد ضعف قوة ثم جعل من بعد قوة ضعفا وشيبة﴾</span></span>: ثم: حرف عطف وتراخ، وجعل: فعل ماض، ومن بعد ضعف: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بجعل، وقوة: مفعول جعل، وثم وما بعدها: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿يخلق ما يشاء وهو العليم القدير﴾</span></span>: يخلق ما: فعل وفاعل مستتر ومفعول، والجملة حالية، وهو: مبتدأ، والعليم: خبر أول، والقدير: خبر ثان.</p></div>"
  30,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم الساعة يقسم المجرمون ما لبثوا غير ساعة﴾</span></span>: الواو استئنافية، ويوم: ظرف متعلق بيقسم، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span> في محل جر بإضافة الظرف إليها، ويقسم المجرمون: فعل وفاعل، وما: نافية، ولبثوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لبثوا...﴾</span></span> لا محل لها من الإعراب، لأنها واقعة في جواب القسم، وغير: ظرف متعلق بلبثوا، وساعة: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك كانوا يؤفكون﴾</span></span>: كذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: كانوا يؤفكون إفكا مثل ذلك، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وكان فعل ماض ناقص، وواو الجماعة اسمها، ويؤفكون: فعل مضارع مبني لما لم يسمَّ فاعله، وواو الجماعة نائب فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤفكون﴾</span></span> خبر كانوا.</p></div>"
  30,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين أوتوا العلم والإيمان لقد لبثتم في كتاب الله إلى يوم البعث﴾</span></span>: الواو عاطفة، وقال الذين: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعلم: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أوتوا﴾</span></span>، والإيمان: عطف على العلم. لقد: اللام: جواب لقسم محذوف، وقد: حرف تحقيق، ولبثتم: فعل وفاعل، وفي كتاب الله: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبثتم﴾</span></span>، وإلى يوم البعث: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بلبثتم، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد لبثتم ...﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهذا يوم البعث ولكنكم كنتم لا تعلمون﴾</span></span>: الفاء عاطفة على جملة <span class="hlt"><span class="qpc-hafs">﴿لقد لبثتم﴾</span></span> أو فصيحة والتقدير: إن كنتم منكرين للبعث فهذا يوم البعث. وهذا: مبتدأ، ويوم: خبر، والبعث: مضاف إليه. ولكنكم: الواو حالية، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم ...﴾</span></span>: خبر لكن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعلمون﴾</span></span>: خبر كان.</p></div>"
  30,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيومئذ لا ينفع الذين ظلموا معذرتهم ولا هم يستعتبون﴾</span></span>: الفاء عاطفة أو فصيحة، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بالفعل المنفي <span class="hlt"><span class="qpc-hafs">﴿ينفع﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ تقوم الساعة لا ينفع. ولا: نافية، وينفع: فعل مضارع، والذين: مفعوله المقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> صلة الموصول لا محل لها من الإعراب. ومعذرتهم: فاعل ينفع، والواو: حرف عطف، ولا: نافية، وهم: مبتدأ، ويستعتبون: فعل مضارع مبني لما لم يسمَّ فاعله وواو الجماعة نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستعتبون﴾</span></span>: خبر.</p></div>"
  30,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد ضربنا للناس في هذا القرآن من كل مثل﴾</span></span>: الواو استئنافية، واللام واقعة في جواب قسم مقدر، وقد: حرف تحقيق، وضربنا: فعل وفاعل، وللناس: جار ومجرور متعلقان بضربنا، وفي هذا القرآن: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بضربنا، ومن كل مثل: جار ومجرور ومضاف إليه والجار والمجرور متعلقان بصفة لموصوف محذوف هو مفعول ضربنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد ضربنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن جئتهم بآية ليقولن الذين كفروا إن أنتم إلا مبطلون﴾</span></span>: الواو عاطفة، واللام: موطئة للقسم، وإن: شرطية، وجئتهم: فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿جئتهم﴾</span></span> في موضع فعل الشرط، وبآية: جار ومجرور متعلقان بجئتهم، وليقولن: اللام واقعة في جواب القسم، ويقولن: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والذين: اسم موصول في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الذين لا محل لها من الإعراب. وإن: نافية، وأنتم: مبتدأ، وإلا: أداة حصر، ومبطلون: خبر أنتم، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن أنتم ...﴾</span></span> مقول القول في محل نصب.</p></div>"
  30,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك يطبع الله على قلوب الذين لا يعلمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف والتقدير: طبعًا مثلَ ذلك الطبع يطبع اللهُ على قلوب الذين لا يعلمون، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب. ويطبع الله: فعل وفاعل، وعلى قلوب: جار ومجرور متعلقان بيطبع، الذين: اسم موصول مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> صلة الذين لا محل لها من الإعراب.</p></div>"
  30,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر إن وعد الله حق﴾</span></span>: الفاء فصيحة، أي: إذا علمت ذلك فاصبر. واصبر: فعل أمر، والفاعل مستتر تقديره أنت، وإن حرف ناسخ، ووعد اسمها ولفظ الجلالة، مضاف إليه، حق: خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يستخفنك الذين لا يوقنون﴾</span></span>: الواو عاطفة، ولا: ناهية، ويستخفنك: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة في محل جزم بلا الناهية، والكاف: مفعول به مقدم، والذين: فاعل <span class="hlt"><span class="qpc-hafs">﴿يستخفنك﴾</span></span> المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يوقنون﴾</span></span> صلة الذين لا محل لها من الإعراب.</p></div>"
