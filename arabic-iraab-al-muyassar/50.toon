quran[45]{c,v,t}:
  50,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ق﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿والقرآن المجيد﴾</span></span>: الواو حرف قسم وجر، والقرآن مقسم به، والمجيد صفة، والجواب محذوف يدل عليه ما بعده، والتقدير: إنك جئتهم منذرًا بالبعث، فلم يقبلوا، بل عجبوا، وقيل: هو مذكور، واختلفوا في تقديره، فقيل: هو <span class="hlt"><span class="qpc-hafs">﴿قد علمنا﴾</span></span>، وقيل: هو قوله: <span class="hlt"><span class="qpc-hafs">﴿ما يلفظ من قول﴾</span></span> وقيل: لتبعثن، أو لترجعن على ما دل عليه سياق الآيات.</p></div>"
  50,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل عجبوا أن جاءهم منذر منهم فقال الكافرون هذا شيء عجيب﴾</span></span>: بل حرف عطف وإضراب، وعجبوا فعل وفاعل، وأن وما في حيزها في تأويل مصدر منصوب بنزع الخافض، أي: من أن جاءهم، ومنذر فاعل جاءهم، ومنهم صفة لمنذر، فقال: الفاء عاطفة، وقال الكافرون فعل وفاعل، وهذا مبتدأ، وشيء خبر، وعجيب صفة، والجملة مقول القول.</p></div>"
  50,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئذا متنا وكنا ترابا﴾</span></span>: الهمزة للاستفهام الإنكاري، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط، ومتنا فعل وفاعل، وجملة متنا في محل جر بإضافة الظرف إليها، وناصب الظرف مضمر معناه: أحين نموت ونبلى نرجع، لأن ما بعده دل عليه، وكنا: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وترابًا خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك رجع بعيد﴾</span></span>: ذلك مبتدأ، ورجع خبر، وبعيد صفة.</p></div>"
  50,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد علمنا ما تنقص الأرض منهم وعندنا كتاب حفيظ﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقد حرف تحقيق، وعلمنا فعل وفاعل، وما: اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنقص الأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. ومنهم جار ومجرور متعلقان بتنقص، والواو حالية، وعندنا ظرف متعلق بمحذوف خبر مقدم، وكتاب مبتدأ مؤخر، وحفيظ صفة، والجملة حال.</p></div>"
  50,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل كذبوا بالحق لما جاءهم فهم في أمر مريج﴾</span></span>: بل حرف إضراب وعطف إضراب، وكذبوا فعل وفاعل، وبالحق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، ولما ظرفية حينية، أو رابطة، فهم: الفاء عاطفة، وهم مبتدأ، وأمر خبر، ومريج صفة.</p></div>"
  50,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلم ينظروا إلى السماء فوقهم كيف بنيناها وزيناها وما لها من فروج﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف، ولم حرف نفي وقلب وجزم، وينظروا مضارع مجزوم بحذف النون والواو فاعل، وإلى السماء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينظروا﴾</span></span>، وكيف اسم استفهام في محل نصب حال، وبنيناها فعل وفاعل ومفعول به، والجملة بدل من السماء، والواو للحال، وما نافية، ولها: جار ومجرور متعلقان بمحذوف خبر مقدم، ومن حرف جر صلة، وفروج مجرور لفظًا مبتدأ مؤخر محلا.</p></div>"
  50,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض مددناها وألقينا فيها رواسي﴾</span></span>: الواو حرف عطف، والأرض عطف على محل <span class="hlt"><span class="qpc-hafs">﴿إلى السماء﴾</span></span>، وهو النصب على المفعولية، وجملة مددناها حالية، أو تنصب <span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> بفعل محذوف، تقديره: ومددنا الأرض، وألقينا عطف على مددنا، وفيها: جار ومجرور متعلقان بألقينا، ورواسي مفعول به، أي: جبالًا راسية ثوابت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنبتنا فيها من كل زوج بهيج﴾</span></span>: الواو عاطفة، وأنبتنا عطف على ما تقدم أيضًا، وفيها: جار ومجرور متعلقان بأنبتنا، ومن كل زوج: جار ومجرور متعلقان بصفة لمفعول محذوف والتقدير: فأنبتنا فيها نباتًا كائنًا من كل زوج، وزوج: مضاف إليه، وبهيج صفة لزوج.</p></div>"
  50,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تبصرة﴾</span></span>: مفعول من أجله  للأفعال السابقة من قوله: <span class="hlt"><span class="qpc-hafs">﴿بنيناها وزيناها﴾</span></span> وقوله: <span class="hlt"><span class="qpc-hafs">﴿مددناها وألقينا فيها رواسي وأنبتنا فيها﴾</span></span> أي: ليكون ما ذكر من الأفعال ومعمولاتها تبصرة، أو: نائب مفعول مطلق لفعل مقدر لأنه اسم مصدر، أي: بصرهم تبصرة، أو: حال من الفاعل، أي: مبصرين، أو: حال من المفعول على حذف مضاف، أي: ذات تبصير لمن يراها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وذكرى﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿تبصرة﴾</span></span> منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبصرة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عبد﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿منيب﴾</span></span>: نعت لعبد.</p></div>"
  50,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونزلنا من السماء ماء مباركا فأنبتنا به جنات وحب الحصيد﴾</span></span>: الواو عاطفة، ونزلنا فعل وفاعل، ومن السماء: جار ومجرور متعلقان بنزلنا، وماء مفعول به، ومباركًا صفة، فأنبتنا عطف على نزلنا، وبه: جار ومجرور متعلقان بأنبتنا، وجنات مفعول به، وحب الحصيد عطف على جنات، وحذف الموصوف.</p></div>"
  50,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنخل باسقات لها طلع نضيد﴾</span></span>: الواو عاطفة، والنخل عطف على جنات وحب الحصيد، وباسقات حال مقدرة، لأنها في وقت الإنبات لم تكن طوالًا، ولها خبر مقدم، وطلع مبتدأ مؤخر، ونضيد نعت لطلع، والجملة حال من النخل الباسقات بطريق الترادف، أو من الضمير في باسقات على طريق التداخل.</p></div>"
  50,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رزقا﴾</span></span>: مفعول من أجله، أو: نائب عن المفعول المطلق، لأنه بمعنى المصدر من أنبتنا، أو: حال، أي: مرزوقًا للعباد، أو ذا رزق.</p><p><span class="hlt"><span class="qpc-hafs">﴿للعباد﴾</span></span>: جار ومجرور متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأحيينا﴾</span></span>: عطف على فأنبتنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أحيينا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلدة﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ميتًا﴾</span></span>: نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل رفع خبر مقدم، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب.</p><p><span class="hlt"><span class="qpc-hafs">﴿الخروج﴾</span></span>: مبتدأ مؤخر مرفوع بالضمة.</p></div>"
  50,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قبلهم قوم نوح وأصحاب الرس وثمود﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وكذبت فعل ماض والتاء للتأنيث، وقبلهم ظرف متعلق بكذبت، وقوم نوح فاعل، وما بعده عطف عليه.</p></div>"
  50,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعاد وفرعون وإخوان لوط﴾</span></span>: عطف على ما تقدم أيضًا.</p></div>"
  50,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأصحاب الأيكة وقوم تبع﴾</span></span>: عطف أيضًا، وقد مرت جميعًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كل كذب الرسل فحق وعيد﴾</span></span>: كل مبتدأ، والتنوين فيه عوض عن كلمة، أي: كل رسول من المذكورين، وجملة كذب الرسل خبره، والفاء عاطفة، وحق فعل ماض، ووعيد فاعل مضاف لياء المتكلم، وأصله: وعيدي، فحذفت الياء، وبقيت الكسرة دليلًا عليها.</p></div>"
  50,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفعيينا بالخلق الأول بل هم في لبس من خلق جديد﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف، تقديره: أقصدنا الخلق فعجزنا عنه حتى يتوهم أحد عجزنا عن إعادته، وعيينا فعل وفاعل، وبالخلق: جار ومجرور متعلقان بعيينا، والأول صفة للخلق، وبل عطف على مقدر، والتقدير: هم غير منكرين لقدرتنا على الخلق الأول بل هم في خلط وشبهة من خلق مستأنف جديد، وهم مبتدأ، وفي لبس جار ومجرور متعلقان بمحذوف خبر، ومن خلق جار ومجرور متعلقان بمحذوف نعت للبس، وجديد نعت لخلق.</p></div>"
  50,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا الإنسان﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وخلقنا الإنسان فعل ماض وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونعلم ما توسوس به نفسه﴾</span></span>: الواو للحال بتقدير: نحن، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعلم﴾</span></span> خبر مبتدأ مقدر، والجملة الاسمية في محل نصب على الحال المقدرة، أو الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿توسوس﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والتقدير: ونعلم وسوسة نفسه له، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توسوس﴾</span></span>، ونفسه فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونحن أقرب إليه من حبل الوريد﴾</span></span>: نحن: الواو عاطفة، ونحن مبتدأ، وأقرب خبر، وإليها جار ومجرور متعلقان بأقرب، ومن حبل الوريد جار ومجرور متعلقان بأقرب أيضًا.</p></div>"
  50,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ يتلقى المتلقيان عن اليمين وعن الشمال قعيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أقرب﴾</span></span> في الآية السابقة، أو اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتلقى﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿المتلقيان﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span> خبر مقدم، <span class="hlt"><span class="qpc-hafs">﴿وعن الشمال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قعيد﴾</span></span> مبتدأ مؤخر، والجملة الاسمية في محل نصب على الحال من المتلقيان.</p></div>"
  50,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما يلفظ من قول إلا لديه رقيب عتيد﴾</span></span>: ما نافية، ويلفظ فعل مضارع، وفاعله ضمير مستتر تقديره: هو، يعود على الإنسان، ومن حرف جر صلة، وقول مجرور لفظًا منصوب محلا على أنه مفعول يلفظ، وإلا أداة حصر، ولديه ظرف مكان متعلق بمحذوف خبر مقدم، ورقيب مبتدأ مؤخر، وعتيد نعت مرفوع، والجملة في محل نصب حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿يلفظ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يلفظ...﴾</span></span> لا محل لها من الإعراب، لأنها استئناف بياني.</p></div>"
  50,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءت سكرة الموت بالحق ذلك ما كنت منه تحيد﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وجاءت سكرة الموت فعل وفاعل، وبالحق حال، أي: حال كونها متلبسة بالحق، فالباء للملابسة، وقيل: هي للتعدية، وذلك مبتدأ، وما خبر، وكان فعل ماض ناقص، والتاء اسمها، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحيد﴾</span></span>، وجملة تحيد خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة ذلك ما كنت مقول قول محذوف.</p></div>"
  50,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونفخ في الصور ذلك يوم الوعيد﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿وجاءت سكرة الموت﴾</span></span>، ونفخ فعل ماض مبني لما لم يسمَّ فاعله، وفي الصور جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، وذلك مبتدأ، ويوم الوعيد خبره، والإشارة إلى مصدر نفخ.</p></div>"
  50,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءت كل نفس معها سائق وشهيد﴾</span></span>: الواو عاطفة، وجاءت كل نفس فعل وفاعل، ومعها ظرف مكان متعلق بمحذوف خبر مقدم، وسائق مبتدأ مؤخر، وشهيد عطف على سائق، والجملة الاسمية في محل رفع صفة لكل، أو في محل نصب صفة لها، أي: معها من يسوقها، ويشد عليها، ولك أن تجعلها حالية.</p></div>"
  50,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد كنت في غفلة من هذا فكشفنا عنك غطاءك فبصرك اليوم حديد﴾</span></span>: الجملة مقول قول محذوف، أي: يقال لكل نفس، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وكان فعل ماض ناقص، والتاء اسمها، وفي غفلة جار ومجرور متعلقان بمحذوف خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿من هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفلة﴾</span></span>، والفاء حرف عطف، وكشفنا فعل وفاعل، وعنك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وغطاءك مفعول به، والفاء عاطفة، وبصرك مبتدأ، واليوم ظرف متعلق بمحذوف حال، وحديد خبر بصرك.</p></div>"
  50,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال قرينه هذا ما لدي عتيد﴾</span></span>: الواو عاطفة، وقال قرينه فعل وفاعل، وهذا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول بدل من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لدي﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. وعتيد خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>.</p></div>"
  50,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألقيا في جهنم كل كفار عنيد﴾</span></span>: الجملة مقول قول محذوف، أي: يقال: ألقيا، وألقيا فعل أمر مبني على حذف النون لاتصاله بألف الاثنين، وفي جهنم جار ومجرور متعلقان بألقيا، وكل كفار مفعول به، وعنيد صفة لكفار.</p></div>"
  50,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مناع للخير معتد مريب﴾</span></span>: مناع نعت ثانٍ لكفار، وللخير الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مناع﴾</span></span>، ومعتد نعت آخر لكفار مجرور بكسرة مقدرة على الياء المحذوفة لالتقاء الساكنين، ومريب: نعت آخر.</p></div>"
  50,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل مع الله إلها آخر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، أو من <span class="hlt"><span class="qpc-hafs">﴿كفار﴾</span></span>، أو منصوب على الذم، أو مبتدأ والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿فألقياه﴾</span></span>. جملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف مفعول به ثانٍ، و<span class="hlt"><span class="qpc-hafs">﴿إلهًا آخر﴾</span></span> مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فألقياه في العذاب الشديد﴾</span></span>: الفاء رابطة لشبه الموصول بالشرط في العموم، وألقياه: فعل أمر وفاعل ومفعول به، والجملة خبر الذي إذا جعلت خبرًا، وفي العذاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقياه﴾</span></span>، والشديد نعت لـ<span class="hlt"><span class="qpc-hafs">﴿العذاب﴾</span></span>.</p></div>"
  50,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قرينه ربنا ما أطغيته ولكن كان في ضلال بعيد﴾</span></span>: قال قرينه فعل وفاعل، وربنا منادى مضاف، وما نافية، وأطغيته فعل وفاعل ومفعول به، ولكن حرف استدراك مهمل، لأنه خفف، وكان فعل ماض ناقص، واسمها مستتر تقديره: هو، وفي ضلال: جار ومجرور متعلقان بمحذوف خبر كان، وبعيد صفة لضلال، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال قرينه﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  50,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا تختصموا لدي وقد قدمت إليكم بالوعيد﴾</span></span>: قال فعل ماض مبني على الفتح والفاعل مستتر تقديره هو، ولا ناهية، وتختصموا فعل مضارع مجزوم، والجملة مقول القول، ولدي ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تختصموا﴾</span></span>، والواو للحال، وقد حرف تحقيق، وقدمت فعل وفاعل، وإليكم: جار ومجرور متعلقان بقدمت، والباء في بالوعيد حرف صلة، أو يقع الفعل على جملة قوله: <span class="hlt"><span class="qpc-hafs">﴿ما يبدل القول﴾</span></span>، ويكون بالوعيد حالًا، أي: قدمت إليكم هذا متلبسًا بالوعيد مقترنًا به، أو قدمته إليكم موعدًا لكم به.</p></div>"
  50,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما يبدل القول لدي وما أنا بظلام للعبيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يبدل﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لدي﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يبدل﴾</span></span>، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بظلام﴾</span></span> الباء: حرف جر صلة، وظلام: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وللعبيد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظلام﴾</span></span>.</p></div>"
  50,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم نقول لجهنم هل امتلأت﴾</span></span>: يوم ظرف زمان منصوب متعلق بظلام، نقول مضارع مرفوع والفاعل نحن، ولجهنم جار ومجرور بفتحة للعلمية والتأنيث متعلقان بنقول. هل للاستفهام، امتلأت ماض مبني على السكون والتاء فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتقول هل من مزيد﴾</span></span>: الواو عاطفة وتقول مضارع مرفوع والفاعل هي، هل للاستفهام من: حرف جر صلة، ومزيد مجرور لفظًا مرفوع محلا مبتدأ مؤخر خبره محذوف أي هناك، وجملة نقول في محل جر مضاف إليه، وهل امتلأت في محل نصب مقول نقول، وتقول في محل جر معطوفة على نقول، وهل من مزيد في محل نصب مقول تقول.</p></div>"
  50,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأزلفت الجنة﴾</span></span>: الواو حرف عطف، وأزلفت فعل ماض مبني لما لم يسمَّ فاعله، والجنة نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أزلفت﴾</span></span> .</p><p><span class="hlt"><span class="qpc-hafs">﴿غير بعيد﴾</span></span>: منصوب على الظرفية لقيامه مقام الظرف، لأنه صفته، أي: مكانًا غير بعيد، وقيل: منصوب على الحال.</p></div>"
  50,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا ما توعدون لكل أواب حفيظ﴾</span></span>: هذا: مبتدأ، وما: خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span>: صلة الموصول لا محل لها من الإعراب، ولكل: جار ومجرور بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span> بإعادة العامل، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا ما توعدون﴾</span></span>: اعتراضية فصل بها بين البدل والمبدل منه، لا محل لها من الإعراب، أو منصوبة بقول مضمر، والقول المضمر منصوب على الحال، أي: مقولا لهم... .</p></div>"
  50,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من خشي الرحمن بالغيب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول بدل من <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، أو خبر لمبتدأ محذوف، أي: هم من خشي، أو مبتدأ خبره جملة <span class="hlt"><span class="qpc-hafs">﴿ادخلوها بسلام﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿خشي الرحمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. وبالغيب: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجاء بقلب منيب﴾</span></span>: الواو عاطفة وجاء فعل ماض والفاعل مستتر تقديره هو، وبقلب: جار ومجرور في محل نصب حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، ومنيب نعت مجرور، والجملة لا محل لها من الإعراب عطفًا بالواو على جملة الصلة.</p></div>"
  50,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادخلوها بسلام﴾</span></span>: الجملة مقول القول محذوف كما تقدم، وادخلوها فعل وفاعل ومفعول به، وبسلام حال من الفاعل، أي: سالمين من كل مخوفة، فهي حال مقارنة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك يوم الخلود﴾</span></span>: ذلك مبتدأ، ويوم الخلود خبر.</p></div>"
  50,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم ما يشاءون فيها﴾</span></span>: لهم جار ومجرور متعلقان بمحذوف خبر مقدم، وما موصولة مبنية على السكون في محل رفع مبتدأ مؤخر، وجملة يشاءون صلة الموصول لا محل لها من الإعراب، وفيها جار ومجرور متعلقان بمحذوف حال من الموصول، أو متعلقان بيشاءون.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولدينا مزيد﴾</span></span>: لدينا ظرف متعلق بمحذوف خبر مقدم، ومزيد مبتدأ مؤخر.</p></div>"
  50,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا قبلهم من قرن هم أشد منهم بطشا﴾</span></span>: الواو استئنافية، وكم خبرية منصوبة بما بعدها على المفعولية، وأهلكنا فعل وفاعل، وقبلهم ظرف متعلق بمحذوف حال، ومن قرن تمييز كم الخبرية، وهم مبتدأ، وأشد خبر، والجملة صفة لكم، أو لتمييزها، ومنهم: جار ومجرور متعلقان بأشد، وبطشًا تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنقبوا في البلاد هل من محيص﴾</span></span>: فنقبوا: الفاء عاطفة، ونقبوا فعل وفاعل، والعطف على المعنى كأنه اشتد بطشهم فنقبوا، وفي البلاد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقبوا﴾</span></span>، وهل حرف استفهام، ومن حرف جر صلة، ومحيص مجرور لفظًا مرفوع على الابتداء محلا، والخبر محذوف تقديره: لهم، أو لغيرهم، وجملة هل من محيص مقول قول محذوف، وجملة القول حالية من واو نقبوا، أي: فنقبوا في البلاد قائلين: هل من محيص.</p></div>"
  50,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لذكرى لمن كان له قلب أو ألقى السمع وهو شهيد﴾</span></span>: إن حرف ناسخ، وفي ذلك خبر إن المقدم، واللام المزحلقة للتأكيد، وذكرى اسم إن، ولمن: جار ومجرور متعلقان بمحذوف صفة لذكرى، وجملة كان صلة الموصول لا محل لها من الإعراب. وله خبر كان المقدم، وقلب اسمها المؤخر، وأو حرف عطف، وألقى السمع فعل وفاعل مستتر ومفعول به، والواو حالية، وهو مبتدأ، وشهيد خبر.</p></div>"
  50,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا السماوات والأرض وما بينهما في ستة أيام﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وخلقنا فعل وفاعل، والسماوات مفعول به، والأرض عطف على السماوات، وفي ستة أيام: جار ومجرور متعلقان بخلقنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا السماوات...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما مسنا من لغوب﴾</span></span>: الواو عاطفة، أو حالية، وما نافية، ومسنا فعل ماض، ونا مفعول به، ومن حرف جر صلة، ولغوب مجرور لفظًا مرفوع محلا لأنه فاعل.</p></div>"
  50,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر على ما يقولون﴾</span></span>: الفاء الفصيحة، واصبر فعل أمر، وفاعله مستتر تقديره: أنت، وعلى ما يقولون: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبح بحمد ربك﴾</span></span>: سبح فعل أمر، وبحمد ربك حال من فاعل سبح، أي: صل حامدًا .</p><p><span class="hlt"><span class="qpc-hafs">﴿قبل طلوع الشمس﴾</span></span>: ظرف متعلق بسبح .</p><p><span class="hlt"><span class="qpc-hafs">﴿وقبل الغروب﴾</span></span>: عطف على الظرف.</p></div>"
  50,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الليل فسبحه وأدبار السجود﴾</span></span>: الواو عاطفة، ومن الليل جار ومجرور متعلقان بسبح، والفاء عاطفة، وسبحه فعل أمر، والفاعل مستتر، والهاء مفعول به، وأدبار السجود ظرف.</p></div>"
  50,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستمع يوم يناد المناد من مكان قريب﴾</span></span>: عطف على ما تقدم، واستمع فعل أمر، وفاعله مستتر تقديره: أنت، ومفعوله محذوف، أي: واستمع نداء المنادي، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿استمع﴾</span></span>، وقيل: تقدير المفعول ما أقول لك، فعلى هذا يكون يوم منصوبًا بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span> مقدرًا مدلولًا عليه بقوله، والمناد: فاعل، ومن مكان: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينادي﴾</span></span>، وقريب نعت.</p></div>"
  50,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يسمعون الصيحة بالحق ذلك يوم الخروج﴾</span></span>: الظرف بدل من الظرف الأول، وجملة يسمعون في محل جر بإضافة إذا إليها، والصيحة مفعول به، وبالحق حال من الواو في يسمعون أو من الصيحة، وذلك مبتدأ، ويوم الخروج خبر.</p></div>"
  50,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا نحن نحيي ونميت وإلينا المصير﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ونحن ضمير فصل، أو مبتدأ، وجملة نحيي خبر إن، أو خبر نحن، والجملة خبر إن، وإلينا: جار ومجرور متعلقان بمحذوف خبر مقدم، والمصير مبتدأ مؤخر.</p></div>"
  50,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم تشقق الأرض عنهم سراعا ذلك حشر علينا يسير﴾</span></span>: الظرف بدل مما قبله، ومنعه بعضهم لتعدده، وعلقه بالمصير، وجملة تشقق في محل جر بإضافة الظرف إليها، والأرض فاعل، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشقق﴾</span></span>، وسراعًا حال من الضمير في عنهم، وذلك مبتدأ، وحشر خبر، وعلينا جار ومجرور متعلقان بيسير، ويسير خبر ذلك.</p></div>"
  50,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن أعلم بما يقولون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر بالباء، أي: نحن أعلم بالذي يقولونه، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما يقولون﴾</span></span> مجرور بالباء، أي: بقولهم، والجار والمجرور متعلقان بأعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت عليهم بجبار﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جبار﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بجبار﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿جبار﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فذكر بالقرآن من يخاف وعيد﴾</span></span>: الفاء الفصيحة، وذكر فعل أمر، وبالقرآن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>، ومن مفعول به، وجملة يخاف صلة الموصول لا محل لها من الإعراب. ووعيد مفعول يخاف، وحذفت ياء المتكلم اتباعًا للرسم.</p></div>"
