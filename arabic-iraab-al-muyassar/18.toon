quran[110]{c,v,t}:
  18,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الحمد﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، والتقدير: ثابت لله.</p><p><span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>: نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>: فعل ماض، والفاعل مستتر تقديره: هو، والجملة صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿على عبده﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم يجعل له عوجا﴾</span></span>: الواو عاطفة، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span> داخلة في حيز الصلة لا محل لها من الإعراب، أو الواو اعتراضية، فالجملة اعتراضية بين الحال <span class="hlt"><span class="qpc-hafs">﴿قيمًا﴾</span></span> وصاحبها <span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> لا محل لها من الإعراب، أو الواو حالية فالجملة في محل نصب حال من الكتاب.</p></div>"
  18,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قيما﴾</span></span>: حال من الكتاب باعتبار أن جملة <span class="hlt"><span class="qpc-hafs">﴿ولم يجعل﴾</span></span> اعتراضية، أو حال ثانية من الكتاب باعتبار أن جملة <span class="hlt"><span class="qpc-hafs">﴿ولم يجعل﴾</span></span> حال أولى، أو بدل مفرد منها، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>، وقيل: منصوبة بفعل تقديره: جعله قيمًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span>: اللام للتعليل، وينذر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وينذر ينصب مفعولين حذف أولهما وتقديره: الكافرين.</p><p><span class="hlt"><span class="qpc-hafs">﴿بأسًا﴾</span></span>: مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿شديدًا﴾</span></span>: صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿من لدنه﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة ثانية، أو متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويبشر المؤمنين الذين يعملون الصالحات أن لهم أجرا حسنا﴾</span></span>: الواو عاطفة، ويبشر عطف على لينذر، والفاعل مستتر تقديره: هو، والمؤمنين مفعول به، وجملة يعملون الصالحات صلة الذين لا محل لها من الإعراب، والمصدر المؤول من أن وما في حيزها مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يبشر﴾</span></span>، وقيل: منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبشر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن المقدم، وأجرًا اسمها المؤخر، وحسنا نعت.</p></div>"
  18,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ماكثين﴾</span></span>: حال من الهاء في <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ماكثين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أبدًا﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ماكثين﴾</span></span> أيضًا.</p></div>"
  18,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وينذر الذين قالوا اتخذ الله ولدا﴾</span></span>: الواو عاطفة، وينذر عطف على <span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span> الأولى، والذين مفعول ينذر الأول، وحذف الثاني وهو البأس، لأنه سبق ذكره، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، وولدًا مفعول به.</p></div>"
  18,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لهم به من علم﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، ومن حرف جر صلة، وعلم مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا لآبائهم﴾</span></span>: الواو عاطفة، ولا نافية، ولآبائهم عطف على <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كبرت كلمة تخرج من أفواههم إن يقولون إلا كذبا﴾</span></span>: كبرت: فعل ماض لإنشاء الذم، والتاء علامة التأنيث، والفاعل ضمير مستتر تقديره: <span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span> تمييز منصوب. والمخصوص بالذم محذوف تقديره: قولهم المذكور، وهو مبتدأ، والجملة قبله خبره. وجملة الذم استئنافية لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أفواههم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>، وفاعل <span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span> ضمير مستتر. وإن نافية، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كذبًا﴾</span></span> نعت لمصدر محذوف، أي: إلا قولًا كذبًا، أو مفعول به.</p></div>"
  18,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلعلك﴾</span></span>: الفاء استئنافية، ولعل حرف ترجٍّ ونصب وهي من أخوات إن، والكاف اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿باخع﴾</span></span>: خبر لعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿نفسك﴾</span></span>: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلعلك باخع...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿على آثارهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿باخع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم يؤمنوا﴾</span></span>: فعل الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحديث﴾</span></span>: بدل من اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أسفًا﴾</span></span>: مفعول لأجله، أو مصدر في موقع الحال، وجواب الشرط محذوف دل عليه الترجي.</p></div>"
  18,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا جعلنا ما على الأرض زينة لها لنبلوهم أيهم أحسن عملا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به أول لجعلنا على اعتبار أن جعل بمعنى التصيير، و<span class="hlt"><span class="qpc-hafs">﴿على الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وزينة مفعول به ثان لجعلنا، أو حال إن كانت جعلنا بمعنى خلقنا، أو مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿لنبلوهم﴾</span></span> اللام للتعليل، ونبلوهم منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أيهم﴾</span></span> اسم استفهام مبتدأ، والهاء مضاف إليه، وأحسن خبر، و<span class="hlt"><span class="qpc-hafs">﴿عملًا﴾</span></span> تمييز، والجملة في محل نصب سادة مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿نبلو﴾</span></span>، لأنه في معنى نعلم، أو <span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> موصولة بمعنى الذي وهي بدل من الهاء في <span class="hlt"><span class="qpc-hafs">﴿نبلوهم﴾</span></span>، والتقدير: لنبلو الذي هو أحسن، وأحسن خبر لمبتدأ محذوف، أي: هو أحسن، والجملة صلة للموصول لا محل لها من الإعراب.</p></div>"
  18,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لجاعلون﴾</span></span>: اللام المزحلقة، وجاعلون خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿جاعلون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span>: جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿صعيدًا﴾</span></span>: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جاعلون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿جرزًا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿صعيدًا﴾</span></span>.</p></div>"
  18,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم حسبت أن أصحاب الكهف والرقيم كانوا من آياتنا عجبا﴾</span></span>:  أم منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أحسبت. وحسبت فعل وفاعل، وأن وما في حيزها سدت مسد مفعولي حسبت، والرقيم عطف على الكهف، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿من آياتنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وعجبًا خبر كانوا.</p></div>"
  18,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عجبا﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> في الآية السابقة، أو اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أوى﴾</span></span>: فعل ماض.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفتية﴾</span></span>: فاعل أوى، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوى الفتية﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى الكهف﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span>: عطف على أوى.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span>: منادى.</p><p><span class="hlt"><span class="qpc-hafs">﴿آتنا﴾</span></span>: فعل دعاء مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿من لدنك﴾</span></span>: جار ومجرور متعلقان بمحذوف حال لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> وتقدم عليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهيئ﴾</span></span>: عطف على آتنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هيئ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من أمرنا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿رشدًا﴾</span></span>: مفعول به.</p></div>"
  18,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فضربنا﴾</span></span>: الفاء عاطفة، وضربنا فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿على آذانهم﴾</span></span>: جار ومجرور متعلقان بضربنا، ومفعول ضربنا محذوف تقديره: حجابًا مانعًا لهم من السماع.</p><p><span class="hlt"><span class="qpc-hafs">﴿في الكهف﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿سنين﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ضربنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عددًا﴾</span></span>: نعت لسنين، أي: معدودة أو ذوات عدد.</p></div>"
  18,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للتراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿بعثناهم﴾</span></span>: فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنعلم﴾</span></span>: اللام للتعليل أو للعاقبة، ونعلم مضارع منصوب بأن مضمرة بعدها، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثناهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>: اسم استفهام مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحصى﴾</span></span>: فعل ماض، وفاعله يعود على <span class="hlt"><span class="qpc-hafs">﴿أي الحزبين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما لبثوا﴾</span></span>: اللام حرف جر، وما مصدرية، ولبثوا فعل وفاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وما بعدها مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحصى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أمدًا﴾</span></span>: مفعول به، وقيل: <span class="hlt"><span class="qpc-hafs">﴿أحصى﴾</span></span> اسم تفضيل فهو خبر <span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أمدًا﴾</span></span> تمييز.</p></div>"
  18,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن نقص عليك نبأهم بالحق﴾</span></span>: نحن مبتدأ، وجملة نقص خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، ونبأهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل نقص، أو من مفعوله وهو النبأ، فالباء للملابسة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم فتية آمنوا بربهم وزدناهم هدى﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم إن، وفتية خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا بربهم﴾</span></span> خبر ثان، أو نعت لفتية، وزدناهم فعل وفاعل ومفعول به أول، وهدى مفعول به ثان، أو تمييز.</p></div>"
  18,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربطنا﴾</span></span>: عطف على زدناهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿على قلوبهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ربطنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ربطنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قاموا﴾</span></span>: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قاموا﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span>: عطف على قاموا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>: حرف نفي ونصب واستقبال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ندعو﴾</span></span>: مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span> وتقدم عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقد﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span>: فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: حرف جواب وجزاء مهمل.</p><p><span class="hlt"><span class="qpc-hafs">﴿شططا﴾</span></span>: نائب عن المفعول المطلق، أو مفعول به، أو حال من ضمير مصدر <span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span>.</p></div>"
  18,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿قومنا﴾</span></span>: بدل من اسم الإشارة، أو عطف بيان.</p><p><span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>: فعل وفاعل، والجملة خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span>: مفعول به. أو <span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿قومنا﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span> في موضع نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>: حرف تحضيض.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأتون﴾</span></span>: فعل مضارع وفاعل، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿بسلطان﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span>: صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن أظلم﴾</span></span>: الفاء استئنافية، ومن اسم استفهام مبتدأ، وأظلم خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿ممن افترى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ممن﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أظلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿افترى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿افترى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذبا﴾</span></span>: نائب عن المفعول المطلق، لأنه بمعنى المصدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمن أظلم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  18,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ اعتزلتموهم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم زمان مبني على السكون المقدر لالتقاء الساكنين في محل نصب مفعول به لفعل محذوف تقديره: اذكروا، وجملة <span class="hlt"><span class="qpc-hafs">﴿اذكروا﴾</span></span> المقدرة في محل نصب مقول لقول محذوف والتقدير: وقال بعضهم لبعض اذكروا إذ اعتزلتموهم، وقيل: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف فيه معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فأووا﴾</span></span> وهو الجواب، وجملة <span class="hlt"><span class="qpc-hafs">﴿اعتزلتموهم﴾</span></span> في محل جر بالإضافة، وقيل: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ههنا تعليلية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يعبدون إلا الله﴾</span></span>: الواو حرف عطف، وما اسم موصول معطوف على الهاء، أي: اعتزلتموهم واعتزلتم معبوديهم، أو مصدرية، والتقدير: اعتزلتموهم وعبادتهم، وإلا: أداة استثناء، ولفظ الجلالة: مستثنى متصل، أو منقطع، وقيل: الواو اعتراضية، وما نافية، والجملة اعتراضية لا محل لها من الإعراب، وهي إخبار من الله عن الفتية أنهم لم يعبدوا غير الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأووا إلى الكهف﴾</span></span>: الفاء واقعة في جواب شرط مقدر، أي: إن شئتم النجاة بدينكم فأووا، أو إن اعتزلتموهم وما يعبدون فأووا. وإذا كانت <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> شرطية فالفاء في جواب <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>، وإذا كانت تعليلية فالفاء للتفريع على جملة <span class="hlt"><span class="qpc-hafs">﴿وإذ اعتزلتموهم﴾</span></span>.  و<span class="hlt"><span class="qpc-hafs">﴿أووا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الكهف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أووا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ينشر﴾</span></span>: فعل مضارع مجزوم لوقوعه جوابًا للطلب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينشر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span>: فاعل ينشر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رحمته﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لمفعول ينشر المحذوف، أي: ينشر لكم نجاحًا من رحمته.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويهيئ﴾</span></span>: عطف على ينشر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهيئ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من أمركم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مرفقًا﴾</span></span> وتقدم عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿مرفقًا﴾</span></span>: مفعول به.</p></div>"
  18,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وترى﴾</span></span>: الواو استئنافية، وترى فعل مضارع، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span>: مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿وترى الشمس...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>: ظرف مستقبل متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تزاور﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿طلعت﴾</span></span>: فعل ماض مبني على الفتح، والتاء للتأنيث، والفاعل ضمير مستتر تقديره هي يعود على الشمس، والجملة الفعلية في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿تزاور﴾</span></span>: فعل مضارع، وفاعله مستتر تقديره: هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿تزاور﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿عن كهفهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تزاور﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذات اليمين﴾</span></span>: ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تزاور﴾</span></span>. وجملة الشرط <span class="hlt"><span class="qpc-hafs">﴿إذا طلعت...﴾</span></span> في محل نصب حال من الشمس.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا غربت تقرضهم ذات الشمال﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقرضهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿غربت﴾</span></span> فعل ماض مبني على الفتح، والتاء للتأنيث، والفاعل ضمير مستتر تقديره هي يعود على الشمس، وجملة <span class="hlt"><span class="qpc-hafs">﴿غربت﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿تقرضهم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره هي، والهاء مفعول به، والميم علامة الجمع، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقرضهم﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿ذات الشمال﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقرضهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إذا غربت تقرضهم﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿إذا طلعت تزاور﴾</span></span> فهي في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم في فجوة منه﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في فجوة﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فجوة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك من آيات الله﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من آيات الله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من يهد الله فهو المهتد﴾</span></span>: من شرطية في محل نصب مفعول مقدم، ويهد فعل الشرط مجزوم وعلامة جزمه حذف حرف العلة، والفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والمهتدي خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يضلل فلن تجد له وليا مرشدًا﴾</span></span>: عطف على ما تقدم، والفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span> حرف نفي ونصب واستقبال، وتجد فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿وليا﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿مرشدا﴾</span></span> نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن تجد له﴾</span></span> في محل جزم جواب الشرط.</p></div>"
  18,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتحسبهم﴾</span></span>: الواو استئنافية، وتحسبهم فعل مضارع، والفاعل مستتر، ومفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيقاظًا﴾</span></span>: مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم رقود﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ورقود خبر، والجملة في محل نصب حال. وجملة <span class="hlt"><span class="qpc-hafs">﴿وتحسبهم أيقاظا﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونقلبهم﴾</span></span>: الواو عاطفة، ونقلبهم فعل وفاعل مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذات اليمين﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نقلبهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وذات الشمال﴾</span></span>: عطف على ذات اليمين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكلبهم﴾</span></span>: الواو للحال، وكلبهم مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿باسط﴾</span></span>: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذراعيه﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالوصيد﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿باسط﴾</span></span> وجملة <span class="hlt"><span class="qpc-hafs">﴿كلبهم باسط﴾</span></span> جملة حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>: شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿اطلعت﴾</span></span>: فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اطلعت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لوليت﴾</span></span>: اللام واقعة في جواب لو، و<span class="hlt"><span class="qpc-hafs">﴿وليت﴾</span></span> فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فرارًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرارًا﴾</span></span>: نائب عن المفعول المطلق من معنى الفعل قبله، أو مصدر في موضع الحال، أي: فارًّا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لملئت﴾</span></span>: عطف على لوليت.</p><p><span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رعبًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رعبًا﴾</span></span>: تمييز، أو مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿ملئت﴾</span></span>.</p></div>"
  18,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك بعثناهم ليتساءلوا بينهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وبعثناهم فعل وفاعل ومفعول به، وليتساءلوا: اللام للتعليل، ويتساءلوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثناهم﴾</span></span>، والظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال قائل منهم كم لبثتم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال قائل﴾</span></span> فعل وفاعل، وكم اسم استفهام في محل نصب على الظرفية، والمميز المنصوب محذوف تقديره: كم يومًا، بدليل الجواب عليه، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قائل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لبثنا يوما أو بعض يوم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، وجملة لبثنا مقول القول، ويومًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثنا﴾</span></span>، أو حرف عطف، بعض يوم عطف على <span class="hlt"><span class="qpc-hafs">﴿يومًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربكم أعلم بما لبثتم﴾</span></span>: قالوا فعل وفاعل، وربكم مبتدأ، وأعلم خبره، <span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بأعلم، ولبثتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فابعثوا أحدكم بورقكم هذه إلى المدينة فلينظر أيها أزكى طعاما﴾</span></span>: الفاء عاطفة على محذوف، أي: فدعوا التساؤل وخذوا فيما هو أهم وأجدى لنا في موقفنا هذا فابعثوا، وأحدكم مفعول به، وبورقكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابعثوا﴾</span></span>، أو بمحذوف حال من أحدكم، والباء للملابسة، أي: متلبسًا بها ومصاحبًا لها، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ورقكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى المدينة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابعثوا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فلينظر﴾</span></span> الفاء عاطفة، واللام لام الأمر، وينظر مضارع مجزوم بلام الأمر، وأيها استفهامية، أو موصولة، وهي مبتدأ خبره أزكى، وطعامًا تمييز محول عن المضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليأتكم برزق منه وليتلطف﴾</span></span>: الفاء عاطفة، واللام لام الأمر، ويأت مجزوم بلام الأمر، والفاعل مستتر تقديره: هو، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿برزق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span>، وليتلطف عطف على فليأتكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يشعرن بكم أحدا﴾</span></span>: الواو عاطفة، ولا ناهية، ويشعرن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة وهو في محل جزم بلا الناهية، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشعرن﴾</span></span>، وأحدًا مفعول به.</p></div>"
  18,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم إن يظهروا عليكم يرجموكم أو يعيدوكم في ملتهم﴾</span></span>:  إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم إن، وإن شرطية، ويظهروا فعل الشرط، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يظهروا﴾</span></span>، ويرجموكم جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿أو يعيدوكم﴾</span></span> عطف على يرجموكم، و<span class="hlt"><span class="qpc-hafs">﴿في ملتهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعيدوكم﴾</span></span>، وجملة الشرط والجواب في محل رفع خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولن تفلحوا إذا أبدا﴾</span></span>: الواو عاطفة، ولن حرف نفي ونصب واستقبال، وتفلحوا فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، والواو فاعل، وإذًا حرف جواب وجزاء مهمل، وأبدًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تفلحوا﴾</span></span>.</p></div>"
  18,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك أعثرنا عليهم ليعلموا أن وعد الله حق وأن الساعة لا ريب فيها﴾</span></span>: كذلك الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وأعثرنا فعل وفاعل، والمفعول به محذوف، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعثرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليعلموا﴾</span></span> اللام للتعليل، ويعلموا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعثرنا﴾</span></span>، وأن وما في حيزها سدت مسد مفعولي ليعلموا، وحق خبر أن، <span class="hlt"><span class="qpc-hafs">﴿وأن الساعة﴾</span></span> عطف، ولا نافية للجنس، وريب اسم لا مبني على الفتح في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لا، وجملة لا واسمها وخبرها في محل رفع خبر أن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ يتنازعون بينهم أمرهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعثرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتنازعون﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتنازعون﴾</span></span>، وأمرهم نصب بنزع الخافض، أي: في أمرهم، وقيل: تنازعوا تنصب مفعولا إذا كانت بمعنى التجاذب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا ابنوا عليهم بنيانا﴾</span></span>: الفاء عاطفة، وقالوا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span> فعل أمر وفاعل، وهو مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span>، وبنيانًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ابنوا عليهم بنيانًا﴾</span></span> مقول قولهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربهم أعلم بهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بأعلم.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين غلبوا على أمرهم لنتخذن عليهم مسجدا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿غلبوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على أمرهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غلبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لنتخذن﴾</span></span> اللام لام القسم، ونتخذن فعل مضارع مبني على الفتح، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومسجدًا مفعول به.</p></div>"
  18,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون ثلاثة رابعهم كلبهم﴾</span></span>: السين للاستقبال، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ثلاثة﴾</span></span> خبر لمبتدأ محذوف، أي: هم ثلاثة، و<span class="hlt"><span class="qpc-hafs">﴿رابعهم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كلبهم﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم ثلاثة﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿رابعهم كلبهم﴾</span></span> في محل رفع نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ثلاثة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون خمسة سادسهم كلبهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿خمسة﴾</span></span> خبر لمبتدأ محذوف، أي: هم خمسة، و<span class="hlt"><span class="qpc-hafs">﴿سادسهم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كلبهم﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم خمسة﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿سادسهم كلبهم﴾</span></span> في محل رفع نعت لـ<span class="hlt"><span class="qpc-hafs">﴿خمسة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويقولون خمسة﴾</span></span> معطوفة على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿رجما بالغيب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رجمًا﴾</span></span> منصوب على المصدرية بفعل محذوف، أي: يرجمون رجمًا، أو على الحال بمعنى: راجمين، و<span class="hlt"><span class="qpc-hafs">﴿بالغيب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجمًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون سبعة﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿سبعة﴾</span></span> خبر لمبتدأ محذوف والتقدير: هم سبعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وثامنهم كلبهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ثامنهم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كلبهم﴾</span></span> خبره، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿هم سبعة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل ربي أعلم بعدتهم ما يعلمهم إلا قليل﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر مبني على السكون، والفاعل مستتر تقديره أنت، <span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿بعدتهم﴾</span></span> جار ومجرور متعلقان بأعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ربي أعلم بعدتهم﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يعلمهم...﴾</span></span> استئناف بياني لا محل لها من الإعراب، أو حالية، وما نافية، ويعلمهم فعل مضارع ومفعول به، وإلا أداة حصر، وقليل فاعل يعلمهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تمار فيهم إلا مراء ظاهرا﴾</span></span>: الفاء الفصيحة، أي: إن عرفت هذا وحق لك أن تعرفه فلا تجادل، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تمار﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> وعلامة جزمه حذف حرف العلة، وإلا أداة حصر، ومراء مفعول مطلق، وظاهرًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تستفت فيهم منهم أحدا﴾</span></span>: الواو عاطفة، ولا ناهية، تستفت مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> وعلامة جزمه حذف حرف العلة، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستفت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أحدًا﴾</span></span>، وأحدًا مفعول به.</p></div>"
  18,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقولن لشيء إني فاعل ذلك غدا﴾</span></span>: الواو حرف عطف، ولا ناهية، وتقولن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لشيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولن﴾</span></span>، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿فاعل﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني فاعل﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿فاعل﴾</span></span>، وغدًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فاعل﴾</span></span>.</p></div>"
  18,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا أن يشاء الله﴾</span></span>: استثناء مفرغ، وجملة <span class="hlt"><span class="qpc-hafs">﴿أن يشاء الله﴾</span></span> حال، والتقدير: لا تقولن: أفعل غدًا إلا قائلا: إن شاء الله. وقيل: التقدير: إلا بأن يشاء الله، فالمصدر <span class="hlt"><span class="qpc-hafs">﴿أن يشاء الله﴾</span></span> منصوب بنزع الخافض، والجار والمجرور متعلقان بمحذوف حال، أي: إلا متلبسًا بقول: إن شاء الله. وقيل: إن الاستثناء منقطع، وموضع <span class="hlt"><span class="qpc-hafs">﴿أن يشاء الله﴾</span></span> نصب على الاستثناء.</p><p><span class="hlt"><span class="qpc-hafs">﴿واذكر ربك إذا نسيت وقل عسى أن يهدين ربي لأقرب من هذا رشدا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿واذكر﴾</span></span> عطف على ما تقدم، وربك مفعول به، ولا بد من حذف مضاف، أي: مشيئة ربك، وإذا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسيت﴾</span></span> في محل جر بإضافة الظرف إليها، وجوابها محذوف دل عليه ما قبله، أي: فاذكر، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وعسى فعل ماض مبني على الفتح المقدر للتعذر، وهو من أفعال الرجاء، واسمها مستتر تقديره: هو، <span class="hlt"><span class="qpc-hafs">﴿وأن يهديني﴾</span></span> أن وما في حيزها خبر، وربي فاعل يهديني، و<span class="hlt"><span class="qpc-hafs">﴿لأقرب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهديني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من هذا﴾</span></span> جار ومجرور متعلقان بأقرب، ورشدًا تمييز، أو نائب عن المفعول المطلق، لأنه بمعنى المصدر، أي: يهديني هداية.</p></div>"
  18,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولبثوا﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿في كهفهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبثوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثلاثمائة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثلاث﴾</span></span> ظرف، و<span class="hlt"><span class="qpc-hafs">﴿مائة﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿سنين﴾</span></span>: عطف بيان لـ<span class="hlt"><span class="qpc-hafs">﴿ثلاثمائة﴾</span></span> أو بدل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وازدادوا﴾</span></span>: فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿تسعًا﴾</span></span>: مفعول به، أي: تسع سنين.</p></div>"
  18,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل الله أعلم بما لبثوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وأعلم خبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لبثوا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿له غيب السماوات والأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿غيب السماوات والأرض﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أبصر به وأسمع﴾</span></span>: أبصر صيغة تعجب، وهو فعل ماض أتى على صيغة الأمر ومعناه الخبر، والباء صلة في الفاعل إصلاحًا للفظ، وأسمع عطف على أبصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما لهم من دونه من ولي ولا يشرك في حكمه أحدا﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، وولي مبتدأ مؤخر محلا، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span> الواو عاطفة، ولا نافية، ويشرك فعل مضارع وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿في حكمه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشرك﴾</span></span>، وأحدًا مفعول به.</p></div>"
  18,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتل ما أوحي إليك من كتاب ربك﴾</span></span>: الواو عاطفة، واتل فعل أمر مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من كتاب ربك﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا مبدل لكلماته ولن تجد من دونه ملتحدا﴾</span></span>: لا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿مبدل﴾</span></span> اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لكلماته﴾</span></span> خبر، والجملة حالية، <span class="hlt"><span class="qpc-hafs">﴿ولن تجد﴾</span></span> عطف، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ملتحدا﴾</span></span> مفعول به أول.</p></div>"
  18,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واصبر نفسك مع الذين يدعون ربهم بالغداة والعشي يريدون وجهه﴾</span></span>: الواو عاطفة، واصبر فعل أمر معطوف، والفاعل مستتر تقديره: أنت، ونفسك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿مع الذين﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون ربهم﴾</span></span> صلة الذين لا محل لها من الإعراب، وربهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالغداة والعشي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريدون وجهه﴾</span></span> حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تعد عيناك عنهم تريد زينة الحياة الدنيا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿واصبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تعد﴾</span></span> مجزوم بلا وعلامة جزمه حذف حرف العلة، وعيناك فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعد﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تريد زينة الحياة الدنيا﴾</span></span> حال، والدنيا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تطع من أغفلنا قلبه عن ذكرنا واتبع هواه﴾</span></span>: الواو عاطفة، ولا ناهية، وتطع مضارع مجزوم بلا، والفاعل مستتر، ومَن اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغفلنا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وقلبه مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن ذكرنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغفلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اتبع هواه﴾</span></span> فعل ماض وفاعل مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان أمره فرطا﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص، وأمره اسم كان، وفرطا خبر كان.</p></div>"
  18,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل الحق من ربكم﴾</span></span>: الحق خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿من ربكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو الحق مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من ربكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن شاء فليؤمن﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ومَن شرطية مبتدأ، وشاء فعل ماض في محل جزم فعل الشرط، والفاعل مستتر تقديره: هو، والفاء رابطة للجواب، واللام لام الأمر، ويؤمن مضارع مجزوم بلام الأمر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن شاء فليكفر﴾</span></span>: الواو حرف عطف، ومن شرطية مبتدأ، وشاء فعل ماض في محل جزم فعل الشرط، والفاعل مستتر تقديره: هو، والفاء رابطة للجواب، واللام لام الأمر، ويكفر مضارع مجزوم بلام الأمر، والجملة معطوفة على سابقتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا أعتدنا للظالمين نارا أحاط بهم سرادقها﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span> خبر إن، وللظالمين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span>، ونارًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أحاط بهم سرادقها﴾</span></span> الجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نارا﴾</span></span>، وأحاط فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحاط﴾</span></span>، وسرادقها فاعل أحاط.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يستغيثوا يغاثوا بماء كالمهل يشوي الوجوه﴾</span></span>: الواو عاطفة، وإن شرطية، ويستغيثوا فعل الشرط مجزوم وعلامة جزمه حذف النون، والواو فاعل، ويغاثوا جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿بماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغاثوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كالمهل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المهل﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشوي الوجوه﴾</span></span> صفة ثانية أو حال، والوجوه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بئس الشراب وساءت مرتفقا﴾</span></span>: بئس فعل ماض جامد من أفعال الذم، والشراب فاعل، والمخصوص بالذم محذوف، أي: هي، وساءت عطف على بئس، ومرتفقًا تمييز محول عن الفاعل، أي: وساء مرتفقها.</p></div>"
  18,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات﴾</span></span>: إن حرف ناسخ، والذين اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على آمنوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا لا نضيع أجر من أحسن عملا﴾</span></span>: إن: حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا نضيع﴾</span></span>: خبر إن، وفاعل نضيع مستتر تقديره: نحن، وأجر: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا لا نضيع﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿إن الذين...﴾</span></span> والعائد محذوف والتقدير: من أحسن عملا منهم. أو اعتراضية لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك لهم جنات﴾</span></span>: هي الخبر، وقيل: إن الجملتين <span class="hlt"><span class="qpc-hafs">﴿إنا لا نضيع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أولئك لهم جنات﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن الذين...﴾</span></span>. ومَن موصول مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> صلة الموصول لا محل لها من الإعراب، وعملًا تمييز أو مفعول به.</p></div>"
  18,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك لهم جنات عدن تجري من تحتهم الأنهار﴾</span></span>: الجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن الذين...﴾</span></span>، أو خبر إذا جعلت جملة <span class="hlt"><span class="qpc-hafs">﴿إنا لا نضيع...﴾</span></span> اعتراضية. وأولئك مبتدأ. و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> متعلقان بمحذوف خبر مقدم، وجنات عدن مبتدأ مؤخر، والمبتدأ الثاني وخبره خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتهم الأنهار﴾</span></span> حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿يحلون فيها من أساور من ذهب﴾</span></span>: يحلون فعل مضارع مبني لما لم يسمَّ فاعله، الواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حال كونهم في الجنة، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أساور﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لمفعول به ثان محذوف، أي: يحلَّون فيها حليًّا ناشئًا من أساور كائنةٍ من ذهب، و<span class="hlt"><span class="qpc-hafs">﴿من ذهب﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أساور﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحلون﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويلبسون ثيابا خضرا من سندس وإستبرق متكئين فيها على الأرائك﴾</span></span>: الواو عاطفة، ويلبسون عطف على يحلون، والواو فاعل، وثيابًا مفعول به، وخضرًا صفة، و<span class="hlt"><span class="qpc-hafs">﴿من سندس﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، أو حال من <span class="hlt"><span class="qpc-hafs">﴿ثيابًا﴾</span></span>، وإستبرق عطف على سندس، ومتكئين حال من أولئك، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿على الأرائك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نعم الثواب وحسنت مرتفقا﴾</span></span>: نعم فعل ماض جامد من أفعال المدح، والثواب فاعل، والمخصوص بالمدح محذوف، أي: هي، وحسنت عطف على نعم، ومرتفقًا تمييز محول عن الفاعل، أي: وحسن مرتفقها.</p></div>"
  18,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واضرب لهم مثلا رجلين﴾</span></span>: اضرب فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، ومثلًا مفعول به، ورجلين بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>، فيكون <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> بمثابة المفعول الثاني، و<span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span> هو المفعول الأول، أو <span class="hlt"><span class="qpc-hafs">﴿رجلين﴾</span></span> هي المفعول الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿جعلنا لأحدهما جنتين من أعناب وحففناهما بنخل﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجلين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لأحدهما﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، وجنتين مفعول أول، و<span class="hlt"><span class="qpc-hafs">﴿من أعناب﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنتين﴾</span></span>، وحففناهما فعل وفاعل ومفعول به، وهو عطف على جعلنا، و<span class="hlt"><span class="qpc-hafs">﴿بنخل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حففناهما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا بينهما زرعا﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، وزرعا المفعول الأول.</p></div>"
  18,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلتا الجنتين آتت أكلها ولم تظلم منه شيئا﴾</span></span>: كلتا مبتدأ مرفوع وعلامة رفعه ضمة مقدرة على الألف لأنه اسم مقصور، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتت أكلها﴾</span></span> خبر كلتا، ولم تظلم عطف على آتت، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تظلم﴾</span></span>، وشيئًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وفجرنا خلالهما نهرا﴾</span></span>: فجرنا فعل وفاعل، وخلالهما ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span>، ونهرًا مفعول به.</p></div>"
  18,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكان له ثمر فقال لصاحبه وهو يحاوره﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر كان المقدم، وثمر اسمها المؤخر، <span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لصاحبه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة يحاوره خبر، والجملة حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنا أكثر منك مالا وأعز نفرا﴾</span></span>: الجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، وأكثر خبر، و<span class="hlt"><span class="qpc-hafs">﴿منك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span>، ومالًا تمييز، <span class="hlt"><span class="qpc-hafs">﴿وأعز نفرًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أكثر مالًا﴾</span></span>.</p></div>"
  18,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ودخل جنته﴾</span></span>: فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو ظالم لنفسه﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وظالم خبر، والجملة حالية، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال ما أظن أن تبيد هذه أبدا﴾</span></span>: قال فعل ماض، والفاعل مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أظن...﴾</span></span> مقول القول، وأن وما بعدها سدت مسد مفعولي أظن، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿تبيد﴾</span></span>، وأبدًا ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تبيد﴾</span></span>.</p></div>"
  18,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما أظن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما أظن﴾</span></span> الأولى، والساعة مفعول به أول، وقائمة مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن رددت إلى ربي﴾</span></span>: الواو عاطفة، واللام موطئة للقسم، وإن شرطية، ورددت فعل ماض مبني لما لم يسمَّ فاعله في محل جزم فعل الشرط، والتاء نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لأجدن خيرا منها منقلبا﴾</span></span>: اللام واقعة في جواب القسم، وجواب الشرط محذوف دل عليه جواب القسم، وخيرًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أجدن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span>، ومنقلبًا تمييز، أو <span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿منقلبًا﴾</span></span> مفعول به، أي: لأجدن منقلبًا خيرًا منها.</p></div>"
  18,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال له صاحبه وهو يحاوره أكفرت بالذي خلقك من تراب ثم من نطفة ثم سواك رجلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿صاحبه﴾</span></span> فاعل، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة يحاوره خبر، والهمزة للاستفهام، وكفرت فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالذي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفرت﴾</span></span>، وجملة خلقك صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من تراب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ثم من نطفة﴾</span></span> عطف، وثم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿سواك﴾</span></span> فعل ماض والفاعل مستتر، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿رجلًا﴾</span></span> حال، أو مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿سواك﴾</span></span>، وقيل: تمييز.</p></div>"
  18,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لكنا هو الله ربي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لكنا﴾</span></span> الأصل: لكن أنا، <span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> للاستدراك، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير الشأن مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ ثالث، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> خبر، والياء عائدة على المبتدأ الأول، أو <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا أشرك بربي أحدا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولا نافية، وأشرك فعل مضارع، وفاعله مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿بربي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشرك﴾</span></span>، وأحدًا مفعول به.</p></div>"
  18,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله﴾</span></span>: الواو عاطفة، ولولا حرف تحضيض، أي: هلا، وإذ ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قلت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿دخلت﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة في محل رفع خبر لمبتدأ محذوف، أي: هذا الذي شاءه الله، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ، والخبر محذوف تقديره: كان، والجملة مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿شاء الله﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف كما قدرناه، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> شرطية منصوبة الموضع بفعل الشرط، والجواب محذوف، أي: كان، والمعنى: أي شيء شاءه الله كان، والجملة كلها مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا قوة إلا بالله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس، وقوة اسمها المبني على الفتح، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ترن أنا أقل منك مالا وولدا﴾</span></span>: إن شرطية، وترنِ فعل الشرط مجزوم وعلامة جزمه حذف حرف العلة، والنون للوقاية، والياء المحذوفة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> ضمير فصل، وأقل مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿ترنِ﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> توكيد للياء، و<span class="hlt"><span class="qpc-hafs">﴿منك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span>، ومالًا تمييز، وولدًا عطف عليه.</p></div>"
  18,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعسى ربي أن يؤتين خيرا من جنتك﴾</span></span>: الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> اسم عسى، وأن وما في حيزها في محل نصب خبرها، وخيرًا مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يؤتيني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من جنتك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خيرا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويرسل عليها حسبانا من السماء فتصبح صعيدا زلقا﴾</span></span>: الواو عاطفة، ويرسل عطف على يؤتيني، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>، وحسبانًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حسبانا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فتصبح﴾</span></span> الفاء عاطفة على ما تقدم، وتصبح فعل مضارع منصوب لأنه عطف على ما تقدم، واسم تصبح مستتر تقديره: هي، وصعيدًا خبر تصبح، وزلقًا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿صعيدًا﴾</span></span>.</p></div>"
  18,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو يصبح ماؤها غورا فلن تستطيع له طلبا﴾</span></span>: أو حرف عطف، ويصبح مضارع منصوب معطوف على ما قبله، وماؤها اسم يصبح، وغورًا خبرها، والفاء عاطفة، ولن حرف نفي ونصب واستقبال، وتستطيع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، والفاعل ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طلبًا﴾</span></span>، وطلبًا مفعول به.</p></div>"
  18,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأحيط بثمره فأصبح يقلب كفيه على ما أنفق فيها﴾</span></span>: الواو استئنافية، وأحيط فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿بثمره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحيط﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأحيط بثمره﴾</span></span> مستأنفة لا محل لها من الإعراب، فأصبح فعل ماض ناقص، واسمها مستتر تقديره: هو، وجملة يقلب كفيه خبر أصبح، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقلب﴾</span></span>، أو متعلقان بحال محذوفة، والتقدير: يقلب كفيه نادمًا على ما أنفق فيها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهي خاوية على عروشها ويقول يا ليتني لم أشرك بربي أحدا﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وخاوية خبر، و<span class="hlt"><span class="qpc-hafs">﴿على عروشها﴾</span></span> جار ومجرور متعلقان بخاوية، و<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يقلب﴾</span></span>، أو الواو للحال، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> حال من فاعل يقلب، ويا للتنبيه أو للنداء، والمنادى محذوف، وليت حرف تمن ينصب الاسم ويرفع الخبر، والنون للوقاية، والياء اسمها، ولم حرف نفي وقلب وجزم، وأشرك فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بربي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشرك﴾</span></span>، وأحدًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا ليتني لم أشرك﴾</span></span> مقول القول.</p></div>"
  18,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولم تكن له فئة ينصرونه من دون الله وما كان منتصرا﴾</span></span>: الواو للعطف، ولم حرف نفي وقلب وجزم، وتكن فعل مضارع ناقص مجزوم، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكن المقدم، وفئة اسم تكن المؤخر، وجملة ينصرونه صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فئة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والواو حرف عطف، وما نافية، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، ومنتصرًا خبر خبر كان.</p></div>"
  18,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هنالك الولاية لله الحق﴾</span></span>: هنالك اسم إشارة في محل نصب على الظرفية المكانية متعلق بمحذوف خبر مقدم، والولاية مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بما في معنى اسم الإشارة، أو بمتعلقه وهو الخبر المحذوف، أو متعلقان بمحذوف حال من الولاية، والحق صفة لله، أو اسم الإشارة متعلق بمعنى الاستقرار في <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>، والولاية مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، أي: مستقرة لله، أو متعلقان بالولاية نفسها، لأنها مصدر بمعنى النصرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو خير ثوابا وخير عقبا﴾</span></span>: هو مبتدأ، وخير خبر، وثوابًا تمييز، <span class="hlt"><span class="qpc-hafs">﴿وخير عقبًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿خير ثوابًا﴾</span></span>.</p></div>"
  18,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واضرب لهم مثل الحياة الدنيا كماء أنزلناه من السماء﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واضرب فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثل الحياة الدنيا﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿كماء﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلناه من السماء﴾</span></span> صفة لماء، أو <span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span> بمعنى: اذكر، فينصب مفعولا واحدا، والكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر لمبتدأ محذوف، أو في محل نصب صفة لمصدر محذوف، أي: ضربًا مثلَ ماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاختلط به نبات الأرض﴾</span></span>: الفاء حرف عطف، واختلط فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اختلط﴾</span></span>، ونبات الأرض فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأصبح هشيما تذروه الرياح﴾</span></span>: فأصبح عطف على اختلط، واسم أصبح مستتر يعود على نبات الأرض، وهشيمًا خبر أصبح، وجملة <span class="hlt"><span class="qpc-hafs">﴿تذروه الرياح﴾</span></span> صفة لقوله هشيمًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الله على كل شيء مقتدرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو حالية والجملة بعدها في محل نصب حال، وكان فعل ماض ناقص، ولفظ الجلالة اسم كان، ومقتدرًا خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مقتدرًا﴾</span></span>.</p></div>"
  18,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿المال والبنون زينة الحياة الدنيا﴾</span></span>: المال مبتدأ، والبنون عطف على المال، وزينة خبر، والحياة مضاف إليه، والدنيا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿والباقيات الصالحات خير عند ربك ثوابا وخير أملا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، والباقيات مبتدأ، والصالحات صفة، وخير خبر الباقيات، و<span class="hlt"><span class="qpc-hafs">﴿عند ربك﴾</span></span> ظرف متعلق بمحذوف حال، وثوابًا تمييز، <span class="hlt"><span class="qpc-hafs">﴿وخير أملًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿خير ثوابًا﴾</span></span>.</p></div>"
  18,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نسير الجبال﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، ونسير فعل مضارع، والفاعل مستتر تقديره: نحن، والجبال مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسير﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وترى الأرض بارزة﴾</span></span>: الواو عاطفة، وترى فعل مضارع، وفاعل ترى مستتر تقديره: أنت، والأرض مفعول به، وبارزة حال، والجملة في محل جر معطوفة على سابقتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وحشرناهم فلم نغادر منهم أحدا﴾</span></span>: الواو هنا للحال، وحشرناهم فعل وفاعل ومفعول به، والجملة في محل نصب حال، أي: نفعل التسيير في حال حشرهم ليشاهدوا بأعينهم تلك الأهوال، أو الواو عاطفة، وأريد بالماضي المستقبل، أي: ونحشرهم. <span class="hlt"><span class="qpc-hafs">﴿فلم﴾</span></span> الفاء حرف عطف، ولم حرف نفي وقلب وجزم، ونغادر فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أحدًا﴾</span></span>، وأحدًا مفعول به.</p></div>"
  18,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعرضوا على ربك صفا﴾</span></span>: الواو عاطفة على <span class="hlt"><span class="qpc-hafs">﴿وحشرناهم﴾</span></span>، وعرضوا فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عرضوا﴾</span></span>، وصفًّا حال من واو الجماعة في <span class="hlt"><span class="qpc-hafs">﴿عرضوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقد جئتمونا كما خلقناكم أول مرة﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، وجئتمونا فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أو حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span> فعل وفاعل ومفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل مضاف إليه، والجملة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أول مرة﴾</span></span> نصب على الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد جئتمونا﴾</span></span> حالية، أو مقول لقول محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل زعمتم ألن نجعل لكم موعدا﴾</span></span>: بل حرف إضراب، وزعمتم فعل وفاعل، وأن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، ولن حرف نفي ونصب واستقبال، ونجعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، وفاعله مستتر تقديره: نحن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن نجعل...﴾</span></span> في محل رفع خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان، وموعدًا مفعول به أول لـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span> على اعتبار أن نجعل بمعنى الإيجاد، وموعدًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألن نجعل لكم﴾</span></span> سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿زعمتم﴾</span></span>.</p></div>"
  18,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووضع الكتاب فترى المجرمين مشفقين مما فيه﴾</span></span>: الواو عاطفة، ووضع فعل ماض مبني لما لم يسمَّ فاعله، والكتاب نائب فاعل، <span class="hlt"><span class="qpc-hafs">﴿فترى﴾</span></span> الفاء عاطفة، وترى فعل مضارع مرفوع، والفاعل مستتر تقديره: أنت، والمجرمين مفعول به أول، ومشفقين مفعول به ثان، والرؤية هنا علمية، أو الرؤية بصرية و<span class="hlt"><span class="qpc-hafs">﴿مشفقين﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشفقين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون يا ويلتنا مال هذا الكتاب لا يغادر صغيرة ولا كبيرة إلا أحصاها﴾</span></span>: الواو عاطفة، ويقولون عطف، ويا حرف نداء، وويلتنا منادى، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهذا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والكتاب بدل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يغادر﴾</span></span> حالية، وصغيرة مفعول به، <span class="hlt"><span class="qpc-hafs">﴿ولا كبيرة﴾</span></span> عطف على صغيرة، وإلا أداة حصر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحصاها﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صغيرة﴾</span></span>، أو مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يغادر﴾</span></span>، لأنها بمعنى ترك وهي تنصب مفعولين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ووجدوا ما عملوا حاضرا﴾</span></span>: الواو عاطفة، ووجدوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة عملوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول مفعول به، أي: وجدوا عملهم، وحاضرًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يظلم ربك أحدا﴾</span></span>: الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو حالية والجملة بعدها في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يظلم﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أحدا﴾</span></span> مفعول به.</p></div>"
  18,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قلنا﴾</span></span> في محل جر مضاف إليه، وللملائكة جار ومجرور متعلقان بقلنا، واسجدوا فعل أمر وفاعل، ولآدم جار ومجرور متعلقان باسجدوا، فسجدوا فعل وفاعل، وإلا أداة استثناء، وإبليس مستثنى، والاستثناء منقطع، وقيل: متصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان من الجن ففسق عن أمر ربه﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، واسم كان مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> يعود على إبليس، ومن الجن خبر، ففسق عطف على كان، وعن أمر ربه جار ومجرور متعلقان بفسق.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفتتخذونه وذريته أولياء من دوني وهم لكم عدو بئس للظالمين بدلا﴾</span></span>: الهمزة للاستفهام. وتتخذونه: فعل مضارع وفاعل ومفعول به. <span class="hlt"><span class="qpc-hafs">﴿وذريته﴾</span></span>: الواو عاطفة. وذريته: عطف على الهاء، أو الواو بمعنى مع، وذريته مفعول معه. وأولياء: مفعول به ثان. ومن دوني: الجار والمجرور متعلقان بمحذوف صفة لأولياء، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتخذونه﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو للحال. وهم: مبتدأ. ولكم: جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لعدو. وعدو: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿هم لكم عدو﴾</span></span> حال من مفعول تتخذونه أو فاعله. وبئس: فعل ماض جامد لإنشاء الذم، وفاعله ضمير مستتر. وللظالمين: جار ومجرور متعلقان بمحذوف حال. وبدلًا: تمييز، والمخصوص بالذم محذوف، والتقدير: بئس البدل إبليس وذريته.</p></div>"
  18,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أشهدتهم خلق السماوات والأرض ولا خلق أنفسهم﴾</span></span>: ما نافية، وأشهدتهم فعل وفاعل ومفعول به، وخلق السماوات والأرض مفعول به ثان، <span class="hlt"><span class="qpc-hafs">﴿ولا خلق أنفسهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت متخذ المضلين عضدا﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> كان فعل ماض ناقص، والتاء ضمير مبني في محل رفع اسم كان، ومتخذ خبر كان منصوب، والمضلين مضاف إليه، وعضدًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿متخذ﴾</span></span>.</p></div>"
  18,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يقول نادوا شركائي الذين زعمتم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> في محل جر بإضافة الظرف إليها، ونادوا فعل أمر وفاعل، وشركائي مفعول به، والذين نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿زعمتم﴾</span></span> صلة الذين لا محل لها من الإعراب، والعائد محذوف، أي: زعمتموهم شركاء، كما حذف المفعول الثاني لزعمتم أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فدعوهم فلم يستجيبوا لهم وجعلنا بينهم موبقا﴾</span></span>: الفاء عاطفة، ودعوهم فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فلم﴾</span></span> الفاء عاطفة، ولم حرف نفي وقلب وجزم، ويستجيبوا مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستجيبوا﴾</span></span>، وجعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بمحذوف مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿موبقًا﴾</span></span> هو المفعول الأول.</p></div>"
  18,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ورأى المجرمون النار﴾</span></span>: فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فظنوا أنهم مواقعوها﴾</span></span>: الفاء عاطفة، وظنوا فعل وفاعل، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير مبني في محل نصب اسم إن، ومواقعوها خبر إن مرفوع بالواو، لأنه جمع مذكر سالم، والجملة سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿ظنوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولم يجدوا عنها مصرفا﴾</span></span>: الواو عاطفة، ولم يجدوا عطف على ظنوا، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مصرفًا﴾</span></span>، ومصرفًا مفعول به.</p></div>"
  18,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صرفنا في هذا القرآن للناس من كل مثل﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وصرفنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، والقرآن بدل من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من كل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لموصوف محذوف هو مفعول <span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، أي: معنى غريبًا بديعًا يشبه المثل بغرابته وطرافته، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الإنسان أكثر شيء جدلا﴾</span></span>: الواو عاطفة أو حالية، وكان فعل ماض ناقص، والإنسان اسم كان مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span> خبر كان منصوب، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿جدلًا﴾</span></span> تمييز.</p></div>"
  18,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما منع الناس أن يؤمنوا إذ جاءهم الهدى﴾</span></span>: الواو عاطفة، وما نافية، ومنع فعل ماض، والناس مفعول به أول، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يؤمنوا﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءهم الهدى﴾</span></span> في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويستغفروا ربهم إلا أن تأتيهم سنة الأولين أو يأتيهم العذاب قبلا﴾</span></span>: الواو عاطفة، ويستغفروا عطف على يؤمنوا، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span> مفعول به، وإلا أداة حصر، وأن وما في حيزها فاعل منع، وتأتيهم فعل مضارع ومفعول به مقدم، وسنة الأولين فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ويأتيهم العذاب عطف على <span class="hlt"><span class="qpc-hafs">﴿تأتيهم سنة الأولين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قبلًا﴾</span></span> حال من الضمير أو من العذاب، ولا بد من تقدير مضاف محذوف قبل <span class="hlt"><span class="qpc-hafs">﴿أن تأتيهم سنة الأولين﴾</span></span> تقديره: انتظار الإتيان، إذ لا يمكن جعل إتيان سنة الأولين مانعًا من إيمانهم.</p></div>"
  18,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما نرسل المرسلين إلا مبشرين ومنذرين﴾</span></span>: الواو عاطفة، وما نافية، ونرسل فعل مضارع وفاعل مستتر، والمرسلين مفعول به، وإلا أداة حصر، ومبشرين حال، ومنذرين عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجادل الذين كفروا بالباطل ليدحضوا به الحق﴾</span></span>: يجادل فعل مضارع، والذين فاعل، وكفروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بالباطل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليدحضوا﴾</span></span> اللام للتعليل، ويدحضوا فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدحضوا﴾</span></span>، والحق مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتخذوا آياتي وما أنذروا هزوا﴾</span></span>: الواو حالية والجملة بعدها في محل نصب حال،  أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، واتخذوا فعل وفاعل، وآياتي مفعول به أول، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوف على <span class="hlt"><span class="qpc-hafs">﴿آياتي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنذروا﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر معطوف على آياتي، وهزوًا مفعول به ثان.</p></div>"
  18,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن أظلم ممن ذكر بآيات ربه فأعرض عنها ونسي ما قدمت يداه﴾</span></span>: الواو استئنافية، ومَن اسم استفهام معناه النفي في محل رفع مبتدأ، وأظلم خبر، وممن جار ومجرور متعلقان بأظلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وبآيات ربه جار ومجرور متعلقان بذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومَن أظلم...﴾</span></span> مستأنفة لا محل لها من الإعراب، فأعرض عطف على ذكر، وفاعله مستتر تقديره هو، وعنها جار ومجرور متعلقان بأعرض، ونسي عطف على ما تقدم، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ويداه فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا جعلنا على قلوبهم أكنة أن يفقهوه وفي آذانهم وقرا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> خبر إن، وعلى قلوبهم في محل نصب مفعول به ثان لجعلنا، وأكنة مفعول به أول، وأن حرف مصدري ونصب، ويفقهوه فعل مضارع منصوب، والواو فاعل، والهاء مفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يفقهوه﴾</span></span> مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿في آذانهم وقرًا﴾</span></span> عطف على معمولي جعلنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن تدعهم إلى الهدى فلن يهتدوا إذا أبدا﴾</span></span>: الواو حرف عطف، وإن شرطية، وتدعهم فعل الشرط، وفاعله مستتر تقديره أنت، والهاء مفعول به، وإلى الهدى جار ومجرور متعلقان بتدعهم، فلن: الفاء رابطة، ولن حرف نفي ونصب واستقبال، ويهتدوا نصب بلن، والواو فاعل، وإذًا حرف جواب وجزاء، وأبدًا ظرف متعلق بيهتدوا.</p></div>"
  18,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربك الغفور ذو الرحمة لو يؤاخذهم بما كسبوا لعجل لهم العذاب﴾</span></span>: الواو استئنافية، وربك مبتدأ، والغفور خبر، وذو الرحمة خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿وربك الغفور﴾</span></span> مستأنفة لا محل لها من الإعراب، ولو شرطية، ويؤاخذهم فعل مضارع وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤاخذهم﴾</span></span>، وجملة كسبوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، واللام رابطة، وعجل فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجل﴾</span></span>، والعذاب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل لهم موعد لن يجدوا من دونه موئلا﴾</span></span>: بل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> خبر مقدم، وموعد مبتدأ مؤخر، ولن حرف نفي ونصب واستقبال، ويجدوا فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وموئلًا مفعول به.</p></div>"
  18,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك القرى أهلكناهم لما ظلموا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿تلك﴾</span></span> مبتدأ، أو منصوب على الاشتغال، والقرى بدل، وجملة أهلكناهم خبر، أو <span class="hlt"><span class="qpc-hafs">﴿القرى﴾</span></span> خبر، وجملة أهلكناهم حال، أو خبر ثان، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرف بمعنى حين متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكناهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا لمهلكهم موعدا﴾</span></span>: الواو عاطفة، وجعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لمهلكهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿موعدًا﴾</span></span>، ومهلكهم مصدر ميمي مضاف إلى فاعله، وموعدًا مفعول به.</p></div>"
  18,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قال موسى لفتاه لا أبرح حتى أبلغ مجمع البحرين أو أمضي حقبا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، و<span class="hlt"><span class="qpc-hafs">﴿قال موسى﴾</span></span> فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال موسى﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿لفتاه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، ولا نافية، وأبرح فعل مضارع ناقص، واسمها مستتر تقديره: أنا، والخبر محذوف تقديره: أسير، أو <span class="hlt"><span class="qpc-hafs">﴿أبرح﴾</span></span> تامة فلا تستدعي خبرًا، أي: لا أزول عما أنا عليه من السير والطلب ولا أفارقه، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، وأبلغ منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبرح﴾</span></span>، ومجمع البحرين مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أمضي﴾</span></span> معطوف على أبلغ، و<span class="hlt"><span class="qpc-hafs">﴿حقبًا﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أمضي﴾</span></span>.</p></div>"
  18,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما بلغا مجمع بينهما نسيا حوتهما فاتخذ سبيله في البحر سربا﴾</span></span>: الفاء عاطفة، ولما ظرف بمعنى حين، وجملة <span class="hlt"><span class="qpc-hafs">﴿بلغا﴾</span></span> في محل جر بإضافة الظرف إليها، والألف فاعل، ومجمع مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف أضيف إلى <span class="hlt"><span class="qpc-hafs">﴿مجمع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسيا﴾</span></span> لا محل لها من الإعراب، لأنها جواب لما، وحوتهما مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فاتخذ﴾</span></span> الفاء عاطفة، واتخذ فعل ماض، وفاعله مستتر تقديره: هو، أي: الحوت، و<span class="hlt"><span class="qpc-hafs">﴿سبيله﴾</span></span> مفعول به أول، وسربًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿في البحر﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  18,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاوزا قال لفتاه آتنا غداءنا﴾</span></span>: الفاء عاطفة، ولما ظرفية حينية، وجملة جاوزا في محل جر بإضافة الظرف إليها، والمفعول محذوف، أي: جاوزا المكان الذي نسيا الحوت فيه، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال لفتاه﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتنا غداءنا﴾</span></span> مقول القول، وغداءنا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿آتنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقد لقينا من سفرنا هذا نصبا﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، ولقينا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من سفرنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لقينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سفرنا﴾</span></span> أو بدل منه، و<span class="hlt"><span class="qpc-hafs">﴿نصبًا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿لقينا﴾</span></span>.</p></div>"
  18,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أرأيت إذ أوينا إلى الصخرة﴾</span></span>: أرأيت: الهمزة للاستفهام، ورأيت فعل ماض مبني على السكون والتاء فاعل، ومفعولا أرأيت محذوفان اختصارا، أي: أرأيت أمرنا ما عاقبته؟ وجملة أوينا في محل جر بإضافة الظرف إليها، وإلى الصخرة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوينا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإني نسيت الحوت﴾</span></span>: الفاء لتعليل الدهشة التي اعترتهما مما نابهما، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسيت الحوت﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنسانيه إلا الشيطان أن أذكره﴾</span></span>: الواو اعتراضية، والجملة اعتراضية بين المعطوف والمعطوف عليه لا محل لها من الإعراب، وما نافية، وأنسانيه فعل ماض، والنون للوقاية، والياء مفعول به أول، والهاء مفعول به ثان، وإلا أداة حصر، والشيطان فاعل أنسانيه، وأن وما في حيزها بدل اشتمال من الهاء، أي: وما أنساني ذكره إلا الشيطان.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتخذ سبيله في البحر عجبا﴾</span></span>: الواو عاطفة، واتخذ فعل ماض معطوف على نسيت، وفاعله مستتر تقديره هو، أي الحوت، و<span class="hlt"><span class="qpc-hafs">﴿سبيله﴾</span></span> مفعول به أول. و<span class="hlt"><span class="qpc-hafs">﴿عجبا﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في البحر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span> أو بمحذوف حال من المفعول الأول أو الثاني، أو أن <span class="hlt"><span class="qpc-hafs">﴿عجبا﴾</span></span> مفعول مطلق لفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿في البحر﴾</span></span> متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>.</p></div>"
  18,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ذلك ما كنا نبغ﴾</span></span>: ذلك مبتدأ، وما خبر، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل رفع اسم كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿نبغي﴾</span></span> خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك...﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فارتدا على آثارهما قصصا﴾</span></span>: الفاء عاطفة، وارتدا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على آثارهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ارتدا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قصصا﴾</span></span> مفعول مطلق لفعل محذوف، والتقدير: يقصان قصصا، أو حال، والتقدير: فارتدا على آثارهما قاصين.</p></div>"
  18,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فوجدا عبدا من عبادنا آتيناه رحمة من عندنا وعلمناه من لدنا علما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿وجدا عبدًا﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عبدًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيناه﴾</span></span> صفة ثانية، ورحمة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من عندنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، وعلمناه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علمًا﴾</span></span> وتقدم عليه، وعلمًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿علمناه﴾</span></span>.</p></div>"
  18,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال له موسى هل أتبعك على أن تعلمن مما علمت رشدا﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وموسى فاعل، وهل حرف استفهام، وأتبعك فعل مضارع وفاعل مستتر ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿أن تعلمني﴾</span></span> أن وما في حيزها في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بمحذوف حال من الكاف في <span class="hlt"><span class="qpc-hafs">﴿أتبعك﴾</span></span>، أي: هل أتبعك حال كونك معلمًا لي، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعلمني﴾</span></span>، وجملة علمت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ورشدًا مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تعلمني﴾</span></span>، لأن الياء هي المفعول الأول، أو مفعول لأجله، أي: لأجل الرشاد، أو مصدر في موضع نصب على الحال.</p></div>"
  18,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إنك لن تستطيع معي صبرا﴾</span></span>: إن حرف ناسخ، والكاف ضمير مبني في محل نصب اسم إن، ولن حرف نفي ونصب واستقبال، وتستطيع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن تستطيع﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿معي﴾</span></span> ظرف مكان متعلق بمحذوف، أي: حال كونك معي، وصبرًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك...﴾</span></span> مقول القول.</p></div>"
  18,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكيف تصبر على ما لم تحط به خبرا﴾</span></span>: الواو عاطفة، وكيف اسم استفهام في محل نصب حال، وتصبر فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تصبر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تحط﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحط﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خبرا﴾</span></span> نائب عن المفعول المطلق، لأن لم تحط بمعنى لم تخبر، أو تمييز محول عن الفاعل، أي: لم يحط به خبرك.</p></div>"
  18,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ستجدني إن شاء الله صابرا ولا أعصي لك أمرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ستجدني﴾</span></span> السين حرف استقبال، وتجدني فعل مضارع مرفوع، والنون للوقاية، وفاعله مستتر تقديره: أنت، والياء ضمير متصل في محل نصب مفعول به أول. و<span class="hlt"><span class="qpc-hafs">﴿إن شاء الله﴾</span></span> جملة اعتراضية، وجواب الشرط محذوف دل عليه قوله: <span class="hlt"><span class="qpc-hafs">﴿تجدني﴾</span></span>. وصابرًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجدني﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا أعصي لك أمرًا﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿صابرًا﴾</span></span> فهي في محل نصب، أو معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ستجدني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أمرًا﴾</span></span> وتقدم عليه.</p></div>"
  18,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فإن اتبعتني فلا تسألني عن شيء حتى أحدث لك منه ذكرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فإن﴾</span></span> الفاء عاطفة، وإن شرطية، واتبعتني فعل ماض وفاعل ومفعول به، وهو في محل جزم فعل الشرط، والفاء رابطة، ولا ناهية، وتسألني مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والنون للوقاية، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسألني﴾</span></span>، وحتى حرف غاية وجر، وأحدث فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسألني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحدث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>، وذكرًا مفعول به، ولا بد من تقدير صفة محذوفة بعد <span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>، أي: شيء خفي عليك سره.</p></div>"
  18,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانطلقا حتى إذا ركبا في السفينة خرقها﴾</span></span>: الفاء استئنافية، وانطلقا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿انطلقا﴾</span></span> مستأنفة لا محل لها من الإعراب، وحتى حرف غاية وجر، وإذا ظرف للزمن الماضي متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ركبا في السفينة﴾</span></span> في محل جر بإضافة الظرف إليها، وخرقها فعل ماض وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿خرقها﴾</span></span> جواب إذا.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال أخرقتها لتغرق أهلها لقد جئت شيئا إمرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أخرقتها﴾</span></span> الهمزة للاستفهام الإنكاري، وخرقتها فعل ماض وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿لتغرق﴾</span></span> اللام للتعليل، وتغرق فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خرقتها﴾</span></span>، وأهلها مفعول به، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وجئت فعل وفاعل، وشيئًا مفعول به، وإمرًا صفة.</p></div>"
  18,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ألم أقل إنك لن تستطيع معي صبرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ألم﴾</span></span> الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه السكون، و<span class="hlt"><span class="qpc-hafs">﴿إنك﴾</span></span> إن والكاف اسمها، ولن حرف نفي ونصب، وتستطيع مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span> وعلامة نصبه الفتحة الظاهرة، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿معي﴾</span></span> ظرف منصوب بفتحة مقدرة على ما قبل الياء متعلق بمحذوف، أي: حال كونك معي، والياء مضاف إليه، وصبرا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن تستطيع معي صبرًا﴾</span></span> في محل رفع خبر إن.</p></div>"
  18,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا تؤاخذني بما نسيت ولا ترهقني من أمري عسرا﴾</span></span>: لا ناهية، وتؤاخذني فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والنون للوقاية، والفاعل مستتر تقديره: أنت، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تؤاخذني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نسيت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من أمري﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عسرًا﴾</span></span>، وعسرًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿ترهقني﴾</span></span>.</p></div>"
  18,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانطلقا حتى إذا لقيا غلاما فقتله﴾</span></span>: الفاء للعطف، وانطلقا فعل وفاعل، وحتى حرف غاية وجر، وإذا ظرف للزمن الماضي متضمن معنى الشرط، <span class="hlt"><span class="qpc-hafs">﴿لقيا﴾</span></span> فعل الشرط مجزوم، والجملة في محل جر بإضافة الظرف إليها، وغلامًا مفعول به، والفاء حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿فقتله﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿لقيا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال أقتلت نفسا زكية بغير نفس لقد جئت شيئا نكرا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> جواب إذا، <span class="hlt"><span class="qpc-hafs">﴿أقتلت﴾</span></span> الهمزة للاستفهام، وقتلت فعل وفاعل، ونفسًا مفعول به، وزكية صفة، و<span class="hlt"><span class="qpc-hafs">﴿بغير نفس﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل، أي: قتلته ظالما، أو من المفعول، أي: قتلته مظلومًا، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span>، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وجئت فعل وفاعل، وشيئًا مفعول به، ونكرًا صفة.</p></div>"
  18,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ألم أقل لك إنك لن تستطيع معي صبرا﴾</span></span>: ألم: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وأقل: مضارع مجزوم بلم وعلامة جزمه السكون، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span>، وإنك: إن والكاف اسمها، ولن حرف نفي ونصب، وتستطيع مضارع منصوب بلن وعلامة نصبه الفتحة الظاهرة، والفاعل مستتر تقديره أنت، ومعي ظرف منصوب بفتحة مقدرة على ما قبل الياء متعلق بمحذوف، أي: حال كونك معي، والياء مضاف إليه، وصبرا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن تستطيع معي صبرًا﴾</span></span> في محل رفع خبر إن.</p></div>"
  18,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن سألتك عن شيء بعدها فلا تصاحبني﴾</span></span>: إن شرطية، وسألتك فعل ماض وفاعل ومفعول به، وهو في محل جزم فعل الشرط، وعن شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سألتك﴾</span></span>، وبعدها ظرف متعلق بمحذوف صفة لشيء، والفاء رابطة لجواب الشرط، ولا ناهية، وتصاحبني مضارع مجزوم بلا، والنون للوقاية، والياء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد بلغت من لدني عذرا﴾</span></span>: قد حرف تحقيق، وبلغت فعل وفاعل، ومن حرف جر، ولدن ظرف مبني على السكون في محل جر، والياء مضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بلغت﴾</span></span> أو متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿عذرًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عذرًا﴾</span></span> مفعول به.</p></div>"
  18,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانطلقا حتى إذا أتيا أهل قرية استطعما أهلها﴾</span></span>: الفاء عاطفة، وانطلقا فعل وفاعل، وحتى حرف غاية وجر، وإذا ظرف ورد ههنا للزمن الماضي متضمن معنى الشرط، وأتيا فعل وفاعل، وأهل مفعول به، وقرية مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿استطعما أهلها﴾</span></span> لا محل لها من الإعراب، لأنها جواب إذا، وقيل: جملة <span class="hlt"><span class="qpc-hafs">﴿استطعما أهلها﴾</span></span> صفة لقرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأبوا أن يضيفوهما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبوا﴾</span></span> فعل وفاعل، وأن وما في حيزها مفعول أبوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوجدا فيها جدارا يريد أن ينقض فأقامه﴾</span></span>: الفاء عاطفة، ووجدا فعل وفاعل، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجدا﴾</span></span>، وجدارًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جدارًا﴾</span></span>، وأن وما في حيزها مفعول يريد. <span class="hlt"><span class="qpc-hafs">﴿فأقامه﴾</span></span>: الفاء عاطفة، وأقامه فعل وفاعل مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال لو شئت لاتخذت عليه أجرا﴾</span></span>: لو حرف شرط غير جازم، وشئت فعل وفاعل، واللام واقعة في جواب لو، واتخذت فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لاتخذت﴾</span></span> لا محل لها من الإعراب، لأنها جواب لو، وعليه جار ومجرور متعلقان بمحذوف حال، وأجرًا مفعول به.</p></div>"
  18,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هذا فراق بيني وبينك﴾</span></span>: هذا مبتدأ، وفراق خبر، وبيني مضاف إليه، وبينك عطف على بيني.</p><p><span class="hlt"><span class="qpc-hafs">﴿سأنبئك بتأويل ما لم تستطع عليه صبرا﴾</span></span>: السين حرف استقبال، وأنبئك فعل وفاعل مستتر ومفعول به، وبتأويل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سأنبئك﴾</span></span>، وما اسم موصول مضاف إليه، ولم حرف نفي وقلب وجزم، وتستطع مضارع مجزوم بلم، وصبرًا مفعول به، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صبرًا﴾</span></span>.</p></div>"
  18,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أما السفينة فكانت لمساكين يعملون في البحر﴾</span></span>: أما حرف شرط وتفصيل، والسفينة مبتدأ، والفاء رابطة، وكانت: كان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هي، والتاء تاء التأنيث الساكنة، ولمساكين جار ومجرور متعلقان بمحذوف خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿فكانت لمساكين﴾</span></span> خبر السفينة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون في البحر﴾</span></span> صفة لمساكين، وفي البحر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأردت أن أعيبها وكان وراءهم ملك يأخذ كل سفينة غصبا﴾</span></span>: الفاء عاطفة، وأردت فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن أعيبها﴾</span></span> المصدر المؤول مفعول أردت، والواو للحال، وكان فعل ماض ناقص، ووراءهم ظرف متعلق بمحذوف خبر مقدم، وملك اسم كان المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأخذ﴾</span></span> صفة، وكل مفعول به، وسفينة مضاف إليه، وغصبًا نائب عن مفعول مطلق، أو مصدر في موضع نصب على الحال.</p></div>"
  18,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما الغلام فكان أبواه مؤمنين فخشينا أن يرهقهما طغيانا وكفرا﴾</span></span>: الواو عاطفة، وأما حرف شرط وتفصيل، والغلام مبتدأ، فكان: الفاء رابطة، وكان فعل ماض ناقص، وأبواه اسم كان مرفوع بالألف، لأنه مثنى، ومؤمنين خبر كان منصوب بالياء، لأنه مثنى. فخشينا: الفاء عاطفة، وخشينا فعل وفاعل، وأن وما في حيزها مفعول خشينا، وطغيانًا مفعول به ثان، وكفرًا عطف على طغيانًا، وجملة الجواب خبر الغلام.</p></div>"
  18,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأردنا أن يبدلهما ربهما خيرا منه زكاة وأقرب رحما﴾</span></span>: فأردنا عطف على خشينا، وأردنا فعل وفاعل، وأن يبدلهما: أن وما في حيزها مفعول أردنا، ويبدلهما فعل ومفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿ربهما﴾</span></span> فاعل مؤخر، والهاء ضمير مبني في محل جر مضاف إليه، وخيرًا منه مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span>، وزكاة تمييز، <span class="hlt"><span class="qpc-hafs">﴿وأقرب رحمًا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿خيرًا منه زكاة﴾</span></span>، ورحمًا تمييز أو مفعول له.</p></div>"
  18,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما الجدار فكان لغلامين يتيمين في المدينة﴾</span></span>: الواو عاطفة، وأما حرف شرط وتفصيل، والجدار مبتدأ، فكان: الفاء رابطة، وكان فعل ماض ناقص، واسم كان مستتر تقديره هو، ولغلامين جار ومجرور ر خبر كان، ويتيمين صفة لغلامين، و<span class="hlt"><span class="qpc-hafs">﴿في المدينة﴾</span></span> جار ومجرور متعلقان بمحذوف صفة ثانية أو حال، وجملة الجواب <span class="hlt"><span class="qpc-hafs">﴿فكان ...﴾</span></span> خبر الجدار.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان تحته كنز لهما وكان أبوهما صالحا﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص، وتحته ظرف متعلق بمحذوف خبر مقدم، وكنز اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لهما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة. <span class="hlt"><span class="qpc-hafs">﴿وكان أبوهما صالحا﴾</span></span>: كان فعل ماض ناقص، وأبو اسم كان مرفوع بالواو، لأنه من الأسماء الخمسة، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> ضمير مبني في محل جر مضاف إليه، وصالحا خبر كان منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأراد ربك أن يبلغا أشدهما ويستخرجا كنزهما رحمة من ربك﴾</span></span>: الفاء عاطفة، وأراد فعل ماض، وربك فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن يبلغا﴾</span></span> مفعول أراد، وأشدهما مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يبلغا﴾</span></span>، ويستخرجا عطف على يبلغا والألف فاعل، وكنزهما مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿رحمة من ربك﴾</span></span> مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما فعلته عن أمري ذلك تأويل ما لم تسطع عليه صبرا﴾</span></span>: الواو عاطفة، وما نافية، وفعلته فعل وفاعل ومفعول به، وعن أمري جار ومجرور متعلقان بمحذوف حال، أي: صادرًا عن أمري، وذلك مبتدأ، وتأويل خبر، وما مضاف إليه، ولم حرف نفي وقلب وجزم، وتسطع مضارع مجزوم بلم، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صبرًا﴾</span></span>، وصبرًا مفعول به.</p></div>"
  18,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسألونك عن ذي القرنين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ويسألونك فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن ذي القرنين﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسألونك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل سأتلو عليكم منه ذكرا﴾</span></span>: جملة سأتلو مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتلو﴾</span></span>، ومنه جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span> وتقدم عليه، وذكرًا مفعول به.</p></div>"
  18,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا مكنا له في الأرض وآتيناه من كل شيء سببا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿مكَّنا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكَّنا﴾</span></span>، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكَّنا﴾</span></span> أيضًا، وآتيناه عطف على مكَّنا وهو فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من كل شيء﴾</span></span> الجار والمجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سببًا﴾</span></span> وتقدم عليه، وسببًا مفعول به ثان لآتيناه.</p></div>"
  18,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتبع سببا﴾</span></span>: الفاء عاطفة، وأتبع فعل ماض، وفاعله مستتر تقديره هو، وسببًا مفعول به، وقيل: الفعل أتبع يتعدى لمفعولين حذف أحدهما، وتقديره: فأتبع سببًا سببًا آخر، أو فأتبع أمره سببًا.</p></div>"
  18,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا بلغ مغرب الشمس وجدها تغرب في عين حمئة﴾</span></span>: حتى حرف غاية وجر، وإذا ظرف ورد ههنا للزمن الماضي متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿بلغ﴾</span></span> في محل جر بإضافة الظرف إليها، ومغرب الشمس مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدها﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وفي عين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغرب﴾</span></span>، وحمئة صفة لعين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ووجد عندها قوما﴾</span></span>: الواو عاطفة، ووجد عطف على وجدها، وعندها ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span>، وقومًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قلنا يا ذا القرنين إما أن تعذب وإما أن تتخذ فيهم حسنا﴾</span></span>: قلنا فعل وفاعل، وذا القرنين منادى مضاف، وإما حرف شرط وتفصيل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن تعذب﴾</span></span> خبر لمبتدأ محذوف، أي: هو تعذيبك، أو مبتدأ وخبره محذوف، أي: إما تعذيبك واقع، أو مفعول به لفعل محذوف، أي: إما أن تفعل التعذيب. <span class="hlt"><span class="qpc-hafs">﴿وإما أن تتخذ﴾</span></span>: عطف على إما أن تعذب، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتخذ﴾</span></span> أو متعلقان بمحذوف مفعول به ثان لتتخذ، وحسنًا مفعول به أول.</p></div>"
  18,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أما من ظلم فسوف نعذبه﴾</span></span>: أما حرف شرط وتفصيل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿فسوف﴾</span></span>: الفاء رابطة، وسوف حرف استقبال، ونعذبه فعل مضارع وفاعل مستتر ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿سوف نعذبه﴾</span></span> خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم يرد إلى ربه فيعذبه عذابا نكرا﴾</span></span>: ثم حرف عطف وتراخ، ويرد فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، فيعذبه: الفاء عاطفة، ويعذبه فعل وفاعل ومفعول به، وعذابا نائب عن المفعول المطلق، لأنه اسم مصدر، ونكرًا صفة.</p></div>"
  18,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما من آمن وعمل صالحا فله جزاء الحسنى﴾</span></span>: الواو عاطفة، وأما حرف شرط وتفصيل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وعمل فعل ماض وفاعله مستتر تقديره هو، وصالحا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. <span class="hlt"><span class="qpc-hafs">﴿فله﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر مقدم، وجزاء تمييز، أو مصدر في موضع الحال، أي: مجازى، وقيل: انتصب على المصدر، أي: يُجزى جزاء، والحسنى مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسنقول له من أمرنا يسرا﴾</span></span>: الواو عاطفة، وسنقول فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span>، ومن أمرنا جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿يسرًا﴾</span></span> وتقدم عليه، ويسرًا مفعول به، أو نائب عن المفعول المطلق، أي: قولا ذا يسر.</p></div>"
  18,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أتبع سببا﴾</span></span>: ثم حرف عطف، وأتبع فعل ماض، وفاعله مستتر تقديره هو، وسببًا مفعول به، وقيل: الفعل أتبع يتعدى لمفعولين حذف أحدهما، وتقديره: فأتبع سببًا سببًا آخر، أو فأتبع أمره سببًا.</p></div>"
  18,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا بلغ مطلع الشمس وجدها تطلع على قوم لم نجعل لهم من دونها سترا﴾</span></span>: حتى حرف غاية وجر، وإذا ظرف ورد ههنا للزمن الماضي متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿بلغ﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدها﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿تطلع﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿وجدها﴾</span></span>، وعلى قوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطلع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم نجعل﴾</span></span> صفة لقوم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف في موضع نصب مفعول ثان لنجعل، و<span class="hlt"><span class="qpc-hafs">﴿من دونها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وسترًا مفعول نجعل الأول.</p></div>"
  18,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك وقد أحطنا بما لديه خبرا﴾</span></span>: كذلك جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: الأمر كذلك. وقد: الواو عاطفة أو حالية، وقد حرف تحقيق، وأحطنا فعل وفاعل، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحطنا﴾</span></span>، ولديه صلة الموصول لا محل لها من الإعراب، مفعول به.</p></div>"
  18,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أتبع سببا﴾</span></span>: ثم حرف عطف، وأتبع فعل ماض، وفاعله مستتر تقديره هو، وسببًا مفعول به، وقيل: الفعل أتبع يتعدى لمفعولين حذف أحدهما، وتقديره: فأتبع سببًا سببًا آخر، أو فأتبع أمره سببًا.</p></div>"
  18,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا بلغ بين السدين وجد من دونهما قوما لا يكادون يفقهون قولا﴾</span></span>: حتى: حرف غاية وجر، وإذا: ظرف ورد ههنا للزمن الماضي متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿بلغ﴾</span></span> في محل جر بإضافة الظرف إليها، وبين: مفعول به أو ظرف متعلق بنعت لمفعول محذوف، أي: مكانا كائنا بين السدين، والسدين مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومن دونهما مفعول وجد الثاني، وقومًا مفعول وجد الأول، ولا نافية، ويكادون فعل مضارع ناقص مرفوع بثبوت النون، والواو اسم يكاد، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفقهون﴾</span></span> خبر يكاد، وقولًا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يكادون﴾</span></span> صفة لقومًا.</p></div>"
  18,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا ذا القرنين إن يأجوج ومأجوج مفسدون في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، وذا القرنين منادى مضاف، وإن حرف ناسخ، ويأجوج اسم إن منصوب، ومأجوج عطف على يأجوج، ومفسدون خبر إن مرفوع بالواو، لأنه جمع مذكر سالم، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مفسدون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل نجعل لك خرجا على أن تجعل بيننا وبينهم سدا﴾</span></span>: الفاء عاطفة، وهل حرف استفهام، ونجعل فعل مضارع وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول نجعل الثاني، وخرجًا مفعول نجعل الأول، و<span class="hlt"><span class="qpc-hafs">﴿على أن تجعل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خرجًا﴾</span></span>، أي: قائمًا على هذا الشرط، و<span class="hlt"><span class="qpc-hafs">﴿بيننا﴾</span></span> ظرف متعلق بمحذوف مفعول تجعل الثاني، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> عطف على بيننا، وسدًّا مفعول تجعل الأول.</p></div>"
  18,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ما مكني فيه ربي خير﴾</span></span>: ما اسم موصول في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿مكني﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكني﴾</span></span>، وربي فاعل مكني، وخير خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأعينوني بقوة أجعل بينكم وبينهم ردما﴾</span></span>: الفاء الفصيحة، وأعينوني فعل أمر وفاعل ومفعول به، وبقوة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعينوني﴾</span></span>، وأجعل فعل مضارع مجزوم لأنه جواب الطلب، وبينكم ظرف متعلق بمفعول أجعل الثاني، وبينهم عطف عليه، وردمًا مفعول أجعل الأول.</p></div>"
  18,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿آتوني زبر الحديد حتى إذا ساوى بين الصدفين﴾</span></span>: آتوني فعل أمر وفاعل ومفعول به أول، وزبر مفعول به ثان، والحديد مضاف إليه، وحتى حرف غاية وجر، وإذا ظرف ورد ههنا للزمن الماضي متضمن للشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> بعده، وساوى فعل ماض، وفاعله مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿ساوى﴾</span></span> في محل جر بإضافة الظرف إليها، وبين الصدفين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ساوى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال انفخوا حتى إذا جعله نارا قال آتوني أفرغ عليه قطرا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب إذا، وجملة <span class="hlt"><span class="qpc-hafs">﴿انفخوا﴾</span></span> مقول القول، وحتى حرف غاية وجر، وإذا ظرف ورد ههنا للزمن الماضي متضمن للشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> بعده، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعله نارًا﴾</span></span> في محل جر بإضافة الظرف إليها، ونارًا مفعول جعل الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتوني﴾</span></span> مقول القول، وأفرغ مضارع مجزوم لأنه جواب الطلب وفاعله أنا، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفرغ﴾</span></span>، وقطرًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أفرغ﴾</span></span>، والتقدير: آتوني قطرًا أفرغ عليه قطرًا، فحذف الأول لدلالة الثاني عليه، والمسألة من باب التنازع، فقد أعمل الثاني، ولو أعمل الأول لقال آتوني أفرغه عليه قطرًا، إذ التقدير: آتوني قطرًا أفرغه عليه.</p></div>"
  18,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما اسطاعوا أن يظهروه وما استطاعوا له نقبا﴾</span></span>: الفاء عاطفة على محذوف، أي: فجاء قوم يأجوج بعد أن أنهى بناءه وتسويته يحاولون أن يعلوه أو يثقبوه فما اسطاعوا. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، واسطاعوا فعل وفاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما بعدها مفعول <span class="hlt"><span class="qpc-hafs">﴿اسطاعوا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿وما استطاعوا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فما اسطاعوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقبًا﴾</span></span>، ونقبًا مفعول به.</p></div>"
  18,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هذا رحمة من ربي﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مقول القول، وهذا مبتدأ، ورحمة خبر، والإشارة إلى السد، ومن ربي جار ومجرور متعلقان بمحذوف صفة لرحمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء وعد ربي جعله دكاء﴾</span></span>: الفاء استئنافية، وإذا ظرف مستقبل، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء وعد ربي﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعله﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ودكاء مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإذا جاء وعد...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان وعد ربي حقا﴾</span></span>: الواو عاطفة أو حالية، وكان فعل ماض ناقص، ووعد اسم كان مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿حقًّا﴾</span></span> خبر كان منصوب.</p></div>"
  18,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا بعضهم يومئذ يموج في بعض﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وتركنا فعل وفاعل، وبعضهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ جاء وعد ربي، وجملة <span class="hlt"><span class="qpc-hafs">﴿يموج في بعض﴾</span></span> في محل نصب مفعول به ثان لتركنا، والتنوين في <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> عوض عن جملة. وقيل أن <span class="hlt"><span class="qpc-hafs">﴿ترك﴾</span></span> متعديًا إلى مفعول واحد، فتكون جملة <span class="hlt"><span class="qpc-hafs">﴿يموج﴾</span></span> في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونفخ في الصور فجمعناهم جمعا﴾</span></span>: الواو عاطفة، ونفخ فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، وفي الصور جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، فجمعناهم: الفاء عاطفة، وجمعناهم فعل وفاعل ومفعول به، وجمعًا مفعول مطلق.</p></div>"
  18,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعرضنا جهنم يومئذ للكافرين عرضا﴾</span></span>: الواو عاطفة، وعرضنا فعل وفاعل، وجهنم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عرضنا﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ جمعنا الخلائق، وللكافرين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عرضنا﴾</span></span> أيضًا، وعرضًا مفعول مطلق.</p></div>"
  18,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين كانت أعينهم في غطاء عن ذكري وكانوا لا يستطيعون سمعا﴾</span></span>: الذين صفة للكافرين أو بدل منهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> صلة الموصول لا محل لها من الإعراب، وأعينهم اسم كانت، وفي غطاء جار ومجرور متعلقان بمحذوف خبر كانت، وعن ذكري جار ومجرور متعلقان بمحذوف صفة لغطاء، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسم كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يستطيعون سمعًا﴾</span></span> خبر كان.</p></div>"
  18,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفحسب الذين كفروا أن يتخذوا عبادي من دوني أولياء﴾</span></span>: الهمزة للاستفهام، والذين فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الذين لا محل لها من الإعراب، وأن وما في حيزها سدت مسد مفعولي حسب، ويتخذوا فعل وفاعل، وعبادي مفعول به أول منصوب بفتحة مقدرة على ما قبل ياء المتكلم، وياء المتكلم في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من دوني﴾</span></span> جار ومجرور في محل نصب حال من أولياء، وأولياء مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا أعتدنا جهنم للكافرين نزلا﴾</span></span>: إنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعتدنا﴾</span></span> خبر إن، وجهنم مفعول به، وللكافرين جار ومجرور متعلقان بحال من نزلًا، ونزلًا مفعول به ثان أو حال.</p></div>"
  18,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل هل ننبئكم بالأخسرين أعمالا﴾</span></span>: قل فعل أمر مبني على السكون، والفاعل مستتر تقديره أنت، وهل استفهام، وننبئكم مضارع مرفوع بالضمة، والفاعل مستتر تقديره نحن، والكاف مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿هل ننبئكم﴾</span></span> مقول القول، وبالأخسرين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننبئكم﴾</span></span>، وأعمالًا تمييز، وجمع التمييز وهو أصيل في الإفراد لمشاكلة المميز، أو لأن أعمالهم في الضلال مختلفة وليسوا مشتركين في عمل واحد.</p></div>"
  18,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين ضل سعيهم في الحياة الدنيا وهم يحسبون أنهم يحسنون صنعا﴾</span></span>: الذين اسم موصول صفة للأخسرين، أو بدل، أو خبر لمبتدأ محذوف، كأنه جواب لسؤال سائل: ومن هم الأخسرون أعمالا؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span> صلة الموصول لا محل لها من الإعراب، وسعيهم فاعل، وفي الحياة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>، والدنيا صفة، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحسبون﴾</span></span> خبر، وأن وما في حيزها سدت مسد مفعولي يحسبون، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحسنون﴾</span></span> خبر أن، وصنعًا مفعول به أو تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهم يحسبون﴾</span></span> حال من الضمير في سعيهم.</p></div>"
  18,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك الذين كفروا بآيات ربهم ولقائه فحبطت أعمالهم﴾</span></span>: أولئك اسم إشارة مبتدأ، والذين خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بآيات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span> مضاف إليه، ولقائه عطف على آيات، <span class="hlt"><span class="qpc-hafs">﴿فحبطت﴾</span></span> عطف على كفروا، وأعمالهم فاعل حبطت.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا نقيم لهم يوم القيامة وزنا﴾</span></span>: الفاء عاطفة، ولا نافية، ونقيم فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقيم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نقيم﴾</span></span> أيضًا، والقيامة مضاف إليه، ووزنًا مفعول به.</p></div>"
  18,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك جزاؤهم جهنم بما كفروا﴾</span></span>:</p><p>ذلك: اسم إشارة مبتدأ، وجزاؤهم: خبر، وجهنم: بدل أو عطف بيان لقوله: <span class="hlt"><span class="qpc-hafs">﴿جزاؤهم﴾</span></span>.</p><p>أو ذلك: خبر لمبتدأ محذوف، أي: الأمر ذلك، و<span class="hlt"><span class="qpc-hafs">﴿جزاؤهم جهنم﴾</span></span>: مبتدأ وخبر.</p><p>أو ذلك: مبتدأ، وجزاؤهم: مبتدأ ثان، وجهنم: خبر جزاؤهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿جزاؤهم جهنم﴾</span></span> خبر المبتدأ الأول <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p><p>أو ذلك: مبتدأ، وجزاؤهم: بدل أو عطف بيان، وجهنم: خبر.</p><p>و<span class="hlt"><span class="qpc-hafs">﴿بما كفروا﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية وصلتها مجرور بالباء، أي: بكفرهم، والباء ومجرورها متعلقان بمحذوف حال من جزاؤهم، أي: ثابتا بما كفروا، أو متعلقان بمصدر تقديره: جزاء.</p><p>و يجوز أن يكون <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جزاؤهم جهنم﴾</span></span> جملة اعتراضية لا محل لها من الإعراب فيكون الجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿بما كفروا﴾</span></span> متعلقين بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>. أو يكون ذلك: مبتدأ، وجزاؤهم: بدلا أو عطف بيان، وجهنم: خبر مبتدأ مقدر أي: هو جهنم. فيكون الجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿بما كفروا﴾</span></span> متعلقين بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتخذوا آياتي ورسلي هزوا﴾</span></span>: الواو عاطفة، واتخذوا: عطف على كفروا، وآياتي: مفعول به أول، ورسلي: عطف على آياتي، وهزوًا: مفعول به ثان.</p></div>"
  18,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات كانت لهم جنات الفردوس نزلا﴾</span></span>: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على الصلة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت لهم جنات﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿نزلًا﴾</span></span>، لأنه كان صفة له وتقدم عليه، و<span class="hlt"><span class="qpc-hafs">﴿جنات الفردوس﴾</span></span> اسم كانت، والفردوس مضاف إليه، ونزلًا خبر كانت. و يجوز أن يكون الجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> خبر كانت و<span class="hlt"><span class="qpc-hafs">﴿نزلًا﴾</span></span> حالا من <span class="hlt"><span class="qpc-hafs">﴿جنات الفردوس﴾</span></span>.</p></div>"
  18,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خالدين فيها لا يبغون عنها حولا﴾</span></span>: خالدين حال من الضمير في لهم، وفيها جار ومجرور متعلقان بخالدين، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يبغون﴾</span></span> حالية، وعنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حولًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حولًا﴾</span></span> مفعول يبغون.</p></div>"
  18,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لو كان البحر مدادا لكلمات ربي لنفد البحر قبل أن تنفد كلمات ربي ولو جئنا بمثله مددا﴾</span></span>: لو شرطية، وكان البحر مدادا: كان فعل ماض ناقص، والبحر اسم كان مرفوع، ومدادًا خبر كان منصوب، و<span class="hlt"><span class="qpc-hafs">﴿لكلمات﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مدادًا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿لنفد﴾</span></span>: اللام واقعة في جواب لو، وجملة <span class="hlt"><span class="qpc-hafs">﴿نفد البحر﴾</span></span> جواب شرط غير جازم لا محل لها من الإعراب، وقبل ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نفد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن تنفد﴾</span></span> المصدر مجرور بإضافة الظرف إليه، وكلمات فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مضاف إليه، والواو عاطفة، ولو شرطية، وجئنا فعل الشرط، وجواب لو محذوف تقديره: لنفد ولم تفرغ، وبمثله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئنا﴾</span></span>، ومددًا تمييز.</p></div>"
  18,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إنما أنا بشر مثلكم﴾</span></span>: إنما كافة ومكفوفة، وأنا مبتدأ، وبشر خبر، ومثلكم صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوحى إلي أنما إلهكم إله واحد﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span> صفة لبشر، وإليَّ جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span>، وأنما كافة ومكفوفة، ولكنها لم تخرج عن المصدرية فهي وما بعدها في محل رفع نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلهكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> خبر، وواحد صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن كان يرجو لقاء ربه فليعمل عملا صالحا ولا يشرك بعبادة ربه أحدا﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، يعود على من، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرجو﴾</span></span> خبرها، ولقاء ربه مفعول به. <span class="hlt"><span class="qpc-hafs">﴿فليعمل﴾</span></span>: الفاء رابطة لجواب الشرط، واللام لام الأمر، ويعمل فعل مضارع مجزوم بلام الأمر، وعملًا مفعول مطلق أو مفعول به، وصالحًا صفة. وجملة <span class="hlt"><span class="qpc-hafs">﴿فمن كان يرجو...﴾</span></span> مستأنفة لا محل لها من الإعراب، ولا يشرك: لا ناهية، ويشرك فعل مضارع مجزوم بلا الناهية، وبعبادة ربه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشرك﴾</span></span>، وأحدًا مفعول يشرك.</p></div>"
