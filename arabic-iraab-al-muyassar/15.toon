quran[99]{c,v,t}:
  15,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الر﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب وقرآن مبين﴾</span></span>: تلك مبتدأ، وآيات الكتاب خبر، وقرآن عطف على الكتاب، ومبين صفة للقرآن.</p></div>"
  15,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربما يود الذين كفروا لو كانوا مسلمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ربما﴾</span></span> كافة ومكفوفة، ويود الذين فعل مضارع وفاعل، وجملة كفروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> مصدرية لوقوعها بعد <span class="hlt"><span class="qpc-hafs">﴿يود﴾</span></span>، وهي مع مدخولها في تأويل مصدر هو المفعول للودادة، والمعنى: يودون كونهم مسلمين، وقيل: <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> امتناعية، وجوابها محذوف تقديره: لو كانوا مسلمين لسروا بذلك إذ تخلصوا مما هم فيه، ومفعول يود على هذا التقدير، أي: ربما يود الذين كفروا النجاة.</p></div>"
  15,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذرهم يأكلوا ويتمتعوا ويلههم الأمل﴾</span></span>: ذرهم فعل أمر، وفاعل مستتر، ومفعول به، ويأكلوا جواب مجزوم على أنه جواب الأمر، ويتمتعوا عطف على يأكلوا، ويلههم الأمل عطف أيضا، والأمل فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسوف يعلمون﴾</span></span>: الفاء الفصيحة، وسوف حرف استقبال، ويعلمون فعل وفاعل، والمفعول محذوف، أي: عاقبة أمرهم وسوء صنيعهم.</p></div>"
  15,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أهلكنا من قرية إلا ولها كتاب معلوم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، وأهلكنا فعل وفاعل، ومن حرف جر صلة، وقرية مجرور لفظًا ومنصوب محلا على المفعولية، وإلا أداة حصر، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وكتاب مبتدأ مؤخر، ومعلوم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>، والجملة حالية، وقيل: الواو صلة، وقيل: جملة <span class="hlt"><span class="qpc-hafs">﴿لها كتاب معلوم﴾</span></span> صفة لقرية.</p></div>"
  15,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما تسبق من أمة أجلها وما يستأخرون﴾</span></span>: ما نافية، وتسبق فعل مضارع، ومن حرف جر صلة، وأمة فاعل تسبق محلا مجرورة لفظًا، وأجلها مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وما يستأخرون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما تسبق﴾</span></span>.</p></div>"
  15,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا يا أيها الذي نزل عليه الذكر إنك لمجنون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وقالوا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا أيها الذي نزل...﴾</span></span> مقول القول، ويا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والذي صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span> صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، والذكر نائب فاعل، وإن حرف ناسخ، والكاف اسمها، واللام المزحلقة، ومجنون خبر إن.</p></div>"
  15,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لوما تأتينا بالملائكة إن كنت من الصادقين﴾</span></span>: لوما حرف تحضيض كـ: هلا، وتأتينا فعل مضارع، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالملائكة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأتينا﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وجواب إن محذوف تقديره: ائتنا بالملائكة.</p></div>"
  15,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما ننزل الملائكة إلا بالحق﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، وننزل فعل مضارع فاعله مستتر، تقديره: نحن، والملائكة مفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا بالحق، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننزل﴾</span></span>، أو نعت لمصدر محذوف، أي: إلا تنزلًا متلبسًا بالحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كانوا إذا منظرين﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جواب وجزاء مهمل، ومنظرين خبر كان.</p></div>"
  15,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا نحن نزلنا الذكر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ونحن تأكيد لاسم إن، أو ضمير فصل لا محل له من الإعراب، وجملة نزلنا خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا له لحافظون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإنا﴾</span></span> عطف، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حافظون﴾</span></span>، واللام المزحلقة، وحافظون خبر إن. أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير في محل رفع مبتدأ، وجملة نزلنا خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحن نزلنا﴾</span></span> خبر إن.</p></div>"
  15,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا من قبلك في شيع الأولين﴾</span></span>: الواو عاطفة، واللام في جواب قسم مقدر، وأرسلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: رسلًا من قبلك، و<span class="hlt"><span class="qpc-hafs">﴿في شيع الأولين﴾</span></span> جار ومجرور متعلقان بمحذوف نعت آخر للمفعول المحذوف.</p></div>"
  15,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يأتيهم من رسول إلا كانوا به يستهزئون﴾</span></span>: الواو عاطفة، وما نافية، ويأتيهم فعل ومفعول به، ومن حرف جر صلة، ورسول مجرور لفظًا مرفوع محلا على الفاعلية، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span> خبر كانوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا به يستهزئون﴾</span></span> حال، أو صفة لرسول.</p></div>"
  15,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نسلكه في قلوب المجرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: سَلكًا مثل ذلك السَّلك الذي سلكناه في قلوب المستهزئين نسلكه في قلوب المجرمين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نسلكه﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في قلوب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسلكه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المجرمين﴾</span></span> مضاف إليه.</p></div>"
  15,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون به﴾</span></span>: الجملة في محل نصب على الحال، أو تفسيرية لقوله: <span class="hlt"><span class="qpc-hafs">﴿نسلكه﴾</span></span> فلا محل لها من الإعراب. ويؤمنون: فعل مضارع، والواو فاعل. و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد خلت سنة الأولين﴾</span></span>: الواو حالية، وقد حرف تحقيق، وخلت سنة الأولين فعل وفاعل، والجملة حالية، وقيل: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب.</p></div>"
  15,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو فتحنا عليهم بابا من السماء فظلوا فيه يعرجون﴾</span></span>: الواو عاطفة، ولو امتناعية شرطية، وفتحنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فتحنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بابًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بابًا﴾</span></span>، والفاء عاطفة، وظل فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعرجون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعرجون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ظل﴾</span></span>.</p></div>"
  15,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقالوا إنما سكرت أبصارنا بل نحن قوم مسحورون﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، وسكرت أبصارنا فعل وفاعل، والجملة لا محل لها من الإعراب، لأنها جواب لو، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنما سكرت أبصارنا﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحن قوم مسحورون﴾</span></span> تابعة لجملة <span class="hlt"><span class="qpc-hafs">﴿سكرت أبصارنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف إضراب، ونحن مبتدأ، وقوم خبر، ومسحورون صفة.</p></div>"
  15,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جعلنا في السماء بروجا وزيناها للناظرين﴾</span></span>: الواو عاطفة، واللام جواب القسم المحذوف، وقد حرف تحقيق، وجعلنا فعل وفاعل، وقيل: جعلنا بمعنى خلقنا، وقوله: <span class="hlt"><span class="qpc-hafs">﴿في السماء﴾</span></span> جار ومجرور متعلق به، وقيل: بمعنى صيرنا، ومفعوله الأول <span class="hlt"><span class="qpc-hafs">﴿بروجًا﴾</span></span>، والجار والمجرور متعلقان بمحذوف هو المفعول الثاني، وزيناها فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للناظرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زيناها﴾</span></span>.</p></div>"
  15,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحفظناها من كل شيطان رجيم﴾</span></span>: الواو عاطفة، وحفظناها فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من كل شيطان رجيم﴾</span></span> جار ومجرور متعلقان بحفظناها، ورجيم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شيطان﴾</span></span>.</p></div>"
  15,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من استرق السمع فأتبعه شهاب مبين﴾</span></span>: إلا أداة استثناء، ومن اسم موصول في موضع نصب على الاستثناء المتصل، أو الاستثناء منقطع، والمراد: المنع من دخولها والتصرف فيها، والفاء عاطفة، وأتبعه فعل ماض ومفعول به، وشهاب فاعل، ومبين صفة.</p></div>"
  15,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض مددناها وألقينا فيها رواسي﴾</span></span>: الواو عاطفة، والأرض نصب على الاشتغال، أي: مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده، ومددناها فعل وفاعل ومفعول به، وألقينا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقينا﴾</span></span>، ورواسي مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنبتنا فيها من كل شيء موزون﴾</span></span>: الواو عاطفة، وأنبتنا عطف على ما قبله، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من كل شيء﴾</span></span> صفة للمفعول به المحذوف، أي: نباتًا من كل شيء، وموزون صفة.</p></div>"
  15,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا لكم فيها معايش ومن لستم له برازقين﴾</span></span>: الواو عاطفة، وجعلنا عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، أو متعلقان بمحذوف مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومعايش مفعول جعلنا، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> الموصول عطف على معايش، أو على محل لكم، وقيل: منصوب بفعل محذوف مقدر تقديره: وأغنينا من لستم له برازقين، وقيل: الواو ابتدائية، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ خبره محذوف تقديره: ومن لستم له برازقين جعلنا له فيها معايش.</p></div>"
  15,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن من شيء إلا عندنا خزائنه﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span> مِن صلة في المبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿عندنا﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، وخزائنه مبتدأ مؤخر، والجملة خبر شيء.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما ننزله إلا بقدر معلوم﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿ننزله﴾</span></span> فعل مضارع وفاعل مستتر ومفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بقدر﴾</span></span> جار ومجرور متعلقان بمحذوف حال من المفعول، أي: متلبسًا بقدر، أو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ننزله﴾</span></span>، ومعلوم صفة لقدر.</p></div>"
  15,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأرسلنا الرياح لواقح﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأرسلنا الرياح فعل وفاعل ومفعول به، ولواقح حال مقدرة من الرياح.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنزلنا من السماء ماء فأسقيناكموه﴾</span></span>: الفاء عاطفة، وأنزلنا عطف على أرسلنا، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، وماء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فأسقيناكموه﴾</span></span> الفاء عاطفة، وأسقى فعل ماض، ونا فاعل، والكاف مفعول به أول، والميم علامة جمع الذكور، والواو لإشباع ضمة الميم، والهاء مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنتم له بخازنين﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خازنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بخازنين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿خازنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  15,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لنحن نحيي ونميت﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ونحن مبتدأ، وجملة نحيي خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحن نحيي﴾</span></span> خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحيي﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونحن الوارثون﴾</span></span>: نحن مبتدأ، والوارثون خبر.</p></div>"
  15,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وعلمنا فعل وفاعل، والمستقدمين مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿ولقد علمنا المستأخرين﴾</span></span> عطف.</p></div>"
  15,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك هو يحشرهم﴾</span></span>: إن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة يحشرهم خبر، والجملة الاسمية خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه حكيم عليم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وحكيم خبر أول، وعليم خبر ثان.</p></div>"
  15,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا الإنسان من صلصال من حمأ مسنون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وخلقنا الإنسان فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من صلصال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من حمأ﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لصلصال، أو بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿من صلصال﴾</span></span> بإعادة الجار، ومسنون صفة لحمأ.</p></div>"
  15,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والجان خلقناه من قبل من نار السموم﴾</span></span>: الواو عاطفة، والجان نصب على الاشتغال، وخلقناه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من نار السموم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span>.</p></div>"
  15,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قال ربك للملائكة﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال ربك﴾</span></span> في محل جر مضاف إليه، أي: اذكر وقت قول ربك، و<span class="hlt"><span class="qpc-hafs">﴿للملائكة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني خالق بشرا من صلصال من حمأ مسنون﴾</span></span>: إن حرف ناسخ، والياء اسمها، وخالق خبرها، وبشرًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿خالق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من صلصال﴾</span></span> جار ومجرور متعلقان بخلقنا، و<span class="hlt"><span class="qpc-hafs">﴿من حمأ﴾</span></span> صفة لصلصال، أو بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿من صلصال﴾</span></span> بإعادة الجار، ومسنون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حمأ﴾</span></span>.</p></div>"
  15,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا سويته ونفخت فيه من روحي فقعوا له ساجدين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿سويته﴾</span></span> في محل جر بإضافة الظرف إليها، ونفخت عطف على سويته، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من روحي﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول محذوف، أي: روحًا من روحي، <span class="hlt"><span class="qpc-hafs">﴿فقعوا﴾</span></span> الفاء رابطة لجواب إذا، و<span class="hlt"><span class="qpc-hafs">﴿قعوا﴾</span></span> فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ساجدين﴾</span></span>، وساجدين حال.</p></div>"
  15,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسجد الملائكة كلهم أجمعون﴾</span></span>: الفاء عاطفة على محذوف، أي: فخلقه وسواه ونفخ فيه من روحه فسجد الملائكة، و<span class="hlt"><span class="qpc-hafs">﴿كلهم﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿أجمعون﴾</span></span> تأكيد.</p></div>"
  15,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا إبليس أبى أن يكون مع الساجدين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أبى﴾</span></span> فعل ماض، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يكون﴾</span></span> منصوب على المفعولية لـ<span class="hlt"><span class="qpc-hafs">﴿أبى﴾</span></span>، واسم <span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span> مستتر، تقديره: هو، أي: إبليس، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span>، والساجدين مضاف إليه.</p></div>"
  15,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا إبليس ما لك ألا تكون مع الساجدين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض مبني على الفتح، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، يا حرف نداء، وإبليس منادى مفرد علم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام للتوبيخ مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿ألا تكون مع الساجدين﴾</span></span> أن مصدرية ناصبة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> مضارع ناقص منصوب، وفاعله مستتر وجوبا تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿مع الساجدين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون، وأن وما في حيزها نصب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  15,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لم أكن لأسجد لبشر خلقته من صلصال من حمأ مسنون﴾</span></span>: لم حرف نفي وقلب وجزم، وأكن مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، واسمها مستتر تقديره: أنا، واللام لام الجحود، وأسجد فعل مضارع منصوب بأن مضمرة وجوبًا بعدها، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف خبر أكن، و<span class="hlt"><span class="qpc-hafs">﴿لبشر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسجد﴾</span></span>، وجملة خلقته صفة لبشر، و<span class="hlt"><span class="qpc-hafs">﴿من صلصال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من حمأ﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لصلصال، أو بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿من صلصال﴾</span></span> بإعادة الجار، ومسنون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حمأ﴾</span></span>.</p></div>"
  15,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فاخرج منها﴾</span></span>: الفاء الفصيحة، لأنها جواب شرط مقدر، أي: إن تماديت وعصيت فاخرج، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخرج﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنك رجيم﴾</span></span>: الفاء تعليلية، وإن حرف ناسخ، والكاف اسمها، ورجيم خبرها، والجملة لا محل لها من الإعراب.</p></div>"
  15,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن عليك اللعنة إلى يوم الدين﴾</span></span>: الواو عاطفة، وإن حرف ناسخ للتوكيد، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللعنة اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم الدين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مستقرة إلى تلك الغاية.</p></div>"
  15,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب فأنظرني إلى يوم يبعثون﴾</span></span>: رب منادى محذوف منه حرف النداء مضاف إلى ياء المتكلم، الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنظرني﴾</span></span>، ويبعثون مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة يبعثون مضاف إليها.</p></div>"
  15,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فإنك من المنظرين﴾</span></span>: الفاء عاطفة، وإن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المنظرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  15,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى يوم الوقت المعلوم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿المنظرين﴾</span></span>، والوقت مضاف إليه، والمعلوم صفة.</p></div>"
  15,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب بما أغويتني لأزينن لهم في الأرض ولأغوينهم أجمعين﴾</span></span>: رب منادى محذوف منه حرف النداء، وهو مضاف إلى ياء المتكلم، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء للقسم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: أقسم بإغوائك إياي، وجملة <span class="hlt"><span class="qpc-hafs">﴿لأزينن﴾</span></span> جواب القسم، وقيل: الباء للسببية، <span class="hlt"><span class="qpc-hafs">﴿لأزينن﴾</span></span> اللام واقعة في جواب قسم مقدر، وأزينن فعل مضارع مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أزينن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿لأغوينهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لأزينن﴾</span></span>، وأجمعين تأكيد للضمير.</p></div>"
  15,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عبادك منهم المخلصين﴾</span></span>: إلا أداة استثناء، وعبادك مستثنى، والمخلصين صفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  15,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هذا صراط علي مستقيم﴾</span></span>: هذا مبتدأ، وصراط خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليّ﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، أي: حق، ومستقيم صفة ثانية.</p></div>"
  15,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن عبادي ليس لك عليهم سلطان﴾</span></span>: إن حرف ناسخ، وعبادي اسمها، وجملة ليس خبر، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر ليس المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وسلطان اسم ليس المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من اتبعك من الغاوين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول في محل نصب على الاستثناء، وجملة اتبعك صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من الغاوين﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿اتبعك﴾</span></span>.</p></div>"
  15,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن جهنم لموعدهم أجمعين﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، وجهنم اسمها، واللام المزحلقة، وموعدهم خبر إن، وأجمعين تأكيد للضمير.</p></div>"
  15,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لها سبعة أبواب لكل باب منهم جزء مقسوم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وسبعة أبواب مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لكل باب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجزء مبتدأ مؤخر، ومقسوم نعت لجزء.</p></div>"
  15,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في جنات وعيون﴾</span></span>: إن حرف ناسخ، والمتقين اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في جنات﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وعيون عطف على جنات.</p></div>"
  15,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادخلوها بسلام آمنين﴾</span></span>: الجملة مقول القول محذوف، أي: يقال لهم، و<span class="hlt"><span class="qpc-hafs">﴿ادخلوها﴾</span></span> فعل أمر وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بسلام﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿ادخلوها﴾</span></span> أي: سالمين من كل أذى، أو مسلمًا عليكم، وآمنين حال ثانية من الواو في <span class="hlt"><span class="qpc-hafs">﴿ادخلوها﴾</span></span>.</p></div>"
  15,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونزعنا ما في صدورهم من غل إخوانا على سرر متقابلين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ونزعنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في صدورهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من غل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وإخوانًا حال ثانية من <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على سرر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span>، ومتقابلين حال ثالثة من الضمير في <span class="hlt"><span class="qpc-hafs">﴿صدورهم﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إخوانًا﴾</span></span>.</p></div>"
  15,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يمسهم فيها نصب﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span> في الآية السابقة، ولا نافية، ويمسهم فعل مضارع ومفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿نصب﴾</span></span> فاعل مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما هم منها بمخرجين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مخرجين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بمخرجين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مخرجين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  15,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نبئ عبادي أني أنا الغفور الرحيم﴾</span></span>: نبئ فعل أمر، والفاعل مستتر، وعبادي مفعول به، وأن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> ضمير فصل، والغفور خبر أن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، والغفور خبر <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>، والرحيم خبر ثان، والجملة خبر أن، وأن وما في حيزها سدت مسد مفاعيل <span class="hlt"><span class="qpc-hafs">﴿نبئ﴾</span></span>.</p></div>"
  15,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن عذابي هو العذاب الأليم﴾</span></span>: عطف على سابقتها، وأن حرف ناسخ، وعذابي اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعذاب خبر أن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعذاب خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر أن، والأليم صفة للعذاب.</p></div>"
  15,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونبئهم عن ضيف إبراهيم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿نبئ عبادي﴾</span></span>، ونبئهم فعل أمر، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن ضيف إبراهيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبئهم﴾</span></span>.</p></div>"
  15,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ دخلوا عليه فقالوا سلاما قال إنا منكم وجلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف معطوف على <span class="hlt"><span class="qpc-hafs">﴿نبِّئهم﴾</span></span> والتقدير: واذكر إذ دخلوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بدخلوا، <span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span> عطف على دخلوا، و<span class="hlt"><span class="qpc-hafs">﴿سلامًا﴾</span></span> مفعول به، أو مفعول مطلق لفعل محذوف والتقدير: نسلم سلاما، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا...﴾</span></span> إلخ مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿وجلون﴾</span></span> خبر إن.</p></div>"
  15,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لا توجل إنا نبشرك بغلام عليم﴾</span></span>: لا ناهية، وتوجل مضارع مجزوم بلا الناهية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نبشرك خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بغلام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبشرك﴾</span></span>، وعليم صفة، والجملة تعليلية لعدم الوجل.</p></div>"
  15,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أبشرتموني على أن مسني الكبر فبم تبشرون﴾</span></span>: الهمزة للاستفهام التعجبي، وبشرتموني فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span> حرف جر، وإن وما في حيزها في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بمحذوف حال، أي: حالة كونه قد مسني، والكبر فاعل مسني، <span class="hlt"><span class="qpc-hafs">﴿فبم﴾</span></span> الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبشرون﴾</span></span>.</p></div>"
  15,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بشرناك بالحق فلا تكن من القانطين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بشرناك﴾</span></span> فعل ماض وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿بشرناك﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرناك﴾</span></span>، والفاء حرف عطف، ولا ناهية، وتكن مضارع مجزوم بلا الناهية، واسم تكن مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿من القانطين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  15,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ومن يقنط من رحمة ربه إلا الضالون﴾</span></span>: الواو عاطفة، ومن اسم استفهام معناه النفي في محل رفع مبتدأ، وجملة يقنط خبره، و<span class="hlt"><span class="qpc-hafs">﴿من رحمة ربه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقنط﴾</span></span>، وإلا أداة حصر، والضالون بدل من الضمير المستتر في يقنط، بدل بعض من كل.</p></div>"
  15,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فما خطبكم أيها المرسلون﴾</span></span>: الفاء عاطفة، وما اسم استفهام مبتدأ، وخطبكم خبر، أي: ما شأنكم، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة، وحرف النداء محذوف، وها للتنبيه، والمرسلون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿أيها﴾</span></span>.</p></div>"
  15,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا أرسلنا إلى قوم مجرمين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل أرسل، و<span class="hlt"><span class="qpc-hafs">﴿إلى قوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مجرمين﴾</span></span> صفة.</p></div>"
  15,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا آل لوط إنا لمنجوهم أجمعين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿آل لوط﴾</span></span> مستثنى من الضمير المستكن في <span class="hlt"><span class="qpc-hafs">﴿مجرمين﴾</span></span> في الآية السابقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا لمنجوهم﴾</span></span> استئنافية لا محل لها من الإعراب، أو مستثنى منقطع منصوب.</p></div>"
  15,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا امرأته قدرنا إنها لمن الغابرين﴾</span></span>: إلا امرأته مستثنى من آل لوط، أو مستثنى من ضمير المفعول في منجوهم، و<span class="hlt"><span class="qpc-hafs">﴿قدرنا﴾</span></span> فعل وفاعل، وقد ضمن معنى العلم، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من الغابرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  15,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء آل لوط المرسلون﴾</span></span>: الفاء عاطفة على محذوف، أي: فخرجوا من عنده وسافروا من قريته إلى قرية قوم لوط، ولما حينية، أو رابطة، وجاء فعل ماض، وآل لوط مفعول به مقدم، والمرسلون فاعل مؤخر.</p></div>"
  15,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إنكم قوم منكرون﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وإن حرف ناسخ، والكاف اسمها، وقوم خبرها، ومنكرون صفة لقوم.</p></div>"
  15,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بل جئناك بما كانوا فيه يمترون﴾</span></span>: بل حرف إضراب وعطف، وجئناك فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئناك﴾</span></span>، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمترون﴾</span></span>، وجملة يمترون خبر كانوا.</p></div>"
  15,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأتيناك بالحق وإنا لصادقون﴾</span></span>: الواو عاطفة، وأتيناك فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسين، أو متلبسًا أنت لإبصارك له، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتيناك﴾</span></span>، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وصادقون خبر إن.</p></div>"
  15,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأسر بأهلك بقطع من الليل﴾</span></span>: الفاء الفصيحة، وأسر فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿بأهلك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بقطع﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الليل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لقطع.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتبع أدبارهم ولا يلتفت منكم أحد وامضوا حيث تؤمرون﴾</span></span>: الواو عاطفة، واتبع عطف على <span class="hlt"><span class="qpc-hafs">﴿فأسر﴾</span></span>، وأدبارهم مفعول به، والواو حرف عطف، ولا ناهية، ويلتفت مجزوم بلا، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأحد فاعل، وامضوا عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿حيث﴾</span></span> ظرف مبهم في محل نصب مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿امضوا﴾</span></span>، وجملة تؤمرون مضاف إليها الظرف.</p></div>"
  15,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقضينا إليه ذلك الأمر أن دابر هؤلاء مقطوع مصبحين﴾</span></span>: الواو عاطفة، وقضينا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضينا﴾</span></span>، لأنها تضمنت معنى أوحينا، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مفعول قضينا، والأمر بدل من اسم الإشارة، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، ودابر اسمها، ومقطوع خبرها، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها بدل من <span class="hlt"><span class="qpc-hafs">﴿ذلك الأمر﴾</span></span>، أو خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿مصبحين﴾</span></span> حال من الضمير المستقر في <span class="hlt"><span class="qpc-hafs">﴿مقطوع﴾</span></span>.</p></div>"
  15,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء أهل المدينة يستبشرون﴾</span></span>: الواو عاطفة، وجاء أهل المدينة فعل وفاعل، وجملة يستبشرون حال.</p></div>"
  15,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن هؤلاء ضيفي فلا تفضحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل ضمير مستتر، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، وهؤلاء اسمها، وضيفي خبرها، والفاء الفصيحة، ولا ناهية، وتفضحون مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  15,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتقوا الله ولا تخزون﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿اتقوا الله﴾</span></span>: فعل وفاعل ومفعول به، ولا ناهية، وتخزون مجزوم بلا، والواو فاعل، والنون نون الوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  15,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أولم ننهك عن العالمين﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على محذوف، ولم حرف نفي وقلب وجزم، وننهك فعل مضارع مجزوم بلم، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننهك﴾</span></span>.</p></div>"
  15,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هؤلاء بناتي إن كنتم فاعلين﴾</span></span>: هؤلاء بناتي مبتدأ وخبر، ولا بد من تقدير محذوف، أي: فانكحوهن، أو <span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span> مفعول به بفعل مقدر، أي: انكحوا هؤلاء، وبناتي بدل، وإن شرطية، <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وهي في محل جزم فعل الشرط، وفاعلين خبر كنتم، وجواب إن محذوف دل عليه ما قبله، أي: فانكحوهن.</p></div>"
  15,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعمرك إنهم لفي سكرتهم يعمهون﴾</span></span>: اللام للابتداء، عمرك مبتدأ محذوف الخبر وجوبًا، تقديره: قسمي، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم...﴾</span></span> جواب القسم لا محل لها من الإعراب، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في سكرتهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعمهون﴾</span></span> في محل نصب حال من الضمير <span class="hlt"><span class="qpc-hafs">﴿في سكرتهم﴾</span></span> أو من متعلَّق الجار والمجرور. وجملة <span class="hlt"><span class="qpc-hafs">﴿لعمرك إنهم لفي سكرتهم يعمهون﴾</span></span>: اعتراضية لا محل لها من الإعراب.</p></div>"
  15,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذتهم الصيحة مشرقين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذتهم الصيحة﴾</span></span> فعل ومفعول به وفاعل، ومشرقين حال، أي: داخلين في الشروق.</p></div>"
  15,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فجعلنا عاليها سافلها وأمطرنا عليهم حجارة من سجيل﴾</span></span>: الفاء عاطفة، والعطف مرتب على أخذ الصيحة، و<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> فعل وفاعل، وعاليها مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> الأول، وسافلها مفعول جعلنا الثاني، وأمطرنا عطف على جعلنا، وحجارة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمطرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من سجيل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لحجارة.</p></div>"
  15,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات للمتوسمين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآيات اسمها، و<span class="hlt"><span class="qpc-hafs">﴿للمتوسمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>، وقيل: متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>.</p></div>"
  15,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنها لبسبيل مقيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿بسبيل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿مقيم﴾</span></span> صفة.</p></div>"
  15,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية للمؤمنين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآية اسمها، و<span class="hlt"><span class="qpc-hafs">﴿للمؤمنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>، وقيل: متعلقان بنعت لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>.</p></div>"
  15,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كان أصحاب الأيكة لظالمين﴾</span></span>: الواو: استئنافية أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: مخففة من الثقيلة مهملة، وكان فعل ماض ناقص ناسخ، وأصحاب اسمها، والأيكة مضاف إليه، واللام الفارقة، وظالمين خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن كان أصحاب...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو معطوفة.</p></div>"
  15,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانتقمنا منهم﴾</span></span>: الفاء عاطفة على محذوف، أي: أمعنوا في الإثم فانتقمنا، وانتقمنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انتقمنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنهما لبإمام مبين﴾</span></span>: الواو حالية، أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إنهما﴾</span></span> إن حرف ناسخ، والهاء اسمها، والضمير يعود على قرى قوم لوط والأيكة، وقيل: يعودان على الأيكة ومدين، لأن شعيبًا كان مبعوثًا إليهما، وقيل: يعود على لوط وشعيب، وقيل: يعود على الخبرين، خبر إهلاك قوم لوط، وخبر إهلاك قوم شعيب، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿بإمام﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إنهما﴾</span></span>، ومبين صفته.</p></div>"
  15,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد كذب أصحاب الحجر المرسلين﴾</span></span>: عطف على ما تقدم، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كذب أصحاب الجحر﴾</span></span> فعل وفاعل، والمرسلين مفعول به.</p></div>"
  15,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناهم آياتنا﴾</span></span>: الواو عاطفة، وآتيناهم فعل وفاعل ومفعول به أول، وآياتنا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكانوا عنها معرضين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فكانوا﴾</span></span> عطف على آتيناهم، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بمعرضين، ومعرضين خبر كانوا.</p></div>"
  15,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكانوا ينحتون من الجبال بيوتا آمنين﴾</span></span>: الواو عاطفة، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة ينحتون خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من الجبال﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو بـ<span class="hlt"><span class="qpc-hafs">﴿ينحتون﴾</span></span>، وبيوتًا مفعول به، وآمنين حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿ينحتون﴾</span></span>.</p></div>"
  15,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذتهم الصيحة مصبحين﴾</span></span>: الفاء عاطفة، وأخذتهم فعل ومفعول به مقدم، والصيحة فاعل مؤخر، ومصبحين حال، أي: داخلين في وقت الصباح.</p></div>"
  15,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما أغنى عنهم ما كانوا يكسبون﴾</span></span>: الفاء عاطفة، وما نافية، وأغنى فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة يكسبون خبر كانوا، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الأولى استفهامية مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، وقيل: مصدرية.</p></div>"
  15,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما خلقنا السماوات والأرض وما بينهما إلا بالحق﴾</span></span>: الواو عاطفة، وما نافية، وخلقنا السماوات فعل فاعل ومفعول به، والأرض عطف على السماوات، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والباء للملابسة، أي: متلبسًا بالحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الساعة لآتية﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والساعة اسمها، واللام المزحلقة، وآتية خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاصفح الصفح الجميل﴾</span></span>: الفاء الفصيحة، واصفح فعل أمر، وفاعله مستتر تقديره: أنت، والصفح مفعول مطلق، والجميل صفة.</p></div>"
  15,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك هو الخلاق العليم﴾</span></span>: إن حرف ناسخ، وربك اسمها، والخلاق العليم خبراها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل.</p></div>"
  15,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتيناك سبعا من المثاني والقرآن العظيم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وآتيناك فعل ماض وفاعل ومفعول به أول، وسبعًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من المثاني﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سبعًا﴾</span></span>، والقرآن عطف على <span class="hlt"><span class="qpc-hafs">﴿سبعًا﴾</span></span>، والعظيم صفة للقرآن.</p></div>"
  15,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا تمدن عينيك إلى ما متعنا به أزواجا منهم﴾</span></span>: لا ناهية، وتمدن فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، وهو في محل جزم بلا الناهية، والفاعل مستتر تقديره: أنت، وعينيك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمدن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، وأزواجًا مفعول متعنا، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تحزن عليهم واخفض جناحك للمؤمنين﴾</span></span>: الواو عاطفة، ولا تحزن عطف على لا تمدن، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحزن﴾</span></span>، واخفض عطف أيضًا، وجناحك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للمؤمنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخفض﴾</span></span>.</p></div>"
  15,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل إني أنا النذير المبين﴾</span></span>: إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿النذير﴾</span></span> خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، والنذير خبر <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنا النذير﴾</span></span> خبر إن، والمبين صفة.</p></div>"
  15,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كما أنزلنا على المقتسمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف تقديره: آتيناك سبعا من المثانى إيتاءً مثلَ ما أنزلنا، أو إنزالا مثلَ ما أنزلنا، لأن آتيناك بمعنى أنزلنا عليك، وقيل: الكاف في محل نصب صفة لمفعول تقديره: إني أنذركم عذابًا مثلَ العذاب المنزل على المقتسمين، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على المقتسمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>.</p></div>"
  15,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين جعلوا القرآن عضين﴾</span></span>: الذين صفة للمقتسمين، وجملة جعلوا صلة الذين لا محل لها من الإعراب، والقرآن مفعول جعلوا، وعضين مفعول به ثان.</p></div>"
  15,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فوربك لنسألنهم أجمعين﴾</span></span>: الفاء عاطفة، والواو للقسم، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مجرور بواو القسم، والجار والمجرور جار ومجرور متعلقان بفعل محذوف تقديره: أقسم، واللام واقعة في جواب القسم، و<span class="hlt"><span class="qpc-hafs">﴿لنسألنهم﴾</span></span>: فعل وفاعل مستتر ومفعول به، وأجمعين تأكيد.</p></div>"
  15,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عما كانوا يعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لنسألنهم﴾</span></span>، وكان فعل ماض ناقص ناسخ، والواو اسمها، وجملة يعملون خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  15,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصدع بما تؤمر وأعرض عن المشركين﴾</span></span>: الفاء الفصيحة، أي: إن عرفت هذا فاصدع، و<span class="hlt"><span class="qpc-hafs">﴿اصدع﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أو موصولة، و<span class="hlt"><span class="qpc-hafs">﴿عن المشركين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>.</p></div>"
  15,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كفيناك المستهزئين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كفيناك﴾</span></span> فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفيناك﴾</span></span> خبر إن، والمستهزئين مفعول به ثان.</p></div>"
  15,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يجعلون مع الله إلها آخر﴾</span></span>: الذين صفة للمستهزئين، وجملة يجعلون صلة الذين لا محل لها من الإعراب، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف مكان متعلق بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يجعلون﴾</span></span>، وإلهًا مفعول به، وآخر صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسوف يعلمون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وسوف حرف استقبال، ويعلمون فعل مضارع وفاعل، والمفعول محذوف، أي: عاقبة أمرهم.</p></div>"
  15,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد نعلم أنك يضيق صدرك بما يقولون﴾</span></span>: الواو عاطفة، واللام واقعة في جواب للقسم، وقد حرف تحقيق، ونعلم فعل مضارع فاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿أنك﴾</span></span> أن حرف ناسخ، والكاف اسمها، وهي وما في حيزها سدت مسد مفعولي نعلم، وجملة يضيق صدرك خبر أن، وصدرك فاعل يضيق، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضيق﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: يقولون من أقاويل.</p></div>"
  15,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبح بحمد ربك وكن من الساجدين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿بحمد ربك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: وأنت حامد لربك على أن وفقك للتسبيح وأعانك عليه، <span class="hlt"><span class="qpc-hafs">﴿وكن﴾</span></span> فعل أمر ناقص ناسخ، واسمها ضمير مستتر، ومن حرف جر، والساجدين اسم مجرور، والجار والمجرور متعلقان بمحذوف خبر كن.</p></div>"
  15,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واعبد ربك حتى يأتيك اليقين﴾</span></span>: حتى حرف غاية وجر، ويأتيك فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعبد﴾</span></span>، والكاف مفعول به، واليقين فاعل.</p></div>"
