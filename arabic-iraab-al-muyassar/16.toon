quran[128]{c,v,t}:
  16,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتى أمر الله فلا تستعجلوه﴾</span></span>: أتى فعل ماض، وأمر الله فاعله، والفاء عاطفة، ولا ناهية، وتستعجلوه فعل مضارع مجزوم بلا الناهية، والواو فاعل، الهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحانه وتعالى عما يشركون﴾</span></span>: سبحانه: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه، وتعالى فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحانه﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، وما مصدرية، أو موصولة، وجملة يشركون لا محل لها من الإعراب.</p></div>"
  16,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ينزل الملائكة بالروح من أمره على من يشاء من عباده﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ينزل الملائكة﴾</span></span> فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالروح﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span>، أو بمحذوف حال، أي: متلبسة بالروح، و<span class="hlt"><span class="qpc-hafs">﴿من أمره﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿على من يشاء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عباده﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن أنذروا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الروح بمعنى الوحي والوحي فيه معنى القول، و<span class="hlt"><span class="qpc-hafs">﴿أنذروا﴾</span></span>: فعل أمر وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنذروا﴾</span></span> تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن أنذروا﴾</span></span> بدل من الروح مجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنذروا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنه لا إله إلا أنا فاتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، والهاء اسم أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا أنا﴾</span></span> خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> اسمها المبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> بدل من محل <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> واسمها، <span class="hlt"><span class="qpc-hafs">﴿فاتقون﴾</span></span> الفاء الفصيحة، واتقون فعل أمر وفاعل، والنون للوقاية، وياء المتكلم حذفت لمراعاة الفواصل.</p></div>"
  16,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض بالحق تعالى عما يشركون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span> فعل وفاعل مستتر، والسماوات مفعول به، والأرض عطف على السماوات، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: محقًّا، وتعالى فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، وجملة يشركون صلة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  16,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان من نطفة فإذا هو خصيم مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان﴾</span></span> فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من نطفة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، ومن للابتداء، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا الفجائية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخصيم خبر، ومبين صفة.</p></div>"
  16,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأنعام خلقها﴾</span></span>: الواو عاطفة، والأنعام منصوب بفعل محذوف يدل عليه ما بعده. وجملة الفعل المحذوف معطوفة على قوله: <span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان﴾</span></span> في الآية السابقة. وخلقها: فعل وفاعل مستتر ومفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقها﴾</span></span> تفسيرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم فيها دفء ومنافع﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ودفء مبتدأ مؤخر، والجملة حالية، أو مستأنفة لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من دفء، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، ومنافع عطف على دفء.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومنها تأكلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span>، وتأكلون فعل مضارع وفاعل.</p></div>"
  16,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكم فيها جمال حين تريحون وحين تسرحون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجمال مبتدأ مؤخر، وحين ظرف متعلق بمحذوف صفة، وجملة تريحون مضاف إليها، وكذلك قوله: <span class="hlt"><span class="qpc-hafs">﴿وحين تسرحون﴾</span></span>.</p></div>"
  16,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتحمل أثقالكم إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</span></span>: الواو عاطفة، وتحمل أثقالكم فعل مضارع وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى بلد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحمل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تكونوا بالغيه﴾</span></span> صفة لبلد، و<span class="hlt"><span class="qpc-hafs">﴿بالغيه﴾</span></span> خبر تكونوا، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بشق الأنفس﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الضمير المرفوع في <span class="hlt"><span class="qpc-hafs">﴿بالغيه﴾</span></span>، أي: مشقوقًا عليكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربكم لرءوف رحيم﴾</span></span>: إن حرف ناسخ، وربكم اسمها، واللام المزحلقة، ورءوف رحيم خبران.</p></div>"
  16,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها وزينة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿والخيل﴾</span></span> وما بعده عطف على الأنعام، أي: وخلق هؤلاء للركوب والزينة، و<span class="hlt"><span class="qpc-hafs">﴿لتركبوها﴾</span></span> مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمنصوب مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿زينة﴾</span></span> عطف على محل <span class="hlt"><span class="qpc-hafs">﴿لتركبوها﴾</span></span>، وقيل: نصبت على الحال من الها في <span class="hlt"><span class="qpc-hafs">﴿تركبوها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  16,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعلى الله قصد السبيل ومنها جائر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿قصد السبيل﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجائر صفة لموصوف هو المبتدأ المؤخر، أي: سبيل جائر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو شاء لهداكم أجمعين﴾</span></span>: الواو عاطفة، ولو امتناعية شرطية، ومفعول <span class="hlt"><span class="qpc-hafs">﴿شاء﴾</span></span> محذوف، أي: شاء هدايتكم، واللام رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وهداكم فعل وفاعل مستتر ومفعول به، وأجمعين تأكيد.</p></div>"
  16,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي أنزل من السماء ماء لكم منه شراب ومنه شجر فيه تسيمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> خبره، وجملة أنزل صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بأنزل، وماء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بمحذوف حال من شراب، وشراب مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لكم منه شراب﴾</span></span> صفة لماء، و<span class="hlt"><span class="qpc-hafs">﴿منه شجر﴾</span></span> جملة مستأنفة لا محل لها من الإعراب، وهي متألفة من خبر مقدم ومبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسيمون﴾</span></span>، وجملة تسيمون صفة لشجر.</p></div>"
  16,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ينبت لكم به الزرع والزيتون والنخيل والأعناب ومن كل الثمرات﴾</span></span>: ينبت فعل مضارع، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبت﴾</span></span>، والباء للسببية، أي بسببه ينبت الشجر، والزرع مفعول به، والزيتون والنخيل والأعناب عطف على الزرع، و<span class="hlt"><span class="qpc-hafs">﴿من كل الثمرات﴾</span></span> عطف على ما تقدم أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يتفكرون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآية، وجملة يتفكرون صفة لقوم.</p></div>"
  16,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسخر لكم الليل والنهار والشمس والقمر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وسخر لكم الليل﴾</span></span> فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخر﴾</span></span>، والشمس والقمر معطوفان على الليل والنهار.</p><p><span class="hlt"><span class="qpc-hafs">﴿والنجوم مسخرات بأمره﴾</span></span>: الواو عاطفة، والنجوم مبتدأ، ومسخرات خبر، والجملة عطف على الجملة السابقة، و<span class="hlt"><span class="qpc-hafs">﴿بأمره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسخرات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يعقلون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآيات اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآيات، وجملة يعقلون صفة لقوم.</p></div>"
  16,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ذرأ لكم في الأرض مختلفا ألوانه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿الليل والنهار﴾</span></span> في الآية السابقة، وقيل: منصوب بفعل محذوف، أي: وخلق وأنبت، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرأ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرأ﴾</span></span> أيضًا، ومختلفًا حال، وألوانه فاعل <span class="hlt"><span class="qpc-hafs">﴿مختلفًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يذكرون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآية اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآية، وجملة يذكرون صفة لقوم.</p></div>"
  16,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي سخر البحر لتأكلوا منه لحما طريا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبر، وجملة سخر صلة الذي لا محل لها من الإعراب، والبحر مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لتأكلوا﴾</span></span> اللام للتعليل، وتأكلوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكلوا﴾</span></span>، ولحمًا مفعول به، وطريًّا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتستخرجوا منه حلية تلبسونها﴾</span></span>: الواو عاطفة، وتستخرجوا عطف على لتأكلوا، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستخرجوا﴾</span></span>، وحلية مفعول به، وجملة تلبسونها صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حلية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وترى الفلك مواخر فيه ولتبتغوا من فضله ولعلكم تشكرون﴾</span></span>: الواو اعتراضية، وترى الفلك: فعل وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿وترى الفلك﴾</span></span> اعتراضية لا محل لها من الإعراب، ومواخر: حال، لأن الرؤية بصرية، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مواخر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لتبتغوا﴾</span></span> عطف على لتأكلوا، ولعل حرف ناسخ، والكاف اسمها، وجملة تشكرون خبرها.</p></div>"
  16,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وألقى في الأرض رواسي أن تميد بكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وألقى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وسخر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بألقى، ورواسي صفة لمفعول به محذوف، أي: جبالًا رواسي، وأن وما في حيزها مفعول لأجله، أي: كراهة أن تميل بكم وتضطرب، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تميد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنهارا وسبلا﴾</span></span>: الواو عاطفة، وأنهارًا وسبلًا عطف على رواسي، أو مفعول به لفعل محذوف، والتقدير: وجعل فيها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلكم تهتدون﴾</span></span>: لعل حرف ناسخ، والكاف اسمها، وجملة تهتدون خبرها.</p></div>"
  16,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعلامات وبالنجم هم يهتدون﴾</span></span>: الواو عاطفة، وعلامات عطف على <span class="hlt"><span class="qpc-hafs">﴿رواسي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالنجم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهتدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يهتدون﴾</span></span> خبره، وقيل: مفعول لفعل محذوف، أي: ووضع فيها علامات.</p></div>"
  16,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفمن يخلق كمن لا يخلق﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخلق﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كمن﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل رفع خبر المبتدأ، ومَن: اسم موصول في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يخلق﴾</span></span> صلة لـ<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> الثانية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تذكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span> فعل مضارع، والواو فاعل.</p></div>"
  16,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن تعدوا نعمة الله لا تحصوها﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وإن شرطية، وتعدوا فعل الشرط، والواو فاعل، ونعمة الله مفعول به، ولا نافية، وتحصوها جواب الشرط، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لغفور رحيم﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة للتوكيد، وغفور خبر إن الأول، ورحيم خبرها الثاني.</p></div>"
  16,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله يعلم ما تسرون وما تعلنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة يعلم خبر، وفاعل يعلم مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة تسرون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما تعلنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما تسرون﴾</span></span>.</p></div>"
  16,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين يدعون من دون الله لا يخلقون شيئا وهم يخلقون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، والذين مبتدأ، وجملة يدعون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يخلقون﴾</span></span> خبر الذين، وشيئًا مفعول به، والواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يخلقون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخلقون﴾</span></span> خبر المبتدأ.</p></div>"
  16,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أموات غير أحياء وما يشعرون أيان يبعثون﴾</span></span>: أموات خبر لمبتدأ محذوف، وقيل: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿غير أحياء﴾</span></span> صفة لأموات قصد به التأكيد، و<span class="hlt"><span class="qpc-hafs">﴿ما يشعرون﴾</span></span> عطف على أموات، أو خبر ثالث لـ<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أيان﴾</span></span> ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span> فهو متعلق به، والواو تعود على الأصنام.</p></div>"
  16,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلهكم إله واحد﴾</span></span>: إلهكم مبتدأ، وإله خبر، وواحد صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالذين لا يؤمنون بالآخرة قلوبهم منكرة﴾</span></span>: الفاء الفصيحة، والذين مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون بالآخرة﴾</span></span> صلة الذين لا محل لها من الإعراب، وقلوبهم مبتدأ، ومنكرة خبر لقلوبهم، والجملة الاسمية خبر الذين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم مستكبرون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومستكبرون خبر، والجملة في محل نصب على الحال.</p></div>"
  16,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا جرم أن الله يعلم ما يسرون وما يعلنون﴾</span></span>: لا نافية، وجرم فعل ماض، وأن وما في حيزها فاعله، وجملة يعلم خبر أن، وجملة يسرون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما يعلنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما يسرون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا يحب المستكبرين﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يحب﴾</span></span> خبرها، والمستكبرين مفعول يحب.</p></div>"
  16,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم ماذا أنزل ربكم قالوا أساطير الأولين﴾</span></span>: إذا ظرف لما يستقبل من الزمن، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل لهم﴾</span></span> مضاف إليها الظرف، وجملة <span class="hlt"><span class="qpc-hafs">﴿ماذا أنزل ربكم﴾</span></span> نائب فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، والكلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل نصب مفعول مقدم لأنزل، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿أنزل ربكم﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أساطير الأولين﴾</span></span> خبر لمبتدأ محذوف، أي: هي أساطير الأولين، أو: المنزل أساطير الأولين.</p></div>"
  16,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليحملوا أوزارهم كاملة يوم القيامة﴾</span></span>: اللام للتعليل، ويحملوا مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، والواو فاعل، وأوزارهم مفعول به، وكاملة حال، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحملوا﴾</span></span>، وقيل: اللام للعاقبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أوزار الذين يضلونهم بغير علم ألا ساء ما يزرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ومن أوزار﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أوزارهم﴾</span></span>، فالجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحملوا﴾</span></span>، ومن للتبعيض، أي: وبعض أوزار من يضل بضلالهم، وقيل: للجنس، أي: ليحملوا من جنس أوزار الكفار، وجملة <span class="hlt"><span class="qpc-hafs">﴿يضلونهم﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بغير علم﴾</span></span> حال من المفعول به، وقيل: من الفاعل المسند إليه الإضلال، و<span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> أداة تنبيه، و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل ماض لإنشاء الذم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> تمييز، أي: شيئًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿يزرون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يزرون﴾</span></span> صلة لها لا محل لها من الإعراب، والمخصوص بالذم محذوف تقديره: وزرهم.</p></div>"
  16,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد مكر الذين من قبلهم فأتى الله بنيانهم من القواعد﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وقد حرف تحقيق، ومكر الذين فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الذين لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فأتى الله بنيانهم﴾</span></span> فعل وفاعل ومفعول به، وهو عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من القواعد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فخر عليهم السقف من فوقهم وأتاهم العذاب من حيث لا يشعرون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿خر﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خر﴾</span></span>، والسقف فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من فوقهم﴾</span></span> متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿أتاهم العذاب﴾</span></span> فعل ماض، ومفعول به مقدم، وفاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من حيث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتاهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يشعرون﴾</span></span> مضاف إليه.</p></div>"
  16,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم يوم القيامة يخزيهم﴾</span></span>: ثم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يخزيهم﴾</span></span>، والقيامة مضاف إليه، ويخزيهم فعل مضارع، وفاعل مستتر، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقول أين شركائي الذين كنتم تشاقون فيهم﴾</span></span>: أين اسم استفهام في محل نصب على الظرفية المكانية متعلق بمحذوف خبر مقدم، وشركائي مبتدأ مؤخر، والذين صفة لشركائي، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة تشاقون خبر كنتم، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشاقون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين أوتوا العلم إن الخزي اليوم والسوء على الكافرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتوا﴾</span></span> صلة الذين لا محل لها من الإعراب، والواو نائب فاعل، والعلم مفعول به ثان، وإن حرف ناسخ، والخزي اسمها، واليوم ظرف متعلق بالخزي، لأنه مصدر يعمل عمل الفعل، والسوء عطف على الخزي، و<span class="hlt"><span class="qpc-hafs">﴿على الكافرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  16,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين تتوفاهم الملائكة ظالمي أنفسهم﴾</span></span>: الذين نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الكافرين﴾</span></span> في الآية السابقة، أو بدل منه، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتوفاهم الملائكة﴾</span></span> صلة الذين لا محل لها من الإعراب، والجملة فعل ومفعول به وفاعل، وظالمي أنفسهم حال من مفعول تتوفاهم، وأنفسهم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فألقوا السلم ما كنا نعمل من سوء﴾</span></span>: الفاء عاطفة، وألقوا معطوف على توفاهم، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿قال الذين أوتوا العلم﴾</span></span>، وقيل: الفاء للاستئناف، وجملة <span class="hlt"><span class="qpc-hafs">﴿فألقوا السلم﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span> فعل وفاعل، والسلم مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما كنا﴾</span></span> مقول لقول محذوف، أي: قائلين، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعمل﴾</span></span> خبر كنا، ومن صلة، و<span class="hlt"><span class="qpc-hafs">﴿سوء﴾</span></span> مجرور لفظًا منصوب محلا على أنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلى إن الله عليم بما كنتم تعملون﴾</span></span>: بلى: حرف جواب لإبطال النفي في قولهم: <span class="hlt"><span class="qpc-hafs">﴿ما كنا نعمل من سوء﴾</span></span>، وإن حرف ناسخ، ولفظ الجلالة اسمها، وعليم خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة تعملون خبر كان.</p></div>"
  16,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فادخلوا أبواب جهنم خالدين فيها﴾</span></span>: الفاء الفصيحة، وادخلوا فعل أمر وفاعل، وأبواب مفعول به على السعة، وجهنم مضاف إليه، وخالدين حال من فاعل ادخلوا، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلبئس مثوى المتكبرين﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام للابتداء، وبئس فعل ماض لإنشاء الذم، ومثوى المتكبرين فاعل، والمخصوص بالذم محذوف، تقديره: هي.</p></div>"
  16,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل للذين اتقوا ماذا أنزل ربكم قالوا خيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتقوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿أنزل ربكم﴾</span></span> فعل وفاعل، وخيرًا مفعول لفعل محذوف، أي: أنزل خيرًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿للذين أحسنوا في هذه الدنيا حسنة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحسنوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحسنوا﴾</span></span>، والدنيا بدل، وحسنة مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿للذين أحسنوا...﴾</span></span> استئنافية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولدار الآخرة خير﴾</span></span>: اللام للابتداء، ودار الآخرة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنعم دار المتقين﴾</span></span>: اللام للابتداء، و<span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> فعل ماض لإنشاء المدح، و<span class="hlt"><span class="qpc-hafs">﴿دار المتقين﴾</span></span> فاعل، والمخصوص بالمدح محذوف، أي: هي.</p></div>"
  16,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن يدخلونها﴾</span></span>: جنات خبر لمبتدأ محذوف، أو هي المخصوص بالمدح فتعرب مبتدأ، والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿نعم دار المتقين﴾</span></span>، أو خبر لمبتدأ محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدخلونها﴾</span></span> حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها الأنهار لهم فيها ما يشاءون﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها الأنهار﴾</span></span> حال أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال ثالثة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاءون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك يجزي الله المتقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: جزاءً مثلَ ذلك يجزي، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يجزي الله المتقين﴾</span></span> فعل وفاعل ومفعول به.</p></div>"
  16,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين تتوفاهم الملائكة طيبين﴾</span></span>: الذين نعت لـ<span class="hlt"><span class="qpc-hafs">﴿المتقين﴾</span></span> في الآية السابقة، أو بدل منه، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتوفاهم﴾</span></span> صلة الذين لا محل لها من الإعراب، والهاء مفعول به، والملائكة فاعل، وطيبين حال من المفعول في <span class="hlt"><span class="qpc-hafs">﴿تتوفاهم﴾</span></span>، أي: طاهرين من الشوائب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يقولون سلام عليكم ادخلوا الجنة بما كنتم تعملون﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> حال من الملائكة، وسلام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وادخلوا الجنة فعل أمر وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادخلوا﴾</span></span>، وجملة كنتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة تعملون خبر كنتم، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية.</p></div>"
  16,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل ينظرون إلا أن تأتيهم الملائكة أو يأتي أمر ربك﴾</span></span>: هل حرف استفهام معناه النفي، وينظرون فعل مضارع وفاعل، وإلا أداة حصر، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها مفعول ينظرون، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يأتي أمر ربك﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تأتيهم الملائكة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك فعل الذين من قبلهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أو في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿فعل الذين﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما ظلمهم الله﴾</span></span>: الواو اعتراضية، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿ظلمهم الله﴾</span></span> فعل ومفعول به وفاعل، والجملة اعتراضية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> مخففة مهملة، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة يظلمون خبرها، و<span class="hlt"><span class="qpc-hafs">﴿أنفسهم﴾</span></span> مفعول مقدم لقوله: <span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span>، والجملة عطف على الجملة الاعتراضية لا محل لها من الإعراب.</p></div>"
  16,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأصابهم سيئات ما عملوا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أصابهم﴾</span></span> فعل ومفعول به مقدم، وسيئات فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أو مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وحاق بهم ما كانوا به يستهزئون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حاق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، وجملة يستهزئون خبر كانوا.</p></div>"
  16,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين أشركوا لو شاء الله ما عبدنا من دونه من شيء نحن ولا آباؤنا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أشركوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> امتناعية شرطية، و<span class="hlt"><span class="qpc-hafs">﴿شاء الله﴾</span></span> فعل وفاعل، والمفعول محذوف أي: لو شاء خلاف طريقتنا وما يصدر عنا، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿عبدنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> صلة، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span> مجرور لفظًا مفعول عبدنا محلا، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> تأكيد لفاعل <span class="hlt"><span class="qpc-hafs">﴿عبدنا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، <span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا حرمنا من دونه من شيء﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>، ومن حرف جر صلة، وشيء مجرور لفظًا مفعول به منصوب محلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك فعل الذين من قبلهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: فَعَل الذين من قبلهم فِعْلا مثل ذلك الفعل، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿فعل الذين﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل على الرسل إلا البلاغ المبين﴾</span></span>: الفاء عاطفة، وهل حرف استفهام معناه النفي، و<span class="hlt"><span class="qpc-hafs">﴿على الرسل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وإلا أداة حصر، والبلاغ مبتدأ مؤخر، والمبين صفته.</p></div>"
  16,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد بعثنا في كل أمة رسولا﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في كل أمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، ورسولًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن اعبدوا الله واجتنبوا الطاغوت﴾</span></span>: أن مصدرية، وهي مع مدخولها مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> صلة أن المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، لأن البعث فيه معنى القول، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿اعبدوا﴾</span></span> فعل أمر وفاعل، ولفظ الجلالة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿اجتنبوا الطاغوت﴾</span></span> فعل أمر وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمنهم من هدى الله ومنهم من حقت عليه الضلالة﴾</span></span>: الفاء تفريعية استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ مؤخر، وهي نكرة موصوفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿هدى الله﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منهم من حقت عليه الضلالة﴾</span></span> عطف على سابقتها، وهي مثلها في الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسيروا في الأرض فانظروا كيف كان عاقبة المكذبين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سيروا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فانظروا﴾</span></span> الفاء عاطفة، وانظروا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> المقدم، وعاقبة المكذبين اسمها المؤخر.</p></div>"
  16,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن تحرص على هداهم فإن الله لا يهدي من يضل﴾</span></span>: إن شرطية، وتحرص فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿على هداهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحرص﴾</span></span>، أي: ترغب فيه، فإن الفاء رابطة لجواب الشرط، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يهدي خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مفعول به، وجملة يضل صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وقيل: جواب الشرط محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإن الله لا يهدي﴾</span></span> تعليل للجواب، والتقدير: لا تقدر أنت ولا يقدر أحد على هدايتهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما لهم من ناصرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿ناصرين﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا.</p></div>"
  16,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأقسموا بالله جهد أيمانهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وأقسموا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بأقسموا، وجهد: حال، أي: أقسموا بالله مجتهدين في أيمانهم، أو نائب عن المفعول المطلق، لأنه بمعنى المصدر، والمعنى: أقسموا إقسامَ اجتهادٍ في اليمين. وأيمانهم: مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿أقسموا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وقال الذين أشركوا﴾</span></span>، أو استئنافية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا يبعث الله من يموت بلى وعدا عليه حقا﴾</span></span>: لا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يبعث الله من يموت﴾</span></span> فعل وفاعل ومفعول، والجملة لا محل لها من الإعراب، لأنها جواب القسم، و<span class="hlt"><span class="qpc-hafs">﴿بلى﴾</span></span> حرف جواب لإبطال نفي البعث، و<span class="hlt"><span class="qpc-hafs">﴿وعدا﴾</span></span> مفعول مطلق لفعل محذوف. و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وعدا﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿حقًّا﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة والتقدير: حق ذلك حقا، أو أن <span class="hlt"><span class="qpc-hafs">﴿حقا﴾</span></span> نعت للمصدر الذي قبله.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثر الناس لا يعلمون﴾</span></span>: الجملة حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> حرف ناسخ، وأكثر اسمها، وجملة لا يعلمون خبرها.</p></div>"
  16,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليبين لهم الذي يختلفون فيه﴾</span></span>: اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿يبين﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بما دل عليه بلى، أي: يبعثهم ليبين، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مفعول به، وجملة يختلفون فيه صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليعلم الذين كفروا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وليعلم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ليبين﴾</span></span>، والذين فاعل، وجملة كفروا صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنهم كانوا كاذبين﴾</span></span>: أن حرف ناسخ، والهاء اسمها، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وكاذبين خبرها، وجملة كانوا خبر أن، وأن وما في حيزها سدت مسد مفعولي يعلم.</p></div>"
  16,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما قولنا لشيء إذا أردناه أن نقول له كن فيكون﴾</span></span>: إنما كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿قولنا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لشيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قولنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قولنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أردناه﴾</span></span> مضاف إليه، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> ومدخولها خبر <span class="hlt"><span class="qpc-hafs">﴿قولنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span>، وكن فعل أمر من كان التامة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كن﴾</span></span> مقول القول، <span class="hlt"><span class="qpc-hafs">﴿فيكون﴾</span></span> الفاء عاطفة، ويكون معطوف على مقدر، أي: فنقول له ذلك فيكون، أو جواب لشرط محذوف فتكون الفاء فصيحة، أي: فإذا قلنا ذلك فهو يكون، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  16,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هاجروا في الله من بعد ما ظلموا﴾</span></span>: الواو استئنافية، والذين مبتدأ، وجملة هاجروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هاجروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع مدخولها بمصدر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنبوئنهم في الدنيا حسنة﴾</span></span>: اللام واقعة في جواب قسم مقدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نبوئنهم﴾</span></span> خبر الذين، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿حسنة﴾</span></span> صفة لمصدر محذوف، أي: تبوئة حسنة، فهي نائب عن المفعول المطلق، أو مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نبوئنهم﴾</span></span>، لتضمن معناه: نعطينهم، فتكون صفة لمحذوف، أي: دارًا حسنة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولأجر الآخرة أكبر لو كانوا يعلمون﴾</span></span>: الواو حالية، واللام للابتداء، وأجر الآخرة مبتدأ، وأكبر خبر، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة يعلمون خبرها.</p></div>"
  16,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين صبروا وعلى ربهم يتوكلون﴾</span></span>: الذين خبر لمبتدأ محذوف في محل رفع، أي: هم الذين صبروا، أو في محل نصب على المدح، أي: أعني الذين صبروا، وجملة صبروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على ربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتوكلون﴾</span></span>، ويتوكلون فعل مضارع وفاعل.</p></div>"
  16,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم﴾</span></span>: الواو عاطفة، أو استئنافية، وما نافية، وأرسلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وإلا أداة حصر، ورجالًا مفعول أرسلنا، وجملة نوحي إليهم صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما أرسلنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span></span>: الفاء الفصيحة، واسألوا فعل أمر وفاعل، وأهل الذكر مفعوله، وإن شرطية، وكنتم فعل ماض ناقص في محل جزم فعل الشرط، والجواب محذوف دل عليه <span class="hlt"><span class="qpc-hafs">﴿فاسألوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعلمون﴾</span></span> خبرها.</p></div>"
  16,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بالبينات والزبر وأنزلنا إليك الذكر لتبين للناس﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بأرسلنا، أو متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجالًا﴾</span></span>، أي: رجالًا متلبسين بالبينات، أو بأرسلنا مضمرًا، أو بـ<span class="hlt"><span class="qpc-hafs">﴿نوحي﴾</span></span>، أي: نوحي إليهم بالبينات، وأنزلنا عطف على أرسلنا، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، والذكر مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لتبين﴾</span></span> اللام للتعليل، وتبين منصوب بأن مضمرة، والمصدر المؤول من أن المضمرة والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما نزل إليهم ولعلهم يتفكرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿تبين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿نزل إليهم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿ولعلهم﴾</span></span> لعل حرف ناسخ، والهاء اسمها، وجملة يتفكرون خبرها.</p></div>"
  16,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفأمن الذين مكروا السيئات أن يخسف الله بهم الأرض﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، والفاء عاطفة على محذوف، و<span class="hlt"><span class="qpc-hafs">﴿أمن الذين﴾</span></span> فعل وفاعل، وجملة مكروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿السيئات﴾</span></span> نائب مفعول مطلق لأنه صفة المصدر، أي: يمكرون المكرات السيئات، أو مفعول به على تضمين <span class="hlt"><span class="qpc-hafs">﴿يمكرون﴾</span></span> معنى يعملون أو يكسبون، و<span class="hlt"><span class="qpc-hafs">﴿أن يخسف﴾</span></span> أن وما في حيزها مصدر مفعول <span class="hlt"><span class="qpc-hafs">﴿أمن﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿السيئات﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أمن﴾</span></span>، أي: أمنوا العقوبات السيئات، و<span class="hlt"><span class="qpc-hafs">﴿أن يخسف﴾</span></span> أن وما في حيزها بدل من السيئات، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل يخسف، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخسف﴾</span></span>، والأرض مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو يأتيهم العذاب من حيث لا يشعرون﴾</span></span>: عطف على أن يخسف، و<span class="hlt"><span class="qpc-hafs">﴿من حيث﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يشعرون﴾</span></span> مضاف إليه.</p></div>"
  16,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو يأخذهم في تقلبهم فما هم بمعجزين﴾</span></span>: عطف أيضًا على أن يخسف، و<span class="hlt"><span class="qpc-hafs">﴿في تقلبهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من المفعول، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمعجزين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿معجزين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  16,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span></span>: عطف ثالث على <span class="hlt"><span class="qpc-hafs">﴿أن يخسف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على تخوف﴾</span></span> حال أيضًا من الفاعل أو المفعول، أي: يأخذهم متنقصًا إياهم شيئًا بعد شيء، أو: وهم متخوفون.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن ربكم لرءوف رحيم﴾</span></span>: الفاء تعليل لما تقدم، وإن حرف ناسخ، وربكم اسمها، واللام المزحلقة، ورءوف خبر إن الأول، ورحيم خبر إن الثاني.</p></div>"
  16,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا إلى ما خلق الله من شيء يتفيأ ظلاله عن اليمين والشمائل سجدا لله وهم داخرون﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، والواو عاطفة على محذوف مقدر، أي: ألم ينظروا ولم يروا موجهين إلى ما خلق الله، و<span class="hlt"><span class="qpc-hafs">﴿إلى ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق الله﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ما خلق الله﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتفيأ ظلاله﴾</span></span> صفة لشيء، وظلاله فاعل يتفيأ، و<span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والشمائل عطف،أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتفيأ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سجدا لله وهم داخرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سجدًا﴾</span></span> حال من ظلاله، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وداخرون خبر، والجملة حالية من الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿سجدًا﴾</span></span> فهي حال متداخلة.</p></div>"
  16,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولله يسجد ما في السماوات وما في الأرض من دابة والملائكة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسجد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿يسجد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما في الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما في السماوات﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من دابة﴾</span></span> جار ومجرور متعلقان بمحذوف منصوب على الحال المبنية، والملائكة عطف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يستكبرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يستكبرون﴾</span></span> خبر.</p></div>"
  16,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يخافون ربهم من فوقهم ويفعلون ما يؤمرون﴾</span></span>: جملة يخافون نصب على الحال من ضمير يستكبرون، أو بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿لا يستكبرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يخافون ربهم﴾</span></span> فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من فوقهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span>، أي: يخافون ربهم عاليًا عليها في الرتبة، و<span class="hlt"><span class="qpc-hafs">﴿يفعلون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يخافون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة يؤمرون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  16,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الله لا تتخذوا إلهين اثنين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الله﴾</span></span> فعل وفاعل، ولا ناهية، وتتخذوا فعل مضارع مجزوم بلا، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلهين﴾</span></span> مفعول به، واثنين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إلهين﴾</span></span>، وقيل: توكيد لـ<span class="hlt"><span class="qpc-hafs">﴿إلهين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما هو إله واحد﴾</span></span>: إنما كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> خبر، وواحد صفة للتأكيد أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإياي فارهبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فإياي﴾</span></span> الفاء واقعة في جواب شرط مقدر، وإياي ضمير منفصل في محل نصب مفعول به لفعل مقدَّر يفسِّره الفعل المذكور تقديره: ارهبوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿إياي ارهبوا﴾</span></span> في محل جزم جواب الشرط المقدَّر، والتقدير: إن رهبتم شيئًا فإياي ارهبوا. <span class="hlt"><span class="qpc-hafs">﴿فارهبونِ﴾</span></span> الفاء صلة للتزيين، وارهبونِ: فعل أمر مبني على حذف النون، وواو الجماعة فاعل، والنون للوقاية، وياء المتكلم المحذوفة مفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿ارهبونِ﴾</span></span> تفسيرية لا محل لها من الإعراب.</p></div>"
  16,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وله ما في السماوات والأرض﴾</span></span>: الواو عاطفة، والجملة معطوفة على قوله: <span class="hlt"><span class="qpc-hafs">﴿إنما هو إله واحد﴾</span></span>، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، والأرض عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وله الدين واصبا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والدين مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿واصبًا﴾</span></span> حال من الضمير المستكن في الجار والمجرور، والتقدير: والدين ثابت له حال كونه واصبًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفغير الله تتقون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف، و<span class="hlt"><span class="qpc-hafs">﴿غير الله﴾</span></span> مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span> فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعله.</p></div>"
  16,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما بكم من نعمة فمن الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> شرطية في محل رفع مبتدأ، وفعل الشرط محذوف، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بفعل الشرط المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿من نعمة﴾</span></span> جار ومجرور متعلقان بمحذوف حال من اسم الشرط، وقيل: حال من الضمير في الجار، والفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، والتقدير: فهو من الله، والجملة في محل جزم جواب الشرط، وفعل الشرط المحذوف والجواب في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة مبتدأ، والجار والمجرور متعلقان بمحذوف صلتها، وجملة الصلة لا محل لها من الإعراب، والخبر قوله: <span class="hlt"><span class="qpc-hafs">﴿فمن الله﴾</span></span>، والفاء رابطة لتضمن الموصول معنى الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم إذا مسكم الضر فإليه تجأرون﴾</span></span>: ثم حرف عطف، وإذا ظرف مستقبل متضمن معنى الشرط متعلق بالجواب <span class="hlt"><span class="qpc-hafs">﴿تجأرون﴾</span></span>، ومسكم فعل ومفعول به مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿مسكم﴾</span></span> مضاف إليه، والضر فاعل مؤخر، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجأرون﴾</span></span>، وتجأرون فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإليه تجأرون﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  16,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إذا كشف الضر عنكم إذا فريق منكم بربهم يشركون﴾</span></span>: ثم حرف عطف، وإذا ظرف مستقبل متضمن معنى الشرط متعلق بفعل محذوف تقديره: أشرك بعضكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿كشف﴾</span></span> مضاف إليه، والضر مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عنكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشف﴾</span></span>، وإذا فجائية لا محل لها من الإعراب، وفريق مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span>، وجملة يشركون خبر فريق.</p></div>"
  16,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليكفروا بما آتيناهم فتمتعوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ليكفروا﴾</span></span> اللام لام التعليل، ويكفروا مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span>، أي: إشراكهم سببه كفرهم بربهم، وقيل: اللام لام الصيرورة، أو العاقبة، أي: فعاقبة إشراكهم بالله غيره كفرهم بالنعمة التي هي كشف الضر عنهم، والجار والمجرور من اللام والمصدر المؤول من أن والفعل في <span class="hlt"><span class="qpc-hafs">﴿ليكفروا﴾</span></span> متعلقان بمحذوف خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، وجملة آتيناهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فتمتعوا﴾</span></span> جملة معمولة لقول محذوف، أي: قل لهم يا محمد: تمتعوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسوف تعلمون﴾</span></span>: الفاء الفصيحة، وسوف حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span> فعل وفاعل، ومفعوله محذوف تقديره: عاقبة ذلك.</p></div>"
  16,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويجعلون لما لا يعلمون نصيبا مما رزقناهم﴾</span></span>: عطف على ما سبق، ويجعلون فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجعلون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> صلة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والضمير في يعلمون عائد على المشركين، وقيل: عائد على الأصنام المدلول عليها بـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، ونصيبًا مفعول يجعلون، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نصيبًا﴾</span></span>، وجملة رزقناهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿تالله لتسألن عما كنتم تفترون﴾</span></span>: التاء تاء القسم الجارة، ولفظ الجلالة مجرور بتاء القسم، والجار والمجرور متعلقان بمحذوف تقديره: قسمي، واللام واقعة في جواب القسم، وتسألن فعل مضارع مرفوع وعلامة رفعه ثبوت النون المحذوفة لتوالي الأمثال، والواو المحذوفة لالتقاء الساكنين فاعل، والنون المشددة نون التوكيد الثقيلة، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسألن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة تفترون خبر كان.</p></div>"
  16,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويجعلون لله البنات﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ويجعلون﴾</span></span>: عطف على ما تقدم. و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجعلون﴾</span></span>. والبنات: مفعول يجعلون.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحانه﴾</span></span>: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه، وهو مع فعله المحذوف جملة اعتراضية، لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولهم ما يشتهون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ مؤخر، وجملة يشتهون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في محل نصب بفعل مقدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولهم ما يشتهون﴾</span></span> استئنافية لا محل لها من الإعراب، أو الواو حالية، والجملة حالية من ضمير يجعلون.</p></div>"
  16,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا بشر أحدهم بالأنثى ظل وجهه مسودا وهو كظيم﴾</span></span>: إذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿بشر أحدهم﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بالأنثى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظل﴾</span></span> لا محل لها من الإعراب، ووجهه اسم ظل، و<span class="hlt"><span class="qpc-hafs">﴿مسودًّا﴾</span></span> خبرها، والواو حالية أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وكظيم خبر، والجملة حال متداخلة.</p></div>"
  16,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يتوارى من القوم من سوء ما بشر به﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿يتوارى﴾</span></span> حالية من الضمير في <span class="hlt"><span class="qpc-hafs">﴿كظيم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من القوم﴾</span></span> جار ومجرور متعلقان به، و<span class="hlt"><span class="qpc-hafs">﴿من سوء﴾</span></span> جار ومجرور متعلقان به أيضًا، فالأولى للابتداء، والثانية للعلة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مضاف إليه، وجملة بشر به صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيمسكه على هون أم يدسه في التراب﴾</span></span>: الهمزة للاستفهام، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمسكه﴾</span></span> الاستفهامية معمولة لشيء محذوف حال من فاعل يتوارى، أي: يتوارى حائرًا، ويمسكه فعل مضارع وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على هون﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل المستتر، أو من المفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يدسه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يمسكه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في التراب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدسه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span>: حرف تنبيه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ساء ما يحكمون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل ماض جامد لإنشاء الذم مبني على الفتح، والفاعل ضمير مستتر وجوبا تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نكرة موصوفة في محل نصب تمييز لفاعل <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والمخصوص بالذم محذوف، أي: حكمهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> في محل نصب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والتقدير: ساء حكمًا يحكمونه.</p><p>أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول بمعنى الذي في محل رفع فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والمخصوص بالذم محذوف، أي: حكمهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p>أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب. والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وما دخلت عليه في محل رفع فاعل <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والتقدير: ساء حكمهم. والمخصوص بالذم محذوف.</p></div>"
  16,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للذين لا يؤمنون بالآخرة مثل السوء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجملة لا يؤمنون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بالآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، ومثل السوء مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولله المثل الأعلى وهو العزيز الحكيم﴾</span></span>: عطف على ما سبق، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، العزيز خبر أول، والحكيم خبر ثان.</p></div>"
  16,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية، ويؤاخذ الله الناس فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بظلمهم﴾</span></span> الباء حرف جر للسببية، أي: بسبب ظلمهم والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤاخذ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما ترك﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ترك﴾</span></span> فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لدابة، ومن حرف جر صلة، ودابة مجرور لفظًا مفعول به محلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن يؤخرهم إلى أجل مسمى﴾</span></span>: الواو عاطفة، ولكن حرف استدراك مهمل لأنها مخففة، ويؤخرهم فعل مضارع وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى أجل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤخرهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مسمى﴾</span></span> صفة، أي: معين.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء أجلهم لا يستأخرون ساعة ولا يستقدمون﴾</span></span>: الفاء عاطفة والجملة بعدها معطوفة، أو الفاء استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء أجلهم﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يستأخرون﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ساعة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يستأخرون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا يستقدمون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا يستأخرون﴾</span></span>.</p></div>"
  16,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويجعلون لله ما يكرهون وتصف ألسنتهم الكذب﴾</span></span>: الواو استئنافية، ويجعلون فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجعلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿يجعلون﴾</span></span>، وجملة يكرهون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿تصف ألسنتهم الكذب﴾</span></span>، فعل مضارع وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويجعلون لله ما يكرهون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن لهم الحسنى﴾</span></span>: أن ناسخة، والحسنى اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن المقدم، وأن وما في حيزها بدل كل من كل من الكذب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا جرم أن لهم النار وأنهم مفرطون﴾</span></span>: لا نافية، وجرم فعل ماض، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، والنار اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿أنهم مفرطون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن لهم النار﴾</span></span>.</p></div>"
  16,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تالله لقد أرسلنا إلى أمم من قبلك﴾</span></span>: التاء تاء قسم جارة، والجار والمجرور متعلقان بفعل القسم المقدر، واللام واقعة في جواب القسم، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى أمم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبلك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فزين لهم الشيطان أعمالهم﴾</span></span>: الفاء عاطفة، وزين فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span>، والشيطان فاعل، وأعمالهم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو وليهم اليوم ولهم عذاب أليم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿وليهم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بمحذوف حال، أو متعلق بوليهم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، وأليم صفة.</p></div>"
  16,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنزلنا عليك الكتاب إلا لتبين لهم الذي اختلفوا فيه﴾</span></span>: الواو عاطفة، وما نافية، وأنزلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، والكتاب مفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿لتبين﴾</span></span> اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿تبين﴾</span></span> فعل مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهدى ورحمة لقوم يؤمنون﴾</span></span>: هدى ورحمة عطف على محل <span class="hlt"><span class="qpc-hafs">﴿لتبين﴾</span></span>، وقد انتصبا نصب المفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، أو متعلقان بالمصدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span> صفة لقوم.</p></div>"
  16,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله أنزل من السماء ماء فأحيا به الأرض بعد موتها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة أنزل خبر، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span> مفعول به، فأحيا عطف على أنزل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحيا﴾</span></span>، والأرض مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعد موتها﴾</span></span> الظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يسمعون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآية اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>، وجملة يسمعون صفة لقوم.</p></div>"
  16,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن لكم في الأنعام لعبرة﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿في الأنعام﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، وعبرة اسم إن المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿نسقيكم مما في بطونه من بين فرث ودم لبنا خالصا سائغا للشاربين﴾</span></span>: نسقيكم: فعل وفاعل مستتر ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿في بطونه﴾</span></span>: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span> استئنافية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من بين فرث ودم﴾</span></span> حال، لأنه كان في الأصل صفة لقوله: لبنًا، وقدم عليه، أو حال من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> التي قبله، و<span class="hlt"><span class="qpc-hafs">﴿لبنًا﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>، وسائغًا صفة، و<span class="hlt"><span class="qpc-hafs">﴿للشاربين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سائغًا﴾</span></span>.</p></div>"
  16,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ومن ثمرات النخيل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span> صفة لموصوف محذوف هو المبتدأ المؤخر، أي: ثمر كانوا يتخذون منه سكرًا ورزقًا حسنًا، وقيل: <span class="hlt"><span class="qpc-hafs">﴿من ثمرات﴾</span></span> جار ومجرور متعلق بمحذوف دل عليه <span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>، أي: نسقيكم من عصير النخيل والأعناب، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span> حال. وقيل: متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span>، وكررت <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتوكيد، وقيل: تتعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>، فيكون معطوفًا على <span class="hlt"><span class="qpc-hafs">﴿مما في بطونه﴾</span></span>، وقيل: معطوف على الأنعام، أي: ومن ثمرات النخيل والأعناب عبرة، ثم بين العبرة بقوله: تتخذون، والضمير في <span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> يعود على العصير المقدر، وسكرًا مفعول تتخذون، ورزقًا عطف على <span class="hlt"><span class="qpc-hafs">﴿سكرًا﴾</span></span>، وحسنًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يعقلون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآية اسمها المؤخر، وجملة يعقلون صفة لقوم.</p></div>"
  16,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحى ربك إلى النحل أن اتخذي من الجبال بيوتا ومن الشجر ومما يعرشون﴾</span></span>: الواو عاطفة على ما قبلها، أو مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أوحى ربك﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى النحل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من الجبال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتخذي﴾</span></span>، فمن للتبعيض، و<span class="hlt"><span class="qpc-hafs">﴿بيوتًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿اتخذي﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿من الشجر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من الجبال﴾</span></span>، وكذلك <span class="hlt"><span class="qpc-hafs">﴿مما يعرشون﴾</span></span>.</p></div>"
  16,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم كلي من كل الثمرات فاسلكي سبل ربك ذللا﴾</span></span>: ثم حرف عطف للتراخي، و<span class="hlt"><span class="qpc-hafs">﴿كلي﴾</span></span> فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من كل الثمرات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلي﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاسلكي﴾</span></span> الفاء عاطفة، واسلكي عطف على <span class="hlt"><span class="qpc-hafs">﴿كلي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سبل ربك﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ذللًا﴾</span></span> حال من السبل، أو من فاعل <span class="hlt"><span class="qpc-hafs">﴿اسلكي﴾</span></span>، أي: وأنت منقادة لما أمرت به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يخرج من بطونها شراب مختلف ألوانه فيه شفاء للناس﴾</span></span>: يخرج فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿من بطونها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span>، وشراب فاعل يخرج، و<span class="hlt"><span class="qpc-hafs">﴿مختلف﴾</span></span> صفة لشراب، و<span class="hlt"><span class="qpc-hafs">﴿ألوانه﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿مختلف﴾</span></span> لأنه اسم فاعل يعمل عمل الفعل، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وشفاء مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شفاء﴾</span></span>، والجملة صفة ثانية لشراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يتفكرون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآية اسمها المؤخر، وجملة يتفكرون صفة لقوم.</p></div>"
  16,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله خلقكم ثم يتوفاكم ومنكم من يرد إلى أرذل العمر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> خبر، <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للتراخي، <span class="hlt"><span class="qpc-hafs">﴿ومنكم﴾</span></span> الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وهو معطوف على مقدر، أي: فمنكم من يبقى محتفظًا بقوة جسمه وعقله ومنكم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ مؤخر، وجملة يرد صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ونائب الفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿إلى أرذل العمر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكي لا يعلم بعد علم شيئا إن الله عليم قدير﴾</span></span>: اللام لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span> حرف مصدري ونصب، ولا نافية، ويعلم منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، واللام ومدخولها متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، أو اللام للصيرورة، أي: فكانت عاقبته أنه رجع إلى حال الطفولة في النسيان وعدم الإدراك، و<span class="hlt"><span class="qpc-hafs">﴿بعد علم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>، وشيئًا مفعول به ليعلم، وقيل: <span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> منصوبة بالعلم، وإن حرف ناسخ، ولفظ الجلالة اسمها، وعليم خبرها الأول، وقدير خبرها الثاني.</p></div>"
  16,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله فضل بعضكم على بعض في الرزق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span> خبر، وبعضكم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الرزق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حالة كونكم مرزوقين فمنكم غني ومنكم فقير.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما الذين فضلوا برادي رزقهم على ما ملكت أيمانهم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> اسم ما، وجملة <span class="hlt"><span class="qpc-hafs">﴿فضلوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿برادي﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿رادي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿رزقهم﴾</span></span> مضاف إليه من إضافة المصدر إلى مفعوله، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رادي﴾</span></span>، وملكت أيمانهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم فيه سواء﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفبنعمة الله يجحدون﴾</span></span>: استفهام إنكار وتوبيخ، والفاء عاطفة على مقدر، أي: يشركون به فيجحدون نعمته، و<span class="hlt"><span class="qpc-hafs">﴿بنعمة الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>، لأنه متضمن معنى الكفران.</p></div>"
  16,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله جعل لكم من أنفسكم أزواجا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أنفسكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأزواجًا مفعول جعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم من أزواجكم بنين وحفدة﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من أزواجكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وبنين مفعول جعل، وحفدة عطف على بنين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقكم من الطيبات أفبالباطل يؤمنون وبنعمت الله هم يكفرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ورزقكم﴾</span></span> فعل ماض، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الطيبات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقكم﴾</span></span>، والهمزة للاستفهام الإنكاري التوبيخي، والفاء عاطفة على مقدر، أي: يكفرون بالله فيؤمنون بالباطل، و<span class="hlt"><span class="qpc-hafs">﴿بنعمة الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يكفرون خبر.</p></div>"
  16,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله ما لا يملك لهم رزقا من السماوات والأرض﴾</span></span>: الواو عاطفة، ويعبدون فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يملك﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ورزقًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيئا ولا يستطيعون﴾</span></span>: شيئًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>، أو بدل منه بمعنى: قليلًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا يستطيعون﴾</span></span> عطف على صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو مستأنفة لا محل لها من الإعراب، والواو عائدة على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والمراد بها آلهتهم.</p></div>"
  16,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا تضربوا لله الأمثال﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تضربوا﴾</span></span> فعل مضارع مجزوم، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تضربوا﴾</span></span>، والأمثال مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يعلم﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يعلم خبر، والجملة تعليلية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنتم لا تعلمون﴾</span></span>: الواو حالية، وأنتم مبتدأ، وجملة لا تعلمون خبر.</p></div>"
  16,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلا عبدا مملوكا لا يقدر على شيء﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلًا﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عبدًا﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>، ومملوكًا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يقدر على شيء﴾</span></span> صفة ثانية، و<span class="hlt"><span class="qpc-hafs">﴿على شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقدر﴾</span></span>، أي: من التصرفات.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن رزقناه منا رزقا حسنا﴾</span></span>: الواو عاطفة، ومن عطف على <span class="hlt"><span class="qpc-hafs">﴿عبدًا مملوكًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول، أو نكرة موصوفة، كأنه قيل: وحرًّا رزقناه ليطابق عبدًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقناه﴾</span></span> صلة على الأول لا محل لها من الإعراب، وصفة على الثاني، ونا فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقناه﴾</span></span>، ورزقًا مفعول به ثان، أو مفعول مطلق منصوب، وحسنًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو ينفق منه سرا وجهرا هل يستوون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة ينفق خبر، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سرا﴾</span></span> نائب مفعول مطلق، أي: إنفاقا سرا، أو منصوب على الحال، أي: مُسِرًّا. و<span class="hlt"><span class="qpc-hafs">﴿جهرا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿سرا﴾</span></span> منصوب. و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام للنفي. و<span class="hlt"><span class="qpc-hafs">﴿يستوون﴾</span></span> فعل مضارع مرفوع بثبوت النون لأنه من الأفعال الخمسة، والواو ضمير مبني في رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحمد لله بل أكثرهم لا يعلمون﴾</span></span>: الحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وبل حرف إضراب، وأكثرهم مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر.</p></div>"
  16,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضرب الله مثلا رجلين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلًا﴾</span></span> فعل وفاعل ومفعول به، ورجلين بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحدهما أبكم لا يقدر على شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أحدهما﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أبكم﴾</span></span> خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يقدر على شيء﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿أبكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو كلٌّ على مولاه﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كلٌّ﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿على مولاه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلٌّ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أينما يوجهه لا يأت بخير﴾</span></span>: أينما اسم شرط جازم في محل نصب على الظرفية المكانية متعلق بفعل الشرط، وقيل: بجوابه، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span> جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿بخير﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل يستوي هو ومن يأمر بالعدل وهو على صراط مستقيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام معناه النفي، ويستوي فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> تأكيد للفاعل المستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> عطف على الفاعل المستتر في <span class="hlt"><span class="qpc-hafs">﴿يستوي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على صراط مستقيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، والجملة الاسمية صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  16,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولله غيب السماوات والأرض وما أمر الساعة إلا كلمح البصر أو هو أقرب﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وغيب السماوات والأرض مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولله غيب السماوات والأرض﴾</span></span> مستأنفة لا محل لها من الإعراب، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وأمر مبتدأ، والساعة مضاف إليه، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كلمح البصر﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿لمح﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿البصر﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأقرب خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله على كل شيء قدير﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدير﴾</span></span>، وقدير خبر إن.</p></div>"
  16,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله أخرجكم من بطون أمهاتكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة أخرجكم خبر، و<span class="hlt"><span class="qpc-hafs">﴿من بطون أمهاتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تعلمون شيئا﴾</span></span>: الجملة في محل نصب على الحال من الكاف، أي: غير عالمين شيئًا، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم السمع والأبصار والأفئدة لعلكم تشكرون﴾</span></span>: الواو عاطفة، وجعل عطف على أخرجكم، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لجعل، والسمع مفعوله الأول، والأبصار والأفئدة عطف عليه، ولعل حرف ناسخ، والكاف اسمها، وجملة تشكرون خبرها.</p></div>"
  16,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم يروا إلى الطير مسخرات في جو السماء﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، ويروا فعل مضارع مجزوم بلم، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الطير﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، ومسخرات حال، و<span class="hlt"><span class="qpc-hafs">﴿في جو السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسخرات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما يمسكهن إلا الله﴾</span></span>: الجملة حالية، وما نافية، ويمسكهن فعل، وفاعل مستتر، ومفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يؤمنون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآيات اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>، وجملة يؤمنون صفة لقوم.</p></div>"
  16,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله جعل لكم من بيوتكم سكنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> خبر، مفعوله الأول <span class="hlt"><span class="qpc-hafs">﴿سكنًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول أول، و<span class="hlt"><span class="qpc-hafs">﴿من بيوتكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سكنًا﴾</span></span> وتقدم عليه، وإذا كانت <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> بمعنى خلق تعلق أحد الجارّين به، واكتفى بمفعول واحد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم من جلود الأنعام بيوتا تستخفونها يوم ظعنكم ويوم إقامتكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وجعل لكم من جلود الأنعام بيوتًا﴾</span></span> عطف على ما تقدم، وجملة تستخفونها صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بيوتًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم ظعنكم﴾</span></span> الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تستخفونها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم إقامتكم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يوم ظعنكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أصوافها وأوبارها وأشعارها أثاثا ومتاعا إلى حين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ومن أصوافها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من جلود الأنعام﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أثاثًا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿بيوتًا﴾</span></span>، أي: وجعل لكم من أصوافها أثاثًا، و<span class="hlt"><span class="qpc-hafs">﴿متاعًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أثاثًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى حين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متاعًا﴾</span></span>، أو صفة له.</p></div>"
  16,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله جعل لكم مما خلق ظلالا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿ظلالًا﴾</span></span> مفعوله الأول، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان حال، ومما جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ظلالا﴾</span></span>، وإذا كانت <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> بمعنى خلق تعلق أحد الجارّين به، واكتفى بمفعول واحد، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم من الجبال أكنانا﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم سرابيل تقيكم الحر﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿تقيكم الحر﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سرابيل﴾</span></span>، وحذف المعطوف للعلم به، أي: والبرد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسرابيل تقيكم بأسكم﴾</span></span>: الواو عاطفة، وسرابيل عطف على سرابيل الأولى، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقيكم﴾</span></span> صفة، وتقيكم فعل مضارع، وفاعل مستتر، والكاف مفعوله الأول، وبأسكم مفعوله الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك يتم نعمته عليكم لعلكم تسلمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يتم نعمته﴾</span></span> فعل وفاعل مستتر ومفعول به، ولعل حرف ناسخ، والكاف اسمها، وجملة تسلمون خبرها.</p></div>"
  16,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن تولوا فإنما عليك البلاغ المبين﴾</span></span>: الفاء استئنافية، وإن شرطية، وتولوا فعل الشرط، وجواب إن محذوف، أي: فلا غضاضة عليك، والفاء تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> أداة حصر كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿البلاغ﴾</span></span> مبتدأ مؤخر، والمبين صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإن تولوا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  16,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعرفون نعمت الله ثم ينكرونها وأكثرهم الكافرون﴾</span></span>: يعرفون فعل مضارع، والواو فاعل، ونعمة الله مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للتراخي، <span class="hlt"><span class="qpc-hafs">﴿ينكرونها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يعرفون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وأكثرهم﴾</span></span> الواو للحال، وأكثرهم مبتدأ، والكافرون خبره.</p></div>"
  16,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نبعث من كل أمة شهيدا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نبعث﴾</span></span> في محل جر مضاف إليه، ومن كل أمة حال، لأنه كان في الاصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>، وشهيدًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا يؤذن للذين كفروا ولا هم يستعتبون﴾</span></span>: ثم حرف عطف للتراخي، ولا نافية، ويؤذن فعل مضارع مبني لما لم يسمَّ فاعله، وللذين جار ومجرور متعلقان به،  ولا الواو عاطفة، ولا نافية، وهم مبتدأ، وجملة يستعتبون خبر.</p></div>"
  16,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا رأى الذين ظلموا العذاب﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة رأى مضاف إليه، والذين فاعل رأى، وجملة ظلموا صلة الذين لا محل لها من الإعراب، والعذاب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يخفف عنهم ولا هم ينظرون﴾</span></span>: الفاء رابطة لجواب إذا، ولا نافية، ويخفف فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، أي: العذاب، ولا عاطفة، وهم مبتدأ، وجملة ينظرون خبر.</p></div>"
  16,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا رأى الذين أشركوا شركاءهم﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة رأى مضاف إليه، والذين فاعل رأى، وجملة أشركوا صلة الذين لا محل لها من الإعراب، وشركاءهم مفعول رأى.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا هؤلاء شركاؤنا الذين كنا ندعو من دونك﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span> مبتدأ، وشركاؤنا خبر، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿شركاؤنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ندعو﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دونك﴾</span></span> جار ومجرور متعلقان بمحذوف حال من مفعول ندعو المحذوف، أي: ندعوهم ونعبدهم من دونك.</p><p><span class="hlt"><span class="qpc-hafs">﴿فألقوا إليهم القول إنكم لكاذبون﴾</span></span>: الفاء عاطفة، وألقوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إنكم لكاذبون﴾</span></span> إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وكاذبون خبرها، والجملة مقول القول.</p></div>"
  16,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وألقوا إلى الله يومئذ السلم﴾</span></span>: الواو عاطفة، وألقوا فعل وفاعل وهم الكفار، و<span class="hlt"><span class="qpc-hafs">﴿إلى الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوا﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، والسلم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وضل عنهم ما كانوا يفترون﴾</span></span>: الواو عاطفة، وضل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل ضل، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة يفترون خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  16,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين كفروا وصدوا عن سبيل الله زدناهم عذابا فوق العذاب بما كانوا يفسدون﴾</span></span>: الذين مبتدأ، خبره جملة <span class="hlt"><span class="qpc-hafs">﴿زدناهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿صدوا عن سبيل الله﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿زدناهم﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عذابًا﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿فوق العذاب﴾</span></span> ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عذابًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زدناهم﴾</span></span>، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: بسبب صدهم وإفسادهم، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة يفسدون خبرها.</p></div>"
  16,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نبعث في كل أمة شهيدا عليهم من أنفسهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نبعث﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿في كل أمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبعث﴾</span></span>، شهيدًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أنفسهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجئنا بك شهيدا على هؤلاء﴾</span></span>: الواو عاطفة، وجئنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿على هؤلاء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونزلنا عليك الكتاب تبيانا لكل شيء وهدى ورحمة وبشرى للمسلمين﴾</span></span>: الواو عاطفة، ونزلنا عطف على <span class="hlt"><span class="qpc-hafs">﴿جئنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿تبيانًا﴾</span></span> مفعول لأجله، أو حال، أي: مبينًا، و<span class="hlt"><span class="qpc-hafs">﴿لكل شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبيانًا﴾</span></span>، وهدى ورحمة وبشرى عطف على <span class="hlt"><span class="qpc-hafs">﴿تبيانًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للمسلمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرى﴾</span></span>.</p></div>"
  16,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يأمر بالعدل والإحسان وإيتاء ذي القربى﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأمر﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿بالعدل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأمر﴾</span></span>، والإحسان عطف على العدل، وكذلك <span class="hlt"><span class="qpc-hafs">﴿إيتاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذي القربى﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وينهى عن الفحشاء والمنكر والبغي يعظكم لعلكم تذكرون﴾</span></span>: الواو عاطفة، وينهى عطف على يأمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عن الفحشاء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينهى﴾</span></span>، وما بعده عطف عليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعظكم﴾</span></span> حال من فاعل يأمر وينهى، ولعل حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span> خبرها.</p></div>"
  16,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوفوا بعهد الله إذا عاهدتم﴾</span></span>: الواو عاطفة، وأوفوا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بعهد الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوفوا﴾</span></span>، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة عاهدتم مضاف إليها الظرف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تنقضوا الأيمان بعد توكيدها وقد جعلتم الله عليكم كفيلا﴾</span></span>: الواو عاطفة، ولا ناهية، وتنقضوا مضارع مجزوم بلا، والواو فاعل، والأيمان مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تنقضوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿توكيدها﴾</span></span> مضاف إليه، والواو حالية، والجملة حال من فاعل تنقضوا، وقد حرف تحققيق، و<span class="hlt"><span class="qpc-hafs">﴿جعلتم الله﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفيلًا﴾</span></span>، وكفيلًا مفعول به ثان لجعلتم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يعلم ما تفعلون﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلم...﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وتفعلون صلتها لا محل لها من الإعراب.</p></div>"
  16,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تكونوا كالتي نقضت غزلها من بعد قوة أنكاثا﴾</span></span>: الواو عاطفة، ولا ناهية، وتكونوا فعل ماض ناقص ناسخ مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كالتي﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر تكونوا، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿نقضت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، وغزلها مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من بعد قوة﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل نقضت، أي: محكمة له، أو من مفعوله، أي: محكمًا، و<span class="hlt"><span class="qpc-hafs">﴿أنكاثًا﴾</span></span> منصوب بفعل محذوف، أي: فجعلته أنكاثًا، أو بتضمين <span class="hlt"><span class="qpc-hafs">﴿نقضت﴾</span></span> معنى صيرت، فهو مفعول ثان، وقيل: النصب على المصدرية، لأن معنى نقضت نكثت، وقيل: هو حال من <span class="hlt"><span class="qpc-hafs">﴿غزلها﴾</span></span>، أي: منقوضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿تتخذون أيمانكم دخلا بينكم أن تكون أمة هي أربى من أمة﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span> حال من ضمير تكونوا، أي: لا تكونوا مثلها متخذين أيمانكم دخلًا، و<span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span> فعل مضارع وفاعل، وأيمانكم مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿دخلًا﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿بينكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿دخلًا﴾</span></span>، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها مفعول لأجله، أي: مخافة أن تكون، وتكون فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿أمة﴾</span></span> اسم تكون، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أربى﴾</span></span> خبر، والجملة خبر تكون، و<span class="hlt"><span class="qpc-hafs">﴿من أمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أربى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما يبلوكم الله به﴾</span></span>: إنما كافة ومكفوفة، وهي للحصر، و<span class="hlt"><span class="qpc-hafs">﴿يبلوكم الله﴾</span></span> فعل ومفعول مقدم وفاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبلوكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليبينن لكم يوم القيامة ما كنتم فيه تختلفون﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿يبينن﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة وجوبًا، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبينن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وجملة كنتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تختلفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تختلفون﴾</span></span> خبر كنتم.</p></div>"
  16,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو شاء الله لجعلكم أمة واحدة﴾</span></span>: الواو عاطفة، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿شاء الله﴾</span></span> فعل وفاعل، واللام واقعة في جواب لو، و<span class="hlt"><span class="qpc-hafs">﴿جعلكم﴾</span></span> فعل وفاعل مستتر ومفعول به أول، وأمة مفعول به ثان، وواحدة صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن يضل من يشاء﴾</span></span>: الواو حالية، ولكن حرف استدراك مهملة، لأنها خففت، و<span class="hlt"><span class="qpc-hafs">﴿يضل﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مفعول به، ويشاء صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يهدي من يشاء﴾</span></span> عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتسألن عما كنتم تعملون﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وتسألن فعل مضارع مرفوع، لأن النون لم تباشره، فهو معرب، وعلامة رفعه ثبوت النون المحذوفة لتوالي الأمثال، والواو المحذوفة لالتقاء الساكنين نائب فاعل، والنون المشددة هي نون التوكيد الثقيلة، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسألن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر كنتم.</p></div>"
  16,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تتخذوا أيمانكم دخلا بينكم﴾</span></span>: لا ناهية، وتتخذوا مضارع مجزوم بلا، والواو فاعل، وأيمانكم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿دخلًا﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿بينكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿دخلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتزل قدم بعد ثبوتها﴾</span></span>: الفاء فاء السببية المسبوقة بالنهي، و<span class="hlt"><span class="qpc-hafs">﴿تزل﴾</span></span> مضارع منصوب بإضمار أن، و<span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تزل﴾</span></span>، وثبوتها مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتذوقوا السوء بما صددتم عن سبيل الله ولكم عذاب عظيم﴾</span></span>: الواو عاطفة، وتذوقوا عطف على تزل، والسوء مفعول به، والباء حرف جر للسببية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي مع مدخولها في محل جر بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذوقوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عن سبيل الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صددتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> خبر مقدم، وعذاب مبتدأ مؤخر، وعظيم صفته.</p></div>"
  16,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تشتروا بعهد الله ثمنا قليلا﴾</span></span>: الواو عاطفة، ولا ناهية، وتشتروا فعل مضارع مجزوم بلا، و<span class="hlt"><span class="qpc-hafs">﴿بعهد الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشتروا﴾</span></span>، فالباء داخلة على المتروك، و<span class="hlt"><span class="qpc-hafs">﴿ثمنًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قليلًا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما عند الله هو خير لكم إن كنتم تعلمون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسمها، والظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير خبر، والجملة خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان به، وإن شرطية، وكنتم فعل ماض ناقص ناسخ في محل جزم فعل الشرط، والتاء اسم كان، وجملة تعلمون خبرها، وجواب الشرط محذوف دل عليه ما قبله، أي: فلا تنقضوا.</p></div>"
  16,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما عندكم ينفد وما عند الله باق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عندكم﴾</span></span> ظرف متعلق بالصلة، وجملة الصلة لا محل لها من الإعراب، وجملة ينفد خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وما عند الله باق﴾</span></span> عطف على ما سبق ومثله في الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجزين الذين صبروا أجرهم بأحسن ما كانوا يعملون﴾</span></span>: اللام واقعة في جواب قسم مقدر، ونجزين فعل مضارع مبني على الفتح لتأكيده بالنون المشددة، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿الذين صبروا﴾</span></span> مفعوله، وأجرهم مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجزين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بأحسن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجزين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة يعملون خبرها، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، والتقدير: بجزاء أحسن من عملهم الذي كانوا يعملونه في الدنيا، أو نجعل الأجر متناسبًا مع الأحسن من أعمالهم.</p></div>"
  16,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من عمل صالحا من ذكر أو أنثى﴾</span></span>: من اسم شرط جازم في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span> فعل ماض في محل جزم فعل الشرط، وصالحا: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. و<span class="hlt"><span class="qpc-hafs">﴿من ذكر﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أنثى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو مؤمن فلنحيينه حياة طيبة﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مؤمن﴾</span></span> خبر، والجملة حالية، <span class="hlt"><span class="qpc-hafs">﴿فلنحيينه﴾</span></span> الفاء رابطة، واللام: واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿نحيينه﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والهاء: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿حياة﴾</span></span> نائب عن المفعول المطلق، لأنه اسم مصدر. و<span class="hlt"><span class="qpc-hafs">﴿طيبة﴾</span></span> صفة. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلنحيينه﴾</span></span> جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول، والفاء داخلة لما في الموصوف من رائحة الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلنحيينه﴾</span></span> خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجزينهم أجرهم بأحسن ما كانوا يعملون﴾</span></span>: اللام واقعة في جواب القسم، ونجزينهم فعل مضارع مبني على الفتح لتأكيده بالنون المشددة، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعوله، و<span class="hlt"><span class="qpc-hafs">﴿أجرهم﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجزين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بأحسن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجزين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة يعملون خبرها، وقيل: ما موصولة، والتقدير: بجزاء أحسن من عملهم الذي كانوا يعملونه في الدنيا، أو نجعل الأجر متناسبًا مع الأحسن من أعمالهم.</p></div>"
  16,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا قرأت القرآن فاستعذ بالله من الشيطان الرجيم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف لما يستقبل من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿استعذ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قرأت﴾</span></span> في محل جر مضاف إليه، والقرآن مفعول به، أي: إذا أردت قراءة القرآن، والفاء رابطة للجواب، واستعذ فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استعذ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الشيطان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استعذ﴾</span></span> كذلك، والرجيم صفة.</p></div>"
  16,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه ليس له سلطان على الذين آمنوا وعلى ربهم يتوكلون﴾</span></span>: الجملة تعليلية للأمر، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿على الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>، وآمنوا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على ربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتوكلون﴾</span></span>.</p></div>"
  16,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما سلطانه على الذين يتولونه والذين هم به مشركون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿سلطانه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على الذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتولونه﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> الأولى، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشركون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مشركون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم به مشركون﴾</span></span> صلة الذين لا محل لها من الإعراب.</p></div>"
  16,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا بدلنا آية مكان آية﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل، و<span class="hlt"><span class="qpc-hafs">﴿بدلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿مكان﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿بدلنا﴾</span></span>، أو ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿بدلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله أعلم بما ينزل قالوا﴾</span></span>: الواو اعتراضية، والجملة اعتراضية بين شرط <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> وجوابها، لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ينزل﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما أنت مفتر بل أكثرهم لا يعلمون﴾</span></span>: الجملة مقول القول، وإنما كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مفتر﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿أكثرهم﴾</span></span> متبدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر، وحذف مفعول يعلمون للعلم به، أي: حقيقة التبديل والنسخ وفائدتهما.</p></div>"
  16,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل نزله روح القدس من ربك بالحق ليثبت الذين آمنوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿نزله﴾</span></span> فعل ومفعول به مقدم جملة، و<span class="hlt"><span class="qpc-hafs">﴿نزله﴾</span></span> مقول <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، وروح فاعل مؤخر، والقدس مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا بالحق، <span class="hlt"><span class="qpc-hafs">﴿وليثبت﴾</span></span> اللام لام التعليل، ويثبت فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والجار والمجرور من لام التعليل والمصدر المؤول من أن والفعل متعلقان بمحذوف مفعول لأجله، والفاعل مستتر تقديره: هو، والذين مفعول به، وجملة آمنوا صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهدى وبشرى للمسلمين﴾</span></span>: هذان المصدران معطوفان على محل <span class="hlt"><span class="qpc-hafs">﴿ليثبت﴾</span></span>، أي: تثبيتًا وهداية وبشرى.</p></div>"
  16,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد نعلم أنهم يقولون﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، ونعلم فعل مضارع، وفاعل مستتر، وأن وما في حيزها سدت مسد مفعولي نعلم، وأن حرف ناسخ، والهاء اسمها، وجملة يقولون خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما يعلمه بشر﴾</span></span>: الجملة مقول قولهم، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿يعلمه بشر﴾</span></span> فعل ومفعول به مقدم، وبشر فاعل مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لسان الذي يلحدون إليه أعجمي وهذا لسان عربي مبين﴾</span></span>: لسان مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يلحدون إليه﴾</span></span> صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أعجمي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿لسان﴾</span></span>، أي: غير مبين، وهذا مبتدأ، وعربي خبر، ومبين صفة.</p></div>"
  16,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين لا يؤمنون بآيات الله لا يهديهم الله ولهم عذاب أليم﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بآيات الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهديهم الله﴾</span></span> خبر إن، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، وأليم صفته.</p></div>"
  16,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما يفتري الكذب الذين لا يؤمنون بآيات الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، ويفتري فعل مضارع، والكذب مفعول به مقدم، والذين فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون بآيات الله﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنما يفتري...﴾</span></span> استئنافية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأولئك هم الكاذبون﴾</span></span>: الواو اعتراضية، أو عاطفة، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، والكاذبون خبر أولئك، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، والكاذبون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك هم الكاذبون﴾</span></span> اعتراضية، أو معطوفة على الجملة الاستئنافية قبلها، وعلى كلا الوجهين لا محل لها من الإعراب.</p></div>"
  16,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كفر بالله من بعد إيمانه إلا من أكره وقلبه مطمئن بالإيمان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿الذين لا يؤمنون بآيات الله﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأولئك هم الكاذبون﴾</span></span> اعتراض بين البدل والمبدل منه، وقيل: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ، والخبر محذوف، تقديره: فعليهم غضب لدلالة ما بعد <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> الثانية عليه، وقيل: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية وجوابها مقدر تقديره: <span class="hlt"><span class="qpc-hafs">﴿فعليهم غضب﴾</span></span>، لدلالة ما بعد <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> الثانية عليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿كفر بالله﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعد إيمانه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مستثنى متصل، وقيل: هو منقطع، وجملة <span class="hlt"><span class="qpc-hafs">﴿أكره﴾</span></span> صلة الموصول لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وقلبه﴾</span></span> الواو حالية، وقلبه مبتدأ، ومطمئن خبر، و<span class="hlt"><span class="qpc-hafs">﴿بالإيمان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مطمئن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن من شرح بالكفر صدرا فعليهم غضب من الله ولهم عذاب عظيم﴾</span></span>: الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولكن حرف ناسخ، واسمها ضمير الشأن، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ، وشرح فعل الشرط إن جعلت <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية، وصلة لا محل لها من الإعراب إن جعلت <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> موصولًا، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿صدرًا﴾</span></span> تمييز، أي: طاب به نفسًا واعتقده، <span class="hlt"><span class="qpc-hafs">﴿فعليهم﴾</span></span> الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وغضب مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، وعظيم صفة.</p></div>"
  16,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأنهم استحبوا الحياة الدنيا على الآخرة﴾</span></span>: الإشارة إلى ما تقدم من ذكر الغضب والعذاب، واسم الإشارة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بأنهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، أي: ثابت بسبب أنهم، فالباء للسببية، وأن حرف ناسخ، والهاء اسمها، وجملة استحبوا خبرها، أي: اختاروا، والحياة مفعول به، والدنيا صفة، و<span class="hlt"><span class="qpc-hafs">﴿على الآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استحبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن الله لا يهدي القوم الكافرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وأن الله﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بأنهم﴾</span></span>، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يهدي خبرها، والقوم مفعول به، والكافرين صفة القوم.</p></div>"
  16,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك الذين طبع الله على قلوبهم وسمعهم وأبصارهم﴾</span></span>: أولئك مبتدأ، والذين خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿طبع الله﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على قلوبهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طبع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سمعهم وأبصارهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿قلوبهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأولئك هم الغافلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الغافلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الغافلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم الغافلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>.</p></div>"
  16,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا جرم أنهم في الآخرة هم الخاسرون﴾</span></span>: لا نافية، وجرم فعل ماض، وأن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الخاسرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، والخاسرون خبره، والجملة خبر إن.</p></div>"
  16,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إن ربك للذين هاجروا من بعد ما فتنوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> للترتيب مع التراخي، وإن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن بمعنى أنه وليهم وناصرهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿هاجروا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هاجروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، أي: من بعد فتنتهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم جاهدوا وصبروا﴾</span></span>: ثم حرف عطف وتراخ، وجاهدوا وصبروا عطف على هاجروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك من بعدها لغفور رحيم﴾</span></span>: إن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من بعدها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، وغفور خبر إن الأول، ورحيم خبرها الثاني.</p></div>"
  16,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم تأتي كل نفس تجادل عن نفسها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتي﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿كل نفس﴾</span></span> فاعل تأتي، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجادل﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿عن نفسها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجادل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتوفى كل نفس ما عملت وهم لا يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿توفى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تجادل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كل نفس﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما عملت﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿توفى﴾</span></span> الثاني، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو حالية، أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يظلمون﴾</span></span> خبر.</p></div>"
  16,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضرب الله مثلا قرية﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وضرب الله مثلًا فعل وفاعل ومفعول به، وقرية بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>، أي: جعل القرية الموسومة بهذه السمات مثلًا لكل قوم أنعم الله عليهم فأبطرتهم النعمة فكفروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانت آمنة مطمئنة يأتيها رزقها رغدا من كل مكان﴾</span></span>: كانت فعل ماض ناقص ناسخ، واسمها مستتر، وآمنة خبرها، ومطمئنة خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> صفة لقرية، يأتيها فعل مضارع، ومفعول به مقدم، ورزقها فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتيها﴾</span></span> خبر ثالث، و<span class="hlt"><span class="qpc-hafs">﴿رغدًا﴾</span></span> حال من رزقها، أو نائب مفعول مطلق، أي: إتيانًا رغدا. و<span class="hlt"><span class="qpc-hafs">﴿من كل مكان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكفرت بأنعم الله فأذاقها الله لباس الجوع والخوف بما كانوا يصنعون﴾</span></span>: الفاء عاطفة، وكفرت فعل ماض، والفاعل مستتر يعود على القرية، و<span class="hlt"><span class="qpc-hafs">﴿بأنعم الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفرت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فأذاقها﴾</span></span> الفاء عاطفة للتعقيب، و<span class="hlt"><span class="qpc-hafs">﴿أذاقها﴾</span></span> فعل، ومفعول به مقدم، وفاعل مؤخر، ولباس الجوع والخوف مفعول ثان، والباء حرف جر للسببية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أو موصولة، والعائد محذوف، أي: بسبب صنعهم، أو بسبب الذي كانوا يصنعونه، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة يصنعون خبرها.</p></div>"
  16,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم رسول منهم فكذبوه﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وجاءهم رسول فعل ماض ومفعول به مقدم وفاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لرسول، <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span> الفاء حرف عطف، وكذبوه فعل ماض وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم العذاب وهم ظالمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأخذهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>، والعذاب فاعل، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وظالمون خبر، والجملة حالية.</p></div>"
  16,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكلوا مما رزقكم الله حلالا طيبا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقكم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿حلالًا﴾</span></span> حال، أو مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وطيبًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿واشكروا نعمت الله إن كنتم إياه تعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿واشكروا نعمة الله﴾</span></span> فعل أمر وفاعل ومفعول به، وإن شرطية، وكنتم فعل الشرط، وكنتم فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إياه﴾</span></span> مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>.</p></div>"
  16,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما حرم عليكم الميتة والدم ولحم الخنزير وما أهل لغير الله به﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿حرم﴾</span></span> فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرم﴾</span></span>، والميتة مفعول به، والدم ولحم الخنزير عطف على الميتة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أهل﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لغير الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن اضطر غير باغ ولا عاد﴾</span></span>: الفاء تفريعية، ومن اسم شرط جازم في محل رفع مبتدأ، واضطر فعل ماض مبني لما لم يُسَمَّ فاعله في محل جزم فعل الشرط، ونائب الفاعل مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿غير باغ﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿لا عاد﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿باغ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن الله غفور رحيم﴾</span></span>: الفاء رابطة، وإن حرف ناسخ، ولفظ الجلالة اسمها، وغفور خبرها الأول، ورحيم خبرها الثاني، والجملة في محل جزم جواب الشرط.</p></div>"
  16,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقولوا لما تصف ألسنتكم الكذب﴾</span></span>: لا ناهية، وتقولوا مضارع مجزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لما تصف﴾</span></span> اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع مدخولها في محل جر باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ألسنتكم﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿تصف﴾</span></span>، والكذب مفعول <span class="hlt"><span class="qpc-hafs">﴿تصف﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا حلال﴾</span></span> مقول القول، <span class="hlt"><span class="qpc-hafs">﴿وهذا حرام﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿هذا حلال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لتفتروا﴾</span></span> بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿لما تصف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفتروا﴾</span></span>، والكذب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تفتروا﴾</span></span>، أو لـ<span class="hlt"><span class="qpc-hafs">﴿تقولوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا حلال﴾</span></span> بدل منه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أي: ولا تقولوا الكذب لما تصفه ألسنتكم فتقولوا: هذا حرام وهذا حلال، وقيل: إن <span class="hlt"><span class="qpc-hafs">﴿الكذب﴾</span></span> بدل من مفعول <span class="hlt"><span class="qpc-hafs">﴿تصف﴾</span></span> المحذوف، أي: لما تصفه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يفترون على الله الكذب لا يفلحون﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة يفترون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكذب﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلحون﴾</span></span> خبر إن.</p></div>"
  16,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متاع قليل ولهم عذاب أليم﴾</span></span>: متاع خبر لمبتدأ محذوف، أي: ذلك العمل الذي هو ديدنهم متاع قليل الفائدة، أو مبتدأ محذوف الخبر، أي: لهم متاع، و<span class="hlt"><span class="qpc-hafs">﴿قليل﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿أليم﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>.</p></div>"
  16,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا ما قصصنا عليك من قبل﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وعلى الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هادوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما ظلمناهم ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿ظلمناهم﴾</span></span> فعل وفاعل ومفعول به، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> مخففة مهملة فهي حرف استدراك، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنفسهم﴾</span></span> مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"
  16,119,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إن ربك للذين عملوا السوء بجهالة ثم تابوا من بعد ذلك وأصلحوا﴾</span></span>: ثم حرف عطف للتراخي، وإن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، أي: غفور للذين، و<span class="hlt"><span class="qpc-hafs">﴿عملوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿السوء﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بجهالة﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span>، أي: عملوا السوء جاهلين، <span class="hlt"><span class="qpc-hafs">﴿ثم تابوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عملوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تابوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿وأصلحوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تابوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك من بعدها لغفور رحيم﴾</span></span>: إن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من بعدها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفور﴾</span></span>، واللام المزحلقة، وغفور خبر إن، ورحيم خبر ثان.</p></div>"
  16,120,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن إبراهيم كان أمة قانتا لله حنيفا ولم يك من المشركين﴾</span></span>: إن حرف ناسخ، وإبراهيم اسمها، وجملة كان خبرها، واسم كان مستتر تقديره: هو، أي: إبراهيم، و<span class="hlt"><span class="qpc-hafs">﴿أمة﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿قانتًا﴾</span></span> خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قانتًا﴾</span></span>، وحنيفًا خبر ثالث، <span class="hlt"><span class="qpc-hafs">﴿ولم يك﴾</span></span> لم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يك﴾</span></span> فعل مضارع ناقص ناسخ  مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه السكون، وحذفت النون للتخفيف، واسم <span class="hlt"><span class="qpc-hafs">﴿يك﴾</span></span> مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المشركين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿يك﴾</span></span>.</p></div>"
  16,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿شاكرا لأنعمه اجتباه وهداه إلى صراط مستقيم﴾</span></span>: شاكرًا خبر رابع لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لأنعمه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شاكرًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اجتباه﴾</span></span> خبر خامس، <span class="hlt"><span class="qpc-hafs">﴿وهداه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اجتباه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى صراط﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هداه﴾</span></span>، ومستقيم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صراط﴾</span></span>.</p></div>"
  16,122,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناه في الدنيا حسنة وإنه في الآخرة لمن الصالحين﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿آتيناه﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حسنة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حسنة﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرة﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، <span class="hlt"><span class="qpc-hafs">﴿من الصالحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  16,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أوحينا إليك أن اتبع ملة إبراهيم حنيفا﴾</span></span>: ثم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن اتبع﴾</span></span>: أن تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبع﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ملة إبراهيم﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿اتبع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حنيفًا﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان من المشركين﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص ناسخ، واسمها مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من المشركين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  16,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما جعل السبت على الذين اختلفوا فيه﴾</span></span>: إنما كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والسبت نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> فهو بمثابة المفعول الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿اختلفوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اختلفوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك ليحكم بينهم يوم القيامة فيما كانوا فيه يختلفون﴾</span></span>: الواو عاطفة والجملة بعدها معطوفة، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، وجملة يحكم خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span> خبر كانوا.</p></div>"
  16,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادع إلى سبيل ربك بالحكمة والموعظة الحسنة﴾</span></span>: ادع فعل أمر، وفاعله مستتر تقديره: أنت، والمفعول محذوف، أي: الناس، و<span class="hlt"><span class="qpc-hafs">﴿إلى سبيل ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالحكمة﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا بها، والموعظة الحسنة عطف على الحكمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجادلهم بالتي هي أحسن﴾</span></span>: الواو عاطفة، وجادلهم عطف على ادع، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جادلهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وأحسن خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك هو أعلم بمن ضل عن سبيله﴾</span></span>: إن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأعلم خبر، والجملة خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿بمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة ضل صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عن سبيله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو أعلم بالمهتدين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿بالمهتدين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>.</p></div>"
  16,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن عاقبتم فعاقبوا بمثل ما عوقبتم به﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن شرطية، وعاقبتم فعل ماض، والتاء فاعل، وهو في محل جزم فعل الشرط، <span class="hlt"><span class="qpc-hafs">﴿فعاقبوا﴾</span></span> الفاء رابطة، وعاقبوا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بمثل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاقبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مضاف إليه، وجملة عوقبتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عوقبتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فعاقبوا﴾</span></span> في محل جزم جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن صبرتم لهو خير للصابرين﴾</span></span>: اللام موطئة للقسم، وإن شرطية، وصبرتم في محل جزم فعل الشرط، واللام واقعة في جواب القسم لتقدمه، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿للصابرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>.</p></div>"
  16,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واصبر﴾</span></span>: الواو استئنافية، واصبر فعل أمر، وفاعله مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿واصبر﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما صبرك إلا بالله ولا تحزن عليهم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وصبرك مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والواو عاطفة، ولا ناهية، وتحزن فعل مضارع مجزوم بلا، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحزن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تك في ضيق مما يمكرون﴾</span></span>: الواو عاطفة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تكُ﴾</span></span> فعل مضارع مجزوم بلا وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، واسم <span class="hlt"><span class="qpc-hafs">﴿تكُ﴾</span></span> مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿في ضيق﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿تكُ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يمكرون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  16,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله مع الذين اتقوا والذين هم محسنون﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، <span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بمحذوف خبر، والذين مضاف إليه، واتقوا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومحسنون خبر، والجملة صلة الذين لا محل لها من الإعراب.</p></div>"
