quran[55]{c,v,t}:
  54,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اقتربت الساعة وانشق القمر﴾</span></span>: اقتربت الساعة فعل ماضٍ وفاعل، وانشق القمر عطف على الجملة المتقدمة.</p></div>"
  54,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن يروا آية يعرضوا ويقولوا سحر مستمر﴾</span></span>: الواو عاطفة، وإن شرطية، ويروا فعل الشرط مجزوم وعلامة جزمه حذف النون، والواو فاعل، ويعرضوا جواب الشرط، ويقولوا عطف على <span class="hlt"><span class="qpc-hafs">﴿يعرضوا﴾</span></span>، وسحر خبر لمبتدأ محذوف، أي: هذا، ومستمر صفة لسحر.</p></div>"
  54,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذبوا واتبعوا أهواءهم﴾</span></span>: الواو عاطفة، وكذبوا فعل وفاعل، واتبعوا فعل وفاعل، وأهواءهم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكل أمر مستقر﴾</span></span>: الواو للاستئناف، وكل أمر مبتدأ، ومستقر خبره، والجملة استئنافية لا محل لها من الإعراب، وقيل: كل مبتدأ، والخبر محذوف، أي معمول به، أو معطوفًا على الساعة.</p></div>"
  54,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم من الأنباء ما فيه مزدجر﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وجاءهم فعل ماضٍ ومفعول به، ومن الأنباء حال من ما، وما موصولة أو موصوفة، وعلى الحالين هي فاعل جاءهم، وفيه: جار ومجرور متعلقان بمحذوف خبر مقدم. ومزدجر: مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فيه مزدجر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  54,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حكمة بالغة﴾</span></span>: حكمة خبر لمبتدأ محذوف، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في الآية السابقة، وبالغة صفة لحكمة، ومفعول بالغة محذوف، والتقدير: بالغة غايتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء عاطفة، وما نافية، أي: لم تغن النذر شيئا. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية للإنكار في محل نصب نائب مفعول مطلق والتقدير: فأيَّ إغناءٍ تغني النذر، أو في محل نصب مفعول به مقدَّم والتقدير: فأيَّ شيءٍ تغني النذر.</p><p><span class="hlt"><span class="qpc-hafs">﴿تغن﴾</span></span>: فعل مضارع مرفوع بالضمة المقدرة على الياء المحذوفة للوصل لالتقاء الساكنين.</p><p><span class="hlt"><span class="qpc-hafs">﴿النذر﴾</span></span>: فاعل تغن.</p></div>"
  54,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتول عنهم يوم يدع الداع إلى شيء نكر﴾</span></span>: الفاء الفصيحة، وتول فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره: أنت، وعنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>، ويوم ظرفٌ متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span> أو مفعولٌ به لفعل محذوف تقديره: اذكر، وجملة يدع في محل جر مضاف إليه، والداعي فاعل يدعو، وإلى شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعو﴾</span></span>، ونكر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>.</p></div>"
  54,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خشعا أبصارهم يخرجون من الأجداث﴾</span></span>: خشعًا حال من الفاعل في <span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span>، وأبصارهم فاعل الصفة المشبهة <span class="hlt"><span class="qpc-hafs">﴿خشعًا﴾</span></span> مرفوع بالضمة، وضمير الغياب في محل جر مضاف إليه، ويخرجون مضارع مرفوع بثبوت النون والواو في محل رفع فاعل، ومن الأجداث: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأنهم جراد منتشر﴾</span></span>: كأن حرف ناسخ للتشبيه، وضمير الغياب في محل نصب اسم كأن، وجراد خبر كأن مرفوع بالضمة، ومنتشر: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جراد﴾</span></span>، والجملة في محل نصب حال من الفاعل في <span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span>.</p></div>"
  54,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مهطعين إلى الداع يقول الكافرون هذا يوم عسر﴾</span></span>: مهطعين منصوب على الحال أيضًا من فاعل يخرجون، وإلى الداع جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهطعين﴾</span></span>، وجملة يقول الكافرون استئنافية، كأنها قد وقعت جوابًا لسؤال عما نشأ من وصف اليوم بالأهوال وأهله بسوء الحال، أو الجملة حالية من فاعل يخرجون، فالأحوال من الواو إذًا أربعة: واحد مقدم، وثلاثة مؤخرة، وجملة: هذا يوم عسر مقول القول.</p></div>"
  54,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قبلهم قوم نوح فكذبوا عبدنا وقالوا مجنون وازدجر﴾</span></span>: كذبت فعل ماضٍ، والتاء للتأنيث، وقبلهم ظرف زمان منصوب لإضافته متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، وقوم نوح فاعل كذبت، فكذبوا الفاء عاطفة، وكذبوا فعل وفاعل، وعبدنا مفعول به، وقالوا عطف على كذبوا، ومجنون خبر لمبتدأ محذوف، أي: هو مجنون، وازدجر معطوف على قالوا، أي: لم يكتفوا بهذا القول، بل ضموا إليه زجره ونهره، وقيل: هو معطوف على هو مجنون، فهو في حيز مقولهم، أي: قالوا: هو مجنون، وازدجر فعل ماضٍ مبني لما لم يسمَّ فاعله.</p></div>"
  54,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فدعا ربه أني مغلوب فانتصر﴾</span></span>: الفاء عاطفة، ودعا ربه فعل ماضٍ، وفاعل مستتر، ومفعول به، وأن وما في حيزها في محل نصب بنزع الخافض، وأن حرف ناسخ، والياء اسمها، ومغلوب خبرها، والفاء عاطفة، وانتصر فعل أمر، ومتعلق انتصر محذوف.</p></div>"
  54,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ففتحنا أبواب السماء بماء منهمر﴾</span></span>: الفاء عاطفة على محذوف مقدر، أي: فاستجبنا لنوح دعائه ففتحنا، وفتحنا فعل وفاعل، وأبواب السماء مفعول به، وبماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فتحنا﴾</span></span>، والباء للتعدية على المبالغة حيث جعل الماء كالآلة التي يفتح بها، أو الباء للملابسة، أي: متلبسة بماء منهمر، والجار والمجرور متعلقان بمحذوف في موضع نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿منهمر﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span>.</p></div>"
  54,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفجرنا الأرض عيونا﴾</span></span>: فجرنا عطف على فتحنا، والأرض مفعول به، وعيونًا تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿فالتقى الماء على أمر قد قدر﴾</span></span>: فالتقى عطف على فجرنا، والماء فاعل التقى، وعلى أمر جار ومجرور متعلقان بالتقى، وأفادت <span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span> معنى التعليل، وقيل: في موضع نصب على الحال، وجملة قد قدر صفة لأمر.</p></div>"
  54,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحملناه على ذات ألواح ودسر﴾</span></span>: الواو عاطفة، وحملناه فعل وفاعل ومفعول به، وعلى ذات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملناه﴾</span></span>، وألواح مضاف إليه، ودسر عطف على ألواح.</p></div>"
  54,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تجري بأعيننا جزاء لمن كان كفر﴾</span></span>: الجملة صفة لذات دسر، وذات ألواح في الأصل صفة لسفينة، فهي صفة ثانية، وتجري فعل مضارع مرفوع، وعلامة رفعه ضمة مقدرة على الياء، وبأعيننا جار ومجرور في موضع نصب على الحال من الضمير في تجري، أي: مكلوءة، ومحفوظة بأعيننا، وجزاء مفعول لأجله، أو: بتقدير جازيناهم جزاء، أو مصدر في موضع الحال، ولمن جار ومجرور متعلقان بجزاء، وجملة كان صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  54,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد تركناها آية فهل من مدكر﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وتركناها فعل ماضٍ وفاعل ومفعول به، والضمير يعود على الفعلة، وهي إغراقهم على الشكل المذكور، وقيل: يعود على السفينة، وآية حال، أو مفعول به ثانٍ إذا كان تركنا بمعنى جعلناها، والفاء عاطفة، وهل حرف استفهام، ومن حرف جر صلة، ومدكر مجرور لفظًا مرفوع محلًّا على أنه مبتدأ محذوف الخبر، تقديره: موجود.</p></div>"
  54,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكيف كان عذابي ونذر﴾</span></span>: الفاء الفصيحة، وكيف اسم استفهام في محل نصب خبر كان المقدم، وكان عذابي: كان فعل ماض ناقص، وعذاب اسمها، والياء مضاف إليه، ونذر معطوف على عذابي مرفوع بالضمة المقدرة على ما قبل ياء المتكلم المحذوفة، والياء في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿فكيف كان...﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد يسرنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مبتدأ مرفوع محلا  مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، وخبره محذوف تقديره: موجود.</p></div>"
  54,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت عاد﴾</span></span>: فعل ماضٍ وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكيف كان عذابي ونذر﴾</span></span>: الفاء الفصيحة، وكيف اسم استفهام في محل نصب خبر كان المقدم، وكان عذابي: كان فعل ماض ناقص، وعذاب اسمها، والياء مضاف إليه، ونذر معطوف على عذابي مرفوع بالضمة المقدرة على ما قبل ياء المتكلم المحذوفة، والياء في محل جر مضاف إليه، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أرسلنا عليهم ريحا صرصرا في يوم نحس مستمر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا عليهم خبرها، والجملة مستأنفة لا محل لها من الإعراب، وريحًا مفعول أرسلنا، وصرصرًا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ريحًا﴾</span></span>، ومستمر نعت للنحس أو لليوم.</p></div>"
  54,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزع الناس كأنهم أعجاز نخل منقعر﴾</span></span>: الجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ريحًا﴾</span></span>، وكأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وأعجاز نخل خبرها، ومنقعر صفة لنخل، والجملة حالية، وهي حال مقدرة.</p></div>"
  54,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكيف كان عذابي ونذر﴾</span></span>: الفاء الفصيحة، وكيف اسم استفهام في محل نصب خبر كان المقدم، وكان عذابي: كان فعل ماض ناقص، وعذاب اسمها، والياء مضاف إليه، ونذر معطوف على عذابي مرفوع بالضمة المقدرة على ما قبل ياء المتكلم المحذوفة، والياء في محل جر مضاف إليه، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد يسرنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مبتدأ مرفوع محلا  مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، وخبره محذوف تقديره: موجود.</p></div>"
  54,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت ثمود بالنذر﴾</span></span>: فعل ماضٍ وفاعل، وبالنذر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  54,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا أبشرا منا واحدا نتبعه﴾</span></span>: الفاء عاطفة، وقالوا فعل ماضٍ وفاعل، وأبشرًا الهمزة للاستفهام، وبشرًا منصوب على الاشتغال، أي: بفعل مضمر يدل عليه ما بعده، أي: أنتبع بشرًا، ومنا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بشرًا﴾</span></span>، وواحدًا فيه وجهان أظهرهما: أنه نعت لـ<span class="hlt"><span class="qpc-hafs">﴿بشرًا﴾</span></span> إلا أنه يشكل عليه تقديم الصفة المؤولة على الصفة الصريحة، ويجاب بأن منا حينئذ ليس وصفًا، بل حال من <span class="hlt"><span class="qpc-hafs">﴿واحدًا﴾</span></span> قدم عليه، والوجه الثاني: أنه نصب على الحال من الهاء في نتبعه، والبشر يقع على الواحد والجمع، ونتبعه فعل مضارع، وفاعل مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا إذا لفي ضلال وسعر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وإذًا حرف جواب وجزاء مهمل، ولفي اللام المزحلقة، وفي ضلال جار ومجرور متعلقان بمحذوف خبر إن، وسعر معطوف على ضلال.</p></div>"
  54,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أؤلقي الذكر عليه من بيننا﴾</span></span>: الهمزة للاستفهام الإنكاري، وألقي فعل ماض مبني لما لم يسمَّ فاعله، والذكر نائب فاعل، وعليه جار ومجرور متعلقان بألقي، ومن بيننا حال من الهاء في عليه، أي: منفردًا .</p><p><span class="hlt"><span class="qpc-hafs">﴿بل هو كذاب أشر﴾</span></span>: بل: حرف إضراب وعطف، وهو مبتدأ، وكذاب خبر، وأشر نعت.</p></div>"
  54,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيعلمون غدا من الكذاب الأشر﴾</span></span>: الجملة مقول قول محذوف تقديره: قال تعالى. والسين للاستقبال، ويعلمون فعل وفاعل، وغدًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>، ومن اسم استفهام في محل رفع مبتدأ، والكذاب خبره، والأشر صفة، والجملة المعلقة لتصدر الاستفهام بها سدت مسد مفعولي يعلمون.</p></div>"
  54,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا مرسلو الناقة فتنة لهم فارتقبهم واصطبر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومرسلو الناقة خبرها، والجملة مستأنفة لا محل لها من الإعراب، وفتنة مفعول لأجله، ولهم جار ومجرور متعلقان بفتنة، والفاء الفصيحة، وارتقبهم فعل أمر وفاعل مستتر ومفعول به، واصطبر عطف على ارتقبهم، ومتعلق <span class="hlt"><span class="qpc-hafs">﴿واصطبر﴾</span></span> محذوف، أي: واصطبر على أذاهم.</p></div>"
  54,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونبئهم أن الماء قسمة بينهم كل شرب محتضر﴾</span></span>: الواو عاطفة، ونبئهم فعل أمر وفاعل مستتر تقديره: أنت، والهاء مفعول أول، وأن وما في حيزها في موضع المفعول الثاني والثالث، لأن نبأ تنصب ثلاثة مفاعيل، وأن حرف ناسخ، والماء اسمها، وقسمة خبرها، وبينهم ظرف متعلق بمحذوف صفة قسمة، أو بقسمة، لأنها بمعنى مقسومة، وكل مبتدأ، وشرب مضاف إليه، ومحتضر خبر كل.</p></div>"
  54,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنادوا صاحبهم فتعاطى فعقر﴾</span></span>: الفاء عاطفة، ونادوا فعل ماض وفاعل، والمعطوف عليه محذوف، أي: فتمادوا على ذلك، والأحسن أن تكون الفصيحة، وصاحبهم مفعول به، فتعاطى عطف على فنادوا، فعقر عطف على تعاطى.</p></div>"
  54,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكيف كان عذابي ونذر﴾</span></span>: الفاء الفصيحة، وكيف اسم استفهام في محل نصب خبر كان المقدم، وكان عذابي: كان حرف ناسخ، وعذاب اسمها، والياء مضاف إليه، ونذر معطوف على عذابي مرفوع بالضمة المقدرة على ما قبل ياء المتكلم المحذوفة، والياء في محل جر مضاف إليه، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أرسلنا عليهم صيحة واحدة فكانوا كهشيم المحتظر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا خبرها، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وصيحة مفعول به، وواحدة صفة، فكانوا عطف على أرسلنا، والواو اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿كهشيم﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿هشيم﴾</span></span> مضاف إليه، والمحتظر مضاف إليه.</p></div>"
  54,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد يسرنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مبتدأ مرفوع محلا  مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، وخبره محذوف تقديره: موجود.</p></div>"
  54,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قوم لوط بالنذر﴾</span></span>: فعل ماضٍ وفاعل، وبالنذر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  54,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أرسلنا عليهم حاصبا إلا آل لوط نجيناهم بسحر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا خبرها، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وحاصبًا مفعول به، وإلا أداة استثناء، وآل لوط مستثنى بإلا، وفي هذا الاستثناء وجهان أحدهما: أنه متصل، ويكون المعنى أنه أرسل الحاصب على الجميع إلا أهله، فإنه لم يرسل عليهم، والثاني: أنه منقطع، ويكون المعنى أنه لم يرسل على آل لوط، والوجه هو الأول، ونجيناهم فعل وفاعل، وبسحر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناهم﴾</span></span>.</p></div>"
  54,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نعمة من عندنا كذلك نجزي من شكر﴾</span></span>: نعمة نائب مفعول مطلق لأنه اسم مصدر، والتقدير: أنعمنا على لوط ومن معه نعمة، أو: مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿من عندنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لنعمة، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ونجزي فعل مضارع مرفوع، ومن موصول مفعول به، وجملة شكر صلة الموصول لا محل لها من الإعراب.</p></div>"
  54,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أنذرهم بطشتنا فتماروا بالنذر﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأنذرهم فعل وفاعل مستتر، ومفعول به أول، وبطشتنا مفعول به ثانٍ، أو هو منصوب بنزع الخافض قولان، والفاء حرف عطف، وتماروا فعل ماض، والواو فاعل، وبالنذر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تماروا﴾</span></span>.</p></div>"
  54,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد راودوه عن ضيفه فطمسنا أعينهم﴾</span></span>: الجملة عطف على الجملة السابقة، والواو حرف عطف، واللام جواب للقسم المحذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿راودوه﴾</span></span> فعل ماض، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن ضيفه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودوه﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فطمسنا﴾</span></span> فعل ماض معطوف على <span class="hlt"><span class="qpc-hafs">﴿راودوه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أعينهم﴾</span></span> مفعول به، والفاء عاطفة، ومعطوفها محذوف، أي: فقلنا لهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فذوقوا عذابي ونذر﴾</span></span>: الفاء في جواب الشرط المقدر، و<span class="hlt"><span class="qpc-hafs">﴿ذوقوا﴾</span></span> فعل الأمر مبني على حذف النون، والواو في محل رفع فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عذابي﴾</span></span> مفعول به منصوب بفتحة مقدرة على ما قبل ياء المتكلم، والياء في محل جر مضاف إليه، ونذر: مثل <span class="hlt"><span class="qpc-hafs">﴿عذابي﴾</span></span>، والياء المحذوفة في محل جر مضاف إليه، والجملة في محل جزم جواب الشرط المقدر، أي: إن أصررتم على الكفر فذوقوا، والجملة الشرطية كلها في محل نصب مقول القول.</p></div>"
  54,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صبحهم بكرة عذاب مستقر﴾</span></span>: عطف أيضًا، وبكرة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿صبحهم﴾</span></span>، أي: من غير يوم معين، وعذاب فاعل، ومستقر نعت لعذاب، أي: لا يزول عنهم.</p></div>"
  54,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذوقوا عذابي ونذر﴾</span></span>: الفاء في جواب الشرط المقدر، وفعل الأمر مبني على حذف النون، والواو في محل رفع فاعل، وعذابي مفعول به منصوب بفتحة مقدرة عل ما قبل ياء المتكلم، والياء في محل جر مضاف إليه، ونذر: مثل عذابي، والياء المحذوفة في محل جر مضاف إليه، والجملة في محل جزم جواب الشرط المقدر، أي: إن أصررتم على الكفر فذوقوا، والجملة الشرطية كلها في محل نصب مقول القول.</p></div>"
  54,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد يسرنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مبتدأ مرفوع محلا  مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، وخبره محذوف تقديره: موجود.</p></div>"
  54,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاء آل فرعون النذر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿آل﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span> مضاف إليه مجرور بالفتحة لأنه ممنوع من الصرف، و<span class="hlt"><span class="qpc-hafs">﴿النذر﴾</span></span> فاعل مرفوع بالضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد جاء﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p></div>"
  54,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبوا بآياتنا كلها فأخذناهم أخذ عزيز مقتدر﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وكذبوا ماضٍ مبني على الضم والواو فاعل، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، وكلها تأكيد لآياتنا، فأخذناهم: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذناهم﴾</span></span> فعل وفاعل ومفعول به، وأخذ: مفعول مطلق، وعزيز: مضاف إليه، ومقتدر: صفة لعزيز، والإضافة من إضافة المصدر لفاعله.</p></div>"
  54,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أكفاركم خير من أولئكم﴾</span></span>: أكفاركم: الهمزة للاستفهام الإنكاري، الذي هو بمعنى النفي، وكفاركم مبتدأ، وخير خبر، ومن أوليائكم جار ومجرور متعلقان بخير.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم لكم براءة في الزبر﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام الإنكاري، والتقدير: بل ألكم براءة ...؟ و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وبراءة مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿في الزبر﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لبراءة.</p></div>"
  54,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون نحن جميع منتصر﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، أو بمعنى: بل، فقط، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، ونحن مبتدأ، وجميع خبر، ومنتصر نعت لجميع، لأنه بمعنى جمع، والجملة مقول القول، وإنما وحد منتصر للفظ بـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>، فإنه واحد في اللفظ، وإن كان اسمًا للجماعة كالرهط والجيش.</p></div>"
  54,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيهزم الجمع ويولون الدبر﴾</span></span>: السين حرف استقبال، ويهزم فعل مضارع مبني لما لم يسمَّ فاعله، والجمع نائب فاعل، ويولون عطف على سيهزم، والدبر مفعول به.</p></div>"
  54,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل الساعة موعدهم والساعة أدهى وأمر﴾</span></span>: بل حرف إضراب وعطف، والساعة مبتدأ، وموعدهم خبر، والواو حرف عطف، والساعة مبتدأ، وأدهى خبر، وأمر عطف على الساعة، ولك أن تجعل الواو للحال.</p></div>"
  54,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المجرمين في ضلال وسعر﴾</span></span>: إن حرف ناسخ، والمجرمين اسمها، وفي ضلال جار ومجرور متعلقان بمحذوف خبرها، وسعر معطوف بالواو مجرور بالكسرة، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يسحبون في النار على وجوههم﴾</span></span>: يوم الظرف متعلق بقول محذوف، أي: يقال لهم يوم يسحبون، وجملة يسحبون في محل جر بإضافة الظرف إليها، وفي النار جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسحبون﴾</span></span>، وعلى وجوههم جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذوقوا مس سقر﴾</span></span>: ذوقوا فعل أمر مبني على حذف النون، والواو فاعل، والجملة مقول القول المقدر، ومس مفعول به، وسقر مضاف إليه، وهي علم لجهنم، ولذلك منعت من الصرف، لأنها علم مؤنث.</p></div>"
  54,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كل شيء خلقناه بقدر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وكل شيء نصب على الاشتغال بفعل محذوف يدل عليه ما بعده، أي: إنا خلقنا كل شيء خلقناه، وجملة الفعل المحذوف في محل رفع خبر إن، وجملة خلقناه مُفسِّرة لا محل لها من الإعراب، وبقدر جار ومجرور متعلقان بمحذوف حال من كل، أي: مقدرًا محكمًا مرتبًا.</p></div>"
  54,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أمرنا إلا واحدة كلمح بالبصر﴾</span></span>: الواو عاطفة، وما نافية، وأمرنا مبتدأ، وإلا أداة حصر، وواحدة خبر أمرنا، وكلمح جار ومجرور متعلقان بمحذوف حال من متعلق الأمر، وهو الشيء المأمور بالوجود، أي: حال كونه يوجد سريعًا، وبالبصر جار ومجرور متعلقان بلمح.</p></div>"
  54,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أهلكنا أشياعكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أشياعكم﴾</span></span> مفعول به، وضمير الخطاب في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد أهلكنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مجرور لفظًا مرفوع محلا على أنه مبتدأ، وخبره محذوف تقديره: موجود.</p></div>"
  54,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكل شيء فعلوه في الزبر﴾</span></span>: الواو عاطفة، وكل مبتدأ، وشيء مضاف إليه، وجملة فعلوه صفة، وفي الزبر خبر.</p></div>"
  54,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكل صغير وكبير مستطر﴾</span></span>: الواو عاطفة، وكل مبتدأ، وصغير مضاف إليه مجرور بالكسرة، وكبير معطوف بالواو مجرور بالكسرة، ومستطر خبر مرفوع بالضمة، والجملة لا محل لها من الإعراب عطفًا على سابقتها.</p></div>"
  54,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في جنات ونهر﴾</span></span>: إن حرف ناسخ، والمتقين اسمها، وفي جنات جار ومجرور متعلقان بمحذوف خبرها، ونهر عطفت على جنات.</p></div>"
  54,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في مقعد صدق﴾</span></span>: الجار والمجرور بدل بعض من كل من قوله: في جنات، لأن المقعد بعض الجنات، ولك أن تعلقه بمحذوف على أنه خبر ثانٍ لإن.</p><p><span class="hlt"><span class="qpc-hafs">﴿عند مليك﴾</span></span>: ظرف متعلق بمحذوف صفة لجنات، أو لمقعد، وقيل: هو خبر ثان ٍأو ثالث لإن، ومليك صيغة مبالغة.</p><p><span class="hlt"><span class="qpc-hafs">﴿مقتدر﴾</span></span>: نعت، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
