quran[52]{c,v,t}:
  69,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الحاقة﴾</span></span>: الحاقة مبتدأ وما بعده خبره، أو هو خبر لمبتدأ محذوف.</p></div>"
  69,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: ما اسم استفهام مبني على السكون في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحاقة﴾</span></span>: خبر المبتدأ. والجملة الاسمية خبر الحاقة، والرابط هو إعادة المبتدأ بلفظه. وجملة <span class="hlt"><span class="qpc-hafs">﴿الحاقة ما الحاقة﴾</span></span> ابتدائية.</p></div>"
  69,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، أو اعتراضية. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>: فعل ماضٍ، والكاف مفعول به، والفاعل مستتر، والجملة خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: الثانية اسم استفهام أيضا في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحاقة﴾</span></span>: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما الحاقة﴾</span></span> في محل نصب سدت مسد المفعولين الثاني والثالث للفعل <span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>، لأن أدرى ينصب ثلاثة مفاعيل. وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أدراك ما الحاقة﴾</span></span> معطوفة على الجملة السابقة، أو اعتراضية لا محل لها من الإعراب.</p></div>"
  69,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وكذبت فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثمود﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعاد﴾</span></span>: عطف على ثمود.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالقارعة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  69,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما﴾</span></span>: الفاء عاطفة، وأما حرف شرط وتفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثمود﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأهلكوا﴾</span></span>: الفاء رابطة لجواب أما، وأهلكوا فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالطاغية﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكوا﴾</span></span>، والجملة خبر ثمود.</p></div>"
  69,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما﴾</span></span>: الواو عاطفة، وأما حرف شرط وتفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأهلكوا﴾</span></span>: الفاء رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وأهلكوا فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿بريح﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأهلكوا﴾</span></span> خبر عاد.</p><p><span class="hlt"><span class="qpc-hafs">﴿صرصر﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ريح﴾</span></span> مجرورة بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿عاتية﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ريح﴾</span></span> أيضًا.</p></div>"
  69,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سخرها﴾</span></span>: فعل ماضٍ ومفعول به، والفاعل مستتر يعود على الله، والجملة صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿ريح﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخرها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبع﴾</span></span>: نصب على الظرفية الزمانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليال﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وثمانية﴾</span></span>: عطف على سبع ليال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيام﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسوما﴾</span></span>: نعت لسبع ليال وثمانية أيام، أو مصدر منصوب بفعل من لفظه، أي: تحسمهم حسوما، أو حال من مفعول سخرها، أي: ذات حسوم، أو مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿فترى﴾</span></span>: الفاء عاطفة، وترى القوم فعل مضارع، وفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿القوم﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿صرعى﴾</span></span>: حال، لأن الرؤية هنا بصرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأنهم﴾</span></span>: كأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿أعجاز﴾</span></span>: خبر كأن مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿نخل﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿خاوية﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿نخل﴾</span></span> مجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأنهم...﴾</span></span> حال من القوم، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  69,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span>: الفاء عاطفة، وهل حرف استفهام.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>: فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿باقية﴾</span></span>: مجرور لفظًا منصوب محلا، لأنه مفعول ترى.</p></div>"
  69,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء﴾</span></span>: كلام مستأنف لا محل له من الإعراب، أو معطوف على سابقه، وجاء فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن﴾</span></span>: عطف على فرعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿قبله﴾</span></span>: ظرف زمان متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿والمؤتفكات﴾</span></span>: عطف أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالخاطئة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>.</p></div>"
  69,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعصوا﴾</span></span>: الفاء حرف عطف، وعصوا فعل ماضٍ والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فعصوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أخذة﴾</span></span>: نائب مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿رابية﴾</span></span>: نعت، وفتح همزة أخذة، لأنها مصدر مرة، وليست مصدر هيئة، وإنما معنى الهيئة مستفاد من النعت.</p></div>"
  69,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>: ظرفية حينية، أو رابطة.</p><p><span class="hlt"><span class="qpc-hafs">﴿طغى﴾</span></span>: فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الماء﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿حملناكم﴾</span></span>: فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل والكاف مفعول به، والجملة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿في الجارية﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملناكم﴾</span></span>.</p></div>"
  69,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنجعلها﴾</span></span>: اللام للتعليل، ونجعلها فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملناكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول أول لنجعلها، والفاعل ضمير مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>: مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتعيها﴾</span></span>: منصوب بالعطف على نجعل، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أُذن﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿واعية﴾</span></span>: نعت لأُذن.</p></div>"
  69,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط متعلق بجوابه.</p><p><span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>: فعل ماض مبني لما لم يسمَّ فاعله، والجملة في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نفخة﴾</span></span>: نائب الفاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span>: نعت مرفوع.</p></div>"
  69,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحملت﴾</span></span>: فعل ماضٍ مبني لما لم يسمَّ فاعله، معطوف على نفخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span>: نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿والجبال﴾</span></span>: عطف على الأرض.</p><p><span class="hlt"><span class="qpc-hafs">﴿فدكتا﴾</span></span>: عطف أيضًا، ودك فعل ماضٍ مبني لما لم يسمَّ فاعله، والتاء تاء التأنيث الساكنة، والألف نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿دكة﴾</span></span>: نائب مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span>: نعت منصوب.</p></div>"
  69,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيومئذ﴾</span></span>: الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿وقعت﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة والتقدير: يوم إذ نفخ في الصور نفخة واحدة وحملت الأرض والجبال...إلخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقعت﴾</span></span>: فعل ماضٍ والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿الواقعة﴾</span></span>: فاعل مرفوع.</p></div>"
  69,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وانشقت﴾</span></span>: الواو عاطفة، وانشقت فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهي﴾</span></span>: الفاء عاطفة، وهي مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿واهية﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة.</p><p><span class="hlt"><span class="qpc-hafs">﴿واهية﴾</span></span>: خبر هي.</p></div>"
  69,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والملك﴾</span></span>: الواو حالية، والملك مبتدأ مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿على أرجائها﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر الملك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويحمل﴾</span></span>: فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿عرش﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوقهم﴾</span></span>: ظرف منصوب متعلق بمحذوف حال من العرش، أي: حال كونه فوق الملائكة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحمل﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثمانية﴾</span></span>: فاعل مرفوع.</p></div>"
  69,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تعرضون﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تعرضون﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تخفى﴾</span></span>: فعل مضارع مرفوع بضمة مقدرة على الألف.</p><p><span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خافية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿خافية﴾</span></span>: فاعل مرفوع، والجملة حال من الواو في: تعرضون.</p></div>"
  69,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما﴾</span></span>: الفاء استئنافية، وأما حرف شرط أو تفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أُوتي﴾</span></span>: أوتي فعل ماضٍ مبني لما لم يسمَّ فاعله.</p><p><span class="hlt"><span class="qpc-hafs">﴿كتابه﴾</span></span>: مفعول به ثانٍ، والأول نائب الفاعل المستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بيمينه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أُتي﴾</span></span>، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: الفاء رابطة لجواب أما، وجملة يقول خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿هاؤم﴾</span></span>: اسم فعل أمر بمعنى خذوا، والفاعل مستتر تقديره أنتم، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿اقرءوا﴾</span></span>: فعل أمر مبني على حذف النون، والواو فاعل، والجملة في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿هاؤم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كتابيه﴾</span></span>: مفعول به منصوب بفتحة مقدرة على ما قبل الياء، والياء مضاف إليه، والهاء للسكت، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأما من أوتي...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  69,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ظننت﴾</span></span>: فعل ماضٍ والتاء فاعل والجملة في محل خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿أني﴾</span></span>: أن حرف ناسخ، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ملاقٍ﴾</span></span>: خبر أن، وعلامة رفعه الضمة المقدرة على الياء المحذوفة لالتقاء الساكنين، وجملة أن سدت مسد مفعولي ظن.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسابيه﴾</span></span>: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿ملاق﴾</span></span>، لأنه اسم الفاعل، والياء مضاف إليه، والهاء للسكت.</p></div>"
  69,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهو﴾</span></span>: الفاء الفصيحة وهو مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿في عيشة﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿راضية﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عيشة﴾</span></span> مجرور.</p></div>"
  69,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في جنة﴾</span></span>: جار ومجرور متعلقان بمحذوف بدل من قوله في: عيشة.</p><p><span class="hlt"><span class="qpc-hafs">﴿عالية﴾</span></span>: صفة.</p></div>"
  69,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قطوفها﴾</span></span>: مبتدأ مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿دانية﴾</span></span>: خبر مرفوع، والجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿جنة﴾</span></span>.</p></div>"
  69,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>: فعل أمر والواو فاعل، والجملة مقول قول محذوف، أي: يقال لهم ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿واشربوا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هنيئا﴾</span></span>: حال منصوبة، أي: مهنئين.</p><p><span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر للسلبية، وما مصدرية، أو موصولة والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هنيئا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أسلفتم﴾</span></span>: فعل ماضٍ، والتاء ضمير في محل رفع فاعل، والجملة لا محل لها من الإعراب على كل حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿في الأيام﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسلفتم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الخالية﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الأيام﴾</span></span> مجرور.</p></div>"
  69,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما﴾</span></span>: الواو عاطفة، وأما حرف شرط أو تفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أُوتي﴾</span></span>: فعل ماضٍ مبني لما لم يسمَّ فاعله.</p><p><span class="hlt"><span class="qpc-hafs">﴿كتابه﴾</span></span>: مفعول به ثانٍ، والأول نائب الفاعل المستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بشماله﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أُتي﴾</span></span>، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: الفاء رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وجملة يقول خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف نداء، والمنادى محذوف، أو لمجرد التنبيه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليتني﴾</span></span>: ليت حرف ناسخ للتمني، والنون للوقاية، والياء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف جزم وقلب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أُوت﴾</span></span>: فعل مضارع مبني لما لم يسمَّ فاعله مجزوم وعلامة الجزم حذف حرف العلة، ونائب الفاعل مستتر، والجملة في محل رفع خبر ليت.</p><p><span class="hlt"><span class="qpc-hafs">﴿كتابيه﴾</span></span>: مفعول به ثانٍ، والياء مضاف إليه، والهاء للسكت.</p></div>"
  69,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولم﴾</span></span>: الواو عاطفة، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿أدر﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم استفهام في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسابيه﴾</span></span>: خبرها، والياء مضاف إليه، والهاء للسكت، والجملة سدت مسد مفعولي أدرِ المعلقة عن العمل بالاستفهام.</p></div>"
  69,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا ليتها كانت القاضية﴾</span></span>: الياء للنداء، أو للتنبيه، وليت اسمها، والضمير يعود على الموتة في الدنيا، وجملة كانت خبر ليت، واسم كان ضمير مستتر يعود على الموتة، والقاضية خبر كانت منصوب.</p></div>"
  69,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>: فعل ماض.</p><p><span class="hlt"><span class="qpc-hafs">﴿عنِّي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماليه﴾</span></span>: فاعل أغنى، والمفعول محذوف للتعميم، والهاء للسكت.</p><p>وقيل: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في قوله <span class="hlt"><span class="qpc-hafs">﴿ما أغنى﴾</span></span> استفهامية في محل نصب نائب مفعول مطلق لـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، والاستفهام للتوبيخ، وبخ نفسه فقال: أيَّ إغناءٍ أغنى عني مالي، أو في محل نصب مفعول به والتقدير: أيَّ شيءٍ أغنى عني مالي.</p></div>"
  69,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هلك﴾</span></span>: فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿عني﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هلك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلطانيه﴾</span></span>: فاعل هلك، والياء في محل جر بالإضافة، والهاء للسكت.</p></div>"
  69,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خذوه﴾</span></span>: فعل أمر مبني على حذف النون، والواو فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فغلوه﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿خذوه﴾</span></span>، والخطاب للزبانية الموكلين بالعذاب، وجملة خذوه مقول القول لقول مقدر، وجملة القول مستأنفة لا محل لها من الإعراب، مسوقة للإجابة عن سؤال مقدر، كأنه قيل: وما يفعل به بعد هذا التحسر الصادر عنه؟ فقيل: يقال: خذوه.</p></div>"
  69,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجحيم﴾</span></span>: مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده.</p><p><span class="hlt"><span class="qpc-hafs">﴿صلوه﴾</span></span>: فعل أمر، وفاعل، ومفعول به.</p></div>"
  69,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿في سلسلة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسلكوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذرعها﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبعون﴾</span></span>: خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذراعا﴾</span></span>: تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاسلكوه﴾</span></span>: الفاء عاطفة، واسلكوه فعل أمر والواو فاعل والهاء مفعول به.</p></div>"
  69,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان لا يؤمن بالله العظيم﴾</span></span>: إنّه: إنّ حرف ناسخ، والهاء اسمها، وكان: فعل ناقص ناسخ، واسم كان مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمن﴾</span></span> خبر كان، وبالله: الباء حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، والعظيم: صفة لله، والجملة تعليل مستأنف فلا محل لها من الإعراب.</p></div>"
  69,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يحض﴾</span></span>: فعل مضارع مرفوع، وفاعله مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿على طعام﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحض﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿المسكين﴾</span></span>: مضاف إليه.</p></div>"
  69,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فليس﴾</span></span>: الفاء الفصيحة، وليس فعل ماضٍ ناقص.</p><p><span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span>: ظرف متعلق بمحذوف حال، أو متعلق بما في الخبر من معنى الاستقرار.</p><p><span class="hlt"><span class="qpc-hafs">﴿ههنا﴾</span></span>: ها للتنبيه، وهنا اسم إشارة في محل نصب على الظرفية متعلق بما تعلق به اليوم أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span>: اسم ليس.</p></div>"
  69,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿طعام﴾</span></span>: عطف على حميم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من غسلين﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿طعام﴾</span></span>.</p></div>"
  69,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأكله﴾</span></span>: فعل مضارع، والهاء مفعول به مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿الخاطئون﴾</span></span>: فاعل ليأكله مرفوع بالواو.</p></div>"
  69,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span>: الفاء استئنافية، ولا صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أُقسم﴾</span></span>: فعل مضارع، وفاعله مستتر تقديره: أنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span>: فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا أقسم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  69,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، وما موصولة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> السابقة في محل جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span>: فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تبصرون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  69,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقول﴾</span></span>: اللام المزحلقة، وقول خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿كريم﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>، والجملة لا محل لها من الإعراب، لأنها جواب القسم.</p></div>"
  69,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: اسم ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿بقول﴾</span></span>: الباء: حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿قول﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿شاعر﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تؤمنون إيمانا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تؤمنون﴾</span></span>: فعل وفاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿تؤمنون﴾</span></span> اعتراضية لا محل لها من الإعراب.</p></div>"
  69,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> صلة لتأكيد النفي.</p><p><span class="hlt"><span class="qpc-hafs">﴿بقول كاهن﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿بقول شاعر﴾</span></span>، وكاهن: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تتذكرون تذكرًا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span>: فعل وفاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span> اعتراضية لا محل لها من الإعراب.</p></div>"
  69,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>: خبر لمبتدأ محذوف، أي: هو تنزيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿العالمين﴾</span></span>: مضاف إليه.</p></div>"
  69,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span>: الواو عاطفة، ولو شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تقوَّل﴾</span></span>: فعل ماضٍ، وفاعله مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقول﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بعض﴾</span></span>: نائب عن المفعول المطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأقاويل﴾</span></span>: مضاف إليه.</p></div>"
  69,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأخذنا﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿باليمين﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، والجملة لا محل لها من الإعراب، جواب شرط غير جازم.</p></div>"
  69,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقطعنا﴾</span></span>: عطف على لـ<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قطعنا﴾</span></span>، أو بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿الوتين﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة الظاهرة.</p></div>"
  69,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس.</p><p><span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿أحد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحد﴾</span></span>: اسم <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حاجزين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿حاجزين﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب.</p></div>"
  69,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، والكلام معطوف على جواب القسم السابق، فهو من جملة المقسوم به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتذكرة﴾</span></span>: اللام: المزحلقة، وتذكرة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>.</p></div>"
  69,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا﴾</span></span>: عطف أيضًا، وإن و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنعلم﴾</span></span>: اللام المزحلقة، ونعلم فعل مضارع والفاعل مستتر، وجملة نعلم خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: حرف ناسخ ينصب الاسم ويرفع الخبر، وأن وما بعدها سدت مسد مفعولي نعلم.</p><p><span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر أن المقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿مكذبين﴾</span></span>: اسم أن المؤخر.</p></div>"
  69,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لحسرة﴾</span></span>: اللام: المزحلقة، وحسرة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿على الكافرين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حسرة﴾</span></span>.</p></div>"
  69,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لحق﴾</span></span>: اللام: المزحلقة، وحق خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿اليقين﴾</span></span>: مضاف إليه.</p></div>"
  69,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبح﴾</span></span>: الفاء الفصيحة، وسبّح فعل أمر.</p><p><span class="hlt"><span class="qpc-hafs">﴿باسم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبح﴾</span></span>، أو الباء صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>.</p></div>"
