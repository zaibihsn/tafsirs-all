quran[88]{c,v,t}:
  38,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ص﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿والقرآن ذي الذكر﴾</span></span>: الواو: حرف قسم، والقرآن: مجرور بواو القسم، والجار والمجرور متعلقان بفعل القسم المحذوف، وجواب القسم محذوف على الأرجح تقديره: <span class="hlt"><span class="qpc-hafs">﴿إنه لمعجز﴾</span></span> أو <span class="hlt"><span class="qpc-hafs">﴿لقد جاءكم الحق﴾</span></span>، وذي: نعت للقرآن، والذكر: مضاف إليه.</p></div>"
  38,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل الذين كفروا في عزة وشقاق﴾</span></span>: بل: حرف عطف وإضراب انتقالي، والذين: اسم موصول مبني في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وكفر: فعل ماض، والواو: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في عزة﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، <span class="hlt"><span class="qpc-hafs">﴿وشقاق﴾</span></span>: عطف على عزة.</p></div>"
  38,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كم أهلكنا من قبلهم من قرن فنادوا ولات حين مناص﴾</span></span>: كم: خبرية في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، وأهلكنا: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قرن﴾</span></span>: تمييز كم الخبرية. <span class="hlt"><span class="qpc-hafs">﴿فنادوا﴾</span></span>: الفاء عاطفة، ونادوا: فعل ماض، والواو: فاعل. <span class="hlt"><span class="qpc-hafs">﴿ولات﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لات﴾</span></span>: حرف مشبه بـ<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>، واسمها محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿الحين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span>: خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مناص﴾</span></span>: مضاف إليه.</p></div>"
  38,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعجبوا أن جاءهم منذر منهم وقال الكافرون هذا ساحر كذاب﴾</span></span>: الواو عاطفة، وعجبوا: فعل ماض، والواو فاعل، وأن: مصدرية، وهي مع ما في حيزها مصدر منصوب بنزع الخافض، أي: عجبوا من مجيء منذر، و<span class="hlt"><span class="qpc-hafs">﴿منذر﴾</span></span>: فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لمنذر، والواو: حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿قال الكافرون﴾</span></span>: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ساحر﴾</span></span>: خبر، و<span class="hlt"><span class="qpc-hafs">﴿كذاب﴾</span></span>: نعت لساحر.</p></div>"
  38,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أجعل الآلهة إلها واحدا إن هذا لشيء عجاب﴾</span></span>: الهمزة للاستفهام، وجعل: فعل ماض، وفاعله مستتر تقديره هو، والآلهة: مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span>: مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿واحدًا﴾</span></span>: صفة، و<span class="hlt"><span class="qpc-hafs">﴿إن هذا لشيء﴾</span></span>: إن حرف ناسخ، وهذا اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>: خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عجاب﴾</span></span>: صفة لشيء.</p></div>"
  38,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وانطلق الملأ منهم أن امشوا واصبروا على آلهتكم﴾</span></span>: الواو: عاطفة. والجملة بعدها معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قال الكافرون﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿انطلق الملأ﴾</span></span>: فعل ماض، وفاعل. و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، والجملة بعدها تفسيرية لـ<span class="hlt"><span class="qpc-hafs">﴿انطلق﴾</span></span>، لأنه متضمن معنى القول، لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿واصبروا﴾</span></span> عطف على امشوا. و<span class="hlt"><span class="qpc-hafs">﴿على آلهتكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبروا﴾</span></span> على حذف مضاف، أي: على عبادتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لشيء يراد﴾</span></span>: الجملة تعليل للأمر بالصبر، وإن حرف ناسخ، وهذا اسمها، واللام المزحلقة، وشيء: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يراد﴾</span></span> صفة لشيء.</p></div>"
  38,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما سمعنا بهذا في الملة الآخرة إن هذا إلا اختلاق﴾</span></span>: ما: نافية، وسمعنا: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سمعنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الملة﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من هذا، والآخرة: نعت، وإن: نافية، وهذا: مبتدأ، وإلا: أداة حصر، واختلاق: خبر هذا.</p></div>"
  38,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أؤنزل عليه الذكر من بيننا﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>: فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الذكر﴾</span></span>: نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بيننا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل هم في شك من ذكري بل لما يذوقوا عذاب﴾</span></span>: بل: حرف إضراب انتقالي عن مقدر، فكأنه قال: <span class="hlt"><span class="qpc-hafs">﴿إنكارهم للذكر ليس عن علم، بل هم في شك منه﴾</span></span>. وهم: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿من ذكري﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: إضراب انتقالي أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>: حرف نفي وجزم، ويذوقوا: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، والواو فاعل، وعذاب: مفعول به، وعلامة نصبه فتحة مقدرة على ما قبل ياء المتكلم المحذوفة لمراعاة الفواصل.</p></div>"
  38,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم عندهم خزائن رحمة ربك العزيز الوهاب﴾</span></span>: أم: حرف عطف بمعنى بل، فهي منقطعة بمعنى: بل وهمزة الاستفهام، والاستفهام للإنكار والتوبيخ، و<span class="hlt"><span class="qpc-hafs">﴿عندهم﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿خزائن﴾</span></span>: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه، والكاف: ضمير مبني في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الوهاب﴾</span></span>: صفتان لـ<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>.</p></div>"
  38,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لهم ملك السماوات والأرض وما بينهما﴾</span></span>: أم: حرف عطف بمعنى بل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ملك﴾</span></span>: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿السماوات﴾</span></span>: مضاف إليه، والأرض: معطوف مجرور، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: عطف على السماوات، و بينهما: ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليرتقوا في الأسباب﴾</span></span>: الفاء الفصيحة، واللام لام الأمر، ويرتقوا: فعل مضارع مجزوم بلام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿في الأسباب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرتقوا﴾</span></span>.</p></div>"
  38,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جند ما هنالك مهزوم من الأحزاب﴾</span></span>: جند: خبر لمبتدأ محذوف، أي: <span class="hlt"><span class="qpc-hafs">﴿هم جند﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نكرة تامة نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span> على سبيل التحقير، أي: هم جند حقير، أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> صلة. و<span class="hlt"><span class="qpc-hafs">﴿هنالك﴾</span></span>: اسم إشارة في محل نصب على الظرفية المكانية، متعلق بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مهزوم﴾</span></span>: نعت ثالث لجند. و<span class="hlt"><span class="qpc-hafs">﴿من الأحزاب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهزوم﴾</span></span>، أو متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>.</p></div>"
  38,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قبلهم قوم نوح وعاد وفرعون ذو الأوتاد﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿نوح﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span>: عطف على قوم نوح، و<span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>: عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿ذو﴾</span></span>: نعت مرفوع بالواو، لأنه من الأسماء الستة، والأوتاد: مضاف إليه مجرور.</p></div>"
  38,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وثمود وقوم لوط وأصحاب الأيكة أولئك الأحزاب﴾</span></span>: الواو عاطفة،وثمود: معطوف مرفوع، <span class="hlt"><span class="qpc-hafs">﴿وقوم﴾</span></span>: عطف أيضا، و<span class="hlt"><span class="qpc-hafs">﴿لوط﴾</span></span>: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿وأصحاب الأيكة﴾</span></span>: عطف أيضا، و<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>: اسم الإشارة مبتدأ، والأحزاب: خبر.</p></div>"
  38,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كل إلا كذب الرسل فحق عقاب﴾</span></span>: إن نافية لا عمل لها، وكل: مبتدأ، وإلا أداة حصر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذب الرسل﴾</span></span>: خبر كل، <span class="hlt"><span class="qpc-hafs">﴿فحق﴾</span></span>: الفاء حرف عطف، وحق فعل ماض، وعقاب: فاعله مرفوع، وعلامة رفعه الضمة المقدرة على ما قبل ياء المتكلم المحذوفة لمراعاة الفواصل.</p></div>"
  38,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ينظر هؤلاء إلا صيحة واحدة ما لها من فواق﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>: فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>: اسم إشارة مبني على الكسر في محل رفع فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span>: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما ينظر هؤلاء...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة، وفواق: اسم مجرور لفظًا مرفوع محلا على أنه مبتدأ مؤخر.</p></div>"
  38,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا ربنا عجل لنا قطنا قبل يوم الحساب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقالوا: فعل وفاعل، وربنا: منادى مضاف محذوف منه حرف النداء، وعجل: فعل دعاء، وفاعله مستتر وجوبًا تقديره أنت، ولنا: جار ومجرور متعلقان به، وقطنا: مفعول به، وقبل: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عجل﴾</span></span> أيضًا، أو بمحذوف حال، ويوم: مضاف إليه وهو مضاف، والحساب: مضاف إليه.</p></div>"
  38,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اصبر على ما يقولون واذكر عبدنا داود ذا الأيد إنه أواب﴾</span></span>: اصبر: فعل أمر، وفاعله مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿على ما يقولون﴾</span></span>: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>: فعل وفاعل، وهي صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي يقولونه. واذكر: عطف على اصبر، وعبدنا: مفعول به، وداود: بدل، وذا: نعت لداود، والأيد: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه أواب﴾</span></span>: تعليل لكونه من أصحاب الأيد، وإن: حرف توكيد ونصب، والهاء: اسمها، وأواب: خبرها.</p></div>"
  38,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا سخرنا الجبال معه يسبحن بالعشي والإشراق﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿سخرنا الجبال﴾</span></span>: من الفعل والفاعل والمفعول خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسبحن﴾</span></span> حالية من الجبال، ويسبح: فعل مضارع، والنون: في محل رفع فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالعشي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسبحن﴾</span></span>، والإشراق: عطف على <span class="hlt"><span class="qpc-hafs">﴿بالعشي﴾</span></span>.</p></div>"
  38,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والطير محشورة كل له أواب﴾</span></span>: الواو عاطفة، والطير: عطف على الجبال، أو مفعول به لفعل محذوف دل عليه ما قبله، أي: وسخرنا الطير، ومحشورة: حال، وكل: مبتدأ، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أواب﴾</span></span>، وأواب: خبر كل.</p></div>"
  38,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وشددنا ملكه وآتيناه الحكمة وفصل الخطاب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿شددنا ملكه﴾</span></span>: فعل، وفاعل، ومفعول به، وآتيناه: فعل، وفاعل، ومفعول به أول، والحكمة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿فصل الخطاب﴾</span></span> عطف على الحكمة، والخطاب: مضاف إليه.</p></div>"
  38,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهل أتاك نبأ الخصم إذ تسوروا المحراب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وهل: حرف استفهام معناه التعجب والتشويق، و<span class="hlt"><span class="qpc-hafs">﴿أتاك نبأ﴾</span></span>: فعل ماض، ومفعول به مقدم، وفاعل مؤخر، والخصم: مضاف إليه، وإذ: اسم مبني على السكون في محل نصب مفعول به لمحذوف، أي: هل أتاك نبأ تحاكم الخصم إذ تسوروا، أو متعلق بالخصم لما فيه من معنى الفعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تسوروا﴾</span></span> في محل جر مضاف إليه، وتسوروا: فعل ماض، والواو فاعل، والمحراب: مفعول به.</p></div>"
  38,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ دخلوا على داود ففزع منهم﴾</span></span>: إذ: اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> الأولى، أو في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تسوروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>: في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿على داود﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>، والفاء عاطفة، وفزع: فعل ماض، وفاعله مستتر تقديره: هو، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فزع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لا تخف خصمان بغى بعضنا على بعض﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ولا ناهية، وتخف: فعل مضارع مجزوم بلا، وفاعله مستتر تقديره: أنت، وخصمان: خبر لمبتدأ محذوف، أي: نحن خصمان، وجملة <span class="hlt"><span class="qpc-hafs">﴿بغى﴾</span></span> صفة لخصمان، وبعضنا: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بغى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاحكم بيننا بالحق ولا تشطط واهدنا إلى سواء الصراط﴾</span></span>:  الفاء الفصيحة، واحكم: فعل أمر، وفاعله مستتر، وبيننا: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿احكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿احكم﴾</span></span>، واهد: فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى سواء﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اهدنا﴾</span></span>، والصراط: مضاف إليه.</p></div>"
  38,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا أخي له تسع وتسعون نعجة ولي نعجة واحدة﴾</span></span>: إن حرف ناسخ، وهذا اسمها، وأخي: بدل من هذا، أو خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، وتسع: مبتدأ مؤخر، والجملة خبر إن إذا أعربت <span class="hlt"><span class="qpc-hafs">﴿أخي﴾</span></span> بدل، أو خبر ثان إذا أعربت <span class="hlt"><span class="qpc-hafs">﴿أخي﴾</span></span> خبر، وتسعون: عطف على تسع، ونعجة: تمييز، ولي: جار ومجرور متعلقان بمحذوف خبر مقدم، ونعجة: مبتدأ مؤخر، وواحدة: نعت.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال أكفلنيها وعزني في الخطاب﴾</span></span>: الفاء عاطفة، وقال: فعل ماض، وجملة <span class="hlt"><span class="qpc-hafs">﴿أكفلنيها﴾</span></span>: من الفعل، والفاعل المستتر، والمفعولين مقول القول، وعزني: عطف على فقال، و<span class="hlt"><span class="qpc-hafs">﴿في الخطاب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عزني﴾</span></span>.</p></div>"
  38,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لقد ظلمك بسؤال نعجتك إلى نعاجه﴾</span></span>: قال: فعل ماض، والفاعل مستتر، واللام: جواب قسم محذوف، وقد: حرف تحقيق، وظلمك: فعل وفاعل مستتر، والكاف: مفعول به، وبسؤال: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظلمك﴾</span></span>، ونعجتك: مضاف إليه، من إضافة المصدر إلى مفعوله، والفاعل محذوف، أي: بأن سألك نعجتك، و<span class="hlt"><span class="qpc-hafs">﴿إلى نعاجه﴾</span></span>: جار ومجرور متعلقان بمحذوف تقديره ليضمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كثيرا من الخلطاء ليبغي بعضهم على بعض﴾</span></span>: الواو عاطفة، أو حالية، وإن حرف ناسخ، وكثيرا اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الخلطاء﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لكثيرًا، واللام المزحلقة، ويبغي بعضهم: فعل مضارع، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبغي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبغي بعضهم﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات وقليل ما هم﴾</span></span>: إلا: أداة استثناء، والذين: مستثنى منصوب، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وآمن: فعل ماض، والواو: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عملوا﴾</span></span> عطف على آمنوا، و<span class="hlt"><span class="qpc-hafs">﴿الصالحات﴾</span></span>: مفعول به، والواو حالية، وقليل: خبر مقدم، وما: صلة لتأكيد القلة، وهم: مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وظن داود أنما فتناه فاستغفر ربه وخر راكعا وأناب﴾</span></span>: عطف على محذوف، وظن داود: فعل وفاعل، وأنما: كافة ومكفوفة، وهي مع مدخولها سدت مسد مفعولي ظن، وفتناه: فعل ماض، وفاعل، ومفعول به، فاستغفر: عطف على وظن، وربه: مفعول به، وخر: عطف أيضًا، والفاعل مستتر تقديره: هو، وراكعًا: حال، وأناب: عطف أيضًا.</p></div>"
  38,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فغفرنا له ذلك وإن له عندنا لزلفى وحسن مآب﴾</span></span>: عطف أيضًا، وغفرنا: فعل وفاعل، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفرنا﴾</span></span>، وذلك: مفعول به، وإن: الواو عاطفة، وإن حرف ناسخ، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿عندنا﴾</span></span>: ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، واللام المزحلقة، وزلفى: اسم إن، وحسن: عطف على زلفى، ومآب: مضاف إليه.</p></div>"
  38,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا داود إنا جعلناك خليفة في الأرض﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو في محل نصب مقول قول محذوف حالًا من فاعل غفرنا، أي: غفرنا له قائلين. ويا: حرف نداء، وداود: منادى مفرد علم مبني على الضم، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلناك﴾</span></span>: خبرها، وجعلناك: فعل ماض، وفاعل، ومفعول به أول، وخليفة: مفعول جعلنا الثاني، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لخليفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاحكم بين الناس بالحق﴾</span></span>: الفاء الفصيحة، واحكم: فعل أمر، وفاعله مستتر تقديره أنت، وبين الناس: ظرف مكان منصوب على الظرفية متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿احكم﴾</span></span>، وبالحق جار ومجرور متعلقان بمحذوف حال من فاعل احكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تتبع الهوى فيضلك عن سبيل الله﴾</span></span>: الواو عاطفة، ولا ناهية، وتتبع: فعل مضارع مجزوم بلا، وفاعله مستتر تقديره أنت، والهوى: مفعول به، والفاء: هي فاء السببية لوقوعها في جواب النهي، ويضلك: فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والفاعل مستتر تقديره هو يعود على الهوى، والكاف: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن سبيل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضلك﴾</span></span>، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق أي: لا يكن اتباع للهوى فإضلال، ولفظ الجلالة: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يضلون عن سبيل الله لهم عذاب شديد بما نسوا يوم الحساب﴾</span></span>: الجملة تعليلية للنهي عن اتباع الهوى، وإن حرف ناسخ، والذين اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يضلون﴾</span></span> صلة الذين لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عن سبيل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضلون﴾</span></span>، ولفظ الجلالة: مضاف إليه، ولهم: جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب: مبتدأ مؤخر، والجملة الاسمية خبر إن، وشديد: نعت لعذاب، والباء: حرف جر، وما: مصدرية مؤولة مع بعدها بمصدر مجرور بالباء، والجار والمجرور متعلقان بمحذوف حال، أي: بسبب نسيانهم، ويوم: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿نسوا﴾</span></span>، أو ظرف متعلق بمحذوف صفة ثانية لقوله: <span class="hlt"><span class="qpc-hafs">﴿لهم عذاب شديد﴾</span></span>، أي: لهم عذاب شديد كائن في يوم القيامة بسبب نسيانهم. والحساب: مضاف إليه.</p></div>"
  38,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما خلقنا السماء والأرض وما بينهما باطلا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، وخلقنا: فعل، وفاعل، والسماء: مفعول به، والأرض: عطف على السماء، وما: اسم موصول معطوف أيضًا، وبين: ظرف مكان منصوب على الظرفية متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والهاء: مضاف إليه، وباطلًا: نعت لمصدر محذوف، أي: خلقًا باطلًا، أو: حال من فاعل خلقنا، أي: مبطلين أو ذوي باطل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك ظن الذين كفروا فويل للذين كفروا من النار﴾</span></span>: ذلك: اسم إشارة مبتدأ، واللام للبعد، والكاف للخطاب. وهي إشارة إلى خلقها باطلًا، وظن: خبر المبتدأ، والذين: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. فويل: الفاء عاطفة، وويل: مبتدأ، وللذين: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من النار﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لويل.</p></div>"
  38,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم نجعل الذين آمنوا وعملوا الصالحات كالمفسدين في الأرض﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، والاستفهام للإنكار، ونجعل: فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره نحن، والذين: مفعول نجعل الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وآمن: فعل ماض، والواو: فاعل، <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كالمفسدين﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span>: جار ومجرور متعلقان بالمفسدين.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم نجعل المتقين كالفجار﴾</span></span>:  عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: منقطعة بمعنى: بل وهمزة الاستفهام، والاستفهام للإنكار، ونجعل: فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره نحن، والمتقين: مفعول نجعل الأول، و<span class="hlt"><span class="qpc-hafs">﴿كالفجار﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجعل﴾</span></span>.</p></div>"
  38,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كتاب أنزلناه إليك مبارك ليدبروا آياته وليتذكر أولو الألباب﴾</span></span>: كتاب: خبر لمبتدأ محذوف، أي: هذا كتاب، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> صفة، وأنزل: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: فاعل، والهاء: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>، ومبارك: نعت ثان، أو: خبر ثان، أو: خبر مبتدأ محذوف، وليدبروا: اللام لام التعليل، ويدبروا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والواو فاعل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>، وآياته: مفعول به، وليذكر: عطف على ليدبروا، وأولو: فاعل، والألباب: مضاف إليه.</p></div>"
  38,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا لداود سليمان نعم العبد إنه أواب﴾</span></span>: الواو استئنافية، ووهبنا: فعل ماض، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لداود﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وسليمان: مفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿ووهبنا لداود...﴾</span></span> مستأنفة لا محل لها من الإعراب، ونعم: فعل ماض جامد لإنشاء المدح، والعبد: فاعله، والمخصوص بالمدح محذوف لتقدم ذكره، أي هو، و<span class="hlt"><span class="qpc-hafs">﴿إنه أواب﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وأواب خبرها، والجملة تعليل للمدح.</p></div>"
  38,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ عرض عليه بالعشي الصافنات الجياد﴾</span></span>: إذ: اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿عرض﴾</span></span>: في محل جر بالإضافة، وعرض: فعل ماض مبني للمجهول، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالعشي﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، أي: كائنًا في ذلك الوقت، والصافنات: نائب فاعل، والجياد: بدل أو عطف بيان.</p></div>"
  38,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقال إني أحببت حب الخير عن ذكر ربي حتى توارت بالحجاب﴾</span></span>: الفاء عاطفة، وقال: فعل ماض، وفاعله مستتر، وإن حرف ناسخ، والياء اسمها، وجملة أحببت: خبرها، وحب: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أحببت﴾</span></span>، أو نائب عن المفعول المطلق، لأنه اسم مصدر، والخير: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عن ذكر﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحببت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span>: مضاف إليه، والإضافة من إضافة المصدر إلى المفعول، أي: عن أن أذكر ربي، أو إلى الفاعل، أي عن أن يذكرني ربي، وحتى: حرف غاية وجر، وتوارت: فعل ماض، وفاعله ضمير مستتر تقديره هي، وبالحجاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توارت﴾</span></span>.</p></div>"
  38,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ردوها علي فطفق مسحا بالسوق والأعناق﴾</span></span>: ردوها: فعل أمر، وفاعل، ومفعول به، والجملة مقول قول محذوف، أي قال: ردوها، وعليّ: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ردوها﴾</span></span>، فطفق: عطف على محذوف، أي فردوها، وطفق: فعل ماض من أفعال الشروع، وهي تعمل عمل كان، واسمها ضمير مستتر تقديره هو، ومسحًا: مفعول مطلق لفعل محذوف، أي يمسح مسحًا، والجملة خبر طفق، وبالسوق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسحًا﴾</span></span>، والأعناق: عطف على بالسوق.</p></div>"
  38,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد فتنا سليمان وألقينا على كرسيه جسدا ثم أناب﴾</span></span>: الواو استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، وفتنا: فعل وفاعل، وسليمان: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد فتنا سليمان﴾</span></span> مستأنفة لا محل لها من الإعراب، وألقينا: عطف على فتنا، وعلى كرسيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقينا﴾</span></span>، والهاء: في محل جر مضاف إليه، وجسدًا: مفعول به، ثم أناب: عطف أيضًا.</p></div>"
  38,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب اغفر لي وهب لي ملكا لا ينبغي لأحد من بعدي﴾</span></span>: رب: منادى مضاف إلى ياء المتكلم المحذوفة، وهب: فعل دعاء، ولي: جار ومجرور متعلقان به، وملكًا: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ينبغي﴾</span></span>: صفة لملكًا، ولأحد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعدي﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لأحد.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك أنت الوهاب﴾</span></span>: الجملة تعليلية للدعاء بالمغفرة والهبة، وإن حرف ناسخ، والكاف اسمها، وأنت: ضمير فصل، أو مبتدأ، والوهاب: خبر إن، أو خبر أنت، والجملة خبر إن.</p></div>"
  38,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسخرنا له الريح تجري بأمره رخاء حيث أصاب﴾</span></span>: الفاء عاطفة، وسخرنا: فعل وفاعل، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخرنا﴾</span></span>، والريح: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري بأمره﴾</span></span>: في محل نصب على الحال من الريح، وتجري: فعل مضارع، والفاعل مستتر، وبأمره: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، ورخاء: حال من الضمير في تجري، وحيث: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أصاب﴾</span></span>: في محل جر بإضافة الظرف إليها، وأصاب: فعل ماض، والفاعل مستتر.</p></div>"
  38,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والشياطين كل بناء وغواص﴾</span></span>: الواو: حرف عطف، والشياطين: عطف على الريح، وكل: بدل من الشياطين، وبناء: مضاف إليه، وغواص: عطف على بناء.</p></div>"
  38,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآخرين مقرنين في الأصفاد﴾</span></span>: الواو عاطفة، وآخرين: عطف على <span class="hlt"><span class="qpc-hafs">﴿كل بناء﴾</span></span>، أدخل معه في حكم البدل، وهو بدل الكل من الكل، ومقرنين: نعت لآخرين، أي: قرن بعضهم مع بعض في الأصفاد، وفي الأصفاد: جار ومجرور متعلقان بمقرنين.</p></div>"
  38,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا عطاؤنا فامنن أو أمسك بغير حساب﴾</span></span>: الجملة مقول قول محذوف، وهذا: مبتدأ، وعطاؤنا: خبر، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، فامنن: الفاء الفصيحة، وامنن فعل أمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: حرف عطف للتخيير، وأمسك: فعل أمر معطوف على امنن، وبغير: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عطاؤنا﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿امنن﴾</span></span>، أو متعلقان بمحذوف حال مما تقدم.</p></div>"
  38,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن له عندنا لزلفى وحسن مآب﴾</span></span>: الواو عاطفة، وإن: حرف ناسخ، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، وعندنا: ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، واللام المزحلقة، وزلفى: اسم إن، وحسن: عطف على زلفى، ومآب: مضاف إليه.</p></div>"
  38,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر عبدنا أيوب إذ نادى ربه﴾</span></span>: الواو عاطفة، واذكر: فعل أمر، وفاعله مستتر تقديره أنت، وعبدنا: مفعول اذكر، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، وأيوب: بدل، أو عطف بيان لعبدنا، وإذ: اسم مبني على السكون في محل نصب بدل اشتمال من أيوب، وجملة <span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span>: في محل جر بالإضافة، والفاعل مستتر تقديره: هو، وربه: مفعول به، والهاء: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أني مسني الشيطان بنصب وعذاب﴾</span></span>: أن حرف ناسخ، والياء اسمها، وجملة مسني الشيطان خبرها، والمصدر المؤول من أن وما في حيزها منصوب بنزع الخافض، أي: بأني مسني الشيطان، و<span class="hlt"><span class="qpc-hafs">﴿مسني الشيطان﴾</span></span> فعل ماض، ومفعول به مقدم، وفاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿بنصب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسني﴾</span></span>، وعذاب: عطف على نصب.</p></div>"
  38,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اركض برجلك هذا مغتسل بارد وشراب﴾</span></span>: الجملة مقول قول محذوف، واركض: فعل أمر، وفاعله مستتر تقديره أنت، وبرجلك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اركض﴾</span></span>، ومفعول اركض محذوف، أي: الأرض، وهذا: مبتدأ، ومغتسل: خبر، وبارد: صفة لمغتسل، وشراب: عطف.</p></div>"
  38,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا له أهله ومثلهم معهم رحمة منا وذكرى لأولي الألباب﴾</span></span>: الواو عاطفة، ووهبنا: فعل، وفاعل، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وأهله: مفعول به، والهاء: مضاف إليه، ومثلهم: عطف على أهله، <span class="hlt"><span class="qpc-hafs">﴿معهم﴾</span></span>: ظرف متعلق بمحذوف حال، أي: كائنًا معهم، ورحمة: مفعول لأجله، ومنا: جار ومجرور متعلقان بمحذوف صفة لرحمة، وذكرى: عطف على رحمة، ولأولي: جار ومجرور متعلقان بمحذوف نعت لذكرى، والألباب: مضاف إليه.</p></div>"
  38,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخذ بيدك ضغثا فاضرب به ولا تحنث﴾</span></span>: الواو عاطفة، وخذ: فعل أمر والفاعل مستتر، وبيدك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خذ﴾</span></span>، وضغثًا: مفعول به، فاضرب: عطف على خذ، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، والمفعول محذوف، أي امرأتك، ولا تحنث: الواو عاطفة، ولا ناهية، وتحنث: فعل مضارع مجزوم بلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا وجدناه صابرا نعم العبد إنه أواب﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدناه﴾</span></span> خبرها، ووجد فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به أول، وصابرًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿نعم العبد﴾</span></span>: فعل، وفاعل، والمخصوص بالمدح محذوف للعلم به، أي هو، و<span class="hlt"><span class="qpc-hafs">﴿إنه أواب﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وأواب خبرها، والجملة تعليل لمدحه.</p></div>"
  38,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر عبادنا إبراهيم وإسحاق ويعقوب أولي الأيدي والأبصار﴾</span></span>: الواو عاطفة، اذكر: فعل أمر، وفاعله مستتر تقديره أنت، وعبادنا: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، وإبراهيم: بدل، أو عطف بيان، <span class="hlt"><span class="qpc-hafs">﴿وإسحاق ويعقوب﴾</span></span>: عطف على إبراهيم، وأولي: مفعول به، والأيدي: مضاف إليه، والأبصار: عطف على الأيدي.</p></div>"
  38,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخلصناهم﴾</span></span>: خبر إن، وبخالصة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخلصناهم﴾</span></span>، وبخالصة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخلصناهم﴾</span></span>، وذكرى: بدل من خالصة، والدار:مضاف إليه، وإضافة ذكرى إلى الدار من إضافة المصدر إلى المفعول، أي ذكرهم الدار الآخرة.</p></div>"
  38,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم عندنا لمن المصطفين الأخيار﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وعندنا: ظرف متعلق بمحذوف حال، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المصطفين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر إن، والأخيار: صفة.</p></div>"
  38,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر إسماعيل واليسع وذا الكفل وكل من الأخيار﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اذكر إسماعيل﴾</span></span>: فعل، وفاعل مستتر، ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿واليسع وذا الكفل﴾</span></span>: معطوفان على إسماعيل، وكل: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الأخيار﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  38,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا ذكر وإن للمتقين لحسن مآب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وهذا: مبتدأ، وذكر: خبر، وإن: الواو استئنافية، وإن حرف ناسخ، وللمتقين: جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وحسن: اسم إن المؤخر، ومآب: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن للمتقين...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  38,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن مفتحة لهم الأبواب﴾</span></span>: جنات: بدل، أو عطف بيان لحسن مآب، وعدن: مضاف إليه، ومفتحة: حال من جنات عدن، والعامل فيها ما في المتقين من معنى الفعل، ولهم: جار ومجرور متعلقان بمفتحة، والأبواب: نائب فاعل لمفتحة، لأنه اسم مفعول، أو بدل من الضمير في مفتحة، وهو ضمير الجنات.</p></div>"
  38,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متكئين فيها يدعون فيها بفاكهة كثيرة وشراب﴾</span></span>: متكئين: حال من الهاء في لهم، والعامل فيها مفتحة، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئين﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>: مستأنفة لا محل لها من الإعراب، أو حالية، وفيها: جار ومجرور متعلقان بمحذوف حال من فاعل يدعون، أي: مستقرين فيها، وبفاكهة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، وكثيرة: صفة، وشراب: عطف على فاكهة.</p></div>"
  38,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعندهم قاصرات الطرف أتراب﴾</span></span>: الواو عاطفة، والظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>: ضمير مبني في محل جر مضاف إليه، وقاصرات: مبتدأ مؤخر، والطرف: مضاف إليه، وأتراب: صفة لقاصرات.</p></div>"
  38,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا ما توعدون ليوم الحساب﴾</span></span>: هذا: اسم الإشارة مبتدأ، وما: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. وليوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span>، واللام للتعليل، أي: لأجل يوم الحساب، والحساب: مضاف إليه.</p></div>"
  38,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لرزقنا ما له من نفاد﴾</span></span>: إن: حرف ناسخ، وهذا: اسمها، واللام المزحلقة، ورزقنا: خبر إن، وما: نافية، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، ومن: حرف جر صلة، ونفاد: مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا.</p></div>"
  38,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا وإن للطاغين لشر مآب﴾</span></span>: هذا: مبتدأ محذوف الخبر، أي: هذا كما ذكر، أو خبر لمبتدأ محذوف، أي: الأمر هذا، والكلام مستأنف لا محل له من الإعراب، والواو عاطفة، وإن: حرف ناسخ، وللطاغين: جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وشر: اسم إن المؤخر، ومآب: مضاف إليه.</p></div>"
  38,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جهنم يصلونها فبئس المهاد﴾</span></span>: بدل من شر مآب، أو عطف بيان له، وجملة يصلونها حالية، وهو فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، أو: جهنم مفعول محذوف دل عليه يصلونها، والفاء الفصيحة، أي: إن أردت أن تعلم حقيقة جهنم فهي بئس المهاد، وبئس فعل جامد لإنشاء الذم، والمهاد فاعل، والمخصوص بالذم محذوف تقديره: هي.</p></div>"
  38,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا فليذوقوه حميم وغساق﴾</span></span>: هذا: مبتدأ. والفاء اعتراضية. واللام: لام الأمر. ويذوقوه: فعل مضارع مجزوم بلام الأمر. والواو: فاعل. والهاء: مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿فليذوقوه﴾</span></span> اعتراضية لا محل لها من الإعراب. وحميم: خبر المبتدأ. وغساق: معطوف مرفوع.</p></div>"
  38,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآخر من شكله أزواج﴾</span></span>: الواو عاطفة، وآخر: عطف على <span class="hlt"><span class="qpc-hafs">﴿حميم وغساق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من شكله﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لآخر، وأزواج: خبر لمبتدأ محذوف، أي: هي أزواج.</p></div>"
  38,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا فوج مقتحم معكم لا مرحبا بهم إنهم صالو النار﴾</span></span>: الجملة مقول قول محذوف، وهذا: مبتدأ، وفوج: خبر، ومقتحم: صفة لفوج، ومعكم: ظرف متعلق بمحذوف صفة ثانية لفوج، أو حال من الضمير في فوج، ولا نافية، ومرحبًا: منصوب على المصدر، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرحبًا﴾</span></span>، والجملة المنفية مستأنفة لا محل لها من الإعراب، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿صالو﴾</span></span>: خبرها، وحذفت النون للإضافة، والنار: مضاف إليه.</p></div>"
  38,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بل أنتم لا مرحبا بكم أنتم قدمتموه لنا فبئس القرار﴾</span></span>: قالوا: فعل، وفاعل، وبل: حرف إضراب، وأنتم: مبتدأ، وخبره محذوف تقديره: أحق بالقول، ولا نافية، ومرحبًا: منصوب على المصدر، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرحبًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا بل أنتم...﴾</span></span> استئنافية لا محل لها من الإعراب، وأنتم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمتموه﴾</span></span> خبر، وقدمتموه: فعل ماض، والتاء فاعل، والميم علامة جمع الذكور، والواو لإشباع ضمة الميم، والهاء مفعول به، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدَّم﴾</span></span>، فبئس: الفاء عاطفة، وبئس: فعل ماض جامد لإنشاء الذم، والقرار: فاعل، والمخصوص بالذم محذوف، أي: النار.</p></div>"
  38,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا من قدم لنا هذا فزده عذابا ضعفا في النار﴾</span></span>: قالوا: فعل، وفاعل، وربنا: منادى مضاف محذوف منه حرف النداء، ومن: اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span> خبر، وقدم: فعل ماض، والفاعل مستتر، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span>، وهذا: مفعول به، والفاء رابطة لما في الموصول من رائحة الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿فزده﴾</span></span>: خبر، وفعل الدعاء مبني على السكون، والفاعل مستتر تقديره: أنت، والهاء: في محل نصب مفعول به أول، وعذابًا: مفعول به ثان، وضعفًا: نعت لعذاب، أي مضاعفًا، وفي النار: جار ومجرور متعلقان بمحذوف حال من الهاء، أي فزده كائنًا في النار، أو نعت ثان لعذاب.</p></div>"
  38,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا ما لنا لا نرى رجالا كنا نعدهم من الأشرار﴾</span></span>: قالوا: فعل، وفاعل، وما: اسم استفهام مبتدأ، ولنا: جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا نرى﴾</span></span>: حالية، ولا: نافية، ونرى: فعل مضارع مرفوع بالضمة المقدرة، وفاعل نرى ضمير مستتر تقديره نحن، ورجالًا: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: صفة لرجالًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعدهم﴾</span></span>: خبر كان، ومن الأشرار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نعدهم﴾</span></span>.</p></div>"
  38,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتخذناهم سخريا أم زاغت عنهم الأبصار﴾</span></span>: الهمزة: للاستفهام الإنكاري، وهمزة الوصل سقطت استغناء عنها، واتخذناهم: فعل ماض، وفاعل، ومفعول به أول، وسخريًّا: مفعول به ثان، وأم: هي أم المتصلة، وهي حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿زاغت عنهم الأبصار﴾</span></span>: فعل، وفاعل، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زاغت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذناهم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  38,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ذلك لحق تخاصم أهل النار﴾</span></span>: إن حرف ناسخ، وذلك اسمها، واللام المزحلقة، وحق: خبر إن، وتخاصم: بدل من حق، أو خبر لمبتدأ محذوف تقديره: هو، وأهل: مضاف إليه وهو مضاف، والنار: مضاف إليه، وجملة المبتدأ المحذوف وخبره <span class="hlt"><span class="qpc-hafs">﴿هو تخاصم﴾</span></span> مستأنفة بيانيا لا محل لها من الإعراب.</p></div>"
  38,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إنما أنا منذر وما من إله إلا الله الواحد القهار﴾</span></span>: قل: فعل أمر، والفاعل مستتر، إنما: كافة ومكفوفة، وأنا: مبتدأ، ومنذر: خبر، والواو: حرف عطف، وما: نافية، ومن: حرف جر صلة، وإله: مجرور لفظًا مرفوع بالابتداء محلا، وإلا: أداة حصر، ولفظ الجلالة: خبر، و<span class="hlt"><span class="qpc-hafs">﴿الواحد القهار﴾</span></span>: صفتان لله.</p></div>"
  38,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض وما بينهما العزيز الغفار﴾</span></span>: رب: نعت للفظ الجلالة في الآية السابقة، أو بدل، والسماوات: مضاف إليه، والأرض: معطوف مجرور، وما: اسم موصول معطوف في محل جر، وبينهما: ظرف منصوب متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿العزيز الغفار﴾</span></span>: نعتان أيضًا للفظ الجلالة في الآية السابقة.</p></div>"
  38,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل هو نبأ عظيم﴾</span></span>: قل: فعل أمر، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، ونبأ: خبر، وعظيم: صفة.</p></div>"
  38,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أنتم عنه معرضون﴾</span></span>: الجملة نعت ثان للنبأ، أو مستأنفة لا محل لها من الإعراب، وأنتم: مبتدأ، وعنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿معرضون﴾</span></span>، ومعرضون: خبر أنتم.</p></div>"
  38,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما كان لي من علم بالملأ الأعلى إذ يختصمون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما: نافية، وكان: فعل ماض ناقص، ولي: جار ومجرور متعلقان بمحذوف خبر كان المتقدم، ومن: حرف جر صلة، وعلم: مجرور بمن لفظًا في محل رفع اسم كان المؤخر، وبالملأ: جار ومجرور متعلقان بعلم على تقدير مضاف، أي: بأنباء الملأ واختصامهم، والأعلى: صفة للملأ، وإذ: ظرف لما مضى متعلق بمحذوف مضاف إلى الملأ، أي: من علم بكلام الملأ الأعلى، أو اسم مبني على السكون في محل نصب بالمصدر <span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يختصمون﴾</span></span>: في محل جر بالإضافة.</p></div>"
  38,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن يوحى إلي إلا أنما أنا نذير مبين﴾</span></span>: إن:نافية، ويوحى:فعل مضارع مبني لما لم يسمَّ فاعله، وإليّ:جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span>، وإلا: أداة حصر، وإنما: كافة ومكفوفة، وقد سدت مع مدخولها مسد نائب فاعل يوحى، أي: ما يوحى إليَّ إلا الإنذار، والقصر إضافي، وأنا: مبتدأ، ونذير: خبر، ومبين: نعت.</p></div>"
  38,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال ربك للملائكة إني خالق بشرا من طين﴾</span></span>: إذ: اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ يختصمون﴾</span></span>، أو في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال ربك﴾</span></span>: في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿قال ربك﴾</span></span>: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿للملائكة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿إني خالق بشرًا﴾</span></span> إن وما بعدها مقول قول، وإن حرف ناسخ، والياء اسمها، وخالق: خبرها، وبشرًا: مفعول به لخالق، ومن طين: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿بشرًا﴾</span></span>.</p></div>"
  38,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا سويته ونفخت فيه من روحي فقعوا له ساجدين﴾</span></span>: الفاء: عاطفة، وإذا: ظرف مستقبل خافض لشرطه منصوب بجوابه، و<span class="hlt"><span class="qpc-hafs">﴿سويته﴾</span></span>: فعل ماض، والتاء: فاعل، والهاء: مفعول به، والجملة في محل جر بإضافة الظرف إليها، ونفخت: عطف على سويته، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخت﴾</span></span>، وكذلك قوله: <span class="hlt"><span class="qpc-hafs">﴿من روحي﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فقعوا﴾</span></span>: الفاء: رابطة لجواب إذا، وقعوا: فعل أمر، وفاعل، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ساجدين﴾</span></span>، وساجدين: حال.</p></div>"
  38,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسجد الملائكة كلهم أجمعون﴾</span></span>: الفاء: عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿سجد الملائكة﴾</span></span>: فعل، فاعل، وكلهم: تأكيد أول، والهاء: مضاف إليه، وأجمعون: تأكيد ثان مرفوع بالواو.</p></div>"
  38,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا إبليس استكبر وكان من الكافرين﴾</span></span>: إلا: أداة استثناء، وإبليس: مستثنى متصل، أو منقطع، وجملة <span class="hlt"><span class="qpc-hafs">﴿استكبر﴾</span></span>: مستأنفة لا محل لها من الإعراب، وكان: عطف على استكبر، واسم كان مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من الكافرين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  38,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا إبليس ما منعك أن تسجد لما خلقت بيدي﴾</span></span>: قال: فعل ماض، وفاعله يعود على الله تعالى، ويا: حرف نداء، وإبليس: منادى مفرد علم مبني على الضم، وما: اسم استفهام مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿منعك﴾</span></span>: خبر، وأن: حرف مصدري ونصب، وتسجد: فعل مضارع منصوب بأن، وفاعله مستتر تقديره أنت، وأن وما في حيزها في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> المحذوفة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منع﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿لما خلقت بيدي﴾</span></span>: اللام: حرف جر، وما: اسم موصول مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسجد﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقت﴾</span></span>: صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي: خلقته، أو أن ما: مصدرية، والمصدر المؤول مجرور باللام، والمصدر مراد به المخلوق لا حقيقة المصدر، وبيدي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أستكبرت أم كنت من العالين﴾</span></span>: الهمزة: للاستفهام، وهمزة الوصل سقطت استغناء عنها. واستكبرت: فعل وفاعل، وأم: عاطفة متصلة، وكنت: كان فعل ماض ناقص، والتاء اسمها، ومن العالين: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  38,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أنا خير منه خلقتني من نار وخلقته من طين﴾</span></span>: أنا: مبتدأ، وخير: خبر، ومنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، والجملة مقول القول، وخلقتني: فعل، وفاعل، ومفعول به، ومن نار: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلقته من طين﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿خلقتني من نار﴾</span></span>.</p></div>"
  38,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فاخرج منها فإنك رجيم﴾</span></span>: قال: فعل ماض، والفاعل مستتر تقديره هو، يعود على الله تعالى، فاخرج: الفاء الفصيحة، واخرج: فعل أمر، وفاعله مستتر تقديره أنت، ومنها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخرج﴾</span></span>، فإنك: الفاء تعليلية، وإن حرف ناسخ، والكاف اسمها، ورجيم: خبرها.</p></div>"
  38,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن عليك لعنتي إلى يوم الدين﴾</span></span>: الواو عاطفة، وإن: حرف توكيد ونصب، وعليك: جار ومجرور متعلقان بمحذوف خبر إن المقدم، ولعنتي: اسم إن المؤخر، والياء: مضاف إليه، وإلى يوم الدين: الجار والمجرور متعلقان بمحذوف حال، أي: مستمرة، والدين: مضاف إليه.</p></div>"
  38,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب فأنظرني إلى يوم يبعثون﴾</span></span>: قال: فعل ماض، وفاعله مستتر يعود إلى إبليس، <span class="hlt"><span class="qpc-hafs">﴿فأنظرني﴾</span></span>: الفاء: الفصيحة، لأنها أفصحت عن شرط مقدر، وتقديره: <span class="hlt"><span class="qpc-hafs">﴿إذا جعلتني رجيمًا فأمهلني﴾</span></span>، وأنظرني: فعل دعاء، والفاعل مستتر تقديره أنت، والنون للوقاية، والياء مفعول به، وإلى يوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنظرني﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span>: في محل جر بإضافة الظرف إليها.</p></div>"
  38,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فإنك من المنظرين﴾</span></span>: قال: فعل ماض، وفاعله مستتر تقديره: هو، فإنك: الفاء الفصيحة، وإن حرف ناسخ، والكاف اسمها، ومن المنظرين: جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  38,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى يوم الوقت المعلوم﴾</span></span>: إلى يوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿المنظرين﴾</span></span>، والوقت: مضاف إليه، والمعلوم: نعت الوقت مجرور.</p></div>"
  38,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فبعزتك لأغوينهم أجمعين﴾</span></span>: قال: فعل، والفاعل مستتر تقديره هو، والفاء: عاطفة، والباء: حرف جر وقسم، وعزتك: مجرور بالباء، والجار والمجرور متعلقان بفعل القسم المحذوف، واللام: واقعة في جواب القسم، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغوينهم﴾</span></span>: لا محل لها من الإعراب، وأغوينهم: فعل مضارع، وفاعل مستتر تقديره أنا، والهاء مفعول به، وأجمعين: تأكيد.</p></div>"
  38,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عبادك منهم المخلصين﴾</span></span>: إلا: أداة استثناء، وعبادك: مستثنى، ومنهم: جار ومجرور متعلقان بمحذوف حال، والمخلصين: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عبادك﴾</span></span>.</p></div>"
  38,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فالحق والحق أقول﴾</span></span>: قال: فعل، والفاعل مستتر تقديره: هو، والفاء: استئنافية، والحق: مبتدأ، خبره محذوف، تقديره: قسمي، أو مني، أو خبر لمبتدأ محذوف، أي: هو الحق. وجملة <span class="hlt"><span class="qpc-hafs">﴿فالحق...﴾</span></span>مستأنفة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿والحق﴾</span></span>: الواو اعتراضية، والحق: مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أقول﴾</span></span>، أي: لا أقول إلا الحق. وجملة: <span class="hlt"><span class="qpc-hafs">﴿الحق أقول﴾</span></span> اعتراضية بين القسم وجوابه، لا محل لها من الإعراب.</p></div>"
  38,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأملأن جهنم منك وممن تبعك منهم أجمعين﴾</span></span>: اللام: واقعة في جواب القسم المقدر، وأملأن: فعل مضارع مبني على الفتح، والنون للتوكيد، والفاعل مستتر تقديره: أنا، وجهنم: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أملأن﴾</span></span> جواب قسم مقدر، وجملة القسم في محل نصب بدل من الحق، أو مستأنفة بيانيا لا محل لها من الإعراب، ومنك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أملأن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ممن تبعك﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿منك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تبعك﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. ومنهم: جار ومجرور متعلقان بمحذوف حال، وأجمعين: تأكيد للضمير في منهم، أو للكاف في منك، وما عطف عليه.</p></div>"
  38,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل ما أسألكم عليه من أجر وما أنا من المتكلفين﴾</span></span>: قل: فعل أمر، والفاعل مستتر، ما: نافية، وأسألكم: فعل مضارع، وفاعله مستتر تقديره أنا، والكاف مفعول به، وعليه: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لأجر، وتقدم عليه، ومن: حرف جر صلة، وأجر: مجرور لفظًا منصوب محلًّا على أنه مفعول أسألكم، والواو: عاطفة أو حالية، وما: نافية حجازية تعمل عمل ليس، وأنا: اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿من المتكلفين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر ما. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المتكلفين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر المبتدأ.</p></div>"
  38,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا ذكر للعالمين﴾</span></span>: إن: نافية، وهو: مبتدأ، وإلا: أداة حصر، وذكر: خبر هو، وللعالمين: جار ومجرور متعلقان بمحذوف صفة لذكر.</p></div>"
  38,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلمن نبأه بعد حين﴾</span></span>: الواو: عاطفة، واللام: لام القسم، وتعلمن: فعل مضارع مرفوع، لأن نون التوكيد لم تباشره، وعلامة رفعه ثبوت النون المحذوفة لالتقاء الساكنين، والواو: المحذوفة لالتقاء الساكنين أيضًا: فاعل، والنون: نون التوكيد الثقيلة، ونبأه: مفعول به، وبعد: ظرف زمان منصوب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تعلمن﴾</span></span>، وحين: مضاف إليه.</p></div>"
