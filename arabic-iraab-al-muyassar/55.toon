quran[78]{c,v,t}:
  55,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: الرحمن مبتدأ، وقيل: الرحمن خبر لمبتدأ محذوف، أي: الله الرحمن، أو مبتدأ خبره محذوف، أي: الرحمن ربنا.</p></div>"
  55,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿علم القرآن﴾</span></span>: جملة علم القرآن خبر، وعلم يتعدى إلى مفعولين حذف أولهما لشموله، أي: علم من يتعلم، وهذا أولى من تخصيص المفعول الأول المحذوف بواحد معين.</p></div>"
  55,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان﴾</span></span>: فعل ماضٍ، وفاعل مستتر، ومفعول به والألف واللام في الإنسان للجنس.</p></div>"
  55,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿علمه البيان﴾</span></span>: فعل ماضٍ، وفاعل مستتر، ومفعولاه.</p></div>"
  55,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الشمس والقمر بحسبان﴾</span></span>: الشمس مبتدأ، والقمر عطف عليه، وبحسبان خبر الشمس.</p></div>"
  55,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنجم والشجر يسجدان﴾</span></span>: عطف على ما تقدم، وجملة يسجدان خبر النجم.</p></div>"
  55,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسماء رفعها ووضع الميزان﴾</span></span>: الواو عاطفة، والسماء مفعول به بفعل محذوف يدل عليه المذكور. وجملة رفعها تفسيرية لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ووضع الميزان﴾</span></span>: فعل، وفاعل مستتر، ومفعول به.</p></div>"
  55,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا تطغوا في الميزان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، ولا نافية، وتطغوا فعل مضارع منصوب بأن المصدرية، وأن وما بعدها في تأويل منصوب بلام العلة مقدرة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وضع﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تطغوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. ولا ناهية. وتطغوا مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p></div>"
  55,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأقيموا الوزن بالقسط ولا تخسروا الميزان﴾</span></span>: الواو حرف عطف، وأقيموا فعل أمر مبني على حذف النون، والواو فاعل، والوزن مفعول به، وبالقسط حال، أي: افعلوه مستقيمًا بالعدل، والواو حرف عطف، ولا ناهية، وتخسروا فعل مضارع مجزوم بلا، والواو فاعل، والميزان مفعول به.</p></div>"
  55,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض وضعها للأنام﴾</span></span>: الواو حرف عطف. والأرض: مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده. وجملة <span class="hlt"><span class="qpc-hafs">﴿وضعها﴾</span></span> تفسيرية لا محل لها من الإعراب. وللأنام: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وضعها﴾</span></span>.</p></div>"
  55,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيها فاكهة والنخل ذات الأكمام﴾</span></span>: فيها خبر مقدم، وفاكهة مبتدأ مؤخر، والنخل عطف على فاكهة، وذات الأكمام صفة للنخل، والجملة في محل نصب على الحال من الأرض.</p></div>"
  55,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والحب ذو العصف والريحان﴾</span></span>: الحب معطوف على فاكهة مرفوع، وذو نعت للحب مرفوع بالواو، لأنه من الأسماء الستة، والعصف مضاف إليه، والريحان معطوف على فاكهة مرفوع.</p></div>"
  55,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان من صلصال كالفخار﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وخلق فعل ماضٍ، وفاعله مستتر يعود على الله تعالى، والإنسان مفعول به، ومن صلصال جار ومجرور متعلقان بخلق، و<span class="hlt"><span class="qpc-hafs">﴿كالفخار﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل جر صفة لصلصال، و<span class="hlt"><span class="qpc-hafs">﴿الفخار﴾</span></span> مضاف إليه.</p></div>"
  55,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخلق الجان من مارج من نار﴾</span></span>: عطف على ما تقدم، ومن مارج جار ومجرور متعلقان بخلق، ومن لابتداء الغاية، ومن نار صفة لمارج، ومن للبيان، أو للتبعيض.</p></div>"
  55,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب المشرقين ورب المغربين﴾</span></span>: رب المشرقين خبر لمبتدأ محذوف، أي: هو رب المشرقين، ورب المغربين عطف عليه.</p></div>"
  55,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مرج البحرين يلتقيان﴾</span></span>: مرج البحرين فعل ماضٍ، وفاعل مستتر، ومفعول به، وجملة يلتقيان في محل نصب على الحال.</p></div>"
  55,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بينهما برزخ لا يبغيان﴾</span></span>: الظرف متعلق بمحذوف خبر مقدم، وبرزخ مبتدأ مؤخر، ولا نافية، ويبغيان فعل مضارع مرفوع، والجملة صفة لبرزخ، والجملة كلها مستأنفة لا محل لها من الإعراب، أو حال من الضمير في يلتقيان.</p></div>"
  55,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يخرج منهما اللؤلؤ والمرجان﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حال ثانية من الضمير في يلتقيان، ومنهما جار ومجرور متعلقان بيخرج، واللؤلؤ فاعل يخرج، والمرجان عطف على اللؤلؤ.</p></div>"
  55,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وله الجوار المنشآت في البحر كالأعلام﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وله جار ومجرور متعلقان بمحذوف خبر مقدم، والجوار مبتدأ مؤخر، والمنشآت نعت للجوار، وفي البحر جار ومجرور متعلقان بالمنشآت، و<span class="hlt"><span class="qpc-hafs">﴿كالأعلام﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب حال من الجوار، أو من الضمير في المنشآت، و<span class="hlt"><span class="qpc-hafs">﴿الأعلام﴾</span></span> مضاف إليه.</p></div>"
  55,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكذبان﴾</span></span>، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كل من عليها فان﴾</span></span>: كل مبتدأ، ومن اسم موصول في محل جر بالإضافة لكل، وعليها جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. وفان خبر كل، وحذفت الياء لالتقاء الساكنين.</p></div>"
  55,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويبقى وجه ربك ذو الجلال والإكرام﴾</span></span>: الواو عاطفة، ويبقى فعل مضارع مرفوع، ووجه ربك فاعله، وذو الجلال صفة لوجه، والإكرام عطف على الجلال.</p></div>"
  55,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يسأله من في السماوات والأرض كل يوم هو في شأن﴾</span></span>: كلام مستأنف لا محل له من الإعراب، ولك أن تجعل الجملة حالًا من وجه، والعامل فيه يبقى، أي: يبقى حال كونه مسؤولًا من أهل السماوات والأرض، ويسأله فعل مضارع ومفعوله المقدم، ومن موصول فاعل يسأله، وفي السماوات: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. ومتعلق السؤال محذوف، فأهل السماوات يسألونه المغفرة، وأهل الأرض يسألونه المغفرة والرزق، وكل يوم ظرف متعلق بالاستقرار الذي تعلق به خبر هو، وهو مبتدأ، وفي شأن خبر.</p></div>"
  55,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سنفرغ لكم أيها الثقلان﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والسين حرف استقبال، ونفرغ فعل مضارع مرفوع، وفاعله مستتر تقديره نحن، ولكم جار ومجرور متعلقان بنفرغ، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> الثقلان منادى نكرة مقصودة حذف منه حرف النداء، والثقلان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p></div>"
  55,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا معشر الجن والإنس إن استطعتم أن تنفذوا من أقطار السماوات والأرض فانفذوا﴾</span></span>: يا حرف نداء، ومعشر الجن منادى مضاف، والإنس عطف على الجن، وإن شرطية، واستطعتم فعل ماضٍ في محل جزم فعل الشرط، وأن حرف مصدري ونصب، وتنفذوا فعل مضارع منصوب بأن، وأن وما في حيزها في موضع نصب مفعول استطعتم، ومن أقطار السماوات والأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنفذوا﴾</span></span>، فانفذوا: الفاء رابطة لجواب الشرط، لأن الجواب طلب، وانفذوا فعل أمر، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تنفذون إلا بسلطان﴾</span></span>: لا نافية، وتنفذون فعل مضارع مرفوع، والواو فاعل، وإلا أداة حصر، وبسلطان جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنفذون﴾</span></span>.</p></div>"
  55,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يرسل عليكما شواظ من نار ونحاس﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ويرسل فعل مضارع مبني لما لم يسمَّ فاعله، وعليكما جار ومجرور متعلقان بيرسل، وشواظ نائب فاعل، ومن نار نعت لشواظ، ونحاس عطف على شواظ، وقرئ بالجر عطفًا على نار.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تنتصران﴾</span></span>: الفاء عاطفة، ولا نافية، وتنتصران فعل مضارع مرفوع، والألف فاعل.</p></div>"
  55,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا انشقت السماء فكانت وردة كالدهان﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا  ظرف لما يستقبل من الزمن متضمن معنى الشرط متعلق بجوابه، و<span class="hlt"><span class="qpc-hafs">﴿انشقت السماء﴾</span></span> فعل وفاعل، والجملة في محل جر بإضافة الظرف إليها، فكانت عطف على انشقت، واسم كانت مستتر يعود على السماء، ووردة خبرها، وكالدهان جار ومجرور متعلقان بنعت لوردة، أو خبر ثانٍ لكانت، أو حال من اسم كانت.</p></div>"
  55,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيومئذ لا يسأل عن ذنبه إنس ولا جان﴾</span></span>: الفاء رابطة لجواب إذا، وقيل: جواب إذا محذوف، أي: فإذا انشقت السماء رأيت أمرًا عظيمًا، والفاء عاطفة عليه، ولا داعي لهذا التكلف، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بالفعل المنفي <span class="hlt"><span class="qpc-hafs">﴿يسأل﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ انشقت السماء، ولا نافية، ويسأل فعل مضارع مبني لما لم يسمَّ فاعله، وعن ذنبه جار ومجرور متعلقان بيسأل، وإنس نائب فاعل، ولا جان عطف على إنس، والجان والإنس كل منهما اسم جنس.</p></div>"
  55,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعرف المجرمون بسيماهم﴾</span></span>: يعرف فعل مضارع مبني لما لم يسمَّ فاعله، والمجرمون نائب فاعل، وبسيماهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعرف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيؤخذ بالنواصي والأقدام﴾</span></span>: الفاء عاطفة، ويؤخذ فعل مضارع مبني لما لم يسمَّ فاعله، وبالنواصي هو نائب الفاعل، ويؤخذ متعد، ومع ذلك تعدى بالباء، لأنه ضمن معنى يُسحب.</p></div>"
  55,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذه جهنم التي يكذب بها المجرمون﴾</span></span>: هذه مبتدأ، وجهنم خبر، والتي صفة، وجملة يكذب بها المجرمون صلة الموصول لا محل لها من الإعراب.</p></div>"
  55,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يطوفون بينها وبين حميم آن﴾</span></span>: الجملة حال من المجرمين، أو مستأنفة لا محل لها من الإعراب، ويطوفون فعل مضارع مرفوع، والواو فاعل، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يطوفون﴾</span></span>، وبين عطف على الظرف الأول، وآنٍ نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span>، وهو منقوص، فالكسرة مقدرة على الياء المحذوفة لالتقاء الساكنين.</p></div>"
  55,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولمن خاف مقام ربه جنتان﴾</span></span>: الواو عاطفة، ولمن خبر مقدم، وجملة خاف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. ومقام مفعول به، وهو اسم مكان، أو مصدر ميميّ، وربه مضاف إليه وهو مضاف، والهاء ضمير مبني في محل جر مضاف إليه، وجنتان مبتدأ مؤخر.</p></div>"
  55,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذواتا أفنان﴾</span></span>: ذواتا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنتان﴾</span></span>، وأفنان مضاف إليه.</p></div>"
  55,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما عينان تجريان﴾</span></span>: فيهما خبر مقدم، وعينان مبتدأ مؤخر، وجملة تجريان نعت عينان.</p></div>"
  55,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما من كل فاكهة زوجان﴾</span></span>: فيهما خبر مقدم، ومن كل فاكهة حال، لأنه كان في الأصل صفة لزوجان، وزوجان مبتدأ مؤخر.</p></div>"
  55,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متكئين على فرش بطائنها من إستبرق وجنى الجنتين دان﴾</span></span>: متكئين منصوب على المدح بفعل محذوف، أو حال من قوله: ولمن خاف، وقيل: العامل محذوف، أي: يتنعمون متكئين، وعلى فرش جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئين﴾</span></span>، وبطائنها مبتدأ، ومن إستبرق خبر، والجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فرش﴾</span></span>، والواو حالية، أو عاطفة، وجنى مبتدأ والجنتين مضاف إليه، ودانٍ خبر، وعلامة رفعه الضمة المقدرة على الياء المحذوفة لالتقاء الساكنين.</p></div>"
  55,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهن قاصرات الطرف لم يطمثهن إنس قبلهم ولا جان﴾</span></span>: فيهن خبر مقدم، وقاصرات الطرف مبتدأ مؤخر ولم حرف نفي وقلب وجزم، ويطمثهن فعل مضارع مجزوم بلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يطمثهن﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span>، لأن الإضافة لفظية فلا تتعرف، أو حالية، لأن النكرة قد تخصصت بالإضافة، وإنس فاعل، وقبلهم ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يطمثهن﴾</span></span>، ولا جان: عطف على إنس.</p></div>"
  55,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span></span>: الجملة نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span>، أو حال منها، وكأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هن﴾</span></span> اسمها، والياقوت خبرها، والمرجان عطف على الياقوت.</p></div>"
  55,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل جزاء الإحسان إلا الإحسان﴾</span></span>: هل حرف استفهام معناه: الجحد والنفي، وجزاء مبتدأ، والإحسان مضاف إليه، وإلا أداة حصر، والإحسان خبر جزاء.</p></div>"
  55,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن دونهما جنتان﴾</span></span>: من دونهما خبر مقدم، وجنتان مبتدأ مؤخر.</p></div>"
  55,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مدهامتان﴾</span></span>: نعت جنتان.</p></div>"
  55,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما عينان نضاختان﴾</span></span>: الجملة نعت ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿جنتان﴾</span></span>، وفيهما خبر مقدم، وعينان مبتدأ مؤخر، ونضاختان نعت <span class="hlt"><span class="qpc-hafs">﴿عينان﴾</span></span>.</p></div>"
  55,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما فاكهة ونخل ورمان﴾</span></span>: فيهما خبر مقدم، وفاكهة مبتدأ مؤخر، ونخل عطف على فاكهة، ورمان عطف على نخل.</p></div>"
  55,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهن خيرات حسان﴾</span></span>: فيهن خبر مقدم، وخيرات مبتدأ مؤخر، وحسان صفة.</p></div>"
  55,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span></span>: حور بدل من خيرات، أو خبر لمبتدأ مضمر، أي: هن حور، أو مبتدأ حذف خبره، أي: فهن حور، ومقصورات نعت لحور، وفي الخيام جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مقصورات﴾</span></span>.</p></div>"
  55,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لم يطمثهن إنس قبلهم ولا جان﴾</span></span>: لم حرف نفي وقلب وجزم، ويطمثهن فعل مضارع مجزوم بلم، وإنس فاعل، وقبلهم ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يطمثهن﴾</span></span>، ولا جان: عطف على إنس.</p></div>"
  55,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متكئين على رفرف خضر وعبقري حسان﴾</span></span>: حال حذف عامله، أي: يتنعمون، أو نصب على المدح، وعلى رفرف جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئين﴾</span></span>، وخضر نعت، وعبقري عطف على رفرف، وحسان نعت لرفرف خضر وعبقري.</p></div>"
  55,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تبارك﴾</span></span>: فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿اسم﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذي﴾</span></span>: صفة لرب.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجلال﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿والإكرام﴾</span></span>: عطف على الجلال.</p></div>"
