quran[227]{c,v,t}:
  26,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طسم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  26,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب المبين﴾</span></span>: تلك مبتدأ، وآيات الكتاب خبر، والمبين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span>.</p></div>"
  26,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعلك باخع نفسك ألا يكونوا مؤمنين﴾</span></span>: لعل حرف ناسخ، والكاف اسمها، وباخع خبرها، ونفسك مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿باخع﴾</span></span>، وأن وما في حيزها مفعول لأجله، أي: خيفة ألا يؤمنوا، ومؤمنين خبر يكونوا.</p></div>"
  26,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن نشأ ننزل عليهم من السماء آية فظلت أعناقهم لها خاضعين﴾</span></span>: إن شرطية، ونشأ فعل الشرط، وفاعله مستتر تقديره: نحن، ومفعول المشيئة محذوف، أي: إيمانهم، وننزل جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>، والفاء حرف عطف، وظلت فعل ماض ناقص معطوف على ننزل في محل جزم، أو الفاء استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وأعناقهم اسم ظلت، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خاضعين﴾</span></span>، وخاضعين خبر <span class="hlt"><span class="qpc-hafs">﴿ظلت﴾</span></span>.</p></div>"
  26,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يأتيهم من ذكر من الرحمن محدث إلا كانوا عنه معرضين﴾</span></span>: الواو عاطفة، وما نافية، ويأتيهم فعل مضارع، ومفعول به، ومن حرف جر صلة، وذكر فاعل مجرور لفظًا مرفوع محلًّا، و<span class="hlt"><span class="qpc-hafs">﴿من الرحمن﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>، ومحدث صفة ثانية، وإلا أداة حصر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> استثناء من أعم الأحوال فهي حالية، وكان فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿معرضين﴾</span></span>، ومعرضين خبر كان.</p></div>"
  26,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقد كذبوا﴾</span></span>: الفاء الفصيحة، وقد حرف تحقيق، وكذبوا فعل ماض وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسيأتيهم أنباء ما كانوا به يستهزئون﴾</span></span>: عطف على ما تقدم، ويأتيهم فعل مضارع ومفعول به، وأنباء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مضاف إليه، وجملة كانوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والواو اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، وجملة يستهزئون خبر كانوا.</p></div>"
  26,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا إلى الأرض كم أنبتنا فيها من كل زوج كريم﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على مقدر، ولم حرف نفي وقلب وجزم، ويروا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، وكم خبرية في محل نصب مفعول <span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، وأنبتنا فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من كل زوج﴾</span></span> تمييز كم الخبرية، وكريم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿زوج﴾</span></span>.</p></div>"
  26,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> خبرها المقدم، واللام المزحلقة، وآية اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span></span>: الواو حالية، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان أكثرهم مؤمنين﴾</span></span> كان فعل ماض ناقص، وأكثرهم اسمها، ومؤمنين خبرها.</p></div>"
  26,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> اسمها، والكاف مضاف إليه، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن، والرحيم خبر ثان.</p></div>"
  26,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ نادى ربك موسى أن ائت القوم الظالمين﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف والتقدير: واذكر إذ نادى ربك، وجملة <span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span> في محل جر مضاف إليه، وربك فاعل <span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span>، وموسى مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن ائت﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية تؤول وما دخلت عليه بمصدر منصوب بنزع الخافض والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ائت القوم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ائت﴾</span></span>: فعل أمر مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت. والقوم: مفعول به. والظالمين: صفة.</p></div>"
  26,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قوم فرعون ألا يتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قوم فرعون﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿القوم الظالمين﴾</span></span>، أو عطف بيان، والهمزة للاستفهام، ولا نافية، ويتقون فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألا يتقون﴾</span></span> استئنافية لا محل لها من الإعراب، وقيل: الجملة حالية من الضمير الذي تحمله اسم الفاعل، وهو الظالمون، أي: يظلمون غير متقين، وقيل: <span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> للعرض، أو للتنبيه.</p></div>"
  26,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إني أخاف أن يكذبون﴾</span></span>: قال فعل ماض، رب منادى مضاف، حذف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿إنى﴾</span></span> إن حرف ناسخ، والياء اسمها، وجملة أخاف خبرها، وأن وما في حيزها مفعول أخاف.</p></div>"
  26,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويضيق صدري ولا ينطلق لساني فأرسل إلى هارون﴾</span></span>: الواو عاطفة، ويضيق فعل مضارع مرفوع، وصدري فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لا ينطلق لساني﴾</span></span> عطف على ما قبله، <span class="hlt"><span class="qpc-hafs">﴿فأرسل﴾</span></span> الفاء الفصيحة، وأرسل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿إلى هارون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>.</p></div>"
  26,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولهم علي ذنب فأخاف أن يقتلون﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير مبني في محل جر، والجار والمجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> على حرف جر، والياء ضمير مبني في محل جر، والجار والمجرور متعلقان بمحذوف حال، وذنب مبتدأ مؤخر، على تقديرحذف مضاف، أي: تبعة ذنب.</p></div>"
  26,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كلا فاذهبا بآياتنا إنا معكم مستمعون﴾</span></span>: كلا حرف زجر وردع، فاذهبا فعل أمر، وألف الاثنين فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> الباء حرف جر وآيات اسم مجرور، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير في محل جر مضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذهبا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا معكم مستمعون﴾</span></span> تعليلية للأمر، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومستمعون خبرها، والواو فاعل <span class="hlt"><span class="qpc-hafs">﴿مستمعون﴾</span></span>، والمفعول محذوف، أي: ما يدور بينكما وبين فرعون، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span> ظرف متعلق بمحذوف حال، أو خبر ثان، أو بـ<span class="hlt"><span class="qpc-hafs">﴿مستمعون﴾</span></span>.</p></div>"
  26,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتيا فرعون فقولا إنا رسول رب العالمين﴾</span></span>: الفاء عاطفة، وائتيا فرعون فعل أمر وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فقولا﴾</span></span> عطف وهو فعل أمر مبني على حذف النون، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ورسول خبرها، و<span class="hlt"><span class="qpc-hafs">﴿رب العالمين﴾</span></span> مضاف إليه.</p></div>"
  26,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. وقيل: إن <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>: فعل أمر، والفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿معنا﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بني﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إسرائيل﴾</span></span>: مضاف إليه.</p></div>"
  26,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ألم نربك فينا وليدا ولبثت فينا من عمرك سنين﴾</span></span>: قال فعل ماض، ألم نربك الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، ونربك فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه حذف حرف العلة، والفاعل ضمير مستتر تقديره: نحن، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿فينا﴾</span></span> <span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نربك﴾</span></span>، ووليدًا حال، ولبثت فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عمرك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لسنين، وسنين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span> أيضًا.</p></div>"
  26,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿فعلت﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فعلتك﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿فعلت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، والواو حالية، وأنت مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الكافرين﴾</span></span> من حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿الكافرين﴾</span></span> اسم مجرور، والجار والمجرور متعلقان بمحذوف خبر المبتدأ.</p></div>"
  26,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فعلتها إذا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿فعلتها﴾</span></span> فعل ماض، والتاء فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جزاء بمثابة الجواب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا من الضالين﴾</span></span>: الواو واو الحال، وأنا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر، والضالين اسم مجرور، والجار والمجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنا من الضالين﴾</span></span> جملة حالية.</p></div>"
  26,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ففررت منكم لما خفتكم فوهب لي ربي حكما وجعلني من المرسلين﴾</span></span>: الفاء عاطفة، وفررت فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> من حرف جر، والكاف ضمير في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فررت﴾</span></span>، ولما حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿خفتكم﴾</span></span> فعل وفاعل ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿خفتكم﴾</span></span> مضاف إليه، فوهب عطف على ففررت، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> اللام حرف جر، والياء ضمير مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهب﴾</span></span>، وربي فاعل، وحكمًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿جعلني من المرسلين﴾</span></span> عطف على ما تقدم.</p></div>"
  26,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني إسرائيل﴾</span></span>: تلك مبتدأ، ونعمة خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمنها﴾</span></span> صفة لنعمة، و<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> على حرف جر، والياء ضمير في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمنها﴾</span></span>، وأن وما في حيزها عطف بيان لـ<span class="hlt"><span class="qpc-hafs">﴿تلك﴾</span></span>، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span>، أو في محل نصب على أنه مفعول لأجله، وتمنها فعل مضارع، والفاعل ضمير مستتر تقديره: أنت، والهاء منصوب بنزع الخافض، أي: تمن بها، و<span class="hlt"><span class="qpc-hafs">﴿عبدت﴾</span></span> فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بني إسرائيل﴾</span></span> مفعول به منصوب بالياء.</p></div>"
  26,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فرعون وما رب العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل وفاعل، والواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، ورب العالمين خبره.</p></div>"
  26,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب السماوات والأرض وما بينهما إن كنتم موقنين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> خبر لمبتدأ محذوف، وما عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات والأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، وموقنين خبرها، وجواب إن محذوف، أي: إن كنتم ممن يرجى منهم النظر الصحيح والاعتبار السليم نفعكم هذا الجواب.</p></div>"
  26,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لمن حوله ألا تستمعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وحوله: ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والهمزة للاستفهام، ولا نافية، وتستمعون فعل مضارع وفاعله.</p></div>"
  26,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ربكم ورب آبائكم الأولين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> خبر لمبتدأ محذوف، أي: هو، ورب آبائكم عطف على ربكم، والأولين صفة لآبائكم.</p></div>"
  26,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن رسولكم الذي أرسل إليكم لمجنون﴾</span></span>: قال فعل ماض، وإن حرف ناسخ، ورسول اسمها، والكاف مضاف إليه. والذي: صفة. وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسل إليكم﴾</span></span>: صلة للموصول لا محل لها من الإعراب، واللام المزحلقة، ومجنون خبر إن، وجملة إن رسولكم مقول القول.</p></div>"
  26,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب المشرق والمغرب وما بينهما إن كنتم تعقلون﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المشرق﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿المغرب﴾</span></span> معطوف على المشرق، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف أيضا، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿إن كنتم تعقلون﴾</span></span> شرط، وجوابه محذوف.</p></div>"
  26,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لئن اتخذت إلها غيري لأجعلنك من المسجونين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿لئن﴾</span></span> اللام موطئة للقسم، وإن شرطية، واتخذت فعل ماض وفاعل، والفعل في محل جزم فعل الشرط، وإلهًا مفعول به، وغيري صفة، واللام جواب القسم، وجواب الشرط محذوف دل عليه جواب القسم، وأجعلنك فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، والفاعل ضمير مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿من المسجونين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  26,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أولو جئتك بشيء مبين﴾</span></span>: قال فعل ماض، الهمزة للاستفهام، والواو للحال، ولو شرطية، وجئتك فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بشيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئتك﴾</span></span>، ومبين صفة لشيء.</p></div>"
  26,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فأت به إن كنت من الصادقين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿فائت﴾</span></span> الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿فائت﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل الشرط، وكان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  26,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقى عصاه فإذا هي ثعبان مبين﴾</span></span>: الفاء عاطفة، وألقى فعل ماض، وفاعله مستتر تقديره: هو، وعصاه مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا فجائية وهي ظرف، أو حرف، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وثعبان خبر، ومبين صفة.</p></div>"
  26,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونزع يده فإذا هي بيضاء للناظرين﴾</span></span>: الجملة معطوفة على سابقتها، ونزع فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿يده﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا فجائية وهي ظرف، أو حرف، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وبيضاء خبر، و<span class="hlt"><span class="qpc-hafs">﴿للناظرين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p></div>"
  26,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال للملأ حوله إن هذا لساحر عليم﴾</span></span>: قال فعل ماض، والواو فاعل، <span class="hlt"><span class="qpc-hafs">﴿للملأ﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وحوله ظرف متعلق بمحذوف حال، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، واللام المزحلقة، وساحر خبر، وعليم خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن هذا لساحر...﴾</span></span> مقول القول في محل نصب.</p></div>"
  26,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يريد أن يخرجكم من أرضكم بسحره﴾</span></span>: الجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ساحر﴾</span></span>، وأن وما في حيزها مفعول يريد، و<span class="hlt"><span class="qpc-hafs">﴿من أرضكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بسحره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فماذا تأمرون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> في محل نصب على أنه مفعول ثان لتأمرون بحذف الجار، والمفعول الأول محذوف، والتقدير: بأي شيء تأمرونني؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿تأمرون﴾</span></span> معطوفة على مقول القول. أو: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأمرون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف والتقدير: فما الذي تأمروننيه؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿ماذا تأمرون﴾</span></span> معطوفة على مقول القول.</p></div>"
  26,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أرجه وأخاه وابعث في المدائن حاشرين﴾</span></span>: قالوا فعل وفاعل، وأرجه فعل أمر، والهاء مفعول به، وأخاه عطف على الهاء، أو مفعول معه، وابعث عطف على أرجه، و<span class="hlt"><span class="qpc-hafs">﴿في المدائن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابعث﴾</span></span>، وحاشرين صفة لمفعول به محذوف، أي: جنودا يحشرون السحرة ويجمعونهم.</p></div>"
  26,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span></span>: يأتوك فعل مضارع مجزوم، لأنه جواب الأمر، والواو فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بكل سحار﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتوك﴾</span></span>، وعليم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سحار﴾</span></span>.</p></div>"
  26,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فجمع السحرة لميقات يوم معلوم﴾</span></span>: الفاء عاطفة على مقدر، وجمع فعل ماض مبني لما لم يسمَّ فاعله، والسحرة نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لميقات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جمع﴾</span></span>، ويوم مضاف إليه، ومعلوم صفة.</p></div>"
  26,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل للناس هل أنتم مجتمعون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> معطوف على ما تقدم، <span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، وأنتم مبتدأ، ومجتمعون خبر، والجملة مقول القول.</p></div>"
  26,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعلنا نتبع السحرة إن كانوا هم الغالبين﴾</span></span>: الجملة في محل نصب حال، ولعل حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿نتبع﴾</span></span> خبرها، والسحرة مفعول به، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وهو فعل الشرط، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، والغالبين خبر كان.</p></div>"
  26,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء السحرة قالوا لفرعون أئن لنا لأجرا إن كنا نحن الغالبين﴾</span></span>: الفاء عاطفة، ولما حينية ظرفية، أو رابطة، وجاء السحرة فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿لفرعون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، والهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، وأجرًا اسمها المؤخر، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وهو فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل، والغالبين خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  26,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال نعم وإنكم إذا لمن المقربين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> حرف جواب، أي: لكم الأجر، وإنكم عطف، وإن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جواب وجزاء، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المقربين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  26,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لهم موسى ألقوا ما أنتم ملقون﴾</span></span>: قال لهم موسى فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة ألقوا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنتم ملقون﴾</span></span> صلة الموصول لا محل لها من الإعراب، وأنتم مبتدأ، وملقون خبر.</p></div>"
  26,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقوا حبالهم وعصيهم وقالوا بعزة فرعون إنا لنحن الغالبون﴾</span></span>: الفاء عاطفة، وألقوا فعل وفاعل، وحبالهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عصيهم﴾</span></span> عطف على حبالهم، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> عطف على فألقوا، و<span class="hlt"><span class="qpc-hafs">﴿بعزة﴾</span></span> الباء حرف قسم وجر، وعزة مجرور بالباء، والجار والمجرور متعلقان بفعل محذوف، وتقديره: نقسم، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ونحن ضمير فصل، والغالبون خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، والغالبون خبر <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، والجملة خبر إن.</p></div>"
  26,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقى موسى عصاه فإذا هي تلقف ما يأفكون﴾</span></span>: الفاء عاطفة، وألقى موسى عصاه فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة تلقف خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة يأفكون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  26,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقي السحرة ساجدين﴾</span></span>: الفاء عاطفة، وألقي فعل ماض مبني لما لم يسمَّ فاعله، والسحرة نائب فاعل، وساجدين حال.</p></div>"
  26,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا آمنا برب العالمين﴾</span></span>: قالوا فعل ماض، والواو فاعل، وجملة آمنا من الفعل والفاعل مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿برب العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، وجملة القول بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿ألقي﴾</span></span>، أو حالية بتقدير: قد.</p></div>"
  26,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب موسى وهارون﴾</span></span>: رب بدل من رب العالمين، أو عطف بيان، وموسى مضاف إليه، وهارون معطوف.</p></div>"
  26,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال آمنتم له قبل أن آذن لكم﴾</span></span>: قال فعل ماض، وجملة آمنتم مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، وأن وما في حيزها في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آذن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لكبيركم الذي علمكم السحر فلسوف تعلمون﴾</span></span>: إن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وكبيركم خبر إن، والذي صفة، وجملة علمكم صلة الموصول لا محل لها من الإعراب، والكاف مفعول به أول، والسحر مفعول به ثان، <span class="hlt"><span class="qpc-hafs">﴿فلسوف﴾</span></span> الفاء الفصيحة، واللام واقعة في جواب قسم مقدر، وسوف حرف استقبال، وتعلمون فعل مضارع وفاعل، والمفعول محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿لأقطعن أيديكم وأرجلكم من خلاف ولأصلبنكم أجمعين﴾</span></span>: اللام واقعة في جواب قسم مقدر. وأقطعن: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل ضمير مستتر تقديره: أنا. وأيديكم: مفعول به. وأرجلكم: عطف على أيديكم. و<span class="hlt"><span class="qpc-hafs">﴿من خلاف﴾</span></span> جار ومجرور متعلقان بمحذوف حال. ولأصلبنكم: عطف على لأقطعن. وأجمعين: تأكيد للكاف.</p></div>"
  26,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لا ضير إنا إلى ربنا منقلبون﴾</span></span>: قالوا فعل ماض، والواو فاعل، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿ضير﴾</span></span> اسمها المبني على الفتح، وخبرها محذوف، أي: لا ضير علينا، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> تعليل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منقلبون﴾</span></span>، ومنقلبون خبر إن.</p></div>"
  26,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا نطمع أن يغفر لنا ربنا خطايانا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نطمع خبرها، والفاعل مستتر تقديره: نحن، وأن وما في حيزها نصب بنزع الخافض، أي: في غفران خطايانا، أو على تضمين <span class="hlt"><span class="qpc-hafs">﴿نطمع﴾</span></span> معنى نرجو، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها في محل نصب على المفعولية، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> فاعل يغفر، وخطايانا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن كنا أول المؤمنين﴾</span></span>: المصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن كنا﴾</span></span> منصوب بنزع الخافض، أي: لأن كنا، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وأول المؤمنين خبرها.</p></div>"
  26,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إلى موسى أن أسر بعبادي إنكم متبعون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأوحينا فعل وفاعل، وإلى موسى: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأسر: فعل أمر مبني على حذف حرف العلة، والفاعل مستتر. وبعبادي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span>، أو متعلقان بمحذوف حال، أي: مصحوبًا بعبادي، و<span class="hlt"><span class="qpc-hafs">﴿إنكم متبعون﴾</span></span>: إن واسمها، وخبرها. وجملة <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> تعليلة مستأنفة لا محل لها من الإعراب.</p></div>"
  26,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأرسل فرعون في المدائن حاشرين﴾</span></span>: الفاء عاطفة، وأرسل فرعون فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في المدائن﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وحاشرين مفعول به.</p></div>"
  26,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span></span>: الجملة مقول قول محذوف منصوب على الحال، أي: قائلًا، وإن حرف ناسخ، وهؤلاء اسمها، واللام المزحلقة، وشرذمة خبرها، وقليلون صفة.</p></div>"
  26,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم لنا لغائظون﴾</span></span>: الواو عاطفة، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غائظون﴾</span></span>، واللام المزحلقة، وغائظون خبر إن.</p></div>"
  26,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span></span>: الواو عاطفة، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وجميع خبر أول، وحاذرون خبر ثان.</p></div>"
  26,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخرجناهم من جنات وعيون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أخرجناهم﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من جنات وعيون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجناهم﴾</span></span>.</p></div>"
  26,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكنوز ومقام كريم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وكنوز ومقام﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جنات وعيون﴾</span></span>، وكريم صفة.</p></div>"
  26,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك وأورثناها بني إسرائيل﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر محذوف، أي: أخرجناهم مثل ذلك الإخراج، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أورثناها﴾</span></span> الواو عاطفة، أو اعتراضية، وأورثناها: فعل وفاعل ومفعول به أول، وبني: مفعول به ثان، وإسرائيل: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أورثناها...﴾</span></span>: معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أخرجناهم﴾</span></span>، أو اعتراضية لا محل لها من الإعراب.</p></div>"
  26,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتبعوهم مشرقين﴾</span></span>: الفاء عاطفة، وأتبعوهم فعل ماض وفاعل ومفعول به ثان، ومشرقين حال.</p></div>"
  26,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما تراءى الجمعان قال أصحاب موسى إنا لمدركون﴾</span></span>: الفاء عاطفة، ولما ظرفية حينية، أو رابطة، وتراءى الجمعان فعل ماض وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، وأصحاب فاعل قال، وجملة إنا لمدركون مقول القول.</p></div>"
  26,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كلا إن معي ربي سيهدين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿كلا﴾</span></span> حرف ردع وزجر، وإن حرف ناسخ، والظرف متعلق بمحذوف خبر مقدم، وربي اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿إن معي﴾</span></span> تعليل لهذا الردع، وجملة سيهدين استئنافية لا محل لها من الإعراب.</p></div>"
  26,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوحينا إلى موسى أن اضرب بعصاك البحر فانفلق﴾</span></span>: الفاء عاطفة، وأوحينا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى موسى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿اضرب بعصاك البحر﴾</span></span>: فعل أمر، وفاعل مستتر، ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿بعصاك﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فانفلق﴾</span></span> الفاء الفصيحة، أي: فضرب فانفلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكان كل فرق كالطود العظيم﴾</span></span>: الفاء عاطفة، وكان فعل ماض ناقص، وكل اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فرق﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿كالطود﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿الطود﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> صفة للطود.</p></div>"
  26,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأزلفنا ثم الآخرين﴾</span></span>: الواو عاطفة، وأزلفنا فعل وفاعل، وثم ظرف بمعنى هناك، والآخرين مفعول به.</p></div>"
  26,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنجينا موسى ومن معه أجمعين﴾</span></span>: الواو عاطفة، وأنجينا فعل وفاعل، وهو عطف على ما تقدم، وموسى مفعول به، ومَن عطف على موسى، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف مكان متعلق بمحذوف صلة مَن، وجملة الصلة لا محل لها من الإعراب. وأجمعين تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p></div>"
  26,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أغرقنا الآخرين﴾</span></span>: عطف على ما تقدم، وأغرقنا فعل وفاعل، والآخرين مفعول به.</p></div>"
  26,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية وما كان أكثرهم مؤمنين﴾</span></span>: إن حرف ناسخ، <span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وآية اسم إن منصوب، والواو حرف عطف، وما نافية، وكان فعل ماض ناقص، وأكثرهم اسمها، ومؤمنين خبر كان.</p></div>"
  26,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: عطف على ما تقدم، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز الرحيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ،  والعزيز الرحيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن.</p></div>"
  26,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتل عليهم نبأ إبراهيم﴾</span></span>: الواو عاطفة، واتل معطوف على اذكر المقدرة في قوله: <span class="hlt"><span class="qpc-hafs">﴿وإذ نادى ربك موسى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتل﴾</span></span>، ونبأ إبراهيم مفعول به.</p></div>"
  26,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لأبيه وقومه ما تعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نبأ﴾</span></span>، أو اسم مبني على السكون في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿نبأ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿لأبيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وقومه معطوفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل نصب مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>، وجملة ما تعبدون مقول القول.</p></div>"
  26,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا نعبد أصناما فنظل لها عاكفين﴾</span></span>: قالوا فعل ماض، والواو فاعل، وجملة نعبد أصنامًا في محل نصب مقول القول، <span class="hlt"><span class="qpc-hafs">﴿فنظل﴾</span></span> الفاء عاطفة، ونظل فعل مضارع ناقص ناسخ، واسمها ضمير مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاكفين﴾</span></span>، وعاكفين خبر نظل.</p></div>"
  26,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هل يسمعونكم إذ تدعون﴾</span></span>: قال فعل ماض، هل حرف استفهام، ويسمعونكم فعل مضارع، وفاعل، والكاف مفعول به، على تقدير محذوف، أي: يسمعون دعاءكم، أو يسمعونكم تدعون، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يسمعونكم﴾</span></span>، وتدعون فعل مضارع وفاعل، وجملة تدعون مجرورة بإضافة الظرف إليها.</p></div>"
  26,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو ينفعونكم أو يضرون﴾</span></span>: عطف على يسمعونكم، وينفعونكم فعل مضارع، والواو فاعل، والكاف مفعول به، ويضرون مثلها.</p></div>"
  26,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بل وجدنا آباءنا كذلك يفعلون﴾</span></span>: قالوا فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب، ووجدنا فعل وفاعل، وآباءنا مفعول أول لـ<span class="hlt"><span class="qpc-hafs">﴿وجدنا﴾</span></span>، وجملة يفعلون هي المفعول الثاني، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر محذوف، أي: يفعلون فعلًا مثل ذلك، أو مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يفعلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب.</p></div>"
  26,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أفرأيتم ما كنتم تعبدون﴾</span></span>: قال فعل ماض، الهمزة للاستفهام، والفاء عاطفة على محذوف، وجملة كنتم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، لا محل لها من الإعراب. وجملة تعبدون خبر كنتم.</p></div>"
  26,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أنتم وآباؤكم الأقدمون﴾</span></span>: أنتم تأكيد للضمير في <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>، وآباؤكم عطف على <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>، والأقدمون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آباؤكم﴾</span></span>.</p></div>"
  26,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم عدو لي إلا رب العالمين﴾</span></span>: الفاء تعليلية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وعدو خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عدو﴾</span></span>، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> نصب على الاستثناء، والاستثناء منقطع، والعالمين مضاف إليه.</p></div>"
  26,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي خلقني﴾</span></span>: الذي نصب على النعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب العالمين﴾</span></span>، أو بدل، أو عطف بيان، أو الرفع على أنه خبر لمبتدأ محذوف، أي: هو الذي خلقني، وقيل: مبتدأ وخبره جملة <span class="hlt"><span class="qpc-hafs">﴿هو يهدين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو يهدين﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة يهدين خبره، وحذفت الياء لمراعاة الفواصل.</p></div>"
  26,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذي هو يطعمني ويسقين﴾</span></span>: عطف على ما سبق، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة يطعمني خبر، ويسقين عطف على يطعمني.</p></div>"
  26,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مرضت فهو يشفين﴾</span></span>: الواو عاطفة، وإذا ظرف لما يستقبل من الزمان متضمن معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يشفين﴾</span></span>، مرضت فعل وفاعل. والفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة يشفين خبره، وحذفت الياء لمراعاة الفواصل.</p></div>"
  26,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذي يميتني ثم يحيين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> خبر لمبتدأ محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿يميتني﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ثم يحيين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يميتني﴾</span></span>.</p></div>"
  26,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذي أطمع أن يغفر لي خطيئتي يوم الدين﴾</span></span>: الواو عاطفة، والذي عطف على ما قبله، وجملة أطمع صلة الموصول لا محل لها من الإعراب. وأن وما في حيزها نصب بنزع الخافض، أي: في أن يغفر، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span>، وخطيئتي مفعول يغفر، ويوم الدين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span> أيضًا.</p></div>"
  26,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب هب لي حكما وألحقني بالصالحين﴾</span></span>: رب منادى مضاف لياء المتكلم حذف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span> فعل دعاء مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>، وحكمًا مفعول به، وألحقني فعل دعاء مبني على السكون عطف على <span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالصالحين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألحقني﴾</span></span>.</p></div>"
  26,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واجعل لي لسان صدق في الآخرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span>، ولسان صدق مفعول <span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span> الأول، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  26,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واجعلني من ورثة جنة النعيم﴾</span></span>: اجعلني فعل دعاء مبني على السكون، والياء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿من ورثة﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول اجعلني الثاني، وجنة النعيم مضاف إليه.</p></div>"
  26,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واغفر لأبي إنه كان من الضالين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لأبي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span>، وإن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من الضالين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> تعليلية.</p></div>"
  26,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تخزني يوم يبعثون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> طلبية، و<span class="hlt"><span class="qpc-hafs">﴿تخزني﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تخزني﴾</span></span>، ويبعثون فعل مضارع مبني لما لم يسمّ فاعله، والواو نائب فاعل، وجملة يبعثون في محل جر بإضافة الظرف إليها.</p></div>"
  26,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم لا ينفع مال ولا بنون﴾</span></span>: يوم ظرف في محل نصب بدل من يوم الأول، <span class="hlt"><span class="qpc-hafs">﴿لا ينفع مال﴾</span></span> لا نافية، و<span class="hlt"><span class="qpc-hafs">﴿ينفع﴾</span></span> فعل مضارع، ومال فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ينفع مال﴾</span></span> في محل جر بإضافة الظرف إليها، <span class="hlt"><span class="qpc-hafs">﴿ولا بنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿مال﴾</span></span>.</p></div>"
  26,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من أتى الله بقلب سليم﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مبني على السكون في محل نصب بدل من المفعول المحذوف، أو استثناء منه، والتقدير: لا ينفع مال ولا بنون أحدًا إلا من أتى، وقيل: مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿ينفع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بقلب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتى﴾</span></span>، أو متعلقان بمحذوف حال، أي: مصحوبًا، و<span class="hlt"><span class="qpc-hafs">﴿سليم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قلب﴾</span></span>.</p></div>"
  26,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأزلفت الجنة للمتقين﴾</span></span>: الواو عاطفة، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿لا ينفع﴾</span></span>، وأزلفت فعل ماض مبني لما لم يسمَّ فاعله، والجنة نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أزلفت﴾</span></span>.</p></div>"
  26,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبرزت الجحيم للغاوين﴾</span></span>: الواو عاطفة، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أزلفت الجنة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿برزت﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والجحيم نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿للغاوين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿برزت﴾</span></span>.</p></div>"
  26,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل لهم أين ما كنتم تعبدون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أين﴾</span></span> اسم استفهام في محل نصب على الظرفية المكانية متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبتدأ مؤخر، وجملة كنتم صلة الموصول لا محل لها من الإعراب. وجملة تعبدون خبر كنتم.</p></div>"
  26,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من دون الله هل ينصرونكم أو ينتصرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وهل حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿ينصرونكم﴾</span></span> فعل مضارع وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وينتصرون فعل مضارع وفاعل.</p></div>"
  26,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكبكبوا فيها هم والغاوون﴾</span></span>: الفاء حرف عطف، وكبكبوا فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كبكبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> توكيد للواو في <span class="hlt"><span class="qpc-hafs">﴿كبكبوا﴾</span></span>، والغاوون عطف على الواو في <span class="hlt"><span class="qpc-hafs">﴿كبكبوا﴾</span></span>.</p></div>"
  26,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجنود إبليس أجمعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿جنود﴾</span></span> عطف على الواو في <span class="hlt"><span class="qpc-hafs">﴿كبكبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إبليس﴾</span></span> مضاف إليه، وأجمعون توكيد مرفوع بالواو.</p></div>"
  26,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا وهم فيها يختصمون﴾</span></span>: قالوا فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختصمون﴾</span></span>، وجملة يختصمون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والضمير يعود على <span class="hlt"><span class="qpc-hafs">﴿الغاوون﴾</span></span>.</p></div>"
  26,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تالله إن كنا لفي ضلال مبين﴾</span></span>: الجار والمجرور <span class="hlt"><span class="qpc-hafs">﴿تالله﴾</span></span> متعلقان بفعل محذوف تقديره: نقسم، والجملة في محل نصب مقول <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، ومبين صفة.</p></div>"
  26,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ نسويكم برب العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كنّا في ضلال﴾</span></span> في الآية السابقة، أو متعلق بفعل محذوف والتقدير: ضللنا إذ نسويكم، و<span class="hlt"><span class="qpc-hafs">﴿نسويكم﴾</span></span> فعل مضارع والفاعل مستتر، والكاف مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسويكم﴾</span></span> في محل جر بإضافة الظرف إليها، <span class="hlt"><span class="qpc-hafs">﴿برب العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسويكم﴾</span></span>.</p></div>"
  26,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أضلنا إلا المجرمون﴾</span></span>: الواو عاطفة، أو حالية، وما نافية، وأضلنا فعل ماض ومفعول به مقدم، وإلا أداة حصر، والمجرمون فاعل أضلنا.</p></div>"
  26,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما لنا من شافعين﴾</span></span>: الفاء الفصيحة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿شافعين﴾</span></span> مجرور لفظًا مرفوع محلًّا على أنه مبتدأ مؤخر.</p></div>"
  26,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا صديق حميم﴾</span></span>: عطف على شافعين، وحميم صفة لصديق.</p></div>"
  26,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلو أن لنا كرة فنكون من المؤمنين﴾</span></span>: الفاء استئنافية، ولو حرف للتمني، أو للشرط، والجواب محذوف تقديره: لفعلنا كيت وكيت، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، وأن وما في حيزها مفعول لفعل محذوف تقديره: نتمنى، أو فاعل لفعل محذوف إن كانت <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> للشرط، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن المقدم، و<span class="hlt"><span class="qpc-hafs">﴿كرة﴾</span></span> اسم أن المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلو أن...﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فنكون﴾</span></span> الفاء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿نكون﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد الفاء، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق أي: ليت لنا رجوعًا فكوننا من المؤمنين، واسم نكون ضمير مستتر، تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر نكون.</p></div>"
  26,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية وما كان أكثرهم مؤمنين﴾</span></span>: إن حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> اسمها المؤخر، وما نافية، وكان فعل ماض ناقص، وأكثرهم اسمها، ومؤمنين خبرها.</p></div>"
  26,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو العزيز الرحيم﴾</span></span> خبر إن.</p></div>"
  26,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قوم نوح المرسلين﴾</span></span>: كذبت فعل ماض، وقوم فاعل، ونوح مضاف إليه، والمرسلين مفعول به.</p></div>"
  26,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لهم أخوهم نوح ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخوهم﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، ونوح بدل، وألا أداة عرض، وتتقون فعل مضارع وفاعل.</p></div>"
  26,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span></span>: إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان برسول، و<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span> خبر إن، وأمين صفة.</p></div>"
  26,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا الله فعل أمر وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أسألكم عليه من أجر إن أجري إلا على رب العالمين﴾</span></span>: الواو عاطفة، وما نافية، وأسألكم فعل مضارع وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span> مجرور لفظًا منصوب محلًّا، لأنه مفعول به، وإن نافية، وأجري مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿على رب العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا فعل أمر، والواو فاعل، ولفظ الجلالة مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أنؤمن لك واتبعك الأرذلون﴾</span></span>: قال فعل ماض،والواو فاعل، <span class="hlt"><span class="qpc-hafs">﴿أنؤمن﴾</span></span> الهمزة للاستفهام، ونؤمن فعل مضارع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤمن﴾</span></span>، والواو للحال على إضمار قد، و<span class="hlt"><span class="qpc-hafs">﴿اتبعك الأرذلون﴾</span></span> اتبع فعل ماض، والكاف مفعول به، والأرذلون فاعل.</p></div>"
  26,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال وما علمي بما كانوا يعملون﴾</span></span>: قال فعل ماض، والواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية في محل رفع بالابتداء، وعلمي خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علمي﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، والخبر محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة يعملون خبر كانوا.</p></div>"
  26,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن حسابهم إلا على ربي لو تشعرون﴾</span></span>: إن نافية، وحسابهم مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿على ربي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿حسابهم﴾</span></span>، ولو امتناعية، وتشعرون فعل مضارع مرفوع، وجواب لو محذوف، تقديره: ما عبتموهم وما نسبتم إليهم أي نقص.</p></div>"
  26,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنا بطارد المؤمنين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بطارد﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿طارد﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> مضاف إليه.</p></div>"
  26,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن أنا إلا نذير مبين﴾</span></span>: إن نافية، وأنا مبتدأ، وإلا أداة حصر، ونذير خبر، ومبين صفة.</p></div>"
  26,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لئن لم تنته يا نوح لتكونن من المرجومين﴾</span></span>: قال فعل ماض، والواو فاعل، واللام موطئة للقسم، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، وتنته فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والفاعل ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لتكونن﴾</span></span> اللام جواب القسم، وجواب الشرط محذوف، وتكونن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، واسم تكونن ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿من المرجومين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إن قومي كذبون﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> منادى مضاف إلى ياء المتكلم المحذوفة، وحرف النداء محذوف، وإن حرف ناسخ، وقومي اسمها، وجملة كذبون خبرها، وكذبون فعل ماض، والواو فاعل، وياء المتكلم المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فافتح بيني وبينهم فتحا ونجني ومن معي من المؤمنين﴾</span></span>: الفاء الفصيحة، وافتح فعل للطلب، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿افتح﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span>، وفتحًا مفعول مطلق، أو مفعول به، <span class="hlt"><span class="qpc-hafs">﴿ونجني﴾</span></span> الواو عاطفة، ونجني عطف على <span class="hlt"><span class="qpc-hafs">﴿افتح﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> الواو عاطفة، أو للمعية، ومَن عطف على الياء في <span class="hlt"><span class="qpc-hafs">﴿نجني﴾</span></span>، أو مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿معي﴾</span></span> ظرف متعلق بمحذوف صلة مَن، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  26,119,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأنجيناه ومن معه في الفلك المشحون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأنجيناه فعل ماض وفاعل ومفعول به، ومَن مفعول معه، أو عطف على الهاء في أنجيناه، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف متعلق بمحذوف صلة، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿في الفلك﴾</span></span> جار ومجرور متعلقان بالاستقرار الذي تعلق به الظرف، والمشحون صفة للفلك.</p></div>"
  26,120,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أغرقنا بعد الباقين﴾</span></span>: ثم حرف عطف للتراخي، وأغرقنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف زمان مبني على الضم لانقطاعه عن الإضافة لفظًا لا معنى، والمراد: بعد إنجائهم، والباقين مفعول أغرقنا.</p></div>"
  26,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية وما كان أكثرهم مؤمنين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، واللام المزحلقة، وآية اسم إن المؤخر، والواو عاطفة، أو حالية، وما نافية، وكان فعل ماض ناقص، وأكثرهم اسمها، ومؤمنين خبرها.</p></div>"
  26,122,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو العزيز الرحيم﴾</span></span> خبر إن.</p></div>"
  26,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت عاد المرسلين﴾</span></span>: فعل وفاعل ومفعول به، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  26,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لهم أخوهم هود ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وأخوهم فاعل، وهود بدل من <span class="hlt"><span class="qpc-hafs">﴿أخوهم﴾</span></span>، وألا أداة عرض، وتتقون فعل مضارع وفاعل، والجملة مقول القول.</p></div>"
  26,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان برسول، ورسول خبر إن، وأمين صفة لرسول.</p></div>"
  26,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا الله فعل أمر وفاعل ومفعول به، وأطيعون الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أسألكم عليه من أجر إن أجري إلا على رب العالمين﴾</span></span>: الواو عاطفة، وما نافية، وأسألكم فعل مضارع، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span> مجرور لفظًا منصوب محلًّا، لأنه مفعول به، وإن نافية، وأجري مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿على رب العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتبنون بكل ريع آية تعبثون﴾</span></span>: الاستفهام للتقريع والتوبيخ، وتبنون فعل مضارع، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكل ريع﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبنون﴾</span></span>، وآية مفعول به، وتعبثون فعل مضارع وفاعل، وجملة تعبثون في محل نصب على الحال.</p></div>"
  26,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتتخذون مصانع لعلكم تخلدون﴾</span></span>: الواو عاطفة، وتتخذون عطف على تبنون، وتتخذون فعل مضارع وفاعل، ومصانع مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لعلكم تخلدون﴾</span></span> لعل حرف ناسخ، والكاف اسمها، وجملة تخلدون خبرها، وجملة الرجاء في محل نصب على الحال، أي: راجين ومؤملين أن تخلدوا في الدنيا.</p></div>"
  26,130,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا بطشتم بطشتم جبارين﴾</span></span>: الواو عاطفة، وإذا ظرف متعلق بالجواب وهو بطشتم الثانية، وبطشتم فعل ماض، والتاء فاعل، وجملة بطشتم الأولى في محل جر بإضافة <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> إليها، وجبارين حال، أي: غير مبالين بالنتائج والعواقب.</p></div>"
  26,131,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا الله فعل أمر وفاعل ومفعول به، وأطيعون الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,132,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتقوا الذي أمدكم بما تعلمون﴾</span></span>: الواو عاطفة، واتقوا فعل أمر وفاعل، والذي مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أمدكم﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمدكم﴾</span></span>، وجملة تعلمون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  26,133,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمدكم بأنعام وبنين﴾</span></span>: أمدكم: فعل ماض، ومفعول به، والفاعل مستتر. و<span class="hlt"><span class="qpc-hafs">﴿بأنعام﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمدكم﴾</span></span>. وبنين: معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أنعام﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿أمدكم بأنعام﴾</span></span> تفسيرية لجملة <span class="hlt"><span class="qpc-hafs">﴿أمدكم بما تعلمون﴾</span></span> السابقة، لا محل لها من الإعراب. أو بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿أمدكم بما تعلمون﴾</span></span> بإعادة العامل.</p></div>"
  26,134,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجنات وعيون﴾</span></span>: عطف على ما تقدم.</p></div>"
  26,135,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني أخاف عليكم عذاب يوم عظيم﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة أخاف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، وعذاب مفعول به، ويوم مضاف إليه، وعظيم صفة.</p></div>"
  26,136,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا سواء علينا أوعظت أم لم تكن من الواعظين﴾</span></span>: سواء خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿وعظت﴾</span></span> فعل ماض وفاعل، وأم عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تكن﴾</span></span> مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، واسمه مستتر تقديره: أنت، <span class="hlt"><span class="qpc-hafs">﴿من الواعظين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وهمزة التسوية وما في حيزها في تأويل مصدر مبتدأ مؤخر، أي: سواء علينا وعظك.</p></div>"
  26,137,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span></span>: إن نافية، وهذا مبتدأ، وإلا أداة حصر، وخلق خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، والأولين مضاف إليه.</p></div>"
  26,138,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما نحن بمعذبين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمعذبين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿معذبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  26,139,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه فأهلكناهم﴾</span></span>: الفاء الفصيحة، وكذبوه فعل ماض، والواو فاعل، والهاء مفعول به، فأهلكناهم عطف على <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، واللام المزحلقة، وآية اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span></span>: الواو حرف عطف، وما نافية، وكان فعل ماض ناقص ناسخ، وأكثرهم اسمها، ومؤمنين خبرها.</p></div>"
  26,140,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، ورب اسم إن، والكاف مضاف إليه، واللام المزحلقة، وهو ضمير فصل، والعزيز خبر أول لإن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، والجملة خبر إن.</p></div>"
  26,141,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت ثمود المرسلين﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وكذبت فعل ماض، وثمود فاعل، والمرسلين مفعول به.</p></div>"
  26,142,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لهم أخوهم صالح ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، ولهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخوهم﴾</span></span> فاعل، وصالح بدل من <span class="hlt"><span class="qpc-hafs">﴿أخوهم﴾</span></span>، وألا أداة عرض، وتتقون فعل مضارع، والواو فاعل، والجملة مقول القول.</p></div>"
  26,143,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان برسول، ورسول خبر إن، وأمين صفة لرسول.</p></div>"
  26,144,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا الله فعل أمر وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,145,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أسألكم عليه من أجر إن أجري إلا على رب العالمين﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿أسألكم﴾</span></span> فعل مضارع، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿أجر﴾</span></span> مجرور لفظًا منصوب محلًّا، لأنه مفعول به، وإن نافية، وأجري مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿على رب العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,146,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتتركون في ما ههنا آمنين﴾</span></span>: الهمزة للاستفهام، وتتركون فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿فيما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتركون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> حرف تنبيه، وهنا اسم إشارة في محل نصب ظرف مكان متعلق بمحذوف صلة للموصول، وجملة الصلة لا محل لها من الإعراب. وآمنين حال من الواو في تتركون.</p></div>"
  26,147,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في جنات وعيون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿في جنات﴾</span></span> جار ومجرور متعلقان بمحذوف بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿فيما هاهنا﴾</span></span> بإعادة الجار، وعيون عطف على جنات.</p></div>"
  26,148,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وزروع ونخل طلعها هضيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿زروع ونخل﴾</span></span> عطف على جنات، وطلعها مبتدأ، وهضيم خبر، والجملة صفة لنخل.</p></div>"
  26,149,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فارهين﴾</span></span>: الواو حرف عطف، وتنحتون عطف على تتركون، فهو في حيز الاستفهام الإنكاري التوبيخي، ومحل جملة الاستفهام التوبيخية نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿من الجبال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنحتون﴾</span></span>، وبيوتًا مفعول به، وفارهين حال.</p></div>"
  26,150,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا الله فعل أمر وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,151,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span></span>: الواو عاطفة، ولا ناهية، وتطيعوا فعل مضارع مجزوم بلا الناهية، والواو فاعل، وأمر المسرفين مفعول.</p></div>"
  26,152,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يفسدون في الأرض ولا يصلحون﴾</span></span>: الذين صفة للمسرفين، وجملة يفسدون صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفسدون﴾</span></span>، ولا يصلحون عطف على قوله يفسدون.</p></div>"
  26,153,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span></span>: إنما كافة ومكفوفة، وأنت مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المسحرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول.</p></div>"
  26,154,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أنت إلا بشر مثلنا فأت بآية إن كنت من الصادقين﴾</span></span>: ما نافية، وأنت مبتدأ، وإلا أداة حصر، وبشر خبر، ومثلنا صفة، <span class="hlt"><span class="qpc-hafs">﴿فائت﴾</span></span> الفاء الفصيحة، أي: إن كنت صادقًا كما تزعم فائت، و<span class="hlt"><span class="qpc-hafs">﴿بآية﴾</span></span> جار ومجرور متعلقان بقوله: فائت، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، وهو في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، وجواب إن محذوف دل عليه ما قبله، أي: فائت بآية.</p></div>"
  26,155,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هذه ناقة لها شرب ولكم شرب يوم معلوم﴾</span></span>: هذه مبتدأ، وناقة خبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وشرب مبتدأ مؤخر، والجملة صفة لناقة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وشرب يوم مبتدأ مؤخر، ومعلوم صفة ليوم.</p></div>"
  26,156,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تمسوها بسوء فيأخذكم عذاب يوم عظيم﴾</span></span>: الواو عاطفة، ولا ناهية، وتمسوها فعل مضارع مجزوم بلا، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بسوء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمسوها﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فيأخذكم﴾</span></span> الفاء هي السببية، ويأخذكم فعل مضارع منصوب بأن مضمرة بعد الفاء، والكاف مفعول به، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق أي: لا يكن مَسٌّ فأخْذٌ، وعذاب فاعل، ويوم مضاف إليه، وعظيم صفة يوم.</p></div>"
  26,157,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعقروها فأصبحوا نادمين﴾</span></span>: الفاء عاطفة، وعقروها فعل وفاعل، ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فأصبحوا﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أصبحوا نادمين﴾</span></span> فعل ماض ناقص، والواو اسمها، ونادمين خبرها، أو <span class="hlt"><span class="qpc-hafs">﴿أصبحوا﴾</span></span> تامة، والواو فاعل، ونادمين حال.</p></div>"
  26,158,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم العذاب﴾</span></span>: الفاء عاطفة، وأخذهم فعل ماض، والهاء مفعول مقدم، والعذاب فاعل مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية﴾</span></span>: تعليل للأخذ، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> اسم إن مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span></span>: الواو حرف عطف، وما نافية، وكان فعل ماض ناقص ناسخ، وأكثرهم اسمها، ومؤمنين خبرها.</p></div>"
  26,159,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، ورب اسم إن، والكاف مضاف إليه، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، والجملة خبر إن.</p></div>"
  26,160,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قوم لوط المرسلين﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وكذبت فعل، وقوم فاعل، ولوط مضاف إليه، والمرسلين مفعول به.</p></div>"
  26,161,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لهم أخوهم لوط ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وأخوهم فاعل، ولوط بدل من <span class="hlt"><span class="qpc-hafs">﴿أخوهم﴾</span></span>، وألا أداة عرض، وتتقون فعل مضارع، والواو فاعل، والجملة مقول القول.</p></div>"
  26,162,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span></span>: الجملة تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span> إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>، ورسول خبر إن، وأمين صفة لرسول.</p></div>"
  26,163,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,164,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أسألكم عليه من أجر﴾</span></span>: الواو عاطفة، وما نافية، وأسألكم فعل مضارع، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، وأجر مجرور لفظًا منصوب محلًّا، لأنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أجري إلا على رب العالمين﴾</span></span>: إن نافية، وأجري مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿على رب العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,165,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتأتون الذكران من العالمين﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿تأتون﴾</span></span> فعل مضارع، والواو فاعل، والذكران مفعول به، والجملة في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿من العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  26,166,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span></span>: الواو عاطفة، وتذرون عطف على تأتون داخل في حيز الاستفهام التوبيخي، وهو فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وخلق فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بخلق، وربكم فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق لكم ربكم﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من أزواجكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال على أن <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبيين، أو هي للتبعيض.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف إضراب، وأنتم مبتدأ، وقوم خبر، وعادون صفة.</p></div>"
  26,167,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لئن لم تنته يا لوط لتكونن من المخرجين﴾</span></span>: قالوا فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لئن﴾</span></span> اللام موطئة للقسم، وإن شرطية، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تنته﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لتكونن﴾</span></span> اللام واقعة في جواب القسم، و<span class="hlt"><span class="qpc-hafs">﴿تكونن﴾</span></span> فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، واسمه ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿من المخرجين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,168,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إني لعملكم من القالين﴾</span></span>: قال فعل ماض، وإن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لعملكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿القالين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من القالين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، والجملة مقول القول، وقيل: <span class="hlt"><span class="qpc-hafs">﴿من القالين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للخبر المحذوف، أي: لقالٍ من القالين، و<span class="hlt"><span class="qpc-hafs">﴿لعملكم﴾</span></span> جار ومجرور متعلقان بالخبر المحذوف.</p></div>"
  26,169,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب نجني وأهلي مما يعملون﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، وقد حذف منه حرف النداء، ونجني دعاء، والياء مفعول به، وأهلي مفعول معه، أو معطوف على الياء، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجني﴾</span></span>، وجملة يعملون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  26,170,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنجيناه وأهله أجمعين﴾</span></span>: الفاء عاطفة على محذوف مقدر، ونجيناه فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وأهله مفعول معه، أو معطوف على الهاء، وأجمعين تأكيد.</p></div>"
  26,171,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span></span>: إلا أداة استثناء، وعجوزًا مستثنى بإلا، و<span class="hlt"><span class="qpc-hafs">﴿في الغابرين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عجوزًا﴾</span></span>.</p></div>"
  26,172,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم دمرنا الآخرين﴾</span></span>: ثم عاطفة، ودمرنا فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والآخرين مفعول به.</p></div>"
  26,173,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأمطرنا عليهم مطرا فساء مطر المنذرين﴾</span></span>: الواو عاطفة، وأمطرنا عطف على دمرنا، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمطرنا﴾</span></span>، ومطرًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فساء﴾</span></span> الفاء حرف عطف، وساء فعل للذم، ومطر المنذرين فاعل ساء، والمخصوص بالذم محذوف تقديره: مطرهم.</p></div>"
  26,174,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> اسمها المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span></span>: الواو حالية، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، وأكثرهم اسمها، ومؤمنين خبرها.</p></div>"
  26,175,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، ورب اسم إن، والكاف مضاف إليه، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، والجملة خبر إن.</p></div>"
  26,176,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وكذب فعل ماض، وأصحاب فاعل، والأيكة مضاف إليه، والمرسلين مفعول به.</p></div>"
  26,177,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لهم شعيب ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، وقال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وشعيب فاعل، ألا أداة عرض، وتتقون فعل مضارع، والواو فاعل، والجملة مقول القول.</p></div>"
  26,178,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان برسول، ورسول خبر إن، وأمين صفة لرسول.</p></div>"
  26,179,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء الفصيحة، واتقوا الله فعل أمر وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> الواو عاطفة، وأطيعون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لمراعاة الفواصل مفعول به.</p></div>"
  26,180,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أسألكم عليه من أجر﴾</span></span>: الواو عاطفة، وما نافية، وأسألكم فعل مضارع، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، وأجر مجرور لفظًا منصوب محلًّا، لأنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أجري إلا على رب العالمين﴾</span></span>: إن نافية، وأجري مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿على رب العالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  26,181,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أوفوا الكيل ولا تكونوا من المخسرين﴾</span></span>: أوفوا فعل أمر، والواو فاعل، والكيل مفعول به، والواو حرف عطف، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تكونوا﴾</span></span> فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المخسرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  26,182,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وزنوا بالقسطاس المستقيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿زنوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، <span class="hlt"><span class="qpc-hafs">﴿بالقسطاس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زنوا﴾</span></span>، أو بمحذوف حال، والمستقيم نعت.</p></div>"
  26,183,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span></span>: الواو عاطفة، ولا ناهية، وتبخسوا فعل مضارع مجزوم بلا، والواو فاعل، والناس مفعول به أول، وأشياءهم مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span></span>: لا تعثوا عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تبخسوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعثوا﴾</span></span>، مفسدين حال مؤكدة لمعنى عاملها.</p></div>"
  26,184,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتقوا الذي خلقكم والجبلة الأولين﴾</span></span>: الواو عاطفة، واتقوا فعل أمر، والواو فاعل، والذي مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> فعل ماض، والفاعل ضمير مستتر تقديره: هو، والكاف مفعول به، وجملة خلقكم صلة الموصول لا محل لها من الإعراب. والجبلة عطف على <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>، والأولين صفة للجبلة.</p></div>"
  26,185,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span></span>: قالوا فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، وأنت مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المسحرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول.</p></div>"
  26,186,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا﴾</span></span>: الواو عاطفة، وما نافية، وأنت مبتدأ، وإلا أداة حصر، وبشر خبر، ومثلنا نعت لبشر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن نظنك لمن الكاذبين﴾</span></span>: الواو حرف عطف، وإن مخففة من الثقيلة مهملة، ونظنك فعل مضارع مرفوع، والفاعل مستتر تقديره: نحن، والكاف مفعول به، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نظنك﴾</span></span>.</p></div>"
  26,187,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء إن كنت من الصادقين﴾</span></span>: الفاء الفصيحة، وأسقط فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسقط﴾</span></span>، وكسفًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كسفًا﴾</span></span>، وإن شرطية، وكنت فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وجواب الشرط محذوف دل عليه ما قبله، أي: فأسقط علينا.</p></div>"
  26,188,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ربي أعلم بما تعملون﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مبتدأ، وأعلم خبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  26,189,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه فأخذهم عذاب يوم الظلة﴾</span></span>: الفاء عاطفة، وكذبوه فعل ماض، والواو فاعل، والهاء مفعول به، فأخذهم فعل ماض، والهاء مفعول به، وعذاب يوم الظلة فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان عذاب يوم عظيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، واسم كان ضمير مستتر تقديره: هو، وعذاب خبر كان، ويوم مضاف إليه، وعظيم صفة.</p></div>"
  26,190,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآية اسمها المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span></span>: الواو حالية، وما نافية، وكان فعل ماض ناقص ناسخ، وأكثرهم اسم كان، ومؤمنين خبرها.</p></div>"
  26,191,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، والجملة خبر إن.</p></div>"
  26,192,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، والضمير يعود على القرآن، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تنزيل رب العالمين﴾</span></span> خبرها.</p></div>"
  26,193,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نزل به الروح الأمين﴾</span></span>: نزل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا به، فالباء للملابسة، والروح فاعل، والأمين صفة، والجملة صفة لتنزيل.</p></div>"
  26,194,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿على قلبك لتكون من المنذرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿على قلبك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، واللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من المنذرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>.</p></div>"
  26,195,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بلسان عربي مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بلسان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿المنذرين﴾</span></span>، أو بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> بإعادة العامل، أي: نزل بلسان عربي، وعربي صفة، ومبين صفة ثانية.</p></div>"
  26,196,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span></span>: عطف على ما تقدم، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في زبر الأولين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  26,197,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على مقدر، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يكن﴾</span></span> فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> وتقدم عليها، وآية خبر يكن المقدم، و<span class="hlt"><span class="qpc-hafs">﴿أن يعلمه﴾</span></span> في تأويل مصدر اسم يكن، وعلماء بني إسرائيل فاعل يعلمه.</p></div>"
  26,198,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين﴾</span></span>: الواو عاطفة، ولو شرطية امتناعية، ونزلناه فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض الأعجمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلناه﴾</span></span>.</p></div>"
  26,199,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقرأه عليهم﴾</span></span>: الفاء عاطفة، وقرأه فعل ماض، وفاعل مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿بعض الأعجمين﴾</span></span>، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قرأه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كانوا به مؤمنين﴾</span></span>: ما نافية، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمؤمنين، و<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span> خبر كانوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما كانوا به مؤمنين﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  26,200,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر مقدر مؤكد لفعل محذوف، وتقدير الكلام: سلكناه سلكًا مثل هذا السلك البديع المذكور، أي: أدخلنا القرآن في قلوب المجرمين ففهموا معانيه وعرفوا فصاحته. و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿سلكناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في قلوب المجرمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سلكناه﴾</span></span>.</p></div>"
  26,201,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون به حتى يروا العذاب الأليم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حالية من الهاء في <span class="hlt"><span class="qpc-hafs">﴿سلكناه﴾</span></span>، أو حال من المجرمين، ولا نافية، ويؤمنون فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وحتى حرف غاية وجر، ويروا فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، والواو في <span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span> فاعل، والعذاب مفعول به، والأليم صفة.</p></div>"
  26,202,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيأتيهم بغتة﴾</span></span>: الفاء حرف للتعقيب، ويأتيهم فعل مضارع مرفوع، وهو معطوف على يروا، والفاعل مستتر تقديره: هو، والهاء مفعول به، وبغتة حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يشعرون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون خبر، والجملة الاسمية في محل نصب حال.</p></div>"
  26,203,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيقولوا هل نحن منظرون﴾</span></span>: الفاء عاطفة، ويقولوا فعل مضارع منصوب عطف على يأتيهم، والواو فاعل، وهل حرف استفهام معناه التحسر، ونحن مبتدأ، ومنظرون خبر، والجملة مقول القول.</p></div>"
  26,204,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على مقدر يقتضيه المقام، والتقدير: أيغفلون عن ذلك مع تحققه وتقرره فيستعجلون؟ والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجلون﴾</span></span>، ويستعجلون فعل مضارع مرفوع، والواو فاعل.</p></div>"
  26,205,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span></span>: الهمزة للاستفهام، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وقيل الفاء عاطفة، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يقولوا﴾</span></span>، ورأيت: فعل ماض، والتاء: فاعل رأيت، وإن شرطية، ومتعناهم: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء: مفعول به، وسنين: ظرف منصوب بالياء متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span>، وجواب الشرط محذوف دل عليه ما سد مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿رأيت﴾</span></span>، وهو قوله تعالى: <span class="hlt"><span class="qpc-hafs">﴿ما أغنى عنهم ما كانوا يمتعون﴾</span></span> الآتي بعد. والجملة الشرطية بتمامها لا محل لها من الإعراب، لأنها اعتراضية.</p></div>"
  26,206,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم جاءهم ما كانوا يوعدون﴾</span></span>: ثم حرف عطف، وجاءهم فعل ماض، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل جاءهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. والواو اسم كان، ويوعدون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة يوعدون خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"
  26,207,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أغنى عنهم ما كانوا يمتعون﴾</span></span>: ما استفهامية مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، والاستفهام إنكاري بمعنى النفي، وقيل: ما نافية، وأغنى فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أغنى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة فاعل، أو مصدرية، وهي ومدخولها في تأويل مصدر فاعل أغنى.</p></div>"
  26,208,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أهلكنا من قرية إلا لها منذرون﴾</span></span>: الواو عاطفة، أو استئنافية، وما نافية، وأهلكنا فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿قرية﴾</span></span> اسم مجرور بمن لفظًا منصوب محلًّا على أنه مفعول أهلكنا، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومنذرون مبتدأ مؤخر، والجملة حال من <span class="hlt"><span class="qpc-hafs">﴿قرية﴾</span></span>، وقيل: صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما أهلكنا...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  26,209,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذكرى﴾</span></span>: ذكرى: مفعول لأجله والعامل فيه <span class="hlt"><span class="qpc-hafs">﴿منذرون﴾</span></span>، أو خبر لمبتدأ محذوف، أي: هذه ذكرى، وتكون الجملة حينئذ اعتراضية لا محل لها من الإعراب. أو حال، أي: مذكرين. أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿منذرون﴾</span></span>: إما على المبالغة، وإما على الحذف أي: منذرون ذوو ذكرى.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا ظالمين﴾</span></span>: الواو عاطفة أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وظالمين خبر <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما كنا ظالمين﴾</span></span>: يجوز أن تكون معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ذكرى﴾</span></span> أي: نذكّركم ولا نظلم، وأن تكون حالًا من الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿ذكرى﴾</span></span>، لأنه كالمصدر يقتضي مسندًا إليه.</p></div>"
  26,210,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تنزلت به الشياطين﴾</span></span>: الواو عاطفة، وما نافية، وتنزلت فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزلت﴾</span></span>، والضمير للقرآن، والشياطين فاعل تنزلت.</p></div>"
  26,211,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ينبغي لهم وما يستطيعون﴾</span></span>: الواو عاطفة، وما نافية، وينبغي فعل مضارع، وفاعله مستتر يعود على القرآن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وما يستطيعون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما ينبغي﴾</span></span>، ومفعول يستطيعون محذوف، تقديره: ذلك.</p></div>"
  26,212,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم عن السمع لمعزولون﴾</span></span>: الجملة تعليلية لعدم استطاعتهم أن يتنزلوا به، و<span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عن السمع﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿معزولون﴾</span></span>، واللام المزحلقة، ومعزولون خبر إن.</p></div>"
  26,213,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا تدع مع الله إلها آخر﴾</span></span>: الفاء الفصيحة، ولا ناهية، وتدع فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف متعلق بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span> وتقدم عليه، وإلهًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿آخر﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتكون من المعذبين﴾</span></span>: الفاء السببية، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد الفاء، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق أي: لا يكن منك دعوة فحصول عذاب لك، واسم تكون مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿من المعذبين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون.</p></div>"
  26,214,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنذر عشيرتك الأقربين﴾</span></span>: الواو عاطفة، وأنذر فعل أمر، وفاعله مستتر، تقديره: أنت، وعشيرتك مفعول به، والأقربين صفة.</p></div>"
  26,215,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واخفض جناحك لمن اتبعك من المؤمنين﴾</span></span>: عطف أيضًا، واخفض فعل أمر، والفاعل مستتر، وجناحك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخفض﴾</span></span>، واتبعك فعل ماض، والكاف مفعول به، والفاعل مستتر، وجملة اتبعك صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  26,216,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن عصوك فقل إني بريء مما تعملون﴾</span></span>: الفاء عاطفة، وإن شرطية، وعصوك فعل ماض، والواو فاعل، والكاف مفعول به، والفعل في محل جزم فعل الشرط، <span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> الفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها، وبريء خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بريء﴾</span></span>، وجملة تعملون صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿إني بريء﴾</span></span> مقول القول.</p></div>"
  26,217,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتوكل على العزيز الرحيم﴾</span></span>: الواو عاطفة، وتوكل فعل أمر مجزوم، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على العزيز﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الرحيم﴾</span></span> نعت، وقيل: بدل.</p></div>"
  26,218,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي يراك حين تقوم﴾</span></span>: الذي صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span>، ويراك فعل مضارع مرفوع، والفاعل مستتر، والكاف مفعول به، وجملة يراك صلة الموصول لا محل لها من الإعراب. وحين ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يراك﴾</span></span>، وجملة تقوم مجرورة بإضافة الظرف إليها، ومتعلق <span class="hlt"><span class="qpc-hafs">﴿تقوم﴾</span></span> محذوف، أي: إلى الصلاة.</p></div>"
  26,219,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتقلبك في الساجدين﴾</span></span>: الواو عاطفة وتقلبك معطوفة على الكاف في يراك، و<span class="hlt"><span class="qpc-hafs">﴿في الساجدين﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  26,220,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو السميع العليم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والسميع العليم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والسميع العليم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر إن.</p></div>"
  26,221,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل أنبئكم على من تنزل الشياطين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وهل حرف استفهام، وأنبئكم فعل مضارع، والفاعل مستتر، والكاف مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزل﴾</span></span>، والجملة سدت مسد المفعولين الثاني والثالث، و<span class="hlt"><span class="qpc-hafs">﴿تنزل﴾</span></span> فعل مضارع مرفوع، والشياطين فاعل.</p></div>"
  26,222,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزل على كل أفاك أثيم﴾</span></span>: تنزل فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿على كل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزل﴾</span></span>، وهو بدل من الجار والمجرور قبله <span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span>، وأفاك مضاف إليه، وأثيم صفة.</p></div>"
  26,223,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يلقون السمع وأكثرهم كاذبون﴾</span></span>: يلقون فعل مضارع، والواو فاعل، وهو يعود على <span class="hlt"><span class="qpc-hafs">﴿الشياطين﴾</span></span> والجملة حالية، أو يعود على <span class="hlt"><span class="qpc-hafs">﴿كل أفاك أثيم﴾</span></span> والجملة مستأنفة لا محل لها من الإعراب، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كل أفاك أثيم﴾</span></span>، والسمع مفعول به، والواو حالية، وأكثرهم مبتدأ، وكاذبون خبر، والجملة حالية.</p></div>"
  26,224,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والشعراء مبتدأ، ويتبعهم فعل مضارع، والهاء مفعول به مقدم، والغاوون فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتبعهم﴾</span></span> خبر.</p></div>"
  26,225,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أنهم في كل واد يهيمون﴾</span></span>: الجملة استئنافية، لا محل لها من الإعراب. والهمزة للاستفهام. ولم: حرف نفي وقلب وجزم. و<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، وأن وما بعدها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في كل واد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهيمون﴾</span></span>، ويهيمون فعل مضارع، والواو فاعل، والجملة خبر أن، أو الجار والمجرور متعلقان بمحذوف هو الخبر، وجملة يهيمون حالية.</p></div>"
  26,226,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنهم يقولون ما لا يفعلون﴾</span></span>: جملة معطوفة، و<span class="hlt"><span class="qpc-hafs">﴿أنهم﴾</span></span>: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، ويقولون فعل مضارع، والواو فاعل، والجملة خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يفعلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لا يفعلون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  26,227,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات وذكروا الله كثيرا﴾</span></span>: إلا أداة استثناء، والذين مستثنى من الشعراء المذمومين، وآمنوا فعل ماض، والواو فاعل، وجملة آمنوا صلة الموصول لا محل لها من الإعراب. وعملوا الصالحات عطف على <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> داخل في حيز الصلة، وذكروا الله عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span> نائب عن المفعول المطلق، لأنه صفة المصدر، أي: ذكروا الله ذكرًا كثيرًا، أو صفة لظرف زمان محذوف، أي: وقتًا كثيرًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وانتصروا من بعد ما ظلموا﴾</span></span>: عطف على ما تقدم، وانتصروا فعل ماض والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انتصروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> فعل ماض مبني لما لم يسم فاعله، والواو نائب فاعل، وما المصدرية مع مدخولها في تأويل مصدر، أي: من بعد ظلمهم، من إضافة المصدر لمفعوله.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسيعلم الذين ظلموا أي منقلب ينقلبون﴾</span></span>: الواو اسئتنافية، والسين حرف استقبال، ويعلم فعل مضارع، والذين فاعل، وجملة ظلموا صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> اسم استفهام نائب مفعول مطلق عامله <span class="hlt"><span class="qpc-hafs">﴿ينقلبون﴾</span></span>، ولا يجوز أن يكون معمولا لـ<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>، لأن الاستفهام له صدر الكلام، فلا يعمل فيه ما قبله، و<span class="hlt"><span class="qpc-hafs">﴿منقلب﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ينقلبون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينقلبون﴾</span></span> سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>.</p></div>"
