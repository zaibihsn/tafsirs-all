quran[89]{c,v,t}:
  43,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  43,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والكتاب المبين﴾</span></span>: الواو: واو القسم، والكتاب: مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: أُقسم، والمبين: نعت للكتاب.</p></div>"
  43,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا جعلناه قرآنا عربيا لعلكم تعقلون﴾</span></span>: إن: حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span> خبر إن، وجعلناه: فعل وفاعل ومفعول به، وقرآنًا: مفعول به ثان، وعربيًّا: نعت، ولعل: حرف ناسخ، والكاف اسم لعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> خبر لعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا جعلناه﴾</span></span> جواب القسم، وقيل: إن قرآنًا حال من الهاء في <span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لعلكم تعقلون﴾</span></span> تعليلية لا محل لها من الإعراب.</p></div>"
  43,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه في أم الكتاب لدينا لعلي حكيم﴾</span></span>: الواو: عاطفة، والجملة معطوفة على جواب القسم، فهي بمثابة جواب ثان، وإن: حرف ناسخ، والهاء: اسم إن، وفي أم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span>، والكتاب: مضاف إليه، ولدينا: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span>، أو بدل من الجار والمجرور، أو حال من الكتاب أو من أم. واللام المزحلقة، وعلي: خبر إن، وحكيم: خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>. أو: <span class="hlt"><span class="qpc-hafs">﴿في أم الكتاب﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> وتقدم عليه، ولدينا: ظرف متعلق بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> وتقدم عليه.</p></div>"
  43,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفنضرب عنكم الذكر صفحا أن كنتم قوما مسرفين﴾</span></span>: الهمزة: للاستفهام الإنكاري، والفاء: عاطفة على محذوف مُقدر بينها وبين الهمزة، تقديره: أنهملكم فنضرب، ونضرب: فعل مضارع مرفوع، والفاعل مستتر تقديره: نحن، وعنكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نضرب﴾</span></span>، والذكر: مفعول به، أي القرآن، وصفحًا: فيه أوجه: أحدها: أنه مصدر مرادف لمعنى <span class="hlt"><span class="qpc-hafs">﴿نضرب﴾</span></span>. والثاني: أنه منصوب على الحال من فاعل <span class="hlt"><span class="qpc-hafs">﴿نضرب﴾</span></span>، أي صافحين. والثالث: أنه منصوب على أنه ظرف بمعنى الجانب. والرابع: أنه مفعول من أجله، وأن: مصدرية، وهي ومدخولها مفعول من أجله، وكنتم: فعل ماض ناقص، والتاء اسمها، وقوما: خبرها، ومسرفين: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قوما﴾</span></span> منصوب بالياء لأنه جمع مذكر سالم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن كنتم﴾</span></span> مجرور بحرف جر محذوف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نضرب﴾</span></span>، أي: لكونكم.</p></div>"
  43,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أرسلنا من نبي في الأولين﴾</span></span>: كم: خبرية في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وأرسلنا: فعل وفاعل، ومن نبي: تمييز لـ<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> الخبرية، وفي الأولين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p></div>"
  43,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما يأتيهم من نبي إلا كانوا به يستهزئون﴾</span></span>: الواو: عاطفة، وما: نافية، ويأتيهم: فعل مضارع مرفوع، ومفعول به مقدم، ومن: حرف جر صلة، ونبي: مجرور لفظًا مرفوع محلا على أنه فاعل، وإلا: أداة حصر، وكان: فعل ماض ناقص، والواو اسمها، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span> خبر كانوا.</p></div>"
  43,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأهلكنا أشد منهم بطشا ومضى مثل الأولين﴾</span></span>: الفاء: الفصيحة، وأهلكنا: فعل وفاعل، وأشد: مفعول به، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>، وبطشًا: تمييز، وقيل: حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، أي: باطشين، ومضى: عطف على <span class="hlt"><span class="qpc-hafs">﴿فأهلكنا﴾</span></span>، ومثل: فاعل مضى، والأولين: مضاف إليه.</p></div>"
  43,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم﴾</span></span>: الواو: عاطفة، واللام: موطئة للقسم، وإن: شرطية، وسألتهم: فعل ماض مبني على السكون، لاتصاله بضمير رفع متحرك، والتاء: فاعل، والهاء: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿من خلق السماوات والأرض﴾</span></span>: من: اسم استفهام في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span> خبر، والجملة الاستفهامية في محل نصب مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿سألتهم﴾</span></span> المعلقة عن العمل بالاستفهام.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليقولن خلقهن العزيز العليم﴾</span></span>: اللام: واقعة في جواب القسم، لأنه المتقدم كما هي القاعدة، و<span class="hlt"><span class="qpc-hafs">﴿يقولن﴾</span></span>: فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، والواو المحذوفة فاعل، والنون للتوكيد، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقهن﴾</span></span> مقول القول، وكرر الفعل للتأكيد، والعزيز: فاعل، والعليم: صفة.</p></div>"
  43,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل لكم الأرض مهدا﴾</span></span>: الذي: اسم موصول صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span>، أو بدل، وجملة  <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> صلة الموصول لا محل لها من الإعراب، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، على أنها بمعنى خَلَق، وإن كانت بمعنى صَيّر، فالجار والمجرور متعلقان بمحذوف حال، والأرض: مفعول به أول، ومهدًا: مفعول به ثان، أو حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم فيها سبلا﴾</span></span>: عطف على ما تقدم، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، أو في موضع المفعول الثاني، وفيها: جار ومجرور متعلقان بالمفعول به الثاني، وسبلًا: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلكم تهتدون﴾</span></span>: لعل: حرف ناسخ، والكاف اسم لعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تهتدون﴾</span></span> خبر.</p></div>"
  43,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذي نزل من السماء ماء بقدر﴾</span></span>: عطف على الموصول الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span> صلة الموصول لا محل لها من الإعراب، ومن السماء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، وماء: مفعول به، وبقدر: جار ومجرور متعلقان بنعت لـ<span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنشرنا به بلدة ميتا كذلك تخرجون﴾</span></span>: الفاء: عاطفة، وأنشرنا: عطف على نزل، و<span class="hlt"><span class="qpc-hafs">﴿أنشرنا﴾</span></span> فعل وفاعل، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشرنا﴾</span></span>، وبلدة: مفعول به، وميتًا: صفة لبلدة، وكذلك: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف لـ<span class="hlt"><span class="qpc-hafs">﴿تخرجون﴾</span></span>، والتقدير: تخرجون إخراجا مثل ذلك الإخراج، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وتخرجون: فعل ماض مبني لما لم يسم فاعله، والواو نائب فاعل.</p></div>"
  43,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذي خلق الأزواج كلها﴾</span></span>: عطف أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق الأزواج﴾</span></span> صلة الموصول لا محل لها من الإعراب، وكلها: تأكيد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم من الفلك والأنعام ما تركبون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿خلق الأزواج﴾</span></span> داخل في حيز الصلة، ولكم: جار ومجرور متعلقان بمحذوف مفعول به ثان، ومن الفلك: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والأنعام: عطف على <span class="hlt"><span class="qpc-hafs">﴿الفلك﴾</span></span>، وما: اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تركبون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف، أي: ما تركبونه.</p></div>"
  43,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لتستووا على ظهوره ثم تذكروا نعمة ربكم إذا استويتم عليه﴾</span></span>: اللام: للتعليل، وتستووا: فعل مضارع منصوب بأن مضمرة بعد اللام، والواو: فاعل، والمصدر المؤول من أن المضمرة والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> في الآية السابقة، وعلى ظهوره: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستووا﴾</span></span>، ثم: حرف عطف، وتذكروا: عطف على <span class="hlt"><span class="qpc-hafs">﴿تستووا﴾</span></span>، ونعمة: مفعول <span class="hlt"><span class="qpc-hafs">﴿تذكروا﴾</span></span>، وربكم: مضاف إليه، وإذا: ظرف مستقبل متعلق بجوابه المحذوف، والمدلول عليه بـ<span class="hlt"><span class="qpc-hafs">﴿تذكروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿استويتم﴾</span></span> في محل جر بإضافة الظرف إليها، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استويتم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتقولوا سبحان الذي سخر لنا هذا﴾</span></span>: تقولوا: عطف على ما تقدم، وسبحان: نائب مفعول مطلق منصوب بفعل محذوف، والذي: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿سَخَّرَ﴾</span></span> صلة الموصول لا محل لها من الإعراب، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخر﴾</span></span>، وهذا: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا له مقرنين﴾</span></span>: الواو: للحال، وما: نافية، وكان: فعل ماض ناقص، ونا اسمها، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مقرنين﴾</span></span>، ومقرنين: خبر كان.</p></div>"
  43,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا إلى ربنا لمنقلبون﴾</span></span>: الواو: حالية أيضًا، وإن: حرف ناسخ، ونا اسم إن، وإلى ربنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منقلبون﴾</span></span>، واللام: المزحلقة، ومنقلبون: خبر إن.</p></div>"
  43,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلوا له من عباده جزءا﴾</span></span>: الواو: عاطفة أو استئنافية، وجعلوا: فعل وفاعل، والجَعل هنا بمعنى: التصيير، وله: جار ومجرور متعلقان بمفعول به ثان، ومن عباده: جار ومجرور متعلقان بحال محذوف من <span class="hlt"><span class="qpc-hafs">﴿جزءا﴾</span></span>، وجزءًا: مفعول جعلوا الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجعلوا له...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الإنسان لكفور مبين﴾</span></span>: إن: حرف ناسخ، والإنسان: اسم إن، واللام: المزحلقة، وكفور: خبر إن، ومبين: صفة.</p></div>"
  43,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم اتخذ مما يخلق بنات وأصفاكم بالبنين﴾</span></span>: أم: بمعنى بل والهمزة للإضراب، أي: بل اتخذ، واتخذ: فعل ماض، وفاعله مستتر تقديره: هو، ومما: جار ومجرور متعلقان بمحذوف وهو مفعول <span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span> الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخلق﴾</span></span> صلة الموصول لا محل لها من الإعراب، وبنات: مفعول <span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span> الأول، وأصفاكم: عطف على <span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>، وبالبنين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أصفاكم﴾</span></span>.</p></div>"
  43,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا بشر أحدهم بما ضرب للرحمن مثلا﴾</span></span>: الواو: استئنافية، وإذا: ظرف مستقبل متضمن معنى الشرط، وبشر: فعل ماض مبني لما لم يسمَّ فاعله، وأحدهم: نائب فاعل، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span> صلة الموصول لا محل لها من الإعراب، وضرب: متضمن معنى جعل، فيتعلق <span class="hlt"><span class="qpc-hafs">﴿للرحمن﴾</span></span> بمحذوف في موضع المفعول الثاني، ومثلًا: مفعول ضرب الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ظل وجهه مسودا وهو كظيم﴾</span></span>: ظل: فعل ماض ناقص، ووجهه: اسمها، ومسودًا خبرها، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والواو: حالية، وهو: مبتدأ، وكظيم: خبر، والجملة حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذا بشر...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  43,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أومن ينشأ في الحلية وهو في الخصام غير مبين﴾</span></span>: الهمزة: للاستفهام الإنكاري، والواو: حرف عطف، عطفت الجملة على جملة مقدرة، أي: يجترئون، ويبلغون أبعد الآماد في سوء الأدب، ويجعلون لله مَن يُنشأ في الحلية، ومَن: اسم موصول مفعول به لفعل محذوف، وقيل: هي مبتدأ خبره محذوف تقديره: جزء وولد، وجملة <span class="hlt"><span class="qpc-hafs">﴿يُنَشَّأ﴾</span></span> صلة الموصول لا محل لها من الإعراب، ويُنشأ: مبني لما لم يُسمَّ فاعله، ونائب الفاعل مستتر يعود على مَن، وفي الحلية: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينشأ﴾</span></span>، وفي الخصام: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span>، وغير مبين: خبر هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو في الخصام غير مبين﴾</span></span> حالية.</p></div>"
  43,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلوا الملائكة الذين هم عباد الرحمن إناثا﴾</span></span>: الواو: عاطفة، وجعلوا: فعل وفاعل، والملائكة: مفعول جعلوا الأول، والذين: نعت، وهم: مبتدأ، وعباد الرحمن: خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم عباد الرحمن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب. وإناثًا: مفعول جعلوا الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿أشهدوا خلقهم ستكتب شهادتهم ويسألون﴾</span></span>: الهمزة: للاستفهام الإنكاري، وشهدوا: فعل ماض وفاعله، وخلقهم: مفعول به منصوب بالفتة، والضمير في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أشهدوا خلقهم﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية، والسين: حرف استقبال، وتكتب: فعل مضارع مبني لما لم يسمَّ فاعله، وشهادتهم: نائب فاعل، ويسألون: عطف على <span class="hlt"><span class="qpc-hafs">﴿ستكتب﴾</span></span>.</p></div>"
  43,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لو شاء الرحمن ما عبدناهم﴾</span></span>: الواو: عاطفة، وقالوا: فعل وفاعل، ولو: شرطية، وشاء الرحمن: فعل وفاعل، والمفعول به محذوف، وما: نافية، وعبدناهم: فعل وفاعل ومفعول به، والجملة لا محل لها من الإعراب، لأنها واقعة في جواب لو.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما لهم بذلك من علم إن هم إلا يخرصون﴾</span></span>: ما: نافية، ولهم: جار ومجرور متعلقان بمحذوف خبر مقدم، وبذلك: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، ومن: حرف جر صلة، وعلم: مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا، وإن: نافية، وهم: مبتدأ، وإلا: أداة حصر، ويخرصون: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرصون﴾</span></span> في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن هم إلا يخرصون﴾</span></span> لا محل لها من الإعراب، لأنها تعليلية، أو استئناف بياني.</p></div>"
  43,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم آتيناهم كتابا من قبله فهم به مستمسكون﴾</span></span>: أم: حرف عطف معادل للاستفهام في قوله: <span class="hlt"><span class="qpc-hafs">﴿أشهدوا خلقهم﴾</span></span>، فهي متصلة، وقيل: أم: منقطعة بمعنى  <span class="hlt"><span class="qpc-hafs">﴿بل والهمزة﴾</span></span>، وآتيناهم: فعل ماض وفاعل ومفعول به أول، وكتابا: مفعول به ثان، ومن قبله: جار ومجرور متعلقان بمحذوف نعت، والضمير في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أم آتيناهم...﴾</span></span> لا محل لها من الإعراب، لأنها استئنافية، والفاء: عاطفة، وهم: ضمير في محل رفع مبتدأ، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مستمسكون﴾</span></span>، ومستمسكون: خبر مرفوع بالواو، وجملة <span class="hlt"><span class="qpc-hafs">﴿فهم به مستمسكون﴾</span></span> لا محل لها من الإعراب، عطفا على جملة <span class="hlt"><span class="qpc-hafs">﴿آتيناهم...﴾</span></span>.</p></div>"
  43,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل قالوا إنا وجدنا آباءنا على أمة﴾</span></span>: بل: حرف عطف وإضراب، وقالوا: فعل وفاعل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدنا  آباءنا﴾</span></span> خبرها، وجملة إن واسمها وخبرها مقول قولهم، وعلى أمة: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿آباءنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا على آثارهم مهتدون﴾</span></span>: الواو: عاطفة، وإن: حرف ناسخ، ونا: اسمها، وعلى آثارهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهتدون﴾</span></span>، ومهتدون: خبر إن، أو: على آثارهم: خبر، أي: ماشون، ومهتدون: خبر ثان.</p></div>"
  43,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك ما أرسلنا من قبلك في قرية من نذير﴾</span></span>: الواو: عاطفة، وكذلك: جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، تقديره: الأمر كذلك <span class="hlt"><span class="qpc-hafs">﴿بعجزهم عن الإتيان بالحجة، وتمسكهم الأعمى بالتقليد﴾</span></span>، والجملة لا محل لها من الإعراب، عطفا على جملة <span class="hlt"><span class="qpc-hafs">﴿قالوا..﴾</span></span> في الآية السابقة، وما: نافية، وأرسلنا: فعل وفاعل، ومن قبلك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، أو بمحذوف حال من نذير، وفي قرية: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ومن: حرف جر صلة، ونذير: مجرور لفظًا منصوب محلا على أنه مفعول <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا قال مترفوها إنا وجدنا آباءنا على أمة﴾</span></span>: إلا: أداة حصر، والاستثناء من أعم الأحوال، وقال مترفوها: فعل وفاعل، وإن: حرف ناسخ، ونا: اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدنا آباءنا﴾</span></span> خبر إن، وجملة إن واسمها وخبرها مقول قولهم، وعلى أمة: جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿وجدنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا على آثارهم مقتدون﴾</span></span>: الواو عاطفة، وإن: حرف ناسخ، ونا: اسم إن، وعلى آثارهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مقتدون﴾</span></span>، ومقتدون: خبرها، أو: <span class="hlt"><span class="qpc-hafs">﴿على آثارهم﴾</span></span>  خبر، ومقتدون: خبر ثان.</p></div>"
  43,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أولو جئتكم بأهدى مما وجدتم عليه آباءكم﴾</span></span>: قال: فعل ماض، والفاعل ضمير مستتر تقديره: هو، والهمزة: للاستفهام، والواو: حالية، والتقدير: أتقتدون بآبائكم، ولو جئتكم بأهدى مما وجدتم عليه آباءكم من الضلالة، ولو: شرطية، وجئتكم: فعل وفاعل ومفعول به، وبأهدى: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئتكم﴾</span></span>، ومما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهدى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدتم﴾</span></span> صلة الموصول لا محل لها من الإعراب، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجدتم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا بما أرسلتم به كافرون﴾</span></span>: قالوا: فعل وفاعل، وإن: حرف ناسخ، ونا: اسم إن، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلتم﴾</span></span> صلة الموصول لا محل لها من الإعراب. وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلتم﴾</span></span>، وكافرون: خبر إن.</p></div>"
  43,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانتقمنا منهم فانظر كيف كان عاقبة المكذبين﴾</span></span>: الفاء: حرف عطف، وانتقمنا: فعل وفاعل، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انتقمنا﴾</span></span>، فانظر: الفاء عاطفة، وانظر: فعل أمر، وفاعله مستتر تقديره: أنت، وكيف: اسم استفهام في محل نصب خبر مقدم لكان، وكان: فعل ماض ناقص، وعاقبة المكذبين: اسم كان المؤخر.</p></div>"
  43,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذ قال إبراهيم لأبيه وقومه إنني براء مما تعبدون﴾</span></span>: الواو: استئنافية، وإذ: اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال إبراهيم﴾</span></span> في محل جر بالإضافة، ولأبيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وقومه: عطف على <span class="hlt"><span class="qpc-hafs">﴿أبيه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنني براء﴾</span></span> في محل نصب مقول للقول، ومما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿براء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذ قال إبراهيم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  43,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا الذي فطرني فإنه سيهدين﴾</span></span>: إلا: أداة استثناء، والذي: مستثنى، والاستثناء منقطع، كأنه قال: لكن الذي فطرني فإنه سيهدين، أو الاستثناء متصل لأنهم كانوا يشركون مع الله الأصنام. وقيل: إن <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> صفة بمعنى غير، على أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿مما تعبدون﴾</span></span> موصوفة والتقدير: إنني براء من آلهة تعبدونها غير الذي فطرني، أو على انقطاع الاستثناء، وجملة <span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span> صلة الموصول لا محل لها من الإعراب. والفاء: تعليلية، وإن: حرف ناسخ، والهاء: اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيهدين﴾</span></span> خبر إن، والسين: للتأكيد لا للاستقبال، أي: يديم هدايتي، والمفعول به محذوف مراعاة لنهاية الآيات، أي: سيهديني.</p></div>"
  43,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلها كلمة باقية في عقبه لعلهم يرجعون﴾</span></span>: الواو: عاطفة، وجعلها: فعل وفاعل مستتر ومفعول به أول، والضمير يعود على إبراهيم، وكلمة: مفعول به ثان، وباقية: صفة، وفي عقبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿باقية﴾</span></span>، ولعلهم: لعل: حرف ناسخ، والضمير اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span> خبرها.</p></div>"
  43,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل متعت هؤلاء وآباءهم حتى جاءهم الحق ورسول مبين﴾</span></span>: بل: حرف إضراب وعطف، والتقدير: وجعلها كلمة باقية في عقبه، وهؤلاء: اسم إشارة مبني على الكسر في محل نصب مفعول به، وآباءهم: عطف على هؤلاء، أو مفعول معه، وحتى: حرف غاية وجر، وجاءهم الحق: فعل ومفعول به مقدم وفاعل مؤخر، ورسول: عطف على الحق، ومبين: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>.</p></div>"
  43,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جاءهم الحق قالوا هذا سحر وإنا به كافرون﴾</span></span>: الواو: حرف عطف، ولما: رابطة، أو حينية، وجاءهم الحق: فعل ومفعول به مقدم وفاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها واقعة في جواب شرط غير جازم، وهذا: مبتدأ، وسحر: خبره، والجملة مقول قولهم، وإن: حرف ناسخ، ونا: اسم إن، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وكافرون: خبر إن.</p></div>"
  43,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لولا نزل هذا القرآن على رجل من القريتين عظيم﴾</span></span>: الواو: عاطفة، وقالوا: فعل وفاعل، ولولا: حرف تحضيض بمعنى هلا، ونزل: فعل ماض مبني لما لم يسمَّ فاعله، وهذا: اسم إشارة نائب فاعل، والقرآن: بدل، وعلى رجل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، ومن القريتين: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>، وعظيم: صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>.</p></div>"
  43,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أهم يقسمون رحمت ربك﴾</span></span>: الهمزة: للاستفهام الإنكاري تجهيلًا لهم، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقسمون﴾</span></span> خبر، ورحمة ربك: مفعول <span class="hlt"><span class="qpc-hafs">﴿يقسمون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿نحن قسمنا بينهم معيشتهم في الحياة الدنيا﴾</span></span>: نحن: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿قسمنا﴾</span></span> خبر، وبينهم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قسمنا﴾</span></span>، ومعيشتهم: مفعول به، وفي الحياة الدنيا: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورفعنا بعضهم فوق بعض درجات ليتخذ بعضهم بعضا سخريا﴾</span></span>: الواو: حرف عطف، ورفعنا: فعل وفاعل، وبعضهم: مفعول به، وفوق بعض: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رفعنا﴾</span></span>، ودرجات: تمييز، واللام: للتعليل، وقيل: للصيرورة أو العاقبة، ويتخذ: فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رفعنا﴾</span></span>، وبعضهم: فاعل، وبعضًا: مفعول به أول، وسخريًّا: مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورحمت ربك خير مما يجمعون﴾</span></span>: الواو: عاطفة، أو حالية، ورحمة ربك: مبتدأ، وخير: خبر، ومما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجمعون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجمعون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  43,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا أن يكون الناس أمة واحدة﴾</span></span>: الواو: استئنافية، ولولا: حرف امتناع لوجود، وأن وما بعدها في تأويل مصدر مبتدأ محذوف الخبر، والناس: اسم يكون، وأمة: خبرها، وواحدة: نعت أمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لجعلنا لمن يكفر بالرحمن لبيوتهم سقفا من فضة ومعارج عليها يظهرون﴾</span></span>: اللام: رابطة للجواب، وجعلنا: فعل وفاعل، ولمن: في موضع المفعول الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكفر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. وبالرحمن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفر﴾</span></span>، ولبيوتهم: بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿لمن يكفر﴾</span></span> بإعادة الجار، وسقفًا: مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> الأول، ومن فضة: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سقفًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولولا أن يكون الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب، ومعارج: عطف على <span class="hlt"><span class="qpc-hafs">﴿سقفًا﴾</span></span>، وعليها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يظهرون﴾</span></span>، ويظهرون: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿معارج﴾</span></span>.</p></div>"
  43,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولبيوتهم أبوابا وسررا عليها يتكئون﴾</span></span>: الواو: عاطفة: ولبيوتهم: جار ومجرور معطوفان على <span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> في الآية السابقة ومتعلقان بما تعلق به، وأبوابا: مفعول به معطوف على <span class="hlt"><span class="qpc-hafs">﴿سقفا﴾</span></span>، وسررا: معطوف أيضا، وعليها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتكئون﴾</span></span>، ويتكئون: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتكئون﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سررا﴾</span></span>.</p></div>"
  43,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وزخرفا وإن كل ذلك لما متاع الحياة الدنيا﴾</span></span>: زخرفًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿سررًا﴾</span></span>، أو مفعول به لفعل محذوف، أي: وجعلنا لهم زخرفًا، أو عطف على محل من فضة، والواو: عاطفة، وإن: نافية، وكل ذلك: مبتدأ، ولما: بالتشديد بمعنى إلا، ومتاع الحياة الدنيا: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿والآخرة عند ربك للمتقين﴾</span></span>: الواو: حالية، والآخرة: مبتدأ، وعند ربك: ظرف متعلق بمحذوف حال، وللمتقين:  جار ومجرور متعلقان بمحذوف خبر الآخرة.</p></div>"
  43,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يعش عن ذكر الرحمن نقيض له شيطانا فهو له قرين﴾</span></span>: من: اسم شرط جازم في محل رفع مبتدأ، ويعش: فعل الشرط، وعن ذكر الرحمن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعش﴾</span></span>، ونقيض: جواب الشرط، وجملتا الشرط والجزاء خبر مَن، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقيض﴾</span></span>، وشيطانًا: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿نقيض﴾</span></span>، والفاء: حرف عطف، وهو: مبتدأ، وله: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لقرين، وتقدمت عليه، وقرين: خبر.</p></div>"
  43,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم ليصدونهم عن السبيل﴾</span></span>: الواو: عاطفة، وإن: حرف ناسخ، والهاء: اسم إن، والميم: علامة الجمع، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصدونهم﴾</span></span> خبر إن، وعن السبيل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصدونهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويحسبون أنهم مهتدون﴾</span></span>: الواو: حالية، أو عاطفة، ويحسبون: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، ومهتدون خبرها، والجملة سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يحسبون﴾</span></span>.</p></div>"
  43,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا جاءنا قال يا ليت بيني وبينك بعد المشرقين﴾</span></span>: حتى: حرف غاية وجر، وإذا: ظرف لما يستقبل من الزمن متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءنا﴾</span></span> في محل جر بإضافة الظرف إليها، وفاعل <span class="hlt"><span class="qpc-hafs">﴿جاءنا﴾</span></span> يعود على العاشي المأخوذ من <span class="hlt"><span class="qpc-hafs">﴿يعش﴾</span></span> السابق، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ويا: حرف تنبيه، أو حرف نداء، والمنادى محذوف ظاهر التقدير، وليت: حرف تمنّ ونصب، وبيني: ظرف متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span> المقدم، وبينك: عطف على <span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span>، وبعد المشرقين: اسم ليت المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فبئس القرين﴾</span></span>: الفاء: الفصيحة، وبئس: فعل ماض جامد لإنشاء الذم، والقرين: فاعل بئس، والمخصوص بالذم محذوف تقديره: أنت.</p></div>"
  43,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولن ينفعكم اليوم إذ ظلمتم أنكم في العذاب مشتركون﴾</span></span>: الواو: استئنافية، ولن: حرف نفي ونصب واستقبال، وينفعكم: فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿لن﴾</span></span>، واليوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ينفعكم﴾</span></span>، وإذ: ظرف للزمن الماضي بدل من <span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> والتقدير: إذ صحَّ وتبيَّن أنكم ظلمتم، وقيل: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ههنا للتعليل، والتقدير: ولن ينفعكم اليوم اشتراككم في العذاب لأجل ظلمكم في الدنيا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلمتم﴾</span></span> في محل جر بإضافة الظرف إليها، وأن وما بعدها في تأويل مصدر فاعل <span class="hlt"><span class="qpc-hafs">﴿ينفعكم﴾</span></span>، أي: لن ينفعكم اشتراككم في العذاب، كما ينفع الاشتراك في مصائب الدنيا، وقيل: الفاعل مستتر تقديره: تمنيكم، وأن وما بعدها في موضع نصب بنزع الخافض، أي: لأنكم، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفعكم﴾</span></span>، وفي العذاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span>، ومشتركون: خبر أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولن ينفعكم اليوم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  43,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفأنت تسمع الصم أو تهدي العمي﴾</span></span>: الهمزة: للاستفهام الإنكاري التعجبي، والفاء: عاطفة على محذوف مقدر، وأنت: ضمير منفصل في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تسمع﴾</span></span> خبر، والصم: مفعول به، وأو: حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿تهدي العمي﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تسمع الصم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن كان في ضلال مبين﴾</span></span>: الواو: عاطفة، ومَن: اسم موصول معطوف على <span class="hlt"><span class="qpc-hafs">﴿العمي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان...﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. واسم كان ضمير مستتر تقديره: هو، وفي ضلال: جار ومجرور متعلقان بمحذوف خبر كان، ومبين: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ضلال﴾</span></span>.</p></div>"
  43,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإما نذهبن بك فإنا منهم منتقمون﴾</span></span>: الفاء: عاطفة، وإن: شرطية، أدغمت نونها في ما، وما: صلة، ونذهبن: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، وهو في محل جزم فعل الشرط، وبك: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذهبن﴾</span></span>، فإنا: الفاء رابطة لجواب الشرط، وإن: حرف ناسخ، ونا: اسم إن، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منتقمون﴾</span></span>، ومنتقمون: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإنا...﴾</span></span> في محل جزم جواب الشرط.</p></div>"
  43,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو نرينك الذي وعدناهم فإنا عليهم مقتدرون﴾</span></span>: أو: عاطفة، ونرينك: فعل مضارع مبني على الفتح في محل جزم فعل الشرط، والفاعل مستتر تقديره نحن، والكاف مفعول به، والذي: مفعول <span class="hlt"><span class="qpc-hafs">﴿نرينك﴾</span></span> الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعدناهم﴾</span></span> صلة الموصول لا محل لها من الإعراب، والفاء: رابطة لجواب الشرط، وإن: حرف ناسخ، ونا: اسم إن، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مقتدرون﴾</span></span>، ومقتدرون: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإنا...﴾</span></span> في محل جزم جواب الشرط.</p></div>"
  43,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستمسك بالذي أوحي إليك﴾</span></span>: الفاء: الفصيحة، واستمسك: فعل أمر، وفاعله مستتر تقديره: أنت، وبالذي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استمسك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحي إليك﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك على صراط مستقيم﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها تعليل للأمر، وإن: حرف ناسخ، والكاف: اسم إن، وعلى صراط: جار ومجرور متعلقان بمحذوف خبر إن، ومستقيم: نعت لصراط.</p></div>"
  43,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لذكر لك ولقومك وسوف تسألون﴾</span></span>: الواو: عاطفة، وإن: حرف ناسخ، والهاء اسم إن، واللام: المزحلقة، وذِكْر: خبر إن، ولك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذِكْر﴾</span></span>، أو صفة له، ولقومك: عطف على <span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span>، والواو: عاطفة، وسوف: حرف للاستقبال، وتسألون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  43,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واسأل من أرسلنا من قبلك من رسلنا﴾</span></span>: الواو: عاطفة، واسأل: فعل أمر، وفاعله مستتر تقديره أنت، ومَن: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> صلة الموصول لا محل لها من الإعراب. ومن قبلك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، ومن رسلنا: جار ومجرور متعلقان بحال من <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أجعلنا من دون الرحمن آلهة يعبدون﴾</span></span>: الجملة سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿اسأل﴾</span></span> المعلقة عن العمل بالاستفهام، والهمز للاستفهام، وجعلنا: فعل وفاعل، ومن دون الرحمن: جار ومجرور معلقان بمفعول <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> الثاني، وآلهة: مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يُعبدون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span>، ويعبدون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  43,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا موسى بآياتنا إلى فرعون وملئه﴾</span></span>: الواو: للقسم، والمقسم به متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span> محذوف، واللام: جواب للقسم المحذوف، وقد: حرف تحقيق، وأرسلنا: فعل وفاعل، وموسى: مفعول به، وبآياتنا: جار ومجرور متعلقان بمحذوف حال، والباء: للملابسة، وإلى فرعون: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وملئه: عطف على <span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال إني رسول رب العالمين﴾</span></span>: الفاء حرف عطف، وإني: إن حرف ناسخ، والياء اسمها، ورسول: خبر إن، ورب: مضاف، والعالمين: مضاف إليه، وجملة إن وما بعدها مقول القول.</p></div>"
  43,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم بآياتنا إذا هم منها يضحكون﴾</span></span>: الفاء: عاطفة على مقدر، أي: فطلبوا منه الآيات الدالة على صدقه، ولما: ظرفية حينية، أو رابطة، وجاءهم: فعل وفاعل مستتر ومفعول به، وبآياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، وإذا: فجائية، أو ظرف معمول لفعل المفاجأة الذي هو جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، أو حرف، وهم مبتدأ، ومنها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضحكون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يضحكون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  43,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما نريهم من آية إلا هي أكبر من أختها﴾</span></span>: الواو: عاطفة، وما: نافية، ونريهم: فعل وفاعل مستتر ومفعول به أول، ومِن: حرف جر صلة، وآية: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نريهم﴾</span></span>، وإلا: أداة حصر، وهي: مبتدأ، وأكبر: خبر، ومن أختها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكبر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هي أكبر...﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخذناهم بالعذاب لعلهم يرجعون﴾</span></span>: الواو: عاطفة، وأخذناهم: فعل وفاعل ومفعول به، وبالعذاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذناهم﴾</span></span>، ولعلهم: لعل حرف ناسخ، وهم: اسم لعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لعلهم يرجعون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  43,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا يا أيها الساحر ادع لنا ربك بما عهد عندك إننا لمهتدون﴾</span></span>: الواو: عاطفة، وقالوا: فعل وفاعل، ويا: حرف نداء للمتوسط، وأي: منادى نكرة مقصودة مبني على الضم في محل نصب و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والساحر: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وادع: فعل أمر مبني على حذف حرف العلة، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادع﴾</span></span>، وربك: مفعول به، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادع﴾</span></span>، وما: موصولة، وجملة <span class="hlt"><span class="qpc-hafs">﴿عهد﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي والفعل في تأويل مصدر مجرور بالباء، وعندك: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عهد﴾</span></span>، وإننا: إن: حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن، ولمهتدون: خبر إن، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿إننا لمهتدون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  43,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما كشفنا عنهم العذاب إذا هم ينكثون﴾</span></span>: الفاء: عاطفة على محذوف مقدر، أي فدعا موسى فلما كشفنا، ولما: رابطة، أو حينية، وكشفنا: فعل وفاعل، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، والعذاب: مفعول به، وإذا: فجائية، أو ظرف معمول لفعل المفاجأة الذي هو جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، أو حرف، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينكثون﴾</span></span> خبر.</p></div>"
  43,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونادى فرعون في قومه قال يا قوم أليس لي ملك مصر وهذه الأنهار تجري من تحتي أفلا تبصرون﴾</span></span>: الواو: استئنافية، أو عاطفة، ونادى فرعون: فعل وفاعل، وفي قومه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span>، وقال: فعل ماض، وفاعل مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال...﴾</span></span> تفسيرية، لا محل لها من الإعراب. ويا قوم: منادى مضاف إلى ياء المتكلم المحذوفة، والهمزة: للاستفهام التقريري، وليس: فعل ماض ناقص جامد، ولي: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> المقدم، وملك مصر: اسمها المؤخر، وهذه: الواو: حالية، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الأنهار﴾</span></span> بدل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span> خبر، والجملة منصوبة على الحال، أو الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ملك مصر﴾</span></span>، ومن تحتي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ونادى فرعون في قومه...﴾</span></span> مستأنفة لا محل لها من الإعراب، أفلا: الهمزة للاستفهام، والفاء: عاطفة على مقدر، ولا: نافية، وتبصرون: فعل مضارع مرفوع، وعلامة رفعه ثبوت النون.</p></div>"
  43,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم أنا خير من هذا الذي هو مهين﴾</span></span>: أم: حرف عطف، وهي منقطعة مقدرة بـ<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>، أي: بل أنا خير، وقيل: إنها منقطعة مقدرة بـ<span class="hlt"><span class="qpc-hafs">﴿بل وهمزة الاستفهام الإنكاري﴾</span></span>. وأنا: مبتدأ، وخير: خبر، ومن هذا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، والذي: بدل من اسم الإشارة، وهو: مبتدأ، ومهين: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو مهين﴾</span></span> صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يكاد يبين﴾</span></span>: الواو: عاطفة والجملة معطوفة على صلة الموصول، أو الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب أيضًا، وقيل: حالية في محل نصب، ولا: نافية، ويكاد: فعل مضارع ناقص من أفعال المقاربة، واسمها ضمير مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبين﴾</span></span> خبر يكاد.</p></div>"
  43,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلولا ألقي عليه أسورة من ذهب﴾</span></span>: الفاء: عاطفة، ولولا: حرف تحضيض بمعنى هلا، وألقي: فعل ماض مبني لما لم يسمَّ فاعله، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقي﴾</span></span>، وأسورة: نائب فاعل، ومن ذهب: جار ومجرور متعلقان بصفة لـ<span class="hlt"><span class="qpc-hafs">﴿أسورة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو جاء معه الملائكة مقترنين﴾</span></span>: أو: حرف عطف، وجاء: فعل ماض، ومعه: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، والملائكة: فاعل، ومقترنين: حال، أي: متتابعين يشهدون بصدقه.</p></div>"
  43,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستخف قومه فأطاعوه إنهم كانوا قوما فاسقين﴾</span></span>: الفاء: عاطفة، واستخف: فعل ماض، وقومه: مفعول به. فأطاعوه: الفاء: عاطفة، وأطاعوه: فعل ماض وفاعل ومفعول به، وإن: حرف ناسخ، وهم: اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم...﴾</span></span> تعليلية لا محل لها من الإعراب، وكانوا: كان حرف ناسخ، وواو الجماعة اسمها، وقومًا: خبرها، وفاسقين: صفة.</p></div>"
  43,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما آسفونا انتقمنا منهم فأغرقناهم أجمعين﴾</span></span>: الفاء: عاطفة، ولما: حينية ظرفية، أو رابطة، وآسفونا: فعل ماض وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿انتقمنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انتقمنا﴾</span></span>، فأغرقناهم: عطف على <span class="hlt"><span class="qpc-hafs">﴿انتقمنا﴾</span></span>، وأجمعين: تأكيد للهاء.</p></div>"
  43,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فجعلناهم سلفا ومثلا للآخرين﴾</span></span>: الفاء: عاطفة، وجعلناهم: فعل وفاعل ومفعول به أول، وسلفًا: مفعول به ثان، ومثلًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿سلفًا﴾</span></span>، وللآخرين: جار ومجرور متعلقان بصفة لـ<span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>.</p></div>"
  43,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما ضرب ابن مريم مثلا إذا قومك منه يصدون﴾</span></span>: لما: ظرفية حينية، أو رابطة، وضُرب: فعل ماض مبني لما لم يسمَّ فاعله، وابن مريم: نائب فاعل، ومثلًا: مفعول به ثان، لأن ضُرب ضُمّن معنى جعل، أو حال، أي ذُكر ممثلًا به، وإذا: فجائية، أو ظرف معمول لفعل المفاجأة الذي هو جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، أو حرف، وقومك: مبتدأ، ومنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصِدون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿قومك﴾</span></span>.</p></div>"
  43,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا أآلهتنا خير أم هو﴾</span></span>: الواو: عاطفة، وقالوا: فعل وفاعل، والهمزة: للاستفهام، وآلهتنا: مبتدأ، وخير: خبر، وأم: حرف عطف، وهي متصلة، وهو: معطوف على <span class="hlt"><span class="qpc-hafs">﴿آلهتنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما ضربوه لك إلا جدلا بل هم قوم خصمون﴾</span></span>: ما: نافية، وضربوه: فعل وفاعل ومفعول به، ولك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضربوه﴾</span></span>، وإلا: أداة حصر، وجدلًا: مفعول من أجله، أو مصدر في موضع الحال، أي: إلا مجادلين، وبل: حرف إضراب، وهم: مبتدأ، وقوم: خبر، وخصمون: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  43,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا عبد أنعمنا عليه وجعلناه مثلا لبني إسرائيل﴾</span></span>: إن: نافية، وهو: مبتدأ، وإلا: أداة حصر، وعبد: خبر هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span> صفة لعبد، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span>، وجعلناه: عطف على <span class="hlt"><span class="qpc-hafs">﴿أنعمنا﴾</span></span>، ومثلًا: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span>، ولبني إسرائيل: جار ومجرور متعلقان بصفة لـ<span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>.</p></div>"
  43,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نشاء لجعلنا منكم ملائكة في الأرض يخلفون﴾</span></span>: الواو: عاطفة، ولو: شرطية، ونشاء: فعل مضارع مرفوع، والفاعل مستتر تقديره: نحن، واللام: واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>، وجعلنا: فعل وفاعل، ومنكم: جار ومجرور متعلقان بمفعول به ثان، إن كانت <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> بمعنى: صيرنا، وإن كانت بمعنى خلقنا: فالجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخلفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخلفون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ملائكة﴾</span></span>، وقيل من للبدلية، أي: لجعلنا بدلكم ملائكة.</p></div>"
  43,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لعلم للساعة فلا تمترن بها﴾</span></span>: الواو: عاطفة، وإن: حرف ناسخ، والهاء: اسم إن، واللام: المزحلقة، وعلم: خبر إن، وللساعة: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، أي: شرط من أشراطها تُعلم به، فسمي الشرط علمًا لحصول العلم به، والفاء: الفصيحة، ولا: ناهية، وتمترن: فعل مضارع مجزوم بلا الناهية، وعلامة جزمه حذف النون، والواو المحذوفة لالتقاء الساكنين فاعل، والنون المشددة نون التوكيد الثقيلة، وبها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمترن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتبعون هذا صراط مستقيم﴾</span></span>: الواو: عاطفة، واتبعون: فعل أمر مبني على حذف النون، والواو: فاعل، والنون: للوقاية، والياء المحذوفة خطًّا: مفعول به، وهذا: مبتدأ، وصراط: خبر، ومستقيم: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿صراط﴾</span></span>.</p></div>"
  43,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يصدنكم الشيطان إنه لكم عدو مبين﴾</span></span>: الواو: عاطفة، ولا: ناهية، ويصدنكم: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، وهو في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والكاف: مفعول به، والشيطان: فاعل، وإنه: إن: حرف ناسخ، والهاء: اسم إن، ولكم: جار ومجرور متعلقان بمحذوف حال، وعدو: خبر إن، ومبين: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عدو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه لكم عدو مبين﴾</span></span> تعليلية لا محل لها من الإعراب.</p></div>"
  43,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جاء عيسى بالبينات قال قد جئتكم بالحكمة ولأبين لكم بعض الذي تختلفون فيه﴾</span></span>: لما: رابطة، أو حينية، وجاء عيسى: فعل ماض وفاعل، وبالبينات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال...﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد جئتكم...﴾</span></span> مقول القول، ولأبين: الواو: عاطفة، واللام: لام التعليل، وأبين: فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، ولأبين: جار ومجرور معطوفان على <span class="hlt"><span class="qpc-hafs">﴿بالحكمة﴾</span></span>، وقيل: متعلقان بمقدر، أي: وجئتكم لأبين. ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبين﴾</span></span>، وبعض الذي: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أبين﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تختلفون﴾</span></span> صلة الموصول لا محل لها من الإعراب، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تختلفون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span></span>: الفاء: عاطفة، والكلام معطوف على ما سبقه على أنه تتمة كلام عيسى، أو استئنافية، والكلام مستأنف لا محل له من الإعراب، وهو للدلالة على طريق الطاعة، ومحجتها الواضحة، واتقوا الله: فعل أمر وفاعل ومفعول به، وأطيعون: عطف على <span class="hlt"><span class="qpc-hafs">﴿فاتقوا﴾</span></span>، والياء المحذوفة في <span class="hlt"><span class="qpc-hafs">﴿وأطيعون﴾</span></span> لمراعاة خط المصحف مفعول به.</p></div>"
  43,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله هو ربي وربكم فاعبدوه هذا صراط مستقيم﴾</span></span>: إن: حرف ناسخ،  والله: اسم إن، وهو: مبتدأ، وربي: خبر، والجملة خبر إن، وربكم: عطف على <span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله...﴾</span></span> مستأنفة لا محل لها من الإعراب، والفاء: الفصيحة، واعبدوه: فعل وفاعل ومفعول به، وهذا: مبتدأ، وصراط: خبر، ومستقيم: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿صراط﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا صراط مستقيم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  43,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span></span>: الفاء: عاطفة، واختلف الأحزاب: فعل وفاعل، ومن بينهم: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿الأحزاب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فويل للذين ظلموا من عذاب يوم أليم﴾</span></span>: الفاء: عاطفة، وويل: مبتدأ، وساغ الابتداء به لتضمنه معنى الدعاء، وللذين: جار ومجرور متعلقان بمحذوف خبر المبتدأ، ومن عذاب يوم: جار ومجرور متعلقان بمحذوف خبر ثان، أو حال، أي: حال كونه كائنًا من عذاب يوم القيامة، وأليم: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>.</p></div>"
  43,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل ينظرون إلا الساعة أن تأتيهم بغتة وهم لا يشعرون﴾</span></span>: هل: حرف استفهام معناه النفي، أي: لا ينظرون، وينظرون: فعل مضارع مرفوع بثبوت النون، والواو: فاعل، وإلا: أداة حصر، والساعة: مفعول به، وأن تأتيهم: المصدر المنسبك من أن وتأتيهم بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿الساعة﴾</span></span>، وبغتة: حال، والواو: للحال، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يشعرون﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهم لا يشعرون﴾</span></span> حال ثانية.</p></div>"
  43,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الأخلاء يومئذ بعضهم لبعض عدو إلا المتقين﴾</span></span>: الأخلاء: مبتدأ، ويومئذ: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عدو﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ تأتيهم الساعة، وبعضهم: مبتدأ ثان، ولبعض: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عدو﴾</span></span>، وعدو: خبر <span class="hlt"><span class="qpc-hafs">﴿بعضهم﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿الأخلاء﴾</span></span>، وإلا: أداة استثناء، والمتقين: مستثنى بـ<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> منصوب.</p></div>"
  43,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا عباد لا خوف عليكم اليوم ولا أنتم تحزنون﴾</span></span>: الجملة مقول قول محذوف، أي: ويقال لهم، ويا: حرف نداء، وعباد: منادى مضاف إلى ياء المتكلم المحذوفة مراعاة لخط المصحف، ولا: نافية، وخوف: مبتدأ، وساغ الابتداء به، لأنه سُبق بنفي، وعليكم: جار ومجرور متعلقان بمحذوف خبر، واليوم: ظرف متعلق بمحذوف حال، ولا: عطف على ما تقدم، وأنتم: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿تحزنون﴾</span></span> جملة فعلية في محل رفع خبر.</p></div>"
  43,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين آمنوا بآياتنا وكانوا مسلمين﴾</span></span>: الذين: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عبادي﴾</span></span>، لأنه منادى مضاف، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب. وبآياتنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، وكانوا: كان: فعل ماض ناقص، والواو: اسمها، ومسلمين: خبرها، والجملة معطوفة على الصلة، أو: الواو: حالية، والجملة في محل نصب على الحال من الواو.</p></div>"
  43,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادخلوا الجنة أنتم وأزواجكم تحبرون﴾</span></span>: ادخلوا: فعل أمر مبني على حذف النون، والواو: فاعل، والجنة: مفعول به على السعة، وأنتم: مبتدأ، وأزواجكم: عطف على <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحبرون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>.</p></div>"
  43,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يطاف عليهم بصحاف من ذهب وأكواب﴾</span></span>: يطاف: فعل مضارع مبني لما لم يسمَّ فاعله، وعليهم: جار ومجرور متعلقان بمحذوف نائب فاعل، وبصحاف: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يطاف﴾</span></span>، ومن ذهب: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صحاف﴾</span></span>، وأكواب: عطف على <span class="hlt"><span class="qpc-hafs">﴿صحاف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وفيها ما تشتهيه الأنفس وتلذ الأعين وأنتم فيها خالدون﴾</span></span>: الواو: عاطفة، وفيها: جار ومجرور متعلقان بمحذوف خبر مقدم، وما: موصول مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تشتهيه الأنفس﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿تلذ الأعين﴾</span></span>: عطف على الصلة داخلة في حيزها، وأنتم: مبتدأ، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون: خبر <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>.</p></div>"
  43,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك الجنة التي أورثتموها بما كنتم تعملون﴾</span></span>: الواو: عاطفة، وتلك: مبتدأ، والجنة: خبر، والتي: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أورثتموها﴾</span></span> صلة الموصول لا محل لها من الإعراب، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أورثتموها﴾</span></span>، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>.</p></div>"
  43,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لكم فيها فاكهة كثيرة منها تأكلون﴾</span></span>: لكم: جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها: جار ومجرور متعلقان بمحذوف حال، وفاكهة: مبتدأ مؤخر، وكثيرة: صفة، ومنها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فاكهة﴾</span></span>، أو: <span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span> في الآية السابقة بدل من اسم الإشارة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لكم فيها فاكهة﴾</span></span> هي الخبر.</p></div>"
  43,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المجرمين في عذاب جهنم خالدون﴾</span></span>: إن المجرمين: إن: حرف ناسخ، والمجرمين: اسم إن، وفي عذاب: جار ومجرور متعلقان بمحذوف خبر أول، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وجهنم: مضاف إليه، وخالدون: خبر ثان.</p></div>"
  43,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يفتر عنهم وهم فيه مبلسون﴾</span></span>: الجملة حالية، ولا: نافية، ويفتر: فعل مضارع مبني لما لم يسمَّ فاعله، ونائب فاعل مستتر تقديره: هو، أي: العذاب، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفتر﴾</span></span>، والواو: للحال، وهم: مبتدأ، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مبلسون﴾</span></span>، ومبلسون: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهم فيه مبلسون﴾</span></span> حال ثانية.</p></div>"
  43,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ظلمناهم ولكن كانوا هم الظالمين﴾</span></span>: الواو: عاطفة، وما: نافية، وظلمناهم: فعل ماض وفاعل ومفعول به، والواو: حالية، ولكن: مخففة مهملة، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسمها، وهم: ضمير فصل لا محل له من الإعراب، أو هو توكيد للواو، والظالمين: خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  43,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونادوا يا مالك ليقض علينا ربك﴾</span></span>: الواو: عاطفة، ونادوا: فعل ماض وفاعل، وعُبر بالماضي عن المضارع إيذانًا بحقيقة وقوعه، فهو من باب <span class="hlt"><span class="qpc-hafs">﴿أتى أمر الله﴾</span></span>، ويا: للنداء، ومالك: منادى مفرد علم مضموم في محل نصب، واللام: لام الطلب غرضها الدعاء، ويقض: فعل مضارع مجزوم بلام الطلب، وعلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقض﴾</span></span>، أي: ليمتنا، وربك: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إنكم ماكثون﴾</span></span>: قال: فعل ماض، والفاعل ضمير مستتر تقديره هو، وإن:حرف ناسخ، والكاف: اسم إن، والميم: علامة الجمع، وماكثون: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنكم ماكثون﴾</span></span> في موضع نصب مقول القول.</p></div>"
  43,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد جئناكم بالحق ولكن أكثركم للحق كارهون﴾</span></span>: اللام: جواب للقسم المحذوف، وقد: حرف تحقيق، وجئناكم: فعل وفاعل ومفعول به، وبالحق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئناكم﴾</span></span>، والواو: حالية، ولكن: حرف ناسخ، وأكثركم: اسم لكن، والكاف مضاف إليه، وللحق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كارهون﴾</span></span>، وكارهون: خبر لكن.</p></div>"
  43,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم أبرموا أمرا فإنا مبرمون﴾</span></span> أم: منقطعة بمعنى: بل وهمزة الاستفهام الإنكاري، وأبرموا: فعل ماض وفاعل، وأمرًا: مفعول به، والفاء: عاطفة، وإن: حرف ناسخ، ونا: اسم إن، ومبرمون: خبر إن.</p></div>"
  43,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يحسبون أنا لا نسمع سرهم ونجواهم﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، ويحسبون: فعل مضارع مرفوع، والواو فاعل، وأن وما بعدها سدت مسد مفعولي يحسبون، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا نسمع﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>، وسرهم: مفعول <span class="hlt"><span class="qpc-hafs">﴿نسمع﴾</span></span>، ونجواهم: عطف على <span class="hlt"><span class="qpc-hafs">﴿سرهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلى ورسلنا لديهم يكتبون﴾</span></span>: بلى: حرف جواب لإبطال النفي، أي: بلى نحن نسمع سرهم ونجواهم. والواو: للحال، ورسلنا: مبتدأ، ولديهم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يكتبون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكتبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿رسلنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ورسلنا...﴾</span></span> حالية.</p></div>"
  43,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إن كان للرحمن ولد فأنا أول العابدين﴾</span></span>: قل: فعل أمر، وفاعله مستتر تقديره أنت، وإن: شرطية، وكان: فعل ماض ناقص، وللرحمن: جار ومجرور متعلقان بمحذوف خبر كان مقدم، وولد: اسم كان مؤخر، والفاء: رابطة لجواب الشرط، وأنا: مبتدأ، وأول العابدين: خبر.</p></div>"
  43,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان رب السماوات والأرض رب العرش عما يصفون﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، ورب السماوات والأرض: مضاف إليه، ورب العرش: بدل من <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> الأولى، وعما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  43,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذرهم يخوضوا ويلعبوا حتى يلاقوا يومهم الذي يوعدون﴾</span></span>: الفاء: الفصيحة، وذرهم: فعل وفاعل مستتر ومفعول به، ويخوضوا: جواب الطلب، ولذلك جُزم، ويلعبوا: عطف على <span class="hlt"><span class="qpc-hafs">﴿يخوضوا﴾</span></span>، وحتى: حرف غاية وجر، ويلاقوا: فعل مضارع منصوب بأن مضمرة بعد <span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والواو: فاعل، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرهم﴾</span></span>، ويومهم: مفعول به، والذي: صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوعدون﴾</span></span> صلة الموصول لا محل لها من الإعراب، ويوعدون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  43,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي في السماء إله وفي الأرض إله وهو الحكيم العليم﴾</span></span>: الواو: استئنافية، وهو: مبتدأ، والذي: خبره، وفي السماء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>، لأنه بمعنى معبود، وإله: خبر لمبتدأ محذوف تقديره: هو، والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> لا محل لها من الإعراب. وفي الأرض إله: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿في السماء إله﴾</span></span>، وهو: مبتدأ، والحكيم العليم: خبران.</p></div>"
  43,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتبارك الذي له ملك السماوات والأرض وما بينهما﴾</span></span>: الواو: عاطفة، وتبارك: فعل ماض، والذي: فاعله، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، وملك: مبتدأ مؤخر. والسماوات: مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿له ملك السماوات﴾</span></span> صلة الموصول لا محل لها من الإعراب. وما: عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات والأرض﴾</span></span>، والظرف متعلق بمحذوف هو صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعنده علم الساعة وإليه ترجعون﴾</span></span>: الواو: عاطفة، وعنده: ظرف متعلق بمحذوف خبر مقدم، وعلم الساعة: مبتدأ مؤخر، وإليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  43,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يملك الذين يدعون من دونه الشفاعة﴾</span></span>: الواو: عاطفة، ولا: نافية، ويملك: فعل مضارع، والذين: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول، ومن دونه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، والشفاعة: مفعول <span class="hlt"><span class="qpc-hafs">﴿يملك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من شهد بالحق وهم يعلمون﴾</span></span>: إلا: أداة حصر، ومَن: مستثنى من <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، والاستثناء متصل لاندراج الملائكة والمسيح وعزير فيما يعبدونه، والمعنى: إلا من شهد بالحق كعزير والمسيح والملائكة فإنهم يملكون الشفاعة بتمليك الله إياهم لها. وجملة <span class="hlt"><span class="qpc-hafs">﴿شهد بالحق﴾</span></span> صلة مَن، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو حالية أو عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> خبر.</p></div>"
  43,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم من خلقهم ليقولن الله فأنى يؤفكون﴾</span></span>: الواو: عاطفة، واللام: موطئة للقسم، وإن: شرطية، وسألتهم: فعل ماض، وفاعل ومفعول به، وهو في محل جزم فعل الشرط، ومَن: اسم استفهام في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقهم﴾</span></span> خبر مَن، وجملة الاستفهام المعلقة في محل نصب مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿سألتهم﴾</span></span>، وليقولن: اللام: جواب القسم، وجواب الشرط محذوف، ويقولن: فعل مضارع مرفوع بثبوت النون المحذوفة، لتوالي الأمثال، والواو المحذوفة لالتقاء الساكنين فاعل، والنون المشددة: نون التوكيد الثقيلة، والله: فاعل بفعل محذوف دل عليه موصول الاستفهام، والتقدير: خلقنا الله، وقيل: مبتدأ، والفاء: عاطفة، وأنى: اسم استفهام بمعنى كيف في محل نصب على الحال، ويؤفكون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  43,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيله يا رب﴾</span></span>: الواو: للقسم، وقيله: أي <span class="hlt"><span class="qpc-hafs">﴿قوله﴾</span></span> مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف، تقديره: أقسم، والجواب إما محذوف، أي: لأفعلن بهم ما أريد، وإما مذكور، وهو قوله: <span class="hlt"><span class="qpc-hafs">﴿إن هؤلاء قوم لا يؤمنون﴾</span></span>: كأنه قيل: وأُقسم بقيله يا رب، وإن: حرف ناسخ، وهؤلاء: اسم إن، وقوم: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> نعت لقوم.</p></div>"
  43,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصفح عنهم وقل سلام فسوف يعلمون﴾</span></span>: الفاء: الفصيحة، واصفح: فعل أمر وفاعله مستتر تقديره: أنت، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصفح﴾</span></span>، وقل: عطف على <span class="hlt"><span class="qpc-hafs">﴿فاصفح﴾</span></span>، وسلام: خبر لمبتدأ محذوف، أي: الأمر سلام، فسوف: الفاء: عاطفة، وسوف: حرف للاستقبال، ويعلمون: فعل مضارع مرفوع، وعلامة رفعه ثبوت النون، والواو: فاعل، والمفعول به محذوف للتفخيم، أي: مغبةَ أمرهم.</p></div>"
