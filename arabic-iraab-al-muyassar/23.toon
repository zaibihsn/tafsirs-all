quran[118]{c,v,t}:
  23,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد أفلح المؤمنون﴾</span></span>: قد حرف تحقيق، وأفلح فعل ماض، والمؤمنون فاعل.</p></div>"
  23,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين هم في صلاتهم خاشعون﴾</span></span>: الذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿المؤمنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفي صلاتهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خاشعون﴾</span></span>، وخاشعون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة صلة الذين لا محل لها من الإعراب.</p></div>"
  23,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم عن اللغو معرضون﴾</span></span>: الواو عاطفة، والذين عطف على الذين، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وعن اللغو جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿معرضون﴾</span></span>، ومعرضون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة صلة الذين لا محل لها من الإعراب.</p></div>"
  23,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم للزكاة فاعلون﴾</span></span>: الواو عاطفة، والذين عطف على الذين، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفاعلون خبر، وللزكاة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاعلون﴾</span></span>، وضمن فاعلون معنى مؤدون، وقيل: اللام صلة في المفعول به لتقدمه على عامله.</p></div>"
  23,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم لفروجهم حافظون﴾</span></span>: الواو عاطفة، والذين عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وحافظون خبر، ولفروجهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حافظون﴾</span></span>.</p></div>"
  23,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا على أزواجهم﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿على أزواجهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حافظون﴾</span></span> بتضمينه معنى ممسكين، أو بمحذوف حال أي قوامين.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو ما ملكت أيمانهم﴾</span></span>: أو حرف عطف، وما عطف على أزواجهم، وجملة ملكت أيمانهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم غير ملومين﴾</span></span>: الجملة تعليل للاستثناء، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وغير ملومين خبرها.</p></div>"
  23,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن ابتغى وراء ذلك فأولئك هم العادون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، وابتغى فعل ماض في محل جزم فعل الشرط، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿وراء﴾</span></span> ظرف متعلق بمحذوف صفة، وهذا المحذوف مفعول ابتغى، أي: ابتغي شيئًا كائنًا وراء ذلك، أو وراء بمعنى خلاف، فينصب على أنه مفعول به، وذلك مضاف إليه، وجملة الشرط في محل رفع خبر، والفاء رابطة لجواب الشرط، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، والعادون خبر، والجملة خبر أولئك، أو هم ضمير فصل، والعادون خبر أولئك.</p></div>"
  23,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم لأماناتهم وعهدهم راعون﴾</span></span>: الواو عاطفة، والذين عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وراعون خبره، ولأماناتهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راعون﴾</span></span>، وعهدهم عطف على أماناتهم.</p></div>"
  23,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم على صلواتهم يحافظون﴾</span></span>: الواو عاطفة، والذين عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وعلى صلواتهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحافظون﴾</span></span>، وجملة يحافظون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة الاسمية خبر الذين.</p></div>"
  23,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك هم الوارثون﴾</span></span>: أولئك مبتدأ، وهم ضمير فصل، والوارثون خبر، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثانٍ، والوارثون خبره، والجملة الاسمية خبر أولئك.</p></div>"
  23,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يرثون الفردوس هم فيها خالدون﴾</span></span>: الذين خبر ثان، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الوارثون﴾</span></span>، وجملة يرثون صلة الذين لا محل لها من الإعراب، والفردوس مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة هم فيها خالدون حال.</p></div>"
  23,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا الإنسان من سلالة من طين﴾</span></span>: الجملة لا محل لها من الإعراب لأنها جواب قسم محذوف، وخلقنا فعل وفاعل، والإنسان مفعول به، ومن سلالة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، ومن للابتداء، و<span class="hlt"><span class="qpc-hafs">﴿من طين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لسلالة، أو متعلقان بسلالة لأنها بمعنى مسلولة، ومن للبيان، والكلام مستأنف لا محل له من الإعراب.</p></div>"
  23,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلناه نطفة في قرار مكين﴾</span></span>: ثم حرف عطف، وجعلناه فعل وفاعل ومفعول به، ونطفة مفعول به ثان، وفي قرار جار ومجرور متعلقان بمحذوف مفعول به ثالث، ومكين صفة.</p></div>"
  23,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم خلقنا النطفة علقة﴾</span></span>: ثم حرف عطف، وخلقنا فعل وفاعل، والنطفة مفعول به أول، وعلقة مفعول به ثان لأن خلقنا متضمن معنى صيرنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فخلقنا العلقة مضغة﴾</span></span>: الفاء حرف عطف، وخلقنا فعل وفاعل، والعلقة مفعول به أول، ومضغة مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿فخلقنا المضغة عظاما﴾</span></span>: فخلقنا فعل وفاعل، والمضغة مفعول به أول، وعظامًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكسونا العظام لحما﴾</span></span>: الفاء حرف عطف، وكسونا فعل وفاعل، والعظام مفعول به أول، ولحما مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم أنشأناه خلقا آخر﴾</span></span>: ثم حرف عطف، وأنشأناه فعل وفاعل ومفعول به، وخلقًا حال، وآخر صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتبارك الله أحسن الخالقين﴾</span></span>: الفاء استئنافية، وتبارك فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، وأحسن بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، والخالقين مضاف إليه، ومميز أحسن محذوف للعلم به، أي: خلقًا، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  23,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إنكم بعد ذلك لميتون﴾</span></span>: ثم حرف عطف وتراخ، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بعد ذلك﴾</span></span> ظرف متعلق بمحذوف حال، أو: بـ<span class="hlt"><span class="qpc-hafs">﴿ميتون﴾</span></span>، واللام المزحلقة، وميتون خبر إن.</p></div>"
  23,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إنكم يوم القيامة تبعثون﴾</span></span>: عطف ما تقدم، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تبعثون﴾</span></span>، وتبعثون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة تبعثون خبر إن.</p></div>"
  23,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا فوقكم سبع طرائق﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوب، وقد حرف تحقيق، وخلقنا فعل وفاعل، وفوقكم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، وسبع طرائق مفعول خلقنا، وطرائق مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا عن الخلق غافلين﴾</span></span>: الواو حالية، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وعن الخلق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافلين﴾</span></span>، وغافلين خبر كان.</p></div>"
  23,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنزلنا من السماء ماء بقدر فأسكناه في الأرض﴾</span></span>: الواو عاطفة، وأنزلنا عطف على خلقنا، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، وماء مفعول به، وبقدر جار ومجرور متعلقان بمحذوف صفة لماء، أو حال من الضمير، فأسكناه عطف على أنزلنا، وهو فعل وفاعل ومفعول به، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسكناه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا على ذهاب به لقادرون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وعلى ذهاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذهاب﴾</span></span>، وقادرون خبر إن، واللام المزحلقة.</p></div>"
  23,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأنشأنا لكم به جنات من نخيل وأعناب﴾</span></span>: الفاء عاطفة، وأنشأنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأنا﴾</span></span> أيضًا، أو بمحذوف حال، والباء للملابسة، وجنات مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من نخيل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لجنات، وأعناب عطف على نخيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم فيها فواكه كثيرة ومنها تأكلون﴾</span></span>: لكم جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها جار ومجرور متعلقان بمحذوف حال، وفواكه مبتدأ مؤخر، وكثيرة صفة، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span>، وتأكلون فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لكم فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال من جنات، أو صفة.</p></div>"
  23,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وشجرة تخرج من طور سيناء﴾</span></span>: الواو حرف عطف، وشجرة عطف على جنات، وجملة تخرج صفة لشجرة، ومن طور سيناء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿تنبت بالدهن وصبغ للآكلين﴾</span></span>: الجملة صفة ثانية لشجرة، و<span class="hlt"><span class="qpc-hafs">﴿بالدهن﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسة بالدهن ومصحوبة به، وصبغ عطف على الدهن، وللآكلين جار ومجرور متعلقان بمحذوف صفة لصبغ.</p></div>"
  23,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن لكم في الأنعام لعبرة نسقيكم مما في بطونها﴾</span></span>: الواو: حرف عطف. وإن: حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> المقدم. وفي الأنعام: جار ومجرور متعلقان بمحذوف حال. واللام المزحلقة، وعبرة: اسم إن. ونسقيكم: فعل مضارع، والفاعل مستتر، والكاف: مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span> استئنافية لا محل لها من الإعراب. ومما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسيقكم﴾</span></span>. وفي بطونها: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكم فيها منافع كثيرة ومنها تأكلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها جار ومجرور متعلقان بمحذوف حال، ومنافع مبتدأ مؤخر، وكثيرة صفة، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span>، وتأكلون فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لكم فيها ...﴾</span></span> معطوفة على نسقيكم لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿منها يأكلون﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿لكم فيها منافع﴾</span></span> لا محل لها من الإعراب.</p></div>"
  23,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعليها وعلى الفلك تحملون﴾</span></span>: الواو عاطفة، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحملون﴾</span></span>، والضمير يعود على الإبل التي هي من جملة الأنعام، وتحملون فعل مضارع مبني لما لم يسمَّ فاعله والواو نائب فاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿وعليها﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>.</p></div>"
  23,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا نوحا إلى قومه﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأرسلنا فعل وفاعل، ونوحًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى قومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال يا قوم اعبدوا الله ما لكم من إله غيره أفلا تتقون﴾</span></span>: الفاء حرف عطف، وقال فعل ماض، وفاعله مستتر تقديره: هو، ويا حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿اعبدوا﴾</span></span> الله فعل أمر وفاعل ومفعول به، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ مؤخر محلًّا مجرور بمن لفظا، وغيره صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> على المحل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لكم من إله غيره﴾</span></span> مستأنفة لا محل لها من الإعراب، تجري مجرى التعليل للأمر بالعبادة، والهمزة للاستفهام، والفاء عاطفة على مقدر، أي: أتعصون فلا تتقون؟</p></div>"
  23,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقال الملأ الذين كفروا من قومه ما هذا إلا بشر مثلكم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الملأ﴾</span></span> فعل وفاعل، والذين صفة للملأ، وجملة كفروا صلة الذين لا محل لها من الإعراب، ومن قومه جار ومجرور متعلقان بمحذوف حال، وجملة ما هذا مقول القول، وما نافية، وهذا مبتدأ، وإلا أداة حصر، وبشر خبر، ومثلكم صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يريد أن يتفضل عليكم﴾</span></span>: جملة يريد صفة، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها مفعول يريد، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتفضل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو شاء الله لأنزل ملائكة﴾</span></span>: الواو حالية، أو استئنافية، وشاء الله فعل وفاعل، ومفعول المشيئة محذوف يفهم من مضمون جواب لو، أي: لو شاء إنزال رسول، واللام واقعة في جواب لو، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنزل ملائكة﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولو شاء الله...﴾</span></span> في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما سمعنا بهذا في آبائنا الأولين﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وما نافية، وسمعنا فعل وفاعل، وبهذا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سمعنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في آبائنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الأولين﴾</span></span> صفة لآبائنا.</p></div>"
  23,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا رجل به جنة﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وإن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وإلا أداة حصر، ورجل خبر هو، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجنة مبتدأ مؤخر، والجملة صفة رجل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتربصوا به حتى حين﴾</span></span>: الفاء الفصيحة، أي: إن أردتم أن تتبينوا حقيقة فتربصوا، أو الفاء استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وتربصوا فعل أمر، أي: انتظروا، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تربصوا﴾</span></span>، وحتى حرف غاية وجر، وحين مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تربصوا﴾</span></span> أيضًا.</p></div>"
  23,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب انصرني بما كذبون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وانصرني فعل دعاء، والفاعل مستتر، والنون للوقاية، والياء مفعول به، والباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع الفاعل بعدها بمصدر مجرور بالباء، أي: بسبب تكذيبهم إياي، فالباء للسبيية، أو للبدل، أي: انصرني بدل تكذيبهم إياي، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انصرني﴾</span></span>.</p></div>"
  23,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوحينا إليه أن اصنع الفلك بأعيننا ووحينا﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأوحينا: فعل وفاعل، وإليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اصنع﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. واصنع: فعل أمر، وفاعله مستتر تقديره: أنت. والفلك: مفعول به. و<span class="hlt"><span class="qpc-hafs">﴿بأعيننا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من الضمير المستكن في <span class="hlt"><span class="qpc-hafs">﴿اصنع﴾</span></span>. ووحينا عطف على أعيننا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا جاء أمرنا وفار التنور فاسلك فيها من كل زوجين اثنين﴾</span></span>: الفاء عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> في محل جر مضاف إليه، وأمرنا فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فار التنور﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاء أمرنا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاسلك﴾</span></span> الفاء رابطة لجواب إذا، واسلك فعل أمر، وفاعله مستتر تقديره: أنت، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من كل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسلك﴾</span></span>، وزوجين مفعول اسلك، واثنين نعت لزوجين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأهلك إلا من سبق عليه القول منهم﴾</span></span>: الواو عاطفة، وأهلك عطف على اثنين، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مستثنى متصل منصوب، وجملة سبق صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبق﴾</span></span>، والقول فاعل، ومنهم جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تخاطبني في الذين ظلموا إنهم مغرقون﴾</span></span>: الواو عاطفة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تخاطبني﴾</span></span> فعل مضارع مجزوم بلا، والفاعل مستتر تقديره: أنت، والنون للوقاية، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخاطبني﴾</span></span> بتقدير مضاف محذوف أي: في أمر الذين، وجملة ظلموا صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم مغرقون﴾</span></span> تعليل للنهي عن المخاطبة بشأنهم، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، ومغرقون خبرها.</p></div>"
  23,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا استويت أنت ومن معك على الفلك﴾</span></span>: الفاء استئنافية، وإذا ظرف مستقبل، وجملة استويت في محل جر بالإضافة إليها، وأنت تأكيد للتاء، <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> عطف على التاء، ومعك ظرف متعلق بمحذوف صلة لمن لا محل لها من الإعراب، وعلى الفلك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استويت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقل الحمد لله الذي نجانا من القوم الظالمين﴾</span></span>: الفاء رابطة لجواب إذا، وقل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿الحمد﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول، وجملة القول لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والذي صفة لله، وجملة نجانا صلة الذي لا محل لها من الإعراب، ومن القوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجانا﴾</span></span>، والظالمين صفة للقوم، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإذا استويت...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  23,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب أنزلني منزلا مباركا﴾</span></span>: الواو عاطفة، وقل فعل أمر، وفاعله مستتر تقديره: أنت، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وحرف النداء محذوف، وأنزلني فعل دعاء، والفاعل مستتر تقديره: أنت، والنون للوقاية، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿منزلا﴾</span></span> اسم مكان مفعول به ثان، أو اسم مصدر نائب عن المفعول المطلق، و<span class="hlt"><span class="qpc-hafs">﴿مباركا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنت خير المنزلين﴾</span></span>: الواو حالية، وأنت مبتدأ، وخير المنزلين خبر.</p></div>"
  23,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام للابتداء، وآيات اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كنا لمبتلين﴾</span></span>: إن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام الفارقة، ومبتلين خبر كنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا لمبتلين﴾</span></span> خبر إن المخففة، وجملة وإن كنا عطف على سابقتها لا محل لها من الإعراب.</p></div>"
  23,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أنشأنا من بعدهم قرنا آخرين﴾</span></span>: ثم حرف عطف للتراخي، وأنشأنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وقرنا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿آخرين﴾</span></span> صفة.</p></div>"
  23,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأرسلنا فيهم رسولا منهم﴾</span></span>: الفاء حرف عطف، وأرسلنا فعل وفاعل، وفيهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span> مفعول به، ومنهم جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن اعبدوا الله ما لكم من إله غيره أفلا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر منصوب بنزع الخافض، أي: بأن اعبدوا، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ مؤخر محلًّا مجرور بمن لفظا، وغيره صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> على المحل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لكم من إله غيره﴾</span></span> مستأنفة لا محل لها من الإعراب، وهي تجري مجرى التعليل للأمر بالعبادة، والهمزة للاستفهام، والفاء عاطفة على مقدر، أي: أتعصون فلا تتقون؟</p></div>"
  23,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الملأ من قومه الذين كفروا وكذبوا بلقاء الآخرة وأترفناهم في الحياة الدنيا﴾</span></span>: الواو عاطفة، وقال الملأ فعل وفاعل، ومن قومه جار ومجرور متعلقان بمحذوف حال من الفاعل، والذين صفة لقومه، وجملة كفروا صلة الذين، وما بعدها عطف عليه داخل في حيزها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما هذا إلا بشر مثلكم يأكل مما تأكلون منه ويشرب مما تشربون﴾</span></span>: ما نافية، وهذا مبتدأ، وإلا أداة حصر، وبشر خبر، ومثلكم صفة، وجملة يأكل صفة ثانية، ومما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكل﴾</span></span>، وجملة تأكلون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: من مأكولكم، وكذلك قوله: <span class="hlt"><span class="qpc-hafs">﴿ويشرب مما تشربون﴾</span></span>، وحذف العائد من الثاني اكتفاء بالعائد الأول، وهو: منه، والجملة كلها مقول القول.</p></div>"
  23,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن أطعتم بشرا مثلكم إنكم إذًا لخاسرون﴾</span></span>: الواو عاطفة، واللام موطئة للقسم، وإن شرطية، وأطعتم فعل وفاعل، وهو في محل جزم فعل الشرط، وبشرًا مفعول به، ومثلكم صفة، وإن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وخاسرون خبرها، وإذًا حرف جواب لا محل له من الإعراب، وجملة إنكم لخاسرون جواب القسم، وجواب الشرط محذوف دل عليه جواب القسم.</p></div>"
  23,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أيعدكم أنكم إذا متم وكنتم ترابا وعظاما أنكم مخرجون﴾</span></span>: الهمزة للاستفهام، وجملة يعدكم مستأنفة لا محل لها من الإعراب، ويعد فعل مضارع مرفوع، والفاعل ضمير مستتر تقديره: هو، والكاف مفعول به، وأن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها في محل نصب مفعول به ثان، ومخرجون خبرها، وإذا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مخرجون﴾</span></span>، وجملة متم في محل جر بإضافة الظرف إليها، <span class="hlt"><span class="qpc-hafs">﴿وكنتم ترابًا وعظامًا﴾</span></span> عطف على إذا متم، و<span class="hlt"><span class="qpc-hafs">﴿أنكم﴾</span></span> الثانية تأكيد للأولى.</p></div>"
  23,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هيهات هيهات لما توعدون﴾</span></span>: هيهات اسم فعل ماض بمعنى بَعُدَ، والثانية تأكيد لفظي لها، واللام صلة، وما اسم موصول مجرور بلام الصلة لفظا مرفوع محلًّا فاعل لاسم الفعل هيهات، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل فاعل هيهات.</p></div>"
  23,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هي إلا حياتنا الدنيا نموت ونحيا﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وإن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وإلا أداة حصر، وحياتنا خبر، والدنيا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿نموت﴾</span></span> حالية، <span class="hlt"><span class="qpc-hafs">﴿ونحيا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نموت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما نحن بمبعوثين﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمبعوثين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مبعوثين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  23,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا رجل افترى على الله كذبا﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وإلا أداة حصر، ورجل خبر، وجملة افترى صفة، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿افترى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كذبا﴾</span></span> مفعول به للفعل افترى، أي: اختلق كذبا وافتعله، أو مفعول لأجله، أي: افترى لأجل الكذب، أو مصدر في موضع الحال، أي: افترى حال كونه كاذبا وهي حال مؤكدة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما نحن له بمؤمنين﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بمؤمنين﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  23,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب انصرني بما كذبون﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، وانصرني فعل دعاء، والفاعل مستتر، والنون للوقاية، والياء مفعول به، والباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع الفاعل بعدها بمصدر مجرور بالباء، أي: بسبب تكذيبهم إياي، فالباء للسبيية، أو للبدل، أي: انصرني بدل تكذيبهم إياي، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انصرني﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿انصرني بما كذبون﴾</span></span> جواب النداء لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿رب انصرني...﴾</span></span> مقول القول في محل نصب، وجملة القول كلها <span class="hlt"><span class="qpc-hafs">﴿قال رب...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  23,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال عما قليل ليصبحن نادمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span>: عن حرف جر، وما صلة، وقليل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصبحن﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿نادمين﴾</span></span>، واللام واقعة في جواب قسم مقدر، ويصحبن فعل مضارع ناقص مرفوع بثبوت النون المحذوفة لتوالي الأمثال، والواو المحذوفة لالتقاء الساكنين اسمها، والنون المشددة نون التوكيد الثقيلة، ونادمين خبر يصبحن.</p></div>"
  23,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذتهم الصيحة بالحق فجعلناهم غثاء فبعدا للقوم الظالمين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذتهم الصيحة﴾</span></span> فعل ومفعول به وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الصيحة، فجعلناهم عطف على فأخذتهم، والهاء مفعول به أول، وغثاء مفعول به ثان، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span> مفعول مطلق لفعل محذوف أي: بعدوا بعدا، فهو مصدر بمعنى الدعاء عليهم، و<span class="hlt"><span class="qpc-hafs">﴿للقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span>. والظالمين صفة للقوم.</p></div>"
  23,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أنشأنا من بعدهم قرونا آخرين﴾</span></span>: ثم حرف عطف وتراخ، وأنشأنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وقرونًا مفعول به، وآخرين صفة.</p></div>"
  23,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما تسبق من أمة أجلها وما يستأخرون﴾</span></span>: ما نافية، وتسبق فعل مضارع، ومن حرف جر صلة، وأمة مجرور لفظًا مرفوع محلًّا لأنه فاعل تسبق، وأجلها مفعول به، وما يستأخرون عطف على ما سبق.</p></div>"
  23,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أرسلنا رسلنا تترى﴾</span></span>: ثم حرف عطف وتراخ، وأرسلنا فعل وفاعل، ورسلنا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿تترى﴾</span></span> منصوب على الحالية، أي: متتابعين، أو نعت لمصدر محذوف، تقديره: أرسالا تترى، أي: متتابعًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كل ما جاء أمة رسولها كذبوه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كلَّ﴾</span></span> نائب ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوه﴾</span></span> متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية زمانية، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> لا محل لها من الإعراب لأنها صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع مدخولها في تأويل مصدر مجرور بالإضافة والتقدير: كلَّ مجيء، وهو على حذف مضاف، أي: كلَّ وقتِ مجيءِ أمةٍ. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة بمعنى <span class="hlt"><span class="qpc-hafs">﴿وقت﴾</span></span> والعائد محذوف والتقدير: كلَّ وقتٍ جاء فيه أمةً رسولُها، فتكون جملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿أمة﴾</span></span> مفعول مقدم، و<span class="hlt"><span class="qpc-hafs">﴿رسولها﴾</span></span> فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذبوه﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأتبعنا بعضهم بعضا وجعلناهم أحاديث﴾</span></span>: الفاء عاطفة، وأتبعنا فعل وفاعل، وبعضهم مفعول به أول، وبعضًا مفعول به ثان، وجعلناهم عطف على أتبعنا، والهاء مفعول به أول، وأحاديث مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿فبعدا لقوم لا يؤمنون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span> مفعول مطلق لفعل محذوف أي: بعدوا بعدا، فهو مصدر بمعنى الدعاء عليهم، ولقوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span>، ولا نافية، ويؤمنون فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> في محل جر صفة لقوم.</p></div>"
  23,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أرسلنا موسى وأخاه هارون بآياتنا وسلطان مبين﴾</span></span>: ثم حرف عطف وتراخٍ، وأرسلنا فعل وفاعل، وموسى مفعول به، وأخاه عطف عليه، وهارون بدل من <span class="hlt"><span class="qpc-hafs">﴿أخاه﴾</span></span> أو عطف بيان، وبآياتنا جار ومجرور متعلقان بمحذوف حال، أي: حال كونهما متلبسين بآياتنا، فالباء للملابسة، وسلطان عطف على آياتنا، ومبين صفة لسلطان.</p></div>"
  23,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى فرعون وملئه فاستكبروا﴾</span></span>: إلى فرعون جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وملئه عطف على فرعون، فاستكبروا عطف على أرسلنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكانوا قوما عالين﴾</span></span>: كان حرف ناسخ، وواو الجماعة اسمها، وقوما خبرها، وعالين صفة.</p></div>"
  23,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا أنؤمن لبشرين مثلنا وقومهما لنا عابدون﴾</span></span>: الفاء عاطفة، وقالوا فعل وفاعل، والضمير يعود على فرعون وملئه، والهمزة للاستفهام، ونؤمن فعل مضارع، ولبشرين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤمن﴾</span></span>، ومثلنا صفة، <span class="hlt"><span class="qpc-hafs">﴿وقومهما﴾</span></span> الواو للحال، وقومهما مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عابدون﴾</span></span>، وعابدون خبر قومهما.</p></div>"
  23,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوهما فكانوا من المهلكين﴾</span></span>: الفاء عاطفة، وكذبوهما فعل وفاعل ومفعول به، فكانوا عطف على كذبوهما، وكان فعل ماض ناقص، وواو الجماعة اسمها، ومن المهلكين جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  23,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب لعلهم يهتدون﴾</span></span>: الواو استئنافية، وقد حرف تحقيق، وآتينا فعل وفاعل، وموسى مفعول به أول، والكتاب مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا...﴾</span></span> مستأنفة لا محل لها من الإعراب، ولعل حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يهتدون خبرها.</p></div>"
  23,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا ابن مريم وأمه آية﴾</span></span>: الواو عاطفة، وجعلنا فعل وفاعل، وابن مريم مفعول به أول، وأمه عطف على ابن مريم، وآية مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآويناهما إلى ربوة ذات قرار ومعين﴾</span></span>: الواو عاطفة، وآويناهما عطف على جعلنا، وإلى ربوة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آويناهما﴾</span></span>، وذات صفة لربوة، وقرار مضاف إليه، ومعين عطف على قرار.</p></div>"
  23,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الرسل كلوا من الطيبات﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، والرسل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وكلوا فعل أمر مبني على حذف النون، والواو فاعل، ومن الطيبات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واعملوا صالحا إني بما تعملون عليم﴾</span></span>: الواو عاطفة، واعملوا فعل وفاعل عطف على كلوا، وصالحا مفعول به، أو نائب عن المفعول مطلق، لأنه صفة المصدر، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span> إن حرف ناسخ، والياء اسمها وهي تعليل للأمر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span>، وجملة تعملون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وعليم خبر إن.</p></div>"
  23,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن هذه أمتكم أمة واحدة﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، وهذه اسمها، وأمتكم خبرها، وأمة حال لازمة، وواحدة صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا ربكم فاتقون﴾</span></span>: الواو عاطفة، وأنا مبتدأ، وربكم خبر، <span class="hlt"><span class="qpc-hafs">﴿فاتقون﴾</span></span> الفاء الفصيحة، واتقون فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء المحذوفة لرسم المصحف مفعول به.</p></div>"
  23,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتقطعوا أمرهم بينهم زبرا كل حزب بما لديهم فرحون﴾</span></span>: الفاء استئنافية، وتقطعوا فعل ماض، والواو فاعل، وأمرهم منصوب على إسقاط الخافض، أي: تفرقوا في أمرهم، أو مفعول به، وبينهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقطعوا﴾</span></span>، وزبرًا حال من فاعل تقطعوا، أي: أحزابًا متخالفين، وجملة <span class="hlt"><span class="qpc-hafs">﴿فتقطعوا أمرهم...﴾</span></span> مستأنفة لا محل لها من الإعراب، وكل مبتدأ، وحزب مضاف إليه، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فرحون﴾</span></span>، ولديهم ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وفرحون خبر كل حزب.</p></div>"
  23,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذرهم في غمرتهم حتى حين﴾</span></span>: الفاء الفصيحة، وذرهم فعل أمر، وفاعل مستتر تقديره: أنت، والهاء مفعول به، وفي غمرتهم جار ومجرور متعلقان بمحذوف حال، أي: متخبطين في غمرتهم، وحتى حرف غاية وجر، وحين مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرهم﴾</span></span>.</p></div>"
  23,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أيحسبون أنما نمدهم به من مال وبنين﴾</span></span>: الهمزة للاستفهام، ويحسبون فعل وفاعل، وأن وما اسمها، وأن وما بعدها سدت مسد مفعولي يحسبون، وجملة نمدهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمدهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من مال وبنين﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الموصول.</p></div>"
  23,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نسارع لهم في الخيرات بل لا يشعرون﴾</span></span>: الجملة خبر أن، ونسارع فعل مضارع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسارع﴾</span></span>، وفي الخيرات جار ومجرور متعلقان بمحذوف حال، وبل حرف إضراب، ولا نافية، ويشعرون فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿بل لا يشعرون﴾</span></span> استئنافية لا محل لها من الإعراب.</p></div>"
  23,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين هم من خشية ربهم مشفقون﴾</span></span>: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومن خشية ربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشفقون﴾</span></span>، ومشفقون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وربهم مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم من خشية ربهم مشفقون﴾</span></span> صلة الذين لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الذين هم...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  23,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم بآيات ربهم يؤمنون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿إن الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وبآيات ربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وجملة يؤمنون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم بآيات ربهم يؤمنون﴾</span></span> صلة الذين لا محل لها من الإعراب.</p></div>"
  23,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين هم بربهم لا يشركون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿إن الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وبربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span>، وجملة يشركون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم بربهم لا يشركون﴾</span></span> صلة الذين لا محل لها من الإعراب.</p></div>"
  23,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة أنهم إلى ربهم راجعون﴾</span></span>: عطف على إن الذين، وجملة يؤتون صلة الذين لا محل لها من الإعراب، وما مفعول يؤتون، وجملة آتوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وقلوبهم﴾</span></span> الواو حالية، وقلوبهم مبتدأ، ووجلة خبره، و<span class="hlt"><span class="qpc-hafs">﴿أنهم﴾</span></span> أن وما بعدها نصب بنزع الخافض، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وإلى ربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راجعون﴾</span></span>، وراجعون خبر أنهم.</p></div>"
  23,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك يسارعون في الخيرات﴾</span></span>: الجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إن الذين هم من خشية ربهم﴾</span></span> وما عُطِفَ عليه، وأولئك مبتدأ، وجملة يسارعون خبر المبتدأ، وفي الخيرات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسارعون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لها سابقون﴾</span></span>: الواو عاطفة، والجملة معطوفة على سابقتها بمثابة تأكيد لها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سابقون﴾</span></span>، وسابقون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والضمير في <span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> يعود على الخيرات، أو على الجنة، ومفعول سابقون محذوف، أي: سابقون الناس لها، أو اللام للتعليل، أي: سابقون لأجلها.</p></div>"
  23,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا نكلف نفسا إلا وسعها﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، ولا نافية، ونكلف فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، ونفسًا مفعول نكلف الأول، وإلا أداة حصر، ووسعها مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولدينا كتاب ينطق بالحق﴾</span></span>: الواو عاطفة، ولدينا ظرف متعلق بمحذوف خبر مقدم، وكتاب مبتدأ مؤخر، وجملة ينطق صفة، وبالحق جار ومجرور متعلقان بمحذوف حال، أي: متلبسا بالحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يظلمون خبر.</p></div>"
  23,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل قلوبهم في غمرة من هذا﴾</span></span>: بل حرف إضراب، وقلوبهم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في غمرة﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿من هذا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿غمرة﴾</span></span>، أي: كائنة من هذا الذي وصف به المؤمنون.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولهم أعمال من دون ذلك هم لها عاملون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وأعمال مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من دون ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لأعمال، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> صفة ثانية لأعمال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاملون﴾</span></span>، وعاملون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، أي: مستمرون عليها.</p></div>"
  23,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب إذا هم يجأرون﴾</span></span>: حتى ابتدائية، وإذا ظرف لما يستقبل من الزمن خافض لشرطه منصوب بجوابه وهو <span class="hlt"><span class="qpc-hafs">﴿يجأرون﴾</span></span>، وجملة أخذنا في محل جر بإضافة الظرف إليها، ونا فاعل، ومترفيهم مفعول به، وبالعذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span>، وإذا الثانية حرف مفاجأة، والجملة بعدها جواب إذا الأولى لا محل لها من الإعراب.</p></div>"
  23,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا تجأروا اليوم إنكم منا لا تنصرون﴾</span></span>: لا ناهية، وتجأروا فعل مضارع مجزوم بلا، والواو فاعل، واليوم متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تجأروا﴾</span></span>، وإن حرف ناسخ، والكاف اسمها، وجملة إنكم تعليل للنهي، ومنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنصرون﴾</span></span>، ولا نافية، وجملة تنصرون خبر إن، والواو نائب فاعل.</p></div>"
  23,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد كانت آياتي تتلى عليكم فكنتم على أعقابكم تنكصون﴾</span></span>: قد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كانت آياتي﴾</span></span> كان فعل ماض ناقص، وتاء التأنيث، وآيات اسم كان، وجملة تتلى خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلى﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فكنتم﴾</span></span> الفاء عاطفة، وكان فعل ماض ناقص، والتاء اسمها، وعلى أعقابكم جار ومجرور متعلقان بمحذوف حال من فاعل تنكصون، وجملة تنكصون خبر كان.</p></div>"
  23,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span></span>: مستكبرين حال ثانية من فاعل تنكصون، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مستكبرين﴾</span></span>، أي: بسببه، وسامرًا حال ثالثة، وجملة تهجرون حال رابعة.</p></div>"
  23,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يدبروا القول﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، والهمزة للاستفهام، ولم حرف نفي وقلب وجزم، ويدبروا فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والقول مفعول به، والفاء عاطفة على محذوف دخلت عليه الهمزة، أي: أفعلوا ما فعلوا مما سبق ذكره فلم يدبروا القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم جاءهم ما لم يأت آباءهم الأولين﴾</span></span>: أم عاطفة بمعنى بل، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> فعل ومفعول به، وما موصولة فاعل، وجملة لم يأت آباءهم الأولين صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  23,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لم يعرفوا رسولهم فهم له منكرون﴾</span></span>: عطف على ما تقدم، ويعرفوا رسولهم فعل وفاعل ومفعول به، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منكرون﴾</span></span>، ومنكرون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  23,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون به جنة بل جاءهم بالحق وأكثرهم للحق كارهون﴾</span></span>: عطف على ما تقدم أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجنة مبتدأ مؤخر، وبل حرف عطف وإضرب، وجاءهم فعل ومفعول به وفاعل مستتر، وبالحق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، أو بمحذوف حال، أي: متلبسًا بالحق، والواو حالية، وأكثرهم مبتدأ، وللحق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كارهون﴾</span></span>، وكارهون خبر أكثرهم.</p></div>"
  23,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو اتبع الحق أهواءهم لفسدت السماوات والأرض ومن فيهن﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿اتبع الحق﴾</span></span> فعل وفاعل، وأهواءهم مفعول به، واللام واقعة في جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿فسدت السماوات﴾</span></span> فعل وفاعل، <span class="hlt"><span class="qpc-hafs">﴿والأرض﴾</span></span> معطوف على السماوات مرفوع بالضمة، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> عطف على السماوات، و<span class="hlt"><span class="qpc-hafs">﴿فيهن﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أتيناهم بذكرهم﴾</span></span>: بل حرف إضراب، وأتيناهم فعل وفاعل ومفعول به، وبذكرهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتيناهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم عن ذكرهم معرضون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عن ذكرهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿معرضون﴾</span></span>، ومعرضون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  23,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم تسألهم خرجا فخراج ربك خير﴾</span></span>: أم حرف عطف على <span class="hlt"><span class="qpc-hafs">﴿أم يقولون به جنة﴾</span></span>، وتسألهم فعل مضارع، والفاعل مستتر تقديره: أنت، ومفعول به أول، وخرجا مفعول به ثان، والفاء تعليلية، أو فصيحة، وخراج مبتدأ، وربك مضاف إليه، وخير خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو خير الرازقين﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير خبر، و<span class="hlt"><span class="qpc-hafs">﴿الرازقين﴾</span></span> مضاف إليه.</p></div>"
  23,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنك لتدعوهم إلى صراط مستقيم﴾</span></span>: الواو حرف عطف، وإن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وتدعوهم فعل مضارع وفاعل مستتر ومفعول به، وإلى صراط جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدعوهم﴾</span></span>، ومستقيم صفة.</p></div>"
  23,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن الذين لا يؤمنون بالآخرة عن الصراط لناكبون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة لا يؤمنون صلة الذين لا محل لها من الإعراب، وبالآخرة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وعن الصراط جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناكبون﴾</span></span>، واللام المزحلقة، وناكبون خبر إن.</p></div>"
  23,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو رحمناهم وكشفنا ما بهم من ضر للجوا في طغيانهم يعمهون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿رحمناهم﴾</span></span> فعل وفاعل ومفعول به، وكشفنا عطف على رحمناهم، وما مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، ومن ضر جار ومجرور متعلقان بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿لَلَجوا﴾</span></span> اللام رابطة لجواب لو، وجملة لجوا لا محل لها من الإعراب لأنها جواب شرط غير جازم، وفي طغيانهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعمهون﴾</span></span>، وجملة يعمهون حالية.</p></div>"
  23,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أخذناهم بالعذاب فما استكانوا لربهم وما يتضرعون﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأخذناهم فعل وفاعل ومفعول به، وبالعذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذناهم﴾</span></span>، فما استكانوا عطف على أخذناهم، وما نافية، واستكانوا فعل وفاعل، ولربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكانوا﴾</span></span>، والواو حرف عطف، وما نافية، ويتضرعون فعل مضارع وفاعل.</p></div>"
  23,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا فتحنا عليهم بابا ذا عذاب شديد إذا هم فيه مبلسون﴾</span></span>: حتى حرف للابتداء، وإذا شرطية ظرفية متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿مبلسون﴾</span></span>، وجملة فتحنا في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فتحنا﴾</span></span>، وبابًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ذا عذاب﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بابًا﴾</span></span>، وإذا الثانية حرف مفاجأة قائمة مقام فاء الجزاء في الربط، والجملة بعدها جواب إذا الأولى، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مبلسون﴾</span></span>، ومبلسون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  23,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي أنشأ لكم السمع والأبصار والأفئدة﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع خبر، وجملة أنشأ صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأ﴾</span></span>، والسمع مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الأبصار والأفئدة﴾</span></span> عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تشكرون شكرا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تشكرون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قليلا ما تشكرون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  23,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي ذرأكم في الأرض وإليه تحشرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿ذرأكم﴾</span></span> فعل ماض وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذرأكم﴾</span></span> صلة الذي لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرأ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحشرون﴾</span></span>، وتحشرون فعل مضارع وفاعل وجملة و<span class="hlt"><span class="qpc-hafs">﴿إليه تحشرون﴾</span></span> معطوفة على ذرأكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي ذرأكم﴾</span></span> معطوفة على الجملة المستأنفة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي أنشأ لكم السمع...﴾</span></span> لا محل لها من الإعراب.</p></div>"
  23,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي يحيي ويميت وله اختلاف الليل والنهار﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span> صلة الذي لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿يميت﴾</span></span> معطوفة على جملة الصلة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span> فلا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، واختلاف مبتدأ مؤخر، والليل مضاف إليه، والنهار معطوف مجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿له اختلاف الليل والنهار﴾</span></span> معطوفة على جملة الصلة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span> فلا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي يحيي...﴾</span></span> معطوفة على الجملة المستأنفة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي أنشأ لكم السمع...﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تعقلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span>: الهمزة: للاستفهام، والفاء: عاطفة على مستأنف مقدر، أي: ألا تتفكرون فلا تعقلون، أو أتتفكرون فلا تعقلون، ولا: نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> فعل مضارع وواو الجماعة فاعل.</p></div>"
  23,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل قالوا مثل ما قال الأولون﴾</span></span>: بل حرف إضراب، وقالوا فعل وفاعل، ومثل صفة لمصدر محذوف، أي: قولًا مثل قول الأولين، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، والأولون فاعل.</p></div>"
  23,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أئذا متنا وكنا ترابا وعظاما أئنا لمبعوثون﴾</span></span>: الجملة بدل من الجملة قبلها، أي: مستأنفة لا محل لها من الإعراب، والهمزة للاستفهام، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة متنا في محل جر بإضافة إذا إليها، وكنا عطف على متنا، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وترابا خبرها، وعظاما عطف على <span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span>، والهمزة للاستفهام أيضا، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومبعوثون خبرها.</p></div>"
  23,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد وعدنا نحن وآباؤنا هذا من قبل﴾</span></span>: اللام جواب للقسم المحذوف، ووعد فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، ونحن تأكيد للضمير، وآباؤنا معطوف على الضمير المتصل، وهذا في محل نصب مفعول به ثان، ومن قبل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وعدنا﴾</span></span>، أو بمحذوف صفة لقوله: <span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> أي: الكائنون من قبل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا إلا أساطير الأولين﴾</span></span>: إن نافية، وهذا مبتدأ، وإلا أداة حصر، وأساطير الأولين خبر هذا.</p></div>"
  23,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لمن الأرض ومن فيها﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، والجملة استئنافية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> اللام حرف جر، ومن استفهامية، والجار والمجرور متعلقان بمحذوف خبر مقدم، والأرض مبتدأ مؤخر، ومن موصولة عطف على الأرض، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span></span>: إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، وجملة تعلمون خبرها، وكنتم فعل الشرط، والجواب محذوف، أي: فأخبروني بخالقهما.</p></div>"
  23,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون لله قل أفلا تذكرون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف تقديره: هي، والجملة مقول القول، وقل فعل أمر، والهمزة للاستفهام، والفاء عاطفة على محذوف، ولا نافية، وتذكرون فعل مضارع.</p></div>"
  23,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من رب السماوات السبع ورب العرش العظيم﴾</span></span>: قل فعل أمر والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> خبره، والسماوات مضاف إليه، والسبع نعت للسماوات، و<span class="hlt"><span class="qpc-hafs">﴿رب العرش العظيم﴾</span></span> عطف عليه.</p></div>"
  23,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون لله قل أفلا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، والتقدير: قل: من له السماوات السبع؟ و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، والهمزة للاستفهام، والفاء عاطفة على محذوف، ولا نافية، وتتقون فعل مضارع.</p></div>"
  23,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من بيده ملكوت كل شيء﴾</span></span>: من اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بيده﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وملكوت مبتدأ مؤخر، وكل شيء مضاف إليه، والجملة خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو يجير ولا يجار عليه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجير﴾</span></span> في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجار﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يجير﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span></span>: إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، وجملة تعلمون خبرها، وكنتم فعل الشرط، والجواب محذوف، أي: إن كنتم تعلمون فأخبروني.</p></div>"
  23,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون لله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، والتقدير: قل من له ملكوت كل شيء؟ <span class="hlt"><span class="qpc-hafs">﴿قل فأنى تسحرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأنى﴾</span></span> الفاء الفصيحة، وأنى اسم استفهام بمعنى كيف في محل نصب على الحال، وتسحرون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة فأنى تسحرون في محل نصب مقول القول.</p></div>"
  23,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل أتيناهم بالحق وإنهم لكاذبون﴾</span></span>: بل حرف إضراب وعطف، وأتيناهم فعل وفاعل ومفعول به، وبالحق حال، والواو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، وكاذبون خبر إن.</p></div>"
  23,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما اتخذ الله من ولد وما كان معه من إله﴾</span></span>: ما نافية، واتخذ الله فعل وفاعل، ومن حرف جر صلة، وولد مجرور لفظًا منصوب محلًّا لأنه مفعول به، والواو عاطفة، وما نافية، وكان فعل ماض ناقص، ومعه ظرف مكان متعلق بمحذوف خبر مقدم، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مجرور لفظًا مرفوع محلًّا لأنه اسم كان.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق﴾</span></span>: إذًا حرف جواب وجزاء مهمل، واللام واقعة في جواب الشرط <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> المقدر، وذهب كل فعل وفاعل، وإله مضاف إليه، والجملة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذهب﴾</span></span>، وجملة خلق صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولعلا بعضهم على بعض﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، وجملة يصفون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مجرور، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>.</p></div>"
  23,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عالم الغيب والشهادة﴾</span></span>: عالم الغيب مجرور على البدلية من لفظ الجلالة، أو صفة له.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتعالى عما يشركون﴾</span></span>: الفاء عاطفة، وتعالى فعل والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، وجملة يشركون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  23,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل رب إما تريني ما يوعدون﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿إما﴾</span></span> ادغمت إن الشرطية بما الصلة، وتريني فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة وهو في محل جزم فعل الشرط، والنون للوقاية، والياء مفعول به، وما مفعول به ثان، وجملة يوعدون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: يوعدون به من العذاب.</p></div>"
  23,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب فلا تجعلني في القوم الظالمين﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، والفاء رابطة، ولا طلبية، وتجعلني فعل مضارع مجزوم بلا، والنون للوقاية، والياء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿في القوم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان، والظالمين صفة، والجملة في محل جزم جواب الشرط مقترنة بالفاء.</p></div>"
  23,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا على أن نريك ما نعدهم لقادرون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على أن نريك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادرون﴾</span></span>، وأن حرف مصدري ونصب، ونري مضارع منصوب بأن، والفاعل مستتر تقديره: نحن، والكاف مفعول به أول، وما مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿نعدهم﴾</span></span> فعل وفاعل مستتر ومفعول به، والجملة صلة الموصول لا محل لها من الإعراب، واللام المزحلقة، وهي لام الابتداء، وقادرون خبر إن.</p></div>"
  23,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة نحن أعلم بما يصفون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وادفع فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿بالتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادفع﴾</span></span>، والتي نعت لمحذوف، أي: الخصلة، و<span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> مبتدأ وخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب. والسيئة مفعول به، ونحن مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبر جملة، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحن أعلم﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة يصفون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو ما مصدرية، أي: بوصفهم لك وسوء ذكرهم.</p></div>"
  23,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب أعوذ بك من همزات الشياطين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو عاطفة على ما تقدم، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وأعوذ فعل مضارع، والفاعل مستتر تقديره: أنا، وبك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من همزات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، والشياطين مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿رب أعوذ بك﴾</span></span> في محل نصب مقول القول.</p></div>"
  23,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأعوذ بك رب أن يحضرون﴾</span></span>: عطف على ما تقدم، وأعوذ فعل مضارع، وفاعل مستتر تقديره: أنا، وبك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وأن حرف مصدري ونصب، ويحضرون منصوب بأن وعلامة نصبه حذف النون، والنون للوقاية، والواو فاعل، وياء المتكلم المحذوفة في محل نصب مفعول به.</p></div>"
  23,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</span></span>: حتى حرف ابتداء، وإذا ظرف مستقبل متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> في محل جر مضاف إليه، وأحدهم مفعول به مقدم، والموت فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، ورب منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿ارجعون﴾</span></span> فعل دعاء مبني على حذف النون، وواو الجماعة فاعل، والنون للوقاية، والياء المحذوفة لرسم لمصحف مفعول به.</p></div>"
  23,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعلي أعمل صالحا فيما تركت﴾</span></span>: لعل حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعمل﴾</span></span> خبرها، وصالحا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أعمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. و<span class="hlt"><span class="qpc-hafs">﴿فيما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صالحا﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعمل﴾</span></span>، وجملة تركت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كلا إنها كلمة هو قائلها﴾</span></span>: كلا حرف ردع وزجر، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وقائلها خبر، والجملة الاسمية صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿من ورائهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وبرزخ مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لبرزخ، وجملة يبعثون في محل جر مضاف إليه.</p></div>"
  23,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا نفخ في الصور فلا أنساب بينهم يومئذ ولا يتساءلون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف زمان للمستقبل، وجملة نفخ في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، والفاء رابطة لجواب إذا، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿أنساب﴾</span></span> اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بمحذوف خبر لا، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بالخبر المحذوف الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، والتقدير: يوم إذ ينفخ في الصور. <span class="hlt"><span class="qpc-hafs">﴿ولا يتساءلون﴾</span></span> عطف على ما سبق، ويتساءلون فعل مضارع وفاعل.</p></div>"
  23,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن ثقلت موازينه﴾</span></span>: الفاء للتفريع، والجملة معطوفة، أو مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> الشرطية مبتدأ، وثقلت فعل الشرط، وموازينه فاعل، والجملة في محل رفع خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك هم المفلحون﴾</span></span>: الفاء رابطة للجواب، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، والمفلحون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر أولئك، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، والمفلحون خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك ...﴾</span></span> في محل جزم جواب الشرط.</p></div>"
  23,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن خفت موازينه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> شرطية مبتدأ، وخفت فعل الشرط، وموازينه فاعل، والجملة في محل رفع خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك الذين خسروا أنفسهم في جهنم خالدون﴾</span></span>: الفاء رابطة للجواب، وأولئك مبتدأ، والذين خبر، و<span class="hlt"><span class="qpc-hafs">﴿خسروا أنفسهم﴾</span></span> فعل وفاعل ومفعول به، وجملة خسروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في جهنم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر لمبتدأ محذوف، أو خبر بعد خبر لأولئك.</p></div>"
  23,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلفح وجوههم النار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿تلفح﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿وجوههم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿النار﴾</span></span> فاعل، والجملة في محل نصب حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم فيها كالحون﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كالحون﴾</span></span>، أو بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وكالحون خبر.</p></div>"
  23,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تكن آياتي تتلى عليكم﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، وتكن فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وآياتي اسمها، وجملة تتلى خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكنتم بها تكذبون﴾</span></span>: الفاء عاطفة، وكان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span>، وجملة تكذبون خبر كنتم.</p></div>"
  23,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا غلبت علينا شقوتنا﴾</span></span>: قالوا فعل ماض مبني على الضم لاتصاله بالواو، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف، وغلبت فعل ماض، والتاء للتانيث، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غلبت﴾</span></span>، وشقوتنا فاعل غلبت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكنا قوما ضالين﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿ضالين﴾</span></span> صفة.</p></div>"
  23,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربنا أخرجنا منها فإن عدنا فإنا ظالمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> منادى مضاف، وأخرجنا فعل دعاء، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرج﴾</span></span>، والفاء عاطفة، وإن شرطية، وعدنا فعل ماض في محل جزم فعل الشرط، والضمير فاعل، والفاء رابطة لجواب الشرط لأنه جملة اسمية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وظالمون خبرها، والجملة في محل جزم جواب الشرط.</p></div>"
  23,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال اخسئوا فيها﴾</span></span>: جملة اخسئوا مقول القول، واخسئوا فعل أمر، والواو فاعل، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخسئوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تكلمون﴾</span></span>: الواو عاطفة، ولا ناهية، وتكلمون فعل مضارع مجزوم بلا، والنون للوقاية، والياء المحذوفة مفعول به.</p></div>"
  23,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان فريق من عبادي يقولون ربنا آمنا﴾</span></span>: جملة تعليلية، وإن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، وفريق اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿من عبادي﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لفريق، وجملة يقولون خبر كان، وربنا منادى مضاف، وجملة آمنا مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاغفر لنا وارحمنا﴾</span></span>: الفاء عاطفة، واغفر فعل دعاء، وارحمنا عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنت خير الراحمين﴾</span></span>: الواو استئنافية. وأنت مبتدأ، وخير خبر، والراحمين مضاف إليه، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  23,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتخذتموهم سخريا﴾</span></span>: الفاء عاطفة، واتخذتموهم فعل وفاعل ومفعول به أول، والميم علامة جمع الذكور، والواو لإشباع ضمة الميم، وسخريًّا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿حتى أنسوكم ذكري وكنتم منهم تضحكون﴾</span></span>: حتى حرف غاية وجر، وأنسوكم فعل ماض وفاعل ومفعول به أول، وذكري مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، ومنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تضحكون﴾</span></span>، وجملة تضحكون خبر كان.</p></div>"
  23,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني جزيتهم اليوم بما صبروا أنهم هم الفائزون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والياء اسمها، وجملة جزيتهم خبر إن، وجزيتهم فعل ماض وفاعل ومفعول به أول، واليوم ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿جزيتهم﴾</span></span>، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جزيتهم﴾</span></span>، والباء للسببية، أي: بسبب صبرهم، وما مصدرية، وأن وما بعدها في تأويل مصدر مفعول ثان لجزيتهم، أي: جزيتهم فوزهم، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وهم ضمير فصل، والفائزون خبر أن.</p></div>"
  23,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كم لبثتم في الأرض عدد سنين﴾</span></span>: كم استفهامية في محل نصب على الظرفية الزمانية وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، وعدد تمييز كم، وسنين مضاف إليه، وجملة كم لبثتم في محل نصب مقول القول.</p></div>"
  23,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لبثنا يوما أو بعض يوم﴾</span></span>: جملة لبثنا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿يومًا﴾</span></span> ظرف جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، وأو حرف عطف، وبعض يوم معطوف على <span class="hlt"><span class="qpc-hafs">﴿يومًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاسأل العادين﴾</span></span>: الفاء الفصيحة، واسأل فعل دعاء، وفاعل مستتر تقديره: أنت، والعادين مفعول به.</p></div>"
  23,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن لبثتم إلا قليلا لو أنكم كنتم تعلمون﴾</span></span>: قال فعل ماض، وفاعله مستتر يعود على الله سبحانه، وإن نافية، ولبثتم فعل وفاعل، وإلا أداة حصر، وقليلا صفة لظرف محذوف، أي: زمنا قليلا، أو قليلا صفة لمصدر محذوف، أي: لبثا قليلا، ولو حرف امتناع لامتناع. <span class="hlt"><span class="qpc-hafs">﴿أنكم﴾</span></span> أن حرف ناسخ، والكاف اسمها، وجملة كنتم خبرها، وجملة تعلمون خبر كنتم، ومفعول تعلمون محذوف، أي: مقدار لبثتكم.</p></div>"
  23,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفحسبتم أنما خلقناكم عبثا﴾</span></span>: الهمزة للاستفهام، والجملة مستأنفة لا محل لها من الإعراب، وحسبتم فعل وفاعل، وأنما كافة ومكفوفة وهي وما بعدها في تأويل مصدر سد مسد مفعولي حسبتم، وخلقناكم فعل وفاعل ومفعول به، وعبثا منصوب على أنه مصدر واقع موقع الحال، أي: عابثين، أو على المصدرية، أو مفعول لأجله، أي: لأجل العبث.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنكم إلينا لا ترجعون﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، والكاف اسمها، وإلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، ولا نافية، وترجعون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة ترجعون خبر أن.</p></div>"
  23,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتعالى الله الملك الحق﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وتعالى فعل ماض، ولفظ الجلالة فاعل، والملك الحق صفتان له.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿رب العرش الكريم﴾</span></span>: رب صفة ثالثة، والعرش مضاف إليه، والكريم نعت للعرش.</p></div>"
  23,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يدع مع الله إلها آخر﴾</span></span>: الواو استئنافية، ومن شرطية مبتدأ، ويدع فعل الشرط مجزوم بحذف حرف العلة، ومع ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يدع﴾</span></span>، ولفظ الجلالة مضاف إليه، وإلهًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يدع﴾</span></span>، وآخر صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا برهان له به﴾</span></span>: لا نافية للجنس، وبرهان اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر لا، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا برهان...﴾</span></span> في محل نصب صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span> وهي صفة لازمة، وجيء بها للتوكيد. أو اعتراضية بين فعل الشرط وجوابه، فلا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنما حسابه عند ربه﴾</span></span>: الفاء رابطة لجزاء الشرط لأن الجملة اسمية، وإنما كافة ومكفوفة، وحسابه مبتدأ، وعند الظرف متعلق بمحذوف خبر حسابه، وربه مضاف إليه، والجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يدع مع الله...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا يفلح الكافرون﴾</span></span>: الجملة تعليلية لا محل لها من الإعراب، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح﴾</span></span> خبر إنه، والكافرون فاعل.</p></div>"
  23,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب اغفر وارحم﴾</span></span>: الواو استئنافية، وقل فعل أمر، والفاعل مستتر، ورب منادى لياء المتكلم المحذوفة، واغفر فعل دعاء، وارحم عطف عليه، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنت خير الراحمين﴾</span></span>: الواو استئنافية، وأنت مبتدأ، وخير خبر وهو مضاف، و<span class="hlt"><span class="qpc-hafs">﴿الراحمين﴾</span></span> مضاف إليه، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
