quran[93]{c,v,t}:
  27,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طس﴾</span></span>:‌ تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات القرآن وكتاب مبين﴾</span></span>: تلك: مبتدأ، وآيات القرآن: خبر، وكتاب: عطف على القرآن، ومبين: صفة لكتاب.</p></div>"
  27,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هدى وبشرى للمؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هدى﴾</span></span> منصوبة على الحال، والعامل فيها اسم الإشارة، أي: هادية ومبشرة، أو مرفوعة على أنها خبر لمبتدأ محذوف، أي: هي هدى وبشرى، و<span class="hlt"><span class="qpc-hafs">﴿للمؤمنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هدى وبشرى﴾</span></span>.</p></div>"
  27,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين يقيمون الصلاة ويؤتون الزكاة وهم بالآخرة هم يوقنون﴾</span></span>: الذين نعت للمؤمنين، أو خبر لمبتدأ محذوف، أي: هم الذين، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقيمون الصلاة﴾</span></span> صلة الذين لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤتون الزكاة﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يقيمون الصلاة﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو للحال، أو للعطف، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بالآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوقنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، ويوقنون فعل مضارع مرفوع، والواو فاعل، وجملة يوقنون خبر المبتدأ.</p></div>"
  27,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين لا يؤمنون بالآخرة زينا لهم أعمالهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، ولا نافية، ويؤمنون فعل مضارع مرفوع، والواو فاعل، وجملة لا يؤمنون صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بالآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وزين فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أعمالهم﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم يعمهون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يعمهون خبره.</p></div>"
  27,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك الذين لهم سوء العذاب﴾</span></span>: أولئك مبتدأ، والذين خبره، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وسوء العذاب مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم سوء العذاب﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم في الآخرة هم الأخسرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الأخسرون﴾</span></span>، والأخسرون خبره، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، والأخسرون خبر.</p></div>"
  27,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنك لتلقى القرآن من لدن حكيم عليم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، والكاف اسمها، واللام المزحلقة، <span class="hlt"><span class="qpc-hafs">﴿تلقى﴾</span></span> فعل مضارع مبني لما لم يسم فاعله، ونائب الفاعل مستتر، تقديره: أنت، وجملة تلقى خبرها، والقرآن مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من لدن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تلقى﴾</span></span>، وحكيم مضاف إليه، وعليم صفة.</p></div>"
  27,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال موسى لأهله إني آنست نارا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف والتقدير: اذكر إذ قال موسى، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، وموسى فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿لأهله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إني آنست نارًا﴾</span></span> إن حرف ناسخ، والياء اسمها، وآنست فعل ماض، والتاء فاعل، ونارا مفعول به، وجملة آنست خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني آنست نارًا﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿سآتيكم منها بخبر أو آتيكم بشهاب قبس لعلكم تصطلون﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب، وآتيكم فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بخبر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتيكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وآتيكم عطف على آتيكم الأولى، و<span class="hlt"><span class="qpc-hafs">﴿بشهاب﴾</span></span> جار ومجرور متعلقان بآتيكم، وقبس بدل من شهاب، أو نعت له على تأويله بالمفعول، أي: شهاب مقتبس من نار، و<span class="hlt"><span class="qpc-hafs">﴿لعلكم تصطلون﴾</span></span> لعل حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تصطلون﴾</span></span> خبر لعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لعلكم تصطلون﴾</span></span> حالية، أي: راجيًا تأمين الدفء لكم وتوفيره.</p></div>"
  27,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءها نودي أن بورك من في النار ومن حولها﴾</span></span>: الفاء عاطفة على محذوف للاختصار، ولما ظرفية حينية، أو رابطة، وجاءها فعل ماض، وفاعل مستتر، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿نودي﴾</span></span> فعل ماض مبني لما لم يسم فاعله، وجملة <span class="hlt"><span class="qpc-hafs">﴿نودي﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ونائب فاعل <span class="hlt"><span class="qpc-hafs">﴿نودي﴾</span></span> ضمير مستتر تقديره هو، يعود على موسى. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لما في النداء من معنى القول، و<span class="hlt"><span class="qpc-hafs">﴿بورك﴾</span></span> فعل ماض مبني لما لم يُسَمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> نائب فاعل. و<span class="hlt"><span class="qpc-hafs">﴿في النار﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من حولها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من في النار﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿بورك﴾</span></span> تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية دخلت على الماضي، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن بورك﴾</span></span> منصوب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿بورك﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبحان الله رب العالمين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وسبحان: نائب مفعول مطلق منصوب بفعل محذوف، ولفظ الجلالة مضاف إليه، ورب العالمين بدل، أو نعت.</p></div>"
  27,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا موسى إنه أنا الله العزيز الحكيم﴾</span></span>: يا حرف نداء، وموسى منادى مفرد علم، و<span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وأنا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبر، والجملة خبر إن، والعزيز الحكيم صفتان.</p></div>"
  27,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وألق عصاك فلما رآها تهتز كأنها جان ولى مدبرا ولم يعقب﴾</span></span>: الواو حرف عطف، وألق فعل أمر مبني على حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، والكلام معطوف على <span class="hlt"><span class="qpc-hafs">﴿بورك﴾</span></span>، وعصاك مفعول، <span class="hlt"><span class="qpc-hafs">﴿فلما﴾</span></span> الفاء عاطفة على محذوف، أي: فألقاها فاستحالت حية فلما، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> ظرف بمعنى: حين، أو رابطة، ورآها فعل ماض، وفاعل مستتر، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رآها﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة تهتز في محل نصب على الحال، لأن الرؤية هنا بصرية، و<span class="hlt"><span class="qpc-hafs">﴿كأنها جان﴾</span></span> كأن حرف ناسخ، والهاء اسمها، وجان خبرها، والجملة في محل نصب حال ثانية، أو هي حال من ضمير تهتز، و<span class="hlt"><span class="qpc-hafs">﴿ولى﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولى﴾</span></span> لا محل لها من الإعراب، ومدبرًا حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿ولى﴾</span></span>، والواو حرف عطف، ولم حرف نفي وقلب وجزم، ويعقب فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا موسى لا تخف إني لا يخاف لدي المرسلون﴾</span></span>: الجملة مقول لقول محذوف لا بد من تقديره، أي: قال تعالى، ويا أداة نداء، و<span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span> منادى مفرد علم، ولا ناهية، وتخف فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة لا يخاف خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني لا يخاف...﴾</span></span> تعليلية للنهي عن الخوف، و<span class="hlt"><span class="qpc-hafs">﴿لدي﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يخاف﴾</span></span>، والمرسلون فاعل.</p></div>"
  27,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من ظلم ثم بدل حسنا بعد سوء﴾</span></span>: إلا أداة استثناء بمعنى: لكن، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مستثنى في موضع نصب، أو اسم شرط مبتدأ، والجملة مستثناة من أعم الأحوال، وظلم فعل ماض في محل جزم فعل الشرط، <span class="hlt"><span class="qpc-hafs">﴿ثم بدل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ظلم﴾</span></span>، وحسنًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعد سوء﴾</span></span> ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حسنًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإني غفور رحيم﴾</span></span>: الفاء واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: إن حرف ناسخ، والياء اسمها، وغفور رحيم خبراها.</p></div>"
  27,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأدخل يدك في جيبك تخرج بيضاء من غير سوء﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أدخل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وألق عصاك﴾</span></span>، ويدك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في جيبك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدخل﴾</span></span>، وتخرج فعل مضارع مجزوم، لأنه جواب الأمر، وفاعل تخرج ضمير مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿بيضاء﴾</span></span> حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من غير سوء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بيضاء﴾</span></span>، وقيل: حال  أخرى، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بيضاء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿في تسع آيات إلى فرعون وقومه﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في تسع آيات﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو بفعل محذوف أي: اذهب، و<span class="hlt"><span class="qpc-hafs">﴿إلى فرعون﴾</span></span> جار ومجرور متعلقان بالمحذوف المقدر: اذهب، أو بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿تسع﴾</span></span> أو لـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>، وقومه عطف على فرعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا قوما فاسقين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> خبر إن، وقومًا خبر كانوا، وفاسقين صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span> تعليل للأمر بالذهاب.</p></div>"
  27,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءتهم آياتنا مبصرة قالوا هذا سحر مبين﴾</span></span>: الفاء عاطفة على محذوف، و<span class="hlt"><span class="qpc-hafs">﴿جاءتهم﴾</span></span> فعل ماض، والهاء مفعول به، وآياتنا فاعل، ومبصرة حال، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، وسحر خبر، ومبين صفة، والجملة مقول القول.</p></div>"
  27,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجحدوا بها واستيقنتها أنفسهم ظلما وعلوا﴾</span></span>: جحدوا عطف على قالوا و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بجحدوا، والواو للحال، وبعدها <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> مضمرة، واستيقنتها أنفسهم فعل ماض، ومفعول به مقدم، وفاعل مؤخر، وظلمًا مفعول لأجله، أو حال من فاعل جحدوا، أي: ظالمين مستكبرين.</p><p><span class="hlt"><span class="qpc-hafs">﴿فانظر كيف كان عاقبة المفسدين﴾</span></span>: الفاء الفصيحة، وانظر فعل أمر، وفاعله مستتر تقديره: أنت، وكيف اسم استفهام في محل نصب خبر مقدم لكان، وعاقبة المفسدين اسم كان، والجملة معلقة لانظر عن العمل، فهي في محل نصب بنزع الخافض، لأن انظر بمعنى: تفكر.</p></div>"
  27,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا داود وسليمان علما﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وآتينا فعل، وفاعل، وداود مفعول به، وسليمان عطف على داود، وعلمًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</span></span>: الواو حرف عطف، وقالا معطوف على مقدر، والحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول، والذي اسم موصول صفة لله، وجملة فضلنا صلة الموصول لا محل لها من الإعراب. وعلى كثير جار ومجرور متعلقان بفضلنا، ومن عباده صفة لكثير، والمؤمنين صفة لعباده.</p></div>"
  27,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وورث سليمان داود وقال يا أيها الناس علمنا منطق الطير﴾</span></span>: الواو ضية، وورث سليمان داود فعل، وفاعل، ومفعول به، وقال عطف على ورث، و<span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس﴾</span></span>  يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وعلمنا فعل ماض مبني لما لم يسمَّ فاعله، ونا نائب فاعل، ومنطق الطير مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأوتينا من كل شيء إن هذا لهو الفضل المبين﴾</span></span>: الواو عاطفة، وأوتينا عطف على علمنا، ومن كل شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتينا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿إن هذا﴾</span></span>: إن حرف ناسخ، وهذا اسمها، وهو كلام مستأنف لا محل له من الإعراب، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، أو مبتدأ، والفضل خبر إن، أو خبر هو، والجملة خبر إن، والمبين صفة للفضل.</p></div>"
  27,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحشر لسليمان جنوده من الجن والإنس والطير فهم يوزعون﴾</span></span>: الواو استئنافية، وحشر فعل ماض مبني لما لم يسمَّ فاعله، ولسليمان جار ومجرور متعلقان بحشر، وجنوده نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وحشر لسليمان...﴾</span></span> مستأنفة لا محل لها من الإعراب، ومن الجن والإنس والطير حال من جنوده، والفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يوزعون خبر.</p></div>"
  27,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا أتوا على واد النمل قالت نملة يا أيها النمل ادخلوا مساكنكم﴾</span></span>: حتى حرف غاية لمحذوف، تقديره: فساروا حتى إذا أتوا، أو غاية ليوزعون، وعلى وادي النمل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتوا﴾</span></span>، وجملة قالت نملة لا محل لها من الإعراب، ويا أيها النمل  يا حرف نداء، وأي منادى نكرة مقصودة، مبني على الضم في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والنمل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وادخلوا مساكنكم فعل، وفاعل، ومفعول به على السعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا يحطمنكم سليمان وجنوده وهم لا يشعرون﴾</span></span>: نهي مستأنف لا تعلق له بما قبله، أي: لا تكونوا بحيث يحطمونكم، أو بدل من جملة الأمر <span class="hlt"><span class="qpc-hafs">﴿ادخلوا مساكنكم﴾</span></span>، ولا ناهية، ويحطمنكم فعل مضارع مبني على الفتح في محل جزم بلا، والكاف مفعول به، وسليمان فاعل، وجنوده عطف على سليمان، وهم الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون خبر، والجملة حالية.</p></div>"
  27,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتبسم ضاحكا من قولها﴾</span></span>: الفاء عاطفة على محذوف يقتضيه السياق، أي: فسمع قولها المذكور، فتبسم، وضاحكًا حال مؤكدة، ومن قولها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضاحكًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال رب أوزعني أن أشكر نعمتك التي أنعمت علي وعلى والدي﴾</span></span>: الواو عاطفة. وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: عطف على فتبسم. ورب: منادى مضاف إلى ياء المتكلم المحذوفة، وحرف النداء محذوف. وأوزعني: فعل دعاء، وفاعل مستتر، ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وأن وما في حيزها مفعول ثان لأوزعني، لأنه متضمن معنى الإلهام، أو نصب بنزع الخافض، أي: بأن اشكر نعمتك. و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span>: اسم موصول في محل نصب صفة لنعمتك. وجملة أنعمت صلة الموصول لا محل لها من الإعراب. وعلي جار ومجرور متعلقان بأنعمت، وعلى والدي عطف على علي.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأدخلني برحمتك في عبادك الصالحين﴾</span></span>: الواو حرف عطف، وأدخلني فعل دعاء، وفاعل، ومفعول به، وبرحمتك جار ومجرور متعلقان بمحذوف حال، والباء للسببية، وفي عبادك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدخلني﴾</span></span>،   الصالحين نعت لعبادك.</p></div>"
  27,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتفقد الطير فقال ما لي لا أرى الهدهد أم كان من الغائبين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿تفقد﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، أي: سليمان، والطير مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تفقد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا أرى الهدهد﴾</span></span> حال، وأم: منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أكان ...، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، واسمها ضمير مستتر يعود على الهدهد، و<span class="hlt"><span class="qpc-hafs">﴿من الغائبين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  27,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأعذبنه عذابا شديدا أو لأذبحنه أو ليأتيني بسلطان مبين﴾</span></span>: اللام واقعة في جواب قسم مقدر، وأعذبنه فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل ضمير مستتر تقديره: أنا، والهاء مفعول به، وعذابا نائب عن المفعول المطلق، لأنه اسم مصدر، وشديدًا صفة، أو لأذبحنه عطف على لأعذبنه، أو ليأتيني عطف عليه أيضًا، وبسلطان جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيني﴾</span></span>، ومبين صفة.</p></div>"
  27,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمكث غير بعيد فقال أحطت بما لم تحط به وجئتك من سبأ بنبأ يقين﴾</span></span>: الفاء استئنافية، ومكث فعل ماض، وفاعل مستتر، يعود على الهدهد، أو على سليمان، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمكث﴾</span></span> مستأنفة لا محل لها من الإعراب، وغير بعيد ظرف زمان متعلق بمكث، أو صفة لظرف محذوف نابت عنه، أي: وقتًا غير بعيد، أو مكانًا غير بعيد، فهو ظرف مكان، فقال عطف على مكث، وجملة أحطت مقول القول، وبما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحطت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تحط﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحط﴾</span></span>، وجئتك عطف على أحطت، ومن سبأ: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لنبأ، وبنبأ جار ومجرور متعلقان بجئتك، ويقين صفة لنبأ.</p></div>"
  27,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني وجدت امرأة تملكهم وأوتيت من كل شيء ولها عرش عظيم﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة وجدت امرأة خبر إن، وجملة تملكهم صفة لامرأة، وأوتيت الواو عاطفة، أو حالية، وجملة أوتيت معطوفة على جملة تملكهم، أو حالية من فاعل تملكهم، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> مقدرة، ومن كل شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتيت﴾</span></span>، أو بمحذوف هو مفعول أوتيت الثاني، والتقدير: أيضًا من كل شيء، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> خبر مقدم، وعرش مبتدأ مؤخر، وعظيم صفة.</p></div>"
  27,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجدتها وقومها يسجدون للشمس من دون الله﴾</span></span>: جملة وجدتها بدل من وجدت امرأة، فهي داخلة في حيز الخبر، والهاء مفعول به، وقومها عطف على الهاء، أو مفعول معه، وجملة يسجدون حال من مفعولها وما عطف عليه، وللشمس جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسجدون﴾</span></span>، ومن دون الله حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم فصدهم عن السبيل فهم لا يهتدون﴾</span></span>: الواو حرف عطف، وزين فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان به، والشيطان فاعله، وأعمالهم مفعوله، فصدهم عطف على زين، وعن السبيل جار ومجرور متعلقان بصدهم، فهم الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يهتدون خبر.</p></div>"
  27,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا يسجدوا لله الذي يخرج الخبء في السماوات والأرض﴾</span></span>: ألا: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف مصدري ونصب، ولا نافية أو صلة، والمصدر المؤول <span class="hlt"><span class="qpc-hafs">﴿ألا يسجدوا﴾</span></span> منصوب بنزع الخافض، والتقدير: <span class="hlt"><span class="qpc-hafs">﴿فهم لا يهتدون للسجود﴾</span></span>، أو يكون المصدر بدلًا من أعمالهم، والتقدير: <span class="hlt"><span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم عدم السجود﴾</span></span>، أو يكون المصدر بدلًا من السبيل. و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسجدوا﴾</span></span>، والذي: موصول نعت لله، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span> الخبء صلة الموصول لا محل لها من الإعراب. وفي السماوات والأرض جار ومجرور متعلقان بالخبء، أي المخبوء في السماوات، أو بـ<span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span>، على أن <span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> بمعنى: من، أي: يخرجه من السماوات والأرض.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويعلم ما تخفون وما تعلنون﴾</span></span>: الواو عاطفة، ويعلم عطف على يخرج، فهو داخل في حيز الصلة، وفاعل يعلم ضمير مستتر، يعود على الله، وما موصول مفعول به، وجملة تخفون صلة الموصول لا محل لها من الإعراب. وما تعلنون عطف على ما تخفون.</p></div>"
  27,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: مبتدأ، <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رب العرش العظيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>. والعرش مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> نعت.</p></div>"
  27,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال سننظر أصدقت أم كنت من الكاذبين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقال فعل ماض، وجملة سننظر مقول القول، والهمزة للاستفهام، وصدقت فعل وفاعل، وأم متصلة معادلة للهمزة، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  27,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهب بكتابي هذا فألقه إليهم ثم تول عنهم فانظر ماذا يرجعون﴾</span></span>: اذهب فعل أمر، وفاعله مستتر تقديره أنت، وبكتابي جار ومجرور متعلقان باذهب، وهذا نعت لكتابي، أو بدل منه، فألقه الفاء عاطفة، وألقه فعل أمر، وفاعل مستتر، ومفعول به، وإليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقه﴾</span></span>، ثم حرف عطف، وتول فعل أمر على حذف حرف العلة، والفاعل مستتر، تقديره: أنت، وعنهم جار ومجرور متعلقان بمحذوف حال، فانظر عطف على تول، ماذا اسم استفهام في محل نصب مفعول مقدم ليرجعون، أو ما اسم استفهام مبتدأ، وذا اسم موصول بمعنى الذي خبر ما، وجملة يرجعون صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت يا أيها الملأ إني ألقي إلي كتاب كريم﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة ألقي خبرها، وإلي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقي﴾</span></span>، وكتاب نائب فاعل، وكريم صفة.</p></div>"
  27,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، والهاء اسمها، ومن سليمان جار ومجرور متعلقان بمحذوف خبر إن، وإنه الواو عاطفة، وإن حرف ناسخ، والهاء اسمها، وجملة البسملة خبرها، وبسم جار ومجرور متعلقان بمحذوف، والباء للاستعانة أو للإلصاق، وتقدير المحذوف: أبتدئ، فالجار والمجرور في محل نصب مفعول به مقدم، أو ابتدائي، فالجار والمجرور متعلقان بمحذوف خبر لمبتدأ محذوف، ولفظ الجلالة مضاف إليه، والرحمن الرحيم صفتان لله.</p></div>"
  27,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا تعلوا علي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية. ولا ناهية. وتعلوا: فعل مضارع مجزوم بلا، والواو فاعل. وعلَيَّ: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعلوا﴾</span></span>. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية ناصبة للفعل، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية. والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها بدل من <span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>، أو خبر لمبتدأ محذوف، أي: مضمونه ألا تعلوا، أو منصوب بنزع الخافض، أي: بأن لا تعلوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأتوني مسلمين﴾</span></span>: الواو عاطفة. وائتوني: فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء مفعول به. ومسلمين: حال.</p></div>"
  27,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت يا أيها الملأ أفتوني في أمري﴾</span></span>: أفتوني فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء مفعول به، وفي أمري جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفتوني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كنت قاطعة أمرا حتى تشهدون﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنت قاطعة﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، وقاطعة خبرها، وأمرًا مفعول به، وحتى حرف غاية وجر، وتشهدون فعل مضارع منصوب بأن مضمرة بعد حتى، وعلامة نصبه حذف النون، والنون الموجودة نون الوقاية، وياء المتكلم المحذوفة مفعول به، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بقاطعة.</p></div>"
  27,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا نحن أولو قوة وأولو بأس شديد﴾</span></span>: قالوا فعل ماض والواو فاعل، ونحن مبتدأ، وأولو خبر مرفوع وعلامة رفعه الواو، لأنه ملحق بجمع المذكر السالم، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مقول القول، وقوة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أولو بأس شديد﴾</span></span> عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿والأمر إليك فانظري ماذا تأمرين﴾</span></span>: الواو حرف عطف، والأمر مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، <span class="hlt"><span class="qpc-hafs">﴿فانظري﴾</span></span> الفاء الفصيحة، وانظري فعل أمر، والياء فاعل، وماذا اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تأمرين﴾</span></span>، وتأمرين فعل مضارع مرفوع وعلامة رفعه ثبوت النون، وياء المخاطبة فاعل.</p></div>"
  27,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت إن الملوك إذا دخلوا قرية أفسدوها﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقالت فعل ماض، وإن حرف ناسخ، والملوك اسمها، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span> في محل جر بإضافة الظرف إليها، وقرية مفعول به على السعة، وجملة أفسدوها جواب شرط غير جازم لا محل لها من الإعراب، وجملة الشرط وجوابه خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعلوا أعزة أهلها أذلة﴾</span></span>: الواو عاطفة، وجعلوا فعل وفاعل، وأعزة أهلها مفعول جعلوا الأول، وأذلة مفعول جعلوا الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك يفعلون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تفعلون﴾</span></span>، أو نعت لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿يفعلون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل.</p></div>"
  27,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية فناظرة بم يرجع المرسلون﴾</span></span>: إن حرف ناسخ، والياء اسمها، ومرسلة خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بمرسلة، و<span class="hlt"><span class="qpc-hafs">﴿بهدية﴾</span></span> جار ومجرور متعلقان بمرسلة، <span class="hlt"><span class="qpc-hafs">﴿فناظرة﴾</span></span> عطف على مرسلة، و<span class="hlt"><span class="qpc-hafs">﴿بم﴾</span></span> الباء حرف جر، وما الاستفهامية المحذوف ألفها في محل جر بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يرجع المرسلون﴾</span></span> فعل وفاعل، والجملة مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿ناظرة﴾</span></span>.</p></div>"
  27,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء سليمان قال أتمدونن بمال﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرفية حينية، أو رابطة متضمنة معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿جاء سليمان﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، أي: الرسول، وسليمان مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، والهمزة للاستفهام، وتمدونن فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، والنون للوقاية، والياء المحذوفة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بمال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمدونن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما آتاني الله خير مما آتاكم﴾</span></span>: الفاء حرف تعليل لما تقدم من إنكاره عليهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبتدأ، وجملة آتاني صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿آتاني الله﴾</span></span> فعل ماض ومفعول به مقدم، ولفظ الجلالة فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أنتم بهديتكم تفرحون﴾</span></span>: بل حرف إضراب، وأنتم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بهديتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفرحون﴾</span></span>، وجملة تفرحون خبر.</p></div>"
  27,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ارجع إليهم فلنأتينهم بجنود لا قبل لهم بها﴾</span></span>: ارجع فعل أمر، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ارجع﴾</span></span>، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿نأتينهم﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بجنود﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نأتينهم﴾</span></span>، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> اسم لا مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span>، لتضمنه معنى المصدر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنخرجنهم منها أذلة وهم صاغرون﴾</span></span>: الواو عاطفة، ولنخرجنهم عطف على فلنأتينهم، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجنهم﴾</span></span>، والضمير يعود إلى سبأ، و<span class="hlt"><span class="qpc-hafs">﴿أذلة﴾</span></span> حال، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وصاغرون خبر، والجملة حال ثانية من الهاء في <span class="hlt"><span class="qpc-hafs">﴿لنخرجنهم﴾</span></span>.</p></div>"
  27,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا أيها الملأ أيكم يأتيني بعرشها قبل أن يأتوني مسلمين﴾</span></span>: قال فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿أيكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ويأتيني﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعرشها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيني﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتيني بعرشها﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن يأتوني﴾</span></span> أن مصدرية، ويأتوني فعل مضارع منصوب، والواو فاعل، والياء مفعول به، والمصدر المؤول من أن وما في حيزها مضاف إليه، ومسلمين حال.</p></div>"
  27,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال عفريت من الجن أنا آتيك به قبل أن تقوم من مقامك﴾</span></span>: قال فعل ماض، وعفريت فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من الجن﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، وأنا مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيك به﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتيك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من مقامك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقوم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإني عليه لقوي أمين﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قوي﴾</span></span>، واللام المزحلقة، وقوي خبر إن، وأمين خبر ثان.</p></div>"
  27,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال الذي عنده علم من الكتاب﴾</span></span>: قال فعل ماض، والذي فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عنده﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، وعلم مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من الكتاب﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عنده علم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنا آتيك به قبل أن يرتد إليك طرفك﴾</span></span>: أنا مبتدأ، وجملة آتيك به خبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتيك﴾</span></span>، وأن وما في حيزها في محل جر مضاف إليه، وطرفك فاعل يرتد.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما رآه مستقرا عنده قال هذا من فضل ربي﴾</span></span>: الفاء عاطفة على محذوف يقدر بحسب المقام، ولما ظرف بمعنى حين، أو رابطة، ورآه فعل ماض، والفاعل مستتر، والهاء مفعول به، ومستقرًّا حال، لأن الرؤية بصرية، و<span class="hlt"><span class="qpc-hafs">﴿عنده﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مستقرًّا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من فضل ربي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليبلوني أأشكر أم أكفر﴾</span></span>: اللام للتعليل، ويبلوني فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بالمصدر <span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، وفاعل يبلوني مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span>، والياء مفعول، و<span class="hlt"><span class="qpc-hafs">﴿أأشكر﴾</span></span> الهمزة للاستفهام، وأشكر فعل مضارع، وفاعله مستتر تقديره: أنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أأشكر﴾</span></span> بدل من الياء في <span class="hlt"><span class="qpc-hafs">﴿يبلوني﴾</span></span> فهو بمثابة المفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أم أكفر﴾</span></span> عطف على أأشكر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن شكر فإنما يشكر لنفسه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ومَن شرطية مبتدأ، وشكر فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وإن حرف ناسخ، وما مصدرية، وإن وما بعدها في تأويل مصدر اسم إن، أي: فإن ثواب شكره، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وفعل الشرط وجوابه خبر مَن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن كفر فإن ربي غني كريم﴾</span></span>: جملة معطوفة، ومَن شرطية مبتدأ، وكفر فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وإن حرف ناسخ، وربي اسمها، وغني كريم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وفعل الشرط وجوابه خبر مَن.</p></div>"
  27,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال نكروا لها عرشها ننظر أتهتدي أم تكون من الذين لا يهتدون﴾</span></span>: نكروا فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نكروا﴾</span></span>، وعرشها مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ننظر﴾</span></span> فعل مضارع مجزوم، لأنه جواب الأمر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتهتدي﴾</span></span> في محل نصب على المفعولية، وأم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص ناسخ معطوف على <span class="hlt"><span class="qpc-hafs">﴿أتهتدي﴾</span></span>، واسمها مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿من الذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهتدون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءت قيل أهكذا عرشك قالت كأنه هو﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرفية حينية، أو رابطة متضمنة معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هي، <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، <span class="hlt"><span class="qpc-hafs">﴿أهكذا﴾</span></span> الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، وعرشك مبتدأ مؤخر، <span class="hlt"><span class="qpc-hafs">﴿قالت﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿كأنه هو﴾</span></span> كأن حرف ناسخ، والهاء اسمها، والضمير <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأوتينا العلم من قبلها وكنا مسلمين﴾</span></span>: الواو عاطفة على كلام محذوف، و<span class="hlt"><span class="qpc-hafs">﴿أوتينا﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل يعود على سليمان، وقيل: على بلقيس، والعلم مفعول أوتينا الثاني، و<span class="hlt"><span class="qpc-hafs">﴿من قبلها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتينا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وكنا﴾</span></span> الواو عاطفة، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومسلمين خبرها.</p></div>"
  27,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وصدها ما كانت تعبد من دون الله﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وصدها فعل ماض، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> صلة الموصول لا محل لها من الإعراب. واسم كانت مستتر تقديره: هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبد﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: وصدها عبادة الشمس عن الإسلام.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنها كانت من قوم كافرين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، وجملة كانت خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنها﴾</span></span> تعليل، وكانت فعل ماض ناسخ، واسمها مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿من قوم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وكافرين صفة.</p></div>"
  27,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قيل لها ادخلي الصرح﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والجملة مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ادخلي الصرح﴾</span></span> فعل وفاعل ومفعول به، وهي مقول القول، والصرح مفعول به على السعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأته حسبته لجة وكشفت عن ساقيها﴾</span></span>: الفاء عاطفة على محذوف، أي: فدخلته، لما حينية، أو رابطة، وجملة <span class="hlt"><span class="qpc-hafs">﴿حسبته﴾</span></span> لا محل لها من الإعراب، وهي فعل ماض، والهاء مفعول به أول، ولجة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿كشفت عن ساقيها﴾</span></span> عطف على حسبته.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إنه صرح ممرد من قوارير﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وصرح خبرها، وممرد صفة، و<span class="hlt"><span class="qpc-hafs">﴿من قوارير﴾</span></span> جار ومجرور متعلقان بمحذوف صفة ثانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت رب إني ظلمت نفسي وأسلمت مع سليمان لله رب العالمين﴾</span></span>: رب منادى مضاف محذوف منه حرف النداء، وإن حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلمت نفسي﴾</span></span> خبرها، وهي فعل وفاعل ومفعول به، وأسلمت عطف على ظلمت، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بمحذوف حال، أي: كائنة مع سليمان، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسلمت﴾</span></span>، ورب العالمين بدل من لفظ الجلالة، أو صفة له.</p></div>"
  27,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا إلى ثمود أخاهم صالحا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأرسلنا فعل ماض، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى ثمود﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وأخاهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿صالحًا﴾</span></span> بدل من أخاهم، أو عطف بيان.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن اعبدوا الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر منصوب بنزع الخافض، أي: بأن اعبدوا، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> فعل أمر، والواو: فاعل، ولفظ الجلالة: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا هم فريقان يختصمون﴾</span></span>: الفاء عاطفة، وإذا حرف للفجاءة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفريقان خبر، وجملة يختصمون نعت لـ<span class="hlt"><span class="qpc-hafs">﴿فريقان﴾</span></span>.</p></div>"
  27,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم لم تستعجلون بالسيئة قبل الحسنة﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> اللام حرف جر، وما اسم استفهام حذفت ألفه لدخول الجار، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستعجلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالسيئة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تستعجلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قبل الحسنة﴾</span></span> ظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿لولا تستغفرون الله لعلكم ترحمون﴾</span></span>: لولا حرف تحضيض بمعنى هلا، و<span class="hlt"><span class="qpc-hafs">﴿تستغفرون الله﴾</span></span> فعل مضارع مرفوع، والواو فاعل، ولفظ الجلالة مفعوله، و<span class="hlt"><span class="qpc-hafs">﴿لعلكم ترحمون﴾</span></span> لعل حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة ترحمون خبرها.</p></div>"
  27,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا اطيرنا بك وبمن معك﴾</span></span>: قالوا فعل ماض، والواو فاعل، اطيرنا فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اطيرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بمن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿معك﴾</span></span> ظرف مكان متعلق بمحذوف صلة مَن، وجملة الصلة لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿اطيرنا...﴾</span></span> مقول قولهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال طائركم عند الله بل أنتم قوم تفتنون﴾</span></span>: قال فعل ماض، طائركم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عند الله﴾</span></span> ظرف متعلق بمحذوف هو الخبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف إضراب، وأنتم مبتدأ، وقوم خبر، وجملة تفتنون نعت لقوم.</p></div>"
  27,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span></span>: الواو استئنافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿في المدينة﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، وتسعة اسمها المتأخر، ورهط مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكان في المدينة...﴾</span></span> مستأنفة لا محل لها من الإعراب، وجملة يفسدون صفة لتسعة، أو لرهط، و<span class="hlt"><span class="qpc-hafs">﴿لا يصلحون﴾</span></span> عطف على يفسدون.</p></div>"
  27,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا تقاسموا بالله لنبيتنه وأهله﴾</span></span>: قالوا: فعل ماض، والواو فاعل. <span class="hlt"><span class="qpc-hafs">﴿تقاسموا﴾</span></span>: فعل أمر، أو فعل ماض، وحينئذ يكون تفسيرًا لـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، كأنه قيل: ما قالوا؟ فقيل: تقاسموا. أو يكون مع فاعله جملة في محل نصب على الحال بإضمار <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>، أي: قالوا متقاسمين. بالله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقاسموا﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿لنبيتنه﴾</span></span> اللام واقعة في جواب القسم، و<span class="hlt"><span class="qpc-hafs">﴿نبيتنه﴾</span></span> فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: نحن، والهاء مفعول به. <span class="hlt"><span class="qpc-hafs">﴿وأهله﴾</span></span>: الواو عاطفة، أو للمعية. و<span class="hlt"><span class="qpc-hafs">﴿أهله﴾</span></span> معطوف على الهاء، أو مفعول معه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لنقولن لوليه ما شهدنا مهلك أهله﴾</span></span>: ثم: حرف عطف للتراخي. واللام: واقعة في جواب القسم. و<span class="hlt"><span class="qpc-hafs">﴿نقولن﴾</span></span>: فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: نحن. و<span class="hlt"><span class="qpc-hafs">﴿لوليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقولن﴾</span></span>، ما نافية، وشهدنا فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، ومهلك مفعول به، وأهله مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لصادقون﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وصادقون خبر إن.</p></div>"
  27,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومكروا مكرا ومكرنا مكرا وهم لا يشعرون﴾</span></span>: الواو عاطفة، ومكروا فعل، وفاعل، ومكرًا مفعول مطلق، ومكرنا مكرًا عطف على الجملة السابقة، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون خبر.</p></div>"
  27,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانظر كيف كان عاقبة مكرهم أنا دمرناهم وقومهم أجمعين﴾</span></span>: الفاء استئنافية، وانظر فعل أمر، وكيف خبر كان المقدم، وعاقبة اسم كان المؤخر، والجملة في محل نصب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> المعلقة عن العمل بالاستفهام، وجملة <span class="hlt"><span class="qpc-hafs">﴿فانظر كيف...﴾</span></span> مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> بدل من العاقبة، أو خبر لمبتدأ محذوف، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿دمرناهم﴾</span></span> خبرها، وقومهم معطوف على الضمير <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿دمرناهم﴾</span></span>، وأجمعين تأكيد لكل من المعطوف والمعطوف عليه.</p></div>"
  27,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتلك بيوتهم خاوية بما ظلموا﴾</span></span>: الفاء عاطفة، والجملة معطوفة على ما قبلها، وتلك مبتدأ، وبيوتهم خبر، وخاوية حال من بيوتهم، والعامل فيها معنى الإشارة، و<span class="hlt"><span class="qpc-hafs">﴿بما ظلموا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خاوية﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والباء للسببية، أي: بسبب ظلمهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يعلمون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآية اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>، وجملة يعلمون صفة لقوم.</p></div>"
  27,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنجينا الذين آمنوا وكانوا يتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أنجينا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والذين مفعول به، وجملة آمنوا صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> كان فعل ماض ناقص ناسخ، والواو اسمها، ويتقون خبرها، والجملة عطف على آمنوا، فهي في حيز الصلة.</p></div>"
  27,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولوطا إذ قال لقومه﴾</span></span>: الواو استئنافية، ولوطًا مفعول به لفعل محذوف تقديره: اذكر، والجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿لوطًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> مجرورة بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لقومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتأتون الفاحشة وأنتم تبصرون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿تأتون﴾</span></span> فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الفاحشة﴾</span></span> مفعول به، والجملة مقول القول، <span class="hlt"><span class="qpc-hafs">﴿وأنتم﴾</span></span> الواو حالية، وأنتم مبتدأ، وجملة تبصرون خبر أنتم.</p></div>"
  27,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئنكم لتأتون الرجال شهوة من دون النساء﴾</span></span>: الهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتون الرجال﴾</span></span> خبرها، وهي فعل مضارع، والواو فاعل، والرجال مفعول به، وشهوة مفعول لأجله، أو حال من الفاعل، أو من المفعول، و<span class="hlt"><span class="qpc-hafs">﴿من دون النساء﴾</span></span> جار ومجرور متعلقان بمحذوف حال من الفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أنتم قوم تجهلون﴾</span></span>: بل حرف إضراب، وأنتم مبتدأ، وقوم خبر، وتجهلون صفة لقوم.</p></div>"
  27,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما كان جواب قومه إلا أن قالوا أخرجوا آل لوط من قريتكم إنهم أناس يتطهرون﴾</span></span>: الفاء عاطفة، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿جواب قومه﴾</span></span> خبر كان المقدم، وإلا أداة حصر، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن قالوا﴾</span></span> اسم كان المؤخر، وجملة أخرجوا مقول القول، وهي فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿آل لوط﴾</span></span> مفعول به، ومضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قريتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span> تعليل لإخراجهم، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وأناس خبرها، وجملة يتطهرون صفة.</p></div>"
  27,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأنجيناه وأهله إلا امرأته قدرناها من الغابرين﴾</span></span>: الفاء عاطفة على مقدر محذوف يفهم من السياق، و<span class="hlt"><span class="qpc-hafs">﴿أنجيناه﴾</span></span> فعل ماض وفاعل ومفعول به، وأهله عطف على الهاء، أو مفعول معه، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿امرأته﴾</span></span> مستثنى، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدرناها﴾</span></span> استئنافية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قدرناها﴾</span></span> فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الغابرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدرناها﴾</span></span>.</p></div>"
  27,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأمطرنا عليهم مطرا فساء مطر المنذرين﴾</span></span>: الواو عاطفة، وأمطرنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمطرنا﴾</span></span>، ومطرًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فساء﴾</span></span> الفاء عاطفة، وساء فعل ماض للذم، و<span class="hlt"><span class="qpc-hafs">﴿مطر المنذرين﴾</span></span> فاعل، ومضاف إليه.</p></div>"
  27,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل الحمد لله وسلام على عباده الذين اصطفى﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وسلام مبتدأ سوغ الابتداء به ما فيه من معنى الدعاء، وعلى عباده جار ومجرور متعلقان بمحذوف خبر، والذين صفة لعباده، وجملة اصطفى صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي اصطفاهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿آلله خير أما يشركون﴾</span></span>: الهمزة للاستفهام، والله مبتدأ، وخير خبر، وأم عاطفة، وما اسم موصول، وجملة يشركون صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن خلق السماوات والأرض وأنزل لكم من السماء ماء فأنبتنا به حدائق ذات بهجة﴾</span></span>: أم: منقطعة بمعنى بل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. وخبر من محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿خير أم ما يشركون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span> عطف على خلق، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وماء مفعول به، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، وحدائق مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ذات بهجة﴾</span></span> صفة لحدائق.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كان لكم أن تنبتوا شجرها﴾</span></span>: الجملة نعت ثان لحدائق، أو حال منها، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، وأن وما في حيزها اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿تنبتوا﴾</span></span> فعل مضارع منصوب بأن، والواو فاعل، وشجرها مفعول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله بل هم قوم يعدلون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف مكان منصوب متعلق بمحذوف خبر، وبل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وقوم خبر، وجملة يعدلون صفة.</p></div>"
  27,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن جعل الأرض قرارا وجعل خلالها أنهارا﴾</span></span>: أم: منقطعة بمعنى بل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل الأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. وخبر من محذوف، وقرارًا مفعول جعل الثاني، <span class="hlt"><span class="qpc-hafs">﴿وجعل خلالها أنهارًا﴾</span></span> عطف على الجملة الأولى، و<span class="hlt"><span class="qpc-hafs">﴿خلالها﴾</span></span> ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، بمعنى خلق المتعدية لواحد، أو متعلق بمحذوف المفعول الثاني لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، على أنها بمعنى صير، وعلى الوجه الأول يكون <span class="hlt"><span class="qpc-hafs">﴿قرارًا﴾</span></span> حالًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لها رواسي﴾</span></span>: جملة معطوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل بين البحرين حاجزا﴾</span></span>: الجملة معطوفة على ما تقدم، وجعل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بين البحرين﴾</span></span> ظرف متعلق بمحذوف مفعول جعل الثاني، وحاجزا مفعول جعل الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله بل أكثرهم لا يعلمون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر، وبل حرف إضراب، وأكثرهم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر.</p></div>"
  27,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن يجيب المضطر إذا دعاه ويكشف السوء﴾</span></span>: أم: منقطعة بمعنى بل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجيب المضطر﴾</span></span> صلة الموصول لا محل لها من الإعراب. وخبر مَن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعاه﴾</span></span> في محل جر بإضافة الظرف إليها، ويكشف السوء عطف على ما قبلها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعلكم خلفاء الأرض﴾</span></span>: عطف على الجملة الأولى، ويجعلكم فعل مضارع ومفعول به أول، والفاعل ضمير مستتر تقديره: هو، وخلفاء: مفعول به ثان، والأرض مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تتذكرون تذكرا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قليلا ما تذكرون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  27,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن يهديكم في ظلمات البر والبحر﴾</span></span>: أم: منقطعة بمعنى بل، ومَن مبتدأ، وجملة يهديكم صلة الموصول لا محل لها من الإعراب، وخبر من محذوف، و<span class="hlt"><span class="qpc-hafs">﴿في ظلمات البر والبحر﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهديكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يرسل الرياح بشرا بين يدي رحمته أإله مع الله تعالى الله عما يشركون﴾</span></span>: عطف على ما سبق، ويرسل فعل مضارع والفاعل مستتر تقديره: أنت، والرياح مفعول به، وبشرا حال، وبين ظرف منصوب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿بشرا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يدي رحمته﴾</span></span> مضاف إليه، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر، وتعالى فعل ماض، ولفظ الجلالة فاعل، عن حرف جر، وما حرف مصدري، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل بعدها مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>.</p></div>"
  27,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن يبدأ الخلق ثم يعيده ومن يرزقكم من السماء والأرض﴾</span></span>: أم: منقطعة بمعنى بل، ومَن مبتدأ، وجملة يبدأ الخلق صلة الموصول لا محل لها من الإعراب. وخبر من محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ثم يعيده﴾</span></span> عطف على جملة الصلة، والضمير في محل نصب مفعول به، وجملة و<span class="hlt"><span class="qpc-hafs">﴿من يرزقكم﴾</span></span> عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله قل هاتوا برهانكم إن كنتم صادقين﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر، وإن شرطية، وجوابها محذوف، تقديره: <span class="hlt"><span class="qpc-hafs">﴿فهاتوا برهانكم﴾</span></span>.</p></div>"
  27,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لا يعلم من في السماوات والأرض الغيب إلا الله وما يشعرون أيان يبعثون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ولا نافية، ويعلم فعل مضارع، ومَن اسم موصول فاعل يعلم، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. والغيب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن إشارة إلى أن الاستثناء منقطع، ولفظ الجلالة بدل من الاسم الموصول مرفوع بالضمة أي: لا يعلم أحد الغيب إلا الله، والواو عاطفة، وما نافية، ويشعرون فعل مضارع وفاعل، وأيان اسم استفهام بمعنى في محل نصب على الظرفية متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span>، ومعلقة لـ<span class="hlt"><span class="qpc-hafs">﴿يشعرون﴾</span></span> عن نصب المفعول به، فالجملة المؤلفة من <span class="hlt"><span class="qpc-hafs">﴿أيان﴾</span></span> وما بعدها في محل نصب مفعول به.</p></div>"
  27,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل ادارك علمهم في الآخرة بل هم في شك منها بل هم منها عمون﴾</span></span>: بل حرف إضراب، وقيل: هي بمعنى هل، و<span class="hlt"><span class="qpc-hafs">﴿ادارك﴾</span></span> فعل ماض، وعلمهم فاعل، وفي الآخرة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادارك﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿علمهم﴾</span></span>، وبل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عمون﴾</span></span>، وعمون خبر.</p></div>"
  27,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا أئذا كنا ترابا وآباؤنا أئنا لمخرجون﴾</span></span>: الواو للعطف، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة كفروا صلة الذين لا محل لها من الإعراب. والهمزة للاستفهام، وإذا ظرف مستقبل، متضمن معنى الشرط، وجملة كنا في محل جر بإضافة الظرف إليها، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وترابًا خبرها، وآباؤنا عطف على اسم كان، والهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومخرجون خبر إن، والجملة تأكيد للجملة الأولى.</p></div>"
  27,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد وعدنا هذا نحن وآباؤنا من قبل إن هذا إلا أساطير الأولين﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، ووعدنا فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، وهذا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿وعدنا﴾</span></span>، ونحن تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>، وآباؤنا عطف على الضمير البارز في وعدنا، ومن قبل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وعدنا﴾</span></span>، والظرف مبني على الضم لانقطاعه عن الإضافة لفظًا لا معنى، وإن نافية، وهذا مبتدأ، وإلا أداة حصر، وأساطير خبر هذا، والأولين مضاف إليه.</p></div>"
  27,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل سيروا في الأرض فانظروا كيف كان عاقبة المجرمين﴾</span></span>: سيروا فعل أمر، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سيروا﴾</span></span>، فانظروا عطف على سيروا، وكيف اسم استفهام في محل نصب خبر كان المقدم، وعاقبة المجرمين اسم كان المؤخر.</p></div>"
  27,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تحزن عليهم ولا تكن في ضيق مما يمكرون﴾</span></span>: الواو عاطفة على قل، ولا ناهية، وتحزن فعل مضارع مجزوم بلا، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحزن﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا تكن﴾</span></span> عطف على لا تحزن، واسم تكن مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿في ضيق﴾</span></span> خبر، ومما جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ضيق﴾</span></span>، وجملة يمكرون صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون متى هذا الوعد إن كنتم صادقين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ويقولون فعل مضارع وفاعل، ومتى اسم استفهام في محل نصب على الظرفية الزمانية، وهو متعلق بمحذوف خبر مقدم، وهذا مبتدأ مؤخر، والوعد بدل، وإن شرطية، وكنتم فعل الشرط، وكان فعل ماض ناقص، والتاء اسمها، وصادقين خبرها، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  27,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل عسى أن يكون ردف لكم بعض الذي تستعجلون﴾</span></span>: عسى فعل ماض جامد من أفعال الرجاء، واسمها مستتر تقديره: هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يكون﴾</span></span> خبرها، واسم يكون مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿ردف﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بعض﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، وجملة تستعجلون صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿ردف﴾</span></span> خبر يكون.</p></div>"
  27,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لذو فضل على الناس﴾</span></span>: الواو استئنافية، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذو فضل﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿على الناس﴾</span></span> جار ومجرور متعلقان بفضل، أو صفة له، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن ربك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم لا يشكرون﴾</span></span>: الواو حالية، ولكن حرف استدراك ونصب، وأكثرهم اسمها، وجملة لا يشكرون خبرها.</p></div>"
  27,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك ليعلم ما تكن صدورهم وما يعلنون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، وجملة يعلم خبر إن، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكن صدروهم﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، <span class="hlt"><span class="qpc-hafs">﴿وما يعلنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما تكن﴾</span></span>.</p></div>"
  27,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما من غائبة في السماء والأرض إلا في كتاب مبين﴾</span></span>: الواو عاطفة، وما نافية، ومن حرف صلة، وغائبة مجرور لفظًا، مرفوع محلًّا على أنه مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في السماء والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لغائبة، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في كتاب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر غائبة، ومبين صفة.</p></div>"
  27,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا القرآن يقص على بني إسرائيل أكثر الذي هم فيه يختلفون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، وهذا اسمها، والقرآن بدل من اسم الإشارة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقص﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿على بني إسرائيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقص﴾</span></span>، وأكثر مفعول به، والذي: مضاف إليه. وهم: ضمير مبني في محل رفع مبتدأ. وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span> في محل رفع خبر للمبتدأ. وجملة <span class="hlt"><span class="qpc-hafs">﴿هم فيه يختلفون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> لا محل لها من الإعراب.</p></div>"
  27,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لهدى ورحمة للمؤمنين﴾</span></span>: عطف على ما تقدم، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وهدى خبرها، ورحمة عطف على هدى، وللمؤمنين جار ومجرور متعلقان برحمة.</p></div>"
  27,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك يقضي بينهم بحكمه وهو العزيز العليم﴾</span></span>: إن حرف ناسخ، وربك اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span> خبرها، والظرف متعلق بمحذوف حال، وبحكمه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span> خبر أول، و<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span> خبر ثان.</p></div>"
  27,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتوكل على الله إنك على الحق المبين﴾</span></span>: الفاء الفصيحة، وتوكل فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك على الحق المبين﴾</span></span> لا محل لها من الإعراب، لأنها تعليل، وإن حرف ناسخ، والكاف اسمها، وعلى الحق جار ومجرور متعلقان بمحذوف خبر إن، والمبين صفة.</p></div>"
  27,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك لا تسمع الموتى ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تُسمع﴾</span></span> خبر أن، والموتى مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا تسمع﴾</span></span> الصم عطف على سابقتها، والصم مفعول به أول، والدعاء مفعول به ثان، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولوا﴾</span></span> مجرورة بإضافة الظرف إليها، ومدبرين حال.</p></div>"
  27,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت بهادي العمي عن ضلالتهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بهادي﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿هادي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿العمي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عن ضلالتهم﴾</span></span> جار ومجرور متعلقان بهادي، وعُدِّيَ بعن لتضمنه معنى تصرفهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تسمع إلا من يؤمن بآياتنا فهم مسلمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تسمع﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، والفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مسلمون﴾</span></span> خبر.</p></div>"
  27,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقع القول﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> فاعل وقع، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span>، ودابة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لدابة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تكلمهم أن الناس كانوا بآياتنا لا يوقنون﴾</span></span>: جملة تكلمهم صفة ثانية لدابة، أو حال منها، لأنها وصفت، وأن حرف ناسخ، والناس اسمها، وجملة كانوا خبر أن، والجملة في تأويل مصدر منصوب على نزع الخافض، أي: بأن الناس، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكلمهم﴾</span></span>، وكان فعل ماض ناقص، وواو الجماعة اسمها، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوقنون﴾</span></span>، ولا نافية، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يوقنون﴾</span></span> خبر كانوا.</p></div>"
  27,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا ممن يكذب بآياتنا فهم يوزعون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من كل أمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> هنا للتبعيض، وفوجًا مفعول به، وممن جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فوجًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويوم نحشر...﴾</span></span> مستأنفة لا محل لها من الإعراب، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يوزعون خبر.</p></div>"
  27,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا جاءوا قال أكذبتم بآياتي ولم تحيطوا بها علما أماذا كنتم تعملون﴾</span></span>: حتى حرف غاية، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءوا﴾</span></span> في محل جر بإضافة الظرف إليها، ومتعلق جاءوا محذوف، أي: إلى مكان الحساب، وقال فعل ماض، وفاعله مستتر، يعود على الله تعالى. <span class="hlt"><span class="qpc-hafs">﴿أكذبتم﴾</span></span>: الهمزة للاستفهام، وكذبتم فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بآياتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبتم﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ولم﴾</span></span>: الواو حالية، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تحيطوا﴾</span></span> فعل مضارع مجزوم بلم، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحيطوا﴾</span></span>، وعلمًا تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولم تحيطوا ...﴾</span></span> حالية، وأم حرف عطف، وهي منقطعة تقدر بـ<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> فقط، وما اسم استفهام مبتدأ، وذا اسم موصول خبر، أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> كلها اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span>، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة تعملون خبرها.</p></div>"
  27,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووقع القول عليهم بما ظلموا فهم لا ينطقون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿وقع القول﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما ظلموا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span> أيضًا، أي: بسبب ظلمهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ينطقون﴾</span></span> خبر.</p></div>"
  27,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم يروا أنا جعلنا الليل ليسكنوا فيه والنهار مبصرا إن في ذلك لآيات لقوم يؤمنون﴾</span></span>: الهمزة للاستفهام التقريري، والإنكاري، ولم حرف نفي وقلب وجزم، ويروا فعل مضارع مجزوم بلم، والرؤية هنا قلبية لا بصرية، وأن وما بعدها سدت مسد مفعولي يروا، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مفعول جعلنا، ومفعول جعل الثاني محذوف تقديره: مظلما، واللام للتعليل، ويسكنوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وعلامة نصبه حذف النون، والواو فاعل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسكنوا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿والنهار﴾</span></span> الواو عاطفة، والنهار مفعول به أول لفعل محذوف دل عليه المذكور تقديره: جعلنا، و<span class="hlt"><span class="qpc-hafs">﴿مبصرًا﴾</span></span> مفعول به ثان للفعل المحذوف، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وآيات اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، وجملة يؤمنون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  27,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم ينفخ في الصور ففزع من في السماوات ومن في الأرض﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> السابق في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿ويوم نحشر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span> في محل جر مضاف إليه، ونائب الفاعل مستتر، وتقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ففزع﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل فزع، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> الجار والمجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ومن في الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من في السماوات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من شاء الله وكل أتوه داخرين﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مستثنى، وجملة <span class="hlt"><span class="qpc-hafs">﴿شاء الله﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وكل﴾</span></span>: الواو للحال، أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتوه﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿داخرين﴾</span></span> حال.</p></div>"
  27,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وترى الجبال تحسبها جامدة وهي تمر مر السحاب﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ترى الجبال﴾</span></span> فعل مضارع مرفوع، وفاعل مستتر تقديره: أنت، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحسبها﴾</span></span> حال من الجبال، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول تحسبها الأول، و<span class="hlt"><span class="qpc-hafs">﴿جامدة﴾</span></span> مفعول تحسبها الثاني. <span class="hlt"><span class="qpc-hafs">﴿وهي﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمر﴾</span></span> خبر، والجملة حال من الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿جامدة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مر﴾</span></span> مفعول مطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿السحاب﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء إنه خبير بما تفعلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿صُنْعَ﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة قبله والتقدير: صنع الله ذلك صنعا، وأضيف المصدر إلى فاعله. و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿لفظ الجلالة﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿أتقن﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿كل شيء﴾</span></span> مفعول أتقن. وإن حرف ناسخ، والهاء اسمها. وخبير خبرها. و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبير﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿تفعلون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  27,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من جاء بالحسنة فله خير منها وهم من فزع يومئذ آمنون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بالحسنة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> أو بمحذوف حال من فاعل جاء فتكون الباء للملابسة، أي: جاء متلبسًا بها، والفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> على أنه اسم تفضيل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومن فزع جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فزع﴾</span></span>، أي: فزع كائن يومئذ، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، أي: يوم إذ جاء بالحسنة، أو يوم إذ يُنفَخ في الصور. و<span class="hlt"><span class="qpc-hafs">﴿آمنون﴾</span></span> خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  27,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن جاء بالسيئة فكبت وجوههم في النار هل تجزون إلا ما كنتم تعملون﴾</span></span>: الواو عاطفة، ومن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿جاء بالسيئة﴾</span></span> فعل الشرط، والفاء رابطة داخلة على <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> محذوفة، أي: قد كبت، ليصح اقتران الجواب بها، وكبت فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿وجوههم﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في النار﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كبت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فكبت﴾</span></span> في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، وتجزون فعل مضارع مبني لما لم يسمَّ فاعله مرفوع بثبوت النون، والواو نائب فاعل، والجملة حال، أي: فكبت وجوههم مقولًا لهم: هل تجزون، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، وجملة كنتم صلة الموصول لا محل لها من الإعراب. وكان فعل ماض ناقص، والتاء اسمها، وجملة تعملون خبرها.</p></div>"
  27,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما أمرت أن أعبد رب هذه البلدة الذي حرمها﴾</span></span>: الجملة مقول قول محذوف، أي: قل لهم: إنما أمرت، وإنما كافة ومكفوفة، وأمرت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن أعبد﴾</span></span> في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمرت﴾</span></span>، ورب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> مضاف إليه، والبلدة: بدل من اسم الإشارة، والذي: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب هذه البلدة﴾</span></span>، وجملة حرمها: صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وله كل شيء وأمرت أن أكون من المسلمين﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: خبر مقدم، وكل: مبتدأ مؤخر، وشيء: مضاف إليه، وأمرت: فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، وأن أكون: في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمرت﴾</span></span>، ومن المسلمين: جار ومجرور متعلقان بمحذوف خبر أكون.</p></div>"
  27,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن أتلو القرآن فمن اهتدى فإنما يهتدي لنفسه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وأن أتلو﴾</span></span>: عطف على أن أكون، أي: وأمرت بأن أتلو، والقرآن: مفعول به، فمن: الفاء تفريعية، ومن: شرطية مبتدأ، واهتدى: فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وإنما: كافة ومكفوفة، ويهتدي: فعل مضارع، وفاعله مستتر، تقديره: هو، ولنفسه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهتدي﴾</span></span>، وجملة الشرط والجواب خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ضل فقل إنما أنا من المنذرين﴾</span></span>: معطوفة على سابقتها، ومن: شرطية مبتدأ، وضل: فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وقل: فعل أمر والفاعل مستتر تقديره: أنت، إنما: كافة ومكفوفة، وأنا: مبتدأ، من المنذرين: جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول، وجملة الشرط والجواب خبر المبتدأ.</p></div>"
  27,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل الحمد لله سيريكم آياته فتعرفونها وما ربك بغافل عما تعملون﴾</span></span>: الواو عاطفة، وقل: فعل أمر، والفاعل مستتر تقديره: أنت، والحمد: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول، وسيريكم: السين حرف استقبال، ويريكم فعل مضارع، والكاف مفعول به أول، وآياته: مفعول به ثان، والجملة من تتمة مقول القول منتظمة في سلكه، فتعرفونها: الفاء عاطفة، وتعرفونها: فعل مضارع وفاعل ومفعول به، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بغافل﴾</span></span> الباء حرف جر صلة، وغافل: مجرور لفظًا منصوب محلًّا على أنه خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> عن حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، أي: عن الذي تعملونه، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، أي: عن عملكم، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
