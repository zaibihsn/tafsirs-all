quran[6]{c,v,t}:
  114,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>: فعل أمر مبني على السكون، وفاعله مستتر، تقديره: أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> ابتدائية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>: فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره أنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿برب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، ورب مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span>: مضاف إليه مجرور بالكسرة.</p></div>"
  114,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ملك﴾</span></span>: بدل من رب أو عطف بيان أو نعت، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span>: مضاف إليه مجرور بالكسرة.</p></div>"
  114,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: بدل من رب أو عطف بيان أو نعت له، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span>: مضاف إليه مجرور بالكسرة.</p></div>"
  114,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من شر﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، وشر مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الوسواس﴾</span></span>: مضاف إليه مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الخناس﴾</span></span>: نعت مجرور بالكسرة.</p></div>"
  114,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>: مجرور على أنه نعت للوسواس، أو: بدل منه، أو: عطف بيان لجريانه مجرى الجوامد، أو: في محل رفع خبر لمبتدأ محذوف، أي: هو الذي يوسوس في صدور الناس، أو: في محل نصب على الذم بفعل محذوف، أي: أذم الذي يوسوس في صدور الناس.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوسوس﴾</span></span>: فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره هو يعود على الاسم الموصول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوسوس﴾</span></span> لا محل لها من الإعراب لأنها صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿في صدور﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوسوس﴾</span></span>، وصدور مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span>: مضاف إليه مجرور بالكسرة.</p></div>"
  114,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من الجنة﴾</span></span>: جار ومجرور متعلقان بحال محذوفة من <span class="hlt"><span class="qpc-hafs">﴿يوسوس﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والناس﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿الوسواس﴾</span></span>، أو على <span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span>.</p></div>"
