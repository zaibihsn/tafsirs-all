quran[40]{c,v,t}:
  78,1,"<div class=ar lang=ar><p>يتساءلون:</p><p>وقرئ:</p><p>يساءلون، بغير تاء وشد السين، وهى قراءة عبد الله، وابن جبير.</p></div>"
  78,2,""
  78,3,"78:2"
  78,4,"<div class=ar lang=ar><p>سيعلمون ... سيعلمون:</p><p>1- بياء الغيبة، فيهما، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- الأول بالتاء، على الخطاب، والثاني بالياء، على الغيبة، ورويت عن الضحاك.</p></div>"
  78,5,"78:4"
  78,6,""
  78,7,"78:6"
  78,8,"78:6"
  78,9,"78:6"
  78,10,"78:6"
  78,11,"78:6"
  78,12,"78:6"
  78,13,"78:6"
  78,14,"<div class=ar lang=ar><p>ثجاجا:</p><p>قرئ:</p><p>ثجاجا، بالحاء آخرا، أي منصبا، وهى قراءة الأعرج.</p></div>"
  78,15,""
  78,16,"78:15"
  78,17,"78:15"
  78,18,"<div class=ar lang=ar><p>الصور:</p><p>1- بسكون الواو، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بفتحها، وهى قراءة أبى فياض.</p></div>"
  78,19,""
  78,20,"78:19"
  78,21,"<div class=ar lang=ar><p>إن:</p><p>1- بالكسر، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بفتحها، وهى قراءة أبى عمرو المنقري، وابن يعمر.</p></div>"
  78,22,""
  78,23,"<div class=ar lang=ar><p>لابثين:</p><p>1- بالألف، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- لبثين، بغير ألف، وهى قراءة عبد الله، وعلقمة، وزيد بن على، وابن وثاب، وعمرو بن ميمون، وعمرو بن شرحبيل، وطلحة، والأعمش، وحمزة، وقتيبة، وسورة، وروح.</p></div>"
  78,24,""
  78,25,"78:24"
  78,26,"<div class=ar lang=ar><p>وفاقا:</p><p>1- بخف الفاء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بشدها، وهى قراءة أبى بحرية، وابن أبى عبلة.</p></div>"
  78,27,""
  78,28,"<div class=ar lang=ar><p>كذابا:</p><p>1- بكسر الكاف وشد الذال، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بكسر الكاف وخف الذال، وهى قراءة على، وعوف الأعرابى، وأبى رجاء، والأعمش، وعيسى.</p><p>3- بضم الكاف وشد الذال، جمع «كاذب» ، وهى قراءة عمر بن عبد العزيز، والماجشون.</p></div>"
  78,29,"<div class=ar lang=ar><p>وكل شيء:</p><p>1- بنصب «كل» ، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- برفعها، وهى قراءة أبى السمال.</p></div>"
  78,30,""
  78,31,""
  78,32,""
  78,33,""
  78,34,""
  78,35,"<div class=ar lang=ar><p>كذابا:</p><p>1- بالتشديد، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بالتخفيف، وهى قراءة الكسائي.</p></div>"
  78,36,"<div class=ar lang=ar><p>حسابا:</p><p>1- بكسر الحاء وفتح السين مخففة، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بفتح الحاء وشد السين، وهى قراءة ابن قطيب.</p><p>3- بكسر الحاء وشد السين، وهى قراءة شريح بن يزيد، وأبى البرهسم.</p><p>4- حسنا، بالنون، وهى قراءة ابن عباس.</p><p>5- حسبا، بفتح الحاء، وسكون السين والباء، حكاها العدوى، عن ابن عباس.</p></div>"
  78,37,"<div class=ar lang=ar><p>رب ... الرحمن:</p><p>قرئا:</p><p>1- بجرهما، وهى قراءة عبد الله، وابن أبى إسحاق، والأعمش، وابن محيصن، وابن عامر، وعاصم.</p><p>2- برفعهما، وهى قراءة الأعرج، وأبى جعفر، وشيبة، وأبى عمرو، والحرميين.</p><p>3- الأول بالجر، والثاني بالرفع، وهى قراءة الأخوين، والحسن، وابن وثاب، والأعمش، وابن محيصن، بخلاف عنهما.</p></div>"
  78,38,"<div class=ar lang=ar></div>"
  78,39,""
  78,40,"<div class=ar lang=ar><p>المرء:</p><p>1- بفتح الميم، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بضمها، وهى قراءة ابن أبى إسحاق.</p></div>"
