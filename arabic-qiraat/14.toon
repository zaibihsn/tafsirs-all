quran[52]{c,v,t}:
  14,1,""
  14,2,"<div class=ar lang=ar><p>الله:</p><p>قرئ:</p><p>1- بالرفع، والمبتدأ محذوف أي: هو الله، وهى قراءة نافع، وابن عامر.</p><p>2- بالجر، وهى قراءة باقى السبعة.</p></div>"
  14,3,"<div class=ar lang=ar><p>ويصدون:</p><p>وقرئ:</p><p>ويصدون، مضارع «أصد» ، وهى قراءة الحسن.</p></div>"
  14,4,"<div class=ar lang=ar><p>بلسان:</p><p>قرئ:</p><p>1- بلسن، بإسكان السين، كالريش والرياش، وهى قراءة أبى عمران الجونى.</p><p>2- بلسن، بضم اللام والسين، كعماد وعمد، وهى قراءة أبى رجاء، وأبى المتوكل، والجحدري.</p><p>3- بلسن، بضم اللام وسكون السين، مخفف، كرسل ورسل.</p></div>"
  14,5,""
  14,6,""
  14,7,""
  14,8,""
  14,9,"<div class=ar lang=ar><p>تدعوننا:</p><p>وقرئ:</p><p>تدعونا، بإدغام نون الرفع فى الضمير، وهى قراءة طلحة.</p></div>"
  14,10,"<div class=ar lang=ar><p>فاطر:</p><p>وقرئ:</p><p>بالنصب، على المدح، وهى قراءة زيد بن على.</p></div>"
  14,11,"<div class=ar lang=ar><p>فليتوكل:</p><p>وقرئ:</p><p>بكسر اللام، وهى قراءة الحسن.</p></div>"
  14,12,""
  14,13,"<div class=ar lang=ar><p>لنهلكن:</p><p>وقرئ:</p><p>ليهلكن، بياء، وهى قراءة أبى حيوة.</p></div>"
  14,14,"<div class=ar lang=ar><p>ولنسكننكم:</p><p>وقرئ:</p><p>وليسكننكم، بياء الغيبة، وهى قراءة أبى حيوة.</p></div>"
  14,15,"<div class=ar lang=ar><p>واستفتحوا:</p><p>وقرئ:</p><p>بكسر التاء، أمر للرسل، وهى قراءة ابن عباس، ومجاهد، وابن محيصن.</p></div>"
  14,16,""
  14,17,"14:16"
  14,18,"<div class=ar lang=ar><p>الربح:</p><p>1- بالإفراد، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- الرياح، بالجمع، وهى قراءة نافع، وأبى جعفر.</p><p>فى يوم عاصف:</p><p>وقرئ:</p><p>فى يوم عاصف، على الإضافة، وهى قراءة ابن أبى إسحاق، وإبراهيم بن أبى بكر عن الحسن.</p></div>"
  14,19,"<div class=ar lang=ar><p>تر:</p><p>وقرئ:</p><p>بسكون الراء، على إجراء الوصل مجرى الوقف، وهى قراءة السلمى.</p><p>خلق:</p><p>قرئ:</p><p>1- خالق، اسم فاعل، وجر «الأرض» ، وهى قراءة الأخوين.</p><p>2- خلق، فعلا ماضيا، و «الأرض» بالفتح، وهى قراءة باقى السبعة.</p></div>"
  14,20,""
  14,21,"<div class=ar lang=ar><p>وبرزوا:</p><p>وقرئ:</p><p>مبنيا للمفعول، وبتشديد الراء، وهى قراءة زيد بن على.</p></div>"
  14,22,""
  14,23,"<div class=ar lang=ar><p>وأدخل:</p><p>قرئ:</p><p>1- بهمزة المتكلم، مضارع «أدخل» ، وهى قراءة الحسن، وعمرو بن عبيد.</p><p>2- ماضيا مبنيا للمجهول، وهى قراءة الجمهور.</p></div>"
  14,24,""
  14,25,"14:24"
  14,26,"14:24"
  14,27,"14:24"
  14,28,"14:24"
  14,29,"14:24"
  14,30,"<div class=ar lang=ar><p>ليضلوا:</p><p>قرئ:</p><p>1- بفتح الياء، وهى قراءة ابن كثير، وأبى عمرو.</p><p>2- بضمها، وهى قراءة باقى السبعة.</p></div>"
  14,31,""
  14,32,"14:31"
  14,33,"14:31"
  14,34,"<div class=ar lang=ar><p>من كل:</p><p>وقرئ:</p><p>بالتنوين أي: من كل ما سألتموه، و «ما» موصولة، مفعول ثان، وهى قراءة ابن عباس، والضحاك، والحسن، ومحمد بن على، وجعفر بن محمد، وعمرو بن فائد، وقتادة، وسلام، ويعقوب، ونافع فى رواية.</p></div>"
  14,35,"<div class=ar lang=ar><p>واجنبنى:</p><p>وقرئ:</p><p>وأجنبنى، من «أجنب» ، وهى قراءة الجحدري، وعيسى الثقفي.</p></div>"
  14,36,""
  14,37,"<div class=ar lang=ar><p>أفئدة:</p><p>وقرئ:</p><p>1- بتسهيل الهمزة، وهى قراءة هشام.</p><p>2- آفدة، على وزن فاعلة.</p><p>3- أفدة، على وزن فعلة.</p><p>4- أفودة، بالواو المكسورة، بدل الهمزة، وهى قراءة ابن الهيثم.</p><p>تهوى:</p><p>وقرئ:</p><p>1- بضم التاء، مبنيا للمفعول، من «أهوى» ، بهمزة التعدية، وهى قراءة مسلمة بن عبد الله.</p><p>2- بفتح التاء، من «هوى» بمعنى مال، وهى قراءة الجمهور.</p><p>3- بفتح التاء، مضارع «هوى» بمعنى: أحب، وهى قراءة على بن أبى طالب، وزيد بن على، ومحمد بن على، وجعفر بن محمد، ومجاهد.</p></div>"
  14,38,""
  14,39,"14:38"
  14,40,"<div class=ar lang=ar><p>دعاء:</p><p>وقرئ:</p><p>1- بغير ياء، وهى قراءة طلحة، والأعمش.</p><p>2- بياء ساكنة فى الوصل، وهى قراءة ابن كثير.</p><p>3- بياء ساكنة فى الوقف، وهى قراءة لبعضهم.</p></div>"
  14,41,""
  14,42,"<div class=ar lang=ar><p>يؤخرهم:</p><p>قرئ:</p><p>1- بالنون، وهى قراءة السلمى، والحسن، والأعرج، والمفضل عن عاصم، وعباس بن الفضل، وهارون العتكي، ويونس بن حبيب عن أبى عمرو.</p><p>2- بالياء، وهى قراءة الجمهور.</p></div>"
  14,43,""
  14,44,"14:43"
  14,45,"14:43"
  14,46,"<div class=ar lang=ar><p>وإن كان ... لتزول:</p><p>1- هذه قراءة الجمهور.</p><p>وقرئ:</p><p>2- وإن كاد، بدال مكان «النون» ، وفتح اللام الأولى من «لتزول» ورفع الثانية، وهى قراءة عمر، وعلى، وعبد الله، وأبى، وأبى سلمة عبد الرحمن، وأبى إسحاق السبيعي، وزيد بن على.</p><p>3- وإن كان لتزول، بالنون، وعلى القراءة السابقة فى «لتزول» ، وهى قراءة ابن عباس، ومجاهد، وابن وثاب، والكسائي.</p><p>4- وإن كان لتزول، بالنون، وكسر اللام الأولى من «لتزول» ، وفتح الثانية.</p><p>5- وإن كان لتزول، بالنون، وفتح اللامين، على لغة من فتح «لام كى» .</p></div>"
  14,47,"<div class=ar lang=ar><p>مخلف وعده رسله:</p><p>قرئ:</p><p>1- بإضافة «مخلف» إلى «وعده» ، ونصب «رسله» ، وهى قراءة الجمهور.</p><p>2- بنصب «وعده» وإضافة «مخلف» إلى «رسله» ، على الفصل بين المضاف والمضاف إليه بالمفعول.</p></div>"
  14,48,"<div class=ar lang=ar><p>تبدل:</p><p>وقرئ:</p><p>نبدل، بالنون، ونصب «الأرض» .</p><p>وبرزوا:</p><p>وقرئ:</p><p>بضم الباء وكسر الراء مشددة، على البناء للمفعول، وهى قراءة زيد بن على.</p></div>"
  14,49,""
  14,50,"<div class=ar lang=ar><p>قطران:</p><p>وقرئ:</p><p>1- بفتح القاف وكسر الطاء وتنوين الراء، و «آن» : اسم فاعل، من «أنى» ، صفة ل «قطر» ، وهى قراءة على، وأبى هريرة وابن عباس وعكرمة، وابن جبير، وابن سيرين والحسن، وسنان بن سلمة بن المحنق، وزيد ابن على، وقتادة، وأبى صالح، والكلبي، وعيسى الهمداني، وعمرو بن فائد، وعمرو بن عبيد.</p><p>2- بفتح القاف وإسكان الطاء، وهى قراءة عمر بن الخطاب، وعلى بن أبى طالب.</p><p>وجوههم:</p><p>قرئ:</p><p>1- بالنصب، وهى قراءة الجمهور.</p><p>2- بالرفع، على التجوز.</p></div>"
  14,51,""
  14,52,"<div class=ar lang=ar><p>ولينذروا:</p><p>وقرئ:</p><p>1- بتاء مضمومة وكسر الدال، وهى قراءة مجاهد، وحميد.</p><p>2- بفتح الياء والذال، مضارع: نذر بالشيء، إذا علم به، وهى قراءة يحيى بن عمارة، وأحمد.</p><p>يزيد بن أسيد السلمى.</p></div>"
