quran[75]{c,v,t}:
  39,1,"<div class=ar lang=ar><p>تنزيل:</p><p>قرئ:</p><p>بالنصب، وهى قراءة ابن أبى عبلة، وزيد بن على، وعيسى.</p></div>"
  39,2,"<div class=ar lang=ar><p>الدين:</p><p>1- بالنصب، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بالرفع، على الفاعلية، وهى قراءة ابن أبى عبلة.</p></div>"
  39,3,"<div class=ar lang=ar><p>كاذب كفار:</p><p>وقرئ:</p><p>1- كذاب كفار، وهى قراءة أنس بن مالك، والجحدري، والحسن، والأعرج، وابن يعمر.</p><p>2- كذوب كفور، وهى قراءة زيد بن على.</p></div>"
  39,4,""
  39,5,"39:4"
  39,6,"<div class=ar lang=ar><p>يخلقكم:</p><p>وقرئ:</p><p>بإدغام القاف فى الكاف، وهى قراءة عيسى، وطلحة.</p></div>"
  39,7,"<div class=ar lang=ar><p>يرضه:</p><p>وقرئ:</p><p>1- بوصل ضمة الهاء بواو، وهى قراءة النحويين، وابن كثير.</p><p>2- بضمة، فقط، وهى قراءة ابن عامر، وحفص.</p><p>3- بسكون الهاء، وهى لغة لبنى كلاب، وهى قراءة أبى بكر.</p></div>"
  39,8,"<div class=ar lang=ar><p>ليضل:</p><p>1- بضم الياء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بفتحها، وهى قراءة ابن كثير، وأبى عمرو، وعيسى.</p></div>"
  39,9,"<div class=ar lang=ar><p>أمن:</p><p>وقرئ:</p><p>1- بتخفيف الميم، وهى قراءة ابن كثير، ونافع، وحمزة، والأعمش، وعيسى، وشيبة، والحسن.</p><p>2- بتشديد الميم، وهى «أم» أدغمت فى ميم «من» ، وهى قراءة باقى السبعة وقتادة، والأعرج، وأبى جعفر.</p><p>ساجدا وقائما:</p><p>1- بنصبهما على الحال، وهى قراءة الجمهور.</p><p>وقرئا:</p><p>2- برفعهما، إما على النعت ل «قانت» ، وإما على أنه خبر بعد خبر، والواو للجمع بين الصفتين، وهى قراءة الضحاك.</p><p>يتذكر:</p><p>وقرئ:</p><p>يذكر، بإدغام التاء فى الذال.</p></div>"
  39,10,""
  39,11,"39:10"
  39,12,"39:10"
  39,13,"39:10"
  39,14,"39:10"
  39,15,"39:10"
  39,16,"39:10"
  39,17,"<div class=ar lang=ar><p>الطاغوت:</p><p>وقرئ:</p><p>الطواغيت، جمعا، وهى قراءة الحسن.</p></div>"
  39,18,""
  39,19,"39:18"
  39,20,"39:18"
  39,21,"<div class=ar lang=ar><p>يجعله:</p><p>وقرئ:</p><p>بالنصب، وهى قراءة أبى بشر.</p><p>وقال صاحب «الكامل» : هو ضعيف.</p></div>"
  39,22,""
  39,23,"<div class=ar lang=ar><p>مثانى:</p><p>1- بفتح الياء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بسكونها، وهى قراءة هشام، وابن عامر، وأبى بشر.</p></div>"
  39,24,""
  39,25,"39:24"
  39,26,"39:24"
  39,27,"39:24"
  39,28,"39:24"
  39,29,"<div class=ar lang=ar><p>سلما:</p><p>قرئ:</p><p>1- سالما، اسم فاعل، أي خالصا من الشركة، وهى قراءة عبد الله، وابن عباس، وعكرمة، ومجاهد، وقتادة، والزهري، والحسن، بخلاف عنه، والجحدري، وابن كثير، وأبى عمرو.</p><p>2- سلما، بفتح السين واللام، وهى قراءة الأعرج، وشيبة، وأبى رجاء، وطلحة، والحسن، بخلاف عنه، وباقى السبعة.</p><p>3- سلما، بكسر السين وسكون اللام، وهى قراءة ابن جبير.</p><p>4- ورجل سالم، برفعهما.</p><p>مثلا:</p><p>وقرئ:</p><p>مثلين.</p></div>"
  39,30,"<div class=ar lang=ar><p>ميت ... ميتون:</p><p>1- وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- مائت ... مائتون، وهى قراءة ابن الزبير، وابن أبى إسحاق، وابن محيصن، وعيسى، واليماني، وابن أبى غوث، وابن أبى عبلة.</p></div>"
  39,31,""
  39,32,""
  39,33,"<div class=ar lang=ar><p>وصدق:</p><p>1- مشددا، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- مخففا، وهى قراءة أبى صالح، وعكرمة بن سليمان.</p><p>3- مبنيا للمفعول مشددا.</p></div>"
  39,34,"<div class=ar lang=ar></div>"
  39,35,""
  39,36,"<div class=ar lang=ar><p>عبده:</p><p>1- بالإفراد، وهو رسول الله ﷺ، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- عباده، بالجمع، أي: الأنبياء والطيبين من المؤمنين، وهى قراءة أبى جعفر، ومجاهد، وابن وثاب، وطلحة، والأعمش، وحمزة، والكسائي.</p></div>"
  39,37,"<div class=ar lang=ar></div>"
  39,38,"<div class=ar lang=ar><p>كاشفات ... ممسكات:</p><p>1- على الإضافة، وهى قراءة الجمهور.</p><p>وقرئا:</p><p>2- بتنوينهما، ونصب ما بعدهما، وهى قراءة شيبة، والأعرج، وعمرو بن عبيد، وعيسى، بخلاف عنه، وأبى عمرو، وأبى بكر.</p></div>"
  39,39,"<div class=ar lang=ar></div>"
  39,40,""
  39,41,""
  39,42,"<div class=ar lang=ar><p>قضى:</p><p>1- مبنيا للفاعل، و «الموت» نصبا، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- مبنيا للمفعول، و «الموت» رفعا، وهى قراءة ابن وثاب، والأعمش، وطلحة، وعيسى، وحمزة، والكسائي.</p></div>"
  39,43,"<div class=ar lang=ar></div>"
  39,44,""
  39,45,""
  39,46,""
  39,47,""
  39,48,""
  39,49,""
  39,50,""
  39,51,""
  39,52,""
  39,53,""
  39,54,""
  39,55,""
  39,56,"<div class=ar lang=ar><p>يا حسرتا:</p><p>1- بإبدال ياء المتكلم ألفا، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بياء الإضافة، وهى قراءة أبى جعفر.</p><p>3- بالألف والياء، جمعا بين العوض والمعوض، والياء مفتوحة أو ساكنة، ورويت عن أبى جعفر أيضا.</p><p>4- يا حسرتاه، بهاء السكت، فى الوقف، وهى قراءة ابن كثير.</p></div>"
  39,57,""
  39,58,"39:57"
  39,59,"<div class=ar lang=ar><p>جاءتك:</p><p>1- بفتح الكاف وفتح «تاء» ما بعدها، خطابا للكافر ذى النفس، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بكسرها، وكسر «تاء» ما بعدها، والخطاب للنفس، وهى قراءة ابن يعمر، والجحدري، وأبى حيوة، والزعفراني، وابن مقسم، ومسعود بن صالح، والشافعي، عن ابن كثير، ومحمد بن عيسى، فى اختياره، ونصير، والعبسي.</p><p>3- جئتك، بالهمزة من غير مد، بوزن «بعتك» وهى قراءة الحسن، والأعرج، والأعمش.</p></div>"
  39,60,"<div class=ar lang=ar><p>وجوههم:</p><p>وقرئ:</p><p>أجوههم، بدال الواو همزة، وهى قراءة أبى.</p></div>"
  39,61,"<div class=ar lang=ar><p>بمفازتهم:</p><p>1- على الإفراد، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- على الجمع، وهى قراءة السلمى، والحسن، والأعرج، والأعمش، وحمزة، والكسائي، وأبى بكر.</p></div>"
  39,62,""
  39,63,"39:62"
  39,64,"<div class=ar lang=ar><p>تأمرونى:</p><p>1- بإدغام النون فى نون الوقاية وسكون الياء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- على القراءة السابقة، مع فتح الياء، وهى قراءة ابن كثير.</p><p>3- بنونين على الأصل، وهى قراءة ابن عامر.</p><p>4- بنون واحدة مكسورة، وفتح الياء، وهى قراءة نافع.</p><p>أعبد:</p><p>وقرئ:</p><p>بالنصب على إضمار «أن» .</p></div>"
  39,65,"<div class=ar lang=ar><p>ليحبطن:</p><p>1- مبنيا للفاعل، و «عملك» رفع به، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بالياء من «أحبط» ، بالنصب، أي: ليحبطن الله عملك.</p><p>3- بالنون، من: «أحبط» ، أي: لنحبطن عملك، بالنصب.</p></div>"
  39,66,""
  39,67,"<div class=ar lang=ar><p>قدروا:</p><p>وقرئ:</p><p>بتشديد الدال، وهى قراءة الحسن، وعيسى، وأبى نوفل، وأبى حيوة.</p><p>قدره:</p><p>وقرئ:</p><p>بفتح الدال، وهى قراءة الأعمش.</p><p>مطويات:</p><p>وقرئ:</p><p>بالنصب، على الحال، وهى قراءة عيسى، والجحدري.</p></div>"
  39,68,"<div class=ar lang=ar><p>الصور:</p><p>وقرئ:</p><p>بفتح الواو، جمع صورة، وهى قراءة قتادة، وزيد بن على.</p></div>"
  39,69,"<div class=ar lang=ar><p>وأشرقت:</p><p>1- مبينا للفاعل، أي، أضاءت، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- مبينا للمفعول، من: شرقت بالضوء، تشرق، إذا امتلأت، وهى قراءة ابن عباس، وعبيد بن عمير.</p></div>"
  39,70,""
  39,71,"<div class=ar lang=ar><p>يأتكم:</p><p>1- بالياء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- تأتكم، بتاء التأنيث، وهى قراءة ابن هرمز.</p></div>"
  39,72,""
  39,73,"39:72"
  39,74,"39:72"
  39,75,"39:72"
