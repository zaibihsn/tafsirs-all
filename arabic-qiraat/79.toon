quran[46]{c,v,t}:
  79,1,"<div class=ar lang=ar></div>"
  79,2,""
  79,3,""
  79,4,""
  79,5,""
  79,6,""
  79,7,""
  79,8,""
  79,9,""
  79,10,"<div class=ar lang=ar><p>الحافرة:</p><p>1- بالألف، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- الحفرة، بغير ألف، وهى قراءة أبى حيوة، وأبى بحرية، وابن أبى عبلة.</p></div>"
  79,11,"<div class=ar lang=ar><p>نخرة:</p><p>وقرئ:</p><p>1- ناخرة، بألف، وهى قراءة عمر، وأبى، وعبد الله، وابن الزبير، وابن عباس، ومسروق، ومجاهد، والأخوين، وأبى بكر.</p><p>2- بغير ألف، وهى قراءة أبى رجاء، والحسن، والأعرج، وأبى جعفر، وشيبة، والسلمى، وابن جبير، والنخعي، وقتادة، وابن وثاب، وأيوب، وأهل مكة، وشبل، وباقى السبعة.</p></div>"
  79,12,"<div class=ar lang=ar></div>"
  79,13,""
  79,14,""
  79,15,""
  79,16,""
  79,17,""
  79,18,"<div class=ar lang=ar><p>تزكى:</p><p>وقرئ:</p><p>1- بشد الزاى، وهى قراءة الحرميين، وأبى عمرو، بخلاف.</p><p>2- بخفها، وهى قراءة باقى السبعة.</p></div>"
  79,19,"<div class=ar lang=ar></div>"
  79,20,""
  79,21,""
  79,22,""
  79,23,""
  79,24,""
  79,25,""
  79,26,""
  79,27,""
  79,28,""
  79,29,""
  79,30,"<div class=ar lang=ar><p>والأرض:</p><p>1- بالنصب، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- برفعها، وهى قراءة الحسن، وأبى حيوة، وعمرو بن عبيد، وابن أبى عبلة، وأبى السمال.</p></div>"
  79,31,"<div class=ar lang=ar></div>"
  79,32,"<div class=ar lang=ar><p>والجبال:</p><p>1- بالنصب، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- برفعها، وهى قراءة الحسن، وأبى حيوة، وعمرو بن عبيد، وابن أبى عبلة، وأبى السمال.</p></div>"
  79,33,"<div class=ar lang=ar></div>"
  79,34,""
  79,35,""
  79,36,""
  79,37,""
  79,38,""
  79,39,""
  79,40,""
  79,41,""
  79,42,""
  79,43,""
  79,44,""
  79,45,"<div class=ar lang=ar><p>منذر:</p><p>1- بالإضافة، وهى قراءة الجمهور.</p><p>قرئ:</p><p>2- بالتنوين، وهى قراءة عمر بن عبد العزيز، وأبى جعفر، وشيبة، وخالد الحذاء، وابن هرمز، وعيسى، وطلحة، وابن محيصن، وأبى عمرو، فى رواية، وابن مقسم.</p></div>"
  79,46,"<div class=ar lang=ar></div>"
