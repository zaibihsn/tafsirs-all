quran[15]{c,v,t}:
  91,1,"<div class=ar lang=ar></div>"
  91,2,""
  91,3,""
  91,4,""
  91,5,""
  91,6,""
  91,7,""
  91,8,""
  91,9,""
  91,10,""
  91,11,"<div class=ar lang=ar><p>بطغواها:</p><p>1- بفتح الطاء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بضمها، وهى قراءة الحسن، ومحمد بن كعب، وحماد بن سلمة.</p></div>"
  91,12,"<div class=ar lang=ar></div>"
  91,13,""
  91,14,"<div class=ar lang=ar><p>فدمدم:</p><p>1- بميم، بعد دالين، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- فدهدم، بهاء، وهى قراءة ابن الزبير.</p></div>"
  91,15,"<div class=ar lang=ar><p>ولا:</p><p>قرئ:</p><p>1- فلا، بالفاء، وهى قراءة أبى، والأعرج، ونافع، وابن عامر.</p><p>2- ولا، بالواو، وهى قراءة باقى السبعة.</p></div>"
